      "items": [
        {
          "source": "jijie",
          "label": "集解",
          "text": "郑玄曰：「孔子弟子目录云鲁人。」"
        }
      ],
      "sentence_id": null
    },
    {
      "id": "n012",
      "anchor_text": "冄耕字伯牛。",
      "before_context": "冄耕字伯牛。",
      "after_context": "孔子",
      "items": [
        {
          "source": "jijie",
          "label": "集解",
          "text": "郑玄曰鲁人。"
