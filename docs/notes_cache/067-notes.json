      "after_context": "",
      "items": [
        {
          "source": "jijie",
          "label": "集解",
          "text": "郑玄曰：「陈人，贤而有勇。」"
        },
        {
          "source": "suoyin",
          "label": "索隐",
          "text": "家语作「良儒」。陈人，字子正，贤而有勇。孔子周游，常以家车五乘从孔子游。家语在三十五人之中。亦见系家，在三十二人不见，盖传之数亦误也。邹诞本作「公襄儒」。"
        },
        {
          "source": "zhengyi",
          "label": "正义",
          "text": "孔子周游，常以家车五乘从孔子。孔子世家亦云语在三十五人中，今在四十二人数，恐太史公误也。"
        }
      ],
      "sentence_id": null
    },
