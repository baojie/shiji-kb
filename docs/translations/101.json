{
  "chapter": "101",
  "title": "袁盎晁错列传",
  "translations": {
    "1": {
      "title": "袁盎出身",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>是<span class=\"feudal-state\" title=\"邦国\">楚</span>地人，字<span class=\"person\" title=\"人名·规范：袁盎\">丝（袁盎）</span>。"
    },
    "2": {
      "title": "父为群盗",
      "text": "他的父亲从前是群盗，后来迁徙到<span class=\"place\" title=\"地名\">安陵</span>居住。"
    },
    "3": {
      "title": "高后时为吕禄舍人",
      "text": "<span class=\"person\" title=\"人名\">高后</span>时，<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>曾经做过<span class=\"person\" title=\"人名\">吕禄</span>的<span class=\"official\" title=\"官职\">舍人</span>。"
    },
    "4": {
      "title": "孝文帝即位任中郎",
      "text": "等到<span class=\"person\" title=\"人名\">孝文帝</span>即位，<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>的哥哥<span class=\"person\" title=\"人名·规范：袁哙\">哙（袁哙）</span>保举<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>做了<span class=\"official\" title=\"官职\">中郎</span>。"
    },
    "5": {
      "title": "绛侯为丞相得意",
      "text": "<span class=\"person\" title=\"人名\">绛侯</span>做<span class=\"official\" title=\"官职\">丞相</span>，朝见结束快步走出殿堂，神色十分得意。"
    },
    "6": {
      "title": "文帝恭礼绛侯",
      "text": "皇上对他礼敬恭谦，常常亲自目送他离去。"
    },
    "7": {
      "title": "袁盎问文帝",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>进言说： > \"<span class=\"identity\" title=\"身份\">陛下</span>认为<span class=\"official\" title=\"官职\">丞相</span>是什么样的人？\""
    },
    "8": {
      "title": "文帝答为社稷臣",
      "text": "皇上说： > \"是<span class=\"identity\" title=\"身份\">社稷臣</span>。\""
    },
    "9": {
      "title": "袁盎答",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>说："
    },
    "10": {
      "title": "袁盎论社稷臣与功臣之别",
      "text": "> \"<span class=\"person\" title=\"人名\">绛侯</span>是所谓的<span class=\"identity\" title=\"身份\">功臣</span>，不是<span class=\"identity\" title=\"身份\">社稷臣</span>。<span class=\"identity\" title=\"身份\">社稷臣</span>是君主在他就在，君主亡他也亡。当<span class=\"person\" title=\"人名\">吕后</span>在位时，诸<span class=\"dynasty\" title=\"氏族\">吕</span>掌权，擅自相互封王，<span class=\"dynasty\" title=\"氏族\">刘氏</span>的天下<span class=\"idiom\" title=\"成语\">不绝如带</span>（命悬一线）。那时<span class=\"person\" title=\"人名\">绛侯</span>担任<span class=\"official\" title=\"官职\">太尉</span>，掌管兵权，却不能匡正局势。<span class=\"person\" title=\"人名\">吕后</span>去世后，<span class=\"identity\" title=\"身份\">大臣</span>们共同反对诸<span class=\"dynasty\" title=\"氏族\">吕</span>，<span class=\"official\" title=\"官职\">太尉</span>掌管军队，恰好赶上成就了功业，所以只能称为<span class=\"identity\" title=\"身份\">功臣</span>，而不是<span class=\"identity\" title=\"身份\">社稷臣</span>。如今<span class=\"official\" title=\"官职\">丞相</span>有骄傲君主的神色。<span class=\"identity\" title=\"身份\">陛下</span>谦让，<span class=\"identity\" title=\"身份\">臣</span>主双方都失礼，我私下认为<span class=\"identity\" title=\"身份\">陛下</span>不该这样做。\""
    },
    "11": {
      "title": "文帝渐庄丞相益畏",
      "text": "此后朝见时，皇上越发庄重，<span class=\"official\" title=\"官职\">丞相</span>越发畏惧。"
    },
    "12": {
      "title": "绛侯怨袁盎",
      "text": "不久<span class=\"person\" title=\"人名\">绛侯</span>埋怨<span class=\"person\" title=\"人名\">袁盎</span>说： > \"我与你哥哥交好，如今你小子却在朝廷上诋毁我！\""
    },
    "13": {
      "title": "袁盎不谢",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>终究没有去谢罪。"
    },
    "14": {
      "title": "救绛侯",
      "text": "等到<span class=\"person\" title=\"人名\">绛侯</span>被免去<span class=\"official\" title=\"官职\">相</span>职<span class=\"verb-political\" title=\"政治动词\">之国</span>（回到封国）后，<span class=\"identity\" title=\"身份\">国人</span>上书告发他谋反，<span class=\"person\" title=\"人名\">绛侯</span>被征召关押在<span class=\"place\" title=\"地名\">清室</span>，<span class=\"identity\" title=\"身份\">宗室</span>和<span class=\"identity\" title=\"身份\">诸公</span>没有人敢替他说话，只有<span class=\"person\" title=\"人名\">袁盎</span>为<span class=\"person\" title=\"人名\">绛侯</span>辩明无罪。"
    },
    "15": {
      "title": "绛侯得释",
      "text": "<span class=\"person\" title=\"人名\">绛侯</span>得以获释，<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>出了不少力。"
    },
    "16": {
      "title": "结交",
      "text": "<span class=\"person\" title=\"人名\">绛侯</span>于是与<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>深相结交。"
    },
    "17": {
      "title": "淮南王朝杀辟阳侯",
      "text": "<span class=\"person\" title=\"人名\">淮南厉王</span>入朝，<span class=\"verb-penalty\" title=\"刑罚动词\">杀</span>了<span class=\"person\" title=\"人名\">辟阳侯</span>，平日里的举止非常骄横。"
    },
    "18": {
      "title": "袁盎谏削地",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>进谏说： > \"<span class=\"identity\" title=\"身份\">诸侯</span>过于骄横必定会生祸患，应当适当削减他们的封地。\""
    },
    "19": {
      "title": "上不用",
      "text": "皇上没有采纳。<span class=\"person\" title=\"人名\">淮南王</span>更加骄横。"
    },
    "20": {
      "title": "淮南王案发被迁",
      "text": "等到<span class=\"official\" title=\"官职\">棘蒲侯</span><span class=\"person\" title=\"人名\">柴武</span>的<span class=\"identity\" title=\"身份\">太子</span>谋反之事被察觉，审理时牵连到<span class=\"person\" title=\"人名\">淮南王</span>，<span class=\"person\" title=\"人名\">淮南王</span>被征召入京，皇上于是把他流放到<span class=\"feudal-state\" title=\"邦国\">蜀</span>地，用<span class=\"artifact\" title=\"器物\">轞车</span>押送。"
    },
    "21": {
      "title": "袁盎再谏",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>当时任<span class=\"official\" title=\"官职\">中郎将</span>，便进谏说："
    },
    "22": {
      "title": "袁盎谏迁淮南王",
      "text": "> \"<span class=\"identity\" title=\"身份\">陛下</span>向来骄纵<span class=\"person\" title=\"人名\">淮南王</span>，没有稍加管束，才导致了今天的局面，现在又突然严厉挫折他。<span class=\"person\" title=\"人名\">淮南王</span>为人刚烈，假如在路上遇到风霜病死，<span class=\"identity\" title=\"身份\">陛下</span>最终会落得个拥有<span class=\"concept\" title=\"思想\">天下</span>之大却容不下弟弟的名声，背上<span class=\"verb-penalty\" title=\"刑罚动词\">杀</span>弟的罪名，那可怎么办？\""
    },
    "23": {
      "title": "上不听",
      "text": "皇上不听，还是把他流放了。"
    },
    "24": {
      "title": "淮南王病死",
      "text": "<span class=\"person\" title=\"人名\">淮南王</span>到了<span class=\"place\" title=\"地名\">雍</span>地，病死了，消息传来，皇上停食不进，哭得非常悲哀。"
    },
    "25": {
      "title": "袁盎请罪",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>入见，叩头请罪。"
    },
    "26": {
      "title": "文帝悔不用盎言",
      "text": "皇上说： > \"都是因为没有采用你的建议，才到这个地步。\""
    },
    "27": {
      "title": "袁盎劝慰",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>说： > \"请陛下自己宽心，这是过去的事，哪里还能悔改呢！况且<span class=\"identity\" title=\"身份\">陛下</span>有三项超世的德行，这件事不足以损毁您的名声。\""
    },
    "28": {
      "title": "文帝问三高世行",
      "text": "皇上说： > \"我超世的三项德行是哪些事？\""
    },
    "29": {
      "title": "袁盎对",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>说："
    },
    "30": {
      "title": "袁盎论文帝三高世行",
      "text": "> \"<span class=\"identity\" title=\"身份\">陛下</span>居住在<span class=\"feudal-state\" title=\"邦国\">代</span>地时，<span class=\"identity\" title=\"身份\">太后</span>曾经生病，<span class=\"time\" title=\"时间·规范：时长\">三年（时长）</span>间，<span class=\"identity\" title=\"身份\">陛下</span>未曾合眼，没有解衣安睡，汤药不是<span class=\"identity\" title=\"身份\">陛下</span>亲口尝过就不送进。那<span class=\"person\" title=\"人名\">曾参</span>以平民身份尚且难以做到，如今<span class=\"identity\" title=\"身份\">陛下</span>以君王之尊亲自实行，比<span class=\"person\" title=\"人名\">曾参</span>的孝行还要高出许多。当诸<span class=\"dynasty\" title=\"氏族\">吕</span>擅权，<span class=\"identity\" title=\"身份\">大臣</span>专政之时，<span class=\"identity\" title=\"身份\">陛下</span>从<span class=\"feudal-state\" title=\"邦国\">代</span>地乘坐六匹传车奔驰进入难以预测的险境，即使是<span class=\"person\" title=\"人名\">贲育</span>那样的勇士也赶不上<span class=\"identity\" title=\"身份\">陛下</span>。<span class=\"identity\" title=\"身份\">陛下</span>到了<span class=\"place\" title=\"地名\">代邸</span>，面向西推让<span class=\"identity\" title=\"身份\">天子</span>之位两次，面向南推让<span class=\"identity\" title=\"身份\">天子</span>之位三次。那<span class=\"person\" title=\"人名\">许由</span>只推让了一次，而<span class=\"identity\" title=\"身份\">陛下</span>五次推让<span class=\"concept\" title=\"思想\">天下</span>，超过<span class=\"person\" title=\"人名\">许由</span>四倍了。而且<span class=\"identity\" title=\"身份\">陛下</span>流放<span class=\"person\" title=\"人名\">淮南王</span>，是想磨炼他的心志，让他改过，只是<span class=\"official\" title=\"官职\">有司</span>护卫不谨慎，他才病死的。\""
    },
    "31": {
      "title": "上乃解",
      "text": "于是皇上才释然，说： > \"那该怎么办呢？\""
    },
    "32": {
      "title": "袁盎答立三子",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>说： > \"<span class=\"person\" title=\"人名\">淮南王</span>有三个儿子，如何处置只在<span class=\"identity\" title=\"身份\">陛下</span>一念之间。\""
    },
    "33": {
      "title": "立三子为王",
      "text": "于是<span class=\"person\" title=\"人名\">文帝</span>立他的三个儿子都为王。"
    },
    "34": {
      "title": "袁盎名重朝廷",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>因此在朝廷上名望大振。"
    },
    "35": {
      "title": "袁盎慷慨引大体",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>常常引述大义慷慨陈词。"
    },
    "36": {
      "title": "赵同害袁盎",
      "text": "<span class=\"identity\" title=\"身份\">宦者</span><span class=\"person\" title=\"人名\">赵同</span>因为屡次受宠，常常要加害<span class=\"person\" title=\"人名\">袁盎</span>，<span class=\"person\" title=\"人名\">袁盎</span>为此担忧。"
    },
    "37": {
      "title": "袁种献策",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>的侄子<span class=\"person\" title=\"人名·规范：袁种\">种（袁种）</span>做<span class=\"official\" title=\"官职\">常侍骑</span>，持符节陪乘皇帝车驾，劝<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>说： > \"<span class=\"identity\" title=\"身份\">君</span>和他斗，当廷羞辱他，使他的诽谤不被采信。\""
    },
    "38": {
      "title": "伏车讽赵同",
      "text": "<span class=\"person\" title=\"人名\">孝文帝</span>出行，<span class=\"person\" title=\"人名\">赵同</span>陪乘<span class=\"official\" title=\"官职\">参乘</span>，<span class=\"person\" title=\"人名\">袁盎</span>伏在<span class=\"artifact\" title=\"器物\">车</span>前说： > \"<span class=\"identity\" title=\"身份\">臣</span>听说与<span class=\"identity\" title=\"身份\">天子</span>共乘<span class=\"quantity\" title=\"数量\">六尺</span>车驾的，都是<span class=\"concept\" title=\"思想\">天下</span>豪杰英才。如今<span class=\"feudal-state\" title=\"邦国\">汉</span>朝即便缺少人才，<span class=\"identity\" title=\"身份\">陛下</span>怎么偏偏和刀锯之下的余人同乘一车呢！\""
    },
    "39": {
      "title": "赵同泣下车",
      "text": "于是皇上笑了，让<span class=\"person\" title=\"人名\">赵同</span>下车。<span class=\"person\" title=\"人名\">赵同</span>流着泪下了<span class=\"artifact\" title=\"器物\">车</span>。"
    },
    "40": {
      "title": "文帝欲驰峻阪",
      "text": "<span class=\"person\" title=\"人名\">文帝</span>从<span class=\"place\" title=\"地名\">霸陵</span>上登高，想向西驰马奔下陡坡。"
    },
    "41": {
      "title": "袁盎揽辔",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>骑马靠近，在<span class=\"artifact\" title=\"器物\">车</span>旁拉住马缰。"
    },
    "42": {
      "title": "上讥袁盎怯",
      "text": "皇上说： > \"<span class=\"identity\" title=\"身份\">将军</span>怯懦吗？\""
    },
    "43": {
      "title": "袁盎谏",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>说： > \"<span class=\"identity\" title=\"身份\">臣</span>听说<span class=\"quantity\" title=\"数量\">千金</span>之家的子弟不坐在屋檐下，<span class=\"quantity\" title=\"数量\">百金</span>之家的子弟不骑跨门栏，圣明的君主不涉险去侥幸行事。如今<span class=\"identity\" title=\"身份\">陛下</span>驾驭六匹骏马，驰下峻山，假若马惊车<span class=\"verb-military\" title=\"军事动词\">败</span>，<span class=\"identity\" title=\"身份\">陛下</span>纵然可以不顾自己的安危，那又怎么对得起<span class=\"institution\" title=\"名物\">高庙</span>和<span class=\"identity\" title=\"身份\">太后</span>呢？\""
    },
    "44": {
      "title": "上止",
      "text": "皇上于是停下。"
    },
    "45": {
      "title": "幸上林",
      "text": "皇上临幸<span class=\"place\" title=\"地名\">上林</span>苑，<span class=\"identity\" title=\"身份\">皇后</span>和<span class=\"person\" title=\"人名\">慎夫人</span>随行。"
    },
    "46": {
      "title": "同席而坐",
      "text": "她们在宫禁之中，常常同席而坐。"
    },
    "47": {
      "title": "袁盎引却慎夫人座",
      "text": "等到落座时，<span class=\"official\" title=\"官职\">郎署长</span>布设坐席，<span class=\"person\" title=\"人名\">袁盎</span>把<span class=\"person\" title=\"人名\">慎夫人</span>的座位拉向后面。"
    },
    "48": {
      "title": "慎夫人上怒",
      "text": "<span class=\"person\" title=\"人名\">慎夫人</span>生气，不肯就座。皇上也发怒，起身，进入禁中。"
    },
    "49": {
      "title": "袁盎进说",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>于是上前进言说："
    },
    "50": {
      "title": "袁盎论尊卑之序",
      "text": "> \"<span class=\"identity\" title=\"身份\">臣</span>听说尊卑有序，上下才能和睦。如今<span class=\"identity\" title=\"身份\">陛下</span>既已立后，<span class=\"person\" title=\"人名\">慎夫人</span>只是<span class=\"identity\" title=\"身份\">妾</span>，妾与主怎么可以同席而坐呢！这恰恰是丧失了尊卑之序。况且<span class=\"identity\" title=\"身份\">陛下</span>宠爱她，正好可以厚加赏赐。<span class=\"identity\" title=\"身份\">陛下</span>这样为了<span class=\"person\" title=\"人名\">慎夫人</span>，恰恰是害了她。<span class=\"identity\" title=\"身份\">陛下</span>难道没看见'<span class=\"institution\" title=\"名物\">人彘</span>'的故事吗？\""
    },
    "51": {
      "title": "上悦",
      "text": "于是皇上转怒为喜，召来告诉<span class=\"person\" title=\"人名\">慎夫人</span>。"
    },
    "52": {
      "title": "慎夫人赐金",
      "text": "<span class=\"person\" title=\"人名\">慎夫人</span>赏赐<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>黄金<span class=\"quantity\" title=\"数量\">五十斤</span>。"
    },
    "53": {
      "title": "外任陇西都尉",
      "text": "然而<span class=\"person\" title=\"人名\">袁盎</span>也因为屡次直谏，不能长久留在朝中，被调任为<span class=\"official\" title=\"官职\">陇西都尉</span>。"
    },
    "54": {
      "title": "仁爱士卒",
      "text": "他仁爱<span class=\"identity\" title=\"身份\">士卒</span>，<span class=\"identity\" title=\"身份\">士卒</span>都争相为他拼死效命。"
    },
    "55": {
      "title": "迁齐相",
      "text": "升任为<span class=\"official\" title=\"官职\">齐相</span>。"
    },
    "56": {
      "title": "徙吴相袁种献策",
      "text": "又调任<span class=\"official\" title=\"官职\">吴相</span>，辞行时，<span class=\"person\" title=\"人名·规范：袁种\">种（袁种）</span>对<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>说："
    },
    "57": {
      "title": "袁种教盎为吴相之策",
      "text": "> \"<span class=\"person\" title=\"人名\">吴王</span>骄横已久，国中多奸邪之人。如今您如果想纠举惩治，他不上书告发<span class=\"identity\" title=\"身份\">君</span>您，就会用利剑<span class=\"verb-penalty\" title=\"刑罚动词\">刺</span>杀<span class=\"identity\" title=\"身份\">君</span>您。南方地势低湿，<span class=\"identity\" title=\"身份\">君</span>您能够每日饮酒，不干别的，时常劝说<span class=\"person\" title=\"人名\">吴王</span>不要谋反就行了。这样或许可以幸免于难。\""
    },
    "58": {
      "title": "吴王厚遇",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>采用了<span class=\"person\" title=\"人名·规范：袁种\">种（袁种）</span>的计策，<span class=\"person\" title=\"人名\">吴王</span>优厚地对待<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>。"
    },
    "59": {
      "title": "道逢申屠嘉",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>请假回家，途中遇到<span class=\"official\" title=\"官职\">丞相</span><span class=\"person\" title=\"人名\">申屠嘉</span>，下<span class=\"artifact\" title=\"器物\">车</span>拜谒，<span class=\"official\" title=\"官职\">丞相</span>却只从<span class=\"artifact\" title=\"器物\">车</span>上向<span class=\"person\" title=\"人名\">袁盎</span>致谢。"
    },
    "60": {
      "title": "谒丞相",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>回家后，感到对下属有些羞愧，于是到<span class=\"official\" title=\"官职\">丞相</span>府上递上名帖，求见<span class=\"official\" title=\"官职\">丞相</span>。"
    },
    "61": {
      "title": "久而见",
      "text": "<span class=\"official\" title=\"官职\">丞相</span>过了很久才接见他。"
    },
    "62": {
      "title": "袁盎跪请间",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>于是跪下说： > \"请求屏退左右单独交谈。\""
    },
    "63": {
      "title": "丞相拒私语",
      "text": "<span class=\"official\" title=\"官职\">丞相</span>说： > \"如果<span class=\"identity\" title=\"身份\">君</span>所说的是公事，就到官署同<span class=\"official\" title=\"官职\">长史</span>、属吏商议，我会为您上奏；如果是私事，我不接受私下的谈话。\""
    },
    "64": {
      "title": "袁盎跪说",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>就跪着说："
    },
    "65": {
      "title": "袁盎说申屠嘉",
      "text": "> \"<span class=\"identity\" title=\"身份\">君</span>做<span class=\"official\" title=\"官职\">丞相</span>，自己估量一下与<span class=\"person\" title=\"人名\">陈平</span>、<span class=\"person\" title=\"人名\">绛侯</span>相比怎么样？\""
    },
    "66": {
      "title": "丞相答",
      "text": "<span class=\"official\" title=\"官职\">丞相</span>说： > \"我不如他们。\""
    },
    "67": {
      "title": "袁盎论功",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>说： > \"好，<span class=\"identity\" title=\"身份\">君</span>既然自己说不如他们。那<span class=\"person\" title=\"人名\">陈平</span>、<span class=\"person\" title=\"人名\">绛侯</span>辅佐<span class=\"person\" title=\"人名\">高帝</span>，平定<span class=\"concept\" title=\"思想\">天下</span>，担任<span class=\"identity\" title=\"身份\">将相</span>，<span class=\"verb-penalty\" title=\"刑罚动词\">诛</span>灭诸<span class=\"dynasty\" title=\"氏族\">吕</span>，保全了<span class=\"dynasty\" title=\"氏族\">刘氏</span>；而<span class=\"identity\" title=\"身份\">君</span>不过是<span class=\"artifact\" title=\"器物\">材官蹶张</span>（徒步张弩的武士），升为<span class=\"official\" title=\"官职\">队率</span>，累积军功当到<span class=\"official\" title=\"官职\">淮阳守</span>，并没有什么奇谋，也没有<span class=\"verb-military\" title=\"军事动词\">攻</span>城野<span class=\"verb-military\" title=\"军事动词\">战</span>的战功。而且<span class=\"identity\" title=\"身份\">陛下</span>从<span class=\"feudal-state\" title=\"邦国\">代</span>地来后，每次朝见，<span class=\"official\" title=\"官职\">郎官</span>上书陈奏，没有不停下辇车接受他的进言的，言不可用就搁置，言可采纳就接受，没有不称赞的。这是为什么？这是想招揽<span class=\"concept\" title=\"思想\">天下</span>的贤<span class=\"identity\" title=\"身份\">士大夫</span>。皇上每天听到前所未闻的事，明白前所不知的道理，日益圣明；而<span class=\"identity\" title=\"身份\">君</span>如今却自己钳制<span class=\"concept\" title=\"思想\">天下</span>之人的口，日益愚昧。以圣明的君主责问愚昧的相国，<span class=\"identity\" title=\"身份\">君</span>招祸的日子不远了。\""
    },
    "68": {
      "title": "丞相谢",
      "text": "<span class=\"official\" title=\"官职\">丞相</span>于是再拜说： > \"<span class=\"person\" title=\"人名·规范：申屠嘉\">嘉（申屠嘉）</span>是乡野鄙陋之人，竟然不懂得这些，承蒙<span class=\"identity\" title=\"身份\">将军</span>赐教。\""
    },
    "69": {
      "title": "延为上客",
      "text": "就请他进去同坐，奉为<span class=\"identity\" title=\"身份\">上客</span>。"
    },
    "70": {
      "title": "与晁错不睦",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>一向不喜欢<span class=\"person\" title=\"人名\">晁错</span>，<span class=\"person\" title=\"人名\">晁错</span>所在的场合，<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>就离开；<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>在座，<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>也离开：<span class=\"quantity\" title=\"数量\">两人</span>从未在同一屋内交谈过。"
    },
    "71": {
      "title": "景帝即位袁盎抵罪",
      "text": "等到<span class=\"person\" title=\"人名\">孝文帝</span>去世，<span class=\"person\" title=\"人名\">孝景帝</span>即位，<span class=\"person\" title=\"人名\">晁错</span>任<span class=\"official\" title=\"官职\">御史大夫</span>，派官吏查办<span class=\"person\" title=\"人名\">袁盎</span>接受<span class=\"person\" title=\"人名\">吴王</span>财物之事，应当抵罪，皇帝下诏<span class=\"verb-political\" title=\"政治动词\">赦</span>免他，降为<span class=\"identity\" title=\"身份\">庶人</span>。"
    },
    "72": {
      "title": "吴楚反晁错欲治盎",
      "text": "<span class=\"feudal-state\" title=\"邦国\">吴</span>、<span class=\"feudal-state\" title=\"邦国\">楚</span>造反，消息传来，<span class=\"person\" title=\"人名\">晁错</span>对<span class=\"official\" title=\"官职\">丞史</span>说： > \"<span class=\"person\" title=\"人名\">袁盎</span>多次收受<span class=\"person\" title=\"人名\">吴王</span>的<span class=\"artifact\" title=\"器物\">金钱</span>，专替他掩饰，说他不会反。如今果然反了，我想请求追究<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>，他应当知道其中的谋划。\""
    },
    "73": {
      "title": "丞史不同意",
      "text": "<span class=\"official\" title=\"官职\">丞史</span>说： > \"事情未发生前，追究他或许有用。如今叛军西进，追究他有什么用！况且<span class=\"person\" title=\"人名\">袁盎</span>不该会参与阴谋。\""
    },
    "74": {
      "title": "晁错犹豫",
      "text": "<span class=\"person\" title=\"人名\">晁错</span>犹豫未决。"
    },
    "75": {
      "title": "人告袁盎",
      "text": "有人把此事告诉了<span class=\"person\" title=\"人名\">袁盎</span>，<span class=\"person\" title=\"人名\">袁盎</span>害怕，连夜去见<span class=\"person\" title=\"人名\">窦婴</span>，向他陈述<span class=\"feudal-state\" title=\"邦国\">吴</span>造反的缘由，请求到皇上面前当面陈述。"
    },
    "76": {
      "title": "窦婴言上",
      "text": "<span class=\"person\" title=\"人名\">窦婴</span>入宫禀告皇上，皇上就召<span class=\"person\" title=\"人名\">袁盎</span>入见。"
    },
    "77": {
      "title": "晁错在前",
      "text": "<span class=\"person\" title=\"人名\">晁错</span>正在皇上面前，当<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>请求屏退旁人单独奏对时，<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>退了下去，心中很是怨恨。"
    },
    "78": {
      "title": "袁盎请诛晁错",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>详细陈述<span class=\"feudal-state\" title=\"邦国\">吴</span>造反的情状，说都是因为<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>的缘故，唯有赶紧<span class=\"verb-penalty\" title=\"刑罚动词\">斩</span>了<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>以向<span class=\"feudal-state\" title=\"邦国\">吴</span>谢罪，<span class=\"feudal-state\" title=\"邦国\">吴</span>的兵才可罢息。"
    },
    "79": {
      "title": "语在吴事中",
      "text": "这番话的详情记在<span class=\"feudal-state\" title=\"邦国\">吴</span>的事迹中。"
    },
    "80": {
      "title": "任太常大将军",
      "text": "于是派<span class=\"person\" title=\"人名\">袁盎</span>任<span class=\"official\" title=\"官职\">太常</span>，<span class=\"person\" title=\"人名\">窦婴</span>任<span class=\"official\" title=\"官职\">大将军</span>。"
    },
    "81": {
      "title": "两人素善",
      "text": "<span class=\"quantity\" title=\"数量\">两人</span>一向交好。等到<span class=\"feudal-state\" title=\"邦国\">吴</span>反叛，各陵县的<span class=\"identity\" title=\"身份\">长者</span>和<span class=\"place\" title=\"地名\">长安</span>城中的<span class=\"identity\" title=\"身份\">贤大夫</span>争相依附<span class=\"quantity\" title=\"数量\">两人</span>，随从的<span class=\"artifact\" title=\"器物\">车</span>每天有<span class=\"quantity\" title=\"数量\">数百乘</span>。"
    },
    "82": {
      "title": "袁盎使吴",
      "text": "等到<span class=\"person\" title=\"人名\">晁错</span>已被<span class=\"verb-penalty\" title=\"刑罚动词\">诛</span>杀，<span class=\"person\" title=\"人名\">袁盎</span>以<span class=\"official\" title=\"官职\">太常</span>身份出使<span class=\"feudal-state\" title=\"邦国\">吴</span>。"
    },
    "83": {
      "title": "吴王欲杀之",
      "text": "<span class=\"person\" title=\"人名\">吴王</span>想让他做将军，他不肯。<span class=\"person\" title=\"人名\">吴王</span>想<span class=\"verb-penalty\" title=\"刑罚动词\">杀</span>他，派一个<span class=\"official\" title=\"官职\">都尉</span>带<span class=\"quantity\" title=\"数量\">五百人</span>把<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span><span class=\"verb-military\" title=\"军事动词\">围</span>困在军中。"
    },
    "84": {
      "title": "昔日从史事",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>从前做<span class=\"official\" title=\"官职\">吴相</span>时，有个从史曾经私下爱上<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>身边的侍女，<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>知道，没有声张，对他照旧如故。"
    },
    "85": {
      "title": "从史逃归",
      "text": "有人告诉那个从史说\"<span class=\"identity\" title=\"身份\">君</span>知道你和侍女私通了\"，他于是逃走。"
    },
    "86": {
      "title": "袁盎追赐复为从史",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>亲自驱马追赶他，便把侍女赐给他，让他恢复从史之职。"
    },
    "87": {
      "title": "使吴被守",
      "text": "等到<span class=\"person\" title=\"人名\">袁盎</span>出使<span class=\"feudal-state\" title=\"邦国\">吴</span>被围守时，那个从史恰好做了看守<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>的<span class=\"official\" title=\"官职\">校尉</span><span class=\"official\" title=\"官职\">司马</span>，他就把自己的全部行装赍财买来两石醇酒，当时天冷，<span class=\"identity\" title=\"身份\">士卒</span>饥渴，喝酒喝醉了，西南角的卒兵都倒地睡下，这位<span class=\"official\" title=\"官职\">司马</span>夜里把<span class=\"person\" title=\"人名\">袁盎</span>叫起来，说： > \"<span class=\"identity\" title=\"身份\">君</span>可以走了，<span class=\"person\" title=\"人名\">吴王</span>约定明日早上要<span class=\"verb-penalty\" title=\"刑罚动词\">斩</span><span class=\"identity\" title=\"身份\">君</span>。\""
    },
    "88": {
      "title": "盎弗信",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>不信，说： > \"您是什么人？\""
    },
    "89": {
      "title": "司马答",
      "text": "<span class=\"official\" title=\"官职\">司马</span>说： > \"<span class=\"identity\" title=\"身份\">臣</span>就是当年偷<span class=\"identity\" title=\"身份\">君</span>侍女的那个从史。\""
    },
    "90": {
      "title": "袁盎惊谢",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>于是吃惊地辞谢说： > \"您幸亏还有亲人，我不能连累您。\""
    },
    "91": {
      "title": "司马劝其去",
      "text": "<span class=\"official\" title=\"官职\">司马</span>说： > \"<span class=\"identity\" title=\"身份\">君</span>只管走，<span class=\"identity\" title=\"身份\">臣</span>也将逃亡，躲藏好我的亲人，<span class=\"identity\" title=\"身份\">君</span>何必忧虑！\""
    },
    "92": {
      "title": "决张出隧",
      "text": "于是用<span class=\"artifact\" title=\"器物\">刀</span>割破帐幕，带着<span class=\"person\" title=\"人名\">袁盎</span>从醉卒之间的通道出去。"
    },
    "93": {
      "title": "遇梁骑得归",
      "text": "<span class=\"official\" title=\"官职\">司马</span>和<span class=\"person\" title=\"人名\">袁盎</span>分道而行，<span class=\"person\" title=\"人名\">袁盎</span>解下<span class=\"artifact\" title=\"器物\">节毛</span>揣入怀中，拄着<span class=\"artifact\" title=\"器物\">杖</span>，步行了七八里，天亮时，看见<span class=\"feudal-state\" title=\"邦国\">梁</span>国的骑兵，骑马奔驰而去，终于回朝复命。"
    },
    "94": {
      "title": "楚相",
      "text": "<span class=\"feudal-state\" title=\"邦国\">吴</span>、<span class=\"feudal-state\" title=\"邦国\">楚</span>已被攻<span class=\"verb-military\" title=\"军事动词\">破</span>，皇上改立<span class=\"person\" title=\"人名·规范：楚元王\">元王（楚元王）</span>的儿子<span class=\"official\" title=\"官职\">平陆侯</span><span class=\"person\" title=\"人名·规范：刘礼\">礼（刘礼）</span>为<span class=\"official\" title=\"官职\">楚王</span>，派<span class=\"person\" title=\"人名\">袁盎</span>任<span class=\"official\" title=\"官职\">楚相</span>。"
    },
    "95": {
      "title": "上书不用",
      "text": "他曾上书陈事，未被采纳。"
    },
    "96": {
      "title": "病免居家",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>因病免职居家，与乡里相处，随众出入，斗鸡走狗。"
    },
    "97": {
      "title": "剧孟过袁盎",
      "text": "<span class=\"place\" title=\"地名\">洛阳</span>的<span class=\"person\" title=\"人名\">剧孟</span>曾经拜访<span class=\"person\" title=\"人名\">袁盎</span>，<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>好好款待他。"
    },
    "98": {
      "title": "安陵富人问",
      "text": "<span class=\"place\" title=\"地名\">安陵</span>有个富人对<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>说： > \"我听说<span class=\"person\" title=\"人名\">剧孟</span>是赌徒，<span class=\"identity\" title=\"身份\">将军</span>为什么要与他交往？\""
    },
    "99": {
      "title": "袁盎答",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>说："
    },
    "100": {
      "title": "袁盎论剧孟",
      "text": "> \"<span class=\"person\" title=\"人名\">剧孟</span>虽是赌徒，但他母亲去世时，送葬的宾客车辆有<span class=\"quantity\" title=\"数量\">千馀乘</span>，这也算有过人之处了。而且紧急关头是人人都可能遇到的。有一天急难时来敲门求救，不以亲人为推辞的理由，不以存亡作为推脱的借口，<span class=\"concept\" title=\"思想\">天下</span>所仰仗的，只有<span class=\"person\" title=\"人名\">季心</span>、<span class=\"person\" title=\"人名\">剧孟</span>罢了。如今您常带着几个骑从，一旦遇到紧急情况，哪里够用呢！\""
    },
    "101": {
      "title": "骂富人",
      "text": "骂了那个富人，不再与他来往。"
    },
    "102": {
      "title": "诸公多袁盎",
      "text": "<span class=\"identity\" title=\"身份\">诸公</span>听说后，都称许<span class=\"person\" title=\"人名\">袁盎</span>。"
    },
    "103": {
      "title": "景帝时问筹策",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>虽然家居，<span class=\"person\" title=\"人名\">景帝</span>还时常派人向他咨询谋略。"
    },
    "104": {
      "title": "进说阻梁王嗣",
      "text": "<span class=\"person\" title=\"人名\">梁王</span>想谋求做皇位继承人，<span class=\"person\" title=\"人名\">袁盎</span>进言劝阻，此后此议便不再提起。"
    },
    "105": {
      "title": "梁王遣刺客",
      "text": "<span class=\"person\" title=\"人名\">梁王</span>因此怨恨<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>，曾派人<span class=\"verb-penalty\" title=\"刑罚动词\">刺</span>杀<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>。"
    },
    "106": {
      "title": "刺者至关中",
      "text": "<span class=\"verb-penalty\" title=\"刑罚动词\">刺</span>客到了<span class=\"place\" title=\"地名\">关中</span>，打听<span class=\"person\" title=\"人名\">袁盎</span>的为人，<span class=\"identity\" title=\"身份\">诸君</span>称赞<span class=\"person\" title=\"人名\">袁盎</span>之语都说不完。"
    },
    "107": {
      "title": "刺客见告",
      "text": "<span class=\"verb-penalty\" title=\"刑罚动词\">刺</span>客就见<span class=\"person\" title=\"人名\">袁盎</span>说： > \"<span class=\"identity\" title=\"身份\">臣</span>接受<span class=\"person\" title=\"人名\">梁王</span>的金钱来<span class=\"verb-penalty\" title=\"刑罚动词\">刺</span>杀<span class=\"identity\" title=\"身份\">君</span>，<span class=\"identity\" title=\"身份\">君</span>是长者，不忍<span class=\"verb-penalty\" title=\"刑罚动词\">刺</span><span class=\"identity\" title=\"身份\">君</span>。但后来<span class=\"verb-penalty\" title=\"刑罚动词\">刺</span><span class=\"identity\" title=\"身份\">君</span>的还有<span class=\"quantity\" title=\"数量\">十馀</span>批，请防备！\""
    },
    "108": {
      "title": "心不乐问占",
      "text": "<span class=\"person\" title=\"人名\">袁盎</span>心中不乐，家中又接连出现怪异之事，就去<span class=\"person\" title=\"人名\">棓生</span>那里问卜。"
    },
    "109": {
      "title": "被刺身死",
      "text": "回来时，<span class=\"feudal-state\" title=\"邦国\">梁</span>国派来的后批<span class=\"verb-penalty\" title=\"刑罚动词\">刺</span>客果然在<span class=\"place\" title=\"地名\">安陵郭门</span>外拦截<span class=\"verb-penalty\" title=\"刑罚动词\">刺</span><span class=\"verb-penalty\" title=\"刑罚动词\">杀</span>了<span class=\"person\" title=\"人名·规范：袁盎\">盎（袁盎）</span>。"
    },
    "110": {
      "title": "晁错出身",
      "text": "<span class=\"person\" title=\"人名\">晁错</span>是<span class=\"place\" title=\"地名\">颍川</span>人。"
    },
    "111": {
      "title": "学于张恢",
      "text": "他跟随<span class=\"place\" title=\"地名\">轵</span>县<span class=\"person\" title=\"人名\">张恢</span>先生学习<span class=\"institution\" title=\"名物\">申商刑名</span>之学，与<span class=\"place\" title=\"地名\">洛阳</span>的<span class=\"person\" title=\"人名\">宋孟</span>及<span class=\"person\" title=\"人名\">刘礼</span>同师。"
    },
    "112": {
      "title": "以文学为太常掌故",
      "text": "凭借<span class=\"official\" title=\"官职\">文学</span>出任<span class=\"official\" title=\"官职\">太常掌故</span>。"
    },
    "113": {
      "title": "为人刻深",
      "text": "<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>为人严厉刚直，刻薄深刻。"
    },
    "114": {
      "title": "孝文时求治尚书者",
      "text": "<span class=\"person\" title=\"人名\">孝文帝</span>时，<span class=\"concept\" title=\"思想\">天下</span>没有研究<span class=\"institution\" title=\"名物\">尚书</span>的人，只听说<span class=\"place\" title=\"地名\">济南</span>的<span class=\"person\" title=\"人名\">伏生</span>是从前的<span class=\"feudal-state\" title=\"邦国\">秦</span>朝<span class=\"official\" title=\"官职\">博士</span>，研究<span class=\"institution\" title=\"名物\">尚书</span>，年龄<span class=\"time\" title=\"时间·规范：年龄\">九十馀（年龄）</span>岁，年老不能征召，于是下诏让<span class=\"official\" title=\"官职\">太常</span>派人去向他学习。"
    },
    "115": {
      "title": "太常遣错受尚书",
      "text": "<span class=\"official\" title=\"官职\">太常</span>派<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>到<span class=\"person\" title=\"人名\">伏生</span>那里学习<span class=\"institution\" title=\"名物\">尚书</span>。"
    },
    "116": {
      "title": "还而言便宜",
      "text": "回来后，趁机上书陈述便利国事之事，用<span class=\"institution\" title=\"名物\">尚书</span>来称引论说。"
    },
    "117": {
      "title": "任太子舍人等",
      "text": "皇上下诏任命他为<span class=\"official\" title=\"官职\">太子舍人</span>、<span class=\"official\" title=\"官职\">门大夫</span>、<span class=\"official\" title=\"官职\">家令</span>。"
    },
    "118": {
      "title": "太子号为智囊",
      "text": "因为他善于辩论而得到<span class=\"identity\" title=\"身份\">太子</span>的宠幸，<span class=\"identity\" title=\"身份\">太子</span>家里给他起了个外号叫\"智囊\"。"
    },
    "119": {
      "title": "屡言削藩",
      "text": "他在<span class=\"person\" title=\"人名·规范：孝文帝\">孝文（孝文帝）</span>时屡次上书，议论削夺<span class=\"identity\" title=\"身份\">诸侯</span>之事，以及<span class=\"institution\" title=\"名物\">法令</span>中可以修改确定的地方。"
    },
    "120": {
      "title": "迁中大夫",
      "text": "上书<span class=\"quantity\" title=\"数量\">数十</span>次，<span class=\"person\" title=\"人名·规范：孝文帝\">孝文（孝文帝）</span>没有采纳，但很看重他的才能，提升他为<span class=\"official\" title=\"官职\">中大夫</span>。"
    },
    "121": {
      "title": "太子善错策",
      "text": "当那时，<span class=\"identity\" title=\"身份\">太子</span>赞赏<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>的计策，<span class=\"person\" title=\"人名\">袁盎</span>等诸位<span class=\"identity\" title=\"身份\">大功臣</span>大多不喜欢<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>。"
    },
    "122": {
      "title": "景帝立为内史",
      "text": "<span class=\"person\" title=\"人名\">景帝</span>即位，任命<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>为<span class=\"official\" title=\"官职\">内史</span>。"
    },
    "123": {
      "title": "宠幸倾九卿",
      "text": "<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>常屡次请求单独奏事，皇帝都听从，宠幸胜过了<span class=\"official\" title=\"官职\">九卿</span>，<span class=\"institution\" title=\"名物\">法令</span>多有变更修订。"
    },
    "124": {
      "title": "丞相心不便",
      "text": "<span class=\"official\" title=\"官职\">丞相</span><span class=\"person\" title=\"人名\">申屠嘉</span>心中不快，但没办法伤害他。"
    },
    "125": {
      "title": "凿庙壖垣",
      "text": "<span class=\"official\" title=\"官职\">内史</span>府位于<span class=\"institution\" title=\"名物\">太上庙</span>外垣之中，大门朝东，出入不方便，<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>就凿开两座朝南的门，凿开了<span class=\"institution\" title=\"名物\">庙</span>的外墙。"
    },
    "126": {
      "title": "丞相大怒",
      "text": "<span class=\"official\" title=\"官职\">丞相</span><span class=\"person\" title=\"人名·规范：申屠嘉\">嘉（申屠嘉）</span>听说此事，大怒，想借此过失上奏请<span class=\"verb-penalty\" title=\"刑罚动词\">诛</span><span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>。"
    },
    "127": {
      "title": "错夜请间",
      "text": "<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>听说后，立即连夜请求单独奏对，把事情原委一一禀告皇上。"
    },
    "128": {
      "title": "丞相奏请诛",
      "text": "<span class=\"official\" title=\"官职\">丞相</span>上朝奏事，顺便说到<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>擅自凿开<span class=\"institution\" title=\"名物\">庙垣</span>做门，请求交付<span class=\"official\" title=\"官职\">廷尉</span><span class=\"verb-penalty\" title=\"刑罚动词\">诛</span>办。"
    },
    "129": {
      "title": "上辩非庙垣",
      "text": "皇上说： > \"这不是<span class=\"institution\" title=\"名物\">庙垣</span>，只是外墙以内的围墙，不能按法论处。\""
    },
    "130": {
      "title": "丞相谢",
      "text": "<span class=\"official\" title=\"官职\">丞相</span>谢罪。"
    },
    "131": {
      "title": "丞相怒言",
      "text": "退朝后，<span class=\"official\" title=\"官职\">丞相</span>愤怒地对<span class=\"official\" title=\"官职\">长史</span>说： > \"我应当先<span class=\"verb-penalty\" title=\"刑罚动词\">斩</span>了再上报，竟然先奏请，被这小子给卖了，是我的错。\""
    },
    "132": {
      "title": "丞相发病死",
      "text": "<span class=\"official\" title=\"官职\">丞相</span>于是发病死去。"
    },
    "133": {
      "title": "错愈贵",
      "text": "<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>因此更加显贵。"
    },
    "134": {
      "title": "迁御史大夫削诸侯",
      "text": "升任<span class=\"official\" title=\"官职\">御史大夫</span>，奏请<span class=\"identity\" title=\"身份\">诸侯</span>们的罪过，削夺其封地，收回他们的支属郡县。"
    },
    "135": {
      "title": "奏上集议",
      "text": "奏章呈上，皇上命<span class=\"identity\" title=\"身份\">公卿</span>、<span class=\"identity\" title=\"身份\">列侯</span>、<span class=\"identity\" title=\"身份\">宗室</span>集会商议，没人敢责难，只有<span class=\"person\" title=\"人名\">窦婴</span>与他争辩，从此与<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>有了嫌隙。"
    },
    "136": {
      "title": "诸侯疾错",
      "text": "<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>所变更的法令有<span class=\"quantity\" title=\"数量\">三十章</span>，<span class=\"identity\" title=\"身份\">诸侯</span>都喧哗怨恨<span class=\"person\" title=\"人名\">晁错</span>。"
    },
    "137": {
      "title": "错父来问",
      "text": "<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>的父亲听说后，从<span class=\"place\" title=\"地名\">颍川</span>赶来，对<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>说： > \"皇上刚即位，您就执掌政权，侵削<span class=\"identity\" title=\"身份\">诸侯</span>，疏远人家的骨肉至亲，许多人议论都怨恨您，这是为何呢？\""
    },
    "138": {
      "title": "晁错答",
      "text": "<span class=\"person\" title=\"人名\">晁错</span>说： > \"本该如此。不这样做，<span class=\"identity\" title=\"身份\">天子</span>就不尊贵，<span class=\"institution\" title=\"名物\">宗庙</span>就不安稳。\""
    },
    "139": {
      "title": "错父曰",
      "text": "<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>的父亲说："
    },
    "140": {
      "title": "晁错父之言",
      "text": "> \"<span class=\"dynasty\" title=\"氏族\">刘氏</span>是安稳了，而<span class=\"dynasty\" title=\"氏族\">晁氏</span>却危险了，我要离开您回去了！\""
    },
    "141": {
      "title": "饮药死",
      "text": "于是饮药自尽，说： > \"我不忍心看见祸患殃及我自身。\""
    },
    "142": {
      "title": "七国反",
      "text": "死后<span class=\"time\" title=\"时间·规范：时长\">十多天（时长）</span>，<span class=\"feudal-state\" title=\"邦国\">吴</span>、<span class=\"feudal-state\" title=\"邦国\">楚</span>、<span class=\"feudal-state\" title=\"邦国\">七国</span>果然反叛，以<span class=\"verb-penalty\" title=\"刑罚动词\">诛</span><span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>为名。"
    },
    "143": {
      "title": "错被斩东市",
      "text": "等到<span class=\"person\" title=\"人名\">窦婴</span>、<span class=\"person\" title=\"人名\">袁盎</span>进言，皇上命<span class=\"person\" title=\"人名\">晁错</span>穿着<span class=\"artifact\" title=\"器物\">朝衣</span><span class=\"verb-penalty\" title=\"刑罚动词\">斩</span>于<span class=\"place\" title=\"地名\">东市</span>。"
    },
    "144": {
      "title": "邓公上书",
      "text": "<span class=\"person\" title=\"人名\">晁错</span>死后，<span class=\"official\" title=\"官职\">谒者仆射</span><span class=\"person\" title=\"人名\">邓公</span>任<span class=\"official\" title=\"官职\">校尉</span>，作为将领<span class=\"verb-military\" title=\"军事动词\">击</span>讨<span class=\"feudal-state\" title=\"邦国\">吴</span>、<span class=\"feudal-state\" title=\"邦国\">楚</span>军队。"
    },
    "145": {
      "title": "谒见上",
      "text": "回朝后，上书陈述军事，谒见皇上。"
    },
    "146": {
      "title": "上问",
      "text": "皇上问道： > \"你从军中来，听说<span class=\"person\" title=\"人名\">晁错</span>已死，<span class=\"feudal-state\" title=\"邦国\">吴</span>、<span class=\"feudal-state\" title=\"邦国\">楚</span>罢兵了吗？\""
    },
    "147": {
      "title": "邓公对",
      "text": "<span class=\"person\" title=\"人名\">邓公</span>说： > \"<span class=\"person\" title=\"人名\">吴王</span>谋反已有<span class=\"time\" title=\"时间·规范：时长\">数十年（时长）</span>了，因削地发怒，以<span class=\"verb-penalty\" title=\"刑罚动词\">诛</span><span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>为名，他的本意并不在<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>。而且<span class=\"identity\" title=\"身份\">臣</span>恐怕<span class=\"concept\" title=\"思想\">天下</span>之<span class=\"identity\" title=\"身份\">士</span>从此缄口，不敢再进言了！\""
    },
    "148": {
      "title": "上问何哉",
      "text": "皇上说： > \"为什么呢？\""
    },
    "149": {
      "title": "邓公再对",
      "text": "<span class=\"person\" title=\"人名\">邓公</span>说："
    },
    "150": {
      "title": "邓公论晁错之死",
      "text": "> \"那<span class=\"person\" title=\"人名\">晁错</span>忧虑<span class=\"identity\" title=\"身份\">诸侯</span>势力强大难以控制，所以奏请削地来尊奉<span class=\"place\" title=\"地名\">京师</span>，这是万世之利。计划刚刚推行，就突然遭受大<span class=\"verb-penalty\" title=\"刑罚动词\">戮</span>，对内堵塞了<span class=\"identity\" title=\"身份\">忠臣</span>之口，对外为<span class=\"identity\" title=\"身份\">诸侯</span>报了仇，<span class=\"identity\" title=\"身份\">臣</span>私下认为<span class=\"identity\" title=\"身份\">陛下</span>不该这样做。\""
    },
    "151": {
      "title": "景帝默然",
      "text": "于是<span class=\"person\" title=\"人名\">景帝</span>沉默良久，说： > \"您说得对，我也后悔了。\""
    },
    "152": {
      "title": "拜邓公为城阳中尉",
      "text": "就<span class=\"verb-political\" title=\"政治动词\">拜</span><span class=\"person\" title=\"人名\">邓公</span>为<span class=\"official\" title=\"官职\">城阳中尉</span>。"
    },
    "153": {
      "title": "邓公事略",
      "text": "<span class=\"person\" title=\"人名\">邓公</span>是<span class=\"place\" title=\"地名\">成固</span>人，多有奇谋。"
    },
    "154": {
      "title": "建元起家九卿",
      "text": "<span class=\"time\" title=\"时间·规范：年号\">建元（年号）</span>年间，皇上招求<span class=\"institution\" title=\"名物\">贤良</span>之士，<span class=\"identity\" title=\"身份\">公卿</span>举荐<span class=\"person\" title=\"人名\">邓公</span>，当时<span class=\"person\" title=\"人名\">邓公</span>已免官，起家再任<span class=\"official\" title=\"官职\">九卿</span>。"
    },
    "155": {
      "title": "一年谢病",
      "text": "<span class=\"time\" title=\"时间·规范：时长\">一年（时长）</span>后，又称病辞官归家。"
    },
    "156": {
      "title": "子邓章",
      "text": "他的<span class=\"identity\" title=\"身份\">儿子</span><span class=\"person\" title=\"人名·规范：邓章\">章（邓章）</span>凭借研究<span class=\"institution\" title=\"名物\">黄老言</span>而在<span class=\"identity\" title=\"身份\">诸公</span>中显名。"
    },
    "157": {
      "title": "太史公曰",
      "text": "<span class=\"person\" title=\"人名\">太史公</span>说：<span class=\"person\" title=\"人名\">袁盎</span>虽然不好学，但也善于附会旁证，以仁心为本，援引大义慷慨陈词。他恰逢<span class=\"person\" title=\"人名·规范：孝文帝\">孝文（孝文帝）</span>初立，资质适应时世。时势变迁，及至<span class=\"feudal-state\" title=\"邦国\">吴</span>、<span class=\"feudal-state\" title=\"邦国\">楚</span>造反时那一番进言，言论虽被采纳，但最终也没有成功。喜好名声自负贤能，终因名声而身<span class=\"verb-military\" title=\"军事动词\">败</span>。<span class=\"person\" title=\"人名\">晁错</span>做<span class=\"official\" title=\"官职\">家令</span>时，屡次进言不被采用；后来擅权，多所变更。<span class=\"identity\" title=\"身份\">诸侯</span>发难，不赶紧匡救时局，反而想报私仇，结果自己丢了性命。俗语说\"变更古法扰乱常规，不死则亡\"，难道说的就是<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>这类人吗！"
    },
    "158": {
      "title": "赞",
      "text": "<span class=\"person\" title=\"人名·规范：袁盎\">袁丝（袁盎）</span>公正耿直，也多附会之词。 揽缰谏驰为帝所重，拉却坐席得慎夫人仰赖。 <span class=\"person\" title=\"人名\">晁错</span>建议削藩之策，屡陈利害。 尊主抑<span class=\"identity\" title=\"身份\">臣</span>，家族危险而国家安泰。 可悲啊这两位<span class=\"identity\" title=\"身份\">子</span>，功名既立而身<span class=\"verb-military\" title=\"军事动词\">败</span>亡！"
    }
  }
}