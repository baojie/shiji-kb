{
  "chapter": "023",
  "title": "礼书",
  "translations": {
    "1": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "1.1": {
      "title": "太史公赞礼德",
      "text": "<span class=\"person\" title=\"人名\">太史公</span>说：盛大美好啊<span class=\"concept\" title=\"思想\">德</span>！它宰制万物，役使<span class=\"identity\" title=\"身份\">群众</span>，这岂是人力所能做到的呢？"
    },
    "1.2": {
      "title": "礼仪源于人情",
      "text": "我到<span class=\"official\" title=\"官职\">大行礼官</span>那里，观察<span class=\"institution\" title=\"名物\">三代</span>礼仪的增减变化，才明白<span class=\"institution\" title=\"名物\">礼</span>是根据人情而制定的，<span class=\"institution\" title=\"名物\">仪</span>是根据人性而设立的，它们的由来已经很久远了。"
    },
    "2": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "2.1": {
      "title": "礼制统一万民",
      "text": "<span class=\"concept\" title=\"思想\">人道</span>错综复杂，千头万绪，<span class=\"artifact\" title=\"器物\">规矩</span>无所不贯通，用<span class=\"concept\" title=\"思想\">仁义</span>来引导他们前进，用<span class=\"institution\" title=\"名物\">刑罚</span>来约束他们，所以<span class=\"concept\" title=\"思想\">德</span>厚的人地位尊贵，俸禄丰厚的人受到宠荣，这是用来统一天下、整齐<span class=\"identity\" title=\"身份\">万民</span>的。"
    },
    "2.2": {
      "title": "礼以养五官",
      "text": "人的身体习惯乘坐车驾，就为他制作<span class=\"artifact\" title=\"器物\">金舆</span><span class=\"artifact\" title=\"器物\">错衡</span>来繁饰它；眼睛喜好五色，就为他制作<span class=\"artifact\" title=\"器物\">黼黻文章</span>来表现它；耳朵喜欢<span class=\"artifact\" title=\"器物\">钟磬</span>之声，就为他调谐<span class=\"artifact\" title=\"器物\">八音</span>来荡涤他的心灵；口舌贪爱五味，就为他调制各种酸咸美味来成就它；情感喜好珍奇，就为他雕琢<span class=\"artifact\" title=\"器物\">圭璧</span>来通达他的心意。"
    },
    "2.3": {
      "title": "礼防淫侈",
      "text": "所以<span class=\"artifact\" title=\"器物\">大路</span>用<span class=\"artifact\" title=\"器物\">越席</span>，戴<span class=\"artifact\" title=\"器物\">皮弁</span>穿<span class=\"artifact\" title=\"器物\">布裳</span>，奏<span class=\"artifact\" title=\"器物\">硃弦</span>通<span class=\"artifact\" title=\"器物\">洞越</span>，献<span class=\"artifact\" title=\"器物\">大羹</span>陈<span class=\"artifact\" title=\"器物\">玄酒</span>，这是用来防止奢侈，挽救颓败的。"
    },
    "2.4": {
      "title": "尊卑有序",
      "text": "因此君臣朝廷尊卑贵贱的等级秩序，下及<span class=\"identity\" title=\"身份\">黎庶</span>的<span class=\"artifact\" title=\"器物\">车舆</span><span class=\"artifact\" title=\"器物\">衣服</span><span class=\"institution\" title=\"名物\">宫室</span>、饮食嫁娶丧祭的区分，事情各有所宜，物品各有节度文饰。"
    },
    "2.5": {
      "title": "仲尼观禘",
      "text": "<span class=\"person\" title=\"人名\">仲尼</span>说： > \"<span class=\"institution\" title=\"名物\">禘</span>祭从灌酒之后开始，我就不想再看了。\""
    },
    "3": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "3.1": {
      "title": "管仲僭越",
      "text": "<span class=\"feudal-state\" title=\"邦国\">周</span>朝衰落，<span class=\"institution\" title=\"名物\">礼</span>被废弃，乐遭破坏，大小等级互相逾越，<span class=\"person\" title=\"人名\">管仲</span>家中竟然兼备<span class=\"institution\" title=\"名物\">三归</span>之台。"
    },
    "3.2": {
      "title": "守正者反被侮",
      "text": "遵循<span class=\"institution\" title=\"名物\">法</span>度坚守正道的人在世上遭受侮辱，奢侈逾越本分的人反被称为显贵荣耀。"
    },
    "3.3": {
      "title": "子夏心战",
      "text": "自从<span class=\"person\" title=\"人名\">子夏</span>这样的<span class=\"person\" title=\"人名\">夫子</span>门下高徒，尚且说： > \"出门看见繁华盛丽就喜欢，入门听闻<span class=\"person\" title=\"人名\">夫子</span>的<span class=\"concept\" title=\"思想\">道</span>就快乐，两者在心中交战，自己无法决断\"，"
    },
    "3.4": {
      "title": "中庸以下受俗蒙蔽",
      "text": "更何况<span class=\"concept\" title=\"思想\">中庸</span>以下的人，渐渐被失教所浸染，在<span class=\"artifact\" title=\"器物\">被服</span>风尚上已成习俗了呢？"
    },
    "3.5": {
      "title": "孔子正名不合卫",
      "text": "<span class=\"person\" title=\"人名\">孔子</span>说\"必定要<span class=\"institution\" title=\"名物\">正名</span>\"，在<span class=\"feudal-state\" title=\"邦国\">卫</span>国所居之时也与当地不合。"
    },
    "3.6": {
      "title": "仲尼没后受业者散",
      "text": "<span class=\"person\" title=\"人名\">仲尼</span>去世后，他的弟子们沉沦埋没不被任用，有的前往<span class=\"feudal-state\" title=\"邦国\">齐</span>、<span class=\"feudal-state\" title=\"邦国\">楚</span>，有的隐入<span class=\"place\" title=\"地名\">河海</span>，难道不令人痛心吗！"
    },
    "4": {
      "title": "秦袭古礼",
      "text": "到<span class=\"feudal-state\" title=\"邦国\">秦</span>拥有<span class=\"concept\" title=\"思想\">天下</span>，全部吸收<span class=\"feudal-state\" title=\"邦国\">六国</span>的<span class=\"institution\" title=\"名物\">礼仪</span>，选取其中好的部分，虽然不合<span class=\"concept\" title=\"思想\">圣</span>人之制，但其中尊君抑臣、朝廷庄严的一面，仍是依照古代以来的传统。"
    },
    "5": {
      "title": "高祖承秦制",
      "text": "到了<span class=\"person\" title=\"人名\">高祖</span>，光有四海，<span class=\"person\" title=\"人名\">叔孙通</span>对礼仪有所增损，但大体上都沿袭<span class=\"feudal-state\" title=\"邦国\">秦</span>朝旧制。从<span class=\"identity\" title=\"身份\">天子</span>的称号下至<span class=\"identity\" title=\"身份\">佐僚</span>以及<span class=\"institution\" title=\"名物\">宫室</span>官名，改动不多。"
    },
    "6": {
      "title": "孝文罢礼",
      "text": "<span class=\"person\" title=\"人名\">孝文</span>即位后，<span class=\"official\" title=\"官职\">有司</span>建议要制定<span class=\"institution\" title=\"名物\">仪礼</span>，<span class=\"person\" title=\"人名\">孝文</span>喜好<span class=\"concept\" title=\"思想\">道家</span>的学说，认为繁琐的<span class=\"institution\" title=\"名物\">礼</span>节修饰外貌，对治理没有益处，关键在于亲身感化，因此废弃了这件事。"
    },
    "7": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "7.1": {
      "title": "晁错请削诸侯",
      "text": "<span class=\"person\" title=\"人名\">孝景</span>的时候，<span class=\"official\" title=\"官职\">御史大夫</span><span class=\"person\" title=\"人名\">晁错</span>深明世务<span class=\"institution\" title=\"名物\">刑名</span>之学，屡次进谏<span class=\"person\" title=\"人名\">孝景</span>说： > \"<span class=\"identity\" title=\"身份\">诸侯</span>是王室的藩屏辅翼，作为<span class=\"identity\" title=\"身份\">臣子</span>应当一体对待，这是古今通制。如今大国专断自治、各行其政，不听从<span class=\"place\" title=\"地名\">京师</span>命令，恐怕不可传之后世。\""
    },
    "7.2": {
      "title": "七国反晁错死",
      "text": "<span class=\"person\" title=\"人名\">孝景</span>采用了他的计策，而<span class=\"feudal-state\" title=\"邦国\">六国</span>叛乱，以<span class=\"person\" title=\"人名\">错</span>为首名讨伐对象，<span class=\"identity\" title=\"身份\">天子</span><span class=\"legal\" title=\"刑法\">诛</span>杀<span class=\"person\" title=\"人名\">错</span>以化解危难。"
    },
    "7.3": {
      "title": "事见袁盎",
      "text": "这件事记载在<span class=\"person\" title=\"人名\">袁盎</span>的传记中。"
    },
    "7.4": {
      "title": "官者苟安",
      "text": "此后做<span class=\"official\" title=\"官职\">官者</span>都只求交结权贵、苟安俸禄而已，没有人再敢议论礼制了。"
    },
    "8": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "8.1": {
      "title": "今上求礼不就",
      "text": "<span class=\"identity\" title=\"身份\">今上</span>即位后，招致<span class=\"concept\" title=\"思想\">儒术</span>之士，令他们共同制定<span class=\"institution\" title=\"名物\">仪</span>礼，<span class=\"time\" title=\"时间·规范：时长\">十馀年（时长）</span>都未能成就。"
    },
    "8.2": {
      "title": "有议采风定制",
      "text": "有人说古时太平之世，<span class=\"identity\" title=\"身份\">万民</span>和悦欢喜，祥瑞感应纷纷到来，于是采集风俗，定立<span class=\"institution\" title=\"名物\">制作</span>。"
    },
    "8.3": {
      "title": "上诏责议者",
      "text": "皇上听闻这番话，下诏给<span class=\"official\" title=\"官职\">御史</span>说： > \"凡受天命称王的，各有所由而兴起，途径不同而归宿相同，这是说要因循百姓、追随习俗来制定制度。<span class=\"identity\" title=\"身份\">议者</span>都称颂太古之世，<span class=\"identity\" title=\"身份\">百姓</span>又能期望什么呢？<span class=\"feudal-state\" title=\"邦国\">汉</span>也是<span class=\"quantity\" title=\"数量\">一家</span>之事，<span class=\"institution\" title=\"名物\">典法</span>若不流传，又对<span class=\"identity\" title=\"身份\">子孙</span>如何交代？教化隆盛者恢宏博大，治道浅陋者狭隘偏狭，岂能不勉力为之！\""
    },
    "8.4": {
      "title": "太初改制",
      "text": "于是在<span class=\"time\" title=\"时间\">太初之元</span>改变<span class=\"institution\" title=\"名物\">正朔</span>，更换<span class=\"institution\" title=\"名物\">服色</span>，封祭<span class=\"place\" title=\"地名\">太山</span>，定立<span class=\"institution\" title=\"名物\">宗庙百官之仪</span>，作为<span class=\"institution\" title=\"名物\">典常</span>，流传后世。"
    },
    "9": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "9.1": {
      "title": "礼由人起",
      "text": "<span class=\"institution\" title=\"名物\">礼</span>是由人产生的。"
    },
    "9.2": {
      "title": "欲争乱生",
      "text": "人生来就有欲望，有欲望而得不到满足就不能不愤恨，愤恨而没有节度就会争夺，争夺就会祸乱。"
    },
    "9.3": {
      "title": "先王制礼",
      "text": "<span class=\"identity\" title=\"身份\">先王</span>厌恶这种祸乱，所以制定<span class=\"concept\" title=\"思想\">礼义</span>来涵养人的欲望，满足人的需求，使欲望不至于穷尽物资，物资不至于被欲望耗竭，二者相辅相成而共同增长，这就是<span class=\"institution\" title=\"名物\">礼</span>产生的原因。"
    },
    "9.4": {
      "title": "礼者养也",
      "text": "所以<span class=\"institution\" title=\"名物\">礼</span>就是\"养\"。"
    },
    "10": {
      "title": "礼养五官",
      "text": "<span class=\"biology\" title=\"生物\">稻</span><span class=\"biology\" title=\"生物\">粱</span>五味，是用来养口的；<span class=\"biology\" title=\"生物\">椒</span><span class=\"biology\" title=\"生物\">兰</span><span class=\"biology\" title=\"生物\">芬茝</span>，是用来养鼻的；<span class=\"artifact\" title=\"器物\">钟鼓</span><span class=\"artifact\" title=\"器物\">管弦</span>，是用来养耳的；雕刻的花纹图案，是用来养目的；疏朗的居室、<span class=\"artifact\" title=\"器物\">床笫</span><span class=\"artifact\" title=\"器物\">几席</span>，是用来养身体的：所以<span class=\"institution\" title=\"名物\">礼</span>就是\"养\"。"
    },
    "11": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "11.1": {
      "title": "君子好辨",
      "text": "<span class=\"concept\" title=\"思想\">君子</span>既得到了养，又喜好其中的区别。"
    },
    "11.2": {
      "title": "辨有贵贱",
      "text": "所谓辨别，就是贵贱有等级，长幼有差别，贫富轻重都各有相应的规格。"
    },
    "11.3": {
      "title": "天子之礼养五官",
      "text": "所以<span class=\"identity\" title=\"身份\">天子</span>乘<span class=\"artifact\" title=\"器物\">大路</span>铺<span class=\"artifact\" title=\"器物\">越席</span>，是用来养身体的；车侧载<span class=\"biology\" title=\"生物\">臭茝</span>，是用来养鼻的；车前有<span class=\"artifact\" title=\"器物\">错衡</span>，是用来养目的；<span class=\"artifact\" title=\"器物\">和鸾</span>的声响，步行时合乎<span class=\"institution\" title=\"名物\">武象</span>之乐，快行时合乎<span class=\"institution\" title=\"名物\">韶濩</span>之乐，是用来养耳的；<span class=\"artifact\" title=\"器物\">龙旂</span><span class=\"artifact\" title=\"器物\">九斿</span>，是用来养<span class=\"concept\" title=\"思想\">信</span>的；<span class=\"artifact\" title=\"器物\">寝兕</span>持虎之饰、<span class=\"artifact\" title=\"器物\">鲛韅</span>弥龙的装饰，是用来养威仪的。"
    },
    "11.4": {
      "title": "大路之马养安",
      "text": "所以<span class=\"artifact\" title=\"器物\">大路</span>驾的<span class=\"biology\" title=\"生物\">马</span>，必定要<span class=\"concept\" title=\"思想\">信</span>达到训导柔顺之后，才可以乘用，这是用来养安全的。"
    },
    "11.5": {
      "title": "四养之理",
      "text": "谁能知道出生入死以守节义是为了养生；谁能知道轻视费用是为了养财；谁能知道<span class=\"concept\" title=\"思想\">恭敬辞让</span>是为了养安；谁能知道<span class=\"concept\" title=\"思想\">礼义</span>文理是为了养情。"
    },
    "12": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "12.1": {
      "title": "偏狭必败",
      "text": "人如果只知贪生，这样的人必定死；只知贪利，这样的人必定受害；以怠惰为安，这样的人必定危殆；以纵情为安，这样的人必定灭亡。"
    },
    "12.2": {
      "title": "圣人一于礼义",
      "text": "所以<span class=\"concept\" title=\"思想\">圣人</span>把一切归一于<span class=\"concept\" title=\"思想\">礼义</span>，那么就两方面都得到了；只归于情性，就两方面都失去了。"
    },
    "12.3": {
      "title": "儒墨之分",
      "text": "所以<span class=\"concept\" title=\"思想\">儒者</span>是要让人两方面都得到的，<span class=\"concept\" title=\"思想\">墨者</span>是要让人两方面都失去的。这就是<span class=\"concept\" title=\"思想\">儒墨</span>的区别。"
    },
    "13": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "13.1": {
      "title": "礼乃治本",
      "text": "礼治辨别的极致，是国家强固的根本，是威望施行的<span class=\"concept\" title=\"思想\">道</span>，是功名的总汇。"
    },
    "13.2": {
      "title": "王公由礼则一天下",
      "text": "<span class=\"identity\" title=\"身份\">王公</span>遵循礼，就能统一<span class=\"concept\" title=\"思想\">天下</span>，使<span class=\"identity\" title=\"身份\">诸侯</span><span class=\"legal\" title=\"刑法\">臣</span>服；不遵循礼，就是抛弃<span class=\"institution\" title=\"名物\">社稷</span>。"
    },
    "14": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "14.1": {
      "title": "礼道之要",
      "text": "所以坚硬的铠甲锋利的<span class=\"artifact\" title=\"器物\">兵</span>器不足以制胜，高城深池不足以坚固，严厉的政令繁苛的<span class=\"institution\" title=\"名物\">刑</span>法不足以立威。遵循<span class=\"concept\" title=\"思想\">道</span>就行得通，不遵循<span class=\"concept\" title=\"思想\">道</span>就被废弃。"
    },
    "14.2": {
      "title": "楚兵之利",
      "text": "<span class=\"feudal-state\" title=\"邦国\">楚</span>人用<span class=\"artifact\" title=\"器物\">鲛革</span><span class=\"biology\" title=\"生物\">犀兕</span>之皮，做成<span class=\"artifact\" title=\"器物\">甲</span>，坚硬如<span class=\"artifact\" title=\"器物\">金石</span>；<span class=\"place\" title=\"地名\">宛</span>地出产的长<span class=\"artifact\" title=\"器物\">铁</span>矛，锋利如<span class=\"biology\" title=\"生物\">蜂</span><span class=\"biology\" title=\"生物\">虿</span>的刺，轻利锐捷，迅疾如烈风。"
    },
    "14.3": {
      "title": "楚败垂涉",
      "text": "然而<span class=\"artifact\" title=\"器物\">兵</span>败于<span class=\"place\" title=\"地名\">垂涉</span>，<span class=\"person\" title=\"人名\">唐昧</span>死于那里；<span class=\"person\" title=\"人名\">庄蹻</span>起兵作乱，<span class=\"feudal-state\" title=\"邦国\">楚</span>国被分为四分。"
    },
    "14.4": {
      "title": "非兵不利",
      "text": "难道这是没有坚甲利<span class=\"artifact\" title=\"器物\">兵</span>吗？是因为统领他们的方法不合<span class=\"concept\" title=\"思想\">道</span>的缘故。"
    },
    "14.5": {
      "title": "楚之地险",
      "text": "以<span class=\"place\" title=\"地名\">汝</span>水、<span class=\"place\" title=\"地名\">颍</span>水为险阻，以<span class=\"place\" title=\"地名\">江</span>水、<span class=\"place\" title=\"地名\">汉</span>水为护城河，以<span class=\"place\" title=\"地名\">邓林</span>为阻隔，沿着<span class=\"place\" title=\"地名\">方城</span>为屏障。"
    },
    "14.6": {
      "title": "秦师至鄢郢",
      "text": "然而<span class=\"feudal-state\" title=\"邦国\">秦</span>师到达<span class=\"place\" title=\"地名\">鄢郢</span>，攻取如摇枯叶一般容易。难道这是没有险阻要塞吗？是因为统领的方法不合<span class=\"concept\" title=\"思想\">道</span>的缘故。"
    },
    "15": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "15.1": {
      "title": "纣之暴虐",
      "text": "<span class=\"person\" title=\"人名\">纣</span><span class=\"legal\" title=\"刑法\">剖</span>开<span class=\"person\" title=\"人名\">比干</span>之心，<span class=\"legal\" title=\"刑法\">囚</span>禁<span class=\"person\" title=\"人名\">箕子</span>，设<span class=\"institution\" title=\"名物\">砲格</span>之刑，<span class=\"legal\" title=\"刑法\">刑</span><span class=\"legal\" title=\"刑法\">杀</span>无辜之人，当时臣下战战兢兢，没有人能保全性命。"
    },
    "15.2": {
      "title": "周师来而纣不能用民",
      "text": "然而<span class=\"feudal-state\" title=\"邦国\">周</span>师一到，号令在下面就行不通了，不能役使他的民众。这岂是号令不严、<span class=\"institution\" title=\"名物\">刑</span>罚不重吗？是因为统领的方法不合<span class=\"concept\" title=\"思想\">道</span>的缘故。"
    },
    "16": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "16.1": {
      "title": "古兵简而敌屈",
      "text": "古时候的<span class=\"artifact\" title=\"器物\">兵</span>器，只有<span class=\"artifact\" title=\"器物\">戈</span>、<span class=\"artifact\" title=\"器物\">矛</span>、<span class=\"artifact\" title=\"器物\">弓</span>、<span class=\"artifact\" title=\"器物\">矢</span>而已，然而敌国不待试兵就屈服了。"
    },
    "16.2": {
      "title": "无险无备而民应",
      "text": "城郭不加修筑，沟池不加挖掘，关塞不设屏障，机变不施用，然而国家安然无事，不畏外敌而稳固，没有别的缘故，就是明<span class=\"concept\" title=\"思想\">道</span>而均分利益，按时役使而真诚爱护，那么下面的响应就像影随形、响随声一样。"
    },
    "16.3": {
      "title": "不命者始俟刑",
      "text": "有不遵从命令的，然后再用<span class=\"institution\" title=\"名物\">刑</span>罚对待，那么民众就知道自己有罪。"
    },
    "16.4": {
      "title": "刑一人而天下服",
      "text": "所以<span class=\"institution\" title=\"名物\">刑</span>罚<span class=\"quantity\" title=\"数量\">一人</span>而<span class=\"concept\" title=\"思想\">天下</span>都臣服。受罚之人不怨恨上面，因为知道罪在自己。"
    },
    "16.5": {
      "title": "刑省而威行",
      "text": "因此<span class=\"institution\" title=\"名物\">刑罚</span>省减而威望施行如流水，没有别的缘故，就是遵循<span class=\"concept\" title=\"思想\">道</span>的缘故。"
    },
    "16.6": {
      "title": "由道则行",
      "text": "所以遵循<span class=\"concept\" title=\"思想\">道</span>就行得通，不遵循<span class=\"concept\" title=\"思想\">道</span>就被废弃。"
    },
    "17": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "17.1": {
      "title": "尧刑少而天下治",
      "text": "古时候<span class=\"person\" title=\"人名\">帝尧</span>治理<span class=\"concept\" title=\"思想\">天下</span>，大概<span class=\"legal\" title=\"刑法\">杀</span><span class=\"quantity\" title=\"数量\">一人</span><span class=\"legal\" title=\"刑法\">刑</span><span class=\"quantity\" title=\"数量\">二人</span>而<span class=\"concept\" title=\"思想\">天下</span>就得到治理。"
    },
    "17.2": {
      "title": "刑措不用",
      "text": "史传说： > \"威严严厉而不用，<span class=\"institution\" title=\"名物\">刑</span>罚放置而不用。\""
    },
    "18": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "18.1": {
      "title": "礼三本",
      "text": "<span class=\"astronomy\" title=\"天文\">天地</span>，是生命的根本；先祖，是族类的根本；君师，是治理的根本。"
    },
    "18.2": {
      "title": "三本不可缺",
      "text": "没有<span class=\"astronomy\" title=\"天文\">天地</span>从哪里产生？没有先祖从哪里出来？没有君师怎么治理？三者缺一，就没有安定的人。"
    },
    "18.3": {
      "title": "礼之三本",
      "text": "所以<span class=\"institution\" title=\"名物\">礼</span>，上事奉天，下事奉地，尊崇先祖而推崇君师，这就是<span class=\"institution\" title=\"名物\">礼</span>的三本。"
    },
    "19": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "19.1": {
      "title": "王者天太祖",
      "text": "所以<span class=\"identity\" title=\"身份\">王者</span>以<span class=\"identity\" title=\"身份\">太祖</span>配天，<span class=\"identity\" title=\"身份\">诸侯</span>不敢怀有此心，<span class=\"identity\" title=\"身份\">大夫</span><span class=\"identity\" title=\"身份\">士</span>各有固定的宗庙，这是用来辨别贵贱的。贵贱分明，是得到礼的根本。"
    },
    "19.2": {
      "title": "祭祀辨尊卑",
      "text": "<span class=\"institution\" title=\"名物\">郊</span>祭专属于<span class=\"identity\" title=\"身份\">天子</span>，<span class=\"institution\" title=\"名物\">社</span>祭可到<span class=\"identity\" title=\"身份\">诸侯</span>，下及<span class=\"identity\" title=\"身份\">士大夫</span>，这是用来辨别尊者事尊，卑者事卑，应当大的就大，应当小的就小。"
    },
    "19.3": {
      "title": "世代祭祀之别",
      "text": "所以拥有<span class=\"concept\" title=\"思想\">天下</span>的祭<span class=\"quantity\" title=\"数量\">七世</span>，拥有一国的祭<span class=\"quantity\" title=\"数量\">五世</span>，拥有<span class=\"artifact\" title=\"器物\">五乘</span>之地的祭<span class=\"quantity\" title=\"数量\">三世</span>，拥有<span class=\"artifact\" title=\"器物\">三乘</span>之地的祭<span class=\"quantity\" title=\"数量\">二世</span>，只能用<span class=\"institution\" title=\"名物\">特牲</span>祭祀的不得立<span class=\"institution\" title=\"名物\">宗庙</span>，这是用来辨别积厚者流泽广，积薄者流泽狭。"
    },
    "20": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "20.1": {
      "title": "大飨贵本",
      "text": "<span class=\"institution\" title=\"名物\">大飨</span>之礼以<span class=\"artifact\" title=\"器物\">玄尊</span>为上，俎上放生<span class=\"biology\" title=\"生物\">鱼</span>，先进<span class=\"artifact\" title=\"器物\">大羹</span>，是尊重饮食的根本。"
    },
    "20.2": {
      "title": "贵本而亲用",
      "text": "<span class=\"institution\" title=\"名物\">大飨</span>以<span class=\"artifact\" title=\"器物\">玄尊</span>为上而饮用薄酒，食物先献<span class=\"biology\" title=\"生物\">黍</span><span class=\"biology\" title=\"生物\">稷</span>而食用<span class=\"biology\" title=\"生物\">稻</span><span class=\"biology\" title=\"生物\">粱</span>，祭哜先用<span class=\"artifact\" title=\"器物\">大羹</span>而饱食众美味，是尊重根本而亲切实用。"
    },
    "20.3": {
      "title": "文理归太一",
      "text": "尊重根本叫做文，亲切实用叫做理，两者合一而成文，归于<span class=\"institution\" title=\"名物\">太一</span>，这叫做大隆。"
    },
    "21": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "21.1": {
      "title": "尊俎豆之礼同一",
      "text": "所以<span class=\"artifact\" title=\"器物\">尊</span>之中以<span class=\"artifact\" title=\"器物\">玄尊</span>为上，<span class=\"artifact\" title=\"器物\">俎</span>之上以生<span class=\"biology\" title=\"生物\">鱼</span>为先，<span class=\"artifact\" title=\"器物\">豆</span>中以<span class=\"artifact\" title=\"器物\">大羹</span>为先，道理是一样的。"
    },
    "21.2": {
      "title": "诸礼不享用之例",
      "text": "<span class=\"artifact\" title=\"器物\">利爵</span>不品尝，<span class=\"artifact\" title=\"器物\">成事俎</span>不尝食，<span class=\"institution\" title=\"名物\">三侑</span>之礼不吃，<span class=\"institution\" title=\"名物\">大昏</span>之礼未废斋戒，<span class=\"institution\" title=\"名物\">大庙</span>之礼未迎尸，始绝气还未小敛，道理是一样的。"
    },
    "21.3": {
      "title": "大路麻絻散麻",
      "text": "<span class=\"artifact\" title=\"器物\">大路</span>的<span class=\"artifact\" title=\"器物\">素幬</span>车盖，<span class=\"institution\" title=\"名物\">郊</span>祭的<span class=\"artifact\" title=\"器物\">麻絻</span>，<span class=\"institution\" title=\"名物\">丧服</span>先用<span class=\"artifact\" title=\"器物\">散麻</span>，道理是一样的。"
    },
    "21.4": {
      "title": "三年哭清庙之歌",
      "text": "<span class=\"time\" title=\"时间·规范：时长\">三年（时长）</span>之丧哭而不回声，<span class=\"place\" title=\"地名\">清庙</span>的颂歌一人唱而三人叹和，悬挂一架<span class=\"artifact\" title=\"器物\">钟</span>还要轻击膈架，<span class=\"artifact\" title=\"器物\">硃弦</span>而通越之瑟，道理是一样的。"
    },
    "22": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "22.1": {
      "title": "礼之三境",
      "text": "大凡<span class=\"institution\" title=\"名物\">礼</span>始于粗略，成于文饰，终于简约。"
    },
    "22.2": {
      "title": "情文代胜",
      "text": "所以至于完备，情与文都充分体现；其次，情与文交替地居于主位；再下，回归情感归于<span class=\"institution\" title=\"名物\">太一</span>。"
    },
    "22.3": {
      "title": "天地万象和谐",
      "text": "<span class=\"astronomy\" title=\"天文\">天地</span>因此相合，<span class=\"astronomy\" title=\"天文\">日月</span>因此光明，<span class=\"time\" title=\"时间\">四时</span>因此有序，<span class=\"astronomy\" title=\"天文\">星辰</span>因此运行，<span class=\"place\" title=\"地名\">江</span>水<span class=\"place\" title=\"地名\">河</span>水因此流淌，万物因此昌盛，好恶因此有节度，喜怒因此恰当。"
    },
    "22.4": {
      "title": "礼顺则明",
      "text": "用之于下就能和顺，用之于上就能明察。"
    },
    "23": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "23.1": {
      "title": "立隆为极",
      "text": "<span class=\"person\" title=\"人名\">太史公</span>说：至极啊！确立隆盛作为准则，而<span class=\"concept\" title=\"思想\">天下</span>没有谁能增减它。"
    },
    "23.2": {
      "title": "本末相顺",
      "text": "本末相顺，终始相应，极致的文饰足以辨别，极致的明察足以令人悦服。"
    },
    "23.3": {
      "title": "从之者治",
      "text": "<span class=\"concept\" title=\"思想\">天下</span>顺从它的就得治，不顺从的就乱；顺从的就安宁，不顺从的就危险。<span class=\"concept\" title=\"思想\">小人</span>不能效法它。"
    },
    "24": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "24.1": {
      "title": "礼深而辩者弱",
      "text": "<span class=\"institution\" title=\"名物\">礼</span>的形貌确实深邃啊，坚白同异那种辩察之论，进入其中就显得薄弱了。"
    },
    "24.2": {
      "title": "礼大而陋说者望",
      "text": "它的形貌确实博大啊，擅自制作<span class=\"institution\" title=\"名物\">典制</span>那些狭隘浅陋的议论，进入其中就只能望而兴叹。"
    },
    "24.3": {
      "title": "礼高而轻俗者坠",
      "text": "它的形貌确实高远啊，暴慢放纵、轻视世俗以此为高的那些人，进入其中就只能坠落下来。"
    },
    "25": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "25.1": {
      "title": "礼如绳衡规矩",
      "text": "所以<span class=\"artifact\" title=\"器物\">绳</span>确实摆开，就不可能用曲直来欺骗人；<span class=\"artifact\" title=\"器物\">衡</span>确实悬起，就不可能用轻重来欺骗人；<span class=\"artifact\" title=\"器物\">规矩</span>确实摆放，就不可能用方圆来欺骗人；<span class=\"concept\" title=\"思想\">君子</span>审察<span class=\"institution\" title=\"名物\">礼</span>，就不可能用诈伪来欺骗他。"
    },
    "25.2": {
      "title": "礼为人道之极",
      "text": "所以<span class=\"artifact\" title=\"器物\">绳</span>是直的极致，<span class=\"artifact\" title=\"器物\">衡</span>是平的极致，<span class=\"artifact\" title=\"器物\">规矩</span>是方圆的极致，<span class=\"institution\" title=\"名物\">礼</span>是<span class=\"concept\" title=\"思想\">人道</span>的极致。"
    },
    "26": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "26.1": {
      "title": "法礼者有方",
      "text": "然而不效法<span class=\"institution\" title=\"名物\">礼</span>、不以<span class=\"institution\" title=\"名物\">礼</span>为满足的，叫做无方之民；效法<span class=\"institution\" title=\"名物\">礼</span>、以<span class=\"institution\" title=\"名物\">礼</span>为满足的，叫做有方之士。"
    },
    "26.2": {
      "title": "能虑能固乃圣",
      "text": "在<span class=\"institution\" title=\"名物\">礼</span>之中能够思索的，叫做能虑；能虑而不改易的，叫做能固。能虑能固，再加上喜好它，就是圣人了。"
    },
    "26.3": {
      "title": "圣人为道之极",
      "text": "天，是高的极致；地，是低的极致；<span class=\"astronomy\" title=\"天文\">日月</span>，是明的极致；无穷，是广大的极致；<span class=\"concept\" title=\"思想\">圣人</span>，是<span class=\"concept\" title=\"思想\">道</span>的极致。"
    },
    "27": {
      "title": "本段",
      "text": "（本段内容在以下子段中。）"
    },
    "27.1": {
      "title": "礼之隆杀为要",
      "text": "以财物为用，以贵贱为文饰，以多少为差异，以隆重或简杀为关键。"
    },
    "27.2": {
      "title": "礼之隆杀中流",
      "text": "文饰繁多，情欲俭省，这是<span class=\"institution\" title=\"名物\">礼</span>的隆盛；文饰俭省，情欲繁多，这是<span class=\"institution\" title=\"名物\">礼</span>的简杀；文饰与情欲互为内外表里，并行而交织，这是<span class=\"institution\" title=\"名物\">礼</span>的中流。"
    },
    "27.3": {
      "title": "君子兼得",
      "text": "<span class=\"concept\" title=\"思想\">君子</span>上则达到其隆盛，下则尽到其简杀，中则处于其中流。"
    },
    "27.4": {
      "title": "君子守礼",
      "text": "步行、驰骤、广驾奔驰都不超出<span class=\"institution\" title=\"名物\">礼</span>的范围，所以<span class=\"concept\" title=\"思想\">君子</span>的性情像守着宫庭一样。"
    },
    "27.5": {
      "title": "圣人周浃",
      "text": "人处于此域，是士<span class=\"concept\" title=\"思想\">君子</span>；越出此外，是<span class=\"identity\" title=\"身份\">民</span>。于其中而房皇周浃，委曲得其次序的，是<span class=\"concept\" title=\"思想\">圣人</span>。"
    },
    "27.6": {
      "title": "礼之功大",
      "text": "所以厚，是<span class=\"institution\" title=\"名物\">礼</span>的积累；大，是<span class=\"institution\" title=\"名物\">礼</span>的广博；高，是<span class=\"institution\" title=\"名物\">礼</span>的隆盛；明，是<span class=\"institution\" title=\"名物\">礼</span>的尽致。礼因于人心，不是从天而降。合乎诚心而修饰外貌，挽救弊端振兴雅道。用它来治理<span class=\"identity\" title=\"身份\">黎甿</span>，用它来事奉宗庙社稷。情与文饰都可贵重，隆盛与简杀难以假借。<span class=\"person\" title=\"人名\">仲尼</span>坐于树下，<span class=\"person\" title=\"人名·规范：叔孙通\">孙通（叔孙通）</span>行礼于野。<span class=\"concept\" title=\"思想\">圣人</span>制作教化，没有不由此而来的。"
    }
  }
}