{
  "chapter": "025",
  "title": "律书",
  "translations": {
    "1": {
      "title": "律历与兵法",
      "text": ""
    },
    "1.1": {
      "title": "六律为万事根本",
      "text": "<span class=\"identity\" title=\"身份\">王者</span>制事立法，各种物度规则，一律都取决于<span class=\"institution\" title=\"名物\">六律</span>，<span class=\"institution\" title=\"名物\">六律</span>是万事的根本。"
    },
    "1.2": {
      "title": "望敌知吉凶",
      "text": "它对于<span class=\"artifact\" title=\"器物\">兵械</span>尤为重要，所以说\"望敌军之气可以知道<span class=\"concept\" title=\"思想\">吉凶</span>，听军声可以判断胜负\"，这是历代君王不变的道理。"
    },
    "1.3": {
      "title": "武王伐纣吹律听声",
      "text": "<span class=\"person\" title=\"人名·规范：周武王\">武王（周武王）</span><span class=\"verb-military\" title=\"军事动词\">伐</span><span class=\"person\" title=\"人名·规范：帝辛\">纣（帝辛）</span>之时，吹律管听音声，从<span class=\"time\" title=\"时间\">孟春</span>推至<span class=\"time\" title=\"时间\">季冬</span>，<span class=\"concept\" title=\"思想\">杀气</span>相并，而音声崇<span class=\"institution\" title=\"名物\">宫</span>。"
    },
    "1.4": {
      "title": "同声相从自然之理",
      "text": "同声相应相从，是事物的<span class=\"concept\" title=\"思想\">自然</span>之理，有什么奇怪的呢？"
    },
    "2": {
      "title": "兵法的正当性",
      "text": ""
    },
    "2.1": {
      "title": "兵者圣人讨暴",
      "text": "<span class=\"artifact\" title=\"器物\">兵</span>，是<span class=\"identity\" title=\"身份\">圣人</span>用以<span class=\"legal\" title=\"刑法\">讨</span>伐强暴、平定乱世、夷除险阻、拯救危殆的。"
    },
    "2.2": {
      "title": "含齿戴角之兽受犯则反抗",
      "text": "连长着牙齿、顶着犄角的野<span class=\"biology\" title=\"生物\">兽</span>被侵犯尚知反抗，何况人怀有好恶喜怒之气呢？"
    },
    "2.3": {
      "title": "情性之理",
      "text": "喜则爱心生，怒则毒螫加人，这是情性的道理。"
    },
    "3": {
      "title": "历代战争回顾",
      "text": ""
    },
    "3.1": {
      "title": "黄帝涿鹿之战",
      "text": "从前<span class=\"person\" title=\"人名\">黄帝</span>有<span class=\"place\" title=\"地名\">涿鹿</span>之战，以平定火灾；"
    },
    "3.2": {
      "title": "颛顼讨共工",
      "text": "<span class=\"person\" title=\"人名·规范：帝颛顼\">颛顼（帝颛顼）</span>有讨<span class=\"person\" title=\"人名\">共工</span>的战阵，以平定水患；"
    },
    "3.3": {
      "title": "成汤南巢之伐",
      "text": "<span class=\"person\" title=\"人名·规范：商汤\">成汤（商汤）</span>有<span class=\"place\" title=\"地名\">南巢</span>之<span class=\"verb-military\" title=\"军事动词\">伐</span>，以<span class=\"legal\" title=\"刑法\">殄</span>灭<span class=\"feudal-state\" title=\"邦国\">夏</span>的乱政。"
    },
    "3.4": {
      "title": "递兴递废受命于天",
      "text": "递相兴起、递相废除，取胜者当政，是所从天受的天命。"
    },
    "4": {
      "title": "名将论",
      "text": ""
    },
    "4.1": {
      "title": "名士迭兴",
      "text": "自此以后，名士相继兴起，"
    },
    "4.2": {
      "title": "三国用名将",
      "text": "<span class=\"feudal-state\" title=\"邦国\">晋</span>任用<span class=\"person\" title=\"人名·规范：狐偃\">咎犯（狐偃）</span>，<span class=\"feudal-state\" title=\"邦国\">齐</span>任用<span class=\"person\" title=\"人名·规范：王子城父\">王子（王子城父）</span>，<span class=\"feudal-state\" title=\"邦国\">吴</span>任用<span class=\"person\" title=\"人名\">孙武</span>，申明军纪军约，赏罚必定守信，终能称霸<span class=\"identity\" title=\"身份\">诸侯</span>，兼并别国疆土。"
    },
    "4.3": {
      "title": "身宠君尊",
      "text": "虽不及<span class=\"time\" title=\"时间\">三代</span>的诰誓之盛，然而自身得宠、君主尊荣，显扬于当世，岂不是一种光荣吗？"
    },
    "4.4": {
      "title": "世儒昧于兵事",
      "text": "岂能与那些昧于大势、不权衡轻重、动辄说应以<span class=\"concept\" title=\"思想\">德化</span>、不当用<span class=\"artifact\" title=\"器物\">兵</span>的世俗儒者相比吗？大则导致国君受辱、国土沦丧，小则遭受侵犯、国势削弱，他们却坚执此说毫不动摇！"
    },
    "4.5": {
      "title": "刑罚诛伐不可废",
      "text": "所以<span class=\"ritual\" title=\"礼仪\">教</span>育中的<span class=\"verb-penalty\" title=\"刑罚动词\">笞</span>责不能废于家庭，<span class=\"institution\" title=\"名物\">刑罚</span>不能舍弃于国家，<span class=\"legal\" title=\"刑法\">诛伐</span>不能停息于天下，使用上有巧拙之分，施行中有顺逆之别罢了。"
    },
    "5": {
      "title": "穷兵黩武之戒",
      "text": ""
    },
    "5.1": {
      "title": "桀纣手搏豺狼",
      "text": "<span class=\"person\" title=\"人名\">夏桀</span>、<span class=\"person\" title=\"人名·规范：帝辛\">殷纣（帝辛）</span>能徒手搏击<span class=\"biology\" title=\"生物\">豺狼</span>，徒步追逐<span class=\"biology\" title=\"生物\">马</span>四匹，勇力不可谓小；"
    },
    "5.2": {
      "title": "百战克胜诸侯慑服",
      "text": "百战皆胜，<span class=\"identity\" title=\"身份\">诸侯</span>慑服，权势不可谓轻。"
    },
    "5.3": {
      "title": "秦二世连兵边陲",
      "text": "<span class=\"person\" title=\"人名\">秦二世</span>屯驻大军于无用之地，连年<span class=\"artifact\" title=\"器物\">兵</span>戈于边陲，兵力不可谓弱；"
    },
    "5.4": {
      "title": "结怨匈奴越",
      "text": "与<span class=\"tribe\" title=\"族群\">匈奴</span>结怨，陷入与<span class=\"feudal-state\" title=\"邦国\">越</span>族的祸端，形势不可谓寡。"
    },
    "5.5": {
      "title": "穷武不知足",
      "text": "等到其威信尽失、势力穷极，乡里小人都成了敌国，祸咎就生于穷兵黩武而不知足、贪得之心不止啊。"
    },
    "6": {
      "title": "高祖时期",
      "text": ""
    },
    "6.1": {
      "title": "三边外畔",
      "text": "<span class=\"person\" title=\"人名\">高祖</span>得了天下，三边还有外族叛乱；"
    },
    "6.2": {
      "title": "大国之王臣节未尽",
      "text": "大国的王虽然称为藩辅，但臣子的节度尚未尽守。"
    },
    "6.3": {
      "title": "偃武休息羁縻不备",
      "text": "适逢<span class=\"person\" title=\"人名\">高祖</span>厌倦军事，又有<span class=\"person\" title=\"人名·规范：萧何\">萧（萧何）</span>、<span class=\"person\" title=\"人名·规范：张良\">张（张良）</span>的谋划，所以停止用兵、一心休息，对外族只羁縻而不设防备。"
    },
    "7": {
      "title": "孝文帝的军事决策",
      "text": ""
    },
    "7.1": {
      "title": "陈武等建议征讨",
      "text": "到<span class=\"person\" title=\"人名·规范：汉文帝\">孝文（汉文帝）</span>即位，<span class=\"official\" title=\"官职\">将军</span><span class=\"person\" title=\"人名\">陈武</span>等建议说： ::: 陈武等建议征讨 \"<span class=\"feudal-state\" title=\"邦国\">南越</span>、<span class=\"feudal-state\" title=\"邦国\">朝鲜</span>自从<span class=\"feudal-state\" title=\"邦国\">秦</span>朝时即已内附为臣，后来拥<span class=\"artifact\" title=\"器物\">兵</span>据险，反复观望。<span class=\"person\" title=\"人名\">高祖</span>时天下刚刚安定，<span class=\"identity\" title=\"身份\">人民</span>小安，不便再动<span class=\"artifact\" title=\"器物\">兵</span>。如今<span class=\"identity\" title=\"身份\">陛下</span><span class=\"concept\" title=\"思想\">仁惠</span>安抚<span class=\"identity\" title=\"身份\">百姓</span>，恩泽遍及海内，正应趁<span class=\"identity\" title=\"身份\">士民</span>乐于效力，<span class=\"legal\" title=\"刑法\">征讨</span>叛逆，以统一疆土。\" :::"
    },
    "7.2": {
      "title": "文帝答复",
      "text": "<span class=\"person\" title=\"人名·规范：汉文帝\">孝文（汉文帝）</span>说： ::: 文帝答复 \"<span class=\"identity\" title=\"身份\">朕</span>能承担戴冠着衣之任，实在没想到此事。当年遭逢<span class=\"dynasty\" title=\"氏族\">吕氏</span>之乱，<span class=\"identity\" title=\"身份\">功臣</span><span class=\"identity\" title=\"身份\">宗室</span>都不以为耻，使朕误居正位，常常战战兢兢，恐怕不能善终。况且<span class=\"artifact\" title=\"器物\">兵</span>是<span class=\"artifact\" title=\"器物\">凶器</span>，即使攻克所愿之地，行动也会带来耗损与伤病，让<span class=\"identity\" title=\"身份\">百姓</span>远征又如何？再说<span class=\"identity\" title=\"身份\">先帝</span>知道劳民不可再烦扰，所以不以此为意。<span class=\"identity\" title=\"身份\">朕</span>岂敢自以为能做到？如今<span class=\"tribe\" title=\"族群\">匈奴</span>内侵，<span class=\"official\" title=\"官职\">军吏</span>没有战功，边民父子荷<span class=\"artifact\" title=\"器物\">兵</span>日久，<span class=\"identity\" title=\"身份\">朕</span>常常为之动心伤痛，没有一天忘怀。如今还不能使其远离，姑且加固边防、增设侦候，缔结和亲、派遣使者，安宁北陲，功绩就已经很大了。暂且不要再议军事。\" :::"
    },
    "7.3": {
      "title": "百姓无繇天下殷富",
      "text": "所以<span class=\"identity\" title=\"身份\">百姓</span>免除了内外徭役，得以在田亩中喘息，天下殷富，<span class=\"artifact\" title=\"器物\">粟</span>价跌到<span class=\"quantity\" title=\"数量\">十馀钱</span>，<span class=\"biology\" title=\"生物\">鸡</span>鸣<span class=\"biology\" title=\"生物\">狗</span>吠之声相闻，炊烟相连<span class=\"quantity\" title=\"数量\">万里</span>，可以说是和乐无虞了！"
    },
    "8": {
      "title": "太史公评文帝",
      "text": "<span class=\"person\" title=\"人名\">太史公</span>说： ::: 太史公评文帝 <span class=\"person\" title=\"人名·规范：汉文帝\">文帝（汉文帝）</span>时，正值天下刚脱离水深火热，<span class=\"identity\" title=\"身份\">人民</span>乐于本业，顺应他们的欲望，能不扰乱他们，所以<span class=\"identity\" title=\"身份\">百姓</span>得以安定。自<span class=\"quantity\" title=\"数量\">六七十</span>岁的老翁也未曾到过集市，游乐嬉戏如小儿的情状。这就是<span class=\"person\" title=\"人名\">孔子</span>所称的<span class=\"concept\" title=\"思想\">有德</span><span class=\"identity\" title=\"身份\">君子</span>吧！ :::"
    },
    "9": {
      "title": "七正二十八舍",
      "text": ""
    },
    "9.1": {
      "title": "书曰七正",
      "text": "<span class=\"book\" title=\"典籍·规范：书\">尚书（书）</span>上说\"<span class=\"astronomy\" title=\"天文\">七正</span>\"，还有<span class=\"astronomy\" title=\"天文\">二十八舍</span>。"
    },
    "9.2": {
      "title": "律历成就万物",
      "text": "<span class=\"institution\" title=\"名物\">律历</span>，是天用来贯通<span class=\"institution\" title=\"名物\">五行</span><span class=\"institution\" title=\"名物\">八正</span>之气，天用来成就万物的。"
    },
    "9.3": {
      "title": "舍者日月所舍",
      "text": "舍，是<span class=\"astronomy\" title=\"天文\">日月</span>所宿停之处。舍，就是舒散之气。"
    },
    "10": {
      "title": "十月：亥月",
      "text": ""
    },
    "10.1": {
      "title": "不周风居西北",
      "text": "<span class=\"astronomy\" title=\"天文\">不周风</span>位于西北，主<span class=\"verb-penalty\" title=\"刑罚动词\">杀</span>生之气。"
    },
    "10.2": {
      "title": "东壁居不周风东",
      "text": "<span class=\"astronomy\" title=\"天文\">东壁</span>位于<span class=\"astronomy\" title=\"天文\">不周风</span>之东，主开启生气而向东推移。到达<span class=\"astronomy\" title=\"天文\">营室</span>。"
    },
    "10.3": {
      "title": "营室营胎阳气",
      "text": "<span class=\"astronomy\" title=\"天文\">营室</span>，主营育<span class=\"institution\" title=\"名物\">阳气</span>之胎而使之生出。"
    },
    "10.4": {
      "title": "东至于危",
      "text": "再向东到<span class=\"astronomy\" title=\"天文\">危</span>。<span class=\"astronomy\" title=\"天文\">危</span>，就是毁坏。说的是<span class=\"institution\" title=\"名物\">阳气</span>的毁坏，所以叫<span class=\"astronomy\" title=\"天文\">危</span>。"
    },
    "10.5": {
      "title": "十月律中应锺",
      "text": "<span class=\"time\" title=\"时间\">十月</span>，律与<span class=\"institution\" title=\"名物\">应锺</span>相应。"
    },
    "10.6": {
      "title": "应锺之义",
      "text": "<span class=\"institution\" title=\"名物\">应锺</span>，是<span class=\"institution\" title=\"名物\">阳气</span>的回应，不当用事。"
    },
    "10.7": {
      "title": "十二子为亥",
      "text": "在<span class=\"institution\" title=\"名物\">十二子</span>中对应亥。亥，是\"该\"的意思。说的是<span class=\"institution\" title=\"名物\">阳气</span>藏于下，所以叫该。"
    },
    "11": {
      "title": "十一月：子月",
      "text": ""
    },
    "11.1": {
      "title": "广莫风居北方",
      "text": "<span class=\"astronomy\" title=\"天文\">广莫风</span>位于北方。"
    },
    "11.2": {
      "title": "广莫之义",
      "text": "<span class=\"astronomy\" title=\"天文\">广莫</span>，是说<span class=\"institution\" title=\"名物\">阳气</span>在下，<span class=\"institution\" title=\"名物\">阴</span>不能比<span class=\"institution\" title=\"名物\">阳</span>广大，所以叫<span class=\"astronomy\" title=\"天文\">广莫</span>。"
    },
    "11.3": {
      "title": "东至于虚",
      "text": "再向东到<span class=\"astronomy\" title=\"天文\">虚</span>。<span class=\"astronomy\" title=\"天文\">虚</span>，能实能虚，说的是<span class=\"institution\" title=\"名物\">阳气</span>在冬天宛然藏于虚中，<span class=\"time\" title=\"时间\">冬至</span>日则<span class=\"institution\" title=\"名物\">一阴</span>下藏，<span class=\"institution\" title=\"名物\">一阳</span>上舒，所以叫<span class=\"astronomy\" title=\"天文\">虚</span>。"
    },
    "11.4": {
      "title": "东至须女",
      "text": "再向东到<span class=\"astronomy\" title=\"天文\">须女</span>。说的是万物变动其位置，<span class=\"institution\" title=\"名物\">阴阳气</span>尚未相离，仍相等待，所以叫<span class=\"astronomy\" title=\"天文\">须女</span>。"
    },
    "11.5": {
      "title": "十一月律中黄锺",
      "text": "<span class=\"time\" title=\"时间\">十一月</span>，律与<span class=\"institution\" title=\"名物\">黄锺</span>相应。"
    },
    "11.6": {
      "title": "黄锺之义",
      "text": "<span class=\"institution\" title=\"名物\">黄锺</span>，是<span class=\"institution\" title=\"名物\">阳气</span>从黄泉起而出之意。"
    },
    "11.7": {
      "title": "十二子为子",
      "text": "在<span class=\"institution\" title=\"名物\">十二子</span>中对应子。子，是\"滋\"的意思；滋者，说的是万物滋生于下。"
    },
    "11.8": {
      "title": "十母为壬癸",
      "text": "在<span class=\"institution\" title=\"名物\">十母</span>中对应壬癸。壬，意为\"任\"，说的是<span class=\"institution\" title=\"名物\">阳气</span>任养万物于下。癸，意为\"揆\"，说的是万物可以揆度，所以叫癸。"
    },
    "11.9": {
      "title": "东至牵牛",
      "text": "再向东到<span class=\"astronomy\" title=\"天文\">牵牛</span>。<span class=\"astronomy\" title=\"天文\">牵牛</span>，说的是<span class=\"institution\" title=\"名物\">阳气</span>牵引万物使它们出来。<span class=\"biology\" title=\"生物\">牛</span>，意为\"冒\"，说的是土地虽然冰冻，万物仍能冒土而生。<span class=\"biology\" title=\"生物\">牛</span>，是用来耕地种植万物的。"
    },
    "11.10": {
      "title": "东至于建星",
      "text": "再向东到<span class=\"astronomy\" title=\"天文\">建星</span>。<span class=\"astronomy\" title=\"天文\">建星</span>，是开始建立万物生长的意思。"
    },
    "11.11": {
      "title": "十二月律中大吕",
      "text": "<span class=\"time\" title=\"时间\">十二月</span>，律与<span class=\"institution\" title=\"名物\">大吕</span>相应。在<span class=\"institution\" title=\"名物\">十二子</span>中对应丑。"
    },
    "12": {
      "title": "正月：寅月",
      "text": ""
    },
    "12.1": {
      "title": "条风居东北",
      "text": "<span class=\"astronomy\" title=\"天文\">条风</span>位于东北，主出生万物。"
    },
    "12.2": {
      "title": "条之义",
      "text": "\"条\"，意为条理治理万物而使它们出生，所以叫<span class=\"astronomy\" title=\"天文\">条风</span>。"
    },
    "12.3": {
      "title": "南至箕",
      "text": "再向南到<span class=\"astronomy\" title=\"天文\">箕</span>。<span class=\"astronomy\" title=\"天文\">箕</span>，说的是万物扎根如棋子，所以叫<span class=\"astronomy\" title=\"天文\">箕</span>。"
    },
    "12.4": {
      "title": "正月律中泰蔟",
      "text": "<span class=\"time\" title=\"时间\">正月</span>，律与<span class=\"institution\" title=\"名物\">泰蔟</span>相应。"
    },
    "12.5": {
      "title": "泰蔟之义",
      "text": "<span class=\"institution\" title=\"名物\">泰蔟</span>，说的是万物簇生，所以叫<span class=\"institution\" title=\"名物\">泰蔟</span>。"
    },
    "12.6": {
      "title": "十二子为寅",
      "text": "在<span class=\"institution\" title=\"名物\">十二子</span>中对应寅。寅，说的是万物开始生发像蚯蚓一样蠕动，所以叫寅。"
    },
    "12.7": {
      "title": "南至尾",
      "text": "再向南到<span class=\"astronomy\" title=\"天文\">尾</span>，说的是万物刚生出像尾巴一样。"
    },
    "12.8": {
      "title": "南至心",
      "text": "再向南到<span class=\"astronomy\" title=\"天文\">心</span>，说的是万物开始生出像有了花心。"
    },
    "12.9": {
      "title": "南至房",
      "text": "再向南到<span class=\"astronomy\" title=\"天文\">房</span>。<span class=\"astronomy\" title=\"天文\">房</span>，是说万物的门户，到了门口就出来了。"
    },
    "13": {
      "title": "二月：卯月",
      "text": ""
    },
    "13.1": {
      "title": "明庶风居东方",
      "text": "<span class=\"astronomy\" title=\"天文\">明庶风</span>位于东方。"
    },
    "13.2": {
      "title": "明庶之义",
      "text": "<span class=\"astronomy\" title=\"天文\">明庶</span>，意思是明示万物尽数生出。"
    },
    "13.3": {
      "title": "二月律中夹锺",
      "text": "<span class=\"time\" title=\"时间\">二月</span>，律与<span class=\"institution\" title=\"名物\">夹锺</span>相应。"
    },
    "13.4": {
      "title": "夹锺之义",
      "text": "<span class=\"institution\" title=\"名物\">夹锺</span>，说的是<span class=\"institution\" title=\"名物\">阴阳</span>相夹杂于中间。"
    },
    "13.5": {
      "title": "十二子为卯",
      "text": "在<span class=\"institution\" title=\"名物\">十二子</span>中对应卯。卯，意为\"茂\"，说的是万物茂盛。"
    },
    "13.6": {
      "title": "十母为甲乙",
      "text": "在<span class=\"institution\" title=\"名物\">十母</span>中对应甲乙。甲，说的是万物剖开外甲而出生；乙，说的是万物生出时轧轧而发。"
    },
    "13.7": {
      "title": "南至氐",
      "text": "再向南到<span class=\"astronomy\" title=\"天文\">氐</span>。<span class=\"astronomy\" title=\"天文\">氐</span>，说的是万物皆已到达此处。"
    },
    "13.8": {
      "title": "南至亢",
      "text": "再向南到<span class=\"astronomy\" title=\"天文\">亢</span>。<span class=\"astronomy\" title=\"天文\">亢</span>，说的是万物亢然显现。"
    },
    "13.9": {
      "title": "南至角",
      "text": "再向南到<span class=\"astronomy\" title=\"天文\">角</span>。<span class=\"astronomy\" title=\"天文\">角</span>，说的是万物都有了枝条棱角如同角一样。"
    },
    "13.10": {
      "title": "三月律中姑洗",
      "text": "<span class=\"time\" title=\"时间\">三月</span>，律与<span class=\"institution\" title=\"名物\">姑洗</span>相应。"
    },
    "13.11": {
      "title": "姑洗之义与辰",
      "text": "<span class=\"institution\" title=\"名物\">姑洗</span>，说的是万物洗濯而生。在<span class=\"institution\" title=\"名物\">十二子</span>中对应辰。辰，说的是万物震起。"
    },
    "14": {
      "title": "四月：巳月",
      "text": ""
    },
    "14.1": {
      "title": "清明风居东南",
      "text": "<span class=\"astronomy\" title=\"天文\">清明风</span>位于东南角，主风吹万物而使之向西行。"
    },
    "14.2": {
      "title": "轸",
      "text": "<span class=\"astronomy\" title=\"天文\">轸</span>。<span class=\"astronomy\" title=\"天文\">轸</span>，说的是万物日益增长而轸轸然。"
    },
    "14.3": {
      "title": "西至翼",
      "text": "再向西到<span class=\"astronomy\" title=\"天文\">翼</span>。<span class=\"astronomy\" title=\"天文\">翼</span>，说的是万物都有了羽翼。"
    },
    "14.4": {
      "title": "四月律中中吕",
      "text": "<span class=\"time\" title=\"时间\">四月</span>，律与<span class=\"institution\" title=\"名物\">中吕</span>相应。"
    },
    "14.5": {
      "title": "中吕之义",
      "text": "<span class=\"institution\" title=\"名物\">中吕</span>，说的是万物都一起结伴向西而行。"
    },
    "14.6": {
      "title": "十二子为巳",
      "text": "在<span class=\"institution\" title=\"名物\">十二子</span>中对应巳。巳，说的是<span class=\"institution\" title=\"名物\">阳气</span>已经极尽。"
    },
    "14.7": {
      "title": "西至七星",
      "text": "再向西到<span class=\"astronomy\" title=\"天文\">七星</span>。<span class=\"astronomy\" title=\"天文\">七星</span>，阳数成就于七，所以叫<span class=\"astronomy\" title=\"天文\">七星</span>。"
    },
    "14.8": {
      "title": "西至张",
      "text": "再向西到<span class=\"astronomy\" title=\"天文\">张</span>。<span class=\"astronomy\" title=\"天文\">张</span>，说的是万物都已张大。"
    },
    "14.9": {
      "title": "西至注",
      "text": "再向西到<span class=\"astronomy\" title=\"天文\">注</span>。<span class=\"astronomy\" title=\"天文\">注</span>，说的是万物开始衰落，<span class=\"institution\" title=\"名物\">阳气</span>下注，所以叫<span class=\"astronomy\" title=\"天文\">注</span>。"
    },
    "14.10": {
      "title": "五月律中蕤宾",
      "text": "<span class=\"time\" title=\"时间\">五月</span>，律与<span class=\"institution\" title=\"名物\">蕤宾</span>相应。"
    },
    "14.11": {
      "title": "蕤宾之义",
      "text": "<span class=\"institution\" title=\"名物\">蕤宾</span>，说的是<span class=\"institution\" title=\"名物\">阴气</span>幼小，所以叫蕤；阳气萎缩不当用事，所以叫宾。"
    },
    "15": {
      "title": "午月",
      "text": ""
    },
    "15.1": {
      "title": "景风居南方",
      "text": "<span class=\"astronomy\" title=\"天文\">景风</span>位于南方。"
    },
    "15.2": {
      "title": "景之义",
      "text": "<span class=\"astronomy\" title=\"天文\">景</span>，说的是<span class=\"institution\" title=\"名物\">阳气</span>之道已达极致，所以叫<span class=\"astronomy\" title=\"天文\">景风</span>。"
    },
    "15.3": {
      "title": "十二子为午",
      "text": "在<span class=\"institution\" title=\"名物\">十二子</span>中对应午。午，是<span class=\"institution\" title=\"名物\">阴阳</span>相交，所以叫午。"
    },
    "15.4": {
      "title": "十母为丙丁",
      "text": "在<span class=\"institution\" title=\"名物\">十母</span>中对应丙丁。丙，说的是阳道显著光明，所以叫丙；丁，说的是万物壮盛，所以叫丁。"
    },
    "15.5": {
      "title": "西至弧",
      "text": "再向西到<span class=\"astronomy\" title=\"天文\">弧</span>。<span class=\"astronomy\" title=\"天文\">弧</span>，说的是万物呜咽凋落将要走向死亡。"
    },
    "15.6": {
      "title": "西至狼",
      "text": "再向西到<span class=\"astronomy\" title=\"天文\">狼</span>。<span class=\"astronomy\" title=\"天文\">狼</span>，说的是万物可以度量，可以断定万物，所以叫<span class=\"astronomy\" title=\"天文\">狼</span>。"
    },
    "16": {
      "title": "六月：未月",
      "text": ""
    },
    "16.1": {
      "title": "凉风居西南",
      "text": "<span class=\"astronomy\" title=\"天文\">凉风</span>位于西南角，主地。"
    },
    "16.2": {
      "title": "地沈夺万物气",
      "text": "地，是沉夺万物之气的。"
    },
    "16.3": {
      "title": "六月律中林锺",
      "text": "<span class=\"time\" title=\"时间\">六月</span>，律与<span class=\"institution\" title=\"名物\">林锺</span>相应。"
    },
    "16.4": {
      "title": "林锺之义",
      "text": "<span class=\"institution\" title=\"名物\">林锺</span>，说的是万物走向死气林林然。"
    },
    "16.5": {
      "title": "十二子为未",
      "text": "在<span class=\"institution\" title=\"名物\">十二子</span>中对应未。未，说的是万物皆已成熟，有了滋味。"
    },
    "16.6": {
      "title": "北至罚",
      "text": "再向北到<span class=\"astronomy\" title=\"天文\">罚</span>。<span class=\"astronomy\" title=\"天文\">罚</span>，说的是万物之气被夺可以<span class=\"verb-military\" title=\"军事动词\">伐</span>取。"
    },
    "16.7": {
      "title": "北至参",
      "text": "再向北到<span class=\"astronomy\" title=\"天文\">参</span>。<span class=\"astronomy\" title=\"天文\">参</span>是说万物可以参验，所以叫<span class=\"astronomy\" title=\"天文\">参</span>。"
    },
    "16.8": {
      "title": "七月律中夷则",
      "text": "<span class=\"time\" title=\"时间\">七月</span>，律与<span class=\"institution\" title=\"名物\">夷则</span>相应。"
    },
    "16.9": {
      "title": "夷则之义",
      "text": "<span class=\"institution\" title=\"名物\">夷则</span>，说的是<span class=\"institution\" title=\"名物\">阴气</span>贼害万物。"
    },
    "16.10": {
      "title": "十二子为申",
      "text": "在<span class=\"institution\" title=\"名物\">十二子</span>中对应申。申，说的是<span class=\"institution\" title=\"名物\">阴</span>气当用事，申然贼害万物，所以叫申。"
    },
    "16.11": {
      "title": "北至浊",
      "text": "再向北到<span class=\"astronomy\" title=\"天文\">浊</span>。<span class=\"astronomy\" title=\"天文\">浊</span>，意为触，说的是万物都触死，所以叫<span class=\"astronomy\" title=\"天文\">浊</span>。"
    },
    "16.12": {
      "title": "北至留",
      "text": "再向北到<span class=\"astronomy\" title=\"天文\">留</span>。<span class=\"astronomy\" title=\"天文\">留</span>，说的是<span class=\"institution\" title=\"名物\">阳气</span>稽留未走，所以叫<span class=\"astronomy\" title=\"天文\">留</span>。"
    },
    "16.13": {
      "title": "八月律中南吕",
      "text": "<span class=\"time\" title=\"时间\">八月</span>，律与<span class=\"institution\" title=\"名物\">南吕</span>相应。"
    },
    "16.14": {
      "title": "南吕之义",
      "text": "<span class=\"institution\" title=\"名物\">南吕</span>，说的是<span class=\"institution\" title=\"名物\">阳气</span>结伴入藏。"
    },
    "16.15": {
      "title": "十二子为酉",
      "text": "在<span class=\"institution\" title=\"名物\">十二子</span>中对应酉。酉，是万物的衰老阶段，所以叫酉。"
    },
    "17": {
      "title": "九月：戌月",
      "text": ""
    },
    "17.1": {
      "title": "阊阖风居西方",
      "text": "<span class=\"astronomy\" title=\"天文\">阊阖风</span>位于西方。"
    },
    "17.2": {
      "title": "阊阖之义",
      "text": "阊，是倡；阖，是藏。说的是<span class=\"institution\" title=\"名物\">阳气</span>引导万物，归藏于黄泉之下。"
    },
    "17.3": {
      "title": "十母为庚辛",
      "text": "在<span class=\"institution\" title=\"名物\">十母</span>中对应庚辛。庚，说的是<span class=\"institution\" title=\"名物\">阴气</span>更新万物，所以叫庚；辛，说的是万物正辛苦生长，所以叫辛。"
    },
    "17.4": {
      "title": "北至胃",
      "text": "再向北到<span class=\"astronomy\" title=\"天文\">胃</span>。<span class=\"astronomy\" title=\"天文\">胃</span>，说的是<span class=\"institution\" title=\"名物\">阳气</span>就要收藏，都胃胃然闭合。"
    },
    "17.5": {
      "title": "北至娄",
      "text": "再向北到<span class=\"astronomy\" title=\"天文\">娄</span>。<span class=\"astronomy\" title=\"天文\">娄</span>，说的是呼唤万物并收纳它们进来。"
    },
    "17.6": {
      "title": "北至奎",
      "text": "再向北到<span class=\"astronomy\" title=\"天文\">奎</span>。<span class=\"astronomy\" title=\"天文\">奎</span>，主用毒螫<span class=\"verb-penalty\" title=\"刑罚动词\">杀</span>死万物，奎然而将其收藏。"
    },
    "17.7": {
      "title": "九月律中无射",
      "text": "<span class=\"time\" title=\"时间\">九月</span>，律与<span class=\"institution\" title=\"名物\">无射</span>相应。"
    },
    "17.8": {
      "title": "无射之义",
      "text": "<span class=\"institution\" title=\"名物\">无射</span>，是<span class=\"institution\" title=\"名物\">阴气</span>盛而当用事，<span class=\"institution\" title=\"名物\">阳气</span>无剩余，所以叫<span class=\"institution\" title=\"名物\">无射</span>。"
    },
    "17.9": {
      "title": "十二子为戌",
      "text": "在<span class=\"institution\" title=\"名物\">十二子</span>中对应戌。戌，说的是万物尽皆<span class=\"verb-military\" title=\"军事动词\">灭</span>亡，所以叫戌。"
    },
    "18": {
      "title": "五音律数",
      "text": ""
    },
    "18.1": {
      "title": "九九八十一为宫",
      "text": "律数：九九八十一作为<span class=\"institution\" title=\"名物\">宫</span>音。"
    },
    "18.2": {
      "title": "三分去一为徵",
      "text": "三分去其一，得五十四，作为<span class=\"institution\" title=\"名物\">徵</span>音。"
    },
    "18.3": {
      "title": "三分益一为商",
      "text": "三分益其一，得七十二，作为<span class=\"institution\" title=\"名物\">商</span>音。"
    },
    "18.4": {
      "title": "三分去一为羽",
      "text": "三分去其一，得四十八，作为<span class=\"institution\" title=\"名物\">羽</span>音。"
    },
    "18.5": {
      "title": "三分益一为角",
      "text": "三分益其一，得六十四，作为<span class=\"institution\" title=\"名物\">角</span>音。"
    },
    "19": {
      "title": "十二律长度",
      "text": ""
    },
    "19.1": {
      "title": "黄锺长八寸七分一",
      "text": "<span class=\"institution\" title=\"名物\">黄锺</span>长<span class=\"quantity\" title=\"数量\">八寸</span>七分一，为<span class=\"institution\" title=\"名物\">宫</span>音。"
    },
    "19.2": {
      "title": "大吕长七寸五分三分",
      "text": "<span class=\"institution\" title=\"名物\">大吕</span>长<span class=\"quantity\" title=\"数量\">七寸</span>五分三分。"
    },
    "19.3": {
      "title": "太蔟长七寸分二",
      "text": "<span class=\"institution\" title=\"名物\">太蔟</span>长<span class=\"quantity\" title=\"数量\">七寸</span>分二，为<span class=\"institution\" title=\"名物\">角</span>音。"
    },
    "19.4": {
      "title": "夹锺长六寸分三分一",
      "text": "<span class=\"institution\" title=\"名物\">夹锺</span>长<span class=\"quantity\" title=\"数量\">六寸</span>分三分一。"
    },
    "19.5": {
      "title": "姑洗长六寸分四",
      "text": "<span class=\"institution\" title=\"名物\">姑洗</span>长<span class=\"quantity\" title=\"数量\">六寸</span>分四，为<span class=\"institution\" title=\"名物\">羽</span>音。"
    },
    "19.6": {
      "title": "仲吕长五寸九分三分二",
      "text": "<span class=\"institution\" title=\"名物\">仲吕</span>长<span class=\"quantity\" title=\"数量\">五寸</span>九分三分二，为<span class=\"institution\" title=\"名物\">徵</span>音。"
    },
    "19.7": {
      "title": "蕤宾长五寸六分三分",
      "text": "<span class=\"institution\" title=\"名物\">蕤宾</span>长<span class=\"quantity\" title=\"数量\">五寸</span>六分三分。"
    },
    "19.8": {
      "title": "林锺长五寸分四",
      "text": "<span class=\"institution\" title=\"名物\">林锺</span>长<span class=\"quantity\" title=\"数量\">五寸</span>分四，为<span class=\"institution\" title=\"名物\">角</span>音。"
    },
    "19.9": {
      "title": "夷则长五寸三分二",
      "text": "<span class=\"institution\" title=\"名物\">夷则</span>长<span class=\"quantity\" title=\"数量\">五寸</span>三分二，为<span class=\"institution\" title=\"名物\">商</span>音。"
    },
    "19.10": {
      "title": "南吕长四寸分八",
      "text": "<span class=\"institution\" title=\"名物\">南吕</span>长<span class=\"quantity\" title=\"数量\">四寸</span>分八，为<span class=\"institution\" title=\"名物\">徵</span>音。"
    },
    "19.11": {
      "title": "无射长四寸四分三分二",
      "text": "<span class=\"institution\" title=\"名物\">无射</span>长<span class=\"quantity\" title=\"数量\">四寸</span>四分三分二。"
    },
    "19.12": {
      "title": "应锺长四寸二分三分二",
      "text": "<span class=\"institution\" title=\"名物\">应锺</span>长<span class=\"quantity\" title=\"数量\">四寸</span>二分三分二，为<span class=\"institution\" title=\"名物\">羽</span>音。"
    },
    "20": {
      "title": "生锺分",
      "text": ""
    },
    "20.1": {
      "title": "生锺分",
      "text": "生锺分："
    },
    "20.2": {
      "title": "子一分",
      "text": "<span class=\"institution\" title=\"名物\">子</span>为一分。"
    },
    "20.3": {
      "title": "丑三分二",
      "text": "<span class=\"institution\" title=\"名物\">丑</span>为三分之二。"
    },
    "20.4": {
      "title": "寅九分八",
      "text": "<span class=\"institution\" title=\"名物\">寅</span>为九分之八。"
    },
    "20.5": {
      "title": "卯二十七分十六",
      "text": "<span class=\"institution\" title=\"名物\">卯</span>为二十七分之十六。"
    },
    "20.6": {
      "title": "辰八十一分六十四",
      "text": "<span class=\"institution\" title=\"名物\">辰</span>为八十一分之六十四。"
    },
    "20.7": {
      "title": "巳二百四十三分一百二十八",
      "text": "<span class=\"institution\" title=\"名物\">巳</span>为二百四十三分之一百二十八。"
    },
    "20.8": {
      "title": "午七百二十九分五百一十二",
      "text": "<span class=\"institution\" title=\"名物\">午</span>为七百二十九分之五百一十二。"
    },
    "20.9": {
      "title": "未二千一百八十七分一千二十四",
      "text": "<span class=\"institution\" title=\"名物\">未</span>为二千一百八十七分之一千二十四。"
    },
    "20.10": {
      "title": "申六千五百六十一分四千九十六",
      "text": "<span class=\"institution\" title=\"名物\">申</span>为六千五百六十一分之四千九十六。"
    },
    "20.11": {
      "title": "酉一万九千六百八十三分八千一百九十二",
      "text": "<span class=\"institution\" title=\"名物\">酉</span>为一万九千六百八十三分之八千一百九十二。"
    },
    "20.12": {
      "title": "戌五万九千四十九分三万二千七百六十八",
      "text": "<span class=\"institution\" title=\"名物\">戌</span>为五万九千四十九分之三万二千七百六十八。"
    },
    "20.13": {
      "title": "亥十七万七千一百四十七分六万五千五百三十六",
      "text": "<span class=\"institution\" title=\"名物\">亥</span>为十七万七千一百四十七分之六万五千五百三十六。"
    },
    "21": {
      "title": "生黄锺术",
      "text": ""
    },
    "21.1": {
      "title": "生黄锺术曰",
      "text": "生<span class=\"institution\" title=\"名物\">黄锺</span>之术如下："
    },
    "21.2": {
      "title": "以下生者",
      "text": "以下生（低生高）的，倍其被除数，三倍其除数。"
    },
    "21.3": {
      "title": "以上生者",
      "text": "以上生（高生低）的，四倍其被除数，三倍其除数。"
    },
    "21.4": {
      "title": "上九商八",
      "text": "上九，<span class=\"institution\" title=\"名物\">商</span>八，<span class=\"institution\" title=\"名物\">羽</span>七，<span class=\"institution\" title=\"名物\">角</span>六，<span class=\"institution\" title=\"名物\">宫</span>五，<span class=\"institution\" title=\"名物\">徵</span>九。"
    },
    "21.5": {
      "title": "置一而九三之以为法",
      "text": "置一而九次以三相乘作为除数。用被除数除以除数，即得长<span class=\"quantity\" title=\"数量\">一寸</span>。"
    },
    "21.6": {
      "title": "黄锺之宫",
      "text": "共得<span class=\"quantity\" title=\"数量\">九寸</span>，命名为\"<span class=\"institution\" title=\"名物\">黄锺之宫</span>\"。"
    },
    "21.7": {
      "title": "音始于宫",
      "text": "所以说音始于<span class=\"institution\" title=\"名物\">宫</span>，穷尽于<span class=\"institution\" title=\"名物\">角</span>；数始于一，终于十，成于三；气始于<span class=\"astronomy\" title=\"天文\">冬至</span>，周而复生。"
    },
    "22": {
      "title": "神形论",
      "text": ""
    },
    "22.1": {
      "title": "神生于无形成于有",
      "text": "神生于无，形成于有，形而后有数，形而成声，所以说神使气，气则就形。"
    },
    "22.2": {
      "title": "形理如类",
      "text": "形之理可依类推。有的未形而未类，有的同形而同类，类而可分别，类而可识辨。"
    },
    "22.3": {
      "title": "圣人识天地之别",
      "text": "<span class=\"identity\" title=\"身份\">圣人</span>知<span class=\"concept\" title=\"思想\">天地</span>识别的法则，所以从有到未有，才能得到细微若气、微妙若声的东西。"
    },
    "22.4": {
      "title": "圣人因神存之",
      "text": "然而<span class=\"identity\" title=\"身份\">圣人</span>因神而存留它，虽然神妙必定求真其情，核其精华之道者明智。"
    },
    "22.5": {
      "title": "存天地之神",
      "text": "没有圣人之心凭借聪明，谁能存留<span class=\"concept\" title=\"思想\">天地</span>之神而成形其情呢？"
    },
    "22.6": {
      "title": "神者物受之",
      "text": "神，是万物承受它而不能知其来去的，所以<span class=\"identity\" title=\"身份\">圣人</span>敬畏并想存留它。"
    },
    "22.7": {
      "title": "唯欲存之",
      "text": "只要想存留它，神也就存留下来。想存留它的心，所以没有比这更可贵的了。"
    },
    "23": {
      "title": "太史公再论",
      "text": "::: 太史公曰 <span class=\"person\" title=\"人名\">太史公</span>说：<span class=\"astronomy\" title=\"天文\">旋玑</span><span class=\"astronomy\" title=\"天文\">玉衡</span>用来齐整<span class=\"astronomy\" title=\"天文\">七政</span>，即<span class=\"astronomy\" title=\"天文\">天地</span>和<span class=\"astronomy\" title=\"天文\">二十八宿</span>。<span class=\"institution\" title=\"名物\">十母</span>、<span class=\"institution\" title=\"名物\">十二子</span>、<span class=\"institution\" title=\"名物\">锺律</span>的调理，来自上古。建立律吕、推运历法、制定日度，都是可以依据来度量的。合于<span class=\"artifact\" title=\"器物\">符节</span>，通达<span class=\"concept\" title=\"思想\">道德</span>，便是由此而言。 :::"
    },
    "24": {
      "title": "赞",
      "text": "::: 赞 自从往昔<span class=\"person\" title=\"人名·规范：黄帝\">轩后（黄帝）</span>，曾命<span class=\"person\" title=\"人名\">伶纶</span>制定乐律。 听辨雌雄之音，使厚薄均衡。 以此调和气候，以此规范星辰。 军队仪容取其节度，<span class=\"artifact\" title=\"器物\">乐器</span>因此而造。 自微小以知显著，测度造化、穷究神妙。 伟大啊虚受之道，含养众生人民。 :::"
    }
  }
}