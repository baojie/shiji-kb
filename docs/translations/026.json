    "37": {
      "title": "历法术语释义\n\n## [37.1] 大馀小馀",
      "text": "右边所列<span class=\"institution\" title=\"名物\">历书</span>：大馀指的是<span class=\"astronomy\" title=\"天文\">日</span>；小馀指的是<span class=\"astronomy\" title=\"天文\">月</span>。"
    },
    "37.2": {
      "title": "端蒙年名",
      "text": "<span class=\"institution\" title=\"名物\">端蒙</span>是年名。"
    },
    "37.3": {
      "title": "地支之名",
      "text": "地支的别名：<span class=\"institution\" title=\"名物\">丑</span>叫<span class=\"institution\" title=\"名物\">赤奋若</span>，<span class=\"institution\" title=\"名物\">寅</span>叫<span class=\"institution\" title=\"名物\">摄提格</span>。"
    },
    "37.4": {
      "title": "天干之名",
      "text": "天干的别名：<span class=\"institution\" title=\"名物\">丙</span>叫<span class=\"institution\" title=\"名物\">游兆</span>。"
    },
    "37.5": {
      "title": "四方与时辰",
      "text": "<span class=\"institution\" title=\"名物\">正北</span>，<span class=\"astronomy\" title=\"天文\">冬至</span>加<span class=\"time\" title=\"时间\">子</span>时；<span class=\"institution\" title=\"名物\">正西</span>，加<span class=\"time\" title=\"时间\">酉</span>时；<span class=\"institution\" title=\"名物\">正南</span>，加<span class=\"time\" title=\"时间\">午</span>时；<span class=\"institution\" title=\"名物\">正东</span>，加<span class=\"time\" title=\"时间\">卯</span>时。"
    },
    "38": {
      "title": "太史公赞",
      "text": "历数的兴起，由来已久。<span class=\"person\" title=\"人名\">重</span>、<span class=\"person\" title=\"人名\">黎</span>曾主管其事，<span class=\"person\" title=\"人名\">容成</span>曾为之纪录。推步<span class=\"astronomy\" title=\"天文\">天象</span>，考察阴阳消长的母子关系。<span class=\"institution\" title=\"名物\">五胜</span>循环往复，<span class=\"institution\" title=\"名物\">三正</span>交替兴起。<span class=\"institution\" title=\"名物\">孟陬</span>之月为岁之本始，<span class=\"identity\" title=\"身份\">畴人</span>谨循正轨。敬谨授时的方法，以校正岁首为美。"
    }
  }
