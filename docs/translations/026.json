{
  "chapter": "026",
  "title": "历书",
  "translations": {
    "1": {
      "title": "历法的起源\n\n## [1.1] 建正于孟春",
      "text": "从远古以来，历法都把一年之首定在<span class=\"time\" title=\"时间\">孟春</span>正月。"
    },
    "1.2": {
      "title": "万物复苏",
      "text": "这时冰雪消融、蛰虫出土，百草勃勃生发，子规鸟率先鸣叫。"
    },
    "1.3": {
      "title": "四时循环",
      "text": "万物按年成熟，生于东方，依次经过<span class=\"time\" title=\"时间\">四时</span>，终于<span class=\"time\" title=\"时间\">冬</span>季的分点。"
    },
    "1.4": {
      "title": "鸡鸣天明",
      "text": "那时鸡叫三遍，天色才大亮。"
    },
    "1.5": {
      "title": "十二节终丑",
      "text": "按顺序调理十二节气，止于<span class=\"institution\" title=\"名物\">丑</span>位。"
    },
    "1.6": {
      "title": "日月生明",
      "text": "<span class=\"astronomy\" title=\"天文\">日月</span>有了运行规律，所以天地才光明。"
    },
    "1.7": {
      "title": "明幽雌雄",
      "text": "明就是\"孟\"（盛壮），幽就是\"幼\"（衰微），幽与明就是雌雄。"
    },
    "1.8": {
      "title": "雌雄代兴",
      "text": "雌雄交替而起，顺应至正的大统。"
    },
    "1.9": {
      "title": "日月东西",
      "text": "<span class=\"astronomy\" title=\"天文\">日</span>归于西方，从东方升起而放光明；<span class=\"astronomy\" title=\"天文\">月</span>归于东方，从西方升起而放光明。"
    },
    "1.10": {
      "title": "正统之本",
      "text": "校正历法若不遵循天象，又不合于人事，那么凡事都容易败坏而难以成功。"
    },
    "2": {
      "title": "王者改正朔",
      "text": "<span class=\"identity\" title=\"身份\">王者</span>改朝换代，必定要慎重对待开国之初，改换<span class=\"institution\" title=\"名物\">正朔</span>，变易<span class=\"institution\" title=\"名物\">服色</span>，推本溯源于上天的元气，顺承天意。"
    },
    "3": {
      "title": "黄帝建历\n\n## [3.1] 神农以前",
      "text": "<span class=\"person\" title=\"人名\">太史公</span>说：<span class=\"person\" title=\"人名\">神农</span>以前的历法已非常久远了。"
    },
    "3.2": {
      "title": "黄帝考定星历",
      "text": "大概<span class=\"person\" title=\"人名\">黄帝</span>考察制定<span class=\"institution\" title=\"名物\">星历</span>，建立<span class=\"institution\" title=\"名物\">五行</span>学说，开启阴阳消长之理，校正<span class=\"institution\" title=\"名物\">闰馀</span>，于是设置了<span class=\"concept\" title=\"思想\">天地</span>、<span class=\"concept\" title=\"思想\">神祇</span>、万物之类的官职，这就是所谓五官。"
    },
    "3.3": {
      "title": "各司其职",
      "text": "各司其序，不相紊乱。"
    },
    "3.4": {
      "title": "民有信神有明",
      "text": "民因此能有信用，神因此能有明德。"
    },
    "3.5": {
      "title": "民神异业",
      "text": "民与神各有其业，相互敬重而不亵渎，所以神降下嘉美的生灵，民以万物奉享，灾祸不生，所求不乏。"
    },
    "4": {
      "title": "颛顼复古\n\n## [4.1] 少昚衰九黎乱",
      "text": "<span class=\"person\" title=\"人名\">少昚氏</span>衰微之时，<span class=\"tribe\" title=\"族群\">九黎</span>扰乱<span class=\"concept\" title=\"思想\">神祇</span>之德，民神混杂错乱，不可放任这样的事物，灾祸频至，万物无不受害、不能尽其天寿。"
    },
    "4.2": {
      "title": "命重黎司天地",
      "text": "<span class=\"person\" title=\"人名\">颛顼</span>承继帝位，就命<span class=\"official\" title=\"官职\">南正</span><span class=\"person\" title=\"人名\">重</span>主管天事、专属神灵，命<span class=\"official\" title=\"官职\">火正</span><span class=\"person\" title=\"人名\">黎</span>主管地事、专属民事，让他们恢复旧有常规，不再相互侵渎。"
    },
    "4.3": {
      "title": "三苗服九黎之德",
      "text": "后来<span class=\"tribe\" title=\"族群\">三苗</span>沿袭<span class=\"tribe\" title=\"族群\">九黎</span>之德，所以重、黎二官都废弃了自己的职责，<span class=\"institution\" title=\"名物\">闰馀</span>错乱失次，<span class=\"institution\" title=\"名物\">孟陬</span>之月失其本位，<span class=\"astronomy\" title=\"天文\">摄提</span>星无法纪录位置，历数因此失去次序。"
    },
    "5": {
      "title": "尧舜继承\n\n## [5.1] 尧用羲和",
      "text": "<span class=\"person\" title=\"人名\">尧</span>又重用<span class=\"person\" title=\"人名\">重</span>、<span class=\"person\" title=\"人名\">黎</span>的后人，不忘旧臣，让他们继续主持，并<span class=\"verb-political\" title=\"政治动词\">立</span>了<span class=\"official\" title=\"官职\">羲和</span>之官。"
    },
    "5.2": {
      "title": "明时正度",
      "text": "昭明时节、订正法度，则<span class=\"concept\" title=\"思想\">阴阳</span>调和，风雨有节，生长之气到来，百姓没有夭亡瘟疫。"
    },
    "5.3": {
      "title": "尧禅舜",
      "text": "<span class=\"person\" title=\"人名\">尧</span>年老禅位给<span class=\"person\" title=\"人名\">舜</span>，在<span class=\"place\" title=\"地名\">文祖</span>庙郑重告诫他，说\"天的历数就在你身上\"。"
    },
    "5.4": {
      "title": "舜命禹",
      "text": "<span class=\"person\" title=\"人名\">舜</span>也同样以此命托付给<span class=\"person\" title=\"人名\">禹</span>。"
    },
    "5.5": {
      "title": "王者所重",
      "text": "由此看来，历数确为<span class=\"identity\" title=\"身份\">王者</span>所重视之事。"
    },
    "6": {
      "title": "三代正朔\n\n## [6.1] 夏殷周正朔",
      "text": "<span class=\"feudal-state\" title=\"邦国\">夏</span>以<span class=\"time\" title=\"时间\">正月</span>为岁首，<span class=\"feudal-state\" title=\"邦国\">殷</span>以<span class=\"time\" title=\"时间\">十二月</span>为岁首，<span class=\"feudal-state\" title=\"邦国\">周</span>以<span class=\"time\" title=\"时间\">十一月</span>为岁首。"
    },
    "6.2": {
      "title": "三王循环",
      "text": "大概<span class=\"feudal-state\" title=\"邦国\">三王</span>的正朔如同循环往复，穷尽则返回根本。"
    },
    "6.3": {
      "title": "天下有道",
      "text": "<span class=\"concept\" title=\"思想\">天下</span>有道，则纪序不失；无道，则<span class=\"institution\" title=\"名物\">正朔</span>不通行于<span class=\"identity\" title=\"身份\">诸侯</span>。"
    },
    "7": {
      "title": "周室衰微\n\n## [7.1] 畴人子弟分散",
      "text": "<span class=\"person\" title=\"人名\">幽</span>王、<span class=\"person\" title=\"人名\">厉</span>王之后，<span class=\"feudal-state\" title=\"邦国\">周</span>室衰微，<span class=\"identity\" title=\"身份\">陪臣</span><span class=\"official\" title=\"官职\">执政</span>把持朝政，史官不记时日，国君不告朔于庙，所以掌管历法的<span class=\"identity\" title=\"身份\">畴人</span><span class=\"identity\" title=\"身份\">子弟</span>四散各处，或在中原诸国，或流落于夷狄，因此祥瑞之事废弃而不再统一。"
    },
    "7.2": {
      "title": "周襄王闰三月",
      "text": "<span class=\"person\" title=\"人名\">周襄王</span><span class=\"time\" title=\"时间\">二十六年</span>设<span class=\"time\" title=\"时间\">闰三月</span>，而<span class=\"book\" title=\"典籍\">春秋</span>加以批评。"
    },
    "7.3": {
      "title": "先王正时法",
      "text": "<span class=\"identity\" title=\"身份\">先王</span>校正时令的方法是：以冬至为一岁之始、为历法的起点，以二分二至时正于中气之月，把岁馀归入岁终的闰月。"
    },
    "7.4": {
      "title": "三则各有其效",
      "text": "起点正确，则次序不乱；中气正确，则民不迷惑；岁馀归于岁终，则万事不悖乱。"
    },
    "8": {
      "title": "战国与邹衍\n\n## [8.1] 战国无暇",
      "text": "其后<span class=\"feudal-state\" title=\"邦国\">战国</span>并争，各国只求强国擒敌、救急解纷而已，哪里有闲暇顾及历法呢！"
    },
    "8.2": {
      "title": "邹衍显于诸侯",
      "text": "这时只有<span class=\"person\" title=\"人名\">邹衍</span>，通晓<span class=\"institution\" title=\"名物\">五德之传</span>，阐发阴阳消长的分理，因而显名于<span class=\"identity\" title=\"身份\">诸侯</span>。"
    },
    "9": {
      "title": "秦代改历\n\n## [9.1] 秦灭六国无暇",
      "text": "而秦朝也因<span class=\"feudal-state\" title=\"邦国\">秦</span><span class=\"legal\" title=\"刑法\">灭</span><span class=\"institution\" title=\"名物\">六国</span>、兵事极为繁忙，又登至尊之位时日尚浅，无暇顾及历法。"
    },
    "9.2": {
      "title": "秦自谓水德",
      "text": "秦也颇推崇<span class=\"institution\" title=\"名物\">五胜</span>之说，自以为获得<span class=\"institution\" title=\"名物\">水德</span>的祥瑞，把<span class=\"place\" title=\"地名\">河</span>水改名叫\"<span class=\"place\" title=\"地名\">德水</span>\"，以<span class=\"time\" title=\"时间\">十月</span>为岁首，崇尚黑色。"
    },
    "9.3": {
      "title": "闰馀未真",
      "text": "但推算历度<span class=\"institution\" title=\"名物\">闰馀</span>，还不能见到它真正的规律。"
    },
    "10": {
      "title": "汉初沿秦制\n\n## [10.1] 高祖自谓水德",
      "text": "<span class=\"feudal-state\" title=\"邦国\">汉</span>朝兴起，<span class=\"person\" title=\"人名\">高祖</span>说\"<span class=\"place\" title=\"地名\">北畤</span>是等我来兴建的\"，也自以为获得<span class=\"institution\" title=\"名物\">水德</span>的祥瑞。"
    },
    "10.2": {
      "title": "张苍认同",
      "text": "尽管精通历法的人以及<span class=\"person\" title=\"人名\">张苍</span>等人，都认为是这样。"
    },
    "10.3": {
      "title": "袭秦正朔",
      "text": "那时<span class=\"concept\" title=\"思想\">天下</span>刚刚安定，正在整顿大纲大纪，<span class=\"person\" title=\"人名\">高后</span>以女主当政，都无暇顾及此事，所以<span class=\"legal\" title=\"刑法\">袭</span>用<span class=\"feudal-state\" title=\"邦国\">秦</span>的<span class=\"institution\" title=\"名物\">正朔</span>和<span class=\"institution\" title=\"名物\">服色</span>。"
    },
    "11": {
      "title": "公孙臣建议与黄龙之瑞\n\n## [11.1] 公孙臣上书",
      "text": "到<span class=\"person\" title=\"人名\">孝文</span>帝时，<span class=\"place\" title=\"地名\">鲁</span>地人<span class=\"person\" title=\"人名\">公孙臣</span>以<span class=\"institution\" title=\"名物\">终始五德</span>之说上书，说\"<span class=\"feudal-state\" title=\"邦国\">汉</span>得<span class=\"institution\" title=\"名物\">土德</span>，应当改元，更改<span class=\"institution\" title=\"名物\">正朔</span>，变易<span class=\"institution\" title=\"名物\">服色</span>。应当有祥瑞出现，那祥瑞就是<span class=\"mythical\" title=\"神话\">黄龙</span>出现\"。"
    },
    "11.2": {
      "title": "张苍驳回",
      "text": "事情交付<span class=\"official\" title=\"官职\">丞相</span><span class=\"person\" title=\"人名\">张苍</span>处理，<span class=\"person\" title=\"人名\">张苍</span>也学过<span class=\"institution\" title=\"名物\">律历</span>，认为不对，废止了此议。"
    },
    "11.3": {
      "title": "黄龙现成纪",
      "text": "后来<span class=\"mythical\" title=\"神话\">黄龙</span>出现于<span class=\"place\" title=\"地名\">成纪</span>，<span class=\"person\" title=\"人名\">张苍</span>自请罢免，他打算撰写的论著也没写成。"
    },
    "11.4": {
      "title": "新垣平作乱",
      "text": "而<span class=\"person\" title=\"人名\">新垣平</span>以<span class=\"institution\" title=\"名物\">望气</span>之术进见文帝，颇多谈论订正历法、<span class=\"institution\" title=\"名物\">服色</span>之事，受到尊宠，后来作乱被诛，所以<span class=\"person\" title=\"人名\">孝文帝</span>废置此议，不再过问。"
    },
    "12": {
      "title": "太初改元\n\n## [12.1] 唐都落下闳",
      "text": "到<span class=\"identity\" title=\"身份\">今上</span>即位，召来<span class=\"institution\" title=\"名物\">方士</span><span class=\"person\" title=\"人名\">唐都</span>，分别天上诸星的部位；而巴郡人<span class=\"person\" title=\"人名\">落下闳</span>负责运算推演历法，然后<span class=\"astronomy\" title=\"天文\">日辰</span>的度数与<span class=\"feudal-state\" title=\"邦国\">夏</span>朝正朔相合。"
    },
    "12.2": {
      "title": "改元封禅",
      "text": "于是改元，更换官号，封禅于<span class=\"place\" title=\"地名\">泰山</span>。"
    },
    "12.3": {
      "title": "诏御史",
      "text": "因而下诏给<span class=\"official\" title=\"官职\">御史</span>说：\"近来，<span class=\"official\" title=\"官职\">有司</span>说<span class=\"astronomy\" title=\"天文\">星度</span>没有校定，我广为延请询问，以审理<span class=\"astronomy\" title=\"天文\">星度</span>，还未能完全了解。"
    },
    "13": {
      "title": "黄帝历法传统\n\n## [13.1] 黄帝合而不死",
      "text": "听说昔日<span class=\"person\" title=\"人名\">黄帝</span>调和阴阳而长生不死，名察历数、验证时令，厘定清浊二气，创立<span class=\"institution\" title=\"名物\">五部</span>之历，建立节气与物候的分数。"
    },
    "13.2": {
      "title": "其事久远",
      "text": "然而此事实在久远了。"
    },
    "13.3": {
      "title": "书缺乐弛",
      "text": "典籍缺失、礼乐废弛，<span class=\"identity\" title=\"身份\">朕</span>深感忧虑。"
    },
    "13.4": {
      "title": "循明水德",
      "text": "<span class=\"identity\" title=\"身份\">朕</span>还不能遵循并昭明历数，只能积累日分之差，大致顺应<span class=\"institution\" title=\"名物\">水德</span>所胜之理。"
    },
    "14": {
      "title": "太初历法原则\n\n## [14.1] 五音与日至",
      "text": "<span class=\"time\" title=\"时间\">今日</span>正值<span class=\"astronomy\" title=\"天文\">夏至</span>，<span class=\"artifact\" title=\"器物\">黄钟</span>为宫音，<span class=\"artifact\" title=\"器物\">林钟</span>为徵音，<span class=\"artifact\" title=\"器物\">太蔟</span>为商音，<span class=\"artifact\" title=\"器物\">南吕</span>为羽音，<span class=\"artifact\" title=\"器物\">姑洗</span>为角音。"
    },
    "14.2": {
      "title": "阴阳离合",
      "text": "自此以后，气候重新归正，羽声重新清越，名实重新订正变化，以至于<span class=\"time\" title=\"时间\">子日</span>当<span class=\"astronomy\" title=\"天文\">冬至</span>，那么<span class=\"concept\" title=\"思想\">阴阳</span>离合之道便得以运行。"
    },
    "15": {
      "title": "改元宣告\n\n## [15.1] 更元为太初",
      "text": "<span class=\"time\" title=\"时间\">十一月</span><span class=\"time\" title=\"时间\">甲子</span>日<span class=\"time\" title=\"时间\">朔旦</span>之时，<span class=\"time\" title=\"时间\">冬至</span>已可推定，兹改以<span class=\"time\" title=\"时间\">七年</span>为<span class=\"time\" title=\"时间\">太初元年</span>。"
    },
    "15.2": {
      "title": "年名月名日名",
      "text": "年名叫'<span class=\"institution\" title=\"名物\">焉逢</span><span class=\"institution\" title=\"名物\">摄提格</span>'，月名叫'<span class=\"institution\" title=\"名物\">毕聚</span>'，日得<span class=\"time\" title=\"时间\">甲子</span>日，合于<span class=\"institution\" title=\"名物\">夜半朔旦冬至</span>。\""
    },
    "16": {
      "title": "太初元年标识",
      "text": "<span class=\"time\" title=\"时间\">太初元年</span>，岁名叫\"<span class=\"institution\" title=\"名物\">焉逢</span><span class=\"institution\" title=\"名物\">摄提格</span>\"，月名叫\"<span class=\"institution\" title=\"名物\">毕聚</span>\"，日得<span class=\"time\" title=\"时间\">甲子</span>日，合于<span class=\"institution\" title=\"名物\">夜半朔旦冬至</span>。"
    },
    "17": {
      "title": "太初纪年\n\n## [17.1] 正北方位",
      "text": "<span class=\"institution\" title=\"名物\">正北</span>方位。"
    },
    "17.2": {
      "title": "太初元年数值",
      "text": "十二个月，无大馀，无小馀；无大馀，无小馀；"
    },
    "17.3": {
      "title": "太初元年",
      "text": "<span class=\"institution\" title=\"名物\">焉逢</span><span class=\"institution\" title=\"名物\">摄提格</span><span class=\"time\" title=\"时间\">太初元年</span>。"
    },
    "17.4": {
      "title": "太初二年月数",
      "text": "十二个月。"
    },
    "17.5": {
      "title": "太初二年数值",
      "text": "大馀五十四，小馀三百四十八；大馀五，小馀八；"
    },
    "17.6": {
      "title": "太初二年",
      "text": "<span class=\"institution\" title=\"名物\">端蒙</span><span class=\"institution\" title=\"名物\">单阏</span><span class=\"time\" title=\"时间\">二年</span>。"
    },
    "17.7": {
      "title": "太初三年月数",
      "text": "闰年十三个月。"
    },
    "17.8": {
      "title": "太初三年数值",
      "text": "大馀四十八，小馀六百九十六；大馀十，小馀十六；"
    },
    "17.9": {
      "title": "太初三年",
      "text": "<span class=\"institution\" title=\"名物\">游兆</span><span class=\"institution\" title=\"名物\">执徐</span><span class=\"time\" title=\"时间\">三年</span>。"
    },
    "17.10": {
      "title": "太初四年月数",
      "text": "十二个月。"
    },
    "17.11": {
      "title": "太初四年数值",
      "text": "大馀十二，小馀六百三；大馀十五，小馀二十四；"
    },
    "17.12": {
      "title": "太初四年",
      "text": "<span class=\"institution\" title=\"名物\">彊梧</span><span class=\"institution\" title=\"名物\">大荒落</span><span class=\"time\" title=\"时间\">四年</span>。"
    },
    "18": {
      "title": "天汉纪年\n\n## [18.1] 天汉元年月数",
      "text": "十二个月。"
