{
  "chapter": "082",
  "title": "田单列传",
  "translations": {
    "1": {
      "title": "",
      "text": ""
    },
    "1.1": {
      "title": "田单出身",
      "text": "<span class=\"person\" title=\"人名\">田单</span>，是<span class=\"feudal-state\" title=\"邦国\">齐</span>国<span class=\"dynasty\" title=\"氏族\">田</span>氏的远房族人。"
    },
    "1.2": {
      "title": "初为市掾",
      "text": "<span class=\"time\" title=\"时间·规范：时代\">湣王时（时代）</span>，<span class=\"person\" title=\"人名·规范：田单\">单（田单）</span>担任<span class=\"place\" title=\"地名\">临菑</span>的<span class=\"official\" title=\"官职\">市掾</span>，不被人所知。"
    },
    "2": {
      "title": "",
      "text": ""
    },
    "2.1": {
      "title": "乐毅破齐",
      "text": "等到<span class=\"feudal-state\" title=\"邦国\">燕</span>国派<span class=\"person\" title=\"人名\">乐毅</span><span class=\"verb-military\" title=\"军事动词\">讨伐</span>并<span class=\"verb-military\" title=\"军事动词\">攻破</span><span class=\"feudal-state\" title=\"邦国\">齐</span>国，<span class=\"person\" title=\"人名\">齐湣王</span>出逃，随即退保<span class=\"place\" title=\"地名\">莒</span>城。"
    },
    "2.2": {
      "title": "田单备车走安平",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>军长驱直入平定<span class=\"feudal-state\" title=\"邦国\">齐</span>国，而<span class=\"person\" title=\"人名\">田单</span>逃到<span class=\"place\" title=\"地名\">安平</span>，命令他的<span class=\"identity\" title=\"身份\">宗人</span>把<span class=\"artifact\" title=\"器物\">车</span><span class=\"artifact\" title=\"器物\">轴</span>末端都锯短并包上<span class=\"artifact\" title=\"器物\">铁笼</span>。"
    },
    "2.3": {
      "title": "田单脱身至即墨",
      "text": "不久<span class=\"feudal-state\" title=\"邦国\">燕</span>军<span class=\"verb-military\" title=\"军事动词\">攻</span>打<span class=\"place\" title=\"地名\">安平</span>，城墙崩坏，<span class=\"feudal-state\" title=\"邦国\">齐</span>人逃走，争抢道路，因为车轴<span class=\"artifact\" title=\"器物\">轊</span>折断使<span class=\"artifact\" title=\"器物\">车</span>损<span class=\"verb-military\" title=\"军事动词\">坏</span>，被<span class=\"feudal-state\" title=\"邦国\">燕</span>军所<span class=\"verb-military\" title=\"军事动词\">俘虏</span>，只有<span class=\"person\" title=\"人名\">田单</span>的<span class=\"identity\" title=\"身份\">宗人</span>因为<span class=\"artifact\" title=\"器物\">铁笼</span>的缘故得以逃脱，向东退保<span class=\"place\" title=\"地名\">即墨</span>。"
    },
    "2.4": {
      "title": "燕下齐城唯莒即墨不下",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>军已经使<span class=\"feudal-state\" title=\"邦国\">齐</span>国的城邑全部<span class=\"verb-military\" title=\"军事动词\">投降</span>，只有<span class=\"place\" title=\"地名\">莒</span>、<span class=\"place\" title=\"地名\">即墨</span>没有攻下。"
    },
    "2.5": {
      "title": "燕兵围莒",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>军听说<span class=\"person\" title=\"人名\">齐王</span>在<span class=\"place\" title=\"地名\">莒</span>，集中兵力<span class=\"verb-military\" title=\"军事动词\">攻</span>打那里。"
    },
    "2.6": {
      "title": "淖齿杀湣王",
      "text": "<span class=\"person\" title=\"人名\">淖齿</span>既已<span class=\"verb-penalty\" title=\"刑罚动词\">杀</span><span class=\"person\" title=\"人名·规范：齐湣王\">湣王（齐湣王）</span>于<span class=\"place\" title=\"地名\">莒</span>，于是齐人坚守，抵抗<span class=\"feudal-state\" title=\"邦国\">燕</span>军，<span class=\"time\" title=\"时间·规范：时长\">数年（时长）</span>没有被攻下。"
    },
    "2.7": {
      "title": "即墨大夫战死",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>军引兵向东<span class=\"verb-military\" title=\"军事动词\">围攻</span><span class=\"place\" title=\"地名\">即墨</span>，<span class=\"place\" title=\"地名\">即墨</span>的<span class=\"identity\" title=\"身份\">大夫</span>出城<span class=\"verb-military\" title=\"军事动词\">应战</span>，<span class=\"verb-military\" title=\"军事动词\">战</span>死。"
    },
    "2.8": {
      "title": "城中推田单",
      "text": "城中人共同推举<span class=\"person\" title=\"人名\">田单</span>，说： \"<span class=\"place\" title=\"地名\">安平</span>之<span class=\"verb-military\" title=\"军事动词\">战</span>，<span class=\"person\" title=\"人名\">田单</span>的<span class=\"identity\" title=\"身份\">宗人</span>因<span class=\"artifact\" title=\"器物\">铁笼</span>得以保全，熟习军事。\""
    },
    "2.9": {
      "title": "立为将军",
      "text": "就立他为<span class=\"official\" title=\"官职\">将军</span>，以<span class=\"place\" title=\"地名\">即墨</span>抵抗<span class=\"feudal-state\" title=\"邦国\">燕</span>国。"
    },
    "3": {
      "title": "",
      "text": ""
    },
    "3.1": {
      "title": "燕惠王即位",
      "text": "不久，<span class=\"person\" title=\"人名\">燕昭王</span>去世，<span class=\"person\" title=\"人名·规范：燕惠王\">惠王（燕惠王）</span>即位，与<span class=\"person\" title=\"人名\">乐毅</span>有嫌隙。"
    },
    "3.2": {
      "title": "田单纵反间",
      "text": "<span class=\"person\" title=\"人名\">田单</span>听说后，就在<span class=\"feudal-state\" title=\"邦国\">燕</span>国散布<span class=\"legal\" title=\"刑法\">反间</span>之言，公开宣扬说： \"<span class=\"person\" title=\"人名\">齐王</span>已死，齐国没攻下的城邑只剩两座了。<span class=\"person\" title=\"人名\">乐毅</span>害怕被<span class=\"verb-penalty\" title=\"刑罚动词\">诛</span>杀不敢回国，借<span class=\"verb-military\" title=\"军事动词\">讨伐</span><span class=\"feudal-state\" title=\"邦国\">齐</span>国为名，实际上想拖延战争，在南面称王于<span class=\"feudal-state\" title=\"邦国\">齐</span>国。<span class=\"feudal-state\" title=\"邦国\">齐</span>人尚未归附，所以暂缓<span class=\"verb-military\" title=\"军事动词\">攻</span><span class=\"place\" title=\"地名\">即墨</span>以等待时机。<span class=\"feudal-state\" title=\"邦国\">齐</span>人所害怕的，只怕其他将领来，<span class=\"place\" title=\"地名\">即墨</span>就要被[摧毁了。\""
    },
    "3.3": {
      "title": "燕王中计",
      "text": "<span class=\"person\" title=\"人名\">燕王</span>信以为真，派<span class=\"person\" title=\"人名\">骑劫</span>代替<span class=\"person\" title=\"人名\">乐毅</span>。"
    },
    "4": {
      "title": "",
      "text": ""
    },
    "4.1": {
      "title": "乐毅归赵",
      "text": "<span class=\"person\" title=\"人名\">乐毅</span>因此归向<span class=\"feudal-state\" title=\"邦国\">赵</span>国，<span class=\"feudal-state\" title=\"邦国\">燕</span>人<span class=\"identity\" title=\"身份\">士</span>卒愤愤不平。"
    },
    "4.2": {
      "title": "祭祖诱鸟",
      "text": "而<span class=\"person\" title=\"人名\">田单</span>就命令城中人吃饭时必在庭院中<span class=\"institution\" title=\"名物\">祭祀</span><span class=\"identity\" title=\"身份\">先祖</span>，飞<span class=\"biology\" title=\"生物\">鸟</span>都盘旋在城中下来啄食。"
    },
    "4.3": {
      "title": "燕人生疑",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>人对此感到奇怪。"
    },
    "4.4": {
      "title": "田单称神师",
      "text": "<span class=\"person\" title=\"人名\">田单</span>趁机宣扬说： \"有神来下凡教导我。\""
    },
    "4.5": {
      "title": "令士卒传神师之说",
      "text": "就对城中人说： \"将会有<span class=\"concept\" title=\"思想\">神人</span>做我的军师。\""
    },
    "4.6": {
      "title": "卒自请为师",
      "text": "有一个<span class=\"identity\" title=\"身份\">士</span>卒说： \"<span class=\"identity\" title=\"身份\">臣</span>可以做军师吗？\""
    },
    "4.7": {
      "title": "卒反走",
      "text": "说完就反身逃走。"
    },
    "4.8": {
      "title": "田单引还师事之",
      "text": "<span class=\"person\" title=\"人名\">田单</span>起身，把他引回来，让他朝东坐着，像师长一样侍奉他。"
    },
    "4.9": {
      "title": "卒自认无能",
      "text": "<span class=\"identity\" title=\"身份\">士</span>卒说： \"<span class=\"identity\" title=\"身份\">臣</span>欺骗了<span class=\"identity\" title=\"身份\">君</span>，实在没有什么才能。\""
    },
    "4.10": {
      "title": "田单止其言",
      "text": "<span class=\"person\" title=\"人名\">田单</span>说： \"<span class=\"identity\" title=\"身份\">子</span>不要说出来！\""
    },
    "4.11": {
      "title": "每出号令必称神师",
      "text": "就奉他为师。每次发布号令，必称是神师所说。"
    },
    "4.12": {
      "title": "宣言燕军劓齐卒",
      "text": "就又宣扬说： \"我只怕<span class=\"feudal-state\" title=\"邦国\">燕</span>军将俘获的<span class=\"feudal-state\" title=\"邦国\">齐</span>卒<span class=\"legal\" title=\"刑法\">割鼻</span>，置于阵前，与我军<span class=\"verb-military\" title=\"军事动词\">作战</span>，<span class=\"place\" title=\"地名\">即墨</span>就会<span class=\"verb-military\" title=\"军事动词\">败</span>了。\""
    },
    "4.13": {
      "title": "燕人果然",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>人听了，果真照做。"
    },
    "4.14": {
      "title": "齐人坚守",
      "text": "城中人看见<span class=\"feudal-state\" title=\"邦国\">齐</span>国那些<span class=\"verb-military\" title=\"军事动词\">投降</span>的人都被<span class=\"legal\" title=\"刑法\">割鼻</span>，都愤怒不已，更加坚守，唯恐被俘。"
    },
    "4.15": {
      "title": "再纵反间掘墓",
      "text": "<span class=\"person\" title=\"人名·规范：田单\">单（田单）</span>又散布<span class=\"legal\" title=\"刑法\">反间</span>说： \"我怕<span class=\"feudal-state\" title=\"邦国\">燕</span>人<span class=\"legal\" title=\"刑法\">挖掘</span>城外的坟墓，◉侮辱<span class=\"identity\" title=\"身份\">先人</span>，令人寒心。\""
    },
    "4.16": {
      "title": "燕军掘墓烧尸",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>军全部<span class=\"verb-military\" title=\"军事动词\">挖</span>掘坟墓，<span class=\"verb-military\" title=\"军事动词\">焚烧</span>死尸。"
    },
    "4.17": {
      "title": "齐人怒十倍",
      "text": "<span class=\"place\" title=\"地名\">即墨</span>人从城上望见，都涕泪横流，都想出<span class=\"verb-military\" title=\"军事动词\">战</span>，愤怒自然倍增十倍。"
    },
    "5": {
      "title": "",
      "text": ""
    },
    "5.1": {
      "title": "田单与士卒同甘",
      "text": "<span class=\"person\" title=\"人名\">田单</span>知道<span class=\"identity\" title=\"身份\">士</span>卒可用，就亲自拿着<span class=\"artifact\" title=\"器物\">版插</span>，与<span class=\"identity\" title=\"身份\">士</span>卒分担劳作，把<span class=\"identity\" title=\"身份\">妻妾</span>编入行伍之中，把所有饮食都分给<span class=\"identity\" title=\"身份\">士</span>兵享用。"
    },
    "5.2": {
      "title": "诈降之计",
      "text": "命令全副武装的甲兵都埋伏起来，让<span class=\"identity\" title=\"身份\">老弱</span><span class=\"identity\" title=\"身份\">女子</span>登上城墙守卫，派使者去与<span class=\"feudal-state\" title=\"邦国\">燕</span>国约定<span class=\"verb-military\" title=\"军事动词\">投降</span>，<span class=\"feudal-state\" title=\"邦国\">燕</span>军都高呼<span class=\"time\" title=\"时间·规范：时长\">万年（时长）</span>。"
    },
    "5.3": {
      "title": "富豪遗燕将",
      "text": "<span class=\"person\" title=\"人名\">田单</span>又收集<span class=\"identity\" title=\"身份\">民</span>间黄金，得<span class=\"quantity\" title=\"数量\">千溢</span>，让<span class=\"place\" title=\"地名\">即墨</span>的<span class=\"identity\" title=\"身份\">富豪</span>赠送给<span class=\"feudal-state\" title=\"邦国\">燕</span>军将领，说： \"<span class=\"place\" title=\"地名\">即墨</span>如果<span class=\"verb-military\" title=\"军事动词\">投降</span>，希望不要<span class=\"verb-military\" title=\"军事动词\">俘</span>[掠夺我们◉家族的<span class=\"identity\" title=\"身份\">妻妾</span>，让我们安居。\""
    },
    "5.4": {
      "title": "燕将许之",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>军将领非常高兴，答应了。"
    },
    "5.5": {
      "title": "燕军益懈",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>军因此更加松懈。"
    },
    "6": {
      "title": "",
      "text": ""
    },
    "6.1": {
      "title": "束兵刃于牛角",
      "text": "<span class=\"person\" title=\"人名\">田单</span>就从城中收集了<span class=\"quantity\" title=\"数量\">千馀</span>头<span class=\"biology\" title=\"生物\">牛</span>，为它们做<span class=\"artifact\" title=\"器物\">绛缯衣</span>，画上五彩<span class=\"biology\" title=\"生物\">龙</span>的花纹，在牛角上绑上<span class=\"artifact\" title=\"器物\">兵刃</span>，在牛尾灌上油<span class=\"artifact\" title=\"器物\">脂</span>束上<span class=\"biology\" title=\"生物\">芦苇</span>，<span class=\"legal\" title=\"刑法\">点燃</span>芦苇末端。"
    },
    "6.2": {
      "title": "凿城穴夜纵牛",
      "text": "凿开城墙<span class=\"quantity\" title=\"数量\">数十</span>个洞穴，夜里放出<span class=\"biology\" title=\"生物\">牛</span>，<span class=\"identity\" title=\"身份\">壮士</span><span class=\"quantity\" title=\"数量\">五千人</span>跟在牛后面。"
    },
    "6.3": {
      "title": "牛奔燕军",
      "text": "<span class=\"biology\" title=\"生物\">牛</span>尾火热，狂怒奔向<span class=\"feudal-state\" title=\"邦国\">燕</span>军，<span class=\"feudal-state\" title=\"邦国\">燕</span>军夜中大惊。"
    },
    "6.4": {
      "title": "炬火炫耀",
      "text": "<span class=\"biology\" title=\"生物\">牛</span>尾的<span class=\"artifact\" title=\"器物\">炬火</span>光芒炫耀，<span class=\"feudal-state\" title=\"邦国\">燕</span>军看到牛身上都是<span class=\"biology\" title=\"生物\">龙</span>纹，被冲撞到的都死伤。"
    },
    "6.5": {
      "title": "五千人击之",
      "text": "<span class=\"quantity\" title=\"数量\">五千人</span>趁机衔枚<span class=\"artifact\" title=\"器物\">枚</span><span class=\"verb-military\" title=\"军事动词\">攻击</span>敌人，城中擂鼓呼喊跟随而上，<span class=\"identity\" title=\"身份\">老弱</span>都<span class=\"verb-military\" title=\"军事动词\">敲击</span><span class=\"artifact\" title=\"器物\">铜器</span>发出声响，声音震动<span class=\"astronomy\" title=\"天文\">天地</span>。"
    },
    "6.6": {
      "title": "燕军败走",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>军大惊，<span class=\"verb-military\" title=\"军事动词\">溃败</span>而走。"
    },
    "6.7": {
      "title": "齐人杀骑劫",
      "text": "<span class=\"feudal-state\" title=\"邦国\">齐</span>人于是<span class=\"verb-penalty\" title=\"刑罚动词\">击杀</span>了燕将<span class=\"person\" title=\"人名\">骑劫</span>。"
    },
    "6.8": {
      "title": "尽复齐七十城",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>军慌乱奔逃，<span class=\"feudal-state\" title=\"邦国\">齐</span>人<span class=\"verb-military\" title=\"军事动词\">追</span>击逃兵<span class=\"verb-military\" title=\"军事动词\">追逐</span>败北，所过的城邑都背叛<span class=\"feudal-state\" title=\"邦国\">燕</span>国而归附<span class=\"person\" title=\"人名\">田单</span>，兵力日益增多，乘胜追击，<span class=\"feudal-state\" title=\"邦国\">燕</span>军日益<span class=\"verb-military\" title=\"军事动词\">溃败</span>，最终退到<span class=\"place\" title=\"地名\">黄河</span>边上，而<span class=\"feudal-state\" title=\"邦国\">齐</span>国<span class=\"quantity\" title=\"数量\">七十馀城</span>都重新归为<span class=\"feudal-state\" title=\"邦国\">齐</span>国所有。"
    },
    "6.9": {
      "title": "迎襄王入临菑",
      "text": "就在<span class=\"place\" title=\"地名\">莒</span>迎接<span class=\"person\" title=\"人名·规范：齐襄王\">襄王（齐襄王）</span>，进入<span class=\"place\" title=\"地名\">临菑</span>而执政。"
    },
    "7": {
      "title": "",
      "text": ""
    },
    "7.1": {
      "title": "封安平君",
      "text": "<span class=\"person\" title=\"人名·规范：齐襄王\">襄王（齐襄王）</span><span class=\"verb-political\" title=\"政治动词\">封</span><span class=\"person\" title=\"人名\">田单</span>，封号为<span class=\"official\" title=\"官职\">安平君</span>。"
    },
    "8": {
      "title": "太史公曰",
      "text": "<span class=\"person\" title=\"人名\">太史公</span>说：用兵以正面接战，以奇计取胜。 善用兵的人，出奇制胜无穷无尽。 奇正相互转化相生，如圆环之没有尽头。 起初像处<span class=\"identity\" title=\"身份\">女</span>一样柔弱，诱使敌人打开门户；后来如脱逃的<span class=\"biology\" title=\"生物\">兔</span>子一样迅捷，敌人来不及抵挡：这说的就是<span class=\"person\" title=\"人名\">田单</span>吧！"
    },
    "9": {
      "title": "",
      "text": ""
    },
    "9.1": {
      "title": "法章灌园",
      "text": "当初，<span class=\"person\" title=\"人名\">淖齿</span><span class=\"verb-penalty\" title=\"刑罚动词\">杀</span><span class=\"person\" title=\"人名·规范：齐湣王\">湣王（齐湣王）</span>时，<span class=\"place\" title=\"地名\">莒</span>人寻找<span class=\"person\" title=\"人名·规范：齐湣王\">湣王（齐湣王）</span>的儿子<span class=\"person\" title=\"人名\">法章</span>，在<span class=\"official\" title=\"官职\">太史</span><span class=\"person\" title=\"人名\">嬓</span>的家中找到他，他正在为人灌园。"
    },
    "9.2": {
      "title": "嬓女善遇之",
      "text": "<span class=\"person\" title=\"人名\">嬓</span>的女儿怜悯而善待他。"
    },
    "9.3": {
      "title": "法章告之以情",
      "text": "后来<span class=\"person\" title=\"人名\">法章</span>私下告诉了女子实情，女子就与他私通。"
    },
    "9.4": {
      "title": "君王后",
      "text": "等到<span class=\"place\" title=\"地名\">莒</span>人共同<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"person\" title=\"人名\">法章</span>为<span class=\"person\" title=\"人名\">齐王</span>，以<span class=\"place\" title=\"地名\">莒</span>抵抗<span class=\"feudal-state\" title=\"邦国\">燕</span>国，而<span class=\"person\" title=\"人名\">太史氏</span>之女就成了<span class=\"identity\" title=\"身份\">皇后</span>，就是所谓的\"<span class=\"person\" title=\"人名\">君王后</span>\"。"
    },
    "10": {
      "title": "",
      "text": ""
    },
    "10.1": {
      "title": "燕围画邑避王蠋",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>军刚入<span class=\"feudal-state\" title=\"邦国\">齐</span>国时，听说<span class=\"place\" title=\"地名\">画邑</span>人<span class=\"person\" title=\"人名\">王蠋</span>贤能，就在军中下令：\"环绕<span class=\"place\" title=\"地名\">画邑</span><span class=\"quantity\" title=\"数量\">三十里</span>内不得进入。\"这是因为<span class=\"person\" title=\"人名\">王蠋</span>的缘故。"
    },
    "10.2": {
      "title": "燕招王蠋为将",
      "text": "不久派人对<span class=\"person\" title=\"人名·规范：王蠋\">蠋（王蠋）</span>说： \"<span class=\"feudal-state\" title=\"邦国\">齐</span>人多崇尚<span class=\"identity\" title=\"身份\">子</span>之义，我想任用<span class=\"identity\" title=\"身份\">子</span>为将，封<span class=\"identity\" title=\"身份\">子</span><span class=\"quantity\" title=\"数量\">万户</span>。\""
    },
    "10.3": {
      "title": "王蠋固辞",
      "text": "<span class=\"person\" title=\"人名·规范：王蠋\">蠋（王蠋）</span>坚决推辞。"
    },
    "10.4": {
      "title": "燕人威胁屠城",
      "text": "<span class=\"feudal-state\" title=\"邦国\">燕</span>人说： \"<span class=\"identity\" title=\"身份\">子</span>不听从，我就率三军<span class=\"verb-military\" title=\"军事动词\">屠</span>灭<span class=\"place\" title=\"地名\">画邑</span>。\""
    },
    "10.5": {
      "title": "王蠋殉节",
      "text": "<span class=\"person\" title=\"人名\">王蠋</span>说： \"<span class=\"identity\" title=\"身份\">忠臣</span>不事奉两位<span class=\"identity\" title=\"身份\">君</span>主，贞<span class=\"identity\" title=\"身份\">女</span>不改嫁两个丈夫。<span class=\"person\" title=\"人名\">齐王</span>不听我的劝谏，所以我退而耕于田野。国家已经<span class=\"verb-military\" title=\"军事动词\">灭亡</span>，我不能保存它；如今又用武力胁迫我做<span class=\"identity\" title=\"身份\">君</span>的将军，这是帮助<span class=\"person\" title=\"人名\">桀</span>为暴啊。与其活着没有<span class=\"concept\" title=\"思想\">义</span>节，不如被<span class=\"verb-penalty\" title=\"刑罚动词\">烹</span>煮！\""
    },
    "10.6": {
      "title": "王蠋自尽",
      "text": "于是把颈子缠在<span class=\"biology\" title=\"生物\">树</span>枝上，自己猛地挣脱使颈骨折断而死。"
    },
    "10.7": {
      "title": "齐大夫感王蠋",
      "text": "<span class=\"feudal-state\" title=\"邦国\">齐</span>国逃亡的<span class=\"identity\" title=\"身份\">大夫</span>听说后，说： \"<span class=\"person\" title=\"人名\">王蠋</span>是<span class=\"identity\" title=\"身份\">布衣</span>，<span class=\"concept\" title=\"思想\">义</span>不向北面臣服于<span class=\"feudal-state\" title=\"邦国\">燕</span>国，何况是在位食禄的人呢！\""
    },
    "10.8": {
      "title": "立襄王",
      "text": "于是相聚去<span class=\"place\" title=\"地名\">莒</span>，寻找<span class=\"identity\" title=\"身份\">诸子</span>，<span class=\"verb-political\" title=\"政治动词\">立</span>了<span class=\"person\" title=\"人名·规范：齐襄王\">襄王（齐襄王）</span>。"
    },
    "11": {
      "title": "赞",
      "text": "<span class=\"institution\" title=\"名物\">军法</span>以正面接战，实际崇尚奇兵。 截断<span class=\"artifact\" title=\"器物\">车轴</span>自救，反间之计先行。 群<span class=\"biology\" title=\"生物\">鸟</span>聚集象征神师，五<span class=\"biology\" title=\"生物\">牛</span>高扬<span class=\"artifact\" title=\"器物\">旌</span>旗。 终于<span class=\"verb-military\" title=\"军事动词\">攻破</span><span class=\"person\" title=\"人名\">骑劫</span>，全复<span class=\"feudal-state\" title=\"邦国\">齐</span>国城邑。 <span class=\"person\" title=\"人名·规范：齐襄王\">襄王（齐襄王）</span>继位，就封他于<span class=\"place\" title=\"地名\">安平</span>。"
    }
  }
}