{
  "chapter": "011",
  "title": "孝景本纪",
  "translations": {
    "1": {
      "title": "孝景身世",
      "text": "<span class=\"person\" title=\"人名\">孝景皇帝</span>的身世。"
    },
    "1.1": {
      "title": "出身介绍",
      "text": "<span class=\"person\" title=\"人名\">孝景皇帝</span>是<span class=\"person\" title=\"人名\">孝文</span>的<span class=\"identity\" title=\"身份\">中子</span>。母亲是<span class=\"person\" title=\"人名\">窦太后</span>。"
    },
    "1.2": {
      "title": "得以立嗣",
      "text": "<span class=\"person\" title=\"人名\">孝文</span>在<span class=\"feudal-state\" title=\"邦国\">代</span>国的时候，前后有三个儿子，等到<span class=\"person\" title=\"人名\">窦太后</span>得到宠幸，前后两位夫人都死了，前面三个儿子也相继死去，所以<span class=\"person\" title=\"人名\">孝景</span>得以被立为嗣君。"
    },
    "2": {
      "title": "元年大事",
      "text": "元年诸事记录。"
    },
    "2.1": {
      "title": "大赦赐爵",
      "text": "<span class=\"time\" title=\"时间\">元年四月乙卯</span>，<span class=\"verb-political\" title=\"政治动词\">赦</span>免<span class=\"concept\" title=\"思想\">天下</span>。<span class=\"time\" title=\"时间\">乙巳</span>，赐给百姓爵位一级。"
    },
    "2.2": {
      "title": "减租立庙",
      "text": "<span class=\"time\" title=\"时间\">五月</span>，免除<span class=\"institution\" title=\"名物\">田半租</span>，为<span class=\"person\" title=\"人名\">孝文</span>建立<span class=\"place\" title=\"地名\">太宗庙</span>。命令<span class=\"identity\" title=\"身份\">群臣</span>不必朝贺。"
    },
    "2.3": {
      "title": "匈奴入代",
      "text": "<span class=\"tribe\" title=\"族群\">匈奴</span>侵入<span class=\"feudal-state\" title=\"邦国\">代</span>地，与他们约定<span class=\"institution\" title=\"名物\">和亲</span>。"
    },
    "3": {
      "title": "二年大事",
      "text": "二年诸事记录。"
    },
    "3.1": {
      "title": "封萧何孙",
      "text": "<span class=\"time\" title=\"时间\">二年春</span>，封故<span class=\"official\" title=\"官职\">相国</span><span class=\"person\" title=\"人名\">萧何</span>的孙子<span class=\"person\" title=\"人名·规范：萧系\">系（萧系）</span>为<span class=\"official\" title=\"官职\">武陵侯</span>。"
    },
    "3.2": {
      "title": "男子傅籍",
      "text": "男子<span class=\"quantity\" title=\"数量\">二十</span>岁就要登记服役。"
    },
    "3.3": {
      "title": "孝文太后崩",
      "text": "<span class=\"time\" title=\"时间\">四月壬午</span>，<span class=\"person\" title=\"人名\">孝文太后</span><span class=\"verb-political\" title=\"政治动词\">崩</span>。"
    },
    "3.4": {
      "title": "诸王之国",
      "text": "<span class=\"official\" title=\"官职·规范：广川王\">广川（广川王）</span>、<span class=\"official\" title=\"官职\">长沙王</span>都<span class=\"verb-political\" title=\"政治动词\">之国</span>前往封地。"
    },
    "3.5": {
      "title": "申屠嘉卒",
      "text": "<span class=\"official\" title=\"官职\">丞相</span><span class=\"person\" title=\"人名\">申屠嘉</span><span class=\"verb-political\" title=\"政治动词\">卒</span>。"
    },
    "3.6": {
      "title": "陶青为相",
      "text": "<span class=\"time\" title=\"时间\">八月</span>，任命<span class=\"official\" title=\"官职\">御史大夫</span><span class=\"place\" title=\"地名\">开封</span>人<span class=\"person\" title=\"人名\">陶青</span>为<span class=\"official\" title=\"官职\">丞相</span>。"
    },
    "3.7": {
      "title": "彗星现",
      "text": "<span class=\"astronomy\" title=\"天文\">彗星</span>出现在东北方。"
    },
    "4": {
      "title": "二年天象",
      "text": "二年天象与置县。"
    },
    "4.1": {
      "title": "衡山雨雹",
      "text": "<span class=\"time\" title=\"时间\">秋</span>，<span class=\"place\" title=\"地名\">衡山</span>下冰雹，大的有<span class=\"quantity\" title=\"数量\">五寸</span>，深的达<span class=\"quantity\" title=\"数量\">二尺</span>。"
    },
    "4.2": {
      "title": "荧惑逆行",
      "text": "<span class=\"astronomy\" title=\"天文\">荧惑</span>星逆行，停留在<span class=\"astronomy\" title=\"天文\">北辰</span>方位。"
    },
    "4.3": {
      "title": "月出北辰",
      "text": "<span class=\"astronomy\" title=\"天文\">月</span>出现在<span class=\"astronomy\" title=\"天文\">北辰</span>星之间。"
    },
    "4.4": {
      "title": "岁星逆行",
      "text": "<span class=\"astronomy\" title=\"天文\">岁星</span>在<span class=\"astronomy\" title=\"天文\">天廷</span>之中逆行。"
    },
    "4.5": {
      "title": "置县",
      "text": "设置<span class=\"place\" title=\"地名\">南陵</span>以及<span class=\"place\" title=\"地名\">内史</span>、<span class=\"place\" title=\"地名\">祋祤</span>为县。"
    },
    "5": {
      "title": "三年灾异",
      "text": "三年诸事记录。"
    },
    "5.1": {
      "title": "大赦天下",
      "text": "<span class=\"time\" title=\"时间\">三年正月乙巳</span>，<span class=\"verb-political\" title=\"政治动词\">赦</span>免<span class=\"concept\" title=\"思想\">天下</span>。"
    },
    "5.2": {
      "title": "长星出现",
      "text": "<span class=\"astronomy\" title=\"天文\">长星</span>出现在西方。"
    },
    "5.3": {
      "title": "雒阳火灾",
      "text": "天火焚烧了<span class=\"place\" title=\"地名\">雒阳</span><span class=\"place\" title=\"地名\">东宫</span>的大殿和城中房舍。"
    },
    "6": {
      "title": "七国反叛",
      "text": "七国起兵作乱。"
    },
    "6.1": {
      "title": "七王反",
      "text": "<span class=\"official\" title=\"官职\">吴王</span><span class=\"person\" title=\"人名·规范：刘濞\">濞（刘濞）</span>、<span class=\"official\" title=\"官职\">楚王</span><span class=\"person\" title=\"人名·规范：刘戊\">戊（刘戊）</span>、<span class=\"official\" title=\"官职\">赵王</span><span class=\"person\" title=\"人名·规范：刘遂\">遂（刘遂）</span>、<span class=\"official\" title=\"官职\">胶西王</span><span class=\"person\" title=\"人名·规范：刘卬\">卬（刘卬）</span>、<span class=\"official\" title=\"官职\">济南王</span><span class=\"person\" title=\"人名·规范：刘辟光\">辟光（刘辟光）</span>、<span class=\"official\" title=\"官职\">菑川王</span><span class=\"person\" title=\"人名·规范：刘贤\">贤（刘贤）</span>、<span class=\"official\" title=\"官职\">胶东王</span><span class=\"person\" title=\"人名·规范：刘雄渠\">雄渠（刘雄渠）</span>起兵反叛，发兵向西进军。"
    },
    "6.2": {
      "title": "诛晁错围梁",
      "text": "<span class=\"identity\" title=\"身份\">天子</span>因此<span class=\"verb-penalty\" title=\"刑罚动词\">诛</span>杀<span class=\"person\" title=\"人名\">晁错</span>，派<span class=\"person\" title=\"人名\">袁盎</span>前去晓谕劝告，但叛军不停止，接着向西<span class=\"verb-military\" title=\"军事动词\">围</span>攻<span class=\"feudal-state\" title=\"邦国\">梁</span>国。"
    },
    "6.3": {
      "title": "发兵平叛",
      "text": "<span class=\"identity\" title=\"身份\">上</span>于是派<span class=\"official\" title=\"官职\">大将军</span><span class=\"person\" title=\"人名\">窦婴</span>、<span class=\"official\" title=\"官职\">太尉</span><span class=\"person\" title=\"人名\">周亚夫</span>率军<span class=\"verb-penalty\" title=\"刑罚动词\">诛</span>讨叛军。"
    },
    "7": {
      "title": "平叛善后",
      "text": "平定叛乱之后的处置。"
    },
    "7.1": {
      "title": "赦亡军",
      "text": "<span class=\"time\" title=\"时间\">六月乙亥</span>，<span class=\"verb-political\" title=\"政治动词\">赦</span>免逃亡的士兵以及<span class=\"person\" title=\"人名\">楚元王</span>之子<span class=\"person\" title=\"人名·规范：刘艺\">艺（刘艺）</span>等参与谋反的人。"
    },
    "7.2": {
      "title": "封窦婴",
      "text": "<span class=\"verb-political\" title=\"政治动词\">封</span><span class=\"official\" title=\"官职\">大将军</span><span class=\"person\" title=\"人名\">窦婴</span>为<span class=\"official\" title=\"官职\">魏其侯</span>。"
    },
    "7.3": {
      "title": "立楚王",
      "text": "<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"person\" title=\"人名\">楚元王</span>之子<span class=\"official\" title=\"官职\">平陆侯</span><span class=\"person\" title=\"人名·规范：刘礼\">礼（刘礼）</span>为<span class=\"official\" title=\"官职\">楚王</span>。"
    },
    "8": {
      "title": "封立迁王",
      "text": "封立皇子与迁徙诸王。"
    },
    "8.1": {
      "title": "立胶西中山王",
      "text": "<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"identity\" title=\"身份\">皇子</span><span class=\"person\" title=\"人名·规范：刘端\">端（刘端）</span>为<span class=\"official\" title=\"官职\">胶西王</span>，<span class=\"identity\" title=\"身份\">皇子</span><span class=\"person\" title=\"人名·规范：刘胜\">胜（刘胜）</span>为<span class=\"official\" title=\"官职\">中山王</span>。"
    },
    "8.2": {
      "title": "迁三王",
      "text": "将<span class=\"official\" title=\"官职\">济北王</span><span class=\"person\" title=\"人名·规范：刘志\">志（刘志）</span>改封为<span class=\"official\" title=\"官职\">菑川王</span>，<span class=\"official\" title=\"官职\">淮阳王</span><span class=\"person\" title=\"人名·规范：刘馀\">馀（刘馀）</span>改封为<span class=\"official\" title=\"官职\">鲁王</span>，<span class=\"official\" title=\"官职\">汝南王</span><span class=\"person\" title=\"人名·规范：刘非\">非（刘非）</span>改封为<span class=\"official\" title=\"官职\">江都王</span>。"
    },
    "8.3": {
      "title": "齐燕王薨",
      "text": "<span class=\"official\" title=\"官职\">齐王</span><span class=\"person\" title=\"人名·规范：刘将庐\">将庐（刘将庐）</span>、<span class=\"official\" title=\"官职\">燕王</span><span class=\"person\" title=\"人名·规范：刘嘉\">嘉（刘嘉）</span>都<span class=\"verb-political\" title=\"政治动词\">薨</span>。"
    },
    "9": {
      "title": "四年诸事",
      "text": "四年诸事记录。"
    },
    "9.1": {
      "title": "立太子",
      "text": "<span class=\"time\" title=\"时间\">四年夏</span>，<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"identity\" title=\"身份\">太子</span>。"
    },
    "9.2": {
      "title": "立胶东王",
      "text": "<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"identity\" title=\"身份\">皇子</span><span class=\"person\" title=\"人名·规范：刘彻\">彻（刘彻）</span>为<span class=\"official\" title=\"官职\">胶东王</span>。"
    },
    "9.3": {
      "title": "大赦天下",
      "text": "<span class=\"time\" title=\"时间\">六月甲戌</span>，<span class=\"verb-political\" title=\"政治动词\">赦</span>免<span class=\"concept\" title=\"思想\">天下</span>。"
    },
    "9.4": {
      "title": "改阳为阳陵",
      "text": "<span class=\"time\" title=\"时间\">後九月</span>，把<span class=\"place\" title=\"地名\">阳</span>改名为<span class=\"place\" title=\"地名\">阳陵</span>。"
    },
    "9.5": {
      "title": "复置津关",
      "text": "重新设置<span class=\"institution\" title=\"名物\">津关</span>，凭<span class=\"artifact\" title=\"器物\">传</span>符出入。"
    },
    "9.6": {
      "title": "赵国改郡",
      "text": "<span class=\"time\" title=\"时间\">冬</span>，把<span class=\"place\" title=\"地名\">赵国</span>改为<span class=\"place\" title=\"地名\">邯郸郡</span>。"
    },
    "10": {
      "title": "五年诸事",
      "text": "五年诸事记录。"
    },
    "10.1": {
      "title": "作阳陵渭桥",
      "text": "<span class=\"time\" title=\"时间\">五年三月</span>，修建<span class=\"place\" title=\"地名\">阳陵</span>、<span class=\"place\" title=\"地名\">渭桥</span>。"
    },
    "10.2": {
      "title": "募民徙陵",
      "text": "<span class=\"time\" title=\"时间\">五月</span>，招募百姓迁徙到<span class=\"place\" title=\"地名\">阳陵</span>，赐给每户钱二十万。"
    },
    "10.3": {
      "title": "江都暴风",
      "text": "<span class=\"place\" title=\"地名\">江都</span>刮起大暴风，从西方来，毁坏城墙<span class=\"quantity\" title=\"数量\">十二丈</span>。"
    },
    "10.4": {
      "title": "封陈蟜",
      "text": "<span class=\"time\" title=\"时间\">丁卯</span>，封<span class=\"identity\" title=\"身份\">长公主</span>的儿子<span class=\"person\" title=\"人名·规范：陈蟜\">蟜（陈蟜）</span>为<span class=\"official\" title=\"官职\">隆虑侯</span>。"
    },
    "10.5": {
      "title": "广川王徙赵",
      "text": "将<span class=\"official\" title=\"官职\">广川王</span>改封为<span class=\"official\" title=\"官职\">赵王</span>。"
    },
    "11": {
      "title": "六年诸事",
      "text": "六年诸事记录。"
    },
    "11.1": {
      "title": "封五侯",
      "text": "<span class=\"time\" title=\"时间\">六年春</span>，<span class=\"verb-political\" title=\"政治动词\">封</span><span class=\"official\" title=\"官职\">中尉</span><span class=\"person\" title=\"人名·规范：卫绾\">绾（卫绾）</span>为<span class=\"official\" title=\"官职\">建陵侯</span>，<span class=\"place\" title=\"地名\">江都</span><span class=\"official\" title=\"官职\">丞相</span><span class=\"person\" title=\"人名·规范：刘嘉\">嘉（刘嘉）</span>为<span class=\"official\" title=\"官职\">建平侯</span>，<span class=\"place\" title=\"地名\">陇西</span><span class=\"official\" title=\"官职\">太守</span><span class=\"person\" title=\"人名\">浑邪</span>为<span class=\"official\" title=\"官职\">平曲侯</span>，<span class=\"feudal-state\" title=\"邦国\">赵</span>国<span class=\"official\" title=\"官职\">丞相</span><span class=\"person\" title=\"人名·规范：刘嘉\">嘉（刘嘉）</span>为<span class=\"official\" title=\"官职\">江陵侯</span>，前<span class=\"official\" title=\"官职\">将军</span><span class=\"person\" title=\"人名·规范：栾布\">布（栾布）</span>为<span class=\"official\" title=\"官职\">鄃侯</span>。"
    },
    "11.2": {
      "title": "梁楚王薨",
      "text": "<span class=\"feudal-state\" title=\"邦国\">梁</span>、<span class=\"feudal-state\" title=\"邦国\">楚</span>两位王都<span class=\"verb-political\" title=\"政治动词\">薨</span>。"
    },
    "11.3": {
      "title": "伐树殖兰池",
      "text": "<span class=\"time\" title=\"时间\">後九月</span>，<span class=\"verb-military\" title=\"军事动词\">砍伐</span><span class=\"institution\" title=\"名物\">驰道</span>旁的<span class=\"biology\" title=\"生物\">树</span>木，在<span class=\"place\" title=\"地名\">兰池</span>栽种植物。"
    },
    "12": {
      "title": "废太子",
      "text": "废黜栗太子。"
    },
    "12.1": {
      "title": "废栗太子",
      "text": "<span class=\"time\" title=\"时间\">七年冬</span>，<span class=\"verb-penalty\" title=\"刑罚动词\">废</span>黜<span class=\"identity\" title=\"身份\">栗太子</span>为<span class=\"official\" title=\"官职\">临江王</span>。"
    },
    "12.2": {
      "title": "日食",
      "text": "<span class=\"time\" title=\"时间\">十月晦</span>，<span class=\"astronomy\" title=\"天文\">日</span>发生日食。"
    },
    "12.3": {
      "title": "免徒隶",
      "text": "<span class=\"time\" title=\"时间\">春</span>，赦免修筑<span class=\"place\" title=\"地名\">阳陵</span>的徒隶。"
    },
    "12.4": {
      "title": "陶青免",
      "text": "<span class=\"official\" title=\"官职\">丞相</span><span class=\"person\" title=\"人名·规范：陶青\">青（陶青）</span>被免职。"
    },
    "12.5": {
      "title": "周亚夫为相",
      "text": "<span class=\"time\" title=\"时间\">二月乙巳</span>，任命<span class=\"official\" title=\"官职\">太尉</span><span class=\"official\" title=\"官职\">条侯</span><span class=\"person\" title=\"人名\">周亚夫</span>为<span class=\"official\" title=\"官职\">丞相</span>。"
    },
    "13": {
      "title": "立太子",
      "text": "立皇后与新太子。"
    },
    "13.1": {
      "title": "立皇后",
      "text": "<span class=\"time\" title=\"时间\">四月乙巳</span>，<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"official\" title=\"官职\">胶东王</span>的<span class=\"identity\" title=\"身份\">太后</span>为<span class=\"identity\" title=\"身份\">皇后</span>。"
    },
    "13.2": {
      "title": "立太子刘彻",
      "text": "<span class=\"time\" title=\"时间\">丁巳</span>，<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"official\" title=\"官职\">胶东王</span>为<span class=\"identity\" title=\"身份\">太子</span>，名<span class=\"person\" title=\"人名·规范：刘彻\">彻（刘彻）</span>。"
    },
    "14": {
      "title": "中元年诸事",
      "text": "中元年诸事记录。"
    },
    "14.1": {
      "title": "封侯",
      "text": "<span class=\"time\" title=\"时间\">中元年</span>，封故<span class=\"official\" title=\"官职\">御史大夫</span><span class=\"person\" title=\"人名\">周苛</span>的孙子<span class=\"person\" title=\"人名·规范：周平\">平（周平）</span>为<span class=\"official\" title=\"官职\">绳侯</span>，故<span class=\"official\" title=\"官职\">御史大夫</span><span class=\"person\" title=\"人名\">周昌</span>的<span class=\"person\" title=\"人名·规范：周左车\">左车（周左车）</span>为<span class=\"official\" title=\"官职\">安阳侯</span>。"
    },
    "14.2": {
      "title": "赦天下除禁锢",
      "text": "<span class=\"time\" title=\"时间\">四月乙巳</span>，<span class=\"verb-political\" title=\"政治动词\">赦</span>免<span class=\"concept\" title=\"思想\">天下</span>，<span class=\"institution\" title=\"名物\">赐爵</span>一级。解除<span class=\"legal\" title=\"刑法\">禁锢</span>之刑。"
    },
    "14.3": {
      "title": "地动雨雹",
      "text": "发生地震。<span class=\"place\" title=\"地名\">衡山</span>、<span class=\"place\" title=\"地名\">原都</span>下冰雹，大的达<span class=\"quantity\" title=\"数量\">尺八寸</span>。"
    },
    "15": {
      "title": "中二年诸事",
      "text": "中二年诸事记录。"
    },
    "15.1": {
      "title": "匈奴入燕",
      "text": "<span class=\"time\" title=\"时间\">中二年二月</span>，<span class=\"tribe\" title=\"族群\">匈奴</span>侵入<span class=\"feudal-state\" title=\"邦国\">燕</span>国，于是不再<span class=\"institution\" title=\"名物\">和亲</span>。"
    },
    "15.2": {
      "title": "临江王死",
      "text": "<span class=\"time\" title=\"时间\">三月</span>，召<span class=\"official\" title=\"官职\">临江王</span>前来。他随即<span class=\"verb-penalty\" title=\"刑罚动词\">死</span>在<span class=\"official\" title=\"官职\">中尉</span>府中。"
    },
    "15.3": {
      "title": "立广川胶东王",
      "text": "<span class=\"time\" title=\"时间\">夏</span>，<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"identity\" title=\"身份\">皇子</span><span class=\"person\" title=\"人名·规范：刘越\">越（刘越）</span>为<span class=\"official\" title=\"官职\">广川王</span>，<span class=\"identity\" title=\"身份\">皇子</span><span class=\"person\" title=\"人名·规范：刘寄\">寄（刘寄）</span>为<span class=\"official\" title=\"官职\">胶东王</span>。封四位侯。"
    },
    "15.4": {
      "title": "日食",
      "text": "<span class=\"time\" title=\"时间\">九月甲戌</span>，发生<span class=\"astronomy\" title=\"天文\">日食</span>。"
    },
    "16": {
      "title": "中三年诸事",
      "text": "中三年诸事记录。"
    },
    "16.1": {
      "title": "罢诸侯御史",
      "text": "<span class=\"time\" title=\"时间\">中三年冬</span>，<span class=\"verb-political\" title=\"政治动词\">废</span>除<span class=\"identity\" title=\"身份\">诸侯</span>国中的<span class=\"official\" title=\"官职\">御史中丞</span>。"
    },
    "16.2": {
      "title": "匈奴王来降",
      "text": "<span class=\"time\" title=\"时间\">春</span>，<span class=\"tribe\" title=\"族群\">匈奴</span>有两位王率领部属前来<span class=\"verb-military\" title=\"军事动词\">归降</span>，都被封为<span class=\"identity\" title=\"身份\">列侯</span>。"
    },
    "16.3": {
      "title": "立清河王",
      "text": "<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"identity\" title=\"身份\">皇子</span><span class=\"person\" title=\"人名·规范：刘方乘\">方乘（刘方乘）</span>为<span class=\"official\" title=\"官职\">清河王</span>。"
    },
    "16.4": {
      "title": "彗星出西北",
      "text": "<span class=\"time\" title=\"时间\">三月</span>，<span class=\"astronomy\" title=\"天文\">彗星</span>出现在西北方。"
    },
    "16.5": {
      "title": "刘舍为相",
      "text": "<span class=\"official\" title=\"官职\">丞相</span><span class=\"person\" title=\"人名\">周亚夫</span>被免职，任命<span class=\"official\" title=\"官职\">御史大夫</span><span class=\"official\" title=\"官职\">桃侯</span><span class=\"person\" title=\"人名\">刘舍</span>为<span class=\"official\" title=\"官职\">丞相</span>。"
    },
    "16.6": {
      "title": "地动",
      "text": "<span class=\"time\" title=\"时间\">四月</span>，发生地震。"
    },
    "16.7": {
      "title": "日食",
      "text": "<span class=\"time\" title=\"时间\">九月戊戌晦</span>，发生<span class=\"astronomy\" title=\"天文\">日食</span>。军队驻扎在<span class=\"place\" title=\"地名\">东都门</span>外。"
    },
    "17": {
      "title": "中四年诸事",
      "text": "中四年诸事记录。"
    },
    "17.1": {
      "title": "置德阳宫",
      "text": "<span class=\"time\" title=\"时间\">中四年三月</span>，设置<span class=\"place\" title=\"地名\">德阳宫</span>。"
    },
    "17.2": {
      "title": "蝗灾",
      "text": "发生大规模<span class=\"biology\" title=\"生物\">蝗</span>灾。"
    },
    "17.3": {
      "title": "赦阳陵徒",
      "text": "<span class=\"time\" title=\"时间\">秋</span>，<span class=\"verb-political\" title=\"政治动词\">赦</span>免修筑<span class=\"place\" title=\"地名\">阳陵</span>的刑徒。"
    },
    "18": {
      "title": "中五年诸事",
      "text": "中五年诸事记录。"
    },
    "18.1": {
      "title": "立常山王",
      "text": "<span class=\"time\" title=\"时间\">中五年夏</span>，<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"identity\" title=\"身份\">皇子</span><span class=\"person\" title=\"人名·规范：刘舜\">舜（刘舜）</span>为<span class=\"official\" title=\"官职\">常山王</span>。分封十位侯。"
    },
    "18.2": {
      "title": "赦天下赐爵",
      "text": "<span class=\"time\" title=\"时间\">六月丁巳</span>，<span class=\"verb-political\" title=\"政治动词\">赦</span>免<span class=\"concept\" title=\"思想\">天下</span>，<span class=\"institution\" title=\"名物\">赐爵</span>一级。"
    },
    "18.3": {
      "title": "大水",
      "text": "天下发大水。"
    },
    "18.4": {
      "title": "改丞相为相",
      "text": "改称<span class=\"identity\" title=\"身份\">诸侯</span>国的<span class=\"official\" title=\"官职\">丞相</span>为<span class=\"official\" title=\"官职\">相</span>。"
    },
    "18.5": {
      "title": "秋地动",
      "text": "<span class=\"time\" title=\"时间\">秋</span>，发生地震。"
    },
    "19": {
      "title": "中六年诸事",
      "text": "中六年诸事记录。"
    },
    "19.1": {
      "title": "郊祀雍五帝",
      "text": "<span class=\"time\" title=\"时间\">中六年二月己卯</span>，皇上出行到<span class=\"place\" title=\"地名\">雍</span>，在郊外祭祀<span class=\"institution\" title=\"名物\">五帝</span>。"
    },
    "19.2": {
      "title": "雨雹",
      "text": "<span class=\"time\" title=\"时间\">三月</span>，下冰雹。"
    },
    "19.3": {
      "title": "三王薨",
      "text": "<span class=\"time\" title=\"时间\">四月</span>，<span class=\"person\" title=\"人名\">梁孝王</span>、<span class=\"person\" title=\"人名\">城阳共王</span>、<span class=\"person\" title=\"人名\">汝南王</span>都<span class=\"verb-political\" title=\"政治动词\">薨</span>。"
    },
    "20": {
      "title": "分梁为五",
      "text": "封立梁孝王诸子。"
    },
    "20.1": {
      "title": "立梁孝王诸子",
      "text": "<span class=\"verb-political\" title=\"政治动词\">立</span><span class=\"person\" title=\"人名\">梁孝王</span>的儿子<span class=\"person\" title=\"人名·规范：刘明\">明（刘明）</span>为<span class=\"official\" title=\"官职\">济川王</span>，儿子<span class=\"person\" title=\"人名·规范：刘彭离\">彭离（刘彭离）</span>为<span class=\"official\" title=\"官职\">济东王</span>，儿子<span class=\"person\" title=\"人名·规范：刘定\">定（刘定）</span>为<span class=\"official\" title=\"官职\">山阳王</span>，儿子<span class=\"person\" title=\"人名·规范：刘不识\">不识（刘不识）</span>为<span class=\"official\" title=\"官职\">济阴王</span>。<span class=\"feudal-state\" title=\"邦国\">梁</span>国一分为五。"
    },
    "20.2": {
      "title": "封四侯",
      "text": "分封四位侯。"
    },
    "21": {
      "title": "官制改革",
      "text": "官制改革与其他。"
    },
    "21.1": {
      "title": "改官名",
      "text": "更改<span class=\"official\" title=\"官职\">廷尉</span>为<span class=\"official\" title=\"官职\">大理</span>，<span class=\"official\" title=\"官职\">将作少府</span>为<span class=\"official\" title=\"官职\">将作大匠</span>，<span class=\"official\" title=\"官职\">主爵中尉</span>为<span class=\"official\" title=\"官职\">都尉</span>，<span class=\"official\" title=\"官职\">长信詹事</span>为<span class=\"official\" title=\"官职\">长信少府</span>，<span class=\"official\" title=\"官职\">将行</span>为<span class=\"official\" title=\"官职\">大长秋</span>，<span class=\"official\" title=\"官职\">大行</span>为<span class=\"official\" title=\"官职\">行人</span>，<span class=\"official\" title=\"官职\">奉常</span>为<span class=\"official\" title=\"官职\">太常</span>，<span class=\"official\" title=\"官职\">典客</span>为<span class=\"official\" title=\"官职\">大行</span>，<span class=\"official\" title=\"官职\">治粟内史</span>为<span class=\"official\" title=\"官职\">大农</span>。"
    },
    "21.2": {
      "title": "置左右内官",
      "text": "把<span class=\"official\" title=\"官职\">大内</span>设为<span class=\"official\" title=\"官职\">二千石</span>级，设置<span class=\"official\" title=\"官职\">左右内官</span>，隶属于<span class=\"official\" title=\"官职\">大内</span>。"
    },
    "21.3": {
      "title": "日食",
      "text": "<span class=\"time\" title=\"时间\">七月辛亥</span>，发生<span class=\"astronomy\" title=\"天文\">日食</span>。"
    },
    "21.4": {
      "title": "匈奴入上郡",
      "text": "<span class=\"time\" title=\"时间\">八月</span>，<span class=\"tribe\" title=\"族群\">匈奴</span>侵入<span class=\"place\" title=\"地名\">上郡</span>。"
    },
    "22": {
      "title": "後元年诸事",
      "text": "後元年诸事记录。"
    },
    "22.1": {
      "title": "改中大夫令",
      "text": "<span class=\"time\" title=\"时间\">後元年冬</span>，改<span class=\"official\" title=\"官职\">中大夫令</span>为<span class=\"official\" title=\"官职\">卫尉</span>。"
    },
    "22.2": {
      "title": "赦天下赐爵",
      "text": "<span class=\"time\" title=\"时间\">三月丁酉</span>，<span class=\"verb-political\" title=\"政治动词\">赦</span>免<span class=\"concept\" title=\"思想\">天下</span>，<span class=\"institution\" title=\"名物\">赐爵</span>一级，<span class=\"official\" title=\"官职\">中二千石</span>、<span class=\"identity\" title=\"身份\">诸侯</span>国<span class=\"official\" title=\"官职\">相</span>赐爵为<span class=\"official\" title=\"官职\">右庶长</span>。"
    },
    "22.3": {
      "title": "大酺",
      "text": "<span class=\"time\" title=\"时间\">四月</span>，全国大聚饮。"
    },
    "22.4": {
      "title": "地动",
      "text": "<span class=\"time\" title=\"时间\">五月丙戌</span>，发生地震，当日早饭时又震动。"
    },
    "22.5": {
      "title": "上庸地震",
      "text": "<span class=\"place\" title=\"地名\">上庸</span>地震持续了<span class=\"quantity\" title=\"数量\">二十二日</span>，毁坏了城墙。"
    },
    "22.6": {
      "title": "日食",
      "text": "<span class=\"time\" title=\"时间\">七月乙巳</span>，发生<span class=\"astronomy\" title=\"天文\">日食</span>。"
    },
    "22.7": {
      "title": "刘舍免相",
      "text": "<span class=\"official\" title=\"官职\">丞相</span><span class=\"person\" title=\"人名\">刘舍</span>被免职。"
    },
    "22.8": {
      "title": "卫绾为相",
      "text": "<span class=\"time\" title=\"时间\">八月壬辰</span>，任命<span class=\"official\" title=\"官职\">御史大夫</span><span class=\"person\" title=\"人名·规范：卫绾\">绾（卫绾）</span>为<span class=\"official\" title=\"官职\">丞相</span>，<span class=\"verb-political\" title=\"政治动词\">封</span>为<span class=\"official\" title=\"官职\">建陵侯</span>。"
    },
    "23": {
      "title": "後二年诸事",
      "text": "後二年诸事记录。"
    },
    "23.1": {
      "title": "一日三动",
      "text": "<span class=\"time\" title=\"时间\">後二年正月</span>，大地<span class=\"quantity\" title=\"数量\">一日</span>中震动了三次。"
    },
    "23.2": {
      "title": "郅都击匈奴",
      "text": "<span class=\"person\" title=\"人名·规范：郅都\">郅（郅都）</span><span class=\"official\" title=\"官职\">将军</span><span class=\"verb-military\" title=\"军事动词\">攻击</span><span class=\"tribe\" title=\"族群\">匈奴</span>。聚饮<span class=\"quantity\" title=\"数量\">五日</span>。"
    },
    "23.3": {
      "title": "禁马食粟",
      "text": "命令<span class=\"place\" title=\"地名\">内史</span>及各郡不得用<span class=\"artifact\" title=\"器物\">粟</span>米喂<span class=\"biology\" title=\"生物\">马</span>，违者<span class=\"legal\" title=\"刑法\">没入</span>县官。"
    },
    "23.4": {
      "title": "徒隶衣七布",
      "text": "命令徒隶穿<span class=\"artifact\" title=\"器物\">七布</span>衣服。停止用<span class=\"biology\" title=\"生物\">马</span>舂米。"
    },
    "24": {
      "title": "後二年续事",
      "text": "後二年其他事。"
    },
    "24.1": {
      "title": "禁超量食",
      "text": "因为当年收成不好，禁止<span class=\"concept\" title=\"思想\">天下</span>百姓消费超过当年产出的粮食。"
    },
    "24.2": {
      "title": "省列侯之国",
      "text": "减少<span class=\"identity\" title=\"身份\">列侯</span><span class=\"verb-political\" title=\"政治动词\">之国</span>的数量。"
    },
    "24.3": {
      "title": "匈奴入雁门",
      "text": "<span class=\"time\" title=\"时间\">三月</span>，<span class=\"tribe\" title=\"族群\">匈奴</span>侵入<span class=\"place\" title=\"地名\">雁门</span>。"
    },
    "24.4": {
      "title": "租长陵田大旱",
      "text": "<span class=\"time\" title=\"时间\">十月</span>，征收<span class=\"place\" title=\"地名\">长陵</span>的田租。发生大旱。"
    },
    "24.5": {
      "title": "三地民疫",
      "text": "<span class=\"place\" title=\"地名\">衡山国</span>、<span class=\"place\" title=\"地名\">河东</span>、<span class=\"place\" title=\"地名\">云中郡</span>的百姓发生瘟疫。"
    },
    "25": {
      "title": "後三年天象",
      "text": "後三年天象异变。"
    },
    "25.1": {
      "title": "日月皆赤",
      "text": "<span class=\"time\" title=\"时间\">後三年十月</span>，<span class=\"astronomy\" title=\"天文\">日月</span>都呈赤色，持续<span class=\"quantity\" title=\"数量\">五日</span>。"
    },
    "25.2": {
      "title": "雷日如紫",
      "text": "<span class=\"time\" title=\"时间\">十二月晦</span>，打雷。<span class=\"astronomy\" title=\"天文\">日</span>呈紫色。"
    },
    "25.3": {
      "title": "五星守太微",
      "text": "<span class=\"astronomy\" title=\"天文\">五星</span>逆行，停留在<span class=\"astronomy\" title=\"天文\">太微</span>星区。"
    },
    "25.4": {
      "title": "月贯天廷",
      "text": "<span class=\"astronomy\" title=\"天文\">月</span>贯穿<span class=\"astronomy\" title=\"天文\">天廷</span>中。"
    },
    "26": {
      "title": "景帝崩",
      "text": "皇太子冠礼与景帝驾崩。"
    },
    "26.1": {
      "title": "皇太子冠",
      "text": "<span class=\"time\" title=\"时间\">正月甲寅</span>，<span class=\"identity\" title=\"身份\">皇太子</span>行冠礼。"
    },
    "26.2": {
      "title": "孝景崩",
      "text": "<span class=\"time\" title=\"时间\">甲子</span>，<span class=\"person\" title=\"人名\">孝景皇帝</span><span class=\"verb-political\" title=\"政治动词\">崩</span>。"
    },
    "27": {
      "title": "遗诏继位",
      "text": "遗诏与新君即位。"
    },
    "27.1": {
      "title": "遗诏赐爵",
      "text": "遗诏赏赐<span class=\"identity\" title=\"身份\">诸侯王</span>以下直至百姓中为父后的人爵位一级，<span class=\"concept\" title=\"思想\">天下</span>每户<span class=\"quantity\" title=\"数量\">百钱</span>。"
    },
    "27.2": {
      "title": "出宫人",
      "text": "遣送宫中宫人归家，免除她们的赋役。"
    },
    "27.3": {
      "title": "太子即位",
      "text": "<span class=\"identity\" title=\"身份\">太子</span>即位，这就是<span class=\"person\" title=\"人名\">孝武皇帝</span>。"
    },
    "28": {
      "title": "封外戚",
      "text": "册封皇太后弟弟。"
    },
    "28.1": {
      "title": "封田蚡田胜",
      "text": "<span class=\"time\" title=\"时间\">三月</span>，封<span class=\"identity\" title=\"身份\">皇太后</span>的弟弟<span class=\"person\" title=\"人名·规范：田蚡\">蚡（田蚡）</span>为<span class=\"official\" title=\"官职\">武安侯</span>，弟弟<span class=\"person\" title=\"人名·规范：田胜\">胜（田胜）</span>为<span class=\"official\" title=\"官职\">周阳侯</span>。"
    },
    "28.2": {
      "title": "置阳陵",
      "text": "设置<span class=\"place\" title=\"地名\">阳陵</span>邑。"
    },
    "29": {
      "title": "太史公曰",
      "text": "太史公的评论。"
    },
    "29.1": {
      "title": "七国之乱",
      "text": "<span class=\"person\" title=\"人名\">太史公</span>说：<span class=\"feudal-state\" title=\"邦国\">汉</span>朝兴起后，<span class=\"person\" title=\"人名\">孝文</span>施行大德，<span class=\"concept\" title=\"思想\">天下</span>人心归附安定，到了<span class=\"person\" title=\"人名\">孝景</span>，不必再担忧异姓诸侯，而<span class=\"person\" title=\"人名\">晁错</span>苛刻削弱<span class=\"identity\" title=\"身份\">诸侯</span>，终于使<span class=\"feudal-state\" title=\"邦国\">七国</span>一同起兵，<span class=\"institution\" title=\"名物\">合从</span>联合向西进军，这是因为<span class=\"identity\" title=\"身份\">诸侯</span>势力过于强盛，而<span class=\"person\" title=\"人名·规范：晁错\">错（晁错）</span>削弱他们不是循序渐进。"
    },
    "29.2": {
      "title": "主父偃之策",
      "text": "等到<span class=\"person\" title=\"人名\">主父偃</span>建言施行推恩之策，<span class=\"identity\" title=\"身份\">诸侯</span>的势力因此削弱，天下终于安定。〘※安危之机〙，岂不在于谋略吗？"
    }
  }
}