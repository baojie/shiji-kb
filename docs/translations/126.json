  "chapter": "126",
  "title": "滑稽列传",
  "translations": {
    "6": {
      "title": "本段",
      "text": "百馀年之后，<span class=\"feudal-state\" title=\"邦国\">楚</span>有<span class=\"person\" title=\"人名\">优孟</span>。"
    },
    "9": {
      "title": "本段",
      "text": "其后两百馀年，<span class=\"feudal-state\" title=\"邦国\">秦</span>有<span class=\"person\" title=\"人名\">优旃</span>。"
