{
  "chapter": "001_五帝本纪",
  "mapping": [
    {
      "note_id": "n001",
      "sentence_id": null,
      "score": 0,
      "anchor_text": ""
    },
    {
      "note_id": "n002",
      "sentence_id": "s001",
      "score": 2.3,
      "anchor_text": "黃帝者，"
    },
    {
      "note_id": "n003",
      "sentence_id": "s001",
      "score": 2.4,
      "anchor_text": "少典之子，"
    },
    {
      "note_id": "n004",
      "sentence_id": "s001",
      "score": 1.0,
      "anchor_text": "姓公孫，名曰軒轅。"
    },
    {
      "note_id": "n005",
      "sentence_id": "s002",
      "score": 1.0,
      "anchor_text": "生而神靈，弱而能言，"
    },
    {
      "note_id": "n006",
      "sentence_id": "s002",
      "score": 2.4,
      "anchor_text": "幼而徇齊，"
    },
    {
      "note_id": "n007",
      "sentence_id": "s002",
      "score": 1.0,
      "anchor_text": "長而敦敏，成而聰明。"
    },
    {
      "note_id": "n008",
      "sentence_id": "s003",
      "score": 1.0,
      "anchor_text": "軒轅之時，神農氏世衰。"
    },
    {
      "note_id": "n009",
      "sentence_id": "s005",
      "score": 0.81,
      "anchor_text": "氏弗能征。於是軒轅乃習用干戈，以征不享，"
    },
    {
      "note_id": "n010",
      "sentence_id": "s006",
      "score": 0.6,
      "anchor_text": "諸侯咸來賓從。而蚩尤最爲暴，莫能伐。"
    },
    {
      "note_id": "n011",
      "sentence_id": "s007",
      "score": 0.62,
      "anchor_text": "侵陵諸侯，諸侯咸歸軒轅。軒轅乃修德振兵，"
    },
    {
      "note_id": "n012",
      "sentence_id": "s008",
      "score": 2.3,
      "anchor_text": "治五氣，"
    },
    {
      "note_id": "n013",
      "sentence_id": "s008",
      "score": 2.3,
      "anchor_text": "蓺五種，"
    },
    {
      "note_id": "n014",
      "sentence_id": "s008",
      "score": 1.0,
      "anchor_text": "撫萬民，度四方，"
    },
    {
      "note_id": "n015",
      "sentence_id": "s008",
      "score": 2.7,
      "anchor_text": "教熊羆貔貅貙虎，"
    },
    {
      "note_id": "n016",
      "sentence_id": "s008",
      "score": 3.0,
      "anchor_text": "以與炎帝戰於阪泉之野。"
    },
    {
      "note_id": "n017",
      "sentence_id": "s009",
      "score": 1.0,
      "anchor_text": "三戰，然後得其志。"
    },
    {
      "note_id": "n018",
      "sentence_id": "s010",
      "score": 1.0,
      "anchor_text": "蚩尤作亂，不用帝命。"
    },
    {
      "note_id": "n019",
      "sentence_id": "s011",
      "score": 1.0,
      "anchor_text": "於是黃帝乃徵師諸侯，與蚩尤戰於涿鹿之野，"
    },
    {
      "note_id": "n020",
      "sentence_id": "s011",
      "score": 0.8,
      "anchor_text": "遂禽殺蚩尤。"
    },
    {
      "note_id": "n021",
      "sentence_id": "s013",
      "score": 1.0,
      "anchor_text": "。天下有不順者，黃帝從而征之，平者去之，"
    },
    {
      "note_id": "n022",
      "sentence_id": "s013",
      "score": 2.4,
      "anchor_text": "披山通道，"
    },
    {
      "note_id": "n023",
      "sentence_id": "s014",
      "score": 1.0,
      "anchor_text": "東至于海，登丸山，"
    },
    {
      "note_id": "n024",
      "sentence_id": "s014",
      "score": 2.3,
      "anchor_text": "及岱宗。"
    },
    {
      "note_id": "n025",
      "sentence_id": "s015",
      "score": 2.5,
      "anchor_text": "西至于空桐，"
    },
    {
      "note_id": "n026",
      "sentence_id": "s015",
      "score": 0.67,
      "anchor_text": "登雞頭。"
    },
    {
      "note_id": "n027",
      "sentence_id": "s016",
      "score": 1.0,
      "anchor_text": "南至于江，登熊、湘。"
    },
    {
      "note_id": "n028",
      "sentence_id": "s017",
      "score": 0.75,
      "anchor_text": "北逐葷粥，"
    },
    {
      "note_id": "n029",
      "sentence_id": "s017",
      "score": 2.4,
      "anchor_text": "合符釜山，"
    },
    {
      "note_id": "n030",
      "sentence_id": "s017",
      "score": 2.7,
      "anchor_text": "而邑于涿鹿之阿。"
    },
    {
      "note_id": "n031",
      "sentence_id": "s018",
      "score": 0.77,
      "anchor_text": "遷徙往來無常處，以師兵爲營衞。"
    },
    {
      "note_id": "n032",
      "sentence_id": "s019",
      "score": 1.0,
      "anchor_text": "官名皆以雲命，爲雲師。"
    },
    {
      "note_id": "n033",
      "sentence_id": "s020",
      "score": 1.0,
      "anchor_text": "置左右大監，監于萬國。"
    },
    {
      "note_id": "n034",
      "sentence_id": "s021",
      "score": 1.0,
      "anchor_text": "萬國和，而鬼神山川封禪與爲多焉。"
    },
    {
      "note_id": "n035",
      "sentence_id": "s022",
      "score": 1.0,
      "anchor_text": "獲寶鼎，迎日推筴。"
    },
    {
      "note_id": "n036",
      "sentence_id": "s023",
      "score": 1.0,
      "anchor_text": "舉風后、力牧、常先、大鴻"
    },
    {
      "note_id": "n037",
      "sentence_id": "s024",
      "score": 0.62,
      "anchor_text": "以治民。順天地之紀，"
    },
    {
      "note_id": "n038",
      "sentence_id": "s024",
      "score": 2.4,
      "anchor_text": "幽明之占，"
    },
    {
      "note_id": "n039",
      "sentence_id": "s024",
      "score": 2.4,
      "anchor_text": "死生之說，"
    },
    {
      "note_id": "n040",
      "sentence_id": "s024",
      "score": 2.4,
      "anchor_text": "存亡之難。"
    },
    {
      "note_id": "n041",
      "sentence_id": "s025",
      "score": 2.6,
      "anchor_text": "時播百穀草木，"
    },
    {
      "note_id": "n042",
      "sentence_id": "s025",
      "score": 2.6,
      "anchor_text": "淳化鳥獸蟲蛾，"
    },
    {
      "note_id": "n043",
      "sentence_id": "s025",
      "score": 2.8,
      "anchor_text": "旁羅日月星辰水波"
    },
    {
      "note_id": "n044",
      "sentence_id": "s025",
      "score": 2.4,
      "anchor_text": "土石金玉，"
    },
    {
      "note_id": "n045",
      "sentence_id": "s025",
      "score": 1.0,
      "anchor_text": "勞勤心力耳目，節用水火材物。"
    },
    {
      "note_id": "n046",
      "sentence_id": "s026",
      "score": 1.0,
      "anchor_text": "有土德之瑞，故號黃帝。"
    },
    {
      "note_id": "n047",
      "sentence_id": "s027",
      "score": 1.0,
      "anchor_text": "黃帝二十五子，其得姓者十四人。"
    },
    {
      "note_id": "n048",
      "sentence_id": "s028",
      "score": 2.7,
      "anchor_text": "黃帝居軒轅之丘，"
    },
    {
      "note_id": "n049",
      "sentence_id": "s028",
      "score": 2.7,
      "anchor_text": "而娶於西陵之女，"
    },
    {
      "note_id": "n050",
      "sentence_id": "s028",
      "score": 2.4,
      "anchor_text": "是爲嫘祖。"
    },
    {
      "note_id": "n051",
      "sentence_id": "s029",
      "score": 2.7,
      "anchor_text": "嫘祖爲黃帝正妃，"
    },
    {
      "note_id": "n052",
      "sentence_id": "s029",
      "score": 1.0,
      "anchor_text": "子，其後皆有天下：其一曰玄囂，是爲青陽，"
    },
    {
      "note_id": "n053",
      "sentence_id": "s029",
      "score": 2.6,
      "anchor_text": "青陽降居江水；"
    },
    {
      "note_id": "n054",
      "sentence_id": "s029",
      "score": 1.0,
      "anchor_text": "其二曰昌意，降居若水。"
    },
    {
      "note_id": "n055",
      "sentence_id": "s030",
      "score": 0.93,
      "anchor_text": "蜀山氏女，曰昌僕，生高陽，高陽有聖悳焉。"
    },
    {
      "note_id": "n056",
      "sentence_id": "s031",
      "score": 2.3,
      "anchor_text": "黃帝崩，"
    },
    {
      "note_id": "n057",
      "sentence_id": "s031",
      "score": 0.67,
      "anchor_text": "葬橋山。"
    },
    {
      "note_id": "n058",
      "sentence_id": "s033",
      "score": 2.6,
      "anchor_text": "帝顓頊高陽者，"
    },
    {
      "note_id": "n059",
      "sentence_id": "s034",
      "score": 0.93,
      "anchor_text": "也。靜淵以有謀，疏通而知事；養材以任地，"
    },
    {
      "note_id": "n060",
      "sentence_id": "s034",
      "score": 2.2,
      "anchor_text": "載時"
    },
    {
      "note_id": "n061",
      "sentence_id": "s034",
      "score": 1.0,
      "anchor_text": "以象天，依鬼神以制義，"
    },
    {
      "note_id": "n062",
      "sentence_id": "s034",
      "score": 2.2,
      "anchor_text": "治氣"
    },
    {
      "note_id": "n063",
      "sentence_id": "s034",
      "score": 0.58,
      "anchor_text": "以教化，絜誠以祭祀。北至于幽陵，"
    },
    {
      "note_id": "n064",
      "sentence_id": "s035",
      "score": 2.5,
      "anchor_text": "南至于交阯，"
    },
    {
      "note_id": "n065",
      "sentence_id": "s035",
      "score": 2.5,
      "anchor_text": "西至于流沙，"
    },
    {
      "note_id": "n066",
      "sentence_id": "s035",
      "score": 2.5,
      "anchor_text": "東至于蟠木。"
    },
    {
      "note_id": "n067",
      "sentence_id": "s036",
      "score": 2.4,
      "anchor_text": "動靜之物，"
    },
    {
      "note_id": "n068",
      "sentence_id": "s036",
      "score": 2.4,
      "anchor_text": "大小之神，"
    },
    {
      "note_id": "n069",
      "sentence_id": "s036",
      "score": 0.88,
      "anchor_text": "日月所照，莫不砥屬。"
    },
    {
      "note_id": "n070",
      "sentence_id": "s037",
      "score": 0.88,
      "anchor_text": "帝顓頊生子曰窮蟬。"
    },
    {
      "note_id": "n071",
      "sentence_id": "s038",
      "score": 2.3,
      "anchor_text": "顓頊崩，"
    },
    {
      "note_id": "n072",
      "sentence_id": "s039",
      "score": 2.5,
      "anchor_text": "帝嚳高辛者，"
    },
    {
      "note_id": "n073",
      "sentence_id": "s039",
      "score": 0.67,
      "anchor_text": "黃帝之曾孫也。高辛父曰蟜極，"
    },
    {
      "note_id": "n074",
      "sentence_id": "s041",
      "score": 3.0,
      "anchor_text": "。自玄囂與蟜極皆不得在位，至高辛即帝位。"
    },
    {
      "note_id": "n075",
      "sentence_id": "s043",
      "score": 1.0,
      "anchor_text": "高辛生而神靈，自言其名。"
    },
    {
      "note_id": "n076",
      "sentence_id": "s048",
      "score": 0.86,
      "anchor_text": "用之，撫教萬民而利誨之，曆日月而迎送之，"
    },
    {
      "note_id": "n077",
      "sentence_id": "s048",
      "score": 2.7,
      "anchor_text": "明鬼神而敬事之。"
    },
    {
      "note_id": "n078",
      "sentence_id": "s049",
      "score": 1.0,
      "anchor_text": "其色郁郁，其德嶷嶷。"
    },
    {
      "note_id": "n079",
      "sentence_id": "s050",
      "score": 1.0,
      "anchor_text": "其動也時，其服也士。"
    },
    {
      "note_id": "n080",
      "sentence_id": "s051",
      "score": 0.78,
      "anchor_text": "帝嚳溉執中而徧天下，"
    },
    {
      "note_id": "n081",
      "sentence_id": "s051",
      "score": 1.0,
      "anchor_text": "日月所照，風雨所至，莫不從服。"
    },
    {
      "note_id": "n082",
      "sentence_id": "s052",
      "score": 2.7,
      "anchor_text": "帝嚳娶陳鋒氏女，"
    },
    {
      "note_id": "n083",
      "sentence_id": "s052",
      "score": 2.3,
      "anchor_text": "生放勳。"
    },
    {
      "note_id": "n084",
      "sentence_id": "s053",
      "score": 1.0,
      "anchor_text": "娶娵訾氏女，生摯。"
    },
    {
      "note_id": "n085",
      "sentence_id": "s054",
      "score": 2.3,
      "anchor_text": "帝嚳崩，"
    },
    {
      "note_id": "n086",
      "sentence_id": "s054",
      "score": 0.6,
      "anchor_text": "而摯代立。帝摯立，不善（崩），"
    },
    {
      "note_id": "n087",
      "sentence_id": "s056",
      "score": 2.3,
      "anchor_text": "帝堯者，"
    },
    {
      "note_id": "n088",
      "sentence_id": "s052",
      "score": 2.2,
      "anchor_text": "放勳。"
    },
    {
      "note_id": "n089",
      "sentence_id": "s057",
      "score": 2.4,
      "anchor_text": "其仁如天，"
    },
    {
      "note_id": "n090",
      "sentence_id": "s057",
      "score": 2.4,
      "anchor_text": "其知如神。"
    },
    {
      "note_id": "n091",
      "sentence_id": "s058",
      "score": 2.4,
      "anchor_text": "就之如日，"
    },
    {
      "note_id": "n092",
      "sentence_id": "s058",
      "score": 2.4,
      "anchor_text": "望之如雲。"
    },
    {
      "note_id": "n093",
      "sentence_id": "s059",
      "score": 1.0,
      "anchor_text": "富而不驕，貴而不舒。"
    },
    {
      "note_id": "n094",
      "sentence_id": "s060",
      "score": 2.4,
      "anchor_text": "黃收純衣，"
    },
    {
      "note_id": "n095",
      "sentence_id": "s060",
      "score": 0.56,
      "anchor_text": "彤車乘白馬。能明馴德，"
    },
    {
      "note_id": "n096",
      "sentence_id": "s062",
      "score": 0.8,
      "anchor_text": "以親九族。九族既睦，便章百姓。"
    },
    {
      "note_id": "n097",
      "sentence_id": "s064",
      "score": 1.0,
      "anchor_text": "乃命羲、和，"
    },
    {
      "note_id": "n098",
      "sentence_id": "s064",
      "score": 2.4,
      "anchor_text": "敬順昊天，"
    },
    {
      "note_id": "n099",
      "sentence_id": "s064",
      "score": 2.2,
      "anchor_text": "數法"
    },
    {
      "note_id": "n100",
      "sentence_id": "s025",
      "score": 2.4,
      "anchor_text": "日月星辰，"
    },
    {
      "note_id": "n101",
      "sentence_id": "s064",
      "score": 2.4,
      "anchor_text": "敬授民時。"
    },
    {
      "note_id": "n102",
      "sentence_id": "s065",
      "score": 1.0,
      "anchor_text": "分命羲仲，居郁夷，曰暘谷。"
    },
    {
      "note_id": "n103",
      "sentence_id": "s066",
      "score": 1.0,
      "anchor_text": "敬道日出，便程東作。"
    },
    {
      "note_id": "n104",
      "sentence_id": "s067",
      "score": 1.0,
      "anchor_text": "日中，星鳥，以殷中春。"
    },
    {
      "note_id": "n105",
      "sentence_id": "s068",
      "score": 1.0,
      "anchor_text": "其民析，鳥獸字微。"
    },
    {
      "note_id": "n106",
      "sentence_id": "s069",
      "score": 1.0,
      "anchor_text": "申命羲叔，居南交。"
    },
    {
      "note_id": "n107",
      "sentence_id": "s070",
      "score": 1.0,
      "anchor_text": "便程南爲，敬致。"
    },
    {
      "note_id": "n108",
      "sentence_id": "s071",
      "score": 1.0,
      "anchor_text": "日永，星火，以正中夏。"
    },
    {
      "note_id": "n109",
      "sentence_id": "s072",
      "score": 1.0,
      "anchor_text": "其民因，鳥獸希革。"
    },
    {
      "note_id": "n110",
      "sentence_id": "s073",
      "score": 2.4,
      "anchor_text": "申命和仲，"
    },
    {
      "note_id": "n111",
      "sentence_id": "s073",
      "score": 2.3,
      "anchor_text": "居西土，"
    },
    {
      "note_id": "n112",
      "sentence_id": "s073",
      "score": 2.3,
      "anchor_text": "曰昧谷。"
    },
    {
      "note_id": "n113",
      "sentence_id": "s074",
      "score": 1.0,
      "anchor_text": "敬道日入，便程西成。"
    },
    {
      "note_id": "n114",
      "sentence_id": "s075",
      "score": 1.0,
      "anchor_text": "夜中，星虛，"
    },
    {
      "note_id": "n115",
      "sentence_id": "s075",
      "score": 2.4,
      "anchor_text": "以正中秋。"
    },
    {
      "note_id": "n116",
      "sentence_id": "s076",
      "score": 1.0,
      "anchor_text": "其民夷易，鳥獸毛毨。"
    },
    {
      "note_id": "n117",
      "sentence_id": "s077",
      "score": 1.0,
      "anchor_text": "申命和叔；居北方，曰幽都。"
    },
    {
      "note_id": "n118",
      "sentence_id": "s078",
      "score": 2.4,
      "anchor_text": "便在伏物。"
    },
    {
      "note_id": "n119",
      "sentence_id": "s079",
      "score": 1.0,
      "anchor_text": "日短，星昴，以正中冬。"
    },
    {
      "note_id": "n120",
      "sentence_id": "s080",
      "score": 1.0,
      "anchor_text": "其民燠，鳥獸氄毛。"
    },
    {
      "note_id": "n121",
      "sentence_id": "s081",
      "score": 1.0,
      "anchor_text": "歲三百六十六日，以閏月正四時。"
    },
    {
      "note_id": "n122",
      "sentence_id": "s047",
      "score": 0.5,
      "anchor_text": "信飭"
    },
    {
      "note_id": "n123",
      "sentence_id": "s083",
      "score": 0.78,
      "anchor_text": "堯曰：「誰可順此事？」"
    },
    {
      "note_id": "n124",
      "sentence_id": "s084",
      "score": 0.73,
      "anchor_text": "放齊曰：「嗣子丹朱開明。」"
    },
    {
      "note_id": "n125",
      "sentence_id": "s086",
      "score": 0.44,
      "anchor_text": "堯曰：「吁！頑凶，不用。」"
    },
    {
      "note_id": "n126",
      "sentence_id": "s088",
      "score": 0.79,
      "anchor_text": "可者？」讙兜曰：「共工旁聚布功，可用。」"
    },
    {
      "note_id": "n127",
      "sentence_id": "s089",
      "score": 0.87,
      "anchor_text": "：「共工善言，其用僻，似恭漫天，不可。」"
    },
    {
      "note_id": "n128",
      "sentence_id": "s090",
      "score": 0.86,
      "anchor_text": "堯又曰：「嗟，四嶽，"
    },
    {
      "note_id": "n129",
      "sentence_id": "s090",
      "score": 1.0,
      "anchor_text": "湯湯洪水滔天，浩浩懷山襄陵，"
    },
    {
      "note_id": "n130",
      "sentence_id": "s090",
      "score": 0.71,
      "anchor_text": "下民其憂，有能使治者？」皆曰鯀可。"
    },
    {
      "note_id": "n131",
      "sentence_id": "s092",
      "score": 0.73,
      "anchor_text": "堯曰：「鯀負命毀族，不可。」"
    },
    {
      "note_id": "n132",
      "sentence_id": "s093",
      "score": 0.83,
      "anchor_text": "嶽曰：「异哉，試不可用而已。」"
    },
    {
      "note_id": "n133",
      "sentence_id": "s094",
      "score": 0.58,
      "anchor_text": "堯於是聽嶽用鯀。九歲，功用不成。"
    },
    {
      "note_id": "n134",
      "sentence_id": "s097",
      "score": 0.93,
      "anchor_text": "四嶽：朕在位七十載，汝能庸命，踐朕位？」"
    },
    {
      "note_id": "n135",
      "sentence_id": "s098",
      "score": 0.7,
      "anchor_text": "嶽應曰：「鄙悳忝帝位。」"
    },
    {
      "note_id": "n136",
      "sentence_id": "s100",
      "score": 0.8,
      "anchor_text": "」眾皆言於堯曰：「有矜在民閒，曰虞舜。」"
    },
    {
      "note_id": "n137",
      "sentence_id": "s104",
      "score": 0.93,
      "anchor_text": "母嚚，弟傲，能和以孝，烝烝治，不至姦。」"
    },
    {
      "note_id": "n138",
      "sentence_id": "s105",
      "score": 0.75,
      "anchor_text": "堯曰：「吾其試哉。」"
    },
    {
      "note_id": "n139",
      "sentence_id": "s106",
      "score": 2.7,
      "anchor_text": "於是堯妻之二女，"
    },
    {
      "note_id": "n140",
      "sentence_id": "s106",
      "score": 2.6,
      "anchor_text": "觀其德於二女。"
    },
    {
      "note_id": "n141",
      "sentence_id": "s107",
      "score": 0.88,
      "anchor_text": "舜飭下二女於嬀汭，"
    },
    {
      "note_id": "n142",
      "sentence_id": "s108",
      "score": 0.77,
      "anchor_text": "如婦禮。堯善之，乃使舜慎和五典，"
    },
    {
      "note_id": "n143",
      "sentence_id": "s110",
      "score": 1.0,
      "anchor_text": "。賓於四門，四門穆穆，諸侯遠方賓客皆敬。"
    },
    {
      "note_id": "n144",
      "sentence_id": "s111",
      "score": 2.6,
      "anchor_text": "堯使舜入山林"
    },
    {
      "note_id": "n145",
      "sentence_id": "s112",
      "score": 0.88,
      "anchor_text": "聖，召舜曰：「女謀事至而言可績，三年矣。"
    },
    {
      "note_id": "n146",
      "sentence_id": "s114",
      "score": 0.55,
      "anchor_text": "女登帝位。」舜讓於德不懌。"
    },
    {
      "note_id": "n147",
      "sentence_id": "s115",
      "score": 2.4,
      "anchor_text": "正月上日，"
    },
    {
      "note_id": "n148",
      "sentence_id": "s115",
      "score": 0.6,
      "anchor_text": "舜受終於文祖。文祖者，堯大祖也。"
    },
    {
      "note_id": "n149",
      "sentence_id": "s118",
      "score": 0.71,
      "anchor_text": "政，以觀天命。舜乃在璿璣玉衡，以齊七政。"
    },
    {
      "note_id": "n150",
      "sentence_id": "s119",
      "score": 2.5,
      "anchor_text": "遂類于上帝，"
    },
    {
      "note_id": "n151",
      "sentence_id": "s119",
      "score": 2.4,
      "anchor_text": "禋于六宗，"
    },
    {
      "note_id": "n152",
      "sentence_id": "s119",
      "score": 2.4,
      "anchor_text": "望于山川，"
    },
    {
      "note_id": "n153",
      "sentence_id": "s119",
      "score": 2.4,
      "anchor_text": "辯于羣神。"
    },
    {
      "note_id": "n154",
      "sentence_id": "s120",
      "score": 1.0,
      "anchor_text": "揖五瑞，擇吉月日，見四嶽諸牧，班瑞。"
    },
    {
      "note_id": "n155",
      "sentence_id": "s121",
      "score": 1.0,
      "anchor_text": "歲二月，東巡狩，至於岱宗，祡，"
    },
    {
      "note_id": "n156",
      "sentence_id": "s121",
      "score": 2.5,
      "anchor_text": "望秩於山川。"
    },
    {
      "note_id": "n157",
      "sentence_id": "s122",
      "score": 1.0,
      "anchor_text": "遂見東方君長，合時月正日，"
    },
    {
      "note_id": "n158",
      "sentence_id": "s122",
      "score": 2.5,
      "anchor_text": "同律度量衡，"
    },
    {
      "note_id": "n159",
      "sentence_id": "s122",
      "score": 2.3,
      "anchor_text": "脩五禮"
    },
    {
      "note_id": "n160",
      "sentence_id": "s122",
      "score": 2.2,
      "anchor_text": "五玉"
    },
    {
      "note_id": "n161",
      "sentence_id": "s122",
      "score": 2.2,
      "anchor_text": "三帛"
    },
    {
      "note_id": "n162",
      "sentence_id": "s122",
      "score": 2.2,
      "anchor_text": "二生"
    },
    {
      "note_id": "n163",
      "sentence_id": "s122",
      "score": 2.2,
      "anchor_text": "一死"
    },
    {
      "note_id": "n164",
      "sentence_id": "s122",
      "score": 2.2,
      "anchor_text": "爲摯，"
    },
    {
      "note_id": "n165",
      "sentence_id": "s122",
      "score": 1.0,
      "anchor_text": "如五器，卒乃復。"
    },
    {
      "note_id": "n166",
      "sentence_id": "s123",
      "score": 0.6,
      "anchor_text": "十一月，北巡狩：皆如初。歸，至于祖禰廟，"
    },
    {
      "note_id": "n167",
      "sentence_id": "s125",
      "score": 0.69,
      "anchor_text": "用特牛禮。五歲一巡狩，羣后四朝。"
    },
    {
      "note_id": "n168",
      "sentence_id": "s126",
      "score": 0.75,
      "anchor_text": "徧告以言，"
    },
    {
      "note_id": "n169",
      "sentence_id": "s126",
      "score": 1.0,
      "anchor_text": "明試以功，車服以庸。"
    },
    {
      "note_id": "n170",
      "sentence_id": "s127",
      "score": 1.0,
      "anchor_text": "肇十有二州，決川。"
    },
    {
      "note_id": "n171",
      "sentence_id": "s128",
      "score": 2.4,
      "anchor_text": "象以典刑，"
    },
    {
      "note_id": "n172",
      "sentence_id": "s128",
      "score": 2.4,
      "anchor_text": "流宥五刑，"
    },
    {
      "note_id": "n173",
      "sentence_id": "s128",
      "score": 2.4,
      "anchor_text": "鞭作官刑，"
    },
    {
      "note_id": "n174",
      "sentence_id": "s128",
      "score": 2.4,
      "anchor_text": "扑作教刑，"
    },
    {
      "note_id": "n175",
      "sentence_id": "s128",
      "score": 2.4,
      "anchor_text": "金作贖刑。"
    },
    {
      "note_id": "n176",
      "sentence_id": "s129",
      "score": 0.5,
      "anchor_text": "眚烖過，赦；"
    },
    {
      "note_id": "n177",
      "sentence_id": "s129",
      "score": 2.2,
      "anchor_text": "怙終"
    },
    {
      "note_id": "n178",
      "sentence_id": "s129",
      "score": 1.0,
      "anchor_text": "賊，刑。"
    },
    {
      "note_id": "n179",
      "sentence_id": "s130",
      "score": 0.83,
      "anchor_text": "欽哉，欽哉，惟刑之靜哉！"
    },
    {
      "note_id": "n180",
      "sentence_id": "s131",
      "score": 2.6,
      "anchor_text": "讙兜進言共工，"
    },
    {
      "note_id": "n181",
      "sentence_id": "s131",
      "score": 2.9,
      "anchor_text": "堯曰不可而試之工師，"
    },
    {
      "note_id": "n182",
      "sentence_id": "s131",
      "score": 2.5,
      "anchor_text": "共工果淫辟。"
    },
    {
      "note_id": "n183",
      "sentence_id": "s132",
      "score": 0.87,
      "anchor_text": "嶽彊請試之，試之而無功，故百姓不便。三苗"
    },
    {
      "note_id": "n184",
      "sentence_id": "s133",
      "score": 1.0,
      "anchor_text": "在江淮、荊州"
    },
    {
      "note_id": "n185",
      "sentence_id": "s134",
      "score": 0.87,
      "anchor_text": "爲亂。於是舜歸而言於帝，請流共工於幽陵，"
    },
    {
      "note_id": "n186",
      "sentence_id": "s134",
      "score": 2.4,
      "anchor_text": "以變北狄；"
    },
    {
      "note_id": "n187",
      "sentence_id": "s134",
      "score": 2.6,
      "anchor_text": "放驩兜於崇山，"
    },
    {
      "note_id": "n188",
      "sentence_id": "s134",
      "score": 0.89,
      "anchor_text": "以變南蠻；遷三苗於三危，"
    },
    {
      "note_id": "n189",
      "sentence_id": "s134",
      "score": 1.0,
      "anchor_text": "以變西戎；殛鯀於羽山，"
    },
    {
      "note_id": "n190",
      "sentence_id": "s135",
      "score": 0.69,
      "anchor_text": "子之政，薦之於天。堯辟位凡二十八年而崩。"
    },
    {
      "note_id": "n191",
      "sentence_id": "s137",
      "score": 0.47,
      "anchor_text": "百姓悲哀，如喪父母。三年，四方莫舉樂，"
    },
    {
      "note_id": "n192",
      "sentence_id": "s139",
      "score": 0.7,
      "anchor_text": "以思堯。堯知子丹朱之不肖，"
    },
    {
      "note_id": "n193",
      "sentence_id": "s139",
      "score": 0.9,
      "anchor_text": "不足授天下，於是乃權授舜。"
    },
    {
      "note_id": "n194",
      "sentence_id": "s142",
      "score": 0.8,
      "anchor_text": "堯崩，三年之喪畢，舜讓辟丹朱於南河之南。"
    },
    {
      "note_id": "n195",
      "sentence_id": "s144",
      "score": 0.88,
      "anchor_text": "。舜曰「天也」，夫而後之中國踐天子位焉，"
    },
    {
      "note_id": "n196",
      "sentence_id": "s145",
      "score": 2.3,
      "anchor_text": "虞舜者，"
    },
    {
      "note_id": "n197",
      "sentence_id": "s145",
      "score": 2.4,
      "anchor_text": "名曰重華。"
    },
    {
      "note_id": "n198",
      "sentence_id": "s146",
      "score": 2.6,
      "anchor_text": "重華父曰瞽叟，"
    },
    {
      "note_id": "n199",
      "sentence_id": "s146",
      "score": 0.83,
      "anchor_text": "瞽叟父曰橋牛，"
    },
    {
      "note_id": "n200",
      "sentence_id": "s146",
      "score": 0.83,
      "anchor_text": "橋牛父曰句望，"
    },
    {
      "note_id": "n201",
      "sentence_id": "s148",
      "score": 1.0,
      "anchor_text": "舜父瞽叟盲，而舜母"
    },
    {
      "note_id": "n202",
      "sentence_id": "s151",
      "score": 1.0,
      "anchor_text": "舜，冀州之人也。"
    },
    {
      "note_id": "n203",
      "sentence_id": "s152",
      "score": 2.4,
      "anchor_text": "舜耕歷山，"
    },
    {
      "note_id": "n204",
      "sentence_id": "s152",
      "score": 0.67,
      "anchor_text": "漁雷澤，"
    },
    {
      "note_id": "n205",
      "sentence_id": "s152",
      "score": 0.67,
      "anchor_text": "陶河濱，"
    },
    {
      "note_id": "n206",
      "sentence_id": "s152",
      "score": 2.6,
      "anchor_text": "作什器於壽丘，"
    },
    {
      "note_id": "n207",
      "sentence_id": "s152",
      "score": 2.5,
      "anchor_text": "就時於負夏。"
    },
    {
      "note_id": "n208",
      "sentence_id": "s157",
      "score": 0.67,
      "anchor_text": "舜年二十以孝聞。三十而帝堯問可用者，"
    },
    {
      "note_id": "n209",
      "sentence_id": "s160",
      "score": 0.71,
      "anchor_text": "汭，內行彌謹。堯二女不敢以貴驕事舜親戚，"
    },
    {
      "note_id": "n210",
      "sentence_id": "s161",
      "score": 0.6,
      "anchor_text": "甚有婦道。堯九男皆益篤。"
    },
    {
      "note_id": "n211",
      "sentence_id": "s162",
      "score": 1.0,
      "anchor_text": "舜耕歷山，歷山之人皆讓畔；"
    },
    {
      "note_id": "n212",
      "sentence_id": "s162",
      "score": 0.86,
      "anchor_text": "雷澤上人皆讓居；陶河濱，河濱器皆不苦窳。"
    },
    {
      "note_id": "n213",
      "sentence_id": "s163",
      "score": 2.7,
      "anchor_text": "一年而所居成聚，"
    },
    {
      "note_id": "n214",
      "sentence_id": "s163",
      "score": 1.0,
      "anchor_text": "二年成邑，三年成都。"
    },
    {
      "note_id": "n215",
      "sentence_id": "s164",
      "score": 2.6,
      "anchor_text": "堯乃賜舜絺衣，"
    },
    {
      "note_id": "n216",
      "sentence_id": "s166",
      "score": 0.81,
      "anchor_text": "火焚廩。舜乃以兩笠自扞而下，去，得不死。"
    },
    {
      "note_id": "n217",
      "sentence_id": "s167",
      "score": 1.0,
      "anchor_text": "後瞽叟又使舜穿井，舜穿井爲匿空"
    },
    {
      "note_id": "n218",
      "sentence_id": "s167",
      "score": 2.2,
      "anchor_text": "旁出。"
    },
    {
      "note_id": "n219",
      "sentence_id": "s168",
      "score": 1.0,
      "anchor_text": "舜既入深，瞽叟與象共下土實井，"
    },
    {
      "note_id": "n220",
      "sentence_id": "s168",
      "score": 1.0,
      "anchor_text": "舜從匿空出，去。"
    },
    {
      "note_id": "n221",
      "sentence_id": "s171",
      "score": 0.47,
      "anchor_text": "爲已死。象曰「本謀者象。」象與其父母分，"
    },
    {
      "note_id": "n222",
      "sentence_id": "s164",
      "score": 0.44,
      "anchor_text": "象取之。牛羊倉廩予父母。」象乃止舜宮居，"
    },
    {
      "note_id": "n223",
      "sentence_id": "s175",
      "score": 0.5,
      "anchor_text": "我思舜正鬱陶！」舜曰：「然，爾其庶矣！」"
    },
    {
      "note_id": "n224",
      "sentence_id": "s179",
      "score": 2.9,
      "anchor_text": "昔高陽氏有才子八人，"
    },
    {
      "note_id": "n225",
      "sentence_id": "s179",
      "score": 0.8,
      "anchor_text": "世得其利，謂之「八愷」。"
    },
    {
      "note_id": "n226",
      "sentence_id": "s179",
      "score": 2.9,
      "anchor_text": "昔高陽氏有才子八人，"
    },
    {
      "note_id": "n227",
      "sentence_id": "s180",
      "score": 0.71,
      "anchor_text": "世謂之「八元」。"
    },
    {
      "note_id": "n228",
      "sentence_id": "s181",
      "score": 0.89,
      "anchor_text": "此十六族者，世濟其美，"
    },
    {
      "note_id": "n229",
      "sentence_id": "s183",
      "score": 0.62,
      "anchor_text": "。至於堯，堯未能舉。舜舉八愷，使主后土，"
    },
    {
      "note_id": "n230",
      "sentence_id": "s183",
      "score": 1.0,
      "anchor_text": "以揆百事，莫不時序。"
    },
    {
      "note_id": "n231",
      "sentence_id": "s184",
      "score": 1.0,
      "anchor_text": "舉八元，使布五教于四方，"
    },
    {
      "note_id": "n232",
      "sentence_id": "s184",
      "score": 1.0,
      "anchor_text": "父義，母慈，兄友，弟恭，子孝，內平外成。"
    },
    {
      "note_id": "n233",
      "sentence_id": "s185",
      "score": 2.8,
      "anchor_text": "昔帝鴻氏有不才子，"
    },
    {
      "note_id": "n234",
      "sentence_id": "s185",
      "score": 1.0,
      "anchor_text": "掩義隱賊，好行凶慝，天下謂之渾沌。"
    },
    {
      "note_id": "n235",
      "sentence_id": "s186",
      "score": 2.3,
      "anchor_text": "少暤氏"
    },
    {
      "note_id": "n236",
      "sentence_id": "s186",
      "score": 0.87,
      "anchor_text": "才子，毀信惡忠，崇飾惡言，天下謂之窮奇。"
    },
    {
      "note_id": "n237",
      "sentence_id": "s187",
      "score": 1.0,
      "anchor_text": "才子，不可教訓，不知話言，天下謂之檮杌。"
    },
    {
      "note_id": "n238",
      "sentence_id": "s188",
      "score": 0.4,
      "anchor_text": "此三族世憂之。至于堯，堯未能去。縉雲氏"
    },
    {
      "note_id": "n239",
      "sentence_id": "s190",
      "score": 1.0,
      "anchor_text": "才子，貪于飲食，冒于貨賄，天下謂之饕餮。"
    },
    {
      "note_id": "n240",
      "sentence_id": "s191",
      "score": 1.0,
      "anchor_text": "天下惡之，比之三凶。"
    },
    {
      "note_id": "n241",
      "sentence_id": "s192",
      "score": 2.5,
      "anchor_text": "舜賓於四門，"
    },
    {
      "note_id": "n242",
      "sentence_id": "s192",
      "score": 0.88,
      "anchor_text": "乃流四凶族，遷于四裔，"
    },
    {
      "note_id": "n243",
      "sentence_id": "s192",
      "score": 2.4,
      "anchor_text": "以御螭魅，"
    },
    {
      "note_id": "n244",
      "sentence_id": "s197",
      "score": 0.53,
      "anchor_text": "三年喪畢，讓丹朱，天下歸舜。而禹、皋陶、"
    },
    {
      "note_id": "n245",
      "sentence_id": "s198",
      "score": 1.0,
      "anchor_text": "契、后稷、伯夷、夔、龍、倕、益、彭祖"
    },
    {
      "note_id": "n246",
      "sentence_id": "s198",
      "score": 1.0,
      "anchor_text": "自堯時而皆舉用，未有分職。"
    },
    {
      "note_id": "n247",
      "sentence_id": "s199",
      "score": 1.0,
      "anchor_text": "方耳目，命十二牧論帝德，行厚德，遠佞人，"
    },
    {
      "note_id": "n248",
      "sentence_id": "s200",
      "score": 0.6,
      "anchor_text": "則蠻夷率服。舜謂四嶽曰：「有能奮庸"
    },
    {
      "note_id": "n249",
      "sentence_id": "s204",
      "score": 0.5,
      "anchor_text": "，讓於稷、契與皋陶。舜曰：「然，往矣。」"
    },
    {
      "note_id": "n250",
      "sentence_id": "s206",
      "score": 0.75,
      "anchor_text": "舜曰：「弃，黎民始飢，"
    },
    {
      "note_id": "n251",
      "sentence_id": "s206",
      "score": 0.88,
      "anchor_text": "汝后稷播時百穀。」"
    },
    {
      "note_id": "n252",
      "sentence_id": "s207",
      "score": 0.91,
      "anchor_text": "舜曰：「契，百姓不親，五品不馴，"
    },
    {
      "note_id": "n253",
      "sentence_id": "s207",
      "score": 0.92,
      "anchor_text": "汝爲司徒，而敬敷五教，在寬。」"
    },
    {
      "note_id": "n254",
      "sentence_id": "s208",
      "score": 0.89,
      "anchor_text": "舜曰：「皋陶，蠻夷猾夏，"
    },
    {
      "note_id": "n255",
      "sentence_id": "s208",
      "score": 2.4,
      "anchor_text": "寇賊姦軌，"
    },
    {
      "note_id": "n256",
      "sentence_id": "s208",
      "score": 2.3,
      "anchor_text": "汝作士，"
    },
    {
      "note_id": "n257",
      "sentence_id": "s208",
      "score": 1.0,
      "anchor_text": "五刑有服，五服三就；"
    },
    {
      "note_id": "n258",
      "sentence_id": "s208",
      "score": 2.4,
      "anchor_text": "五流有度，"
    },
    {
      "note_id": "n259",
      "sentence_id": "s208",
      "score": 2.4,
      "anchor_text": "五度三居："
    },
    {
      "note_id": "n260",
      "sentence_id": "s208",
      "score": 0.8,
      "anchor_text": "維明能信。」"
    },
    {
      "note_id": "n261",
      "sentence_id": "s209",
      "score": 0.78,
      "anchor_text": "舜曰：「誰能馴予工？」"
    },
    {
      "note_id": "n262",
      "sentence_id": "s211",
      "score": 0.7,
      "anchor_text": "皆曰垂可。於是以垂爲共工。"
    },
    {
      "note_id": "n263",
      "sentence_id": "s212",
      "score": 0.89,
      "anchor_text": "舜曰：「誰能馴予上下"
    },
    {
      "note_id": "n264",
      "sentence_id": "s214",
      "score": 0.47,
      "anchor_text": "草木鳥獸？」皆曰益可。於是以益爲朕虞。"
    },
    {
      "note_id": "n265",
      "sentence_id": "s215",
      "score": 0.92,
      "anchor_text": "益拜稽首，讓于諸臣朱虎、熊羆。"
    },
    {
      "note_id": "n266",
      "sentence_id": "s217",
      "score": 0.47,
      "anchor_text": "曰：「往矣，汝諧。」遂以朱虎、熊羆爲佐。"
    },
    {
      "note_id": "n267",
      "sentence_id": "s219",
      "score": 0.62,
      "anchor_text": "舜曰：「嗟！四嶽，有能典朕三禮？」"
    },
    {
      "note_id": "n268",
      "sentence_id": "s222",
      "score": 0.58,
      "anchor_text": "曰伯夷可。舜曰：「嗟！伯夷，以汝爲秩宗，"
    },
    {
      "note_id": "n269",
      "sentence_id": "s222",
      "score": 0.89,
      "anchor_text": "夙夜維敬，直哉維靜絜。」"
    },
    {
      "note_id": "n270",
      "sentence_id": "s223",
      "score": 0.56,
      "anchor_text": "伯夷讓夔、龍。舜曰：「然。"
    },
    {
      "note_id": "n271",
      "sentence_id": "s225",
      "score": 1.0,
      "anchor_text": "以夔爲典樂，教稺子，"
    },
    {
      "note_id": "n272",
      "sentence_id": "s225",
      "score": 2.3,
      "anchor_text": "直而溫，"
    },
    {
      "note_id": "n273",
      "sentence_id": "s225",
      "score": 2.3,
      "anchor_text": "寬而栗，"
    },
    {
      "note_id": "n274",
      "sentence_id": "s225",
      "score": 1.0,
      "anchor_text": "剛而毋虐，簡而毋傲；"
    },
    {
      "note_id": "n275",
      "sentence_id": "s225",
      "score": 0.8,
      "anchor_text": "詩言意，歌長言，"
    },
    {
      "note_id": "n276",
      "sentence_id": "s225",
      "score": 1.0,
      "anchor_text": "聲依永，律和聲，"
    },
    {
      "note_id": "n277",
      "sentence_id": "s225",
      "score": 0.92,
      "anchor_text": "八音能諧，毋相奪倫，神人以和。」"
    },
    {
      "note_id": "n278",
      "sentence_id": "s227",
      "score": 0.62,
      "anchor_text": "夔曰：「於！予擊石拊石，百獸率舞。」"
    },
    {
      "note_id": "n279",
      "sentence_id": "s228",
      "score": 0.93,
      "anchor_text": "舜曰：「龍，朕畏忌讒說殄僞，振驚朕眾，"
    },
    {
      "note_id": "n280",
      "sentence_id": "s228",
      "score": 0.92,
      "anchor_text": "命汝爲納言，夙夜出入朕命，惟信。」"
    },
    {
      "note_id": "n281",
      "sentence_id": "s230",
      "score": 0.56,
      "anchor_text": "舜曰：「嗟！女二十有二人，"
    },
    {
      "note_id": "n282",
      "sentence_id": "s230",
      "score": 0.88,
      "anchor_text": "敬哉，惟時相天事。」"
    },
    {
      "note_id": "n283",
      "sentence_id": "s231",
      "score": 0.77,
      "anchor_text": "考功，三考絀陟，遠近眾功咸興。分北三苗。"
    },
    {
      "note_id": "n284",
      "sentence_id": "s233",
      "score": 1.0,
      "anchor_text": "此二十二人咸成厥功：皋陶爲大理，平，"
    },
    {
      "note_id": "n285",
      "sentence_id": "s233",
      "score": 1.0,
      "anchor_text": "伏得其實；伯夷主禮，上下咸讓；垂主工師，"
    },
    {
      "note_id": "n286",
      "sentence_id": "s233",
      "score": 0.9,
      "anchor_text": "百工致功；益主虞，山澤辟；"
    },
    {
      "note_id": "n287",
      "sentence_id": "s233",
      "score": 1.0,
      "anchor_text": "主賓客，遠人至；十二牧行而九州莫敢辟違；"
    },
    {
      "note_id": "n288",
      "sentence_id": "s233",
      "score": 1.0,
      "anchor_text": "唯禹之功爲大，披九山，"
    },
    {
      "note_id": "n289",
      "sentence_id": "s234",
      "score": 0.53,
      "anchor_text": "宜。方五千里，至于荒服。南撫交阯、北發，"
    },
    {
      "note_id": "n290",
      "sentence_id": "s234",
      "score": 0.53,
      "anchor_text": "宜。方五千里，至于荒服。南撫交阯、北發，"
    },
    {
      "note_id": "n291",
      "sentence_id": "s235",
      "score": 1.0,
      "anchor_text": "北山戎、發、息慎，"
    },
    {
      "note_id": "n292",
      "sentence_id": "s235",
      "score": 1.0,
      "anchor_text": "東長、鳥夷，"
    },
    {
      "note_id": "n293",
      "sentence_id": "s235",
      "score": 2.4,
      "anchor_text": "四海之內"
    },
    {
      "note_id": "n294",
      "sentence_id": "s236",
      "score": 0.64,
      "anchor_text": "咸戴帝舜之功。於是禹乃興九招之樂，"
    },
    {
      "note_id": "n295",
      "sentence_id": "s238",
      "score": 1.0,
      "anchor_text": "子事，年五十八堯崩，年六十一代堯踐帝位。"
    },
    {
      "note_id": "n296",
      "sentence_id": "s240",
      "score": 0.67,
      "anchor_text": "，崩於蒼梧之野。葬於江南九疑，是爲零陵。"
    },
    {
      "note_id": "n297",
      "sentence_id": "s241",
      "score": 1.0,
      "anchor_text": "踐帝位，載天子旗，往朝父瞽叟，夔夔唯謹，"
    },
    {
      "note_id": "n298",
      "sentence_id": "s242",
      "score": 0.67,
      "anchor_text": "如子道。封弟象爲諸侯。"
    },
    {
      "note_id": "n299",
      "sentence_id": "s243",
      "score": 2.7,
      "anchor_text": "舜子商均亦不肖，"
    },
    {
      "note_id": "n300",
      "sentence_id": "s243",
      "score": 2.7,
      "anchor_text": "舜乃豫薦禹於天。"
    },
    {
      "note_id": "n301",
      "sentence_id": "s245",
      "score": 0.57,
      "anchor_text": "十七年而崩。三年喪畢，禹亦乃讓舜子，"
    },
    {
      "note_id": "n302",
      "sentence_id": "s247",
      "score": 0.71,
      "anchor_text": "踐天子位。堯子丹朱，舜子商均，皆有疆土，"
    },
    {
      "note_id": "n303",
      "sentence_id": "s248",
      "score": 0.43,
      "anchor_text": "以奉先祀。服其服，禮樂如之。以客見天子，"
    },
    {
      "note_id": "n304",
      "sentence_id": "s250",
      "score": 1.0,
      "anchor_text": "帝至舜、禹，皆同姓而異其國號，以章明德。"
    },
    {
      "note_id": "n305",
      "sentence_id": "s251",
      "score": 1.0,
      "anchor_text": "，帝顓頊爲高陽，帝嚳爲高辛，帝堯爲陶唐，"
    },
    {
      "note_id": "n306",
      "sentence_id": "s251",
      "score": 2.5,
      "anchor_text": "帝舜爲有虞。"
    },
    {
      "note_id": "n307",
      "sentence_id": "s252",
      "score": 0.75,
      "anchor_text": "禹爲夏后而別氏，姓姒氏。契爲商，姓子氏。"
    },
    {
      "note_id": "n308",
      "sentence_id": "s254",
      "score": 1.0,
      "anchor_text": "弃爲周，姓姬氏。"
    },
    {
      "note_id": "n309",
      "sentence_id": "s255",
      "score": 2.4,
      "anchor_text": "太史公曰："
    },
    {
      "note_id": "n310",
      "sentence_id": "s255",
      "score": 1.0,
      "anchor_text": "學者多稱五帝，尚矣。"
    },
    {
      "note_id": "n311",
      "sentence_id": "s256",
      "score": 0.94,
      "anchor_text": "》獨載堯以來；而百家言黃帝，其文不雅馴，"
    },
    {
      "note_id": "n312",
      "sentence_id": "s256",
      "score": 2.7,
      "anchor_text": "薦紳先生難言之。"
    },
    {
      "note_id": "n313",
      "sentence_id": "s257",
      "score": 0.87,
      "anchor_text": "孔子所傳宰予問《五帝德》及帝繫姓，"
    },
    {
      "note_id": "n314",
      "sentence_id": "s257",
      "score": 2.5,
      "anchor_text": "儒者或不傳。"
    },
    {
      "note_id": "n315",
      "sentence_id": "s258",
      "score": 0.83,
      "anchor_text": "余嘗西至空桐，"
    },
    {
      "note_id": "n316",
      "sentence_id": "s017",
      "score": 0.75,
      "anchor_text": "北過涿鹿，"
    },
    {
      "note_id": "n317",
      "sentence_id": "s258",
      "score": 0.94,
      "anchor_text": "舜之處，風教固殊焉，總之不離古文者近是。"
    },
    {
      "note_id": "n318",
      "sentence_id": "s259",
      "score": 0.79,
      "anchor_text": "《國語》，其發明《五帝德》、帝繫姓章矣，"
    },
    {
      "note_id": "n319",
      "sentence_id": "s259",
      "score": 2.5,
      "anchor_text": "顧弟弗深考，"
    },
    {
      "note_id": "n320",
      "sentence_id": "s259",
      "score": 2.7,
      "anchor_text": "其所表見皆不虛。"
    },
    {
      "note_id": "n321",
      "sentence_id": "s260",
      "score": 0.8,
      "anchor_text": "書缺有閒矣，"
    },
    {
      "note_id": "n322",
      "sentence_id": "s260",
      "score": 2.9,
      "anchor_text": "其軼乃時時見於他說。"
    },
    {
      "note_id": "n323",
      "sentence_id": "s262",
      "score": 1.0,
      "anchor_text": "余并論次，擇其言尤雅者，故著爲本紀書首。"
    }
  ]
}