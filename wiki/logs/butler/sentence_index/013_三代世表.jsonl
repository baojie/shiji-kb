{"sid": "013_三代世表.1.1.s1", "chapter": "013_三代世表", "para": "1.1", "seq": 1, "text": "太史公曰：五帝、三代之记，尚矣。", "len": 16}
{"sid": "013_三代世表.1.2.s1", "chapter": "013_三代世表", "para": "1.2", "seq": 1, "text": "自殷以前诸侯不可得而谱，周以来乃颇可著。", "len": 20}
{"sid": "013_三代世表.1.3.s1", "chapter": "013_三代世表", "para": "1.3", "seq": 1, "text": "孔子因史文次春秋，纪元年，正时日月，盖其详哉。", "len": 23}
{"sid": "013_三代世表.1.4.s1", "chapter": "013_三代世表", "para": "1.4", "seq": 1, "text": "至於序尚书则略，无年月；或颇有，然多阙，不可录。", "len": 24}
{"sid": "013_三代世表.1.5.s1", "chapter": "013_三代世表", "para": "1.5", "seq": 1, "text": "故疑则传疑，盖其慎也。", "len": 11}
{"sid": "013_三代世表.2.1.s1", "chapter": "013_三代世表", "para": "2.1", "seq": 1, "text": "余读谍记，黄帝以来皆有年数。", "len": 14}
{"sid": "013_三代世表.2.2.s1", "chapter": "013_三代世表", "para": "2.2", "seq": 1, "text": "稽其历谱谍终始五德之传，古文咸不同，乖异。", "len": 21}
{"sid": "013_三代世表.2.3.s1", "chapter": "013_三代世表", "para": "2.3", "seq": 1, "text": "夫子之弗论次其年月，岂虚哉！", "len": 14}
{"sid": "013_三代世表.2.4.s1", "chapter": "013_三代世表", "para": "2.4", "seq": 1, "text": "於是以五帝系谍、尚书集世纪黄帝以来讫共和为世表。", "len": 24}
{"sid": "013_三代世表.2.4.s2", "chapter": "013_三代世表", "para": "2.4", "seq": 2, "text": "::: | 帝王世国号 | 颛顼属 | 俈属 | 尧属 | 舜属 | 夏属 | 殷属 | 周属 | | [a1] 黄帝号有熊。", "len": 63}
{"sid": "013_三代世表.2.4.s3", "chapter": "013_三代世表", "para": "2.4", "seq": 3, "text": "| 黄帝生昌意。", "len": 8}
{"sid": "013_三代世表.2.4.s4", "chapter": "013_三代世表", "para": "2.4", "seq": 4, "text": "| 黄帝生玄嚣。", "len": 8}
{"sid": "013_三代世表.2.4.s5", "chapter": "013_三代世表", "para": "2.4", "seq": 5, "text": "| 黄帝生玄嚣。", "len": 8}
{"sid": "013_三代世表.2.4.s6", "chapter": "013_三代世表", "para": "2.4", "seq": 6, "text": "| 黄帝生昌意。", "len": 8}
{"sid": "013_三代世表.2.4.s7", "chapter": "013_三代世表", "para": "2.4", "seq": 7, "text": "| 黄帝生昌意。", "len": 8}
{"sid": "013_三代世表.2.4.s8", "chapter": "013_三代世表", "para": "2.4", "seq": 8, "text": "| 黄帝生玄嚣。", "len": 8}
{"sid": "013_三代世表.2.4.s9", "chapter": "013_三代世表", "para": "2.4", "seq": 9, "text": "| 黄帝生玄嚣。", "len": 8}
{"sid": "013_三代世表.2.4.s10", "chapter": "013_三代世表", "para": "2.4", "seq": 10, "text": "| | [a2] 颛顼，黄帝孙。", "len": 16}
{"sid": "013_三代世表.2.4.s11", "chapter": "013_三代世表", "para": "2.4", "seq": 11, "text": "起黄帝，至颛顼三世，号高阳。", "len": 14}
{"sid": "013_三代世表.2.4.s12", "chapter": "013_三代世表", "para": "2.4", "seq": 12, "text": "| 昌意生颛顼。", "len": 8}
{"sid": "013_三代世表.2.4.s13", "chapter": "013_三代世表", "para": "2.4", "seq": 13, "text": "为高阳氏。", "len": 5}
{"sid": "013_三代世表.2.4.s14", "chapter": "013_三代世表", "para": "2.4", "seq": 14, "text": "| 玄嚣生蟜极。", "len": 8}
{"sid": "013_三代世表.2.4.s15", "chapter": "013_三代世表", "para": "2.4", "seq": 15, "text": "| 玄嚣生蟜极。", "len": 8}
{"sid": "013_三代世表.2.4.s16", "chapter": "013_三代世表", "para": "2.4", "seq": 16, "text": "| 昌意生颛顼。", "len": 8}
{"sid": "013_三代世表.2.4.s17", "chapter": "013_三代世表", "para": "2.4", "seq": 17, "text": "颛顼生穷蝉。", "len": 6}
{"sid": "013_三代世表.2.4.s18", "chapter": "013_三代世表", "para": "2.4", "seq": 18, "text": "| 昌意生颛顼。", "len": 8}
{"sid": "013_三代世表.2.4.s19", "chapter": "013_三代世表", "para": "2.4", "seq": 19, "text": "| 玄嚣生蟜极。", "len": 8}
{"sid": "013_三代世表.2.4.s20", "chapter": "013_三代世表", "para": "2.4", "seq": 20, "text": "蟜极生高辛。", "len": 6}
{"sid": "013_三代世表.2.4.s21", "chapter": "013_三代世表", "para": "2.4", "seq": 21, "text": "| 玄嚣生蟜极。", "len": 8}
{"sid": "013_三代世表.2.4.s22", "chapter": "013_三代世表", "para": "2.4", "seq": 22, "text": "蟜极生高辛。", "len": 6}
{"sid": "013_三代世表.2.4.s23", "chapter": "013_三代世表", "para": "2.4", "seq": 23, "text": "| | [a3] 帝俈，黄帝曾孙。", "len": 17}
{"sid": "013_三代世表.2.4.s24", "chapter": "013_三代世表", "para": "2.4", "seq": 24, "text": "起黄帝，至帝俈四世。", "len": 10}
{"sid": "013_三代世表.2.4.s25", "chapter": "013_三代世表", "para": "2.4", "seq": 25, "text": "号高辛。", "len": 4}
{"sid": "013_三代世表.2.4.s26", "chapter": "013_三代世表", "para": "2.4", "seq": 26, "text": "|  | 蟜极生高辛，为帝俈。", "len": 15}
{"sid": "013_三代世表.2.4.s27", "chapter": "013_三代世表", "para": "2.4", "seq": 27, "text": "| 蟜极生高辛。", "len": 8}
{"sid": "013_三代世表.2.4.s28", "chapter": "013_三代世表", "para": "2.4", "seq": 28, "text": "高辛生放勋。", "len": 6}
{"sid": "013_三代世表.2.4.s29", "chapter": "013_三代世表", "para": "2.4", "seq": 29, "text": "| 穷蝉生敬康。", "len": 8}
{"sid": "013_三代世表.2.4.s30", "chapter": "013_三代世表", "para": "2.4", "seq": 30, "text": "敬康生句望。", "len": 6}
{"sid": "013_三代世表.2.4.s31", "chapter": "013_三代世表", "para": "2.4", "seq": 31, "text": "|  | 高辛生契，为殷祖。", "len": 14}
{"sid": "013_三代世表.2.4.s32", "chapter": "013_三代世表", "para": "2.4", "seq": 32, "text": "| 高辛生后稷，为周祖。", "len": 12}
{"sid": "013_三代世表.2.4.s33", "chapter": "013_三代世表", "para": "2.4", "seq": 33, "text": "| | [a4] 尧。", "len": 11}
{"sid": "013_三代世表.2.4.s34", "chapter": "013_三代世表", "para": "2.4", "seq": 34, "text": "起黄帝，至俈子五世。", "len": 10}
{"sid": "013_三代世表.2.4.s35", "chapter": "013_三代世表", "para": "2.4", "seq": 35, "text": "号唐。", "len": 3}
{"sid": "013_三代世表.2.4.s36", "chapter": "013_三代世表", "para": "2.4", "seq": 36, "text": "|  |  | 放勋为尧。", "len": 13}
{"sid": "013_三代世表.2.4.s37", "chapter": "013_三代世表", "para": "2.4", "seq": 37, "text": "| 句望生蟜牛。", "len": 8}
{"sid": "013_三代世表.2.4.s38", "chapter": "013_三代世表", "para": "2.4", "seq": 38, "text": "蟜牛生瞽叟。", "len": 6}
{"sid": "013_三代世表.2.4.s39", "chapter": "013_三代世表", "para": "2.4", "seq": 39, "text": "|  | 契生昭明。", "len": 10}
{"sid": "013_三代世表.2.4.s40", "chapter": "013_三代世表", "para": "2.4", "seq": 40, "text": "| 后稷生不窋。", "len": 8}
{"sid": "013_三代世表.2.4.s41", "chapter": "013_三代世表", "para": "2.4", "seq": 41, "text": "| | [a5] 舜，黄帝玄孙之玄孙，号虞。", "len": 22}
{"sid": "013_三代世表.2.4.s42", "chapter": "013_三代世表", "para": "2.4", "seq": 42, "text": "|  |  |  | 瞽叟生重华，是为帝舜。", "len": 22}
{"sid": "013_三代世表.2.4.s43", "chapter": "013_三代世表", "para": "2.4", "seq": 43, "text": "| 颛顼生鲧。", "len": 7}
{"sid": "013_三代世表.2.4.s44", "chapter": "013_三代世表", "para": "2.4", "seq": 44, "text": "鲧生文命。", "len": 5}
{"sid": "013_三代世表.2.4.s45", "chapter": "013_三代世表", "para": "2.4", "seq": 45, "text": "| 昭明生相土。", "len": 8}
{"sid": "013_三代世表.2.4.s46", "chapter": "013_三代世表", "para": "2.4", "seq": 46, "text": "| 不窋生鞠。", "len": 7}
{"sid": "013_三代世表.2.4.s47", "chapter": "013_三代世表", "para": "2.4", "seq": 47, "text": "| | [a6] 禹，黄帝耳孙，号夏。", "len": 19}
{"sid": "013_三代世表.2.4.s48", "chapter": "013_三代世表", "para": "2.4", "seq": 48, "text": "|  |  |  |  | 文命，是为禹。", "len": 21}
{"sid": "013_三代世表.2.4.s49", "chapter": "013_三代世表", "para": "2.4", "seq": 49, "text": "| 相土生昌若。", "len": 8}
{"sid": "013_三代世表.2.4.s50", "chapter": "013_三代世表", "para": "2.4", "seq": 50, "text": "| 鞠生公刘。", "len": 7}
{"sid": "013_三代世表.2.4.s51", "chapter": "013_三代世表", "para": "2.4", "seq": 51, "text": "| | [a7] 帝启，伐有扈，作甘誓。", "len": 20}
{"sid": "013_三代世表.2.4.s52", "chapter": "013_三代世表", "para": "2.4", "seq": 52, "text": "|  |  |  |  |  | 昌若生曹圉。", "len": 23}
{"sid": "013_三代世表.2.4.s53", "chapter": "013_三代世表", "para": "2.4", "seq": 53, "text": "| 公刘生庆节。", "len": 8}
{"sid": "013_三代世表.2.4.s54", "chapter": "013_三代世表", "para": "2.4", "seq": 54, "text": "| | [a8] 帝太康 |  |  |  |  |  | 曹圉生冥。", "len": 35}
{"sid": "013_三代世表.2.4.s55", "chapter": "013_三代世表", "para": "2.4", "seq": 55, "text": "| 庆节生皇仆。", "len": 8}
{"sid": "013_三代世表.2.4.s56", "chapter": "013_三代世表", "para": "2.4", "seq": 56, "text": "| | [a9] 帝仲康，太康弟。", "len": 17}
{"sid": "013_三代世表.2.4.s57", "chapter": "013_三代世表", "para": "2.4", "seq": 57, "text": "|  |  |  |  |  | 冥生振。", "len": 21}
{"sid": "013_三代世表.2.4.s58", "chapter": "013_三代世表", "para": "2.4", "seq": 58, "text": "| 皇仆生差弗。", "len": 8}
{"sid": "013_三代世表.2.4.s59", "chapter": "013_三代世表", "para": "2.4", "seq": 59, "text": "| | [a10] 帝相 |  |  |  |  |  | 振生微。", "len": 34}
{"sid": "013_三代世表.2.4.s60", "chapter": "013_三代世表", "para": "2.4", "seq": 60, "text": "| 差弗生毁渝。", "len": 8}
{"sid": "013_三代世表.2.4.s61", "chapter": "013_三代世表", "para": "2.4", "seq": 61, "text": "| | [a11] 帝少康 |  |  |  |  |  | 微生报丁。", "len": 36}
{"sid": "013_三代世表.2.4.s62", "chapter": "013_三代世表", "para": "2.4", "seq": 62, "text": "| 毁渝生公非。", "len": 8}
{"sid": "013_三代世表.2.4.s63", "chapter": "013_三代世表", "para": "2.4", "seq": 63, "text": "| | [a12] 帝予 |  |  |  |  |  | 报丁生报乙。", "len": 36}
{"sid": "013_三代世表.2.4.s64", "chapter": "013_三代世表", "para": "2.4", "seq": 64, "text": "| 公非生高圉。", "len": 8}
{"sid": "013_三代世表.2.4.s65", "chapter": "013_三代世表", "para": "2.4", "seq": 65, "text": "| | [a13] 帝槐 |  |  |  |  |  | 报乙生报丙。", "len": 36}
{"sid": "013_三代世表.2.4.s66", "chapter": "013_三代世表", "para": "2.4", "seq": 66, "text": "| 高圉生亚圉。", "len": 8}
{"sid": "013_三代世表.2.4.s67", "chapter": "013_三代世表", "para": "2.4", "seq": 67, "text": "| | [a14] 帝芒 |  |  |  |  |  | 报丙生主壬。", "len": 36}
{"sid": "013_三代世表.2.4.s68", "chapter": "013_三代世表", "para": "2.4", "seq": 68, "text": "| 亚圉生公祖类。", "len": 9}
{"sid": "013_三代世表.2.4.s69", "chapter": "013_三代世表", "para": "2.4", "seq": 69, "text": "| | [a15] 帝泄 |  |  |  |  |  | 主壬生主癸。", "len": 36}
{"sid": "013_三代世表.2.4.s70", "chapter": "013_三代世表", "para": "2.4", "seq": 70, "text": "| 公祖类生太王亶父。", "len": 11}
{"sid": "013_三代世表.2.4.s71", "chapter": "013_三代世表", "para": "2.4", "seq": 71, "text": "| | [a16] 帝不降 |  |  |  |  |  | 主癸生天乙，是为殷汤。", "len": 42}
{"sid": "013_三代世表.2.4.s72", "chapter": "013_三代世表", "para": "2.4", "seq": 72, "text": "| 亶父生季历。", "len": 8}
{"sid": "013_三代世表.2.4.s73", "chapter": "013_三代世表", "para": "2.4", "seq": 73, "text": "| | [a17] 帝扃，不降弟。", "len": 17}
{"sid": "013_三代世表.2.4.s74", "chapter": "013_三代世表", "para": "2.4", "seq": 74, "text": "|  |  |  |  |  |  | 季历生文王昌。", "len": 27}
{"sid": "013_三代世表.2.4.s75", "chapter": "013_三代世表", "para": "2.4", "seq": 75, "text": "益易卦。", "len": 4}
{"sid": "013_三代世表.2.4.s76", "chapter": "013_三代世表", "para": "2.4", "seq": 76, "text": "| | [a18] 帝廑 |  |  |  |  |  |  | 文王昌生武王发。", "len": 41}
{"sid": "013_三代世表.2.4.s77", "chapter": "013_三代世表", "para": "2.4", "seq": 77, "text": "| | [a19] 帝孔甲，不降子。", "len": 18}
{"sid": "013_三代世表.2.4.s78", "chapter": "013_三代世表", "para": "2.4", "seq": 78, "text": "好鬼神，淫乱不好德，二龙去。", "len": 14}
{"sid": "013_三代世表.2.4.s79", "chapter": "013_三代世表", "para": "2.4", "seq": 79, "text": "|  |  |  |  |  |  |  | | [a20] 帝皋 |  |  |  |  |  |  |  | | [a21] 帝发 |  |  |  |  |  |  |  | | [a22] 帝履癸，是为桀。", "len": 107}
{"sid": "013_三代世表.2.4.s80", "chapter": "013_三代世表", "para": "2.4", "seq": 80, "text": "|  |  |  |  |  |  |  | | 帝王 | | [b1] 帝外丙，汤太子。", "len": 45}
{"sid": "013_三代世表.2.4.s81", "chapter": "013_三代世表", "para": "2.4", "seq": 81, "text": "太丁蚤卒，故立次弟外丙。", "len": 12}
{"sid": "013_三代世表.2.4.s82", "chapter": "013_三代世表", "para": "2.4", "seq": 82, "text": "| | [b2] 帝仲壬，外丙弟。", "len": 17}
{"sid": "013_三代世表.2.4.s83", "chapter": "013_三代世表", "para": "2.4", "seq": 83, "text": "| | [b3] 帝太甲，故太子太丁子。", "len": 20}
{"sid": "013_三代世表.2.4.s84", "chapter": "013_三代世表", "para": "2.4", "seq": 84, "text": "淫，伊尹放之桐宫。", "len": 9}
{"sid": "013_三代世表.2.4.s85", "chapter": "013_三代世表", "para": "2.4", "seq": 85, "text": "三年，悔过自责，伊尹乃迎之复位。", "len": 16}
{"sid": "013_三代世表.2.4.s86", "chapter": "013_三代世表", "para": "2.4", "seq": 86, "text": "| | [b4] 帝沃丁。", "len": 13}
{"sid": "013_三代世表.2.4.s87", "chapter": "013_三代世表", "para": "2.4", "seq": 87, "text": "伊尹卒。", "len": 4}
{"sid": "013_三代世表.2.4.s88", "chapter": "013_三代世表", "para": "2.4", "seq": 88, "text": "| | [b5] 帝太庚，沃丁弟。", "len": 17}
{"sid": "013_三代世表.2.4.s89", "chapter": "013_三代世表", "para": "2.4", "seq": 89, "text": "| | [b6] 帝小甲，太庚弟。", "len": 17}
{"sid": "013_三代世表.2.4.s90", "chapter": "013_三代世表", "para": "2.4", "seq": 90, "text": "殷道衰，诸侯或不至。", "len": 10}
{"sid": "013_三代世表.2.4.s91", "chapter": "013_三代世表", "para": "2.4", "seq": 91, "text": "| | [b7] 帝雍己，小甲弟。", "len": 17}
{"sid": "013_三代世表.2.4.s92", "chapter": "013_三代世表", "para": "2.4", "seq": 92, "text": "| | [b8] 帝太戊，雍己弟。", "len": 17}
{"sid": "013_三代世表.2.4.s93", "chapter": "013_三代世表", "para": "2.4", "seq": 93, "text": "以桑穀生，称中宗。", "len": 9}
{"sid": "013_三代世表.2.4.s94", "chapter": "013_三代世表", "para": "2.4", "seq": 94, "text": "| | [b9] 帝中丁 | | [b10] 帝外壬，中丁弟。", "len": 31}
{"sid": "013_三代世表.2.4.s95", "chapter": "013_三代世表", "para": "2.4", "seq": 95, "text": "| | [b11] 帝河亶甲，外壬弟。", "len": 19}
{"sid": "013_三代世表.2.4.s96", "chapter": "013_三代世表", "para": "2.4", "seq": 96, "text": "| | [b12] 帝祖乙 | | [b13] 帝祖辛 | | [b14] 帝沃甲，祖辛弟。", "len": 46}
{"sid": "013_三代世表.2.4.s97", "chapter": "013_三代世表", "para": "2.4", "seq": 97, "text": "| | [b15] 帝祖丁，祖辛子。", "len": 18}
{"sid": "013_三代世表.2.4.s98", "chapter": "013_三代世表", "para": "2.4", "seq": 98, "text": "| | [b16] 帝南庚，沃甲子。", "len": 18}
{"sid": "013_三代世表.2.4.s99", "chapter": "013_三代世表", "para": "2.4", "seq": 99, "text": "| | [b17] 帝阳甲，祖丁子。", "len": 18}
{"sid": "013_三代世表.2.4.s100", "chapter": "013_三代世表", "para": "2.4", "seq": 100, "text": "| | [b18] 帝盘庚，阳甲弟。", "len": 18}
{"sid": "013_三代世表.2.4.s101", "chapter": "013_三代世表", "para": "2.4", "seq": 101, "text": "徙河南。", "len": 4}
{"sid": "013_三代世表.2.4.s102", "chapter": "013_三代世表", "para": "2.4", "seq": 102, "text": "| | [b19] 帝小辛，盘庚弟。", "len": 18}
{"sid": "013_三代世表.2.4.s103", "chapter": "013_三代世表", "para": "2.4", "seq": 103, "text": "| | [b20] 帝小乙，小辛弟。", "len": 18}
{"sid": "013_三代世表.2.4.s104", "chapter": "013_三代世表", "para": "2.4", "seq": 104, "text": "| | [b21] 帝武丁。", "len": 14}
{"sid": "013_三代世表.2.4.s105", "chapter": "013_三代世表", "para": "2.4", "seq": 105, "text": "雉升鼎耳雊。", "len": 6}
{"sid": "013_三代世表.2.4.s106", "chapter": "013_三代世表", "para": "2.4", "seq": 106, "text": "得傅说。", "len": 4}
{"sid": "013_三代世表.2.4.s107", "chapter": "013_三代世表", "para": "2.4", "seq": 107, "text": "称高宗。", "len": 4}
{"sid": "013_三代世表.2.4.s108", "chapter": "013_三代世表", "para": "2.4", "seq": 108, "text": "| | [b22] 帝祖庚 | | [b23] 帝甲，祖庚弟。", "len": 31}
{"sid": "013_三代世表.2.4.s109", "chapter": "013_三代世表", "para": "2.4", "seq": 109, "text": "| | [b24] 帝廪辛 | | [b25] 帝庚丁，廪辛弟。", "len": 32}
{"sid": "013_三代世表.2.4.s110", "chapter": "013_三代世表", "para": "2.4", "seq": 110, "text": "殷徙河北。", "len": 5}
{"sid": "013_三代世表.2.4.s111", "chapter": "013_三代世表", "para": "2.4", "seq": 111, "text": "| | [b26] 帝武乙。", "len": 14}
{"sid": "013_三代世表.2.4.s112", "chapter": "013_三代世表", "para": "2.4", "seq": 112, "text": "慢神震死。", "len": 5}
{"sid": "013_三代世表.2.4.s113", "chapter": "013_三代世表", "para": "2.4", "seq": 113, "text": "| | [b27] 帝太丁 | | [b28] 帝乙。", "len": 27}
{"sid": "013_三代世表.2.4.s114", "chapter": "013_三代世表", "para": "2.4", "seq": 114, "text": "殷益衰。", "len": 4}
{"sid": "013_三代世表.2.4.s115", "chapter": "013_三代世表", "para": "2.4", "seq": 115, "text": "| | [b29] 帝辛，是为纣。", "len": 17}
{"sid": "013_三代世表.2.4.s116", "chapter": "013_三代世表", "para": "2.4", "seq": 116, "text": "| | 周 | 鲁 | 齐 | 晋 | 秦 | 楚 | 宋 | 卫 | 陈 | 蔡 | 曹 | 燕 | |  [r1] 成王诵  |  鲁周公旦，武王弟。", "len": 77}
{"sid": "013_三代世表.2.4.s117", "chapter": "013_三代世表", "para": "2.4", "seq": 117, "text": "初封。", "len": 3}
{"sid": "013_三代世表.2.4.s118", "chapter": "013_三代世表", "para": "2.4", "seq": 118, "text": "|  齐太公尚，文王、武王师。", "len": 15}
{"sid": "013_三代世表.2.4.s119", "chapter": "013_三代世表", "para": "2.4", "seq": 119, "text": "初封。", "len": 3}
{"sid": "013_三代世表.2.4.s120", "chapter": "013_三代世表", "para": "2.4", "seq": 120, "text": "|  晋唐叔虞，武王子。", "len": 12}
{"sid": "013_三代世表.2.4.s121", "chapter": "013_三代世表", "para": "2.4", "seq": 121, "text": "初封。", "len": 3}
{"sid": "013_三代世表.2.4.s122", "chapter": "013_三代世表", "para": "2.4", "seq": 122, "text": "|  秦恶来，助纣。", "len": 10}
{"sid": "013_三代世表.2.4.s123", "chapter": "013_三代世表", "para": "2.4", "seq": 123, "text": "父飞廉，有力。", "len": 7}
{"sid": "013_三代世表.2.4.s124", "chapter": "013_三代世表", "para": "2.4", "seq": 124, "text": "|  楚熊绎。", "len": 7}
{"sid": "013_三代世表.2.4.s125", "chapter": "013_三代世表", "para": "2.4", "seq": 125, "text": "绎父鬻熊，事文王。", "len": 9}
{"sid": "013_三代世表.2.4.s126", "chapter": "013_三代世表", "para": "2.4", "seq": 126, "text": "初封。", "len": 3}
{"sid": "013_三代世表.2.4.s127", "chapter": "013_三代世表", "para": "2.4", "seq": 127, "text": "|  宋微子启，纣庶兄。", "len": 12}
{"sid": "013_三代世表.2.4.s128", "chapter": "013_三代世表", "para": "2.4", "seq": 128, "text": "初封。", "len": 3}
{"sid": "013_三代世表.2.4.s129", "chapter": "013_三代世表", "para": "2.4", "seq": 129, "text": "|  卫康叔，武王弟。", "len": 11}
{"sid": "013_三代世表.2.4.s130", "chapter": "013_三代世表", "para": "2.4", "seq": 130, "text": "初封。", "len": 3}
{"sid": "013_三代世表.2.4.s131", "chapter": "013_三代世表", "para": "2.4", "seq": 131, "text": "|  陈胡公满，舜之后。", "len": 12}
{"sid": "013_三代世表.2.4.s132", "chapter": "013_三代世表", "para": "2.4", "seq": 132, "text": "初封。", "len": 3}
{"sid": "013_三代世表.2.4.s133", "chapter": "013_三代世表", "para": "2.4", "seq": 133, "text": "|  蔡叔度，武王弟。", "len": 11}
{"sid": "013_三代世表.2.4.s134", "chapter": "013_三代世表", "para": "2.4", "seq": 134, "text": "初封。", "len": 3}
{"sid": "013_三代世表.2.4.s135", "chapter": "013_三代世表", "para": "2.4", "seq": 135, "text": "|  曹叔振铎，武王弟。", "len": 12}
{"sid": "013_三代世表.2.4.s136", "chapter": "013_三代世表", "para": "2.4", "seq": 136, "text": "初封。", "len": 3}
{"sid": "013_三代世表.2.4.s137", "chapter": "013_三代世表", "para": "2.4", "seq": 137, "text": "|  燕召公奭，周同姓。", "len": 12}
{"sid": "013_三代世表.2.4.s138", "chapter": "013_三代世表", "para": "2.4", "seq": 138, "text": "初封。", "len": 3}
{"sid": "013_三代世表.2.4.s139", "chapter": "013_三代世表", "para": "2.4", "seq": 139, "text": "| |  [r2] 康王钊刑错四十余年。", "len": 20}
{"sid": "013_三代世表.2.4.s140", "chapter": "013_三代世表", "para": "2.4", "seq": 140, "text": "|  鲁公伯禽  |  丁公吕伋  |  晋侯燮  |  女防  |  熊乂  |  微仲，启弟。", "len": 49}
{"sid": "013_三代世表.2.4.s141", "chapter": "013_三代世表", "para": "2.4", "seq": 141, "text": "|  康伯  |  申公  |  蔡仲  |    |  九世至惠侯。", "len": 35}
{"sid": "013_三代世表.2.4.s142", "chapter": "013_三代世表", "para": "2.4", "seq": 142, "text": "| |  [r3] 昭王瑕南巡不返。", "len": 18}
{"sid": "013_三代世表.2.4.s143", "chapter": "013_三代世表", "para": "2.4", "seq": 143, "text": "不赴，讳之。", "len": 6}
{"sid": "013_三代世表.2.4.s144", "chapter": "013_三代世表", "para": "2.4", "seq": 144, "text": "|  考公  |  乙公  |  武侯  |  旁皋  |  熊黮  |  宋公  |  孝伯  |  相公  |  蔡伯  |  太伯  |    | |  [r4] 穆王满。", "len": 89}
{"sid": "013_三代世表.2.4.s145", "chapter": "013_三代世表", "para": "2.4", "seq": 145, "text": "作甫刑。", "len": 4}
{"sid": "013_三代世表.2.4.s146", "chapter": "013_三代世表", "para": "2.4", "seq": 146, "text": "荒服不至。", "len": 5}
{"sid": "013_三代世表.2.4.s147", "chapter": "013_三代世表", "para": "2.4", "seq": 147, "text": "|  炀公，考公弟。", "len": 10}
{"sid": "013_三代世表.2.4.s148", "chapter": "013_三代世表", "para": "2.4", "seq": 148, "text": "|  癸公  |  成侯  |  大几  |  熊胜  |  丁公  |  嗣伯  |  孝公  |  宫侯  |  仲君  |    | |  [r5] 恭王伊扈  |  幽公  |  哀公  |  厉侯  |  大骆  |  熊炀  |  湣公，丁公弟。", "len": 129}
{"sid": "013_三代世表.2.4.s149", "chapter": "013_三代世表", "para": "2.4", "seq": 149, "text": "|  疌伯  |  慎公  |  厉侯  |  宫伯  |    | |  [r6] 懿王坚。", "len": 47}
{"sid": "013_三代世表.2.4.s150", "chapter": "013_三代世表", "para": "2.4", "seq": 150, "text": "周道衰，诗人作刺。", "len": 9}
{"sid": "013_三代世表.2.4.s151", "chapter": "013_三代世表", "para": "2.4", "seq": 151, "text": "|  魏公  |  胡公  |  靖侯  |  非子  |  熊渠  |  炀公，湣公弟。", "len": 45}
{"sid": "013_三代世表.2.4.s152", "chapter": "013_三代世表", "para": "2.4", "seq": 152, "text": "|  靖伯  |  幽公  |  武侯  |  孝伯  |    | |  [r7] 孝王方，懿王弟。", "len": 51}
{"sid": "013_三代世表.2.4.s153", "chapter": "013_三代世表", "para": "2.4", "seq": 153, "text": "|  厉公  |  献公弑胡公。", "len": 16}
{"sid": "013_三代世表.2.4.s154", "chapter": "013_三代世表", "para": "2.4", "seq": 154, "text": "|    |  秦侯  |  熊无康  |  厉公  |  贞伯  |  厘公  |    |  夷伯  |    | |  [r8] 夷王燮，懿王子。", "len": 76}
{"sid": "013_三代世表.2.4.s155", "chapter": "013_三代世表", "para": "2.4", "seq": 155, "text": "|  献公，厉公弟。", "len": 10}
{"sid": "013_三代世表.2.4.s156", "chapter": "013_三代世表", "para": "2.4", "seq": 156, "text": "|  武公  |    |  公伯  |  熊鸷红  |  厘公  |  顷侯  |    |    |    |    | |  [r9] 厉王胡。", "len": 75}
{"sid": "013_三代世表.2.4.s157", "chapter": "013_三代世表", "para": "2.4", "seq": 157, "text": "以恶闻过乱，出奔，遂死于彘。", "len": 14}
{"sid": "013_三代世表.2.4.s158", "chapter": "013_三代世表", "para": "2.4", "seq": 158, "text": "|  真公  |    |    |  秦仲  |  熊延，红弟。", "len": 33}
{"sid": "013_三代世表.2.4.s159", "chapter": "013_三代世表", "para": "2.4", "seq": 159, "text": "|    |  厘侯  |    |    |    |    | |  [r10] 共和，二伯行政。", "len": 51}
{"sid": "013_三代世表.2.4.s160", "chapter": "013_三代世表", "para": "2.4", "seq": 160, "text": "|  武公，真公弟。", "len": 10}
{"sid": "013_三代世表.2.4.s161", "chapter": "013_三代世表", "para": "2.4", "seq": 161, "text": "|    |    |    |  熊勇  |    |    |    |    |    |    |", "len": 53}
{"sid": "013_三代世表.3.1.s1", "chapter": "013_三代世表", "para": "3.1", "seq": 1, "text": "张夫子问褚先生曰： “诗言契、后稷皆无父而生。", "len": 23}
{"sid": "013_三代世表.3.1.s2", "chapter": "013_三代世表", "para": "3.1", "seq": 2, "text": "今案诸传记咸言有父，父皆黄帝子也，得无与诗谬乎？“", "len": 25}
{"sid": "013_三代世表.4.1.s1", "chapter": "013_三代世表", "para": "4.1", "seq": 1, "text": "褚先生曰： “不然。", "len": 10}
{"sid": "013_三代世表.4.1.s2", "chapter": "013_三代世表", "para": "4.1", "seq": 2, "text": "诗言契生於卵，后稷人迹者，欲见其有天命精诚之意耳。", "len": 25}
{"sid": "013_三代世表.4.2.s1", "chapter": "013_三代世表", "para": "4.2", "seq": 1, "text": "鬼神不能自成，须人而生，柰何无父而生乎！", "len": 20}
{"sid": "013_三代世表.4.2.s2", "chapter": "013_三代世表", "para": "4.2", "seq": 2, "text": "一言有父，一言无父，信以传信，疑以传疑，故两言之。", "len": 25}
{"sid": "013_三代世表.4.3.s1", "chapter": "013_三代世表", "para": "4.3", "seq": 1, "text": "尧知契、稷皆贤人，天之所生，故封之契七十里，後十馀世至汤，王天下。", "len": 33}
{"sid": "013_三代世表.4.4.s1", "chapter": "013_三代世表", "para": "4.4", "seq": 1, "text": "尧知后稷子孙之後王也，故益封之百里，其後世且千岁，至文王而有天下。", "len": 33}
{"sid": "013_三代世表.5.1.s1", "chapter": "013_三代世表", "para": "5.1", "seq": 1, "text": "诗传曰：‘汤之先为契，无父而生。", "len": 16}
{"sid": "013_三代世表.5.1.s2", "chapter": "013_三代世表", "para": "5.1", "seq": 2, "text": "契母与姊妹浴於玄丘水，有燕衔卵堕之，契母得，故含之，误吞之，即生契。", "len": 34}
{"sid": "013_三代世表.5.2.s1", "chapter": "013_三代世表", "para": "5.2", "seq": 1, "text": "契生而贤，尧立为司徒，姓之曰子氏。", "len": 17}
{"sid": "013_三代世表.5.2.s2", "chapter": "013_三代世表", "para": "5.2", "seq": 2, "text": "子者兹；兹，益大也。", "len": 10}
{"sid": "013_三代世表.5.3.s1", "chapter": "013_三代世表", "para": "5.3", "seq": 1, "text": "诗人美而颂之曰‘殷社芒芒，天命玄鸟，降而生商’。", "len": 24}
{"sid": "013_三代世表.5.3.s2", "chapter": "013_三代世表", "para": "5.3", "seq": 2, "text": "商者质，殷号也。", "len": 8}
{"sid": "013_三代世表.6.1.s1", "chapter": "013_三代世表", "para": "6.1", "seq": 1, "text": "文王之先为后稷，后稷亦无父而生。", "len": 16}
{"sid": "013_三代世表.6.2.s1", "chapter": "013_三代世表", "para": "6.2", "seq": 1, "text": "后稷母为姜嫄，出见大人迹而履践之，知於身，则生后稷。", "len": 26}
{"sid": "013_三代世表.6.3.s1", "chapter": "013_三代世表", "para": "6.3", "seq": 1, "text": "姜嫄以为无父，贱而弃之道中，牛羊避不践也。", "len": 21}
{"sid": "013_三代世表.6.4.s1", "chapter": "013_三代世表", "para": "6.4", "seq": 1, "text": "抱之山中，山者养之。", "len": 10}
{"sid": "013_三代世表.6.4.s2", "chapter": "013_三代世表", "para": "6.4", "seq": 2, "text": "又捐之大泽，鸟覆席食之。", "len": 12}
{"sid": "013_三代世表.6.5.s1", "chapter": "013_三代世表", "para": "6.5", "seq": 1, "text": "姜嫄怪之，於是知其天子，乃取长之。", "len": 17}
{"sid": "013_三代世表.6.6.s1", "chapter": "013_三代世表", "para": "6.6", "seq": 1, "text": "尧知其贤才，立以为大农，姓之曰姬氏。", "len": 18}
{"sid": "013_三代世表.6.6.s2", "chapter": "013_三代世表", "para": "6.6", "seq": 2, "text": "姬者，本也。", "len": 6}
{"sid": "013_三代世表.6.7.s1", "chapter": "013_三代世表", "para": "6.7", "seq": 1, "text": "诗人美而颂之曰“‘厥初生民’，深修益成，而道后稷之始也。", "len": 28}
{"sid": "013_三代世表.7.1.s1", "chapter": "013_三代世表", "para": "7.1", "seq": 1, "text": "孔子曰：‘昔者尧命契为子氏，为有汤也。", "len": 19}
{"sid": "013_三代世表.7.1.s2", "chapter": "013_三代世表", "para": "7.1", "seq": 2, "text": "命后稷为姬氏，为有文王也。", "len": 13}
{"sid": "013_三代世表.7.1.s3", "chapter": "013_三代世表", "para": "7.1", "seq": 3, "text": "大王命季历，明天瑞也。", "len": 11}
{"sid": "013_三代世表.7.1.s4", "chapter": "013_三代世表", "para": "7.1", "seq": 4, "text": "太伯之吴，遂生源也。“", "len": 11}
{"sid": "013_三代世表.7.2.s1", "chapter": "013_三代世表", "para": "7.2", "seq": 1, "text": "天命难言，非圣人莫能见。", "len": 12}
{"sid": "013_三代世表.7.3.s1", "chapter": "013_三代世表", "para": "7.3", "seq": 1, "text": "舜、禹、契、后稷皆黄帝子孙也。", "len": 15}
{"sid": "013_三代世表.7.4.s1", "chapter": "013_三代世表", "para": "7.4", "seq": 1, "text": "黄帝策天命而治天下，德泽深後世，故其子孙皆复立为天子，是天之报有德也。", "len": 35}
{"sid": "013_三代世表.7.5.s1", "chapter": "013_三代世表", "para": "7.5", "seq": 1, "text": "人不知，以为氾从布衣匹夫起耳。", "len": 15}
{"sid": "013_三代世表.7.5.s2", "chapter": "013_三代世表", "para": "7.5", "seq": 2, "text": "夫布衣匹夫安能无故而起王天下乎？", "len": 16}
{"sid": "013_三代世表.7.5.s3", "chapter": "013_三代世表", "para": "7.5", "seq": 3, "text": "其有天命然。", "len": 6}
{"sid": "013_三代世表.8.1.s1", "chapter": "013_三代世表", "para": "8.1", "seq": 1, "text": "“黄帝後世何王天下之久远邪？”", "len": 15}
{"sid": "013_三代世表.8.2.s1", "chapter": "013_三代世表", "para": "8.2", "seq": 1, "text": "曰：“传云天下之君王为万夫之黔首请赎民之命者帝，有福万世。", "len": 29}
{"sid": "013_三代世表.8.2.s2", "chapter": "013_三代世表", "para": "8.2", "seq": 2, "text": "黄帝是也。", "len": 5}
{"sid": "013_三代世表.8.3.s1", "chapter": "013_三代世表", "para": "8.3", "seq": 1, "text": "五政明则修礼义，因天时举兵征伐而利者王，有福千世。", "len": 25}
{"sid": "013_三代世表.8.4.s1", "chapter": "013_三代世表", "para": "8.4", "seq": 1, "text": "蜀王，黄帝後世也，至今在汉西南五千里，常来朝降，输献於汉，非以其先之有德，泽流後世邪？", "len": 43}
{"sid": "013_三代世表.8.5.s1", "chapter": "013_三代世表", "para": "8.5", "seq": 1, "text": "行道德岂可以忽乎哉！", "len": 10}
{"sid": "013_三代世表.8.5.s2", "chapter": "013_三代世表", "para": "8.5", "seq": 2, "text": "人君王者举而观之。", "len": 9}
{"sid": "013_三代世表.9.1.s1", "chapter": "013_三代世表", "para": "9.1", "seq": 1, "text": "汉大将军霍子孟名光者，亦黄帝後世也。", "len": 18}
{"sid": "013_三代世表.9.2.s1", "chapter": "013_三代世表", "para": "9.2", "seq": 1, "text": "此可为博闻远见者言，固难为浅闻者说也。", "len": 19}
{"sid": "013_三代世表.9.2.s2", "chapter": "013_三代世表", "para": "9.2", "seq": 2, "text": "何以言之？", "len": 5}
{"sid": "013_三代世表.9.3.s1", "chapter": "013_三代世表", "para": "9.3", "seq": 1, "text": "古诸侯以国为姓。", "len": 8}
{"sid": "013_三代世表.9.3.s2", "chapter": "013_三代世表", "para": "9.3", "seq": 2, "text": "霍者，国名也。", "len": 7}
{"sid": "013_三代世表.9.4.s1", "chapter": "013_三代世表", "para": "9.4", "seq": 1, "text": "武王封弟叔处於霍，後世晋献公灭霍公，後世为庶民，往来居平阳。", "len": 30}
{"sid": "013_三代世表.9.5.s1", "chapter": "013_三代世表", "para": "9.5", "seq": 1, "text": "平阳在河东，河东晋地，分为卫国。", "len": 16}
{"sid": "013_三代世表.9.6.s1", "chapter": "013_三代世表", "para": "9.6", "seq": 1, "text": "以诗言之，亦可为周世。", "len": 11}
{"sid": "013_三代世表.9.6.s2", "chapter": "013_三代世表", "para": "9.6", "seq": 2, "text": "周起后稷，后稷无父而生。", "len": 12}
{"sid": "013_三代世表.9.7.s1", "chapter": "013_三代世表", "para": "9.7", "seq": 1, "text": "以三代世传言之，后稷有父名高辛；高辛，黄帝曾孙。", "len": 24}
{"sid": "013_三代世表.9.8.s1", "chapter": "013_三代世表", "para": "9.8", "seq": 1, "text": "黄帝终始传曰：‘汉兴百有馀年，有人不短不长，出燕之乡，持天下之政，时有婴兒主，欲行车。‘", "len": 44}
{"sid": "013_三代世表.9.9.s1", "chapter": "013_三代世表", "para": "9.9", "seq": 1, "text": "霍将军者，本居平阳燕。", "len": 11}
{"sid": "013_三代世表.9.9.s2", "chapter": "013_三代世表", "para": "9.9", "seq": 2, "text": "臣为郎时，与方士考功会旗亭下，为臣言。", "len": 19}
{"sid": "013_三代世表.9.9.s3", "chapter": "013_三代世表", "para": "9.9", "seq": 3, "text": "岂不伟哉！", "len": 5}
{"sid": "013_三代世表.9.9.s4", "chapter": "013_三代世表", "para": "9.9", "seq": 4, "text": "::: 赞", "len": 5}
{"sid": "013_三代世表.10.s1", "chapter": "013_三代世表", "para": "10", "seq": 1, "text": "高辛之胤，大启祯祥。", "len": 10}
{"sid": "013_三代世表.10.s2", "chapter": "013_三代世表", "para": "10", "seq": 2, "text": "脩己吞薏，石纽兴王。", "len": 10}
{"sid": "013_三代世表.10.s3", "chapter": "013_三代世表", "para": "10", "seq": 3, "text": "天命玄鸟，简狄生商。", "len": 10}
{"sid": "013_三代世表.10.s4", "chapter": "013_三代世表", "para": "10", "seq": 4, "text": "姜嫄履迹，祚流岐昌。", "len": 10}
{"sid": "013_三代世表.10.s5", "chapter": "013_三代世表", "para": "10", "seq": 5, "text": "俱膺历运，互有兴亡。", "len": 10}
{"sid": "013_三代世表.10.s6", "chapter": "013_三代世表", "para": "10", "seq": 6, "text": "风馀周召，刑措成康。", "len": 10}
{"sid": "013_三代世表.10.s7", "chapter": "013_三代世表", "para": "10", "seq": 7, "text": "出彘之後，诸侯日彊。", "len": 10}
{"sid": "013_三代世表.10.s8", "chapter": "013_三代世表", "para": "10", "seq": 8, "text": ":::", "len": 3}
