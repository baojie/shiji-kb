{"sid": "119_循吏列传.1.s1", "chapter": "119_循吏列传", "para": "1", "seq": 1, "text": "太史公曰：法令所以导民也，刑罚所以禁奸也。", "len": 21}
{"sid": "119_循吏列传.1.s2", "chapter": "119_循吏列传", "para": "1", "seq": 2, "text": "文武不备，良民惧然身修者，官未曾乱也。", "len": 19}
{"sid": "119_循吏列传.1.s3", "chapter": "119_循吏列传", "para": "1", "seq": 3, "text": "奉职循理，亦可以为治，何必威严哉？", "len": 17}
{"sid": "119_循吏列传.2.s1", "chapter": "119_循吏列传", "para": "2", "seq": 1, "text": "孙叔敖者，楚之处士也。", "len": 11}
{"sid": "119_循吏列传.2.s2", "chapter": "119_循吏列传", "para": "2", "seq": 2, "text": "虞丘相进之於楚庄王，以自代也。", "len": 15}
{"sid": "119_循吏列传.2.s3", "chapter": "119_循吏列传", "para": "2", "seq": 3, "text": "三月为楚相，施教导民，上下和合，世俗盛美，政缓禁止，吏无奸邪，盗贼不起。", "len": 36}
{"sid": "119_循吏列传.2.s4", "chapter": "119_循吏列传", "para": "2", "seq": 4, "text": "秋冬则劝民山采，春夏以水，各得其所便，民皆乐其生。", "len": 25}
{"sid": "119_循吏列传.3.s1", "chapter": "119_循吏列传", "para": "3", "seq": 1, "text": "庄王以为币轻，更以小为大，百姓不便，皆去其业。", "len": 23}
{"sid": "119_循吏列传.3.s2", "chapter": "119_循吏列传", "para": "3", "seq": 2, "text": "市令言之相曰：“市乱，民莫安其处，次行不定。", "len": 22}
{"sid": "119_循吏列传.3.s3", "chapter": "119_循吏列传", "para": "3", "seq": 3, "text": "” 相曰：“如此几何顷乎？", "len": 13}
{"sid": "119_循吏列传.3.s4", "chapter": "119_循吏列传", "para": "3", "seq": 4, "text": "” 市令曰：“三月顷。", "len": 11}
{"sid": "119_循吏列传.3.s5", "chapter": "119_循吏列传", "para": "3", "seq": 5, "text": "” 相曰：“罢，吾今令之复矣。", "len": 15}
{"sid": "119_循吏列传.3.s6", "chapter": "119_循吏列传", "para": "3", "seq": 6, "text": "” 後五日，朝，相言之王曰：“前日更币，以为轻。", "len": 24}
{"sid": "119_循吏列传.3.s7", "chapter": "119_循吏列传", "para": "3", "seq": 7, "text": "今市令来言曰“市乱，民莫安其处，次行之不定”。", "len": 23}
{"sid": "119_循吏列传.3.s8", "chapter": "119_循吏列传", "para": "3", "seq": 8, "text": "臣请遂令复如故。", "len": 8}
{"sid": "119_循吏列传.3.s9", "chapter": "119_循吏列传", "para": "3", "seq": 9, "text": "“王许之，下令三日而市复如故。", "len": 15}
{"sid": "119_循吏列传.4.s1", "chapter": "119_循吏列传", "para": "4", "seq": 1, "text": "楚民俗好庳车，王以为庳车不便马，欲下令使高之。", "len": 23}
{"sid": "119_循吏列传.4.s2", "chapter": "119_循吏列传", "para": "4", "seq": 2, "text": "相曰：“令数下，民不知所从，不可。", "len": 17}
{"sid": "119_循吏列传.4.s3", "chapter": "119_循吏列传", "para": "4", "seq": 3, "text": "王必欲高车，臣请教闾里使高其困。", "len": 16}
{"sid": "119_循吏列传.4.s4", "chapter": "119_循吏列传", "para": "4", "seq": 4, "text": "乘车者皆君子，君子不能数下车。", "len": 15}
{"sid": "119_循吏列传.4.s5", "chapter": "119_循吏列传", "para": "4", "seq": 5, "text": "” 王许之。", "len": 6}
{"sid": "119_循吏列传.4.s6", "chapter": "119_循吏列传", "para": "4", "seq": 6, "text": "居半岁，民悉自高其车。", "len": 11}
{"sid": "119_循吏列传.5.s1", "chapter": "119_循吏列传", "para": "5", "seq": 1, "text": "此不教而民从其化，近者视而效之，远者四面望而法之。", "len": 25}
{"sid": "119_循吏列传.5.s2", "chapter": "119_循吏列传", "para": "5", "seq": 2, "text": "故三得相而不喜，知其材自得之也；三去相而不悔，知非己之罪也。", "len": 30}
{"sid": "119_循吏列传.6.s1", "chapter": "119_循吏列传", "para": "6", "seq": 1, "text": "子产者，郑之列大夫也。", "len": 11}
{"sid": "119_循吏列传.6.s2", "chapter": "119_循吏列传", "para": "6", "seq": 2, "text": "郑昭君之时，以所爱徐挚为相，国乱，上下不亲，父子不和。", "len": 27}
{"sid": "119_循吏列传.6.s3", "chapter": "119_循吏列传", "para": "6", "seq": 3, "text": "大宫子期言之君，以子产为相。", "len": 14}
{"sid": "119_循吏列传.6.s4", "chapter": "119_循吏列传", "para": "6", "seq": 4, "text": "为相一年，竖子不戏狎，斑白不提挈，僮子不犁畔。", "len": 23}
{"sid": "119_循吏列传.6.s5", "chapter": "119_循吏列传", "para": "6", "seq": 5, "text": "二年，市不豫贾。", "len": 8}
{"sid": "119_循吏列传.6.s6", "chapter": "119_循吏列传", "para": "6", "seq": 6, "text": "三年，门不夜关，道不拾遗。", "len": 13}
{"sid": "119_循吏列传.6.s7", "chapter": "119_循吏列传", "para": "6", "seq": 7, "text": "四年，田器不归。", "len": 8}
{"sid": "119_循吏列传.6.s8", "chapter": "119_循吏列传", "para": "6", "seq": 8, "text": "五年，士无尺籍，丧期不令而治。", "len": 15}
{"sid": "119_循吏列传.6.s9", "chapter": "119_循吏列传", "para": "6", "seq": 9, "text": "治郑二十六年而死，丁壮号哭，老人兒啼，曰：“子产去我死乎！", "len": 29}
{"sid": "119_循吏列传.6.s10", "chapter": "119_循吏列传", "para": "6", "seq": 10, "text": "民将安归？”", "len": 6}
{"sid": "119_循吏列传.7.s1", "chapter": "119_循吏列传", "para": "7", "seq": 1, "text": "公仪休者，鲁博士也。", "len": 10}
{"sid": "119_循吏列传.7.s2", "chapter": "119_循吏列传", "para": "7", "seq": 2, "text": "以高弟为鲁相。", "len": 7}
{"sid": "119_循吏列传.7.s3", "chapter": "119_循吏列传", "para": "7", "seq": 3, "text": "奉法循理，无所变更，百官自正。", "len": 15}
{"sid": "119_循吏列传.7.s4", "chapter": "119_循吏列传", "para": "7", "seq": 4, "text": "使食禄者不得与下民争利，受大者不得取小。", "len": 20}
{"sid": "119_循吏列传.8.s1", "chapter": "119_循吏列传", "para": "8", "seq": 1, "text": "客有遗相鱼者，相不受。", "len": 11}
{"sid": "119_循吏列传.8.s2", "chapter": "119_循吏列传", "para": "8", "seq": 2, "text": "客曰：“闻君嗜鱼，遗君鱼，何故不受也？", "len": 19}
{"sid": "119_循吏列传.8.s3", "chapter": "119_循吏列传", "para": "8", "seq": 3, "text": "” 相曰：“以嗜鱼，故不受也。", "len": 15}
{"sid": "119_循吏列传.8.s4", "chapter": "119_循吏列传", "para": "8", "seq": 4, "text": "今为相，能自给鱼；今受鱼而免，谁复给我鱼者？", "len": 22}
{"sid": "119_循吏列传.8.s5", "chapter": "119_循吏列传", "para": "8", "seq": 5, "text": "吾故不受也。”", "len": 7}
{"sid": "119_循吏列传.9.s1", "chapter": "119_循吏列传", "para": "9", "seq": 1, "text": "食茹而美，拔其园葵而弃之。", "len": 13}
{"sid": "119_循吏列传.9.s2", "chapter": "119_循吏列传", "para": "9", "seq": 2, "text": "见其家织布好，而疾出其家妇，燔其机，云“欲令农士工女安所雠其货乎” ？", "len": 35}
{"sid": "119_循吏列传.10.s1", "chapter": "119_循吏列传", "para": "10", "seq": 1, "text": "石奢者，楚昭王相也。", "len": 10}
{"sid": "119_循吏列传.10.s2", "chapter": "119_循吏列传", "para": "10", "seq": 2, "text": "坚直廉正，无所阿避。", "len": 10}
{"sid": "119_循吏列传.10.s3", "chapter": "119_循吏列传", "para": "10", "seq": 3, "text": "行县，道有杀人者，相追之，乃其父也。", "len": 18}
{"sid": "119_循吏列传.10.s4", "chapter": "119_循吏列传", "para": "10", "seq": 4, "text": "纵其父而还自系焉。", "len": 9}
{"sid": "119_循吏列传.10.s5", "chapter": "119_循吏列传", "para": "10", "seq": 5, "text": "使人言之王曰：”杀人者，臣之父也。", "len": 17}
{"sid": "119_循吏列传.10.s6", "chapter": "119_循吏列传", "para": "10", "seq": 6, "text": "夫以父立政，不孝也；废法纵罪，非忠也；臣罪当死。", "len": 24}
{"sid": "119_循吏列传.10.s7", "chapter": "119_循吏列传", "para": "10", "seq": 7, "text": "” 王曰：“追而不及，不当伏罪，子其治事矣。", "len": 22}
{"sid": "119_循吏列传.10.s8", "chapter": "119_循吏列传", "para": "10", "seq": 8, "text": "” 石奢曰：”不私其父，非孝子也；不奉主法，非忠臣也。", "len": 27}
{"sid": "119_循吏列传.10.s9", "chapter": "119_循吏列传", "para": "10", "seq": 9, "text": "王赦其罪，上惠也；伏诛而死，臣职也。", "len": 18}
{"sid": "119_循吏列传.10.s10", "chapter": "119_循吏列传", "para": "10", "seq": 10, "text": "” 遂不受令，自刎而死。", "len": 12}
{"sid": "119_循吏列传.11.s1", "chapter": "119_循吏列传", "para": "11", "seq": 1, "text": "李离者，晋文公之理也。", "len": 11}
{"sid": "119_循吏列传.11.s2", "chapter": "119_循吏列传", "para": "11", "seq": 2, "text": "过听杀人，自拘当死。", "len": 10}
{"sid": "119_循吏列传.11.s3", "chapter": "119_循吏列传", "para": "11", "seq": 3, "text": "文公曰：“官有贵贱，罚有轻重。", "len": 15}
{"sid": "119_循吏列传.11.s4", "chapter": "119_循吏列传", "para": "11", "seq": 4, "text": "下吏有过，非子之罪也。", "len": 11}
{"sid": "119_循吏列传.11.s5", "chapter": "119_循吏列传", "para": "11", "seq": 5, "text": "” 李离曰：“臣居官为长，不与吏让位；受禄为多，不与下分利。", "len": 30}
{"sid": "119_循吏列传.11.s6", "chapter": "119_循吏列传", "para": "11", "seq": 6, "text": "今过听杀人，傅其罪下吏，非所闻也。", "len": 17}
{"sid": "119_循吏列传.11.s7", "chapter": "119_循吏列传", "para": "11", "seq": 7, "text": "” 辞不受令。", "len": 7}
{"sid": "119_循吏列传.11.s8", "chapter": "119_循吏列传", "para": "11", "seq": 8, "text": "文公曰：”子则自以为有罪，寡人亦有罪邪？", "len": 20}
{"sid": "119_循吏列传.11.s9", "chapter": "119_循吏列传", "para": "11", "seq": 9, "text": "” 李离曰：“理有法，失刑则刑，失死则死。", "len": 21}
{"sid": "119_循吏列传.11.s10", "chapter": "119_循吏列传", "para": "11", "seq": 10, "text": "公以臣能听微决疑，故使为理。", "len": 14}
{"sid": "119_循吏列传.11.s11", "chapter": "119_循吏列传", "para": "11", "seq": 11, "text": "今过听杀人，罪当死。", "len": 10}
{"sid": "119_循吏列传.11.s12", "chapter": "119_循吏列传", "para": "11", "seq": 12, "text": "” 遂不受令，伏剑而死。", "len": 12}
{"sid": "119_循吏列传.11.s13", "chapter": "119_循吏列传", "para": "11", "seq": 13, "text": "::: 太史公曰", "len": 8}
{"sid": "119_循吏列传.12.s1", "chapter": "119_循吏列传", "para": "12", "seq": 1, "text": "太史公曰：孙叔敖出一言，郢市复。", "len": 16}
{"sid": "119_循吏列传.12.s2", "chapter": "119_循吏列传", "para": "12", "seq": 2, "text": "子产病死，郑民号哭。", "len": 10}
{"sid": "119_循吏列传.12.s3", "chapter": "119_循吏列传", "para": "12", "seq": 3, "text": "公仪子见好布而家妇逐。", "len": 11}
{"sid": "119_循吏列传.12.s4", "chapter": "119_循吏列传", "para": "12", "seq": 4, "text": "石奢纵父而死，楚昭名立。", "len": 12}
{"sid": "119_循吏列传.12.s5", "chapter": "119_循吏列传", "para": "12", "seq": 5, "text": "李离过杀而伏剑，晋文以正国法。", "len": 15}
{"sid": "119_循吏列传.12.s6", "chapter": "119_循吏列传", "para": "12", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "119_循吏列传.12.1.s1", "chapter": "119_循吏列传", "para": "12.1", "seq": 1, "text": "奉职循理，为政之先。", "len": 10}
{"sid": "119_循吏列传.12.1.s2", "chapter": "119_循吏列传", "para": "12.1", "seq": 2, "text": "恤人体国，良史述焉。", "len": 10}
{"sid": "119_循吏列传.12.1.s3", "chapter": "119_循吏列传", "para": "12.1", "seq": 3, "text": "叔孙、郑产，自昔称贤。", "len": 11}
{"sid": "119_循吏列传.12.1.s4", "chapter": "119_循吏列传", "para": "12.1", "seq": 4, "text": "拔葵一利，赦父非𠎝。", "len": 10}
{"sid": "119_循吏列传.12.1.s5", "chapter": "119_循吏列传", "para": "12.1", "seq": 5, "text": "李离伏剑，为法而然。", "len": 10}
{"sid": "119_循吏列传.12.1.s6", "chapter": "119_循吏列传", "para": "12.1", "seq": 6, "text": ":::", "len": 3}
