{"sid": "062_管晏列传.1.s1", "chapter": "062_管晏列传", "para": "1", "seq": 1, "text": "管仲夷吾者，颍上人也。", "len": 11}
{"sid": "062_管晏列传.1.s2", "chapter": "062_管晏列传", "para": "1", "seq": 2, "text": "少时常与鲍叔牙游，鲍叔知其贤。", "len": 15}
{"sid": "062_管晏列传.1.s3", "chapter": "062_管晏列传", "para": "1", "seq": 3, "text": "管仲贫困，常欺鲍叔，鲍叔终善遇之，不以为言。", "len": 22}
{"sid": "062_管晏列传.1.s4", "chapter": "062_管晏列传", "para": "1", "seq": 4, "text": "已而鲍叔事齐公子小白，管仲事公子纠。", "len": 18}
{"sid": "062_管晏列传.1.s5", "chapter": "062_管晏列传", "para": "1", "seq": 5, "text": "及小白立为桓公，公子纠死，管仲囚焉。", "len": 18}
{"sid": "062_管晏列传.1.s6", "chapter": "062_管晏列传", "para": "1", "seq": 6, "text": "鲍叔遂进管仲。", "len": 7}
{"sid": "062_管晏列传.1.s7", "chapter": "062_管晏列传", "para": "1", "seq": 7, "text": "管仲既用，任政於齐，齐桓公以霸，九合诸侯，一匡天下，管仲之谋也。", "len": 32}
{"sid": "062_管晏列传.2.s1", "chapter": "062_管晏列传", "para": "2", "seq": 1, "text": "管仲曰：“吾始困时，尝与鲍叔贾，分财利多自与，鲍叔不以我为贪，知我贫也。", "len": 36}
{"sid": "062_管晏列传.2.s2", "chapter": "062_管晏列传", "para": "2", "seq": 2, "text": "吾尝为鲍叔谋事而更穷困，鲍叔不以我为愚，知时有利不利也。", "len": 28}
{"sid": "062_管晏列传.2.s3", "chapter": "062_管晏列传", "para": "2", "seq": 3, "text": "吾尝三仕三见逐於君，鲍叔不以我为不肖，知我不遭时也。", "len": 26}
{"sid": "062_管晏列传.2.s4", "chapter": "062_管晏列传", "para": "2", "seq": 4, "text": "吾尝三战三走，鲍叔不以我怯，知我有老母也。", "len": 21}
{"sid": "062_管晏列传.2.s5", "chapter": "062_管晏列传", "para": "2", "seq": 5, "text": "公子纠败，召忽死之，吾幽囚受辱，鲍叔不以我为无耻，知我不羞小节而耻功名不显于天下也。", "len": 42}
{"sid": "062_管晏列传.2.s6", "chapter": "062_管晏列传", "para": "2", "seq": 6, "text": "生我者父母，知我者鲍子也。“", "len": 14}
{"sid": "062_管晏列传.3.s1", "chapter": "062_管晏列传", "para": "3", "seq": 1, "text": "鲍叔既进管仲，以身下之。", "len": 12}
{"sid": "062_管晏列传.3.s2", "chapter": "062_管晏列传", "para": "3", "seq": 2, "text": "子孙世禄於齐，有封邑者十馀世，常为名大夫。", "len": 21}
{"sid": "062_管晏列传.3.s3", "chapter": "062_管晏列传", "para": "3", "seq": 3, "text": "天下不多管仲之贤而多鲍叔能知人也。", "len": 17}
{"sid": "062_管晏列传.4.s1", "chapter": "062_管晏列传", "para": "4", "seq": 1, "text": "管仲既任政相齐，以区区之齐在海滨，通货积财，富国彊兵，与俗同好恶。", "len": 33}
{"sid": "062_管晏列传.4.s2", "chapter": "062_管晏列传", "para": "4", "seq": 2, "text": "故其称曰：“仓廪实而知礼节，衣食足而知荣辱，上服度则六亲固。", "len": 30}
{"sid": "062_管晏列传.4.s3", "chapter": "062_管晏列传", "para": "4", "seq": 3, "text": "四维不张，国乃灭亡。", "len": 10}
{"sid": "062_管晏列传.4.s4", "chapter": "062_管晏列传", "para": "4", "seq": 4, "text": "下令如流水之原，令顺民心。", "len": 13}
{"sid": "062_管晏列传.4.s5", "chapter": "062_管晏列传", "para": "4", "seq": 5, "text": "“故论卑而易行。", "len": 8}
{"sid": "062_管晏列传.4.s6", "chapter": "062_管晏列传", "para": "4", "seq": 6, "text": "俗之所欲，因而予之；俗之所否，因而去之。", "len": 20}
{"sid": "062_管晏列传.5.s1", "chapter": "062_管晏列传", "para": "5", "seq": 1, "text": "其为政也，善因祸而为福，转败而为功。", "len": 18}
{"sid": "062_管晏列传.5.s2", "chapter": "062_管晏列传", "para": "5", "seq": 2, "text": "贵轻重，慎权衡。", "len": 8}
{"sid": "062_管晏列传.5.s3", "chapter": "062_管晏列传", "para": "5", "seq": 3, "text": "桓公实怒少姬，南袭蔡，管仲因而伐楚，责包茅不入贡於周室。", "len": 28}
{"sid": "062_管晏列传.5.s4", "chapter": "062_管晏列传", "para": "5", "seq": 4, "text": "桓公实北征山戎，而管仲因而令燕修召公之政。", "len": 21}
{"sid": "062_管晏列传.5.s5", "chapter": "062_管晏列传", "para": "5", "seq": 5, "text": "於柯之会，桓公欲背曹沫之约，管仲因而信之，诸侯由是归齐。", "len": 28}
{"sid": "062_管晏列传.5.s6", "chapter": "062_管晏列传", "para": "5", "seq": 6, "text": "故曰：“知与之为取，政之宝也。“", "len": 16}
{"sid": "062_管晏列传.6.s1", "chapter": "062_管晏列传", "para": "6", "seq": 1, "text": "管仲富拟於公室，有三归、反坫，齐人不以为侈。", "len": 22}
{"sid": "062_管晏列传.6.s2", "chapter": "062_管晏列传", "para": "6", "seq": 2, "text": "管仲卒，齐国遵其政，常彊於诸侯。", "len": 16}
{"sid": "062_管晏列传.6.s3", "chapter": "062_管晏列传", "para": "6", "seq": 3, "text": "後百馀年而有晏子焉。", "len": 10}
{"sid": "062_管晏列传.7.s1", "chapter": "062_管晏列传", "para": "7", "seq": 1, "text": "晏平仲婴者，莱之夷维人也。", "len": 13}
{"sid": "062_管晏列传.7.s2", "chapter": "062_管晏列传", "para": "7", "seq": 2, "text": "事齐灵公、庄公、景公，以节俭力行重於齐。", "len": 20}
{"sid": "062_管晏列传.7.s3", "chapter": "062_管晏列传", "para": "7", "seq": 3, "text": "既相齐，食不重肉，妾不衣帛。", "len": 14}
{"sid": "062_管晏列传.7.s4", "chapter": "062_管晏列传", "para": "7", "seq": 4, "text": "其在朝，君语及之，即危言；语不及之，即危行。", "len": 22}
{"sid": "062_管晏列传.7.s5", "chapter": "062_管晏列传", "para": "7", "seq": 5, "text": "国有道，即顺命；无道，即衡命。", "len": 15}
{"sid": "062_管晏列传.7.s6", "chapter": "062_管晏列传", "para": "7", "seq": 6, "text": "以此三世显名於诸侯。", "len": 10}
{"sid": "062_管晏列传.8.s1", "chapter": "062_管晏列传", "para": "8", "seq": 1, "text": "越石父贤，在縲绁中。", "len": 10}
{"sid": "062_管晏列传.8.s2", "chapter": "062_管晏列传", "para": "8", "seq": 2, "text": "晏子出，遭之涂，解左骖赎之，载归。", "len": 17}
{"sid": "062_管晏列传.8.s3", "chapter": "062_管晏列传", "para": "8", "seq": 3, "text": "弗谢，入闺。", "len": 6}
{"sid": "062_管晏列传.8.s4", "chapter": "062_管晏列传", "para": "8", "seq": 4, "text": "久之，越石父请绝。", "len": 9}
{"sid": "062_管晏列传.8.s5", "chapter": "062_管晏列传", "para": "8", "seq": 5, "text": "晏子戄然，摄衣冠谢曰：“婴虽不仁，免子於戹，何子求绝之速也？", "len": 30}
{"sid": "062_管晏列传.8.s6", "chapter": "062_管晏列传", "para": "8", "seq": 6, "text": "“石父曰：“不然。", "len": 9}
{"sid": "062_管晏列传.8.s7", "chapter": "062_管晏列传", "para": "8", "seq": 7, "text": "吾闻君子诎於不知己而信於知己者。", "len": 16}
{"sid": "062_管晏列传.8.s8", "chapter": "062_管晏列传", "para": "8", "seq": 8, "text": "方吾在縲绁中，彼不知我也。", "len": 13}
{"sid": "062_管晏列传.8.s9", "chapter": "062_管晏列传", "para": "8", "seq": 9, "text": "夫子既已感寤而赎我，是知己；知己而无礼，固不如在縲绁之中。", "len": 29}
{"sid": "062_管晏列传.8.s10", "chapter": "062_管晏列传", "para": "8", "seq": 10, "text": "“晏子於是延入为上客。", "len": 11}
{"sid": "062_管晏列传.9.s1", "chapter": "062_管晏列传", "para": "9", "seq": 1, "text": "晏子为齐相，出，其御之妻从门间而闚其夫。", "len": 20}
{"sid": "062_管晏列传.9.s2", "chapter": "062_管晏列传", "para": "9", "seq": 2, "text": "其夫为相御，拥大盖，策驷马，意气扬扬甚自得|扬扬自得也。", "len": 28}
{"sid": "062_管晏列传.9.s3", "chapter": "062_管晏列传", "para": "9", "seq": 3, "text": "既而归，其妻请去。", "len": 9}
{"sid": "062_管晏列传.9.s4", "chapter": "062_管晏列传", "para": "9", "seq": 4, "text": "夫问其故。", "len": 5}
{"sid": "062_管晏列传.9.s5", "chapter": "062_管晏列传", "para": "9", "seq": 5, "text": "妻曰：“晏子长不满六尺，身相齐国，名显诸侯。", "len": 22}
{"sid": "062_管晏列传.9.s6", "chapter": "062_管晏列传", "para": "9", "seq": 6, "text": "今者妾观其出，志念深矣，常有以自下者。", "len": 19}
{"sid": "062_管晏列传.9.s7", "chapter": "062_管晏列传", "para": "9", "seq": 7, "text": "今子长八尺，乃为人仆御，然子之意自以为足，妾是以求去也。", "len": 28}
{"sid": "062_管晏列传.9.s8", "chapter": "062_管晏列传", "para": "9", "seq": 8, "text": "“其後夫自抑损。", "len": 8}
{"sid": "062_管晏列传.9.s9", "chapter": "062_管晏列传", "para": "9", "seq": 9, "text": "晏子怪而问之，御以实对。", "len": 12}
{"sid": "062_管晏列传.9.s10", "chapter": "062_管晏列传", "para": "9", "seq": 10, "text": "晏子荐以为大夫。", "len": 8}
{"sid": "062_管晏列传.9.s11", "chapter": "062_管晏列传", "para": "9", "seq": 11, "text": "::: 太史公曰", "len": 8}
{"sid": "062_管晏列传.10.s1", "chapter": "062_管晏列传", "para": "10", "seq": 1, "text": "太史公曰：吾读管氏牧民、山高、乘马、轻重、九府，及晏子春秋，详哉其言之也。", "len": 37}
{"sid": "062_管晏列传.10.s2", "chapter": "062_管晏列传", "para": "10", "seq": 2, "text": "既见其著书，欲观其行事，故次其传。", "len": 17}
{"sid": "062_管晏列传.10.s3", "chapter": "062_管晏列传", "para": "10", "seq": 3, "text": "至其书，世多有之，是以不论，论其轶事。", "len": 19}
{"sid": "062_管晏列传.12.s1", "chapter": "062_管晏列传", "para": "12", "seq": 1, "text": "管仲世所谓贤臣，然孔子小之。", "len": 14}
{"sid": "062_管晏列传.12.s2", "chapter": "062_管晏列传", "para": "12", "seq": 2, "text": "岂以为周道衰微，桓公既贤，而不勉之至王，乃称霸哉？", "len": 25}
{"sid": "062_管晏列传.12.s3", "chapter": "062_管晏列传", "para": "12", "seq": 3, "text": "语曰“将顺其美，匡救其恶，故上下能哙亲也“。", "len": 22}
{"sid": "062_管晏列传.12.s4", "chapter": "062_管晏列传", "para": "12", "seq": 4, "text": "岂管仲之谓乎？", "len": 7}
{"sid": "062_管晏列传.11.s1", "chapter": "062_管晏列传", "para": "11", "seq": 1, "text": "方晏子伏庄公尸哭之，成礼然後去，岂所谓“见义不为无勇“者邪？", "len": 30}
{"sid": "062_管晏列传.11.s2", "chapter": "062_管晏列传", "para": "11", "seq": 2, "text": "至其谏说，犯君之颜，此所谓“进思尽忠，退思补过“者哉！", "len": 27}
{"sid": "062_管晏列传.11.s3", "chapter": "062_管晏列传", "para": "11", "seq": 3, "text": "假令晏子而在，余虽为之执鞭，所忻慕焉。", "len": 19}
{"sid": "062_管晏列传.11.s4", "chapter": "062_管晏列传", "para": "11", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "062_管晏列传.13.s1", "chapter": "062_管晏列传", "para": "13", "seq": 1, "text": "夷吾成霸，平仲称贤。", "len": 10}
{"sid": "062_管晏列传.13.s2", "chapter": "062_管晏列传", "para": "13", "seq": 2, "text": "粟乃实廪，豆不掩肩。", "len": 10}
{"sid": "062_管晏列传.13.s3", "chapter": "062_管晏列传", "para": "13", "seq": 3, "text": "转祸为福，危言获全。", "len": 10}
{"sid": "062_管晏列传.13.s4", "chapter": "062_管晏列传", "para": "13", "seq": 4, "text": "孔赖左衽，史忻执鞭。", "len": 10}
{"sid": "062_管晏列传.13.s5", "chapter": "062_管晏列传", "para": "13", "seq": 5, "text": "成礼而去，人望存焉。", "len": 10}
{"sid": "062_管晏列传.13.s6", "chapter": "062_管晏列传", "para": "13", "seq": 6, "text": ":::", "len": 3}
