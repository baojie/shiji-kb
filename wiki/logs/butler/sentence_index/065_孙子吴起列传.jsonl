{"sid": "065_孙子吴起列传.1.s1", "chapter": "065_孙子吴起列传", "para": "1", "seq": 1, "text": "孙子武者，齐人也。", "len": 9}
{"sid": "065_孙子吴起列传.1.s2", "chapter": "065_孙子吴起列传", "para": "1", "seq": 2, "text": "以兵法见於吴王阖庐。", "len": 10}
{"sid": "065_孙子吴起列传.1.s3", "chapter": "065_孙子吴起列传", "para": "1", "seq": 3, "text": "阖庐曰：“子之十三篇，吾尽观之矣，可以小试勒兵乎？", "len": 25}
{"sid": "065_孙子吴起列传.1.s4", "chapter": "065_孙子吴起列传", "para": "1", "seq": 4, "text": "“对曰：“可。", "len": 7}
{"sid": "065_孙子吴起列传.1.s5", "chapter": "065_孙子吴起列传", "para": "1", "seq": 5, "text": "“阖庐曰：“可试以妇人乎？", "len": 13}
{"sid": "065_孙子吴起列传.1.s6", "chapter": "065_孙子吴起列传", "para": "1", "seq": 6, "text": "“曰：“可。", "len": 6}
{"sid": "065_孙子吴起列传.1.s7", "chapter": "065_孙子吴起列传", "para": "1", "seq": 7, "text": "“於是许之，出宫中美女，得百八十人。", "len": 18}
{"sid": "065_孙子吴起列传.1.s8", "chapter": "065_孙子吴起列传", "para": "1", "seq": 8, "text": "孙子分为二队，以王之宠姬二人各为队长，皆令持戟。", "len": 24}
{"sid": "065_孙子吴起列传.1.s9", "chapter": "065_孙子吴起列传", "para": "1", "seq": 9, "text": "令之曰：“汝知而心与左右手背乎？", "len": 16}
{"sid": "065_孙子吴起列传.1.s10", "chapter": "065_孙子吴起列传", "para": "1", "seq": 10, "text": "“妇人曰：“知之。", "len": 9}
{"sid": "065_孙子吴起列传.1.s11", "chapter": "065_孙子吴起列传", "para": "1", "seq": 11, "text": "“孙子曰：“前，则视心；左，视左手；右，视右手；後，即视背。", "len": 30}
{"sid": "065_孙子吴起列传.1.s12", "chapter": "065_孙子吴起列传", "para": "1", "seq": 12, "text": "“妇人曰：“诺。", "len": 8}
{"sid": "065_孙子吴起列传.1.s13", "chapter": "065_孙子吴起列传", "para": "1", "seq": 13, "text": "“约束既布，乃设鈇钺，即三令五申之。", "len": 18}
{"sid": "065_孙子吴起列传.1.s14", "chapter": "065_孙子吴起列传", "para": "1", "seq": 14, "text": "於是鼓之右，妇人大笑。", "len": 11}
{"sid": "065_孙子吴起列传.1.s15", "chapter": "065_孙子吴起列传", "para": "1", "seq": 15, "text": "孙子曰：“约束不明，申令不熟，将之罪也。", "len": 20}
{"sid": "065_孙子吴起列传.1.s16", "chapter": "065_孙子吴起列传", "para": "1", "seq": 16, "text": "“复三令五申而鼓之左，妇人复大笑。", "len": 17}
{"sid": "065_孙子吴起列传.1.s17", "chapter": "065_孙子吴起列传", "para": "1", "seq": 17, "text": "孙子曰：“约束不明，申令不熟，将之罪也；既已明而不如法者，吏士之罪也。", "len": 35}
{"sid": "065_孙子吴起列传.1.s18", "chapter": "065_孙子吴起列传", "para": "1", "seq": 18, "text": "“乃欲斩左古队长。", "len": 9}
{"sid": "065_孙子吴起列传.1.s19", "chapter": "065_孙子吴起列传", "para": "1", "seq": 19, "text": "吴王从台上观，见且斩爱姬，大骇。", "len": 16}
{"sid": "065_孙子吴起列传.1.s20", "chapter": "065_孙子吴起列传", "para": "1", "seq": 20, "text": "趣使使下令曰：“寡人已知将军能用兵矣。", "len": 19}
{"sid": "065_孙子吴起列传.1.s21", "chapter": "065_孙子吴起列传", "para": "1", "seq": 21, "text": "寡人非此二姬，食不甘味，原勿斩也。", "len": 17}
{"sid": "065_孙子吴起列传.1.s22", "chapter": "065_孙子吴起列传", "para": "1", "seq": 22, "text": "“孙子曰：“臣既已受命为将，将在军，君命有所不受。", "len": 25}
{"sid": "065_孙子吴起列传.1.s23", "chapter": "065_孙子吴起列传", "para": "1", "seq": 23, "text": "“遂斩队长二人以徇。", "len": 10}
{"sid": "065_孙子吴起列传.1.s24", "chapter": "065_孙子吴起列传", "para": "1", "seq": 24, "text": "用其次为队长，於是复鼓之。", "len": 13}
{"sid": "065_孙子吴起列传.1.s25", "chapter": "065_孙子吴起列传", "para": "1", "seq": 25, "text": "妇人左右前後跪起皆中规矩绳墨，无敢出声。", "len": 20}
{"sid": "065_孙子吴起列传.1.s26", "chapter": "065_孙子吴起列传", "para": "1", "seq": 26, "text": "於是孙子使使报王曰：“兵既整齐，王可试下观之，唯王所欲用之，虽赴水火犹可也。", "len": 38}
{"sid": "065_孙子吴起列传.1.s27", "chapter": "065_孙子吴起列传", "para": "1", "seq": 27, "text": "“吴王曰：“将军罢休就舍，寡人不原下观。", "len": 20}
{"sid": "065_孙子吴起列传.1.s28", "chapter": "065_孙子吴起列传", "para": "1", "seq": 28, "text": "“孙子曰：“王徒好其言，不能用其实。", "len": 18}
{"sid": "065_孙子吴起列传.1.s29", "chapter": "065_孙子吴起列传", "para": "1", "seq": 29, "text": "“於是阖庐知孙子能用兵，卒以为将。", "len": 17}
{"sid": "065_孙子吴起列传.1.s30", "chapter": "065_孙子吴起列传", "para": "1", "seq": 30, "text": "西破彊楚，入郢，北威齐晋，显名诸侯，孙子与有力焉。", "len": 25}
{"sid": "065_孙子吴起列传.2.s1", "chapter": "065_孙子吴起列传", "para": "2", "seq": 1, "text": "孙武既死，後百馀岁有孙膑。", "len": 13}
{"sid": "065_孙子吴起列传.2.s2", "chapter": "065_孙子吴起列传", "para": "2", "seq": 2, "text": "膑生阿鄄之间，膑亦孙武之後世子孙也。", "len": 18}
{"sid": "065_孙子吴起列传.2.s3", "chapter": "065_孙子吴起列传", "para": "2", "seq": 3, "text": "孙膑尝与庞涓俱学兵法。", "len": 11}
{"sid": "065_孙子吴起列传.2.s4", "chapter": "065_孙子吴起列传", "para": "2", "seq": 4, "text": "庞涓既事魏，得为惠王将军，而自以为能不及孙膑，乃阴使召孙膑。", "len": 30}
{"sid": "065_孙子吴起列传.2.s5", "chapter": "065_孙子吴起列传", "para": "2", "seq": 5, "text": "膑至，庞涓恐其贤於己，疾之，则以法刑断其两足而黥之，欲隐勿见。", "len": 31}
{"sid": "065_孙子吴起列传.3.s1", "chapter": "065_孙子吴起列传", "para": "3", "seq": 1, "text": "齐使者如梁，孙膑以刑徒阴见，说齐使。", "len": 18}
{"sid": "065_孙子吴起列传.3.s2", "chapter": "065_孙子吴起列传", "para": "3", "seq": 2, "text": "齐使以为奇，窃载与之齐。", "len": 12}
{"sid": "065_孙子吴起列传.3.s3", "chapter": "065_孙子吴起列传", "para": "3", "seq": 3, "text": "齐将田忌善而客待之。", "len": 10}
{"sid": "065_孙子吴起列传.3.s4", "chapter": "065_孙子吴起列传", "para": "3", "seq": 4, "text": "忌数与齐诸公子驰逐重射。", "len": 12}
{"sid": "065_孙子吴起列传.3.s5", "chapter": "065_孙子吴起列传", "para": "3", "seq": 5, "text": "孙子见其马足不甚相远，马有上、中、下、辈。", "len": 21}
{"sid": "065_孙子吴起列传.3.s6", "chapter": "065_孙子吴起列传", "para": "3", "seq": 6, "text": "於是孙子谓田忌曰：“君弟重射，臣能令君胜。", "len": 21}
{"sid": "065_孙子吴起列传.3.s7", "chapter": "065_孙子吴起列传", "para": "3", "seq": 7, "text": "“田忌信然之，与王及诸公子逐射千金。", "len": 18}
{"sid": "065_孙子吴起列传.3.s8", "chapter": "065_孙子吴起列传", "para": "3", "seq": 8, "text": "及临质，孙子曰：“今以君之下驷与彼上驷，取君上驷与彼中驷，取君中驷与彼下驷。", "len": 38}
{"sid": "065_孙子吴起列传.3.s9", "chapter": "065_孙子吴起列传", "para": "3", "seq": 9, "text": "“既驰三辈毕，而田忌一不胜而再胜，卒得王千金。", "len": 23}
{"sid": "065_孙子吴起列传.3.s10", "chapter": "065_孙子吴起列传", "para": "3", "seq": 10, "text": "於是忌进孙子於威王。", "len": 10}
{"sid": "065_孙子吴起列传.3.s11", "chapter": "065_孙子吴起列传", "para": "3", "seq": 11, "text": "威王问兵法，遂以为师。", "len": 11}
{"sid": "065_孙子吴起列传.4.s1", "chapter": "065_孙子吴起列传", "para": "4", "seq": 1, "text": "其後魏伐赵，赵急，请救於齐。", "len": 14}
{"sid": "065_孙子吴起列传.4.s2", "chapter": "065_孙子吴起列传", "para": "4", "seq": 2, "text": "齐威王欲将孙膑，膑辞谢曰：“刑馀之人不可。", "len": 21}
{"sid": "065_孙子吴起列传.4.s3", "chapter": "065_孙子吴起列传", "para": "4", "seq": 3, "text": "“於是乃以田忌为将，而孙子为师，居辎车中，坐为计谋。", "len": 26}
{"sid": "065_孙子吴起列传.4.s4", "chapter": "065_孙子吴起列传", "para": "4", "seq": 4, "text": "田忌欲引兵之赵，孙子曰：“夫解杂乱纷纠者不控卷，救斗者不搏撠，批亢捣虚，形格势禁，则自为解耳。", "len": 47}
{"sid": "065_孙子吴起列传.4.s5", "chapter": "065_孙子吴起列传", "para": "4", "seq": 5, "text": "今梁赵相攻，轻兵锐卒必竭於外，老弱罢於内。", "len": 21}
{"sid": "065_孙子吴起列传.4.s6", "chapter": "065_孙子吴起列传", "para": "4", "seq": 6, "text": "君不若引兵疾走大梁，据其街路，旻其方虚，彼必释赵而自救。", "len": 28}
{"sid": "065_孙子吴起列传.4.s7", "chapter": "065_孙子吴起列传", "para": "4", "seq": 7, "text": "是我一举解赵之围而收弊於魏也。", "len": 15}
{"sid": "065_孙子吴起列传.4.s8", "chapter": "065_孙子吴起列传", "para": "4", "seq": 8, "text": "“田忌从之，魏果去邯郸，与齐战於桂陵，大破梁军。", "len": 24}
{"sid": "065_孙子吴起列传.5.s1", "chapter": "065_孙子吴起列传", "para": "5", "seq": 1, "text": "後十三岁，魏与赵攻韩，韩告急於齐。", "len": 17}
{"sid": "065_孙子吴起列传.5.s2", "chapter": "065_孙子吴起列传", "para": "5", "seq": 2, "text": "齐使田忌将而往，直走大梁。", "len": 13}
{"sid": "065_孙子吴起列传.5.s3", "chapter": "065_孙子吴起列传", "para": "5", "seq": 3, "text": "魏将庞涓闻之，去韩而归，齐军既已过而西矣。", "len": 21}
{"sid": "065_孙子吴起列传.5.s4", "chapter": "065_孙子吴起列传", "para": "5", "seq": 4, "text": "孙子谓田忌曰：“彼三晋之兵素悍勇而轻齐，齐号为怯，善战者因其势而利导之。", "len": 36}
{"sid": "065_孙子吴起列传.5.s5", "chapter": "065_孙子吴起列传", "para": "5", "seq": 5, "text": "兵法，百里而趣利者蹶上将，五十里而趣利者军半至。", "len": 24}
{"sid": "065_孙子吴起列传.5.s6", "chapter": "065_孙子吴起列传", "para": "5", "seq": 6, "text": "使齐军入魏地为十万灶，明日为五万灶，又明日为三万灶。", "len": 26}
{"sid": "065_孙子吴起列传.5.s7", "chapter": "065_孙子吴起列传", "para": "5", "seq": 7, "text": "“庞涓行三日，大喜，曰：“我固知齐军怯，入吾地三日，士卒亡者过半矣。", "len": 34}
{"sid": "065_孙子吴起列传.5.s8", "chapter": "065_孙子吴起列传", "para": "5", "seq": 8, "text": "“乃弃其步军，与其轻锐倍日并行逐之。", "len": 18}
{"sid": "065_孙子吴起列传.5.s9", "chapter": "065_孙子吴起列传", "para": "5", "seq": 9, "text": "孙子度其行，暮当至马陵。", "len": 12}
{"sid": "065_孙子吴起列传.5.s10", "chapter": "065_孙子吴起列传", "para": "5", "seq": 10, "text": "马陵道陕，而旁多阻隘，可伏兵，乃斫大树白而书之曰“庞涓死于此树之下“。", "len": 35}
{"sid": "065_孙子吴起列传.5.s11", "chapter": "065_孙子吴起列传", "para": "5", "seq": 11, "text": "於是令齐军善射者万弩，夹道而伏，期曰“暮见火举而俱发“。", "len": 28}
{"sid": "065_孙子吴起列传.5.s12", "chapter": "065_孙子吴起列传", "para": "5", "seq": 12, "text": "庞涓果夜至斫木下，见白书，乃钻火烛之。", "len": 19}
{"sid": "065_孙子吴起列传.5.s13", "chapter": "065_孙子吴起列传", "para": "5", "seq": 13, "text": "读其书未毕，齐军万弩俱发，魏军大乱相失。", "len": 20}
{"sid": "065_孙子吴起列传.5.s14", "chapter": "065_孙子吴起列传", "para": "5", "seq": 14, "text": "庞涓自知智穷兵败，乃自刭，曰：“遂成竖子之名！", "len": 23}
{"sid": "065_孙子吴起列传.5.s15", "chapter": "065_孙子吴起列传", "para": "5", "seq": 15, "text": "“齐因乘胜尽破其军，虏魏太子申以归。", "len": 18}
{"sid": "065_孙子吴起列传.5.s16", "chapter": "065_孙子吴起列传", "para": "5", "seq": 16, "text": "孙膑以此名显天下，世传其兵法。", "len": 15}
{"sid": "065_孙子吴起列传.6.s1", "chapter": "065_孙子吴起列传", "para": "6", "seq": 1, "text": "吴起者，卫人也，好用兵。", "len": 12}
{"sid": "065_孙子吴起列传.6.s2", "chapter": "065_孙子吴起列传", "para": "6", "seq": 2, "text": "尝学於曾子，事鲁君。", "len": 10}
{"sid": "065_孙子吴起列传.6.s3", "chapter": "065_孙子吴起列传", "para": "6", "seq": 3, "text": "齐人攻鲁，鲁欲将吴起，吴起取齐女为妻，而鲁疑之。", "len": 24}
{"sid": "065_孙子吴起列传.6.s4", "chapter": "065_孙子吴起列传", "para": "6", "seq": 4, "text": "吴起於是欲就名，遂杀其妻，以明不与齐也。", "len": 20}
{"sid": "065_孙子吴起列传.6.s5", "chapter": "065_孙子吴起列传", "para": "6", "seq": 5, "text": "鲁卒以为将。", "len": 6}
{"sid": "065_孙子吴起列传.6.s6", "chapter": "065_孙子吴起列传", "para": "6", "seq": 6, "text": "将而攻齐，大破之。", "len": 9}
{"sid": "065_孙子吴起列传.7.s1", "chapter": "065_孙子吴起列传", "para": "7", "seq": 1, "text": "鲁人或恶吴起曰：“起之为人，猜忍人也。", "len": 19}
{"sid": "065_孙子吴起列传.7.s2", "chapter": "065_孙子吴起列传", "para": "7", "seq": 2, "text": "其少时，家累千金，游仕不遂，遂破其家，乡党笑之，吴起杀其谤己者三十馀人，而东出卫郭门。", "len": 43}
{"sid": "065_孙子吴起列传.7.s3", "chapter": "065_孙子吴起列传", "para": "7", "seq": 3, "text": "与其母诀，齧臂而盟曰：起不为卿相，不复入卫。", "len": 22}
{"sid": "065_孙子吴起列传.7.s4", "chapter": "065_孙子吴起列传", "para": "7", "seq": 4, "text": "遂事曾子。", "len": 5}
{"sid": "065_孙子吴起列传.7.s5", "chapter": "065_孙子吴起列传", "para": "7", "seq": 5, "text": "居顷之，其母死，起终不归。", "len": 13}
{"sid": "065_孙子吴起列传.7.s6", "chapter": "065_孙子吴起列传", "para": "7", "seq": 6, "text": "曾子薄之，而与起绝。", "len": 10}
{"sid": "065_孙子吴起列传.7.s7", "chapter": "065_孙子吴起列传", "para": "7", "seq": 7, "text": "起乃之鲁，学兵法以事鲁君。", "len": 13}
{"sid": "065_孙子吴起列传.7.s8", "chapter": "065_孙子吴起列传", "para": "7", "seq": 8, "text": "鲁君疑之，起杀妻以求将。", "len": 12}
{"sid": "065_孙子吴起列传.7.s9", "chapter": "065_孙子吴起列传", "para": "7", "seq": 9, "text": "夫鲁小国，而有战胜之名，则诸侯图鲁矣。", "len": 19}
{"sid": "065_孙子吴起列传.7.s10", "chapter": "065_孙子吴起列传", "para": "7", "seq": 10, "text": "且鲁卫兄弟之国也，而君用起，则是弃卫。", "len": 19}
{"sid": "065_孙子吴起列传.7.s11", "chapter": "065_孙子吴起列传", "para": "7", "seq": 11, "text": "” 鲁君疑之，谢吴起。", "len": 11}
{"sid": "065_孙子吴起列传.8.s1", "chapter": "065_孙子吴起列传", "para": "8", "seq": 1, "text": "吴起於是闻魏文侯贤，欲事之。", "len": 14}
{"sid": "065_孙子吴起列传.8.s2", "chapter": "065_孙子吴起列传", "para": "8", "seq": 2, "text": "文侯问李克曰：“吴起何如人哉？", "len": 15}
{"sid": "065_孙子吴起列传.8.s3", "chapter": "065_孙子吴起列传", "para": "8", "seq": 3, "text": "“李克曰：“起贪而好色，然用兵司马穰苴不能过也。", "len": 24}
{"sid": "065_孙子吴起列传.8.s4", "chapter": "065_孙子吴起列传", "para": "8", "seq": 4, "text": "“於是魏文侯以为将，击秦，拔五城。", "len": 17}
{"sid": "065_孙子吴起列传.9.s1", "chapter": "065_孙子吴起列传", "para": "9", "seq": 1, "text": "起之为将，与士卒最下者同衣食。", "len": 15}
{"sid": "065_孙子吴起列传.9.s2", "chapter": "065_孙子吴起列传", "para": "9", "seq": 2, "text": "卧不设席，行不骑乘，亲裹赢粮，与士卒分劳苦。", "len": 22}
{"sid": "065_孙子吴起列传.9.s3", "chapter": "065_孙子吴起列传", "para": "9", "seq": 3, "text": "卒有病疽者，起为吮之。", "len": 11}
{"sid": "065_孙子吴起列传.9.s4", "chapter": "065_孙子吴起列传", "para": "9", "seq": 4, "text": "卒母闻而哭之。", "len": 7}
{"sid": "065_孙子吴起列传.9.s5", "chapter": "065_孙子吴起列传", "para": "9", "seq": 5, "text": "人曰：“子卒也，而将，军自吮其疽，何哭为？", "len": 21}
{"sid": "065_孙子吴起列传.9.s6", "chapter": "065_孙子吴起列传", "para": "9", "seq": 6, "text": "“母曰：“非然也。", "len": 9}
{"sid": "065_孙子吴起列传.9.s7", "chapter": "065_孙子吴起列传", "para": "9", "seq": 7, "text": "往年吴公吮其父，其父战不旋踵，遂死於敌。", "len": 20}
{"sid": "065_孙子吴起列传.9.s8", "chapter": "065_孙子吴起列传", "para": "9", "seq": 8, "text": "吴公今又吮其子，妾不知其死所矣。", "len": 16}
{"sid": "065_孙子吴起列传.9.s9", "chapter": "065_孙子吴起列传", "para": "9", "seq": 9, "text": "是以哭之。“", "len": 6}
{"sid": "065_孙子吴起列传.10.s1", "chapter": "065_孙子吴起列传", "para": "10", "seq": 1, "text": "文侯以吴起善用兵，廉平，尽能得士心，乃以为西河守，以拒秦、韩。", "len": 31}
{"sid": "065_孙子吴起列传.11.s1", "chapter": "065_孙子吴起列传", "para": "11", "seq": 1, "text": "魏文侯既卒，起事其子武侯。", "len": 13}
{"sid": "065_孙子吴起列传.11.s2", "chapter": "065_孙子吴起列传", "para": "11", "seq": 2, "text": "武侯浮西河而下，中流，顾而谓吴起曰：“美哉乎山河之固，此魏国之宝也！", "len": 34}
{"sid": "065_孙子吴起列传.11.s3", "chapter": "065_孙子吴起列传", "para": "11", "seq": 3, "text": "” 起对曰：“在德不在险。", "len": 13}
{"sid": "065_孙子吴起列传.11.s4", "chapter": "065_孙子吴起列传", "para": "11", "seq": 4, "text": "昔三苗氏左洞庭，右彭蠡，德义不修，禹灭之。", "len": 21}
{"sid": "065_孙子吴起列传.11.s5", "chapter": "065_孙子吴起列传", "para": "11", "seq": 5, "text": "夏桀之居，左河济，右泰华，伊阙在其南，羊肠在其北，修政不仁，汤放之。", "len": 34}
{"sid": "065_孙子吴起列传.11.s6", "chapter": "065_孙子吴起列传", "para": "11", "seq": 6, "text": "殷纣之国，左孟门，右太行，常山在其北，大河经其南，修政不德，武王杀之。", "len": 35}
{"sid": "065_孙子吴起列传.11.s7", "chapter": "065_孙子吴起列传", "para": "11", "seq": 7, "text": "由此观之，在德不在险。", "len": 11}
{"sid": "065_孙子吴起列传.11.s8", "chapter": "065_孙子吴起列传", "para": "11", "seq": 8, "text": "若君不修德，舟中之人尽为敌国也。", "len": 16}
{"sid": "065_孙子吴起列传.11.s9", "chapter": "065_孙子吴起列传", "para": "11", "seq": 9, "text": "” 武侯曰：“善。”", "len": 10}
{"sid": "065_孙子吴起列传.12.s1", "chapter": "065_孙子吴起列传", "para": "12", "seq": 1, "text": "吴起为西河守，甚有声名。", "len": 12}
{"sid": "065_孙子吴起列传.12.s2", "chapter": "065_孙子吴起列传", "para": "12", "seq": 2, "text": "魏置相，相田文。", "len": 8}
{"sid": "065_孙子吴起列传.12.s3", "chapter": "065_孙子吴起列传", "para": "12", "seq": 3, "text": "吴起不悦，谓田文曰：“请与子论功，可乎？", "len": 20}
{"sid": "065_孙子吴起列传.12.s4", "chapter": "065_孙子吴起列传", "para": "12", "seq": 4, "text": "“田文曰：“可。", "len": 8}
{"sid": "065_孙子吴起列传.12.s5", "chapter": "065_孙子吴起列传", "para": "12", "seq": 5, "text": "“起曰：“将三军，使士卒乐死，敌国不敢谋，子孰与起？", "len": 26}
{"sid": "065_孙子吴起列传.12.s6", "chapter": "065_孙子吴起列传", "para": "12", "seq": 6, "text": "“文曰：“不如子。", "len": 9}
{"sid": "065_孙子吴起列传.12.s7", "chapter": "065_孙子吴起列传", "para": "12", "seq": 7, "text": "“起曰：“治百官，亲万民，实府库，子孰与起？", "len": 22}
{"sid": "065_孙子吴起列传.12.s8", "chapter": "065_孙子吴起列传", "para": "12", "seq": 8, "text": "“文曰：“不如子。", "len": 9}
{"sid": "065_孙子吴起列传.12.s9", "chapter": "065_孙子吴起列传", "para": "12", "seq": 9, "text": "“起曰：“守西河而秦兵不敢东乡，韩赵宾从，子孰与起？", "len": 26}
{"sid": "065_孙子吴起列传.12.s10", "chapter": "065_孙子吴起列传", "para": "12", "seq": 10, "text": "“文曰：“不如子。", "len": 9}
{"sid": "065_孙子吴起列传.12.s11", "chapter": "065_孙子吴起列传", "para": "12", "seq": 11, "text": "“起曰：“此三者，子皆出吾下，而位加吾上，何也？", "len": 24}
{"sid": "065_孙子吴起列传.12.s12", "chapter": "065_孙子吴起列传", "para": "12", "seq": 12, "text": "“文曰：“主少国疑，大臣未附，百姓不信，方是之时，属之於子乎？", "len": 31}
{"sid": "065_孙子吴起列传.12.s13", "chapter": "065_孙子吴起列传", "para": "12", "seq": 13, "text": "属之於我乎？", "len": 6}
{"sid": "065_孙子吴起列传.12.s14", "chapter": "065_孙子吴起列传", "para": "12", "seq": 14, "text": "“起默然良久，曰：“属之子矣。", "len": 15}
{"sid": "065_孙子吴起列传.12.s15", "chapter": "065_孙子吴起列传", "para": "12", "seq": 15, "text": "“文曰：“此乃吾所以居子之上也。", "len": 16}
{"sid": "065_孙子吴起列传.12.s16", "chapter": "065_孙子吴起列传", "para": "12", "seq": 16, "text": "“吴起乃自知弗如田文。", "len": 11}
{"sid": "065_孙子吴起列传.13.s1", "chapter": "065_孙子吴起列传", "para": "13", "seq": 1, "text": "田文既死，公叔为相，尚魏公主，而害吴起。", "len": 20}
{"sid": "065_孙子吴起列传.13.s2", "chapter": "065_孙子吴起列传", "para": "13", "seq": 2, "text": "公叔之仆曰：“起易去也。", "len": 12}
{"sid": "065_孙子吴起列传.13.s3", "chapter": "065_孙子吴起列传", "para": "13", "seq": 3, "text": "” 公叔曰：“柰何？", "len": 10}
{"sid": "065_孙子吴起列传.13.s4", "chapter": "065_孙子吴起列传", "para": "13", "seq": 4, "text": "” 其仆曰：“吴起为人节廉而自喜名也。", "len": 19}
{"sid": "065_孙子吴起列传.13.s5", "chapter": "065_孙子吴起列传", "para": "13", "seq": 5, "text": "君因先与武侯言曰：夫吴起贤人也，而侯之国小，又与彊秦壤界，臣窃恐起之无留心也。", "len": 39}
{"sid": "065_孙子吴起列传.13.s6", "chapter": "065_孙子吴起列传", "para": "13", "seq": 6, "text": "武侯即曰：柰何？", "len": 8}
{"sid": "065_孙子吴起列传.13.s7", "chapter": "065_孙子吴起列传", "para": "13", "seq": 7, "text": "君因谓武侯曰：试延以公主，起有留心则必受之。", "len": 22}
{"sid": "065_孙子吴起列传.13.s8", "chapter": "065_孙子吴起列传", "para": "13", "seq": 8, "text": "无留心则必辞矣。", "len": 8}
{"sid": "065_孙子吴起列传.13.s9", "chapter": "065_孙子吴起列传", "para": "13", "seq": 9, "text": "以此卜之。", "len": 5}
{"sid": "065_孙子吴起列传.13.s10", "chapter": "065_孙子吴起列传", "para": "13", "seq": 10, "text": "君因召吴起而与归，即令公主怒而轻君。", "len": 18}
{"sid": "065_孙子吴起列传.13.s11", "chapter": "065_孙子吴起列传", "para": "13", "seq": 11, "text": "吴起见公主之贱君也，则必辞。", "len": 14}
{"sid": "065_孙子吴起列传.13.s12", "chapter": "065_孙子吴起列传", "para": "13", "seq": 12, "text": "” 於是吴起见公主之贱魏相，果辞魏武侯。", "len": 20}
{"sid": "065_孙子吴起列传.13.s13", "chapter": "065_孙子吴起列传", "para": "13", "seq": 13, "text": "武侯疑之而弗信也。", "len": 9}
{"sid": "065_孙子吴起列传.13.s14", "chapter": "065_孙子吴起列传", "para": "13", "seq": 14, "text": "吴起惧得罪，遂去，即之楚。", "len": 13}
{"sid": "065_孙子吴起列传.14.s1", "chapter": "065_孙子吴起列传", "para": "14", "seq": 1, "text": "楚悼王素闻起贤，至则相楚。", "len": 13}
{"sid": "065_孙子吴起列传.14.s2", "chapter": "065_孙子吴起列传", "para": "14", "seq": 2, "text": "明法审令，捐不急之官，废公族疏远者，以抚养战斗之士。", "len": 26}
{"sid": "065_孙子吴起列传.14.s3", "chapter": "065_孙子吴起列传", "para": "14", "seq": 3, "text": "要在彊兵，破驰说之言从横者。", "len": 14}
{"sid": "065_孙子吴起列传.14.s4", "chapter": "065_孙子吴起列传", "para": "14", "seq": 4, "text": "於是南平百越；北并陈蔡，卻三晋；西伐秦。", "len": 20}
{"sid": "065_孙子吴起列传.14.s5", "chapter": "065_孙子吴起列传", "para": "14", "seq": 5, "text": "诸侯患楚之彊。", "len": 7}
{"sid": "065_孙子吴起列传.14.s6", "chapter": "065_孙子吴起列传", "para": "14", "seq": 6, "text": "故楚之贵戚尽欲害吴起。", "len": 11}
{"sid": "065_孙子吴起列传.14.s7", "chapter": "065_孙子吴起列传", "para": "14", "seq": 7, "text": "及悼王死，宗室大臣作乱而攻吴起，吴起走之王尸而伏之。", "len": 26}
{"sid": "065_孙子吴起列传.14.s8", "chapter": "065_孙子吴起列传", "para": "14", "seq": 8, "text": "击起之徒因射刺吴起，并中悼王。", "len": 15}
{"sid": "065_孙子吴起列传.14.s9", "chapter": "065_孙子吴起列传", "para": "14", "seq": 9, "text": "悼王既葬，太子立，乃使令尹尽诛射吴起而并中王尸者。", "len": 25}
{"sid": "065_孙子吴起列传.14.s10", "chapter": "065_孙子吴起列传", "para": "14", "seq": 10, "text": "坐射起而夷宗死者七十馀家。", "len": 13}
{"sid": "065_孙子吴起列传.14.s11", "chapter": "065_孙子吴起列传", "para": "14", "seq": 11, "text": "::: 太史公曰", "len": 8}
{"sid": "065_孙子吴起列传.15.s1", "chapter": "065_孙子吴起列传", "para": "15", "seq": 1, "text": "太史公曰：世俗所称师旅，皆道孙子十三篇，吴起兵法，世多有，故弗论，论其行事所施设者。", "len": 42}
{"sid": "065_孙子吴起列传.15.s2", "chapter": "065_孙子吴起列传", "para": "15", "seq": 2, "text": "语曰：“能行之者未必能言，能言之者未必能行。", "len": 22}
{"sid": "065_孙子吴起列传.15.s3", "chapter": "065_孙子吴起列传", "para": "15", "seq": 3, "text": "“孙子筹策庞涓明矣，然不能蚤救患於被刑。", "len": 20}
{"sid": "065_孙子吴起列传.15.s4", "chapter": "065_孙子吴起列传", "para": "15", "seq": 4, "text": "吴起说武侯以形势不如德，然行之於楚，以刻暴少恩亡其躯。", "len": 27}
{"sid": "065_孙子吴起列传.15.s5", "chapter": "065_孙子吴起列传", "para": "15", "seq": 5, "text": "悲夫！", "len": 3}
{"sid": "065_孙子吴起列传.15.s6", "chapter": "065_孙子吴起列传", "para": "15", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "065_孙子吴起列传.16.s1", "chapter": "065_孙子吴起列传", "para": "16", "seq": 1, "text": "孙子兵法，一十三篇。", "len": 10}
{"sid": "065_孙子吴起列传.16.s2", "chapter": "065_孙子吴起列传", "para": "16", "seq": 2, "text": "美人既斩，良将得焉。", "len": 10}
{"sid": "065_孙子吴起列传.16.s3", "chapter": "065_孙子吴起列传", "para": "16", "seq": 3, "text": "其孙膑脚，筹策庞涓。", "len": 10}
{"sid": "065_孙子吴起列传.16.s4", "chapter": "065_孙子吴起列传", "para": "16", "seq": 4, "text": "吴起相魏，西河称贤； 惨礉事楚，死後留权。", "len": 21}
{"sid": "065_孙子吴起列传.16.s5", "chapter": "065_孙子吴起列传", "para": "16", "seq": 5, "text": ":::", "len": 3}
