{"sid": "107_魏其武安侯列传.1.s1", "chapter": "107_魏其武安侯列传", "para": "1", "seq": 1, "text": "魏其侯窦婴者，孝文后从兄子也。", "len": 15}
{"sid": "107_魏其武安侯列传.1.s2", "chapter": "107_魏其武安侯列传", "para": "1", "seq": 2, "text": "父世观津人。", "len": 6}
{"sid": "107_魏其武安侯列传.1.s3", "chapter": "107_魏其武安侯列传", "para": "1", "seq": 3, "text": "喜宾客。", "len": 4}
{"sid": "107_魏其武安侯列传.1.s4", "chapter": "107_魏其武安侯列传", "para": "1", "seq": 4, "text": "孝文时，婴为吴相，病免。", "len": 12}
{"sid": "107_魏其武安侯列传.1.s5", "chapter": "107_魏其武安侯列传", "para": "1", "seq": 5, "text": "孝景初即位，为詹事。", "len": 10}
{"sid": "107_魏其武安侯列传.2.s1", "chapter": "107_魏其武安侯列传", "para": "2", "seq": 1, "text": "梁孝王者，孝景弟也，其母窦太后爱之。", "len": 18}
{"sid": "107_魏其武安侯列传.2.s2", "chapter": "107_魏其武安侯列传", "para": "2", "seq": 2, "text": "梁孝王朝，因昆弟燕饮。", "len": 11}
{"sid": "107_魏其武安侯列传.2.s3", "chapter": "107_魏其武安侯列传", "para": "2", "seq": 3, "text": "是时上未立太子，酒酣，从容言曰：“千秋之後传梁王。", "len": 25}
{"sid": "107_魏其武安侯列传.2.s4", "chapter": "107_魏其武安侯列传", "para": "2", "seq": 4, "text": "” 太后驩。", "len": 6}
{"sid": "107_魏其武安侯列传.2.s5", "chapter": "107_魏其武安侯列传", "para": "2", "seq": 5, "text": "窦婴引卮酒进上，曰：“天下者，高祖天下，父子相传，此汉之约也，上何以得擅传梁王！", "len": 40}
{"sid": "107_魏其武安侯列传.2.s6", "chapter": "107_魏其武安侯列传", "para": "2", "seq": 6, "text": "” 太后由此憎窦婴。", "len": 10}
{"sid": "107_魏其武安侯列传.2.s7", "chapter": "107_魏其武安侯列传", "para": "2", "seq": 7, "text": "窦婴亦薄其官，因病免。", "len": 11}
{"sid": "107_魏其武安侯列传.2.s8", "chapter": "107_魏其武安侯列传", "para": "2", "seq": 8, "text": "太后除窦婴门籍，不得入朝请。", "len": 14}
{"sid": "107_魏其武安侯列传.3.s1", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 1, "text": "孝景三年，吴楚反，上察宗室诸窦毋如窦婴贤，乃召婴。", "len": 25}
{"sid": "107_魏其武安侯列传.3.s2", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 2, "text": "婴入见，固辞谢病不足任。", "len": 12}
{"sid": "107_魏其武安侯列传.3.s3", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 3, "text": "太后亦惭。", "len": 5}
{"sid": "107_魏其武安侯列传.3.s4", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 4, "text": "於是上曰：“天下方有急，王孙宁可以让邪？", "len": 20}
{"sid": "107_魏其武安侯列传.3.s5", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 5, "text": "” 乃拜婴为大将军，赐金千斤。", "len": 15}
{"sid": "107_魏其武安侯列传.3.s6", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 6, "text": "婴乃言袁盎、栾布诸名将贤士在家者进之。", "len": 19}
{"sid": "107_魏其武安侯列传.3.s7", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 7, "text": "所赐金，陈之廊庑下，军吏过，辄令财取为用，金无入家者。", "len": 27}
{"sid": "107_魏其武安侯列传.3.s8", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 8, "text": "窦婴守荥阳，监齐赵兵。", "len": 11}
{"sid": "107_魏其武安侯列传.3.s9", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 9, "text": "七国兵已尽破，封婴为魏其侯。", "len": 14}
{"sid": "107_魏其武安侯列传.3.s10", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 10, "text": "诸游士宾客争归魏其侯。", "len": 11}
{"sid": "107_魏其武安侯列传.3.s11", "chapter": "107_魏其武安侯列传", "para": "3", "seq": 11, "text": "孝景时每朝议大事，条侯、魏其侯，诸列侯莫敢与亢礼。", "len": 25}
{"sid": "107_魏其武安侯列传.4.s1", "chapter": "107_魏其武安侯列传", "para": "4", "seq": 1, "text": "孝景四年，立栗太子，使魏其侯为太子傅。", "len": 19}
{"sid": "107_魏其武安侯列传.4.s2", "chapter": "107_魏其武安侯列传", "para": "4", "seq": 2, "text": "孝景七年，栗太子废，魏其数争不能得。", "len": 18}
{"sid": "107_魏其武安侯列传.4.s3", "chapter": "107_魏其武安侯列传", "para": "4", "seq": 3, "text": "魏其谢病，屏居蓝田南山之下数月，诸宾客辩士说之，莫能来。", "len": 28}
{"sid": "107_魏其武安侯列传.4.s4", "chapter": "107_魏其武安侯列传", "para": "4", "seq": 4, "text": "梁人高遂乃说魏其曰：“能富贵将军者，上也；能亲将军者，太后也。", "len": 31}
{"sid": "107_魏其武安侯列传.4.s5", "chapter": "107_魏其武安侯列传", "para": "4", "seq": 5, "text": "今将军傅太子，太子废而不能争；争不能得，又弗能死。", "len": 25}
{"sid": "107_魏其武安侯列传.4.s6", "chapter": "107_魏其武安侯列传", "para": "4", "seq": 6, "text": "自引谢病，拥赵女，屏间处而不朝。", "len": 16}
{"sid": "107_魏其武安侯列传.4.s7", "chapter": "107_魏其武安侯列传", "para": "4", "seq": 7, "text": "相提而论，是自明扬主上之过。", "len": 14}
{"sid": "107_魏其武安侯列传.4.s8", "chapter": "107_魏其武安侯列传", "para": "4", "seq": 8, "text": "有如两宫螫将军，则妻子毋类矣。", "len": 15}
{"sid": "107_魏其武安侯列传.4.s9", "chapter": "107_魏其武安侯列传", "para": "4", "seq": 9, "text": "” 魏其侯然之，乃遂起，朝请如故。", "len": 17}
{"sid": "107_魏其武安侯列传.5.s1", "chapter": "107_魏其武安侯列传", "para": "5", "seq": 1, "text": "桃侯免相，窦太后数言魏其侯。", "len": 14}
{"sid": "107_魏其武安侯列传.5.s2", "chapter": "107_魏其武安侯列传", "para": "5", "seq": 2, "text": "孝景帝曰：“太后岂以为臣有爱，不相魏其？", "len": 20}
{"sid": "107_魏其武安侯列传.5.s3", "chapter": "107_魏其武安侯列传", "para": "5", "seq": 3, "text": "魏其者，沾沾自喜耳，多易。", "len": 13}
{"sid": "107_魏其武安侯列传.5.s4", "chapter": "107_魏其武安侯列传", "para": "5", "seq": 4, "text": "难以为相，持重。", "len": 8}
{"sid": "107_魏其武安侯列传.5.s5", "chapter": "107_魏其武安侯列传", "para": "5", "seq": 5, "text": "” 遂不用，用建陵侯卫绾为丞相。", "len": 16}
{"sid": "107_魏其武安侯列传.6.s1", "chapter": "107_魏其武安侯列传", "para": "6", "seq": 1, "text": "武安侯田蚡者，孝景后同母弟也，生长陵。", "len": 19}
{"sid": "107_魏其武安侯列传.6.s2", "chapter": "107_魏其武安侯列传", "para": "6", "seq": 2, "text": "魏其已为大将军後，方盛，蚡为诸郎，未贵，往来侍酒魏其，跪起如子姓。", "len": 33}
{"sid": "107_魏其武安侯列传.6.s3", "chapter": "107_魏其武安侯列传", "para": "6", "seq": 3, "text": "及孝景晚节，蚡益贵幸，为太中大夫。", "len": 17}
{"sid": "107_魏其武安侯列传.6.s4", "chapter": "107_魏其武安侯列传", "para": "6", "seq": 4, "text": "蚡辩有口，学槃盂诸书，王太后贤之。", "len": 17}
{"sid": "107_魏其武安侯列传.6.s5", "chapter": "107_魏其武安侯列传", "para": "6", "seq": 5, "text": "孝景崩，即日太子立，称制，所镇抚多有田蚡宾客计筴，蚡弟田胜，皆以太后弟，孝景後三年封蚡为武安侯，胜为周阳侯。", "len": 54}
{"sid": "107_魏其武安侯列传.7.s1", "chapter": "107_魏其武安侯列传", "para": "7", "seq": 1, "text": "武安侯新欲用事为相，卑下宾客，进名士家居者贵之，欲以倾魏其诸将相。", "len": 33}
{"sid": "107_魏其武安侯列传.7.s2", "chapter": "107_魏其武安侯列传", "para": "7", "seq": 2, "text": "建元元年，丞相绾病免，上议置丞相、太尉。", "len": 20}
{"sid": "107_魏其武安侯列传.7.s3", "chapter": "107_魏其武安侯列传", "para": "7", "seq": 3, "text": "籍福说武安侯曰：“魏其贵久矣，天下士素归之。", "len": 22}
{"sid": "107_魏其武安侯列传.7.s4", "chapter": "107_魏其武安侯列传", "para": "7", "seq": 4, "text": "今将军初兴，未如魏其，即上以将军为丞相，必让魏其。", "len": 25}
{"sid": "107_魏其武安侯列传.7.s5", "chapter": "107_魏其武安侯列传", "para": "7", "seq": 5, "text": "魏其为丞相，将军必为太尉。", "len": 13}
{"sid": "107_魏其武安侯列传.7.s6", "chapter": "107_魏其武安侯列传", "para": "7", "seq": 6, "text": "太尉、丞相尊等耳，又有让贤名。", "len": 15}
{"sid": "107_魏其武安侯列传.7.s7", "chapter": "107_魏其武安侯列传", "para": "7", "seq": 7, "text": "” 武安侯乃微言太后风上，於是乃以魏其侯为丞相，武安侯为太尉。", "len": 31}
{"sid": "107_魏其武安侯列传.7.s8", "chapter": "107_魏其武安侯列传", "para": "7", "seq": 8, "text": "籍福贺魏其侯，因吊曰：“君侯资性喜善疾恶，方今善人誉君侯，故至丞相；然君侯且疾恶，恶人众，亦且毁君侯。", "len": 51}
{"sid": "107_魏其武安侯列传.7.s9", "chapter": "107_魏其武安侯列传", "para": "7", "seq": 9, "text": "君侯能兼容，则幸久；不能，今以毁去矣。", "len": 19}
{"sid": "107_魏其武安侯列传.7.s10", "chapter": "107_魏其武安侯列传", "para": "7", "seq": 10, "text": "” 魏其不听。", "len": 7}
{"sid": "107_魏其武安侯列传.8.s1", "chapter": "107_魏其武安侯列传", "para": "8", "seq": 1, "text": "魏其、武安俱好儒术，推毂赵绾为御史大夫，王臧为郎中令。", "len": 27}
{"sid": "107_魏其武安侯列传.8.s2", "chapter": "107_魏其武安侯列传", "para": "8", "seq": 2, "text": "迎鲁申公，欲设明堂，令列侯就国，除关，以礼为服制，以兴太平。", "len": 30}
{"sid": "107_魏其武安侯列传.8.s3", "chapter": "107_魏其武安侯列传", "para": "8", "seq": 3, "text": "举適诸窦宗室毋节行者，除其属籍。", "len": 16}
{"sid": "107_魏其武安侯列传.8.s4", "chapter": "107_魏其武安侯列传", "para": "8", "seq": 4, "text": "时诸外家为列侯，列侯多尚公主，皆不欲就国，以故毁日至窦太后。", "len": 30}
{"sid": "107_魏其武安侯列传.8.s5", "chapter": "107_魏其武安侯列传", "para": "8", "seq": 5, "text": "太后好黄老之言，而魏其、武安、赵绾、王臧等务隆推儒术，贬道家言，是以窦太后滋不说魏其等。", "len": 44}
{"sid": "107_魏其武安侯列传.8.s6", "chapter": "107_魏其武安侯列传", "para": "8", "seq": 6, "text": "及建元二年，御史大夫赵绾请无奏事东宫。", "len": 19}
{"sid": "107_魏其武安侯列传.8.s7", "chapter": "107_魏其武安侯列传", "para": "8", "seq": 7, "text": "窦太后大怒，乃罢逐赵绾、王臧等，而免丞相、太尉，以柏至侯许昌为丞相，武彊侯庄青翟为御史大夫。", "len": 46}
{"sid": "107_魏其武安侯列传.8.s8", "chapter": "107_魏其武安侯列传", "para": "8", "seq": 8, "text": "魏其、武安由此以侯家居。", "len": 12}
{"sid": "107_魏其武安侯列传.9.s1", "chapter": "107_魏其武安侯列传", "para": "9", "seq": 1, "text": "武安侯虽不任职，以王太后故，亲幸，数言事多效，天下吏士趋势利者，皆去魏其归武安，武安日益横。", "len": 46}
{"sid": "107_魏其武安侯列传.9.s2", "chapter": "107_魏其武安侯列传", "para": "9", "seq": 2, "text": "建元六年，窦太后崩，丞相昌、御史大夫青翟坐丧事不办，免。", "len": 28}
{"sid": "107_魏其武安侯列传.9.s3", "chapter": "107_魏其武安侯列传", "para": "9", "seq": 3, "text": "以武安侯蚡为丞相，以大司农韩安国为御史大夫。", "len": 22}
{"sid": "107_魏其武安侯列传.9.s4", "chapter": "107_魏其武安侯列传", "para": "9", "seq": 4, "text": "天下士郡诸侯愈益附武安。", "len": 12}
{"sid": "107_魏其武安侯列传.10.s1", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 1, "text": "武安者，貌侵，生贵甚。", "len": 11}
{"sid": "107_魏其武安侯列传.10.s2", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 2, "text": "又以为诸侯王多长，上初即位，富於春秋，蚡以肺腑为京师相，非痛折节以礼诎之，天下不肃。", "len": 42}
{"sid": "107_魏其武安侯列传.10.s3", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 3, "text": "当是时，丞相入奏事，坐语移日，所言皆听。", "len": 20}
{"sid": "107_魏其武安侯列传.10.s4", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 4, "text": "荐人或起家至二千石，权移主上。", "len": 15}
{"sid": "107_魏其武安侯列传.10.s5", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 5, "text": "上乃曰：“君除吏已尽未？", "len": 12}
{"sid": "107_魏其武安侯列传.10.s6", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 6, "text": "吾亦欲除吏。", "len": 6}
{"sid": "107_魏其武安侯列传.10.s7", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 7, "text": "” 尝请考工地益宅，上怒曰：“君何不遂取武库！", "len": 23}
{"sid": "107_魏其武安侯列传.10.s8", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 8, "text": "” 是後乃退。", "len": 7}
{"sid": "107_魏其武安侯列传.10.s9", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 9, "text": "尝召客饮，坐其兄盖侯南乡，自坐东乡，以为汉相尊，不可以兄故私桡。", "len": 32}
{"sid": "107_魏其武安侯列传.10.s10", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 10, "text": "武安由此滋骄，治宅甲诸第。", "len": 13}
{"sid": "107_魏其武安侯列传.10.s11", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 11, "text": "田园极膏腴，而市买郡县器物相属於道。", "len": 18}
{"sid": "107_魏其武安侯列传.10.s12", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 12, "text": "前堂罗锺鼓，立曲旃；後房妇女以百数。", "len": 18}
{"sid": "107_魏其武安侯列传.10.s13", "chapter": "107_魏其武安侯列传", "para": "10", "seq": 13, "text": "诸侯奉金玉狗马玩好，不可胜数。", "len": 15}
{"sid": "107_魏其武安侯列传.11.s1", "chapter": "107_魏其武安侯列传", "para": "11", "seq": 1, "text": "魏其失窦太后，益疏不用，无势，诸客稍稍自引而怠傲，唯灌将军独不失故。", "len": 34}
{"sid": "107_魏其武安侯列传.11.s2", "chapter": "107_魏其武安侯列传", "para": "11", "seq": 2, "text": "魏其日默默不得志，而独厚遇灌将军。", "len": 17}
{"sid": "107_魏其武安侯列传.12.s1", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 1, "text": "灌将军夫者，颍阴人也。", "len": 11}
{"sid": "107_魏其武安侯列传.12.s2", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 2, "text": "夫父张孟，尝为颍阴侯婴舍人，得幸，因进之至二千石，故蒙灌氏姓为灌孟。", "len": 34}
{"sid": "107_魏其武安侯列传.12.s3", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 3, "text": "吴楚反时，颍阴侯灌何为将军，属太尉，请灌孟为校尉。", "len": 25}
{"sid": "107_魏其武安侯列传.12.s4", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 4, "text": "夫以千人与父俱。", "len": 8}
{"sid": "107_魏其武安侯列传.12.s5", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 5, "text": "灌孟年老，颍阴侯彊请之，郁郁不得意，故战常陷坚，遂死吴军中。", "len": 30}
{"sid": "107_魏其武安侯列传.12.s6", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 6, "text": "军法，父子俱从军，有死事，得与丧归。", "len": 18}
{"sid": "107_魏其武安侯列传.12.s7", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 7, "text": "灌夫不肯随丧归，奋曰：“原取吴王若将军头，以报父之仇。", "len": 27}
{"sid": "107_魏其武安侯列传.12.s8", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 8, "text": "” 於是灌夫被甲持戟，募军中壮士所善原从者数十人。", "len": 25}
{"sid": "107_魏其武安侯列传.12.s9", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 9, "text": "及出壁门，莫敢前。", "len": 9}
{"sid": "107_魏其武安侯列传.12.s10", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 10, "text": "独二人及从奴十数骑驰入吴军，至吴将麾下，所杀伤数十人。", "len": 27}
{"sid": "107_魏其武安侯列传.12.s11", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 11, "text": "不得前，复驰还，走入汉壁，皆亡其奴，独与一骑归。", "len": 24}
{"sid": "107_魏其武安侯列传.12.s12", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 12, "text": "夫身中大创十馀，適有万金良药，故得无死。", "len": 20}
{"sid": "107_魏其武安侯列传.12.s13", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 13, "text": "夫创少瘳，又复请将军曰：“吾益知吴壁中曲折，请复往。", "len": 26}
{"sid": "107_魏其武安侯列传.12.s14", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 14, "text": "” 将军壮义之，恐亡夫，乃言太尉，太尉乃固止之。", "len": 24}
{"sid": "107_魏其武安侯列传.12.s15", "chapter": "107_魏其武安侯列传", "para": "12", "seq": 15, "text": "吴已破，灌夫以此名闻天下。", "len": 13}
{"sid": "107_魏其武安侯列传.13.s1", "chapter": "107_魏其武安侯列传", "para": "13", "seq": 1, "text": "颍阴侯言之上，上以夫为中郎将。", "len": 15}
{"sid": "107_魏其武安侯列传.13.s2", "chapter": "107_魏其武安侯列传", "para": "13", "seq": 2, "text": "数月，坐法去。", "len": 7}
{"sid": "107_魏其武安侯列传.13.s3", "chapter": "107_魏其武安侯列传", "para": "13", "seq": 3, "text": "後家居长安，长安中诸公莫弗称之。", "len": 16}
{"sid": "107_魏其武安侯列传.13.s4", "chapter": "107_魏其武安侯列传", "para": "13", "seq": 4, "text": "孝景时，至代相。", "len": 8}
{"sid": "107_魏其武安侯列传.13.s5", "chapter": "107_魏其武安侯列传", "para": "13", "seq": 5, "text": "孝景崩，今上初即位，以为淮阳天下交，劲兵处，故徙夫为淮阳太守。", "len": 31}
{"sid": "107_魏其武安侯列传.13.s6", "chapter": "107_魏其武安侯列传", "para": "13", "seq": 6, "text": "建元元年，入为太仆。", "len": 10}
{"sid": "107_魏其武安侯列传.13.s7", "chapter": "107_魏其武安侯列传", "para": "13", "seq": 7, "text": "二年，夫与长乐卫尉窦甫饮，轻重不得，夫醉，搏甫。", "len": 24}
{"sid": "107_魏其武安侯列传.13.s8", "chapter": "107_魏其武安侯列传", "para": "13", "seq": 8, "text": "甫，窦太后昆弟也。", "len": 9}
{"sid": "107_魏其武安侯列传.13.s9", "chapter": "107_魏其武安侯列传", "para": "13", "seq": 9, "text": "上恐太后诛夫，徙为燕相。", "len": 12}
{"sid": "107_魏其武安侯列传.13.s10", "chapter": "107_魏其武安侯列传", "para": "13", "seq": 10, "text": "数岁，坐法去官，家居长安。", "len": 13}
{"sid": "107_魏其武安侯列传.14.s1", "chapter": "107_魏其武安侯列传", "para": "14", "seq": 1, "text": "灌夫为人刚直使酒，不好面谀。", "len": 14}
{"sid": "107_魏其武安侯列传.14.s2", "chapter": "107_魏其武安侯列传", "para": "14", "seq": 2, "text": "贵戚诸有势在己之右，不欲加礼，必陵之；诸士在己之左，愈贫贱，尤益敬，与钧。", "len": 37}
{"sid": "107_魏其武安侯列传.14.s3", "chapter": "107_魏其武安侯列传", "para": "14", "seq": 3, "text": "稠人广众，荐宠下辈。", "len": 10}
{"sid": "107_魏其武安侯列传.14.s4", "chapter": "107_魏其武安侯列传", "para": "14", "seq": 4, "text": "士亦以此多之。", "len": 7}
{"sid": "107_魏其武安侯列传.15.s1", "chapter": "107_魏其武安侯列传", "para": "15", "seq": 1, "text": "夫不喜文学，好任侠，已然诺。", "len": 14}
{"sid": "107_魏其武安侯列传.15.s2", "chapter": "107_魏其武安侯列传", "para": "15", "seq": 2, "text": "诸所与交通，无非豪桀大猾。", "len": 13}
{"sid": "107_魏其武安侯列传.15.s3", "chapter": "107_魏其武安侯列传", "para": "15", "seq": 3, "text": "家累数千万，食客日数十百人。", "len": 14}
{"sid": "107_魏其武安侯列传.15.s4", "chapter": "107_魏其武安侯列传", "para": "15", "seq": 4, "text": "陂池田园，宗族宾客为权利，横於颍川。", "len": 18}
{"sid": "107_魏其武安侯列传.15.s5", "chapter": "107_魏其武安侯列传", "para": "15", "seq": 5, "text": "颍川兒乃歌之曰：“颍水清，灌氏宁；颍水浊，灌氏族。”", "len": 26}
{"sid": "107_魏其武安侯列传.16.s1", "chapter": "107_魏其武安侯列传", "para": "16", "seq": 1, "text": "灌夫家居虽富，然失势，卿相侍中宾客益衰。", "len": 20}
{"sid": "107_魏其武安侯列传.16.s2", "chapter": "107_魏其武安侯列传", "para": "16", "seq": 2, "text": "及魏其侯失势，亦欲倚灌夫引绳批根生平慕之後弃之者。", "len": 25}
{"sid": "107_魏其武安侯列传.16.s3", "chapter": "107_魏其武安侯列传", "para": "16", "seq": 3, "text": "灌夫亦倚魏其而通列侯宗室为名高。", "len": 16}
{"sid": "107_魏其武安侯列传.16.s4", "chapter": "107_魏其武安侯列传", "para": "16", "seq": 4, "text": "两人相为引重，其游如父子然。", "len": 14}
{"sid": "107_魏其武安侯列传.16.s5", "chapter": "107_魏其武安侯列传", "para": "16", "seq": 5, "text": "相得驩甚，无厌，恨相知晚也。", "len": 14}
{"sid": "107_魏其武安侯列传.17.s1", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 1, "text": "灌夫有服，过丞相。", "len": 9}
{"sid": "107_魏其武安侯列传.17.s2", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 2, "text": "丞相从容曰：“吾欲与仲孺过魏其侯，会仲孺有服。", "len": 23}
{"sid": "107_魏其武安侯列传.17.s3", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 3, "text": "” 灌夫曰：“将军乃肯幸临况魏其侯，夫安敢以服为解！", "len": 26}
{"sid": "107_魏其武安侯列传.17.s4", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 4, "text": "请语魏其侯帐具，将军旦日蚤临。", "len": 15}
{"sid": "107_魏其武安侯列传.17.s5", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 5, "text": "” 武安许诺。", "len": 7}
{"sid": "107_魏其武安侯列传.17.s6", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 6, "text": "灌夫具语魏其侯如所谓武安侯。", "len": 14}
{"sid": "107_魏其武安侯列传.17.s7", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 7, "text": "魏其与其夫人益市牛酒，夜洒埽，早帐具至旦。", "len": 21}
{"sid": "107_魏其武安侯列传.17.s8", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 8, "text": "平明，令门下候伺。", "len": 9}
{"sid": "107_魏其武安侯列传.17.s9", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 9, "text": "至日中，丞相不来。", "len": 9}
{"sid": "107_魏其武安侯列传.17.s10", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 10, "text": "魏其谓灌夫曰：“丞相岂忘之哉？", "len": 15}
{"sid": "107_魏其武安侯列传.17.s11", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 11, "text": "” 灌夫不怿，曰：“夫以服请，宜往。", "len": 18}
{"sid": "107_魏其武安侯列传.17.s12", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 12, "text": "” 乃驾，自往迎丞相。", "len": 11}
{"sid": "107_魏其武安侯列传.17.s13", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 13, "text": "丞相特前戏许灌夫，殊无意往。", "len": 14}
{"sid": "107_魏其武安侯列传.17.s14", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 14, "text": "及夫至门，丞相尚卧。", "len": 10}
{"sid": "107_魏其武安侯列传.17.s15", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 15, "text": "於是夫入见，曰：“将军昨日幸许过魏其，魏其夫妻治具，自旦至今，未敢尝食。", "len": 36}
{"sid": "107_魏其武安侯列传.17.s16", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 16, "text": "” 武安鄂谢曰：“吾昨日醉，忽忘与仲孺言。", "len": 21}
{"sid": "107_魏其武安侯列传.17.s17", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 17, "text": "” 乃驾往，又徐行，灌夫愈益怒。", "len": 16}
{"sid": "107_魏其武安侯列传.17.s18", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 18, "text": "及饮酒酣，夫起舞属丞相，丞相不起，夫从坐上语侵之。", "len": 25}
{"sid": "107_魏其武安侯列传.17.s19", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 19, "text": "魏其乃扶灌夫去，谢丞相。", "len": 12}
{"sid": "107_魏其武安侯列传.17.s20", "chapter": "107_魏其武安侯列传", "para": "17", "seq": 20, "text": "丞相卒饮至夜，极驩而去。", "len": 12}
{"sid": "107_魏其武安侯列传.18.s1", "chapter": "107_魏其武安侯列传", "para": "18", "seq": 1, "text": "丞相尝使籍福请魏其城南田。", "len": 13}
{"sid": "107_魏其武安侯列传.18.s2", "chapter": "107_魏其武安侯列传", "para": "18", "seq": 2, "text": "魏其大望曰：“老仆虽弃，将军虽贵，宁可以势夺乎！", "len": 24}
{"sid": "107_魏其武安侯列传.18.s3", "chapter": "107_魏其武安侯列传", "para": "18", "seq": 3, "text": "” 不许。", "len": 5}
{"sid": "107_魏其武安侯列传.18.s4", "chapter": "107_魏其武安侯列传", "para": "18", "seq": 4, "text": "灌夫闻，怒，骂籍福。", "len": 10}
{"sid": "107_魏其武安侯列传.18.s5", "chapter": "107_魏其武安侯列传", "para": "18", "seq": 5, "text": "籍福恶两人有郄，乃谩自好谢丞相曰：“魏其老且死，易忍，且待之。", "len": 31}
{"sid": "107_魏其武安侯列传.18.s6", "chapter": "107_魏其武安侯列传", "para": "18", "seq": 6, "text": "” 已而武安闻魏其、灌夫实怒不予田，亦怒曰：“魏其子尝杀人，蚡活之。", "len": 34}
{"sid": "107_魏其武安侯列传.18.s7", "chapter": "107_魏其武安侯列传", "para": "18", "seq": 7, "text": "蚡事魏其无所不可，何爱数顷田？", "len": 15}
{"sid": "107_魏其武安侯列传.18.s8", "chapter": "107_魏其武安侯列传", "para": "18", "seq": 8, "text": "且灌夫何与也？", "len": 7}
{"sid": "107_魏其武安侯列传.18.s9", "chapter": "107_魏其武安侯列传", "para": "18", "seq": 9, "text": "吾不敢复求田。", "len": 7}
{"sid": "107_魏其武安侯列传.18.s10", "chapter": "107_魏其武安侯列传", "para": "18", "seq": 10, "text": "” 武安由此大怨灌夫、魏其。", "len": 14}
{"sid": "107_魏其武安侯列传.19.s1", "chapter": "107_魏其武安侯列传", "para": "19", "seq": 1, "text": "元光四年春，丞相言灌夫家在颍川，横甚，民苦之。", "len": 23}
{"sid": "107_魏其武安侯列传.19.s2", "chapter": "107_魏其武安侯列传", "para": "19", "seq": 2, "text": "请案。", "len": 3}
{"sid": "107_魏其武安侯列传.19.s3", "chapter": "107_魏其武安侯列传", "para": "19", "seq": 3, "text": "上曰：“此丞相事，何请。", "len": 12}
{"sid": "107_魏其武安侯列传.19.s4", "chapter": "107_魏其武安侯列传", "para": "19", "seq": 4, "text": "” 灌夫亦持丞相阴事，为奸利，受淮南王金与语言。", "len": 24}
{"sid": "107_魏其武安侯列传.19.s5", "chapter": "107_魏其武安侯列传", "para": "19", "seq": 5, "text": "宾客居间，遂止，俱解。", "len": 11}
{"sid": "107_魏其武安侯列传.20.s1", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 1, "text": "夏，丞相取燕王女为夫人，有太后诏，召列侯宗室皆往贺。", "len": 26}
{"sid": "107_魏其武安侯列传.20.s2", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 2, "text": "魏其侯过灌夫，欲与俱。", "len": 11}
{"sid": "107_魏其武安侯列传.20.s3", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 3, "text": "夫谢曰：“夫数以酒失得过丞相，丞相今者又与夫有郄。", "len": 25}
{"sid": "107_魏其武安侯列传.20.s4", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 4, "text": "” 魏其曰：“事已解。", "len": 11}
{"sid": "107_魏其武安侯列传.20.s5", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 5, "text": "” 彊与俱。", "len": 6}
{"sid": "107_魏其武安侯列传.20.s6", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 6, "text": "饮酒酣，武安起为寿，坐皆避席伏。", "len": 16}
{"sid": "107_魏其武安侯列传.20.s7", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 7, "text": "已魏其侯为寿，独故人避席耳，馀半膝席。", "len": 19}
{"sid": "107_魏其武安侯列传.20.s8", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 8, "text": "灌夫不悦。", "len": 5}
{"sid": "107_魏其武安侯列传.20.s9", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 9, "text": "起行酒，至武安，武安膝席曰：“不能满觞。", "len": 20}
{"sid": "107_魏其武安侯列传.20.s10", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 10, "text": "” 夫怒，因嘻笑曰：“将军贵人也，属之！", "len": 20}
{"sid": "107_魏其武安侯列传.20.s11", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 11, "text": "” 时武安不肯。", "len": 8}
{"sid": "107_魏其武安侯列传.20.s12", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 12, "text": "行酒次至临汝侯，临汝侯方与程不识耳语，又不避席。", "len": 24}
{"sid": "107_魏其武安侯列传.20.s13", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 13, "text": "夫无所发怒，乃骂临汝侯曰：“生平毁程不识不直一钱，今日长者为寿，乃效女兒呫嗫耳语！", "len": 41}
{"sid": "107_魏其武安侯列传.20.s14", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 14, "text": "” 武安谓灌夫曰：“程李俱东西宫卫尉，今众辱程将军，仲孺独不为李将军地乎？", "len": 37}
{"sid": "107_魏其武安侯列传.20.s15", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 15, "text": "” 灌夫曰：“今日斩头陷匈，何知程李乎！", "len": 20}
{"sid": "107_魏其武安侯列传.20.s16", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 16, "text": "” 坐乃起更衣，稍稍去。", "len": 12}
{"sid": "107_魏其武安侯列传.20.s17", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 17, "text": "魏其侯去，麾灌夫出。", "len": 10}
{"sid": "107_魏其武安侯列传.20.s18", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 18, "text": "武安遂怒曰：“此吾骄灌夫罪。", "len": 14}
{"sid": "107_魏其武安侯列传.20.s19", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 19, "text": "” 乃令骑留灌夫。", "len": 9}
{"sid": "107_魏其武安侯列传.20.s20", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 20, "text": "灌夫欲出不得。", "len": 7}
{"sid": "107_魏其武安侯列传.20.s21", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 21, "text": "籍福起为谢，案灌夫项令谢。", "len": 13}
{"sid": "107_魏其武安侯列传.20.s22", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 22, "text": "夫愈怒，不肯谢。", "len": 8}
{"sid": "107_魏其武安侯列传.20.s23", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 23, "text": "武安乃麾骑缚夫置传舍，召长史曰：“今日召宗室，有诏。", "len": 26}
{"sid": "107_魏其武安侯列传.20.s24", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 24, "text": "” 劾灌夫骂坐不敬，系居室。", "len": 14}
{"sid": "107_魏其武安侯列传.20.s25", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 25, "text": "遂按其前事，遣吏分曹逐捕诸灌氏支属，皆得弃市罪。", "len": 24}
{"sid": "107_魏其武安侯列传.20.s26", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 26, "text": "魏其侯大媿，为资使宾客请，莫能解。", "len": 17}
{"sid": "107_魏其武安侯列传.20.s27", "chapter": "107_魏其武安侯列传", "para": "20", "seq": 27, "text": "武安吏皆为耳目，诸灌氏皆亡匿，夫系，遂不得告言武安阴事。", "len": 28}
{"sid": "107_魏其武安侯列传.21.s1", "chapter": "107_魏其武安侯列传", "para": "21", "seq": 1, "text": "魏其锐身为救灌夫。", "len": 9}
{"sid": "107_魏其武安侯列传.21.s2", "chapter": "107_魏其武安侯列传", "para": "21", "seq": 2, "text": "夫人谏魏其曰：“灌将军得罪丞相，与太后家忤，宁可救邪？", "len": 27}
{"sid": "107_魏其武安侯列传.21.s3", "chapter": "107_魏其武安侯列传", "para": "21", "seq": 3, "text": "” 魏其侯曰：“侯自我得之，自我捐之，无所恨。", "len": 23}
{"sid": "107_魏其武安侯列传.21.s4", "chapter": "107_魏其武安侯列传", "para": "21", "seq": 4, "text": "且终不令灌仲孺独死，婴独生。", "len": 14}
{"sid": "107_魏其武安侯列传.21.s5", "chapter": "107_魏其武安侯列传", "para": "21", "seq": 5, "text": "” 乃匿其家，窃出上书。", "len": 12}
{"sid": "107_魏其武安侯列传.21.s6", "chapter": "107_魏其武安侯列传", "para": "21", "seq": 6, "text": "立召入，具言灌夫醉饱事，不足诛。", "len": 16}
{"sid": "107_魏其武安侯列传.21.s7", "chapter": "107_魏其武安侯列传", "para": "21", "seq": 7, "text": "上然之，赐魏其食，曰：“东朝廷辩之。”", "len": 19}
{"sid": "107_魏其武安侯列传.22.s1", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 1, "text": "魏其之东朝，盛推灌夫之善，言其醉饱得过，乃丞相以他事诬罪之。", "len": 30}
{"sid": "107_魏其武安侯列传.22.s2", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 2, "text": "武安又盛毁灌夫所为横恣，罪逆不道。", "len": 17}
{"sid": "107_魏其武安侯列传.22.s3", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 3, "text": "魏其度不可柰何，因言丞相短。", "len": 14}
{"sid": "107_魏其武安侯列传.22.s4", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 4, "text": "武安曰：“天下幸而安乐无事，蚡得为肺腑，所好音乐狗马田宅。", "len": 29}
{"sid": "107_魏其武安侯列传.22.s5", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 5, "text": "蚡所爱倡优巧匠之属，不如魏其、灌夫日夜招聚天下豪桀壮士与论议，腹诽而心谤|腹诽心谤，不仰视天而俯画地，辟倪两宫间，幸天下有变，而欲有大功。", "len": 69}
{"sid": "107_魏其武安侯列传.22.s6", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 6, "text": "臣乃不知魏其等所为。", "len": 10}
{"sid": "107_魏其武安侯列传.22.s7", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 7, "text": "” 於是上问朝臣：“两人孰是？", "len": 15}
{"sid": "107_魏其武安侯列传.22.s8", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 8, "text": "” 御史大夫韩安国曰：“魏其言灌夫父死事，身荷戟驰入不测之吴军，身被数十创，名冠三军，此天下壮士，非有大恶，争杯酒，不足引他过以诛也。", "len": 67}
{"sid": "107_魏其武安侯列传.22.s9", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 9, "text": "魏其言是也。", "len": 6}
{"sid": "107_魏其武安侯列传.22.s10", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 10, "text": "丞相亦言灌夫通奸猾，侵细民，家累巨万，横恣颍川，凌轹宗室，侵犯骨肉，此所谓’枝大於本，胫大於股，不折必披’，丞相言亦是。", "len": 60}
{"sid": "107_魏其武安侯列传.22.s11", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 11, "text": "唯明主裁之。", "len": 6}
{"sid": "107_魏其武安侯列传.22.s12", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 12, "text": "” 主爵都尉汲黯是魏其。", "len": 12}
{"sid": "107_魏其武安侯列传.22.s13", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 13, "text": "内史郑当时是魏其，後不敢坚对。", "len": 15}
{"sid": "107_魏其武安侯列传.22.s14", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 14, "text": "馀皆莫敢对。", "len": 6}
{"sid": "107_魏其武安侯列传.22.s15", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 15, "text": "上怒内史曰：“公平生数言魏其、武安长短，今日廷论，局趣效辕下驹，吾并斩若属矣。", "len": 39}
{"sid": "107_魏其武安侯列传.22.s16", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 16, "text": "” 即罢起入，上食太后。", "len": 12}
{"sid": "107_魏其武安侯列传.22.s17", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 17, "text": "太后亦已使人候伺，具以告太后。", "len": 15}
{"sid": "107_魏其武安侯列传.22.s18", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 18, "text": "太后怒，不食，曰：“今我在也，而人皆藉吾弟，令我百岁後，皆鱼肉之矣。", "len": 34}
{"sid": "107_魏其武安侯列传.22.s19", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 19, "text": "且帝宁能为石人邪！", "len": 9}
{"sid": "107_魏其武安侯列传.22.s20", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 20, "text": "此特帝在，即录录，设百岁後，是属宁有可信者乎？", "len": 23}
{"sid": "107_魏其武安侯列传.22.s21", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 21, "text": "” 上谢曰：“俱宗室外家，故廷辩之。", "len": 18}
{"sid": "107_魏其武安侯列传.22.s22", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 22, "text": "不然，此一狱吏所决耳。", "len": 11}
{"sid": "107_魏其武安侯列传.22.s23", "chapter": "107_魏其武安侯列传", "para": "22", "seq": 23, "text": "” 是时郎中令石建为上别言两人事。", "len": 17}
{"sid": "107_魏其武安侯列传.23.s1", "chapter": "107_魏其武安侯列传", "para": "23", "seq": 1, "text": "武安已罢朝，出止车门，召韩御史大夫载，怒曰：“与长孺共一老秃翁，何为首鼠两端？", "len": 39}
{"sid": "107_魏其武安侯列传.23.s2", "chapter": "107_魏其武安侯列传", "para": "23", "seq": 2, "text": "” 韩御史良久谓丞相曰：“君何不自喜？", "len": 19}
{"sid": "107_魏其武安侯列传.23.s3", "chapter": "107_魏其武安侯列传", "para": "23", "seq": 3, "text": "夫魏其毁君，君当免冠解印绶归，曰‘臣以肺腑幸得待罪，固非其任，魏其言皆是’。", "len": 38}
{"sid": "107_魏其武安侯列传.23.s4", "chapter": "107_魏其武安侯列传", "para": "23", "seq": 4, "text": "如此，上必多君有让，不废君。", "len": 14}
{"sid": "107_魏其武安侯列传.23.s5", "chapter": "107_魏其武安侯列传", "para": "23", "seq": 5, "text": "魏其必内愧，杜门齰舌自杀。", "len": 13}
{"sid": "107_魏其武安侯列传.23.s6", "chapter": "107_魏其武安侯列传", "para": "23", "seq": 6, "text": "今人毁君，君亦毁人，譬如贾竖女子争言，何其无大体也！", "len": 26}
{"sid": "107_魏其武安侯列传.23.s7", "chapter": "107_魏其武安侯列传", "para": "23", "seq": 7, "text": "” 武安谢罪曰：“争时急，不知出此。”", "len": 19}
{"sid": "107_魏其武安侯列传.24.s1", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 1, "text": "於是上使御史簿责魏其所言灌夫，颇不雠，欺谩。", "len": 22}
{"sid": "107_魏其武安侯列传.24.s2", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 2, "text": "劾系都司空。", "len": 6}
{"sid": "107_魏其武安侯列传.24.s3", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 3, "text": "孝景时，魏其常受遗诏，曰“事有不便，以便宜论上”。", "len": 25}
{"sid": "107_魏其武安侯列传.24.s4", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 4, "text": "及系，灌夫罪至族，事日急，诸公莫敢复明言於上。", "len": 23}
{"sid": "107_魏其武安侯列传.24.s5", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 5, "text": "魏其乃使昆弟子上书言之，幸得复召见。", "len": 18}
{"sid": "107_魏其武安侯列传.24.s6", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 6, "text": "书奏上，而案尚书大行无遗诏。", "len": 14}
{"sid": "107_魏其武安侯列传.24.s7", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 7, "text": "诏书独藏魏其家，家丞封。", "len": 12}
{"sid": "107_魏其武安侯列传.24.s8", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 8, "text": "乃劾魏其矫先帝诏，罪当弃市。", "len": 14}
{"sid": "107_魏其武安侯列传.24.s9", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 9, "text": "五年十月，悉论灌夫及家属。", "len": 13}
{"sid": "107_魏其武安侯列传.24.s10", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 10, "text": "魏其良久乃闻，闻即恚，病痱，不食欲死。", "len": 19}
{"sid": "107_魏其武安侯列传.24.s11", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 11, "text": "或闻上无意杀魏其，魏其复食，治病，议定不死矣。", "len": 23}
{"sid": "107_魏其武安侯列传.24.s12", "chapter": "107_魏其武安侯列传", "para": "24", "seq": 12, "text": "乃有蜚语为恶言闻上，故以十二月晦论弃市渭城。", "len": 22}
{"sid": "107_魏其武安侯列传.25.s1", "chapter": "107_魏其武安侯列传", "para": "25", "seq": 1, "text": "其春，武安侯病，专呼服谢罪。", "len": 14}
{"sid": "107_魏其武安侯列传.25.s2", "chapter": "107_魏其武安侯列传", "para": "25", "seq": 2, "text": "使巫视鬼者视之，见魏其、灌夫共守，欲杀之。", "len": 21}
{"sid": "107_魏其武安侯列传.25.s3", "chapter": "107_魏其武安侯列传", "para": "25", "seq": 3, "text": "竟死。", "len": 3}
{"sid": "107_魏其武安侯列传.25.s4", "chapter": "107_魏其武安侯列传", "para": "25", "seq": 4, "text": "子恬嗣。", "len": 4}
{"sid": "107_魏其武安侯列传.25.s5", "chapter": "107_魏其武安侯列传", "para": "25", "seq": 5, "text": "元朔三年，武安侯坐衣襜褕入宫，不敬。", "len": 18}
{"sid": "107_魏其武安侯列传.26.s1", "chapter": "107_魏其武安侯列传", "para": "26", "seq": 1, "text": "淮南王安谋反觉，治。", "len": 10}
{"sid": "107_魏其武安侯列传.26.s2", "chapter": "107_魏其武安侯列传", "para": "26", "seq": 2, "text": "王前朝，武安侯为太尉，时迎王至霸上，谓王曰：“上未有太子，大王最贤，高祖孙，即宫车晏驾，非大王立当谁哉！", "len": 52}
{"sid": "107_魏其武安侯列传.26.s3", "chapter": "107_魏其武安侯列传", "para": "26", "seq": 3, "text": "” 淮南王大喜，厚遗金财物。", "len": 14}
{"sid": "107_魏其武安侯列传.26.s4", "chapter": "107_魏其武安侯列传", "para": "26", "seq": 4, "text": "上自魏其时不直武安，特为太后故耳。", "len": 17}
{"sid": "107_魏其武安侯列传.26.s5", "chapter": "107_魏其武安侯列传", "para": "26", "seq": 5, "text": "及闻淮南王金事，上曰：“使武安侯在者，族矣。", "len": 22}
{"sid": "107_魏其武安侯列传.26.s6", "chapter": "107_魏其武安侯列传", "para": "26", "seq": 6, "text": "” ::: 太史公曰", "len": 10}
{"sid": "107_魏其武安侯列传.27.s1", "chapter": "107_魏其武安侯列传", "para": "27", "seq": 1, "text": "太史公曰：魏其、武安皆以外戚重，灌夫用一时决筴而名显。", "len": 27}
{"sid": "107_魏其武安侯列传.27.s2", "chapter": "107_魏其武安侯列传", "para": "27", "seq": 2, "text": "魏其之举以吴楚，武安之贵在日月之际。", "len": 18}
{"sid": "107_魏其武安侯列传.27.s3", "chapter": "107_魏其武安侯列传", "para": "27", "seq": 3, "text": "然魏其诚不知时变，灌夫无术而不逊，两人相翼，乃成祸乱。", "len": 27}
{"sid": "107_魏其武安侯列传.27.s4", "chapter": "107_魏其武安侯列传", "para": "27", "seq": 4, "text": "武安负贵而好权，杯酒责望，陷彼两贤。", "len": 18}
{"sid": "107_魏其武安侯列传.27.s5", "chapter": "107_魏其武安侯列传", "para": "27", "seq": 5, "text": "呜呼哀哉！", "len": 5}
{"sid": "107_魏其武安侯列传.27.s6", "chapter": "107_魏其武安侯列传", "para": "27", "seq": 6, "text": "迁怒及人，命亦不延。", "len": 10}
{"sid": "107_魏其武安侯列传.27.s7", "chapter": "107_魏其武安侯列传", "para": "27", "seq": 7, "text": "众庶不载，竟被恶言。", "len": 10}
{"sid": "107_魏其武安侯列传.27.s8", "chapter": "107_魏其武安侯列传", "para": "27", "seq": 8, "text": "呜呼哀哉！", "len": 5}
{"sid": "107_魏其武安侯列传.27.s9", "chapter": "107_魏其武安侯列传", "para": "27", "seq": 9, "text": "祸所从来矣！", "len": 6}
{"sid": "107_魏其武安侯列传.27.s10", "chapter": "107_魏其武安侯列传", "para": "27", "seq": 10, "text": "::: ::: 赞", "len": 9}
{"sid": "107_魏其武安侯列传.28.s1", "chapter": "107_魏其武安侯列传", "para": "28", "seq": 1, "text": "窦婴、田蚡，势利相雄。", "len": 11}
{"sid": "107_魏其武安侯列传.28.s2", "chapter": "107_魏其武安侯列传", "para": "28", "seq": 2, "text": "咸倚外戚，或恃军功。", "len": 10}
{"sid": "107_魏其武安侯列传.28.s3", "chapter": "107_魏其武安侯列传", "para": "28", "seq": 3, "text": "灌夫自喜，引重其中。", "len": 10}
{"sid": "107_魏其武安侯列传.28.s4", "chapter": "107_魏其武安侯列传", "para": "28", "seq": 4, "text": "意气杯酒，辟睨两宫。", "len": 10}
{"sid": "107_魏其武安侯列传.28.s5", "chapter": "107_魏其武安侯列传", "para": "28", "seq": 5, "text": "事竟不直，冤哉二公！", "len": 10}
