{"sid": "009_吕太后本纪.1.1.s1", "chapter": "009_吕太后本纪", "para": "1.1", "seq": 1, "text": "吕太后者，高祖微时妃也，生孝惠帝、女鲁元太后。", "len": 23}
{"sid": "009_吕太后本纪.1.2.s1", "chapter": "009_吕太后本纪", "para": "1.2", "seq": 1, "text": "及高祖为汉王，得定陶戚姬，爱幸，生赵隐王如意。", "len": 23}
{"sid": "009_吕太后本纪.2.1.s1", "chapter": "009_吕太后本纪", "para": "2.1", "seq": 1, "text": "孝惠为人仁弱，高祖以为不类我，常欲废太子，立戚姬子如意，如意类我。", "len": 33}
{"sid": "009_吕太后本纪.2.2.s1", "chapter": "009_吕太后本纪", "para": "2.2", "seq": 1, "text": "戚姬幸，常从上之关东，日夜啼泣，欲立其子代太子。", "len": 24}
{"sid": "009_吕太后本纪.2.3.s1", "chapter": "009_吕太后本纪", "para": "2.3", "seq": 1, "text": "吕后年长，常留守，希见上，益疏。", "len": 16}
{"sid": "009_吕太后本纪.2.4.s1", "chapter": "009_吕太后本纪", "para": "2.4", "seq": 1, "text": "如意立为赵王後，几代太子者数矣，赖大臣争之，及留侯策，太子得毋废。", "len": 33}
{"sid": "009_吕太后本纪.3.1.s1", "chapter": "009_吕太后本纪", "para": "3.1", "seq": 1, "text": "吕后为人刚毅，佐高祖定天下，所诛大臣多吕后力。", "len": 23}
{"sid": "009_吕太后本纪.3.2.s1", "chapter": "009_吕太后本纪", "para": "3.2", "seq": 1, "text": "吕后兄二人，皆为将。", "len": 10}
{"sid": "009_吕太后本纪.3.3.s1", "chapter": "009_吕太后本纪", "para": "3.3", "seq": 1, "text": "长兄周吕侯死事，封其子吕台为郦侯，子产为交侯；", "len": 23}
{"sid": "009_吕太后本纪.3.4.s1", "chapter": "009_吕太后本纪", "para": "3.4", "seq": 1, "text": "次兄吕释之为建成侯。", "len": 10}
{"sid": "009_吕太后本纪.4.1.s1", "chapter": "009_吕太后本纪", "para": "4.1", "seq": 1, "text": "高祖十二年四月甲辰，崩长乐宫，太子袭号为帝。", "len": 22}
{"sid": "009_吕太后本纪.4.2.s1", "chapter": "009_吕太后本纪", "para": "4.2", "seq": 1, "text": "是时高祖八子：长男肥，孝惠兄也，异母，肥为齐王；", "len": 24}
{"sid": "009_吕太后本纪.4.3.s1", "chapter": "009_吕太后本纪", "para": "4.3", "seq": 1, "text": "馀皆孝惠弟，戚姬子如意为赵王，薄夫人子恆为代王，诸姬子子恢为梁王，子友为淮阳王，子长为淮南王，子建为燕王。", "len": 53}
{"sid": "009_吕太后本纪.4.4.s1", "chapter": "009_吕太后本纪", "para": "4.4", "seq": 1, "text": "高祖弟交为楚王，兄子濞为吴王。", "len": 15}
{"sid": "009_吕太后本纪.4.5.s1", "chapter": "009_吕太后本纪", "para": "4.5", "seq": 1, "text": "非刘氏功臣番君吴芮子臣为长沙王。", "len": 16}
{"sid": "009_吕太后本纪.5.1.s1", "chapter": "009_吕太后本纪", "para": "5.1", "seq": 1, "text": "吕后最怨戚夫人及其子赵王，乃令永巷囚戚夫人，而召赵王。", "len": 27}
{"sid": "009_吕太后本纪.5.2.s1", "chapter": "009_吕太后本纪", "para": "5.2", "seq": 1, "text": "使者三反，赵相建平侯周昌谓使者曰： “高帝属臣赵王，赵王年少。", "len": 31}
{"sid": "009_吕太后本纪.5.2.s2", "chapter": "009_吕太后本纪", "para": "5.2", "seq": 2, "text": "窃闻太后怨戚夫人，欲召赵王并诛之，臣不敢遣王。", "len": 23}
{"sid": "009_吕太后本纪.5.2.s3", "chapter": "009_吕太后本纪", "para": "5.2", "seq": 3, "text": "王且亦病，不能奉诏。”", "len": 11}
{"sid": "009_吕太后本纪.5.3.s1", "chapter": "009_吕太后本纪", "para": "5.3", "seq": 1, "text": "吕后大怒，乃使人召赵相。", "len": 12}
{"sid": "009_吕太后本纪.5.4.s1", "chapter": "009_吕太后本纪", "para": "5.4", "seq": 1, "text": "赵相徵至长安，乃使人复召赵王。", "len": 15}
{"sid": "009_吕太后本纪.6.1.s1", "chapter": "009_吕太后本纪", "para": "6.1", "seq": 1, "text": "王来，未到。", "len": 6}
{"sid": "009_吕太后本纪.6.1.s2", "chapter": "009_吕太后本纪", "para": "6.1", "seq": 2, "text": "孝惠帝慈仁，知太后怒，自迎赵王霸上，与入宫，自挟与赵王起居饮食。", "len": 32}
{"sid": "009_吕太后本纪.6.2.s1", "chapter": "009_吕太后本纪", "para": "6.2", "seq": 1, "text": "太后欲杀之，不得间。", "len": 10}
{"sid": "009_吕太后本纪.6.3.s1", "chapter": "009_吕太后本纪", "para": "6.3", "seq": 1, "text": "孝惠元年十二月，帝晨出射。", "len": 13}
{"sid": "009_吕太后本纪.6.3.s2", "chapter": "009_吕太后本纪", "para": "6.3", "seq": 2, "text": "赵王少，不能蚤起。", "len": 9}
{"sid": "009_吕太后本纪.6.4.s1", "chapter": "009_吕太后本纪", "para": "6.4", "seq": 1, "text": "太后闻其独居，使人持酖饮之。", "len": 14}
{"sid": "009_吕太后本纪.6.4.s2", "chapter": "009_吕太后本纪", "para": "6.4", "seq": 2, "text": "犁明，孝惠还，赵王已死。", "len": 12}
{"sid": "009_吕太后本纪.6.5.s1", "chapter": "009_吕太后本纪", "para": "6.5", "seq": 1, "text": "於是乃徙淮阳王友为赵王。", "len": 12}
{"sid": "009_吕太后本纪.7.1.s1", "chapter": "009_吕太后本纪", "para": "7.1", "seq": 1, "text": "夏，诏赐郦侯父追谥为令武侯。", "len": 14}
{"sid": "009_吕太后本纪.7.2.s1", "chapter": "009_吕太后本纪", "para": "7.2", "seq": 1, "text": "太后遂断戚夫人手足，去眼，煇耳，饮瘖药，使居厕中，命曰“人彘”。", "len": 32}
{"sid": "009_吕太后本纪.7.3.s1", "chapter": "009_吕太后本纪", "para": "7.3", "seq": 1, "text": "居数日，乃召孝惠帝观人彘。", "len": 13}
{"sid": "009_吕太后本纪.7.4.s1", "chapter": "009_吕太后本纪", "para": "7.4", "seq": 1, "text": "孝惠见，问，乃知其戚夫人，乃大哭，因病，岁馀不能起。", "len": 26}
{"sid": "009_吕太后本纪.7.5.s1", "chapter": "009_吕太后本纪", "para": "7.5", "seq": 1, "text": "使人请太后曰： “此非人所为。", "len": 15}
{"sid": "009_吕太后本纪.7.5.s2", "chapter": "009_吕太后本纪", "para": "7.5", "seq": 2, "text": "臣为太后子，终不能治天下。”", "len": 14}
{"sid": "009_吕太后本纪.7.6.s1", "chapter": "009_吕太后本纪", "para": "7.6", "seq": 1, "text": "孝惠以此日饮为淫乐，不听政，故有病也。", "len": 19}
{"sid": "009_吕太后本纪.8.1.s1", "chapter": "009_吕太后本纪", "para": "8.1", "seq": 1, "text": "二年，楚元王、齐悼惠王皆来朝。", "len": 15}
{"sid": "009_吕太后本纪.8.2.s1", "chapter": "009_吕太后本纪", "para": "8.2", "seq": 1, "text": "十月，孝惠与齐王燕饮太后前，孝惠以为齐王兄，置上坐，如家人之礼。", "len": 32}
{"sid": "009_吕太后本纪.8.3.s1", "chapter": "009_吕太后本纪", "para": "8.3", "seq": 1, "text": "太后怒，乃令酌两卮酖，置前，令齐王起为寿。", "len": 21}
{"sid": "009_吕太后本纪.8.4.s1", "chapter": "009_吕太后本纪", "para": "8.4", "seq": 1, "text": "齐王起，孝惠亦起，取卮欲俱为寿。", "len": 16}
{"sid": "009_吕太后本纪.8.5.s1", "chapter": "009_吕太后本纪", "para": "8.5", "seq": 1, "text": "太后乃恐，自起泛孝惠卮。", "len": 12}
{"sid": "009_吕太后本纪.8.6.s1", "chapter": "009_吕太后本纪", "para": "8.6", "seq": 1, "text": "齐王怪之，因不敢饮，详醉去。", "len": 14}
{"sid": "009_吕太后本纪.9.1.s1", "chapter": "009_吕太后本纪", "para": "9.1", "seq": 1, "text": "问，知其酖，齐王恐，自以为不得脱长安，忧。", "len": 21}
{"sid": "009_吕太后本纪.9.2.s1", "chapter": "009_吕太后本纪", "para": "9.2", "seq": 1, "text": "齐内史士说王曰： “太后独有孝惠与鲁元公主。", "len": 22}
{"sid": "009_吕太后本纪.9.2.s2", "chapter": "009_吕太后本纪", "para": "9.2", "seq": 2, "text": "今王有七十馀城，而公主乃食数城。", "len": 16}
{"sid": "009_吕太后本纪.9.2.s3", "chapter": "009_吕太后本纪", "para": "9.2", "seq": 3, "text": "王诚以一郡上太后，为公主汤沐邑，太后必喜，王必无忧。”", "len": 27}
{"sid": "009_吕太后本纪.9.3.s1", "chapter": "009_吕太后本纪", "para": "9.3", "seq": 1, "text": "於是齐王乃上城阳之郡，尊公主为王太后。", "len": 19}
{"sid": "009_吕太后本纪.9.4.s1", "chapter": "009_吕太后本纪", "para": "9.4", "seq": 1, "text": "吕后喜，许之。", "len": 7}
{"sid": "009_吕太后本纪.9.4.s2", "chapter": "009_吕太后本纪", "para": "9.4", "seq": 2, "text": "乃置酒齐邸，乐饮，罢，归齐王。", "len": 15}
{"sid": "009_吕太后本纪.10.1.s1", "chapter": "009_吕太后本纪", "para": "10.1", "seq": 1, "text": "三年，方筑长安城，四年就半，五年六年城就。", "len": 21}
{"sid": "009_吕太后本纪.10.2.s1", "chapter": "009_吕太后本纪", "para": "10.2", "seq": 1, "text": "诸侯来会。", "len": 5}
{"sid": "009_吕太后本纪.10.2.s2", "chapter": "009_吕太后本纪", "para": "10.2", "seq": 2, "text": "十月朝贺。", "len": 5}
{"sid": "009_吕太后本纪.11.1.s1", "chapter": "009_吕太后本纪", "para": "11.1", "seq": 1, "text": "七年秋八月戊寅，孝惠帝崩。", "len": 13}
{"sid": "009_吕太后本纪.11.2.s1", "chapter": "009_吕太后本纪", "para": "11.2", "seq": 1, "text": "发丧，太后哭，泣不下。", "len": 11}
{"sid": "009_吕太后本纪.11.3.s1", "chapter": "009_吕太后本纪", "para": "11.3", "seq": 1, "text": "留侯子张辟彊为侍中，年十五，谓丞相曰： “太后独有孝惠，今崩，哭不悲，君知其解乎？”", "len": 42}
{"sid": "009_吕太后本纪.11.4.s1", "chapter": "009_吕太后本纪", "para": "11.4", "seq": 1, "text": "丞相曰： “何解？”", "len": 10}
{"sid": "009_吕太后本纪.11.5.s1", "chapter": "009_吕太后本纪", "para": "11.5", "seq": 1, "text": "辟彊曰： “帝毋壮子，太后畏君等。", "len": 17}
{"sid": "009_吕太后本纪.11.5.s2", "chapter": "009_吕太后本纪", "para": "11.5", "seq": 2, "text": "君今请拜吕台、吕产、吕禄为将，将兵居南北军，及诸吕皆入宫，居中用事，如此则太后心安，君等幸得脱祸矣。”", "len": 51}
{"sid": "009_吕太后本纪.11.6.s1", "chapter": "009_吕太后本纪", "para": "11.6", "seq": 1, "text": "丞相乃如辟彊计。", "len": 8}
{"sid": "009_吕太后本纪.11.6.s2", "chapter": "009_吕太后本纪", "para": "11.6", "seq": 2, "text": "太后说，其哭乃哀。", "len": 9}
{"sid": "009_吕太后本纪.11.7.s1", "chapter": "009_吕太后本纪", "para": "11.7", "seq": 1, "text": "吕氏权由此起。", "len": 7}
{"sid": "009_吕太后本纪.11.7.s2", "chapter": "009_吕太后本纪", "para": "11.7", "seq": 2, "text": "乃大赦天下。", "len": 6}
{"sid": "009_吕太后本纪.11.8.s1", "chapter": "009_吕太后本纪", "para": "11.8", "seq": 1, "text": "九月辛丑，葬。", "len": 7}
{"sid": "009_吕太后本纪.11.8.s2", "chapter": "009_吕太后本纪", "para": "11.8", "seq": 2, "text": "太子即位为帝，谒高庙。", "len": 11}
{"sid": "009_吕太后本纪.11.9.s1", "chapter": "009_吕太后本纪", "para": "11.9", "seq": 1, "text": "元年，号令一出太后。", "len": 10}
{"sid": "009_吕太后本纪.12.1.s1", "chapter": "009_吕太后本纪", "para": "12.1", "seq": 1, "text": "太后称制，议欲立诸吕为王，问右丞相王陵。", "len": 20}
{"sid": "009_吕太后本纪.12.2.s1", "chapter": "009_吕太后本纪", "para": "12.2", "seq": 1, "text": "王陵曰： “高帝刑白马盟曰‘非刘氏而王，天下共击之’。", "len": 27}
{"sid": "009_吕太后本纪.12.2.s2", "chapter": "009_吕太后本纪", "para": "12.2", "seq": 2, "text": "今王吕氏，非约也。”", "len": 10}
{"sid": "009_吕太后本纪.12.3.s1", "chapter": "009_吕太后本纪", "para": "12.3", "seq": 1, "text": "太后不说。", "len": 5}
{"sid": "009_吕太后本纪.12.3.s2", "chapter": "009_吕太后本纪", "para": "12.3", "seq": 2, "text": "问左丞相陈平、绛侯周勃。", "len": 12}
{"sid": "009_吕太后本纪.12.4.s1", "chapter": "009_吕太后本纪", "para": "12.4", "seq": 1, "text": "勃等对曰： “高帝定天下，王子弟，今太后称制，王昆弟诸吕，无所不可。”", "len": 35}
{"sid": "009_吕太后本纪.12.5.s1", "chapter": "009_吕太后本纪", "para": "12.5", "seq": 1, "text": "太后喜，罢朝。", "len": 7}
{"sid": "009_吕太后本纪.13.1.s1", "chapter": "009_吕太后本纪", "para": "13.1", "seq": 1, "text": "王陵让陈平、绛侯曰： “始与高帝喋血盟，诸君不在邪？", "len": 26}
{"sid": "009_吕太后本纪.13.1.s2", "chapter": "009_吕太后本纪", "para": "13.1", "seq": 2, "text": "今高帝崩，太后女主，欲王吕氏，诸君从欲阿意背约，何面目见高帝地下？”", "len": 34}
{"sid": "009_吕太后本纪.13.2.s1", "chapter": "009_吕太后本纪", "para": "13.2", "seq": 1, "text": "陈平、绛侯曰： “於今面折廷争，臣不如君；夫全社稷，定刘氏之後，君亦不如臣。”", "len": 39}
{"sid": "009_吕太后本纪.13.3.s1", "chapter": "009_吕太后本纪", "para": "13.3", "seq": 1, "text": "王陵无以应之。", "len": 7}
{"sid": "009_吕太后本纪.14.1.s1", "chapter": "009_吕太后本纪", "para": "14.1", "seq": 1, "text": "十一月，太后欲废王陵，乃拜为帝太傅，夺之相权。", "len": 23}
{"sid": "009_吕太后本纪.14.2.s1", "chapter": "009_吕太后本纪", "para": "14.2", "seq": 1, "text": "王陵遂病免归。", "len": 7}
{"sid": "009_吕太后本纪.14.3.s1", "chapter": "009_吕太后本纪", "para": "14.3", "seq": 1, "text": "乃以左丞相平为右丞相，以辟阳侯审食其为左丞相。", "len": 23}
{"sid": "009_吕太后本纪.14.4.s1", "chapter": "009_吕太后本纪", "para": "14.4", "seq": 1, "text": "左丞相不治事，令监宫中，如郎中令。", "len": 17}
{"sid": "009_吕太后本纪.14.5.s1", "chapter": "009_吕太后本纪", "para": "14.5", "seq": 1, "text": "食其故得幸太后，常用事，公卿皆因而决事。", "len": 20}
{"sid": "009_吕太后本纪.14.6.s1", "chapter": "009_吕太后本纪", "para": "14.6", "seq": 1, "text": "乃追尊郦侯父为悼武王，欲以王诸吕为渐。", "len": 19}
{"sid": "009_吕太后本纪.15.1.s1", "chapter": "009_吕太后本纪", "para": "15.1", "seq": 1, "text": "四月，太后欲侯诸吕，乃先封高祖之功臣郎中令无择为博城侯。", "len": 28}
{"sid": "009_吕太后本纪.15.2.s1", "chapter": "009_吕太后本纪", "para": "15.2", "seq": 1, "text": "鲁元公主薨，赐谥为鲁元太后。", "len": 14}
{"sid": "009_吕太后本纪.15.2.s2", "chapter": "009_吕太后本纪", "para": "15.2", "seq": 2, "text": "子偃为鲁王。", "len": 6}
{"sid": "009_吕太后本纪.15.3.s1", "chapter": "009_吕太后本纪", "para": "15.3", "seq": 1, "text": "鲁王父，宣平侯张敖也。", "len": 11}
{"sid": "009_吕太后本纪.15.4.s1", "chapter": "009_吕太后本纪", "para": "15.4", "seq": 1, "text": "封齐悼惠王子章为硃虚侯，以吕禄女妻之。", "len": 19}
{"sid": "009_吕太后本纪.15.5.s1", "chapter": "009_吕太后本纪", "para": "15.5", "seq": 1, "text": "齐丞相寿为平定侯。", "len": 9}
{"sid": "009_吕太后本纪.15.5.s2", "chapter": "009_吕太后本纪", "para": "15.5", "seq": 2, "text": "少府延为梧侯。", "len": 7}
{"sid": "009_吕太后本纪.15.6.s1", "chapter": "009_吕太后本纪", "para": "15.6", "seq": 1, "text": "乃封吕种为沛侯，吕平为扶柳侯，张买为南宫侯。", "len": 22}
{"sid": "009_吕太后本纪.16.1.s1", "chapter": "009_吕太后本纪", "para": "16.1", "seq": 1, "text": "太后欲王吕氏，先立孝惠後宫子彊为淮阳王，子不疑为常山王，子山为襄城侯，子朝为轵侯，子武为壶关侯。", "len": 48}
{"sid": "009_吕太后本纪.16.2.s1", "chapter": "009_吕太后本纪", "para": "16.2", "seq": 1, "text": "太后风大臣，大臣请立郦侯吕台为吕王，太后许之。", "len": 23}
{"sid": "009_吕太后本纪.16.3.s1", "chapter": "009_吕太后本纪", "para": "16.3", "seq": 1, "text": "建成康侯释之卒，嗣子有罪，废，立其弟吕禄为胡陵侯，续康侯後。", "len": 30}
{"sid": "009_吕太后本纪.17.1.s1", "chapter": "009_吕太后本纪", "para": "17.1", "seq": 1, "text": "二年，常山王薨，以其弟襄城侯山为常山王，更名义。", "len": 24}
{"sid": "009_吕太后本纪.17.2.s1", "chapter": "009_吕太后本纪", "para": "17.2", "seq": 1, "text": "十一月，吕王台薨，谥为肃王，太子嘉代立为王。", "len": 22}
{"sid": "009_吕太后本纪.17.3.s1", "chapter": "009_吕太后本纪", "para": "17.3", "seq": 1, "text": "三年，无事。", "len": 6}
{"sid": "009_吕太后本纪.18.1.s1", "chapter": "009_吕太后本纪", "para": "18.1", "seq": 1, "text": "四年，封吕嬃为临光侯，吕他为俞侯，吕更始为赘其侯，吕忿为吕城侯，及诸侯丞相五人。", "len": 40}
{"sid": "009_吕太后本纪.19.1.s1", "chapter": "009_吕太后本纪", "para": "19.1", "seq": 1, "text": "宣平侯女为孝惠皇后时，无子，详为有身，取美人子名之，杀其母，立所名子为太子。", "len": 38}
{"sid": "009_吕太后本纪.19.2.s1", "chapter": "009_吕太后本纪", "para": "19.2", "seq": 1, "text": "孝惠崩，太子立为帝。", "len": 10}
{"sid": "009_吕太后本纪.19.3.s1", "chapter": "009_吕太后本纪", "para": "19.3", "seq": 1, "text": "帝壮，或闻其母死，非真皇后子，乃出言曰： “后安能杀吾母而名我？", "len": 32}
{"sid": "009_吕太后本纪.19.3.s2", "chapter": "009_吕太后本纪", "para": "19.3", "seq": 2, "text": "我未壮，壮即为变。”", "len": 10}
{"sid": "009_吕太后本纪.20.1.s1", "chapter": "009_吕太后本纪", "para": "20.1", "seq": 1, "text": "太后闻而患之，恐其为乱，乃幽之永卷中，言帝病甚，左右莫得见。", "len": 30}
{"sid": "009_吕太后本纪.20.2.s1", "chapter": "009_吕太后本纪", "para": "20.2", "seq": 1, "text": "太后曰： “凡有天下治为万民命者，盖之如天，容之如地，上有欢心以安百姓，百姓欣然以事其上，欢欣交通而天下治。", "len": 54}
{"sid": "009_吕太后本纪.20.2.s2", "chapter": "009_吕太后本纪", "para": "20.2", "seq": 2, "text": "今皇帝病久不已，乃失惑惛乱，不能继嗣奉宗庙祭祀，不可属天下，其代之。”", "len": 35}
{"sid": "009_吕太后本纪.20.3.s1", "chapter": "009_吕太后本纪", "para": "20.3", "seq": 1, "text": "群臣皆顿首言： “皇太后为天下齐民计所以安宗庙社稷甚深，群臣顿首奉诏。”", "len": 36}
{"sid": "009_吕太后本纪.20.4.s1", "chapter": "009_吕太后本纪", "para": "20.4", "seq": 1, "text": "帝废位，太后幽杀之。", "len": 10}
{"sid": "009_吕太后本纪.21.1.s1", "chapter": "009_吕太后本纪", "para": "21.1", "seq": 1, "text": "五月丙辰，立常山王义为帝，更名曰弘。", "len": 18}
{"sid": "009_吕太后本纪.21.2.s1", "chapter": "009_吕太后本纪", "para": "21.2", "seq": 1, "text": "不称元年者，以太后制天下事也。", "len": 15}
{"sid": "009_吕太后本纪.21.3.s1", "chapter": "009_吕太后本纪", "para": "21.3", "seq": 1, "text": "以轵侯朝为常山王。", "len": 9}
{"sid": "009_吕太后本纪.21.4.s1", "chapter": "009_吕太后本纪", "para": "21.4", "seq": 1, "text": "置太尉官，绛侯勃为太尉。", "len": 12}
{"sid": "009_吕太后本纪.22.1.s1", "chapter": "009_吕太后本纪", "para": "22.1", "seq": 1, "text": "五年八月，淮阳王薨，以弟壶关侯武为淮阳王。", "len": 21}
{"sid": "009_吕太后本纪.22.2.s1", "chapter": "009_吕太后本纪", "para": "22.2", "seq": 1, "text": "六年十月，太后曰吕王嘉居处骄恣，废之，以肃王台弟吕产为吕王。", "len": 30}
{"sid": "009_吕太后本纪.22.3.s1", "chapter": "009_吕太后本纪", "para": "22.3", "seq": 1, "text": "夏，赦天下。", "len": 6}
{"sid": "009_吕太后本纪.22.3.s2", "chapter": "009_吕太后本纪", "para": "22.3", "seq": 2, "text": "封齐悼惠王子兴居为东牟侯。", "len": 13}
{"sid": "009_吕太后本纪.23.1.s1", "chapter": "009_吕太后本纪", "para": "23.1", "seq": 1, "text": "七年正月，太后召赵王友。", "len": 12}
{"sid": "009_吕太后本纪.23.2.s1", "chapter": "009_吕太后本纪", "para": "23.2", "seq": 1, "text": "友以诸吕女为受后，弗爱，爱他姬，诸吕女妒，怒去，谗之於太后，诬以罪过，曰： “吕氏安得王！", "len": 45}
{"sid": "009_吕太后本纪.23.2.s2", "chapter": "009_吕太后本纪", "para": "23.2", "seq": 2, "text": "太后百岁後，吾必击之”。", "len": 12}
{"sid": "009_吕太后本纪.23.3.s1", "chapter": "009_吕太后本纪", "para": "23.3", "seq": 1, "text": "太后怒，以故召赵王。", "len": 10}
{"sid": "009_吕太后本纪.23.4.s1", "chapter": "009_吕太后本纪", "para": "23.4", "seq": 1, "text": "赵王至，置邸不见，令卫围守之，弗与食。", "len": 19}
{"sid": "009_吕太后本纪.23.5.s1", "chapter": "009_吕太后本纪", "para": "23.5", "seq": 1, "text": "其群臣或窃馈，辄捕论之，赵王饿，乃歌曰： ::: 诗歌 “诸吕用事兮刘氏危，迫胁王侯兮彊授我妃。", "len": 48}
{"sid": "009_吕太后本纪.23.5.s2", "chapter": "009_吕太后本纪", "para": "23.5", "seq": 2, "text": "我妃既妒兮诬我以恶，谗女乱国兮上曾不寤。", "len": 20}
{"sid": "009_吕太后本纪.23.5.s3", "chapter": "009_吕太后本纪", "para": "23.5", "seq": 3, "text": "我无忠臣兮何故弃国？", "len": 10}
{"sid": "009_吕太后本纪.23.5.s4", "chapter": "009_吕太后本纪", "para": "23.5", "seq": 4, "text": "自决中野兮苍天举直！", "len": 10}
{"sid": "009_吕太后本纪.23.5.s5", "chapter": "009_吕太后本纪", "para": "23.5", "seq": 5, "text": "于嗟不可悔兮宁蚤自财。", "len": 11}
{"sid": "009_吕太后本纪.23.5.s6", "chapter": "009_吕太后本纪", "para": "23.5", "seq": 6, "text": "为王而饿死兮谁者怜之！", "len": 11}
{"sid": "009_吕太后本纪.23.5.s7", "chapter": "009_吕太后本纪", "para": "23.5", "seq": 7, "text": "吕氏绝理兮讬天报仇。", "len": 10}
{"sid": "009_吕太后本纪.23.5.s8", "chapter": "009_吕太后本纪", "para": "23.5", "seq": 8, "text": "” :::", "len": 5}
{"sid": "009_吕太后本纪.23.6.s1", "chapter": "009_吕太后本纪", "para": "23.6", "seq": 1, "text": "丁丑，赵王幽死，以民礼葬之长安民冢次。", "len": 19}
{"sid": "009_吕太后本纪.24.1.s1", "chapter": "009_吕太后本纪", "para": "24.1", "seq": 1, "text": "己丑，日食，昼晦。", "len": 9}
{"sid": "009_吕太后本纪.24.2.s1", "chapter": "009_吕太后本纪", "para": "24.2", "seq": 1, "text": "太后恶之，心不乐，乃谓左右曰： “此为我也。”", "len": 23}
{"sid": "009_吕太后本纪.25.1.s1", "chapter": "009_吕太后本纪", "para": "25.1", "seq": 1, "text": "二月，徙梁王恢为赵王。", "len": 11}
{"sid": "009_吕太后本纪.25.2.s1", "chapter": "009_吕太后本纪", "para": "25.2", "seq": 1, "text": "吕王产徙为梁王，梁王不之国，为帝太傅。", "len": 19}
{"sid": "009_吕太后本纪.25.3.s1", "chapter": "009_吕太后本纪", "para": "25.3", "seq": 1, "text": "立皇子平昌侯太为吕王。", "len": 11}
{"sid": "009_吕太后本纪.25.4.s1", "chapter": "009_吕太后本纪", "para": "25.4", "seq": 1, "text": "更名梁曰吕，吕曰济川。", "len": 11}
{"sid": "009_吕太后本纪.26.1.s1", "chapter": "009_吕太后本纪", "para": "26.1", "seq": 1, "text": "太后女弟吕嬃有女为营陵侯刘泽妻，泽为大将军。", "len": 22}
{"sid": "009_吕太后本纪.26.2.s1", "chapter": "009_吕太后本纪", "para": "26.2", "seq": 1, "text": "太后王诸吕，恐即崩後刘将军为害，乃以刘泽为琅邪王，以慰其心。", "len": 30}
{"sid": "009_吕太后本纪.27.1.s1", "chapter": "009_吕太后本纪", "para": "27.1", "seq": 1, "text": "梁王恢之徙王赵，心怀不乐。", "len": 13}
{"sid": "009_吕太后本纪.27.2.s1", "chapter": "009_吕太后本纪", "para": "27.2", "seq": 1, "text": "太后以吕产女为赵王后。", "len": 11}
{"sid": "009_吕太后本纪.27.3.s1", "chapter": "009_吕太后本纪", "para": "27.3", "seq": 1, "text": "王后从官皆诸吕，擅权，微伺赵王，赵王不得自恣。", "len": 23}
{"sid": "009_吕太后本纪.27.4.s1", "chapter": "009_吕太后本纪", "para": "27.4", "seq": 1, "text": "王有所爱姬，王后使人酖杀之。", "len": 14}
{"sid": "009_吕太后本纪.27.5.s1", "chapter": "009_吕太后本纪", "para": "27.5", "seq": 1, "text": "王乃为歌诗四章，令乐人歌之。", "len": 14}
{"sid": "009_吕太后本纪.27.5.s2", "chapter": "009_吕太后本纪", "para": "27.5", "seq": 2, "text": "王悲，六月即自杀。", "len": 9}
{"sid": "009_吕太后本纪.27.6.s1", "chapter": "009_吕太后本纪", "para": "27.6", "seq": 1, "text": "太后闻之，以为王用妇人弃宗庙礼，废其嗣。", "len": 20}
{"sid": "009_吕太后本纪.28.1.s1", "chapter": "009_吕太后本纪", "para": "28.1", "seq": 1, "text": "宣平侯张敖卒，以子偃为鲁王，敖赐谥为鲁元王。", "len": 22}
{"sid": "009_吕太后本纪.28.2.s1", "chapter": "009_吕太后本纪", "para": "28.2", "seq": 1, "text": "秋，太后使使告代王，欲徙王赵。", "len": 15}
{"sid": "009_吕太后本纪.28.2.s2", "chapter": "009_吕太后本纪", "para": "28.2", "seq": 2, "text": "代王谢，原守代边。", "len": 9}
{"sid": "009_吕太后本纪.29.1.s1", "chapter": "009_吕太后本纪", "para": "29.1", "seq": 1, "text": "太傅产、丞相平等言，武信侯吕禄上侯，位次第一，请立为赵王。", "len": 29}
{"sid": "009_吕太后本纪.29.2.s1", "chapter": "009_吕太后本纪", "para": "29.2", "seq": 1, "text": "太后许之，追尊禄父康侯为赵昭王。", "len": 16}
{"sid": "009_吕太后本纪.29.3.s1", "chapter": "009_吕太后本纪", "para": "29.3", "seq": 1, "text": "九月，燕灵王建薨，有美人子，太后使人杀之，无後，国除。", "len": 27}
{"sid": "009_吕太后本纪.29.4.s1", "chapter": "009_吕太后本纪", "para": "29.4", "seq": 1, "text": "八年十月，立吕肃王子东平侯吕通为燕王，封通弟吕庄为东平侯。", "len": 29}
{"sid": "009_吕太后本纪.30.1.s1", "chapter": "009_吕太后本纪", "para": "30.1", "seq": 1, "text": "三月中，吕后祓，还过轵道，见物如苍犬，据高后掖，忽弗复见。", "len": 29}
{"sid": "009_吕太后本纪.30.2.s1", "chapter": "009_吕太后本纪", "para": "30.2", "seq": 1, "text": "卜之，云赵王如意为祟。", "len": 11}
{"sid": "009_吕太后本纪.30.3.s1", "chapter": "009_吕太后本纪", "para": "30.3", "seq": 1, "text": "高后遂病掖伤。", "len": 7}
{"sid": "009_吕太后本纪.31.1.s1", "chapter": "009_吕太后本纪", "para": "31.1", "seq": 1, "text": "高后为外孙鲁元王偃年少，蚤失父母，孤弱，乃封张敖前姬两子，侈为新都侯，寿为乐昌侯，以辅鲁元王偃。", "len": 48}
{"sid": "009_吕太后本纪.31.2.s1", "chapter": "009_吕太后本纪", "para": "31.2", "seq": 1, "text": "及封中大谒者张释为建陵侯，吕荣为祝兹侯。", "len": 20}
{"sid": "009_吕太后本纪.31.3.s1", "chapter": "009_吕太后本纪", "para": "31.3", "seq": 1, "text": "诸中宦者令丞皆为关内侯，食邑五百户。", "len": 18}
{"sid": "009_吕太后本纪.32.1.s1", "chapter": "009_吕太后本纪", "para": "32.1", "seq": 1, "text": "七月中，高后病甚，乃令赵王吕禄为上将军，军北军；吕王产居南军。", "len": 31}
{"sid": "009_吕太后本纪.32.2.s1", "chapter": "009_吕太后本纪", "para": "32.2", "seq": 1, "text": "吕太后诫产、禄曰： “高帝已定天下，与大臣约，曰‘非刘氏王者，天下共击之’。", "len": 38}
{"sid": "009_吕太后本纪.32.2.s2", "chapter": "009_吕太后本纪", "para": "32.2", "seq": 2, "text": "今吕氏王，大臣弗平。", "len": 10}
{"sid": "009_吕太后本纪.32.2.s3", "chapter": "009_吕太后本纪", "para": "32.2", "seq": 3, "text": "我即崩，帝年少，大臣恐为变。", "len": 14}
{"sid": "009_吕太后本纪.32.2.s4", "chapter": "009_吕太后本纪", "para": "32.2", "seq": 4, "text": "必据兵卫宫，慎毋送丧，毋为人所制。”", "len": 18}
{"sid": "009_吕太后本纪.32.3.s1", "chapter": "009_吕太后本纪", "para": "32.3", "seq": 1, "text": "辛巳，高后崩，遗诏赐诸侯王各千金，将相列侯郎吏皆以秩赐金。", "len": 29}
{"sid": "009_吕太后本纪.32.4.s1", "chapter": "009_吕太后本纪", "para": "32.4", "seq": 1, "text": "大赦天下。", "len": 5}
{"sid": "009_吕太后本纪.32.4.s2", "chapter": "009_吕太后本纪", "para": "32.4", "seq": 2, "text": "以吕王产为相国，以吕禄女为帝后。", "len": 16}
{"sid": "009_吕太后本纪.33.s1", "chapter": "009_吕太后本纪", "para": "33", "seq": 1, "text": "高后已葬，以左丞相审食其为帝太傅。", "len": 17}
{"sid": "009_吕太后本纪.34.1.s1", "chapter": "009_吕太后本纪", "para": "34.1", "seq": 1, "text": "硃虚侯刘章有气力，东牟侯兴居其弟也。", "len": 18}
{"sid": "009_吕太后本纪.34.1.s2", "chapter": "009_吕太后本纪", "para": "34.1", "seq": 2, "text": "皆齐哀王弟，居长安。", "len": 10}
{"sid": "009_吕太后本纪.34.2.s1", "chapter": "009_吕太后本纪", "para": "34.2", "seq": 1, "text": "当是时，诸吕用事擅权，欲为乱，畏高帝故大臣绛、灌等，未敢发。", "len": 30}
{"sid": "009_吕太后本纪.34.3.s1", "chapter": "009_吕太后本纪", "para": "34.3", "seq": 1, "text": "硃虚侯妇，吕禄女，阴知其谋。", "len": 14}
{"sid": "009_吕太后本纪.34.3.s2", "chapter": "009_吕太后本纪", "para": "34.3", "seq": 2, "text": "恐见诛，乃阴令人告其兄齐王，欲令发兵西，诛诸吕而立。", "len": 26}
{"sid": "009_吕太后本纪.34.4.s1", "chapter": "009_吕太后本纪", "para": "34.4", "seq": 1, "text": "硃虚侯欲从中与大臣为应。", "len": 12}
{"sid": "009_吕太后本纪.35.1.s1", "chapter": "009_吕太后本纪", "para": "35.1", "seq": 1, "text": "齐王欲发兵，其相弗听。", "len": 11}
{"sid": "009_吕太后本纪.35.2.s1", "chapter": "009_吕太后本纪", "para": "35.2", "seq": 1, "text": "八月丙午，齐王欲使人诛相，相召平乃反，举兵欲围王，王因杀其相，遂发兵东，诈夺琅邪王兵，并将之而西。", "len": 49}
{"sid": "009_吕太后本纪.35.3.s1", "chapter": "009_吕太后本纪", "para": "35.3", "seq": 1, "text": "语在齐王语中。", "len": 7}
{"sid": "009_吕太后本纪.36.1.s1", "chapter": "009_吕太后本纪", "para": "36.1", "seq": 1, "text": "齐王乃遗诸侯王书曰： ::: 齐王檄文 “高帝平定天下，王诸子弟，悼惠王王齐。", "len": 39}
{"sid": "009_吕太后本纪.36.1.s2", "chapter": "009_吕太后本纪", "para": "36.1", "seq": 2, "text": "悼惠王薨，孝惠帝使留侯良立臣为齐王。", "len": 18}
{"sid": "009_吕太后本纪.36.1.s3", "chapter": "009_吕太后本纪", "para": "36.1", "seq": 3, "text": "孝惠崩，高后用事，春秋高，听诸吕，擅废帝更立，又比杀三赵王，灭梁、赵、燕以王诸吕，分齐为四。", "len": 46}
{"sid": "009_吕太后本纪.36.1.s4", "chapter": "009_吕太后本纪", "para": "36.1", "seq": 4, "text": "忠臣进谏，上惑乱弗听。", "len": 11}
{"sid": "009_吕太后本纪.36.1.s5", "chapter": "009_吕太后本纪", "para": "36.1", "seq": 5, "text": "今高后崩，而帝春秋富，未能治天下，固恃大臣诸侯。", "len": 24}
{"sid": "009_吕太后本纪.36.1.s6", "chapter": "009_吕太后本纪", "para": "36.1", "seq": 6, "text": "而诸吕又擅自尊官，聚兵严威，劫列侯忠臣，矫制以令天下，宗庙所以危。", "len": 33}
{"sid": "009_吕太后本纪.36.1.s7", "chapter": "009_吕太后本纪", "para": "36.1", "seq": 7, "text": "寡人率兵入诛不当为王者。", "len": 12}
{"sid": "009_吕太后本纪.36.1.s8", "chapter": "009_吕太后本纪", "para": "36.1", "seq": 8, "text": "” :::", "len": 5}
{"sid": "009_吕太后本纪.37.1.s1", "chapter": "009_吕太后本纪", "para": "37.1", "seq": 1, "text": "汉闻之，相国吕产等乃遣颍阴侯灌婴将兵击之。", "len": 21}
{"sid": "009_吕太后本纪.37.2.s1", "chapter": "009_吕太后本纪", "para": "37.2", "seq": 1, "text": "灌婴至荥阳，乃谋曰： “诸吕权兵关中，欲危刘氏而自立。", "len": 27}
{"sid": "009_吕太后本纪.37.2.s2", "chapter": "009_吕太后本纪", "para": "37.2", "seq": 2, "text": "今我破齐还报，此益吕氏之资也。”", "len": 16}
{"sid": "009_吕太后本纪.37.3.s1", "chapter": "009_吕太后本纪", "para": "37.3", "seq": 1, "text": "乃留屯荥阳，使使谕齐王及诸侯，与连和，以待吕氏变，共诛之。", "len": 29}
{"sid": "009_吕太后本纪.37.4.s1", "chapter": "009_吕太后本纪", "para": "37.4", "seq": 1, "text": "齐王闻之，乃还兵西界待约。", "len": 13}
{"sid": "009_吕太后本纪.38.1.s1", "chapter": "009_吕太后本纪", "para": "38.1", "seq": 1, "text": "吕禄、吕产欲发乱关中，内惮绛侯、硃虚等，外畏齐、楚兵，又恐灌婴畔之，欲待灌婴兵与齐合而发，犹豫未决。", "len": 50}
{"sid": "009_吕太后本纪.38.2.s1", "chapter": "009_吕太后本纪", "para": "38.2", "seq": 1, "text": "当是时，济川王太、淮阳王武、常山王朝名为少帝弟，及鲁元王吕后外孙，皆年少未之国，居长安。", "len": 44}
{"sid": "009_吕太后本纪.38.3.s1", "chapter": "009_吕太后本纪", "para": "38.3", "seq": 1, "text": "赵王禄、梁王产各将兵居南北军，皆吕氏之人。", "len": 21}
{"sid": "009_吕太后本纪.38.3.s2", "chapter": "009_吕太后本纪", "para": "38.3", "seq": 2, "text": "列侯群臣莫自坚其命。", "len": 10}
{"sid": "009_吕太后本纪.39.1.s1", "chapter": "009_吕太后本纪", "para": "39.1", "seq": 1, "text": "太尉绛侯勃不得入军中主兵。", "len": 13}
{"sid": "009_吕太后本纪.39.2.s1", "chapter": "009_吕太后本纪", "para": "39.2", "seq": 1, "text": "曲周侯郦商老病，其子寄与吕禄善。", "len": 16}
{"sid": "009_吕太后本纪.39.3.s1", "chapter": "009_吕太后本纪", "para": "39.3", "seq": 1, "text": "绛侯乃与丞相陈平谋，使人劫郦商。", "len": 16}
{"sid": "009_吕太后本纪.39.4.s1", "chapter": "009_吕太后本纪", "para": "39.4", "seq": 1, "text": "令其子寄往绐说吕禄曰： “高帝与吕后共定天下，刘氏所立九王，吕氏所立三王，皆大臣之议，事已布告诸侯，诸侯皆以为宜。", "len": 57}
{"sid": "009_吕太后本纪.39.4.s2", "chapter": "009_吕太后本纪", "para": "39.4", "seq": 2, "text": "今太后崩，帝少，而足下佩赵王印，不急之国守籓，乃为上将，将兵留此，为大臣诸侯所疑。", "len": 41}
{"sid": "009_吕太后本纪.39.4.s3", "chapter": "009_吕太后本纪", "para": "39.4", "seq": 3, "text": "足下何不归印，以兵属太尉？", "len": 13}
{"sid": "009_吕太后本纪.39.4.s4", "chapter": "009_吕太后本纪", "para": "39.4", "seq": 4, "text": "请梁王归相国印，与大臣盟而之国，齐兵必罢，大臣得安，足下高枕而王千里，此万世之利也。”", "len": 43}
{"sid": "009_吕太后本纪.40.1.s1", "chapter": "009_吕太后本纪", "para": "40.1", "seq": 1, "text": "吕禄信然其计，欲归将印，以兵属太尉。", "len": 18}
{"sid": "009_吕太后本纪.40.2.s1", "chapter": "009_吕太后本纪", "para": "40.2", "seq": 1, "text": "使人报吕产及诸吕老人，或以为便，或曰不便，计犹豫未有所决。", "len": 29}
{"sid": "009_吕太后本纪.40.3.s1", "chapter": "009_吕太后本纪", "para": "40.3", "seq": 1, "text": "吕禄信郦寄，时与出游猎。", "len": 12}
{"sid": "009_吕太后本纪.40.4.s1", "chapter": "009_吕太后本纪", "para": "40.4", "seq": 1, "text": "过其姑吕嬃，嬃大怒，曰： “若为将而弃军，吕氏今无处矣。”", "len": 29}
{"sid": "009_吕太后本纪.40.5.s1", "chapter": "009_吕太后本纪", "para": "40.5", "seq": 1, "text": "乃悉出珠玉宝器散堂下，曰： “毋为他人守也”", "len": 22}
{"sid": "009_吕太后本纪.41.s1", "chapter": "009_吕太后本纪", "para": "41", "seq": 1, "text": "左丞相食其免。", "len": 7}
{"sid": "009_吕太后本纪.42.1.s1", "chapter": "009_吕太后本纪", "para": "42.1", "seq": 1, "text": "八月庚申旦，平阳侯窋行御史大夫事，见相国产计事。", "len": 24}
{"sid": "009_吕太后本纪.42.2.s1", "chapter": "009_吕太后本纪", "para": "42.2", "seq": 1, "text": "郎中令贾寿使从齐来，因数产曰： “王不蚤之国，今虽欲行，尚可得邪？”", "len": 34}
{"sid": "009_吕太后本纪.42.3.s1", "chapter": "009_吕太后本纪", "para": "42.3", "seq": 1, "text": "具以灌婴与齐楚合从，欲诛诸吕告产，乃趣产急入宫。", "len": 24}
{"sid": "009_吕太后本纪.43.1.s1", "chapter": "009_吕太后本纪", "para": "43.1", "seq": 1, "text": "平阳侯颇闻其语，乃驰告丞相、太尉。", "len": 17}
{"sid": "009_吕太后本纪.43.2.s1", "chapter": "009_吕太后本纪", "para": "43.2", "seq": 1, "text": "太尉欲入北军，不得入。", "len": 11}
{"sid": "009_吕太后本纪.43.2.s2", "chapter": "009_吕太后本纪", "para": "43.2", "seq": 2, "text": "襄平侯通尚符节。", "len": 8}
{"sid": "009_吕太后本纪.43.3.s1", "chapter": "009_吕太后本纪", "para": "43.3", "seq": 1, "text": "乃令持节矫内太尉北军。", "len": 11}
{"sid": "009_吕太后本纪.43.4.s1", "chapter": "009_吕太后本纪", "para": "43.4", "seq": 1, "text": "太尉复令郦寄与典客刘揭先说吕禄曰： “帝使太尉守北军，欲足下之国，急归将印辞去，不然，祸且起。”", "len": 48}
{"sid": "009_吕太后本纪.43.5.s1", "chapter": "009_吕太后本纪", "para": "43.5", "seq": 1, "text": "吕禄以为郦兄不欺己，遂解印属典客，而以兵授太尉。", "len": 24}
{"sid": "009_吕太后本纪.44.1.s1", "chapter": "009_吕太后本纪", "para": "44.1", "seq": 1, "text": "太尉将之入军门，行令军中曰： “为吕氏右襢，为刘氏左襢。”", "len": 29}
{"sid": "009_吕太后本纪.44.2.s1", "chapter": "009_吕太后本纪", "para": "44.2", "seq": 1, "text": "军中皆左襢为刘氏。", "len": 9}
{"sid": "009_吕太后本纪.44.3.s1", "chapter": "009_吕太后本纪", "para": "44.3", "seq": 1, "text": "太尉行至，将军吕禄亦已解上将印去，太尉遂将北军。", "len": 24}
{"sid": "009_吕太后本纪.45.1.s1", "chapter": "009_吕太后本纪", "para": "45.1", "seq": 1, "text": "然尚有南军。", "len": 6}
{"sid": "009_吕太后本纪.45.2.s1", "chapter": "009_吕太后本纪", "para": "45.2", "seq": 1, "text": "平阳侯闻之，以吕产谋告丞相平，丞相平乃召硃虚侯佐太尉。", "len": 27}
{"sid": "009_吕太后本纪.45.3.s1", "chapter": "009_吕太后本纪", "para": "45.3", "seq": 1, "text": "太尉令硃虚侯监军门。", "len": 10}
{"sid": "009_吕太后本纪.45.3.s2", "chapter": "009_吕太后本纪", "para": "45.3", "seq": 2, "text": "令平阳侯告卫尉： “毋入相国产殿门。”", "len": 19}
{"sid": "009_吕太后本纪.46.1.s1", "chapter": "009_吕太后本纪", "para": "46.1", "seq": 1, "text": "吕产不知吕禄已去北军，乃入未央宫，欲为乱，殿门弗得入，裴回往来。", "len": 32}
{"sid": "009_吕太后本纪.46.2.s1", "chapter": "009_吕太后本纪", "para": "46.2", "seq": 1, "text": "平阳侯恐弗胜，驰语太尉。", "len": 12}
{"sid": "009_吕太后本纪.46.3.s1", "chapter": "009_吕太后本纪", "para": "46.3", "seq": 1, "text": "太尉尚恐不胜诸吕，未敢讼言诛之，乃遣硃虚侯谓曰： “急入宫卫帝。”", "len": 33}
{"sid": "009_吕太后本纪.47.1.s1", "chapter": "009_吕太后本纪", "para": "47.1", "seq": 1, "text": "硃虚侯请卒，太尉予卒千馀人。", "len": 14}
{"sid": "009_吕太后本纪.47.2.s1", "chapter": "009_吕太后本纪", "para": "47.2", "seq": 1, "text": "入未央宫门，遂见产廷中。", "len": 12}
{"sid": "009_吕太后本纪.47.2.s2", "chapter": "009_吕太后本纪", "para": "47.2", "seq": 2, "text": "日餔时，遂击产。", "len": 8}
{"sid": "009_吕太后本纪.47.3.s1", "chapter": "009_吕太后本纪", "para": "47.3", "seq": 1, "text": "产走，天风大起，以故其从官乱，莫敢斗。", "len": 19}
{"sid": "009_吕太后本纪.47.4.s1", "chapter": "009_吕太后本纪", "para": "47.4", "seq": 1, "text": "逐产，杀之郎中府吏厕中。", "len": 12}
{"sid": "009_吕太后本纪.48.1.s1", "chapter": "009_吕太后本纪", "para": "48.1", "seq": 1, "text": "硃虚侯已杀产，帝命谒者持节劳硃虚侯。", "len": 18}
{"sid": "009_吕太后本纪.48.2.s1", "chapter": "009_吕太后本纪", "para": "48.2", "seq": 1, "text": "硃虚侯欲夺节信，谒者不肯，硃虚侯则从与载，因节信驰走，斩长乐卫尉吕更始。", "len": 36}
{"sid": "009_吕太后本纪.48.3.s1", "chapter": "009_吕太后本纪", "para": "48.3", "seq": 1, "text": "还，驰入北军，报太尉。", "len": 11}
{"sid": "009_吕太后本纪.48.4.s1", "chapter": "009_吕太后本纪", "para": "48.4", "seq": 1, "text": "太尉起，拜贺硃虚侯曰： “所患独吕产，今已诛，天下定矣。”", "len": 29}
{"sid": "009_吕太后本纪.48.5.s1", "chapter": "009_吕太后本纪", "para": "48.5", "seq": 1, "text": "遂遣人分部悉捕诸吕男女，无少长皆斩之。", "len": 19}
{"sid": "009_吕太后本纪.49.1.s1", "chapter": "009_吕太后本纪", "para": "49.1", "seq": 1, "text": "辛酉，捕斩吕禄，而笞杀吕嬃。", "len": 14}
{"sid": "009_吕太后本纪.49.2.s1", "chapter": "009_吕太后本纪", "para": "49.2", "seq": 1, "text": "使人诛燕王吕通，而废鲁王偃。", "len": 14}
{"sid": "009_吕太后本纪.49.3.s1", "chapter": "009_吕太后本纪", "para": "49.3", "seq": 1, "text": "壬戌，以帝太傅食其复为左丞相。", "len": 15}
{"sid": "009_吕太后本纪.49.4.s1", "chapter": "009_吕太后本纪", "para": "49.4", "seq": 1, "text": "戊辰，徙济川王王梁，立赵幽王子遂为赵王。", "len": 20}
{"sid": "009_吕太后本纪.49.5.s1", "chapter": "009_吕太后本纪", "para": "49.5", "seq": 1, "text": "遣硃虚侯章以诛诸吕氏事告齐王，令罢兵。", "len": 19}
{"sid": "009_吕太后本纪.49.6.s1", "chapter": "009_吕太后本纪", "para": "49.6", "seq": 1, "text": "灌婴兵亦罢荥阳而归。", "len": 10}
{"sid": "009_吕太后本纪.50.1.s1", "chapter": "009_吕太后本纪", "para": "50.1", "seq": 1, "text": "诸大臣相与阴谋曰： “少帝及梁、淮阳、常山王，皆非真孝惠子也。", "len": 31}
{"sid": "009_吕太后本纪.50.1.s2", "chapter": "009_吕太后本纪", "para": "50.1", "seq": 2, "text": "吕后以计诈名他人子，杀其母，养後宫，令孝惠子之，立以为後，及诸王，以彊吕氏。", "len": 38}
{"sid": "009_吕太后本纪.50.1.s3", "chapter": "009_吕太后本纪", "para": "50.1", "seq": 3, "text": "今皆已夷灭诸吕，而置所立，即长用事，吾属无类矣。", "len": 24}
{"sid": "009_吕太后本纪.50.1.s4", "chapter": "009_吕太后本纪", "para": "50.1", "seq": 4, "text": "不如视诸王最贤者立之。”", "len": 12}
{"sid": "009_吕太后本纪.50.2.s1", "chapter": "009_吕太后本纪", "para": "50.2", "seq": 1, "text": "或言 “齐悼惠王高帝长子，今其適子为齐王，推本言之，高帝適长孙，可立也”。", "len": 37}
{"sid": "009_吕太后本纪.50.3.s1", "chapter": "009_吕太后本纪", "para": "50.3", "seq": 1, "text": "大臣皆曰： “吕氏以外家恶而几危宗庙，乱功臣今齐王母家驷，驷钧，恶人也。", "len": 36}
{"sid": "009_吕太后本纪.50.3.s2", "chapter": "009_吕太后本纪", "para": "50.3", "seq": 2, "text": "即立齐王，则复为吕氏。”", "len": 12}
{"sid": "009_吕太后本纪.50.4.s1", "chapter": "009_吕太后本纪", "para": "50.4", "seq": 1, "text": "欲立淮南王，以为少，母家又恶。", "len": 15}
{"sid": "009_吕太后本纪.50.5.s1", "chapter": "009_吕太后本纪", "para": "50.5", "seq": 1, "text": "乃曰： “代王方今高帝见子，最长，仁孝宽厚。", "len": 22}
{"sid": "009_吕太后本纪.50.5.s2", "chapter": "009_吕太后本纪", "para": "50.5", "seq": 2, "text": "太后家薄氏谨良。", "len": 8}
{"sid": "009_吕太后本纪.50.5.s3", "chapter": "009_吕太后本纪", "para": "50.5", "seq": 3, "text": "且立长故顺，以仁孝闻於天下，便。”", "len": 17}
{"sid": "009_吕太后本纪.50.6.s1", "chapter": "009_吕太后本纪", "para": "50.6", "seq": 1, "text": "乃相与共阴使人召代王。", "len": 11}
{"sid": "009_吕太后本纪.50.7.s1", "chapter": "009_吕太后本纪", "para": "50.7", "seq": 1, "text": "代王使人辞谢。", "len": 7}
{"sid": "009_吕太后本纪.50.7.s2", "chapter": "009_吕太后本纪", "para": "50.7", "seq": 2, "text": "再反，然後乘六乘传。", "len": 10}
{"sid": "009_吕太后本纪.50.8.s1", "chapter": "009_吕太后本纪", "para": "50.8", "seq": 1, "text": "後九月晦日己酉，至长安，舍代邸。", "len": 16}
{"sid": "009_吕太后本纪.50.9.s1", "chapter": "009_吕太后本纪", "para": "50.9", "seq": 1, "text": "大臣皆往谒，奉天子玺上代王，共尊立为天子。", "len": 21}
{"sid": "009_吕太后本纪.50.10.s1", "chapter": "009_吕太后本纪", "para": "50.10", "seq": 1, "text": "代王数让，群臣固请，然後听。", "len": 14}
{"sid": "009_吕太后本纪.51.1.s1", "chapter": "009_吕太后本纪", "para": "51.1", "seq": 1, "text": "东牟侯兴居曰： “诛吕氏吾无功，请得除宫。”", "len": 22}
{"sid": "009_吕太后本纪.51.2.s1", "chapter": "009_吕太后本纪", "para": "51.2", "seq": 1, "text": "乃与太仆汝阴侯滕公入宫，前谓少帝曰： “足下非刘氏，不当立。”", "len": 31}
{"sid": "009_吕太后本纪.51.3.s1", "chapter": "009_吕太后本纪", "para": "51.3", "seq": 1, "text": "乃顾麾左右执戟者掊兵罢去。", "len": 13}
{"sid": "009_吕太后本纪.51.4.s1", "chapter": "009_吕太后本纪", "para": "51.4", "seq": 1, "text": "有数人不肯去兵，宦者令张泽谕告，亦去兵。", "len": 20}
{"sid": "009_吕太后本纪.51.5.s1", "chapter": "009_吕太后本纪", "para": "51.5", "seq": 1, "text": "滕公乃召乘舆车载少帝出。", "len": 12}
{"sid": "009_吕太后本纪.51.6.s1", "chapter": "009_吕太后本纪", "para": "51.6", "seq": 1, "text": "少帝曰： “欲将我安之乎？”", "len": 14}
{"sid": "009_吕太后本纪.51.7.s1", "chapter": "009_吕太后本纪", "para": "51.7", "seq": 1, "text": "滕公曰 “出就舍。”", "len": 10}
{"sid": "009_吕太后本纪.51.8.s1", "chapter": "009_吕太后本纪", "para": "51.8", "seq": 1, "text": "舍少府。", "len": 4}
{"sid": "009_吕太后本纪.52.1.s1", "chapter": "009_吕太后本纪", "para": "52.1", "seq": 1, "text": "乃奉天子法驾，迎代王於邸。", "len": 13}
{"sid": "009_吕太后本纪.52.1.s2", "chapter": "009_吕太后本纪", "para": "52.1", "seq": 2, "text": "报曰： “宫谨除。”", "len": 10}
{"sid": "009_吕太后本纪.52.2.s1", "chapter": "009_吕太后本纪", "para": "52.2", "seq": 1, "text": "代王即夕入未央宫。", "len": 9}
{"sid": "009_吕太后本纪.52.3.s1", "chapter": "009_吕太后本纪", "para": "52.3", "seq": 1, "text": "有谒者十人持戟卫端门，曰： “天子在也，足下何为者而入？”", "len": 29}
{"sid": "009_吕太后本纪.52.4.s1", "chapter": "009_吕太后本纪", "para": "52.4", "seq": 1, "text": "代王乃谓太尉。", "len": 7}
{"sid": "009_吕太后本纪.52.4.s2", "chapter": "009_吕太后本纪", "para": "52.4", "seq": 2, "text": "太尉往谕，谒者十人皆掊兵而去。", "len": 15}
{"sid": "009_吕太后本纪.52.5.s1", "chapter": "009_吕太后本纪", "para": "52.5", "seq": 1, "text": "代王遂入而听政。", "len": 8}
{"sid": "009_吕太后本纪.52.6.s1", "chapter": "009_吕太后本纪", "para": "52.6", "seq": 1, "text": "夜，有司分部诛灭梁、淮阳、常山王及少帝於邸。", "len": 22}
{"sid": "009_吕太后本纪.53.s1", "chapter": "009_吕太后本纪", "para": "53", "seq": 1, "text": "代王立为天子。", "len": 7}
{"sid": "009_吕太后本纪.53.s2", "chapter": "009_吕太后本纪", "para": "53", "seq": 2, "text": "二十三年崩，谥为孝文皇帝。", "len": 13}
{"sid": "009_吕太后本纪.53.s3", "chapter": "009_吕太后本纪", "para": "53", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "009_吕太后本纪.54.s1", "chapter": "009_吕太后本纪", "para": "54", "seq": 1, "text": "太史公曰：孝惠皇帝、高后之时，黎民得离战国之苦，君臣俱欲休息乎无为，故惠帝垂拱，高后女主称制，政不出房户，天下晏然。", "len": 58}
{"sid": "009_吕太后本纪.54.s2", "chapter": "009_吕太后本纪", "para": "54", "seq": 2, "text": "::: ::: 赞", "len": 9}
{"sid": "009_吕太后本纪.55.s1", "chapter": "009_吕太后本纪", "para": "55", "seq": 1, "text": "刑罚罕用，罪人是希。", "len": 10}
{"sid": "009_吕太后本纪.55.s2", "chapter": "009_吕太后本纪", "para": "55", "seq": 2, "text": "民务稼穑，衣食滋殖。", "len": 10}
{"sid": "009_吕太后本纪.55.s3", "chapter": "009_吕太后本纪", "para": "55", "seq": 3, "text": "高祖犹微，吕氏作妃。", "len": 10}
{"sid": "009_吕太后本纪.55.s4", "chapter": "009_吕太后本纪", "para": "55", "seq": 4, "text": "及正轩掖，潜用福威。", "len": 10}
{"sid": "009_吕太后本纪.55.s5", "chapter": "009_吕太后本纪", "para": "55", "seq": 5, "text": "志怀安忍，性挟猜疑。", "len": 10}
{"sid": "009_吕太后本纪.55.s6", "chapter": "009_吕太后本纪", "para": "55", "seq": 6, "text": "置鸩齐悼，残彘戚姬。", "len": 10}
{"sid": "009_吕太后本纪.55.s7", "chapter": "009_吕太后本纪", "para": "55", "seq": 7, "text": "孝惠崩殒，其哭不悲。", "len": 10}
{"sid": "009_吕太后本纪.55.s8", "chapter": "009_吕太后本纪", "para": "55", "seq": 8, "text": "诸吕用事，天下示私。", "len": 10}
{"sid": "009_吕太后本纪.55.s9", "chapter": "009_吕太后本纪", "para": "55", "seq": 9, "text": "大臣菹醢，支孽芟夷。", "len": 10}
{"sid": "009_吕太后本纪.55.s10", "chapter": "009_吕太后本纪", "para": "55", "seq": 10, "text": "祸盈斯验，苍狗为菑。", "len": 10}
{"sid": "009_吕太后本纪.55.s11", "chapter": "009_吕太后本纪", "para": "55", "seq": 11, "text": ":::", "len": 3}
