{"sid": "088_蒙恬列传.1.s1", "chapter": "088_蒙恬列传", "para": "1", "seq": 1, "text": "蒙恬者，其先齐人也。", "len": 10}
{"sid": "088_蒙恬列传.1.s2", "chapter": "088_蒙恬列传", "para": "1", "seq": 2, "text": "恬大父蒙骜，自齐事秦昭王，官至上卿。", "len": 18}
{"sid": "088_蒙恬列传.1.s3", "chapter": "088_蒙恬列传", "para": "1", "seq": 3, "text": "秦庄襄王元年，蒙骜为秦将，伐韩，取成皋、荥阳，作置三川郡。", "len": 29}
{"sid": "088_蒙恬列传.1.s4", "chapter": "088_蒙恬列传", "para": "1", "seq": 4, "text": "二年，蒙骜攻赵，取三十七城。", "len": 14}
{"sid": "088_蒙恬列传.1.s5", "chapter": "088_蒙恬列传", "para": "1", "seq": 5, "text": "始皇三年，蒙骜攻韩，取十三城。", "len": 15}
{"sid": "088_蒙恬列传.1.s6", "chapter": "088_蒙恬列传", "para": "1", "seq": 6, "text": "五年，蒙骜攻魏，取二十城，作置东郡。", "len": 18}
{"sid": "088_蒙恬列传.1.s7", "chapter": "088_蒙恬列传", "para": "1", "seq": 7, "text": "始皇七年，蒙骜卒。", "len": 9}
{"sid": "088_蒙恬列传.1.s8", "chapter": "088_蒙恬列传", "para": "1", "seq": 8, "text": "骜子曰武，武子曰恬。", "len": 10}
{"sid": "088_蒙恬列传.1.s9", "chapter": "088_蒙恬列传", "para": "1", "seq": 9, "text": "恬尝书狱典文学。", "len": 8}
{"sid": "088_蒙恬列传.1.s10", "chapter": "088_蒙恬列传", "para": "1", "seq": 10, "text": "始皇二十三年，蒙武为秦裨将军，与王翦攻楚，大破之，杀项燕。", "len": 29}
{"sid": "088_蒙恬列传.1.s11", "chapter": "088_蒙恬列传", "para": "1", "seq": 11, "text": "二十四年，蒙武攻楚，虏楚王。", "len": 14}
{"sid": "088_蒙恬列传.1.s12", "chapter": "088_蒙恬列传", "para": "1", "seq": 12, "text": "蒙恬弟毅。", "len": 5}
{"sid": "088_蒙恬列传.2.s1", "chapter": "088_蒙恬列传", "para": "2", "seq": 1, "text": "始皇二十六年，蒙恬因家世得为秦将，攻齐，大破之，拜为内史。", "len": 29}
{"sid": "088_蒙恬列传.2.s2", "chapter": "088_蒙恬列传", "para": "2", "seq": 2, "text": "秦已并天下，乃使蒙恬将三十万众北逐戎狄，收河南。", "len": 24}
{"sid": "088_蒙恬列传.2.s3", "chapter": "088_蒙恬列传", "para": "2", "seq": 3, "text": "筑长城，因地形，用制险塞，起临洮，至辽东，延袤万馀里。", "len": 27}
{"sid": "088_蒙恬列传.2.s4", "chapter": "088_蒙恬列传", "para": "2", "seq": 4, "text": "於是渡河，据阳山，逶蛇而北。", "len": 14}
{"sid": "088_蒙恬列传.2.s5", "chapter": "088_蒙恬列传", "para": "2", "seq": 5, "text": "暴师於外十馀年，居上郡。", "len": 12}
{"sid": "088_蒙恬列传.2.s6", "chapter": "088_蒙恬列传", "para": "2", "seq": 6, "text": "是时蒙恬威振匈奴。", "len": 9}
{"sid": "088_蒙恬列传.2.s7", "chapter": "088_蒙恬列传", "para": "2", "seq": 7, "text": "始皇甚尊宠蒙氏，信任贤之。", "len": 13}
{"sid": "088_蒙恬列传.2.s8", "chapter": "088_蒙恬列传", "para": "2", "seq": 8, "text": "而亲近蒙毅，位至上卿，出则参乘，入则御前。", "len": 21}
{"sid": "088_蒙恬列传.2.s9", "chapter": "088_蒙恬列传", "para": "2", "seq": 9, "text": "恬任外事而毅常为内谋，名为忠信，故虽诸将相莫敢与之争焉。", "len": 28}
{"sid": "088_蒙恬列传.3.s1", "chapter": "088_蒙恬列传", "para": "3", "seq": 1, "text": "赵高者，诸赵疏远属也。", "len": 11}
{"sid": "088_蒙恬列传.3.s2", "chapter": "088_蒙恬列传", "para": "3", "seq": 2, "text": "赵高昆弟数人，皆生隐宫，其母被刑僇，世世卑贱。", "len": 23}
{"sid": "088_蒙恬列传.3.s3", "chapter": "088_蒙恬列传", "para": "3", "seq": 3, "text": "秦王闻高彊力，通於狱法，举以为中车府令。", "len": 20}
{"sid": "088_蒙恬列传.3.s4", "chapter": "088_蒙恬列传", "para": "3", "seq": 4, "text": "高既私事公子胡亥，喻之决狱。", "len": 14}
{"sid": "088_蒙恬列传.3.s5", "chapter": "088_蒙恬列传", "para": "3", "seq": 5, "text": "高有大罪，秦王令蒙毅法治之。", "len": 14}
{"sid": "088_蒙恬列传.3.s6", "chapter": "088_蒙恬列传", "para": "3", "seq": 6, "text": "毅不敢阿法，当高罪死，除其宦籍。", "len": 16}
{"sid": "088_蒙恬列传.3.s7", "chapter": "088_蒙恬列传", "para": "3", "seq": 7, "text": "帝以高之敦於事也，赦之，复其官爵。", "len": 17}
{"sid": "088_蒙恬列传.4.s1", "chapter": "088_蒙恬列传", "para": "4", "seq": 1, "text": "始皇欲游天下，道九原，直抵甘泉，乃使蒙恬通道，自九原抵甘泉，巉山堙谷，千八百里。", "len": 40}
{"sid": "088_蒙恬列传.4.s2", "chapter": "088_蒙恬列传", "para": "4", "seq": 2, "text": "道未就。", "len": 4}
{"sid": "088_蒙恬列传.4.s3", "chapter": "088_蒙恬列传", "para": "4", "seq": 3, "text": "始皇三十七年冬，行出游会稽，并海上，北走琅邪。", "len": 23}
{"sid": "088_蒙恬列传.4.s4", "chapter": "088_蒙恬列传", "para": "4", "seq": 4, "text": "道病，使蒙毅还祷山川，未反。", "len": 14}
{"sid": "088_蒙恬列传.4.s5", "chapter": "088_蒙恬列传", "para": "4", "seq": 5, "text": "始皇至沙丘崩，祕之，群臣莫知。", "len": 15}
{"sid": "088_蒙恬列传.4.s6", "chapter": "088_蒙恬列传", "para": "4", "seq": 6, "text": "是时丞相李斯、公子胡亥、中车府令赵高常从。", "len": 21}
{"sid": "088_蒙恬列传.4.s7", "chapter": "088_蒙恬列传", "para": "4", "seq": 7, "text": "高雅得幸於胡亥，欲立之，又怨蒙毅法治之而不为己也。", "len": 25}
{"sid": "088_蒙恬列传.4.s8", "chapter": "088_蒙恬列传", "para": "4", "seq": 8, "text": "因有贼心，乃与丞相李斯、公子胡亥阴谋，立胡亥为太子。", "len": 26}
{"sid": "088_蒙恬列传.5.s1", "chapter": "088_蒙恬列传", "para": "5", "seq": 1, "text": "太子已立，遣使者以罪赐公子扶苏、蒙恬死。", "len": 20}
{"sid": "088_蒙恬列传.5.s2", "chapter": "088_蒙恬列传", "para": "5", "seq": 2, "text": "扶苏已死，蒙恬疑而复请之。", "len": 13}
{"sid": "088_蒙恬列传.5.s3", "chapter": "088_蒙恬列传", "para": "5", "seq": 3, "text": "使者以蒙恬属吏，更置。", "len": 11}
{"sid": "088_蒙恬列传.5.s4", "chapter": "088_蒙恬列传", "para": "5", "seq": 4, "text": "胡亥以李斯舍人为护军。", "len": 11}
{"sid": "088_蒙恬列传.5.s5", "chapter": "088_蒙恬列传", "para": "5", "seq": 5, "text": "使者还报，胡亥已闻扶苏死，即欲释蒙恬。", "len": 19}
{"sid": "088_蒙恬列传.5.s6", "chapter": "088_蒙恬列传", "para": "5", "seq": 6, "text": "赵高恐蒙氏复贵而用事，怨之。", "len": 14}
{"sid": "088_蒙恬列传.6.s1", "chapter": "088_蒙恬列传", "para": "6", "seq": 1, "text": "毅还至，赵高因为胡亥忠计，欲以灭蒙氏，乃言曰：“臣闻先帝欲举贤立太子久矣，而毅谏曰‘不可’。", "len": 46}
{"sid": "088_蒙恬列传.6.s2", "chapter": "088_蒙恬列传", "para": "6", "seq": 2, "text": "若知贤而俞弗立，则是不忠而惑主也。", "len": 17}
{"sid": "088_蒙恬列传.6.s3", "chapter": "088_蒙恬列传", "para": "6", "seq": 3, "text": "以臣愚意，不若诛之。", "len": 10}
{"sid": "088_蒙恬列传.6.s4", "chapter": "088_蒙恬列传", "para": "6", "seq": 4, "text": "，” 胡亥听而系蒙毅於代。", "len": 13}
{"sid": "088_蒙恬列传.6.s5", "chapter": "088_蒙恬列传", "para": "6", "seq": 5, "text": "前已囚蒙恬於阳周。", "len": 9}
{"sid": "088_蒙恬列传.6.s6", "chapter": "088_蒙恬列传", "para": "6", "seq": 6, "text": "丧至咸阳，已葬，太子立为二世皇帝，而赵高亲近，日夜毁恶蒙氏，求其罪过，举劾之。", "len": 39}
{"sid": "088_蒙恬列传.7.s1", "chapter": "088_蒙恬列传", "para": "7", "seq": 1, "text": "子婴进谏曰：“臣闻故赵王迁杀其良臣李牧而用颜聚，燕王喜阴用荆轲之谋而倍秦之约，齐王建杀其故世忠臣而用后胜之议。", "len": 55}
{"sid": "088_蒙恬列传.7.s2", "chapter": "088_蒙恬列传", "para": "7", "seq": 2, "text": "此三君者，皆各以变古者失其国而殃及其身。", "len": 20}
{"sid": "088_蒙恬列传.7.s3", "chapter": "088_蒙恬列传", "para": "7", "seq": 3, "text": "今蒙氏，秦之大臣谋士也，而主欲一旦弃去之，臣窃以为不可。", "len": 28}
{"sid": "088_蒙恬列传.7.s4", "chapter": "088_蒙恬列传", "para": "7", "seq": 4, "text": "臣闻轻虑者不可以治国，独智者不可以存君。", "len": 20}
{"sid": "088_蒙恬列传.7.s5", "chapter": "088_蒙恬列传", "para": "7", "seq": 5, "text": "诛杀忠臣而立无节行之人，是内使群臣不相信而外使斗士之意离也，臣窃以为不可。", "len": 37}
{"sid": "088_蒙恬列传.7.s6", "chapter": "088_蒙恬列传", "para": "7", "seq": 6, "text": "” 胡亥不听。", "len": 7}
{"sid": "088_蒙恬列传.7.s7", "chapter": "088_蒙恬列传", "para": "7", "seq": 7, "text": "而遣御史曲宫乘传之代，令蒙毅曰：“先主欲立太子而卿难之。", "len": 28}
{"sid": "088_蒙恬列传.7.s8", "chapter": "088_蒙恬列传", "para": "7", "seq": 8, "text": "今丞相以卿为不忠，罪及其宗。", "len": 14}
{"sid": "088_蒙恬列传.7.s9", "chapter": "088_蒙恬列传", "para": "7", "seq": 9, "text": "朕不忍，乃赐卿死，亦甚幸矣。", "len": 14}
{"sid": "088_蒙恬列传.7.s10", "chapter": "088_蒙恬列传", "para": "7", "seq": 10, "text": "卿其图之！”", "len": 6}
{"sid": "088_蒙恬列传.8.s1", "chapter": "088_蒙恬列传", "para": "8", "seq": 1, "text": "毅对曰：“以臣不能得先主之意，则臣少宦，顺幸没世。", "len": 25}
{"sid": "088_蒙恬列传.8.s2", "chapter": "088_蒙恬列传", "para": "8", "seq": 2, "text": "可谓知意矣。", "len": 6}
{"sid": "088_蒙恬列传.8.s3", "chapter": "088_蒙恬列传", "para": "8", "seq": 3, "text": "以臣不知太子之能，则太子独从，周旋天下，去诸公子绝远，臣无所疑矣。", "len": 33}
{"sid": "088_蒙恬列传.8.s4", "chapter": "088_蒙恬列传", "para": "8", "seq": 4, "text": "夫先主之举用太子，数年之积也，臣乃何言之敢谏，何虑之敢谋！", "len": 29}
{"sid": "088_蒙恬列传.8.s5", "chapter": "088_蒙恬列传", "para": "8", "seq": 5, "text": "非敢饰辞以避死也，为羞累先主之名，原大夫为虑焉，使臣得死情实。", "len": 31}
{"sid": "088_蒙恬列传.8.s6", "chapter": "088_蒙恬列传", "para": "8", "seq": 6, "text": "且夫顺成全者，道之所贵也；刑杀者，道之所卒也。", "len": 23}
{"sid": "088_蒙恬列传.8.s7", "chapter": "088_蒙恬列传", "para": "8", "seq": 7, "text": "昔者秦穆公杀三良而死，罪百里奚而非其罪也，故立号曰‘缪’。", "len": 29}
{"sid": "088_蒙恬列传.8.s8", "chapter": "088_蒙恬列传", "para": "8", "seq": 8, "text": "昭襄王杀武安君白起。", "len": 10}
{"sid": "088_蒙恬列传.8.s9", "chapter": "088_蒙恬列传", "para": "8", "seq": 9, "text": "楚平王杀伍奢。", "len": 7}
{"sid": "088_蒙恬列传.8.s10", "chapter": "088_蒙恬列传", "para": "8", "seq": 10, "text": "吴王夫差杀伍子胥。", "len": 9}
{"sid": "088_蒙恬列传.8.s11", "chapter": "088_蒙恬列传", "para": "8", "seq": 11, "text": "此四君者，皆为大失，而天下非之，以其君为不明，以是籍於诸侯。", "len": 30}
{"sid": "088_蒙恬列传.8.s12", "chapter": "088_蒙恬列传", "para": "8", "seq": 12, "text": "故曰‘用道治者不杀无罪，而罚不加於无辜’。", "len": 21}
{"sid": "088_蒙恬列传.8.s13", "chapter": "088_蒙恬列传", "para": "8", "seq": 13, "text": "唯大夫留心！", "len": 6}
{"sid": "088_蒙恬列传.8.s14", "chapter": "088_蒙恬列传", "para": "8", "seq": 14, "text": "” 使者知胡亥之意，不听蒙毅之言，遂杀之。", "len": 21}
{"sid": "088_蒙恬列传.9.1.s1", "chapter": "088_蒙恬列传", "para": "9.1", "seq": 1, "text": "二世又遣使者之阳周，令蒙恬曰：“君之过多矣，而卿弟毅有大罪，法及内史。”", "len": 36}
{"sid": "088_蒙恬列传.9.2.s1", "chapter": "088_蒙恬列传", "para": "9.2", "seq": 1, "text": "恬曰：“自吾先人，及至子孙，积功信於秦三世矣。", "len": 23}
{"sid": "088_蒙恬列传.9.2.s2", "chapter": "088_蒙恬列传", "para": "9.2", "seq": 2, "text": "今臣将兵三十馀万，身虽囚系，其势足以倍畔，然自知必死而守义者，不敢辱先人之教，以不忘先主也。", "len": 46}
{"sid": "088_蒙恬列传.9.3.s1", "chapter": "088_蒙恬列传", "para": "9.3", "seq": 1, "text": "昔周成王初立，未离襁褓，周公旦负王以朝，卒定天下。", "len": 25}
{"sid": "088_蒙恬列传.9.3.s2", "chapter": "088_蒙恬列传", "para": "9.3", "seq": 2, "text": "及成王有病甚殆，公旦自揃其爪以沈於河，曰：‘王未有识，是旦执事。", "len": 32}
{"sid": "088_蒙恬列传.9.3.s3", "chapter": "088_蒙恬列传", "para": "9.3", "seq": 3, "text": "有罪殃，旦受其不祥。", "len": 10}
{"sid": "088_蒙恬列传.9.3.s4", "chapter": "088_蒙恬列传", "para": "9.3", "seq": 4, "text": "’乃书而藏之记府，可谓信矣。", "len": 14}
{"sid": "088_蒙恬列传.9.3.s5", "chapter": "088_蒙恬列传", "para": "9.3", "seq": 5, "text": "及王能治国，有贼臣言：‘周公旦欲为乱久矣，王若不备，必有大事。", "len": 31}
{"sid": "088_蒙恬列传.9.3.s6", "chapter": "088_蒙恬列传", "para": "9.3", "seq": 6, "text": "’王乃大怒，周公旦走而奔於楚。", "len": 15}
{"sid": "088_蒙恬列传.9.3.s7", "chapter": "088_蒙恬列传", "para": "9.3", "seq": 7, "text": "成王观於记府，得周公旦沈书，乃流涕曰：‘孰谓周公旦欲为乱乎！", "len": 30}
{"sid": "088_蒙恬列传.9.3.s8", "chapter": "088_蒙恬列传", "para": "9.3", "seq": 8, "text": "’杀言之者而反周公旦。", "len": 11}
{"sid": "088_蒙恬列传.9.3.s9", "chapter": "088_蒙恬列传", "para": "9.3", "seq": 9, "text": "故周书曰‘必参而伍之’。", "len": 12}
{"sid": "088_蒙恬列传.9.4.s1", "chapter": "088_蒙恬列传", "para": "9.4", "seq": 1, "text": "今恬之宗，世无二心，而事卒如此，是必孽臣逆乱，内陵之道也。", "len": 29}
{"sid": "088_蒙恬列传.9.4.s2", "chapter": "088_蒙恬列传", "para": "9.4", "seq": 2, "text": "夫成王失而复振则卒昌；桀杀关龙逢，纣杀王子比干而不悔，身死则国亡。", "len": 33}
{"sid": "088_蒙恬列传.9.4.s3", "chapter": "088_蒙恬列传", "para": "9.4", "seq": 3, "text": "臣故曰过可振而谏可觉也。", "len": 12}
{"sid": "088_蒙恬列传.9.4.s4", "chapter": "088_蒙恬列传", "para": "9.4", "seq": 4, "text": "察於参伍，上圣之法也。", "len": 11}
{"sid": "088_蒙恬列传.9.4.s5", "chapter": "088_蒙恬列传", "para": "9.4", "seq": 5, "text": "凡臣之言，非以求免於咎也，将以谏而死，原陛下为万民思从道也。”", "len": 31}
{"sid": "088_蒙恬列传.9.5.s1", "chapter": "088_蒙恬列传", "para": "9.5", "seq": 1, "text": "使者曰：“臣受诏行法於将军，不敢以将军言闻於上也。", "len": 25}
{"sid": "088_蒙恬列传.9.5.s2", "chapter": "088_蒙恬列传", "para": "9.5", "seq": 2, "text": "” 蒙恬喟然太息曰：“我何罪於天，无过而死乎？", "len": 23}
{"sid": "088_蒙恬列传.9.5.s3", "chapter": "088_蒙恬列传", "para": "9.5", "seq": 3, "text": "” 良久，徐曰：“恬罪固当死矣。", "len": 16}
{"sid": "088_蒙恬列传.9.5.s4", "chapter": "088_蒙恬列传", "para": "9.5", "seq": 4, "text": "起临洮属之辽东，城巉万馀里，此其中不能无绝地脉哉？", "len": 25}
{"sid": "088_蒙恬列传.9.5.s5", "chapter": "088_蒙恬列传", "para": "9.5", "seq": 5, "text": "此乃恬之罪也。", "len": 7}
{"sid": "088_蒙恬列传.9.5.s6", "chapter": "088_蒙恬列传", "para": "9.5", "seq": 6, "text": "” 乃吞药自杀。", "len": 8}
{"sid": "088_蒙恬列传.9.5.s7", "chapter": "088_蒙恬列传", "para": "9.5", "seq": 7, "text": "::: 太史公曰", "len": 8}
{"sid": "088_蒙恬列传.10.s1", "chapter": "088_蒙恬列传", "para": "10", "seq": 1, "text": "太史公曰：吾適北边，自直道归，行观蒙恬所为秦筑长城亭障，堑山堙谷，通直道，固轻百姓力矣。", "len": 44}
{"sid": "088_蒙恬列传.10.s2", "chapter": "088_蒙恬列传", "para": "10", "seq": 2, "text": "夫秦之初灭诸侯，天下之心未定，痍伤者未瘳，而恬为名将，不以此时彊谏，振百姓之急，养老存孤，务修众庶之和，而阿意兴功，此其兄弟遇诛，不亦宜乎！", "len": 70}
{"sid": "088_蒙恬列传.10.s3", "chapter": "088_蒙恬列传", "para": "10", "seq": 3, "text": "何乃罪地脉哉？", "len": 7}
{"sid": "088_蒙恬列传.10.s4", "chapter": "088_蒙恬列传", "para": "10", "seq": 4, "text": "::: ::: 太史公赞", "len": 12}
{"sid": "088_蒙恬列传.11.s1", "chapter": "088_蒙恬列传", "para": "11", "seq": 1, "text": "蒙氏秦将，内史忠贤。", "len": 10}
{"sid": "088_蒙恬列传.11.s2", "chapter": "088_蒙恬列传", "para": "11", "seq": 2, "text": "长城首筑，万里安边。", "len": 10}
{"sid": "088_蒙恬列传.11.s3", "chapter": "088_蒙恬列传", "para": "11", "seq": 3, "text": "赵高矫制，扶苏死焉。", "len": 10}
{"sid": "088_蒙恬列传.11.s4", "chapter": "088_蒙恬列传", "para": "11", "seq": 4, "text": "绝地何罪？", "len": 5}
{"sid": "088_蒙恬列传.11.s5", "chapter": "088_蒙恬列传", "para": "11", "seq": 5, "text": "劳人是愆。", "len": 5}
{"sid": "088_蒙恬列传.11.s6", "chapter": "088_蒙恬列传", "para": "11", "seq": 6, "text": "呼天欲诉，三代良然。", "len": 10}
{"sid": "088_蒙恬列传.11.s7", "chapter": "088_蒙恬列传", "para": "11", "seq": 7, "text": ":::", "len": 3}
