{"sid": "112_平津侯主父列传.1.s1", "chapter": "112_平津侯主父列传", "para": "1", "seq": 1, "text": "丞相公孙弘者，齐菑川国薛县人也，字季。", "len": 19}
{"sid": "112_平津侯主父列传.1.s2", "chapter": "112_平津侯主父列传", "para": "1", "seq": 2, "text": "少时为薛狱吏，有罪，免家贫，牧豕海上。", "len": 19}
{"sid": "112_平津侯主父列传.2.s1", "chapter": "112_平津侯主父列传", "para": "2", "seq": 1, "text": "年四十馀，乃学春秋杂说。", "len": 12}
{"sid": "112_平津侯主父列传.2.s2", "chapter": "112_平津侯主父列传", "para": "2", "seq": 2, "text": "养後母孝谨。", "len": 6}
{"sid": "112_平津侯主父列传.3.s1", "chapter": "112_平津侯主父列传", "para": "3", "seq": 1, "text": "建元元年，天子初即位，招贤良文学之士。", "len": 19}
{"sid": "112_平津侯主父列传.3.s2", "chapter": "112_平津侯主父列传", "para": "3", "seq": 2, "text": "是时弘年六十，徵以贤良为博士。", "len": 15}
{"sid": "112_平津侯主父列传.4.s1", "chapter": "112_平津侯主父列传", "para": "4", "seq": 1, "text": "使匈奴，还报，不合上意，上怒，以为不能，弘乃病免归。", "len": 26}
{"sid": "112_平津侯主父列传.5.s1", "chapter": "112_平津侯主父列传", "para": "5", "seq": 1, "text": "元光五年，有诏徵文学，菑川国复推上公孙弘。", "len": 21}
{"sid": "112_平津侯主父列传.6.s1", "chapter": "112_平津侯主父列传", "para": "6", "seq": 1, "text": "弘让谢国人曰：“臣已尝西应命，以不能罢归，原更推选。", "len": 26}
{"sid": "112_平津侯主父列传.6.s2", "chapter": "112_平津侯主父列传", "para": "6", "seq": 2, "text": "” 国人固推弘，弘至太常。", "len": 13}
{"sid": "112_平津侯主父列传.7.s1", "chapter": "112_平津侯主父列传", "para": "7", "seq": 1, "text": "太常令所徵儒士各对策，百馀人，弘第居下。", "len": 20}
{"sid": "112_平津侯主父列传.7.s2", "chapter": "112_平津侯主父列传", "para": "7", "seq": 2, "text": "策奏，天子擢弘对为第一。", "len": 12}
{"sid": "112_平津侯主父列传.7.s3", "chapter": "112_平津侯主父列传", "para": "7", "seq": 3, "text": "召入见，状貌甚丽，拜为博士。", "len": 14}
{"sid": "112_平津侯主父列传.8.s1", "chapter": "112_平津侯主父列传", "para": "8", "seq": 1, "text": "是时通西南夷道，置郡，巴蜀民苦之，诏使弘视之。", "len": 23}
{"sid": "112_平津侯主父列传.8.s2", "chapter": "112_平津侯主父列传", "para": "8", "seq": 2, "text": "还奏事，盛毁西南夷无所用，上不听。", "len": 17}
{"sid": "112_平津侯主父列传.9.s1", "chapter": "112_平津侯主父列传", "para": "9", "seq": 1, "text": "弘为人恢奇多闻，常称以为人主病不广大，人臣病不俭节。", "len": 26}
{"sid": "112_平津侯主父列传.9.s2", "chapter": "112_平津侯主父列传", "para": "9", "seq": 2, "text": "弘为布被，食不重肉。", "len": 10}
{"sid": "112_平津侯主父列传.9.s3", "chapter": "112_平津侯主父列传", "para": "9", "seq": 3, "text": "後母死，服丧三年。", "len": 9}
{"sid": "112_平津侯主父列传.10.s1", "chapter": "112_平津侯主父列传", "para": "10", "seq": 1, "text": "每朝会议，开陈其端，令人主自择，不肯面折庭争。", "len": 23}
{"sid": "112_平津侯主父列传.10.s2", "chapter": "112_平津侯主父列传", "para": "10", "seq": 2, "text": "於是天子察其行敦厚，辩论有馀，习文法吏事，而又缘饰以儒术，上大说之。", "len": 34}
{"sid": "112_平津侯主父列传.11.s1", "chapter": "112_平津侯主父列传", "para": "11", "seq": 1, "text": "二岁中，至左内史。", "len": 9}
{"sid": "112_平津侯主父列传.11.s2", "chapter": "112_平津侯主父列传", "para": "11", "seq": 2, "text": "弘奏事，有不可，不庭辩之。", "len": 13}
{"sid": "112_平津侯主父列传.12.s1", "chapter": "112_平津侯主父列传", "para": "12", "seq": 1, "text": "尝与主爵都尉汲黯请间，汲黯先发之，弘推其後，天子常说，所言皆听，以此日益亲贵。", "len": 39}
{"sid": "112_平津侯主父列传.13.s1", "chapter": "112_平津侯主父列传", "para": "13", "seq": 1, "text": "尝与公卿约议，至上前，皆倍其约以顺上旨。", "len": 20}
{"sid": "112_平津侯主父列传.13.s2", "chapter": "112_平津侯主父列传", "para": "13", "seq": 2, "text": "汲黯庭诘弘曰：“齐人多诈而无情实，始与臣等建此议，今皆倍之，不忠。”", "len": 34}
{"sid": "112_平津侯主父列传.14.s1", "chapter": "112_平津侯主父列传", "para": "14", "seq": 1, "text": "上问弘。", "len": 4}
{"sid": "112_平津侯主父列传.14.s2", "chapter": "112_平津侯主父列传", "para": "14", "seq": 2, "text": "弘谢曰：“夫知臣者以臣为忠，不知臣者以臣为不忠。", "len": 24}
{"sid": "112_平津侯主父列传.14.s3", "chapter": "112_平津侯主父列传", "para": "14", "seq": 3, "text": "” 上然弘言。", "len": 7}
{"sid": "112_平津侯主父列传.14.s4", "chapter": "112_平津侯主父列传", "para": "14", "seq": 4, "text": "左右幸臣每毁弘，上益厚遇之。", "len": 14}
{"sid": "112_平津侯主父列传.15.s1", "chapter": "112_平津侯主父列传", "para": "15", "seq": 1, "text": "元朔三年，张欧免，以弘为御史大夫。", "len": 17}
{"sid": "112_平津侯主父列传.16.s1", "chapter": "112_平津侯主父列传", "para": "16", "seq": 1, "text": "是时通西南夷，东置沧海，北筑朔方之郡。", "len": 19}
{"sid": "112_平津侯主父列传.16.s2", "chapter": "112_平津侯主父列传", "para": "16", "seq": 2, "text": "弘数谏，以为罢敝中国以奉无用之地，原罢之。", "len": 21}
{"sid": "112_平津侯主父列传.17.s1", "chapter": "112_平津侯主父列传", "para": "17", "seq": 1, "text": "於是天子乃使硃买臣等难弘置朔方之便。", "len": 18}
{"sid": "112_平津侯主父列传.17.s2", "chapter": "112_平津侯主父列传", "para": "17", "seq": 2, "text": "发十策，弘不得一。", "len": 9}
{"sid": "112_平津侯主父列传.18.s1", "chapter": "112_平津侯主父列传", "para": "18", "seq": 1, "text": "弘乃谢曰：“山东鄙人，不知其便若是，原罢西南夷、沧海而专奉朔方。", "len": 32}
{"sid": "112_平津侯主父列传.18.s2", "chapter": "112_平津侯主父列传", "para": "18", "seq": 2, "text": "” 上乃许之。", "len": 7}
{"sid": "112_平津侯主父列传.19.s1", "chapter": "112_平津侯主父列传", "para": "19", "seq": 1, "text": "汲黯曰：“弘位在三公，奉禄甚多。", "len": 16}
{"sid": "112_平津侯主父列传.19.s2", "chapter": "112_平津侯主父列传", "para": "19", "seq": 2, "text": "然为布被，此诈也。", "len": 9}
{"sid": "112_平津侯主父列传.19.s3", "chapter": "112_平津侯主父列传", "para": "19", "seq": 3, "text": "” 上问弘。", "len": 6}
{"sid": "112_平津侯主父列传.20.s1", "chapter": "112_平津侯主父列传", "para": "20", "seq": 1, "text": "弘谢曰：“有之。", "len": 8}
{"sid": "112_平津侯主父列传.20.s2", "chapter": "112_平津侯主父列传", "para": "20", "seq": 2, "text": "夫九卿与臣善者无过黯，然今日庭诘弘，诚中弘之病。", "len": 24}
{"sid": "112_平津侯主父列传.20.s3", "chapter": "112_平津侯主父列传", "para": "20", "seq": 3, "text": "夫以三公为布被，诚饰诈欲以钓名。", "len": 16}
{"sid": "112_平津侯主父列传.21.s1", "chapter": "112_平津侯主父列传", "para": "21", "seq": 1, "text": "且臣闻管仲相齐，有三归，侈拟於君，桓公以霸，亦上僭於君。", "len": 28}
{"sid": "112_平津侯主父列传.21.s2", "chapter": "112_平津侯主父列传", "para": "21", "seq": 2, "text": "晏婴相景公，食不重肉，妾不衣丝，齐国亦治，此下比於民。", "len": 27}
{"sid": "112_平津侯主父列传.22.s1", "chapter": "112_平津侯主父列传", "para": "22", "seq": 1, "text": "今臣弘位为御史大夫，而为布被，自九卿以下至於小吏，无差，诚如汲黯言。", "len": 34}
{"sid": "112_平津侯主父列传.22.s2", "chapter": "112_平津侯主父列传", "para": "22", "seq": 2, "text": "且无汲黯忠，陛下安得闻此言。”", "len": 15}
{"sid": "112_平津侯主父列传.23.s1", "chapter": "112_平津侯主父列传", "para": "23", "seq": 1, "text": "天子以为谦让，愈益厚之。", "len": 12}
{"sid": "112_平津侯主父列传.23.s2", "chapter": "112_平津侯主父列传", "para": "23", "seq": 2, "text": "卒以弘为丞相，封平津侯。", "len": 12}
{"sid": "112_平津侯主父列传.24.s1", "chapter": "112_平津侯主父列传", "para": "24", "seq": 1, "text": "弘为人意忌，外宽内深。", "len": 11}
{"sid": "112_平津侯主父列传.24.s2", "chapter": "112_平津侯主父列传", "para": "24", "seq": 2, "text": "诸尝与弘有卻者，虽详与善，阴报其祸。", "len": 18}
{"sid": "112_平津侯主父列传.25.s1", "chapter": "112_平津侯主父列传", "para": "25", "seq": 1, "text": "杀主父偃，徙董仲舒於胶西，皆弘之力也。", "len": 19}
{"sid": "112_平津侯主父列传.26.s1", "chapter": "112_平津侯主父列传", "para": "26", "seq": 1, "text": "食一肉脱粟之饭。", "len": 8}
{"sid": "112_平津侯主父列传.26.s2", "chapter": "112_平津侯主父列传", "para": "26", "seq": 2, "text": "故人所善宾客，仰衣食，弘奉禄皆以给之，家无所馀。", "len": 24}
{"sid": "112_平津侯主父列传.26.s3", "chapter": "112_平津侯主父列传", "para": "26", "seq": 3, "text": "士亦以此贤之。", "len": 7}
{"sid": "112_平津侯主父列传.27.s1", "chapter": "112_平津侯主父列传", "para": "27", "seq": 1, "text": "淮南、衡山谋反，治党与方急。", "len": 14}
{"sid": "112_平津侯主父列传.27.s2", "chapter": "112_平津侯主父列传", "para": "27", "seq": 2, "text": "弘病甚，自以为无功而封，位至丞相，宜佐明主填抚国家，使人由臣子之道。", "len": 34}
{"sid": "112_平津侯主父列传.27.s3", "chapter": "112_平津侯主父列传", "para": "27", "seq": 3, "text": "今诸侯有畔逆之计，此皆宰相奉职不称，恐窃病死，无以塞责。", "len": 28}
{"sid": "112_平津侯主父列传.28.s1", "chapter": "112_平津侯主父列传", "para": "28", "seq": 1, "text": "乃上书曰：“臣闻天下之通道五，所以行之者三。", "len": 22}
{"sid": "112_平津侯主父列传.28.s2", "chapter": "112_平津侯主父列传", "para": "28", "seq": 2, "text": "曰君臣，父子，兄弟，夫妇，长幼之序，此五者天下之通道也。", "len": 28}
{"sid": "112_平津侯主父列传.28.s3", "chapter": "112_平津侯主父列传", "para": "28", "seq": 3, "text": "智，仁，勇，此三者天下之通德，所以行之者也。", "len": 22}
{"sid": "112_平津侯主父列传.29.s1", "chapter": "112_平津侯主父列传", "para": "29", "seq": 1, "text": "故曰‘力行近乎仁，好问近乎智，知耻近乎勇’。", "len": 22}
{"sid": "112_平津侯主父列传.29.s2", "chapter": "112_平津侯主父列传", "para": "29", "seq": 2, "text": "知此三者，则知所以自治；知所以自治，然後知所以治人。", "len": 26}
{"sid": "112_平津侯主父列传.29.s3", "chapter": "112_平津侯主父列传", "para": "29", "seq": 3, "text": "天下未有不能自治而能治人者也，此百世不易之道也。", "len": 24}
{"sid": "112_平津侯主父列传.30.s1", "chapter": "112_平津侯主父列传", "para": "30", "seq": 1, "text": "今陛下躬行大孝，鉴三王，建周道，兼文武，厉贤予禄，量能授官。", "len": 30}
{"sid": "112_平津侯主父列传.30.s2", "chapter": "112_平津侯主父列传", "para": "30", "seq": 2, "text": "今臣弘罢驽之质，无汗马之劳，陛下过意擢臣弘卒伍之中，封为列侯，致位三公。", "len": 36}
{"sid": "112_平津侯主父列传.31.s1", "chapter": "112_平津侯主父列传", "para": "31", "seq": 1, "text": "臣弘行能不足以称，素有负薪之病，恐先狗马填沟壑，终无以报德塞责。", "len": 32}
{"sid": "112_平津侯主父列传.31.s2", "chapter": "112_平津侯主父列传", "para": "31", "seq": 2, "text": "原归侯印，乞骸骨，避贤者路。”", "len": 15}
{"sid": "112_平津侯主父列传.32.s1", "chapter": "112_平津侯主父列传", "para": "32", "seq": 1, "text": "天子报曰：“古者赏有功，褎有德，守成尚文，遭遇右武，未有易此者也。", "len": 33}
{"sid": "112_平津侯主父列传.32.s2", "chapter": "112_平津侯主父列传", "para": "32", "seq": 2, "text": "朕宿昔庶几获承尊位，惧不能宁，惟所与共为治者，君宜知之。", "len": 28}
{"sid": "112_平津侯主父列传.32.s3", "chapter": "112_平津侯主父列传", "para": "32", "seq": 3, "text": "盖君子善善恶恶，君若谨行，常在朕躬。", "len": 18}
{"sid": "112_平津侯主父列传.33.s1", "chapter": "112_平津侯主父列传", "para": "33", "seq": 1, "text": "君不幸罹霜露之病，何恙不已，乃上书归侯，乞骸骨，是章朕之不德也。", "len": 32}
{"sid": "112_平津侯主父列传.33.s2", "chapter": "112_平津侯主父列传", "para": "33", "seq": 2, "text": "今事少间，君其省思虑，一精神，辅以医药。”", "len": 21}
{"sid": "112_平津侯主父列传.34.s1", "chapter": "112_平津侯主父列传", "para": "34", "seq": 1, "text": "因赐告牛酒杂帛。", "len": 8}
{"sid": "112_平津侯主父列传.34.s2", "chapter": "112_平津侯主父列传", "para": "34", "seq": 2, "text": "居数月，病有瘳，视事。", "len": 11}
{"sid": "112_平津侯主父列传.35.s1", "chapter": "112_平津侯主父列传", "para": "35", "seq": 1, "text": "元狩二年，弘病，竟以丞相终。", "len": 14}
{"sid": "112_平津侯主父列传.35.s2", "chapter": "112_平津侯主父列传", "para": "35", "seq": 2, "text": "子度嗣为平津侯。", "len": 8}
{"sid": "112_平津侯主父列传.35.s3", "chapter": "112_平津侯主父列传", "para": "35", "seq": 3, "text": "度为山阳太守十馀岁，坐法失侯。", "len": 15}
{"sid": "112_平津侯主父列传.36.s1", "chapter": "112_平津侯主父列传", "para": "36", "seq": 1, "text": "主父偃者，齐临菑人也。", "len": 11}
{"sid": "112_平津侯主父列传.36.s2", "chapter": "112_平津侯主父列传", "para": "36", "seq": 2, "text": "学长短纵横之术，晚乃学易、春秋、百家言。", "len": 20}
{"sid": "112_平津侯主父列传.37.s1", "chapter": "112_平津侯主父列传", "para": "37", "seq": 1, "text": "游齐诸生间，莫能厚遇也。", "len": 12}
{"sid": "112_平津侯主父列传.37.s2", "chapter": "112_平津侯主父列传", "para": "37", "seq": 2, "text": "齐诸儒生相与排摈，不容於齐。", "len": 14}
{"sid": "112_平津侯主父列传.37.s3", "chapter": "112_平津侯主父列传", "para": "37", "seq": 3, "text": "家贫，假贷无所得，乃北游燕、赵、中山，皆莫能厚遇，为客甚困。", "len": 30}
{"sid": "112_平津侯主父列传.38.s1", "chapter": "112_平津侯主父列传", "para": "38", "seq": 1, "text": "孝武元光元年中，以为诸侯莫足游者，乃西入关见卫将军。", "len": 26}
{"sid": "112_平津侯主父列传.38.s2", "chapter": "112_平津侯主父列传", "para": "38", "seq": 2, "text": "卫将军数言上，上不召。", "len": 11}
{"sid": "112_平津侯主父列传.39.s1", "chapter": "112_平津侯主父列传", "para": "39", "seq": 1, "text": "资用乏，留久，诸公宾客多厌之，乃上书阙下。", "len": 21}
{"sid": "112_平津侯主父列传.39.s2", "chapter": "112_平津侯主父列传", "para": "39", "seq": 2, "text": "朝奏，暮召入见。", "len": 8}
{"sid": "112_平津侯主父列传.40.s1", "chapter": "112_平津侯主父列传", "para": "40", "seq": 1, "text": "所言九事，其八事为律令，一事谏伐匈奴。", "len": 19}
{"sid": "112_平津侯主父列传.40.s2", "chapter": "112_平津侯主父列传", "para": "40", "seq": 2, "text": "其辞曰：", "len": 4}
{"sid": "112_平津侯主父列传.41.s1", "chapter": "112_平津侯主父列传", "para": "41", "seq": 1, "text": "臣闻明主不恶切谏以博观，忠臣不敢避重诛以直谏，是故事无遗策而功流万世。", "len": 35}
{"sid": "112_平津侯主父列传.41.s2", "chapter": "112_平津侯主父列传", "para": "41", "seq": 2, "text": "今臣不敢隐忠避死以效愚计，原陛下幸赦而少察之。", "len": 23}
{"sid": "112_平津侯主父列传.42.s1", "chapter": "112_平津侯主父列传", "para": "42", "seq": 1, "text": "司马法曰：“国虽大，好战必亡；天下虽平，忘战必危。", "len": 25}
{"sid": "112_平津侯主父列传.42.s2", "chapter": "112_平津侯主父列传", "para": "42", "seq": 2, "text": "” 天下既平，天子大凯，春蒐秋狝，诸侯春振旅，秋治兵，所以不忘战也。", "len": 34}
{"sid": "112_平津侯主父列传.43.s1", "chapter": "112_平津侯主父列传", "para": "43", "seq": 1, "text": "且夫怒者逆德也，兵者凶器也，争者末节也。", "len": 20}
{"sid": "112_平津侯主父列传.43.s2", "chapter": "112_平津侯主父列传", "para": "43", "seq": 2, "text": "古之人君一怒必伏尸流血，故圣王重行之。", "len": 19}
{"sid": "112_平津侯主父列传.43.s3", "chapter": "112_平津侯主父列传", "para": "43", "seq": 3, "text": "夫务战胜穷武事者，未有不悔者也。", "len": 16}
{"sid": "112_平津侯主父列传.44.s1", "chapter": "112_平津侯主父列传", "para": "44", "seq": 1, "text": "昔秦皇帝任战胜之威，蚕食天下，并吞战国，海内为一，功齐三代。", "len": 30}
{"sid": "112_平津侯主父列传.44.s2", "chapter": "112_平津侯主父列传", "para": "44", "seq": 2, "text": "务胜不休，欲攻匈奴，李斯谏曰：“不可。", "len": 19}
{"sid": "112_平津侯主父列传.45.s1", "chapter": "112_平津侯主父列传", "para": "45", "seq": 1, "text": "夫匈奴无城郭之居，委积之守，迁徙鸟举，难得而制也。", "len": 25}
{"sid": "112_平津侯主父列传.45.s2", "chapter": "112_平津侯主父列传", "para": "45", "seq": 2, "text": "轻兵深入，粮食必绝；踵粮以行，重不及事。", "len": 20}
{"sid": "112_平津侯主父列传.45.s3", "chapter": "112_平津侯主父列传", "para": "45", "seq": 3, "text": "得其地不足以为利也，遇其民不可役而守也。", "len": 20}
{"sid": "112_平津侯主父列传.45.s4", "chapter": "112_平津侯主父列传", "para": "45", "seq": 4, "text": "胜必杀之，非民父母也。", "len": 11}
{"sid": "112_平津侯主父列传.45.s5", "chapter": "112_平津侯主父列传", "para": "45", "seq": 5, "text": "靡弊中国，快心匈奴，非长策也。”", "len": 16}
{"sid": "112_平津侯主父列传.46.s1", "chapter": "112_平津侯主父列传", "para": "46", "seq": 1, "text": "秦皇帝不听，遂使蒙恬将兵攻胡，辟地千里，以河为境。", "len": 25}
{"sid": "112_平津侯主父列传.46.s2", "chapter": "112_平津侯主父列传", "para": "46", "seq": 2, "text": "地固泽卤，不生五穀。", "len": 10}
{"sid": "112_平津侯主父列传.47.s1", "chapter": "112_平津侯主父列传", "para": "47", "seq": 1, "text": "然後发天下丁男以守北河。", "len": 12}
{"sid": "112_平津侯主父列传.47.s2", "chapter": "112_平津侯主父列传", "para": "47", "seq": 2, "text": "暴兵露师十有馀年，死者不可胜数，终不能逾河而北。", "len": 24}
{"sid": "112_平津侯主父列传.47.s3", "chapter": "112_平津侯主父列传", "para": "47", "seq": 3, "text": "是岂人众不足，兵革不备哉？", "len": 13}
{"sid": "112_平津侯主父列传.47.s4", "chapter": "112_平津侯主父列传", "para": "47", "seq": 4, "text": "其势不可也。", "len": 6}
{"sid": "112_平津侯主父列传.48.s1", "chapter": "112_平津侯主父列传", "para": "48", "seq": 1, "text": "又使天下蜚刍輓粟，起於黄、腄、琅邪负海之郡，转输北河，率三十锺而致一石。", "len": 36}
{"sid": "112_平津侯主父列传.48.s2", "chapter": "112_平津侯主父列传", "para": "48", "seq": 2, "text": "男子疾耕不足於粮饟，女子纺绩不足於帷幕。", "len": 20}
{"sid": "112_平津侯主父列传.48.s3", "chapter": "112_平津侯主父列传", "para": "48", "seq": 3, "text": "百姓靡敝，孤寡老弱不能相养，道路死者相望，盖天下始畔秦也。", "len": 29}
{"sid": "112_平津侯主父列传.49.s1", "chapter": "112_平津侯主父列传", "para": "49", "seq": 1, "text": "及至高皇帝定天下，略地於边，闻匈奴聚於代谷之外而欲击之。", "len": 28}
{"sid": "112_平津侯主父列传.49.s2", "chapter": "112_平津侯主父列传", "para": "49", "seq": 2, "text": "御史成进谏曰：“不可。", "len": 11}
{"sid": "112_平津侯主父列传.49.s3", "chapter": "112_平津侯主父列传", "para": "49", "seq": 3, "text": "夫匈奴之性，兽聚而鸟散，从之如搏影。", "len": 18}
{"sid": "112_平津侯主父列传.49.s4", "chapter": "112_平津侯主父列传", "para": "49", "seq": 4, "text": "今以陛下盛德攻匈奴，臣窃危之。”", "len": 16}
{"sid": "112_平津侯主父列传.50.s1", "chapter": "112_平津侯主父列传", "para": "50", "seq": 1, "text": "高帝不听，遂北至於代谷，果有平城之围。", "len": 19}
{"sid": "112_平津侯主父列传.50.s2", "chapter": "112_平津侯主父列传", "para": "50", "seq": 2, "text": "高皇帝盖悔之甚，乃使刘敬往结和亲之约，然後天下忘干戈之事。", "len": 29}
{"sid": "112_平津侯主父列传.51.s1", "chapter": "112_平津侯主父列传", "para": "51", "seq": 1, "text": "故兵法曰“兴师十万，日费千金”。", "len": 16}
{"sid": "112_平津侯主父列传.51.s2", "chapter": "112_平津侯主父列传", "para": "51", "seq": 2, "text": "夫秦常积众暴兵数十万人，虽有覆军杀将系虏单于之功，亦適足以结怨深雠，不足以偿天下之费。", "len": 43}
{"sid": "112_平津侯主父列传.52.s1", "chapter": "112_平津侯主父列传", "para": "52", "seq": 1, "text": "夫上虚府库，下敝百姓，甘心於外国，非完事也。", "len": 22}
{"sid": "112_平津侯主父列传.52.s2", "chapter": "112_平津侯主父列传", "para": "52", "seq": 2, "text": "夫匈奴难得而制，非一世也。", "len": 13}
{"sid": "112_平津侯主父列传.52.s3", "chapter": "112_平津侯主父列传", "para": "52", "seq": 3, "text": "行盗侵驱，所以为业也，天性固然。", "len": 16}
{"sid": "112_平津侯主父列传.52.s4", "chapter": "112_平津侯主父列传", "para": "52", "seq": 4, "text": "上及虞夏殷周，固弗程督，禽兽畜之，不属为人。", "len": 22}
{"sid": "112_平津侯主父列传.53.s1", "chapter": "112_平津侯主父列传", "para": "53", "seq": 1, "text": "夫上不观虞夏殷周之统，而下近世之失，此臣之所大忧，百姓之所疾苦也。", "len": 33}
{"sid": "112_平津侯主父列传.53.s2", "chapter": "112_平津侯主父列传", "para": "53", "seq": 2, "text": "且夫兵久则变生，事苦则虑易。", "len": 14}
{"sid": "112_平津侯主父列传.54.s1", "chapter": "112_平津侯主父列传", "para": "54", "seq": 1, "text": "乃使边境之民弊靡愁苦而有离心，将吏相疑而外市，故尉佗、章邯得以成其私也。", "len": 36}
{"sid": "112_平津侯主父列传.54.s2", "chapter": "112_平津侯主父列传", "para": "54", "seq": 2, "text": "夫秦政之所以不行者，权分乎二子，此得失之效也。", "len": 23}
{"sid": "112_平津侯主父列传.55.s1", "chapter": "112_平津侯主父列传", "para": "55", "seq": 1, "text": "故周书曰“安危在出令，存亡在所用”。", "len": 18}
{"sid": "112_平津侯主父列传.55.s2", "chapter": "112_平津侯主父列传", "para": "55", "seq": 2, "text": "原陛下详察之，少加意而熟虑焉。", "len": 15}
{"sid": "112_平津侯主父列传.56.s1", "chapter": "112_平津侯主父列传", "para": "56", "seq": 1, "text": "是时赵人徐乐、齐人严安俱上书言世务，各一事。", "len": 22}
{"sid": "112_平津侯主父列传.57.s1", "chapter": "112_平津侯主父列传", "para": "57", "seq": 1, "text": "徐乐曰：臣闻天下之患在於土崩，不在於瓦解，古今一也。", "len": 26}
{"sid": "112_平津侯主父列传.58.s1", "chapter": "112_平津侯主父列传", "para": "58", "seq": 1, "text": "何谓土崩？", "len": 5}
{"sid": "112_平津侯主父列传.58.s2", "chapter": "112_平津侯主父列传", "para": "58", "seq": 2, "text": "秦之末世是也。", "len": 7}
{"sid": "112_平津侯主父列传.58.s3", "chapter": "112_平津侯主父列传", "para": "58", "seq": 3, "text": "陈涉无千乘之尊，尺土之地，身非王公大人名族之後，无乡曲之誉，非有孔、墨、曾子之贤，陶硃、猗顿之富也，然起穷巷，奋棘矜，偏袒大呼而天下从风，此其故何也？", "len": 75}
{"sid": "112_平津侯主父列传.59.s1", "chapter": "112_平津侯主父列传", "para": "59", "seq": 1, "text": "由民困而主不恤，下怨而上不知，俗已乱而政不脩，此三者陈涉之所以为资也。", "len": 35}
{"sid": "112_平津侯主父列传.59.s2", "chapter": "112_平津侯主父列传", "para": "59", "seq": 2, "text": "是之谓土崩。", "len": 6}
{"sid": "112_平津侯主父列传.59.s3", "chapter": "112_平津侯主父列传", "para": "59", "seq": 3, "text": "故曰天下之患在於土崩。", "len": 11}
{"sid": "112_平津侯主父列传.60.s1", "chapter": "112_平津侯主父列传", "para": "60", "seq": 1, "text": "何谓瓦解？", "len": 5}
{"sid": "112_平津侯主父列传.60.s2", "chapter": "112_平津侯主父列传", "para": "60", "seq": 2, "text": "吴、楚、齐、赵之兵是也。", "len": 12}
{"sid": "112_平津侯主父列传.60.s3", "chapter": "112_平津侯主父列传", "para": "60", "seq": 3, "text": "七国谋为大逆，号皆称万乘之君，带甲数十万，威足以严其境内，财足以劝其士民，然不能西攘尺寸之地而身为禽於中原者，此其故何也？", "len": 61}
{"sid": "112_平津侯主父列传.61.s1", "chapter": "112_平津侯主父列传", "para": "61", "seq": 1, "text": "非权轻於匹夫而兵弱於陈涉也，当是之时，先帝之德泽未衰而安土乐俗之民众，故诸侯无境外之助。", "len": 44}
{"sid": "112_平津侯主父列传.61.s2", "chapter": "112_平津侯主父列传", "para": "61", "seq": 2, "text": "此之谓瓦解，故曰天下之患不在瓦解。", "len": 17}
{"sid": "112_平津侯主父列传.62.s1", "chapter": "112_平津侯主父列传", "para": "62", "seq": 1, "text": "由是观之，天下诚有土崩之势，虽布衣穷处之士或首恶而危海内，陈涉是也。", "len": 34}
{"sid": "112_平津侯主父列传.62.s2", "chapter": "112_平津侯主父列传", "para": "62", "seq": 2, "text": "况三晋之君或存乎！", "len": 9}
{"sid": "112_平津侯主父列传.63.s1", "chapter": "112_平津侯主父列传", "para": "63", "seq": 1, "text": "天下虽未有大治也，诚能无土崩之势，虽有彊国劲兵不得旋踵而身为禽矣，吴、楚、齐、赵是也。", "len": 43}
{"sid": "112_平津侯主父列传.63.s2", "chapter": "112_平津侯主父列传", "para": "63", "seq": 2, "text": "况群臣百姓能为乱乎哉！", "len": 11}
{"sid": "112_平津侯主父列传.63.s3", "chapter": "112_平津侯主父列传", "para": "63", "seq": 3, "text": "此二体者，安危之明要也，贤主所留意而深察也。", "len": 22}
{"sid": "112_平津侯主父列传.64.s1", "chapter": "112_平津侯主父列传", "para": "64", "seq": 1, "text": "间者关东五穀不登，年岁未复，民多穷困，重之以边境之事，推数循理而观之，则民且有不安其处者矣。", "len": 46}
{"sid": "112_平津侯主父列传.64.s2", "chapter": "112_平津侯主父列传", "para": "64", "seq": 2, "text": "不安故易动。", "len": 6}
{"sid": "112_平津侯主父列传.64.s3", "chapter": "112_平津侯主父列传", "para": "64", "seq": 3, "text": "易动者，土崩之势也。", "len": 10}
{"sid": "112_平津侯主父列传.65.s1", "chapter": "112_平津侯主父列传", "para": "65", "seq": 1, "text": "故贤主独观万化之原，明於安危之机，脩之庙堂之上，而销未形之患。", "len": 31}
{"sid": "112_平津侯主父列传.65.s2", "chapter": "112_平津侯主父列传", "para": "65", "seq": 2, "text": "其要，期使天下无土崩之势而已矣。", "len": 16}
{"sid": "112_平津侯主父列传.66.s1", "chapter": "112_平津侯主父列传", "para": "66", "seq": 1, "text": "故虽有彊国劲兵，陛下逐走兽，射蜚鸟，弘游燕之囿，淫纵恣之观，极驰骋之乐，自若也。", "len": 40}
{"sid": "112_平津侯主父列传.66.s2", "chapter": "112_平津侯主父列传", "para": "66", "seq": 2, "text": "金石丝竹之声不绝於耳，帷帐之私俳优侏儒之笑不乏於前，而天下无宿忧。", "len": 33}
{"sid": "112_平津侯主父列传.67.s1", "chapter": "112_平津侯主父列传", "para": "67", "seq": 1, "text": "名何必汤武，俗何必成康！", "len": 12}
{"sid": "112_平津侯主父列传.67.s2", "chapter": "112_平津侯主父列传", "para": "67", "seq": 2, "text": "虽然，臣窃以为陛下天然之圣，宽仁之资，而诚以天下为务，则汤武之名不难侔，而成康之俗可复兴也。", "len": 46}
{"sid": "112_平津侯主父列传.68.s1", "chapter": "112_平津侯主父列传", "para": "68", "seq": 1, "text": "此二体者立，然後处尊安之实，扬名广誉於当世，亲天下而服四夷，馀恩遗德为数世隆，南面负扆摄袂而揖王公，此陛下之所服也。", "len": 58}
{"sid": "112_平津侯主父列传.69.s1", "chapter": "112_平津侯主父列传", "para": "69", "seq": 1, "text": "臣闻图王不成，其敝足以安。", "len": 13}
{"sid": "112_平津侯主父列传.69.s2", "chapter": "112_平津侯主父列传", "para": "69", "seq": 2, "text": "安则陛下何求而不得，何为而不成，何征而不服乎哉！", "len": 24}
{"sid": "112_平津侯主父列传.70.s1", "chapter": "112_平津侯主父列传", "para": "70", "seq": 1, "text": "严安上书曰：臣闻周有天下，其治三百馀岁，成康其隆也，刑错四十馀年而不用。", "len": 36}
{"sid": "112_平津侯主父列传.70.s2", "chapter": "112_平津侯主父列传", "para": "70", "seq": 2, "text": "及其衰也，亦三百馀岁，故五伯更起。", "len": 17}
{"sid": "112_平津侯主父列传.71.s1", "chapter": "112_平津侯主父列传", "para": "71", "seq": 1, "text": "五伯者，常佐天子兴利除害，诛暴禁邪，匡正海内，以尊天子。", "len": 28}
{"sid": "112_平津侯主父列传.71.s2", "chapter": "112_平津侯主父列传", "para": "71", "seq": 2, "text": "五伯既没，贤圣莫续，天子孤弱，号令不行。", "len": 20}
{"sid": "112_平津侯主父列传.72.s1", "chapter": "112_平津侯主父列传", "para": "72", "seq": 1, "text": "诸侯恣行，彊陵弱，众暴寡，田常篡齐，六卿分晋，并为战国，此民之始苦也。", "len": 35}
{"sid": "112_平津侯主父列传.72.s2", "chapter": "112_平津侯主父列传", "para": "72", "seq": 2, "text": "於是彊国务攻，弱国备守，合从连横，驰车击毂，介胄生虮虱，民无所告愬。", "len": 34}
{"sid": "112_平津侯主父列传.73.s1", "chapter": "112_平津侯主父列传", "para": "73", "seq": 1, "text": "及至秦王，蚕食天下，并吞战国，称号曰皇帝，主海内之政，坏诸侯之城，销其兵，铸以为锺虡，示不复用。", "len": 48}
{"sid": "112_平津侯主父列传.74.s1", "chapter": "112_平津侯主父列传", "para": "74", "seq": 1, "text": "元元黎民得免於战国，逢明天子，人人自以为更生。", "len": 23}
{"sid": "112_平津侯主父列传.74.s2", "chapter": "112_平津侯主父列传", "para": "74", "seq": 2, "text": "乡使秦缓其刑罚，薄赋敛，省繇役，贵仁义，贱权利，上笃厚，下智巧，变风易俗，化於海内，则世世必安矣。", "len": 49}
{"sid": "112_平津侯主父列传.75.s1", "chapter": "112_平津侯主父列传", "para": "75", "seq": 1, "text": "秦不行是风而其故俗，为智巧权利者进，笃厚忠信者退；法严政峻，谄谀者众，日闻其美，意广心轶。", "len": 45}
{"sid": "112_平津侯主父列传.76.s1", "chapter": "112_平津侯主父列传", "para": "76", "seq": 1, "text": "欲肆威海外，乃使蒙恬将兵以北攻胡，辟地进境，戍於北河，蜚刍輓粟以随其後。", "len": 36}
{"sid": "112_平津侯主父列传.76.s2", "chapter": "112_平津侯主父列传", "para": "76", "seq": 2, "text": "又使尉屠睢将楼船之士南攻百越，使监禄凿渠运粮，深入越，越人遁逃。", "len": 32}
{"sid": "112_平津侯主父列传.77.s1", "chapter": "112_平津侯主父列传", "para": "77", "seq": 1, "text": "旷日持久，粮食绝乏，越人击之，秦兵大败。", "len": 20}
{"sid": "112_平津侯主父列传.77.s2", "chapter": "112_平津侯主父列传", "para": "77", "seq": 2, "text": "秦乃使尉佗将卒以戍越。", "len": 11}
{"sid": "112_平津侯主父列传.78.s1", "chapter": "112_平津侯主父列传", "para": "78", "seq": 1, "text": "当是时，秦祸北构於胡，南挂於越，宿兵无用之地，进而不得退。", "len": 29}
{"sid": "112_平津侯主父列传.78.s2", "chapter": "112_平津侯主父列传", "para": "78", "seq": 2, "text": "行十馀年，丁男被甲，丁女转输，苦不聊生，自经於道树，死者相望。", "len": 31}
{"sid": "112_平津侯主父列传.79.s1", "chapter": "112_平津侯主父列传", "para": "79", "seq": 1, "text": "及秦皇帝崩，天下大叛。", "len": 11}
{"sid": "112_平津侯主父列传.79.s2", "chapter": "112_平津侯主父列传", "para": "79", "seq": 2, "text": "陈胜、吴广举陈，武臣、张耳举赵，项梁举吴，田儋举齐，景驹举郢，周市举魏，韩广举燕，穷山通谷豪士并起，不可胜载也。", "len": 56}
{"sid": "112_平津侯主父列传.80.s1", "chapter": "112_平津侯主父列传", "para": "80", "seq": 1, "text": "然皆非公侯之後，非长官之吏也。", "len": 15}
{"sid": "112_平津侯主父列传.80.s2", "chapter": "112_平津侯主父列传", "para": "80", "seq": 2, "text": "无尺寸之势，起闾巷，杖棘矜，应时而皆动，不谋而俱起，不约而同会，壤长地进，至于霸王，时教使然也。", "len": 48}
{"sid": "112_平津侯主父列传.81.s1", "chapter": "112_平津侯主父列传", "para": "81", "seq": 1, "text": "秦贵为天子，富有天下，灭世绝祀者，穷兵之祸也。", "len": 23}
{"sid": "112_平津侯主父列传.81.s2", "chapter": "112_平津侯主父列传", "para": "81", "seq": 2, "text": "故周失之弱，秦失之彊，不变之患也。", "len": 17}
{"sid": "112_平津侯主父列传.82.s1", "chapter": "112_平津侯主父列传", "para": "82", "seq": 1, "text": "今欲招南夷，朝夜郎，降羌僰，略濊州，建城邑，深入匈奴，燔其茏城，议者美之。", "len": 37}
{"sid": "112_平津侯主父列传.82.s2", "chapter": "112_平津侯主父列传", "para": "82", "seq": 2, "text": "此人臣之利也，非天下之长策也。", "len": 15}
{"sid": "112_平津侯主父列传.83.s1", "chapter": "112_平津侯主父列传", "para": "83", "seq": 1, "text": "今中国无狗吠之惊，而外累於远方之备，靡敝国家，非所以子民也。", "len": 30}
{"sid": "112_平津侯主父列传.83.s2", "chapter": "112_平津侯主父列传", "para": "83", "seq": 2, "text": "行无穷之欲，甘心快意，结怨於匈奴，非所以安边也。", "len": 24}
{"sid": "112_平津侯主父列传.83.s3", "chapter": "112_平津侯主父列传", "para": "83", "seq": 3, "text": "祸结而不解，兵休而复起，近者愁苦，远者惊骇，非所以持久也。", "len": 29}
{"sid": "112_平津侯主父列传.84.s1", "chapter": "112_平津侯主父列传", "para": "84", "seq": 1, "text": "今天下锻甲砥剑，桥箭累弦，转输运粮，未见休时，此天下之所共忧也。", "len": 32}
{"sid": "112_平津侯主父列传.84.s2", "chapter": "112_平津侯主父列传", "para": "84", "seq": 2, "text": "夫兵久而变起，事烦而虑生。", "len": 13}
{"sid": "112_平津侯主父列传.85.s1", "chapter": "112_平津侯主父列传", "para": "85", "seq": 1, "text": "今外郡之地或几千里，列城数十，形束壤制，旁胁诸侯，非公室之利也。", "len": 32}
{"sid": "112_平津侯主父列传.85.s2", "chapter": "112_平津侯主父列传", "para": "85", "seq": 2, "text": "上观齐晋之所以亡者，公室卑削，六卿大盛也；下观秦之所以灭者，严法刻深，欲大无穷也。", "len": 41}
{"sid": "112_平津侯主父列传.86.s1", "chapter": "112_平津侯主父列传", "para": "86", "seq": 1, "text": "今郡守之权，非特六卿之重也；地几千里，非特闾巷之资也；甲兵器械，非特棘矜之用也：以遭万世之变，则不可称讳也。", "len": 54}
{"sid": "112_平津侯主父列传.87.s1", "chapter": "112_平津侯主父列传", "para": "87", "seq": 1, "text": "书奏天子，天子召见三人，谓曰：“公等皆安在？", "len": 22}
{"sid": "112_平津侯主父列传.87.s2", "chapter": "112_平津侯主父列传", "para": "87", "seq": 2, "text": "何相见之晚也！”", "len": 8}
{"sid": "112_平津侯主父列传.88.s1", "chapter": "112_平津侯主父列传", "para": "88", "seq": 1, "text": "於是上乃拜主父偃、徐乐、严安为郎中。", "len": 18}
{"sid": "112_平津侯主父列传.88.s2", "chapter": "112_平津侯主父列传", "para": "88", "seq": 2, "text": "数见，上疏言事，诏拜偃为谒者，迁为中大夫。", "len": 21}
{"sid": "112_平津侯主父列传.88.s3", "chapter": "112_平津侯主父列传", "para": "88", "seq": 3, "text": "一岁中四迁偃。", "len": 7}
{"sid": "112_平津侯主父列传.89.s1", "chapter": "112_平津侯主父列传", "para": "89", "seq": 1, "text": "偃说上曰：“古者诸侯不过百里，彊弱之形易制。", "len": 22}
{"sid": "112_平津侯主父列传.89.s2", "chapter": "112_平津侯主父列传", "para": "89", "seq": 2, "text": "今诸侯或连城数十，地方千里，缓则骄奢易为淫乱，急则阻其彊而合从以逆京师。", "len": 36}
{"sid": "112_平津侯主父列传.90.s1", "chapter": "112_平津侯主父列传", "para": "90", "seq": 1, "text": "今以法割削之，则逆节萌起，前日晁错是也。", "len": 20}
{"sid": "112_平津侯主父列传.90.s2", "chapter": "112_平津侯主父列传", "para": "90", "seq": 2, "text": "今诸侯子弟或十数，而適嗣代立，馀虽骨肉，无尺寸地封，则仁孝之道不宣。", "len": 34}
{"sid": "112_平津侯主父列传.91.s1", "chapter": "112_平津侯主父列传", "para": "91", "seq": 1, "text": "原陛下令诸侯得推恩分子弟，以地侯之。", "len": 18}
{"sid": "112_平津侯主父列传.91.s2", "chapter": "112_平津侯主父列传", "para": "91", "seq": 2, "text": "彼人人喜得所原，上以德施，实分其国，不削而稍弱矣。", "len": 25}
{"sid": "112_平津侯主父列传.91.s3", "chapter": "112_平津侯主父列传", "para": "91", "seq": 3, "text": "“於是上从其计。", "len": 8}
{"sid": "112_平津侯主父列传.92.s1", "chapter": "112_平津侯主父列传", "para": "92", "seq": 1, "text": "又说上曰：“茂陵初立，天下豪桀并兼之家，乱众之民，皆可徙茂陵，内实京师，外销奸猾，此所谓不诛而害除。", "len": 50}
{"sid": "112_平津侯主父列传.92.s2", "chapter": "112_平津侯主父列传", "para": "92", "seq": 2, "text": "” 上又从其计。", "len": 8}
{"sid": "112_平津侯主父列传.93.s1", "chapter": "112_平津侯主父列传", "para": "93", "seq": 1, "text": "尊立卫皇后，及发燕王定国阴事，盖偃有功焉。", "len": 21}
{"sid": "112_平津侯主父列传.93.s2", "chapter": "112_平津侯主父列传", "para": "93", "seq": 2, "text": "大臣皆畏其口，赂遗累千金。", "len": 13}
{"sid": "112_平津侯主父列传.94.s1", "chapter": "112_平津侯主父列传", "para": "94", "seq": 1, "text": "人或说偃曰：“太横矣。", "len": 11}
{"sid": "112_平津侯主父列传.94.s2", "chapter": "112_平津侯主父列传", "para": "94", "seq": 2, "text": "” 主父曰：“臣结发游学四十馀年，身不得遂，亲不以为子，昆弟不收，宾客弃我，我戹戹日久矣。", "len": 45}
{"sid": "112_平津侯主父列传.95.s1", "chapter": "112_平津侯主父列传", "para": "95", "seq": 1, "text": "且丈夫生不五鼎食，死即五鼎烹耳。", "len": 16}
{"sid": "112_平津侯主父列传.95.s2", "chapter": "112_平津侯主父列传", "para": "95", "seq": 2, "text": "吾日暮途远，故倒行暴施之。”", "len": 14}
{"sid": "112_平津侯主父列传.96.s1", "chapter": "112_平津侯主父列传", "para": "96", "seq": 1, "text": "偃盛言朔方地肥饶，外阻河，蒙恬城之以逐匈奴，内省转输戍漕，广中国，灭胡之本也。", "len": 39}
{"sid": "112_平津侯主父列传.97.s1", "chapter": "112_平津侯主父列传", "para": "97", "seq": 1, "text": "上览其说，下公卿议，皆言不便。", "len": 15}
{"sid": "112_平津侯主父列传.97.s2", "chapter": "112_平津侯主父列传", "para": "97", "seq": 2, "text": "公孙弘曰：“秦时常发三十万众筑北河，终不可就，已而弃之。”", "len": 29}
{"sid": "112_平津侯主父列传.98.s1", "chapter": "112_平津侯主父列传", "para": "98", "seq": 1, "text": "主父偃盛言其便，上竟用主父计，立朔方郡。", "len": 20}
{"sid": "112_平津侯主父列传.99.s1", "chapter": "112_平津侯主父列传", "para": "99", "seq": 1, "text": "元朔二年，主父言齐王内淫佚行僻，上拜主父为齐相。", "len": 24}
{"sid": "112_平津侯主父列传.100.s1", "chapter": "112_平津侯主父列传", "para": "100", "seq": 1, "text": "至齐，遍召昆弟宾客，散五百金予之，数之曰：”始吾贫时，昆弟不我衣食，宾客不我内门；今吾相齐，诸君迎我或千里。", "len": 54}
{"sid": "112_平津侯主父列传.100.s2", "chapter": "112_平津侯主父列传", "para": "100", "seq": 2, "text": "吾与诸君绝矣，毋复入偃之门！”", "len": 15}
{"sid": "112_平津侯主父列传.101.s1", "chapter": "112_平津侯主父列传", "para": "101", "seq": 1, "text": "乃使人以王与姊奸事动王，王以为终不得脱罪，恐效燕王论死，乃自杀。", "len": 32}
{"sid": "112_平津侯主父列传.101.s2", "chapter": "112_平津侯主父列传", "para": "101", "seq": 2, "text": "有司以闻。", "len": 5}
{"sid": "112_平津侯主父列传.102.s1", "chapter": "112_平津侯主父列传", "para": "102", "seq": 1, "text": "主父始为布衣时，尝游燕、赵，及其贵，发燕事。", "len": 22}
{"sid": "112_平津侯主父列传.102.s2", "chapter": "112_平津侯主父列传", "para": "102", "seq": 2, "text": "赵王恐其为国患，欲上书言其阴事，为偃居中，不敢发。", "len": 25}
{"sid": "112_平津侯主父列传.103.s1", "chapter": "112_平津侯主父列传", "para": "103", "seq": 1, "text": "及为齐相，出关，即使人上书，告言主父偃受诸侯金，以故诸侯子弟多以得封者。", "len": 36}
{"sid": "112_平津侯主父列传.104.s1", "chapter": "112_平津侯主父列传", "para": "104", "seq": 1, "text": "及齐王自杀，上闻大怒，以为主父劫其王令自杀，乃徵下吏治。", "len": 28}
{"sid": "112_平津侯主父列传.104.s2", "chapter": "112_平津侯主父列传", "para": "104", "seq": 2, "text": "主父服受诸侯金，实不劫王令自杀。", "len": 16}
{"sid": "112_平津侯主父列传.105.s1", "chapter": "112_平津侯主父列传", "para": "105", "seq": 1, "text": "上欲勿诛，是时公孙弘为御史大夫，乃言曰：“齐王自杀无後，国除为郡，入汉，主父偃本首恶，陛下不诛主父偃，无以谢天下。", "len": 57}
{"sid": "112_平津侯主父列传.105.s2", "chapter": "112_平津侯主父列传", "para": "105", "seq": 2, "text": "” 乃遂族主父偃。", "len": 9}
{"sid": "112_平津侯主父列传.106.s1", "chapter": "112_平津侯主父列传", "para": "106", "seq": 1, "text": "主父方贵幸时，宾客以千数，及其族死，无一人收者，唯独洨孔车收葬之。", "len": 33}
{"sid": "112_平津侯主父列传.106.s2", "chapter": "112_平津侯主父列传", "para": "106", "seq": 2, "text": "天子後闻之，以为孔车长者也。", "len": 14}
{"sid": "112_平津侯主父列传.106.s3", "chapter": "112_平津侯主父列传", "para": "106", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "112_平津侯主父列传.107.s1", "chapter": "112_平津侯主父列传", "para": "107", "seq": 1, "text": "太史公曰：公孙弘行义虽脩，然亦遇时。", "len": 18}
{"sid": "112_平津侯主父列传.107.s2", "chapter": "112_平津侯主父列传", "para": "107", "seq": 2, "text": "汉兴八十馀年矣，上方乡文学，招俊乂，以广儒墨，弘为举首。", "len": 28}
{"sid": "112_平津侯主父列传.107.s3", "chapter": "112_平津侯主父列传", "para": "107", "seq": 3, "text": "主父偃当路，诸公皆誉之，及名败身诛，士争言其恶。", "len": 24}
{"sid": "112_平津侯主父列传.107.s4", "chapter": "112_平津侯主父列传", "para": "107", "seq": 4, "text": "悲夫！", "len": 3}
{"sid": "112_平津侯主父列传.107.s5", "chapter": "112_平津侯主父列传", "para": "107", "seq": 5, "text": ":::", "len": 3}
{"sid": "112_平津侯主父列传.108.s1", "chapter": "112_平津侯主父列传", "para": "108", "seq": 1, "text": "太皇太后诏大司徒大司空：“盖闻治国之道，富民为始；富民之要，在於节俭。", "len": 35}
{"sid": "112_平津侯主父列传.108.s2", "chapter": "112_平津侯主父列传", "para": "108", "seq": 2, "text": "孝经曰‘安上治民，莫善於礼’。", "len": 15}
{"sid": "112_平津侯主父列传.108.s3", "chapter": "112_平津侯主父列传", "para": "108", "seq": 3, "text": "‘礼，与奢也宁俭’。", "len": 10}
{"sid": "112_平津侯主父列传.109.s1", "chapter": "112_平津侯主父列传", "para": "109", "seq": 1, "text": "昔者管仲相齐桓，霸诸侯，有九合一匡之功，而仲尼谓之不知礼，以其奢泰侈拟於君故也。", "len": 40}
{"sid": "112_平津侯主父列传.109.s2", "chapter": "112_平津侯主父列传", "para": "109", "seq": 2, "text": "夏禹卑宫室，恶衣服，後圣不循。", "len": 15}
{"sid": "112_平津侯主父列传.110.s1", "chapter": "112_平津侯主父列传", "para": "110", "seq": 1, "text": "由此言之，治之盛也，德优矣，莫高於俭。", "len": 19}
{"sid": "112_平津侯主父列传.110.s2", "chapter": "112_平津侯主父列传", "para": "110", "seq": 2, "text": "俭化俗民，则尊卑之序得，而骨肉之恩亲，争讼之原息。", "len": 25}
{"sid": "112_平津侯主父列传.110.s3", "chapter": "112_平津侯主父列传", "para": "110", "seq": 3, "text": "斯乃家给人足，刑错之本也欤？", "len": 14}
{"sid": "112_平津侯主父列传.110.s4", "chapter": "112_平津侯主父列传", "para": "110", "seq": 4, "text": "可不务哉！", "len": 5}
{"sid": "112_平津侯主父列传.111.s1", "chapter": "112_平津侯主父列传", "para": "111", "seq": 1, "text": "夫三公者，百寮之率，万民之表也。", "len": 16}
{"sid": "112_平津侯主父列传.111.s2", "chapter": "112_平津侯主父列传", "para": "111", "seq": 2, "text": "未有树直表而得曲影者也。", "len": 12}
{"sid": "112_平津侯主父列传.111.s3", "chapter": "112_平津侯主父列传", "para": "111", "seq": 3, "text": "孔子不云乎，‘子率而正，孰敢不正’。", "len": 18}
{"sid": "112_平津侯主父列传.111.s4", "chapter": "112_平津侯主父列传", "para": "111", "seq": 4, "text": "‘举善而教不能则劝’。", "len": 11}
{"sid": "112_平津侯主父列传.112.s1", "chapter": "112_平津侯主父列传", "para": "112", "seq": 1, "text": "维汉兴以来，股肱宰臣身行俭约，轻财重义，较然著明，未有若故丞相平津侯公孙弘者也。", "len": 40}
{"sid": "112_平津侯主父列传.112.s2", "chapter": "112_平津侯主父列传", "para": "112", "seq": 2, "text": "位在丞相而为布被，脱粟之饭，不过一肉。", "len": 19}
{"sid": "112_平津侯主父列传.112.s3", "chapter": "112_平津侯主父列传", "para": "112", "seq": 3, "text": "故人所善宾客皆分奉禄以给之，无有所馀。", "len": 19}
{"sid": "112_平津侯主父列传.112.s4", "chapter": "112_平津侯主父列传", "para": "112", "seq": 4, "text": "诚内自克约而外从制。", "len": 10}
{"sid": "112_平津侯主父列传.113.s1", "chapter": "112_平津侯主父列传", "para": "113", "seq": 1, "text": "汲黯诘之，乃闻于朝，此可谓减於制度而可施行者也。", "len": 24}
{"sid": "112_平津侯主父列传.113.s2", "chapter": "112_平津侯主父列传", "para": "113", "seq": 2, "text": "德优则行，否则止，与内奢泰而外为诡服以钓虚誉者殊科。", "len": 26}
{"sid": "112_平津侯主父列传.114.s1", "chapter": "112_平津侯主父列传", "para": "114", "seq": 1, "text": "以病乞骸骨，孝武皇帝即制曰‘赏有功，襃有德，善善恶恶，君宜知之。", "len": 32}
{"sid": "112_平津侯主父列传.114.s2", "chapter": "112_平津侯主父列传", "para": "114", "seq": 2, "text": "其省思虑，存精神，辅以医药’。", "len": 15}
{"sid": "112_平津侯主父列传.114.s3", "chapter": "112_平津侯主父列传", "para": "114", "seq": 3, "text": "赐告治病，牛酒杂帛。", "len": 10}
{"sid": "112_平津侯主父列传.114.s4", "chapter": "112_平津侯主父列传", "para": "114", "seq": 4, "text": "居数月，有瘳，视事。", "len": 10}
{"sid": "112_平津侯主父列传.114.s5", "chapter": "112_平津侯主父列传", "para": "114", "seq": 5, "text": "至元狩二年，竟以善终于相位。", "len": 14}
{"sid": "112_平津侯主父列传.114.s6", "chapter": "112_平津侯主父列传", "para": "114", "seq": 6, "text": "夫知臣莫若君，此其效也。", "len": 12}
{"sid": "112_平津侯主父列传.115.s1", "chapter": "112_平津侯主父列传", "para": "115", "seq": 1, "text": "弘子度嗣爵，後为山阳太守，坐法失侯。", "len": 18}
{"sid": "112_平津侯主父列传.115.s2", "chapter": "112_平津侯主父列传", "para": "115", "seq": 2, "text": "夫表德章义，所以率俗厉化，圣王之制，不易之道也。", "len": 24}
{"sid": "112_平津侯主父列传.115.s3", "chapter": "112_平津侯主父列传", "para": "115", "seq": 3, "text": "其赐弘後子孙之次当为後者爵关内侯，食邑三百户，徵诣公车，上名尚书，朕亲临拜焉。”", "len": 40}
{"sid": "112_平津侯主父列传.116.s1", "chapter": "112_平津侯主父列传", "para": "116", "seq": 1, "text": "班固称曰：公孙弘、卜式、兒宽皆以鸿渐之翼困於燕雀，远迹羊豕之间，非遇其时，焉能致此位乎？", "len": 44}
{"sid": "112_平津侯主父列传.117.s1", "chapter": "112_平津侯主父列传", "para": "117", "seq": 1, "text": "是时汉兴六十馀载，海内乂安，府库充实，而四夷未宾，制度多阙，上方欲用文武，求之如弗及。", "len": 43}
{"sid": "112_平津侯主父列传.118.s1", "chapter": "112_平津侯主父列传", "para": "118", "seq": 1, "text": "始以蒲轮迎枚生，见主父而叹息。", "len": 15}
{"sid": "112_平津侯主父列传.118.s2", "chapter": "112_平津侯主父列传", "para": "118", "seq": 2, "text": "群臣慕乡，异人并出。", "len": 10}
{"sid": "112_平津侯主父列传.118.s3", "chapter": "112_平津侯主父列传", "para": "118", "seq": 3, "text": "卜式试於刍牧，弘羊擢於贾竖，卫青奋於奴仆，日磾出於降虏，斯亦曩时版筑饭牛之朋矣。", "len": 40}
{"sid": "112_平津侯主父列传.118.s4", "chapter": "112_平津侯主父列传", "para": "118", "seq": 4, "text": "汉之得人，於兹为盛。", "len": 10}
{"sid": "112_平津侯主父列传.119.s1", "chapter": "112_平津侯主父列传", "para": "119", "seq": 1, "text": "儒雅则公孙弘、董仲舒、兒宽，笃行则石建、石庆，质直则汲黯、卜式，推贤则韩安国、郑当时，定令则赵禹、张汤，文章则司马迁、相如，滑稽则东方朔、枚皋，应对则严助、硃买臣，历数则唐都、落下闳，协律则李延年，运筹则桑弘羊，奉使则张骞、苏武，将帅则卫青、霍去病，受遗则霍光、金日磾。", "len": 135}
{"sid": "112_平津侯主父列传.119.s2", "chapter": "112_平津侯主父列传", "para": "119", "seq": 2, "text": "其馀不可胜纪。", "len": 7}
{"sid": "112_平津侯主父列传.120.s1", "chapter": "112_平津侯主父列传", "para": "120", "seq": 1, "text": "是以兴造功业，制度遗文，後世莫及。", "len": 17}
{"sid": "112_平津侯主父列传.120.s2", "chapter": "112_平津侯主父列传", "para": "120", "seq": 2, "text": "孝宣承统，纂脩洪业，亦讲论六，招选茂异，而萧望之、梁丘贺、夏侯胜、韦玄成、严彭祖、尹更始以儒术进，刘向、王襃以文章显。", "len": 59}
{"sid": "112_平津侯主父列传.121.s1", "chapter": "112_平津侯主父列传", "para": "121", "seq": 1, "text": "将相则张安世、赵充国、魏相、邴吉、于定国、杜延年，治民则黄霸、王成、龚遂、郑弘、邵信臣、韩延寿、尹翁归、赵广汉之属，皆有功迹见述於後。", "len": 67}
{"sid": "112_平津侯主父列传.121.s2", "chapter": "112_平津侯主父列传", "para": "121", "seq": 2, "text": "累其名臣，亦其次也。", "len": 10}
{"sid": "112_平津侯主父列传.121.s3", "chapter": "112_平津侯主父列传", "para": "121", "seq": 3, "text": "::: 赞", "len": 5}
{"sid": "112_平津侯主父列传.122.s1", "chapter": "112_平津侯主父列传", "para": "122", "seq": 1, "text": "平津巨儒，晚年始遇。", "len": 10}
{"sid": "112_平津侯主父列传.122.s2", "chapter": "112_平津侯主父列传", "para": "122", "seq": 2, "text": "外示宽俭，内怀嫉妒。", "len": 10}
{"sid": "112_平津侯主父列传.122.s3", "chapter": "112_平津侯主父列传", "para": "122", "seq": 3, "text": "宠备荣爵，身受肺腑。", "len": 10}
{"sid": "112_平津侯主父列传.122.s4", "chapter": "112_平津侯主父列传", "para": "122", "seq": 4, "text": "主父推恩，观时设度。", "len": 10}
{"sid": "112_平津侯主父列传.122.s5", "chapter": "112_平津侯主父列传", "para": "122", "seq": 5, "text": "生食五鼎，死非时蠹。", "len": 10}
{"sid": "112_平津侯主父列传.122.s6", "chapter": "112_平津侯主父列传", "para": "122", "seq": 6, "text": ":::", "len": 3}
