{"sid": "095_樊郦滕灌列传.1.s1", "chapter": "095_樊郦滕灌列传", "para": "1", "seq": 1, "text": "舞阳侯樊哙者，沛人也。", "len": 11}
{"sid": "095_樊郦滕灌列传.1.s2", "chapter": "095_樊郦滕灌列传", "para": "1", "seq": 2, "text": "以屠狗为事，与高祖俱隐。", "len": 12}
{"sid": "095_樊郦滕灌列传.2.s1", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 1, "text": "初从高祖起丰，攻下沛。", "len": 11}
{"sid": "095_樊郦滕灌列传.2.s2", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 2, "text": "高祖为沛公，以哙为舍人。", "len": 12}
{"sid": "095_樊郦滕灌列传.2.s3", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 3, "text": "从攻胡陵、方与，还守丰，击泗水监丰下，破之。", "len": 22}
{"sid": "095_樊郦滕灌列传.2.s4", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 4, "text": "复东定沛，破泗水守薛西。", "len": 12}
{"sid": "095_樊郦滕灌列传.2.s5", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 5, "text": "与司马枿战砀东，卻敌，斩首十五级，赐爵国大夫。", "len": 23}
{"sid": "095_樊郦滕灌列传.2.s6", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 6, "text": "常从，沛公击章邯军濮阳，攻城先登，斩首二十三级，赐爵列大夫。", "len": 30}
{"sid": "095_樊郦滕灌列传.2.s7", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 7, "text": "复常从，从攻城阳，先登。", "len": 12}
{"sid": "095_樊郦滕灌列传.2.s8", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 8, "text": "下户牖，破李由军，斩首十六级，赐上间爵。", "len": 20}
{"sid": "095_樊郦滕灌列传.2.s9", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 9, "text": "从攻围东郡守尉於成武，卻敌，斩首十四级，捕虏十一人，赐爵五大夫。", "len": 32}
{"sid": "095_樊郦滕灌列传.2.s10", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 10, "text": "从击秦军，出亳南。", "len": 9}
{"sid": "095_樊郦滕灌列传.2.s11", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 11, "text": "河间守军於杠里，破之。", "len": 11}
{"sid": "095_樊郦滕灌列传.2.s12", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 12, "text": "击破赵贲军开封北，以卻敌先登，斩候一人，首六十八级，捕虏二十七人，赐爵卿。", "len": 37}
{"sid": "095_樊郦滕灌列传.2.s13", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 13, "text": "从攻破杨熊军於曲遇。", "len": 10}
{"sid": "095_樊郦滕灌列传.2.s14", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 14, "text": "攻宛陵，先登，斩首八级，捕虏四十四人，赐爵封号贤成君。", "len": 27}
{"sid": "095_樊郦滕灌列传.2.s15", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 15, "text": "从攻长社、轘辕，绝河津，东攻秦军於尸，南攻秦军於犨。", "len": 26}
{"sid": "095_樊郦滕灌列传.2.s16", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 16, "text": "破南阳守齮於阳城。", "len": 9}
{"sid": "095_樊郦滕灌列传.2.s17", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 17, "text": "东攻宛城，先登。", "len": 8}
{"sid": "095_樊郦滕灌列传.2.s18", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 18, "text": "西至郦，以卻敌，斩首二十四级，捕虏四十人，赐重封。", "len": 25}
{"sid": "095_樊郦滕灌列传.2.s19", "chapter": "095_樊郦滕灌列传", "para": "2", "seq": 19, "text": "攻武关，至霸上，斩都尉一人，首十级，捕虏百四十六人，降卒二千九百人。", "len": 34}
{"sid": "095_樊郦滕灌列传.3.s1", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 1, "text": "项羽在戏下，欲攻沛公。", "len": 11}
{"sid": "095_樊郦滕灌列传.3.s2", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 2, "text": "沛公从百馀骑因项伯面见项羽，谢无有闭关事。", "len": 21}
{"sid": "095_樊郦滕灌列传.3.s3", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 3, "text": "项羽既飨军士，中酒，亚父谋欲杀沛公，令项庄拔剑舞坐中，欲击沛公，项伯常蔽之。", "len": 38}
{"sid": "095_樊郦滕灌列传.3.s4", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 4, "text": "时独沛公与张良得入坐，樊哙在营外，闻事急，乃持铁盾入到营。", "len": 29}
{"sid": "095_樊郦滕灌列传.3.s5", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 5, "text": "营卫止哙，哙直撞入，立帐下。", "len": 14}
{"sid": "095_樊郦滕灌列传.3.s6", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 6, "text": "项羽目之，问为谁。", "len": 9}
{"sid": "095_樊郦滕灌列传.3.s7", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 7, "text": "张良曰：“沛公参乘樊哙。", "len": 12}
{"sid": "095_樊郦滕灌列传.3.s8", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 8, "text": "” 项羽曰：“壮士。", "len": 10}
{"sid": "095_樊郦滕灌列传.3.s9", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 9, "text": "” 赐之卮酒彘肩。", "len": 9}
{"sid": "095_樊郦滕灌列传.3.s10", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 10, "text": "哙既饮酒，拔剑切肉食，尽之。", "len": 14}
{"sid": "095_樊郦滕灌列传.3.s11", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 11, "text": "项羽曰：”能复饮乎？", "len": 10}
{"sid": "095_樊郦滕灌列传.3.s12", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 12, "text": "” 哙曰：”臣死且不辞，岂特卮酒乎！", "len": 18}
{"sid": "095_樊郦滕灌列传.3.s13", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 13, "text": "且沛公先入定咸阳，暴师霸上，以待大王。", "len": 19}
{"sid": "095_樊郦滕灌列传.3.s14", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 14, "text": "大王今日至，听小人之言，与沛公有隙，臣恐天下解，心疑大王也。", "len": 30}
{"sid": "095_樊郦滕灌列传.3.s15", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 15, "text": "” 项羽默然。", "len": 7}
{"sid": "095_樊郦滕灌列传.3.s16", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 16, "text": "沛公如厕，麾樊哙去。", "len": 10}
{"sid": "095_樊郦滕灌列传.3.s17", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 17, "text": "既出，沛公留车骑，独骑一马，与樊哙等四人步从，从间道山下归走霸上军，而使张良谢项羽。", "len": 42}
{"sid": "095_樊郦滕灌列传.3.s18", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 18, "text": "项羽亦因遂已，无诛沛公之心矣。", "len": 15}
{"sid": "095_樊郦滕灌列传.3.s19", "chapter": "095_樊郦滕灌列传", "para": "3", "seq": 19, "text": "是日微樊哙奔入营谯让项羽，沛公事几殆。", "len": 19}
{"sid": "095_樊郦滕灌列传.4.s1", "chapter": "095_樊郦滕灌列传", "para": "4", "seq": 1, "text": "明日，项羽入屠咸阳，立沛公为汉王。", "len": 17}
{"sid": "095_樊郦滕灌列传.4.s2", "chapter": "095_樊郦滕灌列传", "para": "4", "seq": 2, "text": "汉王赐哙爵为列侯，号临武侯。", "len": 14}
{"sid": "095_樊郦滕灌列传.4.s3", "chapter": "095_樊郦滕灌列传", "para": "4", "seq": 3, "text": "迁为郎中，从入汉中。", "len": 10}
{"sid": "095_樊郦滕灌列传.5.s1", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 1, "text": "还定三秦，别击西丞白水北，雍轻车骑於雍南，破之。", "len": 24}
{"sid": "095_樊郦滕灌列传.5.s2", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 2, "text": "从攻雍、斄城，先登击章平军好畤，攻城，先登陷阵，斩县令丞各一人，首十一级，虏二十人，迁郎中骑将。", "len": 48}
{"sid": "095_樊郦滕灌列传.5.s3", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 3, "text": "从击秦车骑壤东，卻敌，迁为将军。", "len": 16}
{"sid": "095_樊郦滕灌列传.5.s4", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 4, "text": "攻赵贲，下郿、槐里、柳中、咸阳；灌废丘，最。", "len": 22}
{"sid": "095_樊郦滕灌列传.5.s5", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 5, "text": "至栎阳，赐食邑杜之樊乡。", "len": 12}
{"sid": "095_樊郦滕灌列传.5.s6", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 6, "text": "从攻项籍，屠煮枣。", "len": 9}
{"sid": "095_樊郦滕灌列传.5.s7", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 7, "text": "击破王武、程处军於外黄。", "len": 12}
{"sid": "095_樊郦滕灌列传.5.s8", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 8, "text": "攻邹、鲁、瑕丘、薛。", "len": 10}
{"sid": "095_樊郦滕灌列传.5.s9", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 9, "text": "项羽败汉王於彭城，尽复取鲁、梁地。", "len": 17}
{"sid": "095_樊郦滕灌列传.5.s10", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 10, "text": "哙还至荥阳，益食平阴二千户，以将军守广武。", "len": 21}
{"sid": "095_樊郦滕灌列传.5.s11", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 11, "text": "一岁，项羽引而东。", "len": 9}
{"sid": "095_樊郦滕灌列传.5.s12", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 12, "text": "从高祖击项籍，下阳夏，虏楚周将军卒四千人。", "len": 21}
{"sid": "095_樊郦滕灌列传.5.s13", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 13, "text": "围项籍於陈，大破之。", "len": 10}
{"sid": "095_樊郦滕灌列传.5.s14", "chapter": "095_樊郦滕灌列传", "para": "5", "seq": 14, "text": "屠胡陵。", "len": 4}
{"sid": "095_樊郦滕灌列传.6.s1", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 1, "text": "项籍既死，汉王为帝，以哙坚守战有功，益食八百户。", "len": 24}
{"sid": "095_樊郦滕灌列传.6.s2", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 2, "text": "从高帝攻反燕王臧荼，虏荼，定燕地。", "len": 17}
{"sid": "095_樊郦滕灌列传.6.s3", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 3, "text": "楚王韩信反，哙从至陈，取信，定楚。", "len": 17}
{"sid": "095_樊郦滕灌列传.6.s4", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 4, "text": "更赐爵列侯，与诸侯剖符，世世勿绝，食舞阳，号为舞阳侯，除前所食。", "len": 32}
{"sid": "095_樊郦滕灌列传.6.s5", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 5, "text": "以将军从高祖攻反韩王信於代。", "len": 14}
{"sid": "095_樊郦滕灌列传.6.s6", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 6, "text": "自霍人以往至云中，与绛侯等共定之，益食千五百户。", "len": 24}
{"sid": "095_樊郦滕灌列传.6.s7", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 7, "text": "因击陈豨与曼丘臣军，战襄国，破柏人，先登，降定清河、常山凡二十七县，残东垣，迁为左丞相。", "len": 44}
{"sid": "095_樊郦滕灌列传.6.s8", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 8, "text": "破得綦毋卬、尹潘军於无终、广昌。", "len": 16}
{"sid": "095_樊郦滕灌列传.6.s9", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 9, "text": "破豨别将胡人王黄军於代南，因击韩信军於参合。", "len": 22}
{"sid": "095_樊郦滕灌列传.6.s10", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 10, "text": "军所将卒斩韩信，破豨胡骑横谷，斩将军赵既，虏代丞相冯梁、守孙奋、大将王黄、将军、太仆解福等十人。", "len": 48}
{"sid": "095_樊郦滕灌列传.6.s11", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 11, "text": "与诸将共定代乡邑七十三。", "len": 12}
{"sid": "095_樊郦滕灌列传.6.s12", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 12, "text": "其後燕王卢绾反，哙以相国击卢绾，破其丞相抵蓟南，定燕地，凡县十八，乡邑五十一。", "len": 39}
{"sid": "095_樊郦滕灌列传.6.s13", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 13, "text": "益食邑千三百户，定食舞阳五千四百户。", "len": 18}
{"sid": "095_樊郦滕灌列传.6.s14", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 14, "text": "从，斩首百七十六级，虏二百八十八人。", "len": 18}
{"sid": "095_樊郦滕灌列传.6.s15", "chapter": "095_樊郦滕灌列传", "para": "6", "seq": 15, "text": "别，破军七，下城五，定郡六，县五十二，得丞相一人，将军十二人，二千石已下至三百石十一人。", "len": 44}
{"sid": "095_樊郦滕灌列传.7.s1", "chapter": "095_樊郦滕灌列传", "para": "7", "seq": 1, "text": "哙以吕后女弟吕须为妇，生子伉，故其比诸将最亲。", "len": 23}
{"sid": "095_樊郦滕灌列传.8.s1", "chapter": "095_樊郦滕灌列传", "para": "8", "seq": 1, "text": "先黥布反时，高祖尝病甚，恶见人，卧禁中，诏户者无得入群臣。", "len": 29}
{"sid": "095_樊郦滕灌列传.8.s2", "chapter": "095_樊郦滕灌列传", "para": "8", "seq": 2, "text": "群臣绛、灌等莫敢入。", "len": 10}
{"sid": "095_樊郦滕灌列传.8.s3", "chapter": "095_樊郦滕灌列传", "para": "8", "seq": 3, "text": "十馀日，哙乃排闼直入，大臣随之。", "len": 16}
{"sid": "095_樊郦滕灌列传.8.s4", "chapter": "095_樊郦滕灌列传", "para": "8", "seq": 4, "text": "上独枕一宦者卧。", "len": 8}
{"sid": "095_樊郦滕灌列传.8.s5", "chapter": "095_樊郦滕灌列传", "para": "8", "seq": 5, "text": "哙等见上流涕曰：“始陛下与臣等起丰沛，定天下，何其壮也！", "len": 28}
{"sid": "095_樊郦滕灌列传.8.s6", "chapter": "095_樊郦滕灌列传", "para": "8", "seq": 6, "text": "今天下已定，又何惫也！", "len": 11}
{"sid": "095_樊郦滕灌列传.8.s7", "chapter": "095_樊郦滕灌列传", "para": "8", "seq": 7, "text": "且陛下病甚，大臣震恐，不见臣等计事，顾独与一宦者绝乎？", "len": 27}
{"sid": "095_樊郦滕灌列传.8.s8", "chapter": "095_樊郦滕灌列传", "para": "8", "seq": 8, "text": "且陛下独不见赵高之事乎？", "len": 12}
{"sid": "095_樊郦滕灌列传.8.s9", "chapter": "095_樊郦滕灌列传", "para": "8", "seq": 9, "text": "” 高帝笑而起。", "len": 8}
{"sid": "095_樊郦滕灌列传.9.s1", "chapter": "095_樊郦滕灌列传", "para": "9", "seq": 1, "text": "其後卢绾反，高帝使哙以相国击燕。", "len": 16}
{"sid": "095_樊郦滕灌列传.9.s2", "chapter": "095_樊郦滕灌列传", "para": "9", "seq": 2, "text": "是时高帝病甚，人有恶哙党於吕氏，即上一日宫车晏驾，则哙欲以兵尽诛灭戚氏、赵王如意之属。", "len": 43}
{"sid": "095_樊郦滕灌列传.9.s3", "chapter": "095_樊郦滕灌列传", "para": "9", "seq": 3, "text": "高帝闻之大怒，乃使陈平载绛侯代将，而即军中斩哙。", "len": 24}
{"sid": "095_樊郦滕灌列传.9.s4", "chapter": "095_樊郦滕灌列传", "para": "9", "seq": 4, "text": "陈平畏吕后，执哙诣长安。", "len": 12}
{"sid": "095_樊郦滕灌列传.9.s5", "chapter": "095_樊郦滕灌列传", "para": "9", "seq": 5, "text": "至则高祖已崩，吕后释哙，使复爵邑。", "len": 17}
{"sid": "095_樊郦滕灌列传.10.s1", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 1, "text": "孝惠六年，樊哙卒，谥为武侯。", "len": 14}
{"sid": "095_樊郦滕灌列传.10.s2", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 2, "text": "子伉代侯。", "len": 5}
{"sid": "095_樊郦滕灌列传.10.s3", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 3, "text": "而伉母吕须亦为临光侯，高后时用事专权，大臣尽畏之。", "len": 25}
{"sid": "095_樊郦滕灌列传.10.s4", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 4, "text": "伉代侯九岁，高后崩。", "len": 10}
{"sid": "095_樊郦滕灌列传.10.s5", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 5, "text": "大臣诛诸吕、吕须婘属，因诛伉。", "len": 15}
{"sid": "095_樊郦滕灌列传.10.s6", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 6, "text": "舞阳侯中绝数月。", "len": 8}
{"sid": "095_樊郦滕灌列传.10.s7", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 7, "text": "孝文帝既立，乃复封哙他庶子市人为舞阳侯，复故爵邑。", "len": 25}
{"sid": "095_樊郦滕灌列传.10.s8", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 8, "text": "市人立二十九岁卒，谥为荒侯。", "len": 14}
{"sid": "095_樊郦滕灌列传.10.s9", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 9, "text": "子他广代侯。", "len": 6}
{"sid": "095_樊郦滕灌列传.10.s10", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 10, "text": "六岁，侯家舍人得罪他广，怨之，乃上书曰：“荒侯市人病不能为人，令其夫人与其弟乱而生他广，他广实非荒侯子，不当代後。", "len": 57}
{"sid": "095_樊郦滕灌列传.10.s11", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 11, "text": "” 诏下吏。", "len": 6}
{"sid": "095_樊郦滕灌列传.10.s12", "chapter": "095_樊郦滕灌列传", "para": "10", "seq": 12, "text": "孝景中六年，他广夺侯为庶人，国除。", "len": 17}
{"sid": "095_樊郦滕灌列传.11.s1", "chapter": "095_樊郦滕灌列传", "para": "11", "seq": 1, "text": "曲周侯郦商者，高阳人。", "len": 11}
{"sid": "095_樊郦滕灌列传.11.s2", "chapter": "095_樊郦滕灌列传", "para": "11", "seq": 2, "text": "陈胜起时，商聚少年东西略人，得数千。", "len": 18}
{"sid": "095_樊郦滕灌列传.11.s3", "chapter": "095_樊郦滕灌列传", "para": "11", "seq": 3, "text": "沛公略地至陈留，六月馀，商以将卒四千人属沛公於岐。", "len": 25}
{"sid": "095_樊郦滕灌列传.11.s4", "chapter": "095_樊郦滕灌列传", "para": "11", "seq": 4, "text": "从攻长社，先登，赐爵封信成君。", "len": 15}
{"sid": "095_樊郦滕灌列传.11.s5", "chapter": "095_樊郦滕灌列传", "para": "11", "seq": 5, "text": "从沛公攻缑氏，绝河津，破秦军洛阳东。", "len": 18}
{"sid": "095_樊郦滕灌列传.11.s6", "chapter": "095_樊郦滕灌列传", "para": "11", "seq": 6, "text": "从攻下宛、穰，定十七县。", "len": 12}
{"sid": "095_樊郦滕灌列传.11.s7", "chapter": "095_樊郦滕灌列传", "para": "11", "seq": 7, "text": "别将攻旬关，定汉中。", "len": 10}
{"sid": "095_樊郦滕灌列传.12.s1", "chapter": "095_樊郦滕灌列传", "para": "12", "seq": 1, "text": "项羽灭秦，立沛公为汉王。", "len": 12}
{"sid": "095_樊郦滕灌列传.12.s2", "chapter": "095_樊郦滕灌列传", "para": "12", "seq": 2, "text": "汉王赐商爵信成君，以将军为陇西都尉。", "len": 18}
{"sid": "095_樊郦滕灌列传.12.s3", "chapter": "095_樊郦滕灌列传", "para": "12", "seq": 3, "text": "别将定北地、上郡。", "len": 9}
{"sid": "095_樊郦滕灌列传.12.s4", "chapter": "095_樊郦滕灌列传", "para": "12", "seq": 4, "text": "破雍将军焉氏，周类军栒邑，苏駔军於泥阳。", "len": 20}
{"sid": "095_樊郦滕灌列传.12.s5", "chapter": "095_樊郦滕灌列传", "para": "12", "seq": 5, "text": "赐食邑武成六千户。", "len": 9}
{"sid": "095_樊郦滕灌列传.12.s6", "chapter": "095_樊郦滕灌列传", "para": "12", "seq": 6, "text": "以陇西都尉从击项籍军五月，出钜野，与锺离眛战，疾斗，受梁相国印，益食邑四千户。", "len": 39}
{"sid": "095_樊郦滕灌列传.12.s7", "chapter": "095_樊郦滕灌列传", "para": "12", "seq": 7, "text": "以梁相国将从击项羽二岁三月，攻胡陵。", "len": 18}
{"sid": "095_樊郦滕灌列传.13.s1", "chapter": "095_樊郦滕灌列传", "para": "13", "seq": 1, "text": "项羽既已死，汉王为帝。", "len": 11}
{"sid": "095_樊郦滕灌列传.13.s2", "chapter": "095_樊郦滕灌列传", "para": "13", "seq": 2, "text": "其秋，燕王臧荼反，商以将军从击荼，战龙脱，先登陷阵，破荼军易下，卻敌，迁为右丞相，赐爵列侯，与诸侯剖符，世世勿绝，食邑涿五千户，号曰涿侯。", "len": 69}
{"sid": "095_樊郦滕灌列传.13.s3", "chapter": "095_樊郦滕灌列传", "para": "13", "seq": 3, "text": "以右丞相别定上谷，因攻代，受赵相国印。", "len": 19}
{"sid": "095_樊郦滕灌列传.13.s4", "chapter": "095_樊郦滕灌列传", "para": "13", "seq": 4, "text": "以右丞相赵相国别与绛侯等定代、雁门，得代丞相程纵、守相郭同、将军已下至六百石十九人。", "len": 42}
{"sid": "095_樊郦滕灌列传.13.s5", "chapter": "095_樊郦滕灌列传", "para": "13", "seq": 5, "text": "还，以将军为太上皇卫一岁七月。", "len": 15}
{"sid": "095_樊郦滕灌列传.13.s6", "chapter": "095_樊郦滕灌列传", "para": "13", "seq": 6, "text": "以右丞相击陈豨，残东垣。", "len": 12}
{"sid": "095_樊郦滕灌列传.13.s7", "chapter": "095_樊郦滕灌列传", "para": "13", "seq": 7, "text": "又以右丞相从高帝击黥布，攻其前拒，陷两陈，得以破布军，更食曲周五千一百户，除前所食，凡别破军三，降定郡六，县七十三，得丞相、守相、大将各一人，小将二人，二千石已下至六百石十九人。", "len": 89}
{"sid": "095_樊郦滕灌列传.14.s1", "chapter": "095_樊郦滕灌列传", "para": "14", "seq": 1, "text": "商事孝惠、高后时，商病，不治。", "len": 15}
{"sid": "095_樊郦滕灌列传.14.s2", "chapter": "095_樊郦滕灌列传", "para": "14", "seq": 2, "text": "其子寄，字况，与吕禄善。", "len": 12}
{"sid": "095_樊郦滕灌列传.14.s3", "chapter": "095_樊郦滕灌列传", "para": "14", "seq": 3, "text": "及高后崩，大臣欲诛诸吕，吕禄为将军，军於北军，太尉勃不得入北军，於是乃使人劫郦商，令其子况绐吕禄，吕禄信之，故与出游，而太尉勃乃得入据北军，遂诛诸吕。", "len": 75}
{"sid": "095_樊郦滕灌列传.14.s4", "chapter": "095_樊郦滕灌列传", "para": "14", "seq": 4, "text": "是岁商卒，谥为景侯。", "len": 10}
{"sid": "095_樊郦滕灌列传.14.s5", "chapter": "095_樊郦滕灌列传", "para": "14", "seq": 5, "text": "子寄代侯。", "len": 5}
{"sid": "095_樊郦滕灌列传.14.s6", "chapter": "095_樊郦滕灌列传", "para": "14", "seq": 6, "text": "天下称郦况卖交也。", "len": 9}
{"sid": "095_樊郦滕灌列传.15.s1", "chapter": "095_樊郦滕灌列传", "para": "15", "seq": 1, "text": "孝景前三年，吴、楚、齐、赵反，上以寄为将军，围赵城，十月不能下。", "len": 32}
{"sid": "095_樊郦滕灌列传.15.s2", "chapter": "095_樊郦滕灌列传", "para": "15", "seq": 2, "text": "得俞侯栾布自平齐来，乃下赵城，灭赵，王自杀，除国。", "len": 25}
{"sid": "095_樊郦滕灌列传.15.s3", "chapter": "095_樊郦滕灌列传", "para": "15", "seq": 3, "text": "孝景中二年，寄欲取平原君为夫人，景帝怒，下寄吏，有罪，夺侯。", "len": 30}
{"sid": "095_樊郦滕灌列传.15.s4", "chapter": "095_樊郦滕灌列传", "para": "15", "seq": 4, "text": "景帝乃以商他子坚封为缪侯，续郦氏後。", "len": 18}
{"sid": "095_樊郦滕灌列传.15.s5", "chapter": "095_樊郦滕灌列传", "para": "15", "seq": 5, "text": "缪靖侯卒，子康侯遂成立。", "len": 12}
{"sid": "095_樊郦滕灌列传.15.s6", "chapter": "095_樊郦滕灌列传", "para": "15", "seq": 6, "text": "遂成卒，子怀侯世宗立。", "len": 11}
{"sid": "095_樊郦滕灌列传.15.s7", "chapter": "095_樊郦滕灌列传", "para": "15", "seq": 7, "text": "世宗卒，子侯终根立，为太常，坐法，国除。", "len": 20}
{"sid": "095_樊郦滕灌列传.16.s1", "chapter": "095_樊郦滕灌列传", "para": "16", "seq": 1, "text": "汝阴侯夏侯婴，沛人也。", "len": 11}
{"sid": "095_樊郦滕灌列传.16.s2", "chapter": "095_樊郦滕灌列传", "para": "16", "seq": 2, "text": "为沛厩司御。", "len": 6}
{"sid": "095_樊郦滕灌列传.16.s3", "chapter": "095_樊郦滕灌列传", "para": "16", "seq": 3, "text": "每送使客还，过沛泗上亭，与高祖语，未尝不移日也。", "len": 24}
{"sid": "095_樊郦滕灌列传.16.s4", "chapter": "095_樊郦滕灌列传", "para": "16", "seq": 4, "text": "婴已而试补县吏，与高祖相爱。", "len": 14}
{"sid": "095_樊郦滕灌列传.16.s5", "chapter": "095_樊郦滕灌列传", "para": "16", "seq": 5, "text": "高祖戏而伤婴，人有告高祖。", "len": 13}
{"sid": "095_樊郦滕灌列传.16.s6", "chapter": "095_樊郦滕灌列传", "para": "16", "seq": 6, "text": "高祖时为亭长，重坐伤人，告故不伤婴，婴证之。", "len": 22}
{"sid": "095_樊郦滕灌列传.16.s7", "chapter": "095_樊郦滕灌列传", "para": "16", "seq": 7, "text": "後狱覆，婴坐高祖系岁馀，掠笞数百，终以是脱高祖。", "len": 24}
{"sid": "095_樊郦滕灌列传.17.s1", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 1, "text": "高祖之初与徒属欲攻沛也，婴时以县令史为高祖使。", "len": 23}
{"sid": "095_樊郦滕灌列传.17.s2", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 2, "text": "上降沛一日，高祖为沛公，赐婴爵七大夫，以为太仆。", "len": 24}
{"sid": "095_樊郦滕灌列传.17.s3", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 3, "text": "从攻胡陵，婴与萧何降泗水监平，平以胡陵降，赐婴爵五大夫。", "len": 28}
{"sid": "095_樊郦滕灌列传.17.s4", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 4, "text": "从击秦军砀东，攻济阳，下户牖，破李由军雍丘下，以兵车趣攻战疾，赐爵执帛。", "len": 36}
{"sid": "095_樊郦滕灌列传.17.s5", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 5, "text": "常以太仆奉车从击章邯军东阿、濮阳下，以兵车趣攻战疾，破之，赐爵执珪。", "len": 34}
{"sid": "095_樊郦滕灌列传.17.s6", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 6, "text": "复常奉车从击赵贲军开封，杨熊军曲遇。", "len": 18}
{"sid": "095_樊郦滕灌列传.17.s7", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 7, "text": "婴从捕虏六十八人，降卒八百五十人，得印一匮。", "len": 22}
{"sid": "095_樊郦滕灌列传.17.s8", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 8, "text": "因复常奉车从击秦军雒阳东，以兵车趣攻战疾，赐爵封转为滕公。", "len": 29}
{"sid": "095_樊郦滕灌列传.17.s9", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 9, "text": "因复奉车从攻南阳，战於蓝田、芷阳，以兵车趣攻战疾，至霸上。", "len": 29}
{"sid": "095_樊郦滕灌列传.17.s10", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 10, "text": "项羽至，灭秦，立沛公为汉王。", "len": 14}
{"sid": "095_樊郦滕灌列传.17.s11", "chapter": "095_樊郦滕灌列传", "para": "17", "seq": 11, "text": "汉王赐婴爵列侯，号昭平侯，复为太仆，从入蜀、汉。", "len": 24}
{"sid": "095_樊郦滕灌列传.18.s1", "chapter": "095_樊郦滕灌列传", "para": "18", "seq": 1, "text": "还定三秦，从击项籍。", "len": 10}
{"sid": "095_樊郦滕灌列传.18.s2", "chapter": "095_樊郦滕灌列传", "para": "18", "seq": 2, "text": "至彭城，项羽大破汉军。", "len": 11}
{"sid": "095_樊郦滕灌列传.18.s3", "chapter": "095_樊郦滕灌列传", "para": "18", "seq": 3, "text": "汉王败，不利，驰去。", "len": 10}
{"sid": "095_樊郦滕灌列传.18.s4", "chapter": "095_樊郦滕灌列传", "para": "18", "seq": 4, "text": "见孝惠、鲁元，载之。", "len": 10}
{"sid": "095_樊郦滕灌列传.18.s5", "chapter": "095_樊郦滕灌列传", "para": "18", "seq": 5, "text": "汉王急，马罢，虏在後，常蹶两兒欲弃之，婴常收，竟载之，徐行面雍树乃驰。", "len": 35}
{"sid": "095_樊郦滕灌列传.18.s6", "chapter": "095_樊郦滕灌列传", "para": "18", "seq": 6, "text": "汉王怒，行欲斩婴者十馀，卒得脱，而致孝惠、鲁元於丰。", "len": 26}
{"sid": "095_樊郦滕灌列传.19.s1", "chapter": "095_樊郦滕灌列传", "para": "19", "seq": 1, "text": "汉王既至荥阳，收散兵，复振，赐婴食祈阳。", "len": 20}
{"sid": "095_樊郦滕灌列传.19.s2", "chapter": "095_樊郦滕灌列传", "para": "19", "seq": 2, "text": "复常奉车从击项籍，追至陈，卒定楚，至鲁，益食兹氏。", "len": 25}
{"sid": "095_樊郦滕灌列传.20.s1", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 1, "text": "汉王立为帝。", "len": 6}
{"sid": "095_樊郦滕灌列传.20.s2", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 2, "text": "其秋，燕王臧荼反，婴以太仆从击荼。", "len": 17}
{"sid": "095_樊郦滕灌列传.20.s3", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 3, "text": "明年，从至陈，取楚王信。", "len": 12}
{"sid": "095_樊郦滕灌列传.20.s4", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 4, "text": "更食汝阴，剖符世世勿绝。", "len": 12}
{"sid": "095_樊郦滕灌列传.20.s5", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 5, "text": "以太仆从击代，至武泉、云中，益食千户。", "len": 19}
{"sid": "095_樊郦滕灌列传.20.s6", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 6, "text": "因从击韩信军胡骑晋阳旁，大破之。", "len": 16}
{"sid": "095_樊郦滕灌列传.20.s7", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 7, "text": "追北至平城，为胡所围，七日不得通。", "len": 17}
{"sid": "095_樊郦滕灌列传.20.s8", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 8, "text": "高帝使使厚遗阏氏，冒顿开围一角。", "len": 16}
{"sid": "095_樊郦滕灌列传.20.s9", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 9, "text": "高帝出欲驰，婴固徐行，弩皆持满外向，卒得脱。", "len": 22}
{"sid": "095_樊郦滕灌列传.20.s10", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 10, "text": "益食婴细阳千户。", "len": 8}
{"sid": "095_樊郦滕灌列传.20.s11", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 11, "text": "复以太仆从击胡骑句注北，大破之。", "len": 16}
{"sid": "095_樊郦滕灌列传.20.s12", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 12, "text": "以太仆击胡骑平城南，三陷陈，功为多，赐所夺邑五百户。", "len": 26}
{"sid": "095_樊郦滕灌列传.20.s13", "chapter": "095_樊郦滕灌列传", "para": "20", "seq": 13, "text": "以太仆击陈豨、黥布军，陷陈卻敌，益食千户，定食汝阴六千九百户，除前所食。", "len": 36}
{"sid": "095_樊郦滕灌列传.21.s1", "chapter": "095_樊郦滕灌列传", "para": "21", "seq": 1, "text": "婴自上初起沛，常为太仆，竟高祖崩。", "len": 17}
{"sid": "095_樊郦滕灌列传.21.s2", "chapter": "095_樊郦滕灌列传", "para": "21", "seq": 2, "text": "以太仆事孝惠。", "len": 7}
{"sid": "095_樊郦滕灌列传.21.s3", "chapter": "095_樊郦滕灌列传", "para": "21", "seq": 3, "text": "孝惠帝及高后德婴之脱孝惠、鲁元於下邑之间也，乃赐婴县北第第一，曰“近我”，以尊异之。", "len": 42}
{"sid": "095_樊郦滕灌列传.21.s4", "chapter": "095_樊郦滕灌列传", "para": "21", "seq": 4, "text": "孝惠帝崩，以太仆事高后。", "len": 12}
{"sid": "095_樊郦滕灌列传.21.s5", "chapter": "095_樊郦滕灌列传", "para": "21", "seq": 5, "text": "高后崩，代王之来，婴以太仆与东牟侯入清宫，废少帝，以天子法驾迎代王代邸，与大臣共立为孝文皇帝，复为太仆。", "len": 52}
{"sid": "095_樊郦滕灌列传.21.s6", "chapter": "095_樊郦滕灌列传", "para": "21", "seq": 6, "text": "八岁卒，谥为文侯。", "len": 9}
{"sid": "095_樊郦滕灌列传.21.s7", "chapter": "095_樊郦滕灌列传", "para": "21", "seq": 7, "text": "子夷侯灶立，七年卒。", "len": 10}
{"sid": "095_樊郦滕灌列传.21.s8", "chapter": "095_樊郦滕灌列传", "para": "21", "seq": 8, "text": "子共侯赐立，三十一年卒。", "len": 12}
{"sid": "095_樊郦滕灌列传.21.s9", "chapter": "095_樊郦滕灌列传", "para": "21", "seq": 9, "text": "子侯颇尚平阳公主。", "len": 9}
{"sid": "095_樊郦滕灌列传.21.s10", "chapter": "095_樊郦滕灌列传", "para": "21", "seq": 10, "text": "立十九岁，元鼎二年，坐与父御婢奸罪，自杀，国除。", "len": 24}
{"sid": "095_樊郦滕灌列传.22.s1", "chapter": "095_樊郦滕灌列传", "para": "22", "seq": 1, "text": "颍阴侯灌婴者，睢阳贩缯者也。", "len": 14}
{"sid": "095_樊郦滕灌列传.22.s2", "chapter": "095_樊郦滕灌列传", "para": "22", "seq": 2, "text": "高祖之为沛公，略地至雍丘下，章邯败杀项梁，而沛公还军於砀，婴初以中涓从击破东郡尉於成武及秦军於扛里，疾斗，赐爵七大夫。", "len": 59}
{"sid": "095_樊郦滕灌列传.22.s3", "chapter": "095_樊郦滕灌列传", "para": "22", "seq": 3, "text": "从攻秦军亳南、开封、曲遇，战疾力，赐爵执帛，号宣陵君。", "len": 27}
{"sid": "095_樊郦滕灌列传.22.s4", "chapter": "095_樊郦滕灌列传", "para": "22", "seq": 4, "text": "从攻阳武以西至雒阳，破秦军尸北，北绝河津，南破南阳守齮阳城东，遂定南阳郡。", "len": 37}
{"sid": "095_樊郦滕灌列传.22.s5", "chapter": "095_樊郦滕灌列传", "para": "22", "seq": 5, "text": "西入武关，战於蓝田，疾力，至霸上，赐爵执珪，号昌文君。", "len": 27}
{"sid": "095_樊郦滕灌列传.23.s1", "chapter": "095_樊郦滕灌列传", "para": "23", "seq": 1, "text": "沛公立为汉王，拜婴为郎中，从入汉中，十月，拜为中谒者。", "len": 27}
{"sid": "095_樊郦滕灌列传.23.s2", "chapter": "095_樊郦滕灌列传", "para": "23", "seq": 2, "text": "从还定三秦，下栎阳，降塞王。", "len": 14}
{"sid": "095_樊郦滕灌列传.23.s3", "chapter": "095_樊郦滕灌列传", "para": "23", "seq": 3, "text": "还围章邯於废丘，未拔。", "len": 11}
{"sid": "095_樊郦滕灌列传.23.s4", "chapter": "095_樊郦滕灌列传", "para": "23", "seq": 4, "text": "从东出临晋关，击降殷王，定其地。", "len": 16}
{"sid": "095_樊郦滕灌列传.23.s5", "chapter": "095_樊郦滕灌列传", "para": "23", "seq": 5, "text": "击项羽将龙且、魏相项他军定陶南，疾战，破之。", "len": 22}
{"sid": "095_樊郦滕灌列传.23.s6", "chapter": "095_樊郦滕灌列传", "para": "23", "seq": 6, "text": "赐婴爵列侯，号昌文侯，食杜平乡。", "len": 16}
{"sid": "095_樊郦滕灌列传.24.s1", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 1, "text": "复以中谒者从降下砀，以至彭城。", "len": 15}
{"sid": "095_樊郦滕灌列传.24.s2", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 2, "text": "项羽击，大破汉王。", "len": 9}
{"sid": "095_樊郦滕灌列传.24.s3", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 3, "text": "汉王遁而西，婴从还，军於雍丘。", "len": 15}
{"sid": "095_樊郦滕灌列传.24.s4", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 4, "text": "王武、魏公申徒反，从击破之。", "len": 14}
{"sid": "095_樊郦滕灌列传.24.s5", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 5, "text": "攻下黄，西收兵，军於荥阳。", "len": 13}
{"sid": "095_樊郦滕灌列传.24.s6", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 6, "text": "楚骑来众，汉王乃择军中可为骑将者，皆推故秦骑士重泉人李必、骆甲习骑兵，今为校尉，可为骑将。", "len": 45}
{"sid": "095_樊郦滕灌列传.24.s7", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 7, "text": "汉王欲拜之，必、甲曰：“臣故秦民，恐军不信臣，臣原得大王左右善骑者傅之。", "len": 36}
{"sid": "095_樊郦滕灌列传.24.s8", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 8, "text": "” 灌婴虽少，然数力战，乃拜灌婴为中大夫，令李必、骆甲为左右校尉，将郎中骑兵击楚骑於荥阳东，大破之。", "len": 50}
{"sid": "095_樊郦滕灌列传.24.s9", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 9, "text": "受诏别击楚军後，绝其饷道，起阳武至襄邑。", "len": 20}
{"sid": "095_樊郦滕灌列传.24.s10", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 10, "text": "击项羽之将项冠於鲁下，破之，所将卒斩右司马、骑将各一人。", "len": 28}
{"sid": "095_樊郦滕灌列传.24.s11", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 11, "text": "击破柘公王武，军於燕西，所将卒斩楼烦将五人，连尹一人。", "len": 27}
{"sid": "095_樊郦滕灌列传.24.s12", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 12, "text": "击王武别将桓婴白马下，破之，所将卒斩都尉一人。", "len": 23}
{"sid": "095_樊郦滕灌列传.24.s13", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 13, "text": "以骑渡河南，送汉王到雒阳，使北迎相国韩信军於邯郸。", "len": 25}
{"sid": "095_樊郦滕灌列传.24.s14", "chapter": "095_樊郦滕灌列传", "para": "24", "seq": 14, "text": "还至敖仓，婴迁为御史大夫。", "len": 13}
{"sid": "095_樊郦滕灌列传.25.s1", "chapter": "095_樊郦滕灌列传", "para": "25", "seq": 1, "text": "三年，以列侯食邑杜平乡。", "len": 12}
{"sid": "095_樊郦滕灌列传.25.s2", "chapter": "095_樊郦滕灌列传", "para": "25", "seq": 2, "text": "以御史大夫受诏将郎中骑兵东属相国韩信，击破齐军於历下，所将卒虏车骑将军华毋伤及将吏四十六人。", "len": 46}
{"sid": "095_樊郦滕灌列传.25.s3", "chapter": "095_樊郦滕灌列传", "para": "25", "seq": 3, "text": "降下临菑，得齐守相田光。", "len": 12}
{"sid": "095_樊郦滕灌列传.25.s4", "chapter": "095_樊郦滕灌列传", "para": "25", "seq": 4, "text": "追齐相田横至嬴、博，破其骑，所将卒斩骑将一人，生得骑将四人。", "len": 30}
{"sid": "095_樊郦滕灌列传.25.s5", "chapter": "095_樊郦滕灌列传", "para": "25", "seq": 5, "text": "攻下嬴、博，破齐将军田吸於千乘，所将卒斩吸。", "len": 22}
{"sid": "095_樊郦滕灌列传.25.s6", "chapter": "095_樊郦滕灌列传", "para": "25", "seq": 6, "text": "东从韩信攻龙且、留公旋於高密，卒斩龙且，生得右司马、连尹各一人，楼烦将十人，身生得亚将周兰。", "len": 46}
{"sid": "095_樊郦滕灌列传.26.s1", "chapter": "095_樊郦滕灌列传", "para": "26", "seq": 1, "text": "齐地已定，韩信自立为齐王，使婴别将击楚将公杲於鲁北，破之。", "len": 29}
{"sid": "095_樊郦滕灌列传.26.s2", "chapter": "095_樊郦滕灌列传", "para": "26", "seq": 2, "text": "转南，破薛郡长，身虏骑将一人。", "len": 15}
{"sid": "095_樊郦滕灌列传.26.s3", "chapter": "095_樊郦滕灌列传", "para": "26", "seq": 3, "text": "攻阳，前至下相以东南僮、取虑、徐。", "len": 17}
{"sid": "095_樊郦滕灌列传.26.s4", "chapter": "095_樊郦滕灌列传", "para": "26", "seq": 4, "text": "度淮，尽降其城邑，至广陵。", "len": 13}
{"sid": "095_樊郦滕灌列传.26.s5", "chapter": "095_樊郦滕灌列传", "para": "26", "seq": 5, "text": "项羽使项声、薛公、郯公复定淮北。", "len": 16}
{"sid": "095_樊郦滕灌列传.26.s6", "chapter": "095_樊郦滕灌列传", "para": "26", "seq": 6, "text": "婴度淮北，击破项声、郯公下邳，斩薛公，下下邳，击破楚骑於平阳，遂降彭城，虏柱国项佗，降留、薛、沛、酂、萧、相。", "len": 55}
{"sid": "095_樊郦滕灌列传.26.s7", "chapter": "095_樊郦滕灌列传", "para": "26", "seq": 7, "text": "攻苦、谯，复得亚将周兰。", "len": 12}
{"sid": "095_樊郦滕灌列传.26.s8", "chapter": "095_樊郦滕灌列传", "para": "26", "seq": 8, "text": "与汉王会颐乡。", "len": 7}
{"sid": "095_樊郦滕灌列传.26.s9", "chapter": "095_樊郦滕灌列传", "para": "26", "seq": 9, "text": "从击项籍军於陈下，破之，所将卒斩楼烦将二人，虏骑将八人。", "len": 28}
{"sid": "095_樊郦滕灌列传.26.s10", "chapter": "095_樊郦滕灌列传", "para": "26", "seq": 10, "text": "赐益食邑二千五百户。", "len": 10}
{"sid": "095_樊郦滕灌列传.27.s1", "chapter": "095_樊郦滕灌列传", "para": "27", "seq": 1, "text": "项籍败垓下去也，婴以御史大夫受诏将车骑别追项籍至东城，之。", "len": 29}
{"sid": "095_樊郦滕灌列传.27.s2", "chapter": "095_樊郦滕灌列传", "para": "27", "seq": 2, "text": "所将卒五人共斩项籍，皆赐爵列侯。", "len": 16}
{"sid": "095_樊郦滕灌列传.27.s3", "chapter": "095_樊郦滕灌列传", "para": "27", "seq": 3, "text": "降左右司马各一人，卒万二千人，尽得其军将吏。", "len": 22}
{"sid": "095_樊郦滕灌列传.27.s4", "chapter": "095_樊郦滕灌列传", "para": "27", "seq": 4, "text": "下东城、历阳。", "len": 7}
{"sid": "095_樊郦滕灌列传.27.s5", "chapter": "095_樊郦滕灌列传", "para": "27", "seq": 5, "text": "渡江，破吴郡长吴下，得吴守，遂定吴、豫章、会稽郡。", "len": 25}
{"sid": "095_樊郦滕灌列传.27.s6", "chapter": "095_樊郦滕灌列传", "para": "27", "seq": 6, "text": "还定淮北，凡五十二县。", "len": 11}
{"sid": "095_樊郦滕灌列传.28.s1", "chapter": "095_樊郦滕灌列传", "para": "28", "seq": 1, "text": "汉王立为皇帝，赐益婴邑三千户。", "len": 15}
{"sid": "095_樊郦滕灌列传.28.s2", "chapter": "095_樊郦滕灌列传", "para": "28", "seq": 2, "text": "其秋，以车骑将军从击破燕王臧荼。", "len": 16}
{"sid": "095_樊郦滕灌列传.28.s3", "chapter": "095_樊郦滕灌列传", "para": "28", "seq": 3, "text": "明年，从至陈，取楚王信。", "len": 12}
{"sid": "095_樊郦滕灌列传.28.s4", "chapter": "095_樊郦滕灌列传", "para": "28", "seq": 4, "text": "还，剖符，世世勿绝，食颍阴二千五百户，号曰颍阴侯。", "len": 25}
{"sid": "095_樊郦滕灌列传.29.s1", "chapter": "095_樊郦滕灌列传", "para": "29", "seq": 1, "text": "以车骑将军从击反韩王信於代，至马邑，受诏别降楼烦以北六县，斩代左相，破胡骑於武泉北。", "len": 42}
{"sid": "095_樊郦滕灌列传.29.s2", "chapter": "095_樊郦滕灌列传", "para": "29", "seq": 2, "text": "复从击韩信胡骑晋阳下，所将卒斩胡白题将一人。", "len": 22}
{"sid": "095_樊郦滕灌列传.29.s3", "chapter": "095_樊郦滕灌列传", "para": "29", "seq": 3, "text": "受诏并将燕、赵、齐、梁、楚车骑，击破胡骑於硰石。", "len": 24}
{"sid": "095_樊郦滕灌列传.29.s4", "chapter": "095_樊郦滕灌列传", "para": "29", "seq": 4, "text": "至平城，为胡所围，从还军东垣。", "len": 15}
{"sid": "095_樊郦滕灌列传.30.s1", "chapter": "095_樊郦滕灌列传", "para": "30", "seq": 1, "text": "从击陈豨，受诏别攻豨丞相侯敞军曲逆下，破之，卒斩敞及特将五人。", "len": 31}
{"sid": "095_樊郦滕灌列传.30.s2", "chapter": "095_樊郦滕灌列传", "para": "30", "seq": 2, "text": "降曲逆、卢奴、上曲阳、安国、安平。", "len": 17}
{"sid": "095_樊郦滕灌列传.30.s3", "chapter": "095_樊郦滕灌列传", "para": "30", "seq": 3, "text": "攻下东垣。", "len": 5}
{"sid": "095_樊郦滕灌列传.31.s1", "chapter": "095_樊郦滕灌列传", "para": "31", "seq": 1, "text": "黥布反，以车骑将军先出，攻布别将於相，破之，斩亚将楼烦将三人。", "len": 31}
{"sid": "095_樊郦滕灌列传.31.s2", "chapter": "095_樊郦滕灌列传", "para": "31", "seq": 2, "text": "又进击破布上柱国军及大司马军。", "len": 15}
{"sid": "095_樊郦滕灌列传.31.s3", "chapter": "095_樊郦滕灌列传", "para": "31", "seq": 3, "text": "又进破布别将肥诛。", "len": 9}
{"sid": "095_樊郦滕灌列传.31.s4", "chapter": "095_樊郦滕灌列传", "para": "31", "seq": 4, "text": "婴身生得左司马一人，所将卒斩其小将十人，追北至淮上。", "len": 26}
{"sid": "095_樊郦滕灌列传.31.s5", "chapter": "095_樊郦滕灌列传", "para": "31", "seq": 5, "text": "益食二千五百户。", "len": 8}
{"sid": "095_樊郦滕灌列传.31.s6", "chapter": "095_樊郦滕灌列传", "para": "31", "seq": 6, "text": "布已破，高帝归，定令婴食颖阴五千户，除前所食邑。", "len": 24}
{"sid": "095_樊郦滕灌列传.31.s7", "chapter": "095_樊郦滕灌列传", "para": "31", "seq": 7, "text": "凡从得二千石二人，别破军十六，降城四十六，定国一，郡二，县五十二，得将军二人，柱国、相国各一人，二千石十人。", "len": 54}
{"sid": "095_樊郦滕灌列传.32.s1", "chapter": "095_樊郦滕灌列传", "para": "32", "seq": 1, "text": "婴自破布归，高帝崩，婴以列侯事孝惠帝及吕太后。", "len": 23}
{"sid": "095_樊郦滕灌列传.32.s2", "chapter": "095_樊郦滕灌列传", "para": "32", "seq": 2, "text": "太后崩，吕禄等以赵王自置为将军，军长安，为乱。", "len": 23}
{"sid": "095_樊郦滕灌列传.32.s3", "chapter": "095_樊郦滕灌列传", "para": "32", "seq": 3, "text": "齐哀王闻之，举兵西，且入诛不当为王者。", "len": 19}
{"sid": "095_樊郦滕灌列传.32.s4", "chapter": "095_樊郦滕灌列传", "para": "32", "seq": 4, "text": "上将军吕禄等闻之，乃遣婴为大将，将军往击之。", "len": 22}
{"sid": "095_樊郦滕灌列传.32.s5", "chapter": "095_樊郦滕灌列传", "para": "32", "seq": 5, "text": "婴行至荥阳，乃与绛侯等谋，因屯兵荥阳，风齐王以诛吕氏事，齐兵止不前。", "len": 34}
{"sid": "095_樊郦滕灌列传.32.s6", "chapter": "095_樊郦滕灌列传", "para": "32", "seq": 6, "text": "绛侯等既诛诸吕，齐王罢兵归，婴亦罢兵自荥阳归，与绛侯、陈平共立代王为孝文皇帝。", "len": 39}
{"sid": "095_樊郦滕灌列传.32.s7", "chapter": "095_樊郦滕灌列传", "para": "32", "seq": 7, "text": "孝文皇帝於是益封婴三千户，赐黄金千斤，拜为太尉。", "len": 24}
{"sid": "095_樊郦滕灌列传.33.s1", "chapter": "095_樊郦滕灌列传", "para": "33", "seq": 1, "text": "三岁，绛侯勃免相就国，婴为丞相，罢太尉官。", "len": 21}
{"sid": "095_樊郦滕灌列传.33.s2", "chapter": "095_樊郦滕灌列传", "para": "33", "seq": 2, "text": "是岁，匈奴大入北地、上郡，令丞相婴将骑八万五千往击匈奴。", "len": 28}
{"sid": "095_樊郦滕灌列传.33.s3", "chapter": "095_樊郦滕灌列传", "para": "33", "seq": 3, "text": "匈奴去，济北王反，诏乃罢婴之兵。", "len": 16}
{"sid": "095_樊郦滕灌列传.33.s4", "chapter": "095_樊郦滕灌列传", "para": "33", "seq": 4, "text": "後岁馀，婴以丞相卒，谥曰懿侯。", "len": 15}
{"sid": "095_樊郦滕灌列传.33.s5", "chapter": "095_樊郦滕灌列传", "para": "33", "seq": 5, "text": "子平侯阿代侯。", "len": 7}
{"sid": "095_樊郦滕灌列传.33.s6", "chapter": "095_樊郦滕灌列传", "para": "33", "seq": 6, "text": "二十八年卒，子彊代侯。", "len": 11}
{"sid": "095_樊郦滕灌列传.33.s7", "chapter": "095_樊郦滕灌列传", "para": "33", "seq": 7, "text": "十三年，彊有罪，绝二岁。", "len": 12}
{"sid": "095_樊郦滕灌列传.33.s8", "chapter": "095_樊郦滕灌列传", "para": "33", "seq": 8, "text": "元光三年，天子封灌婴孙贤为临汝侯，续灌氏後，八岁，坐行赇有罪，国除。", "len": 34}
{"sid": "095_樊郦滕灌列传.33.s9", "chapter": "095_樊郦滕灌列传", "para": "33", "seq": 9, "text": "::: 太史公曰", "len": 8}
{"sid": "095_樊郦滕灌列传.34.s1", "chapter": "095_樊郦滕灌列传", "para": "34", "seq": 1, "text": "太史公曰：吾適丰沛，问其遗老，观故萧、曹、樊哙、滕公之家，及其素，异哉所闻！", "len": 38}
{"sid": "095_樊郦滕灌列传.34.s2", "chapter": "095_樊郦滕灌列传", "para": "34", "seq": 2, "text": "方其鼓刀屠狗卖缯之时，岂自知附骥之尾，垂名汉廷，德流子孙哉？", "len": 30}
{"sid": "095_樊郦滕灌列传.34.s3", "chapter": "095_樊郦滕灌列传", "para": "34", "seq": 3, "text": "余与他广通，为言高祖功臣之兴时若此云。", "len": 19}
{"sid": "095_樊郦滕灌列传.34.s4", "chapter": "095_樊郦滕灌列传", "para": "34", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "095_樊郦滕灌列传.35.s1", "chapter": "095_樊郦滕灌列传", "para": "35", "seq": 1, "text": "圣贤影响，云蒸龙变。", "len": 10}
{"sid": "095_樊郦滕灌列传.35.s2", "chapter": "095_樊郦滕灌列传", "para": "35", "seq": 2, "text": "屠狗贩缯，攻城野战。", "len": 10}
{"sid": "095_樊郦滕灌列传.35.s3", "chapter": "095_樊郦滕灌列传", "para": "35", "seq": 3, "text": "扶义西上，受封南面。", "len": 10}
{"sid": "095_樊郦滕灌列传.35.s4", "chapter": "095_樊郦滕灌列传", "para": "35", "seq": 4, "text": "郦况卖交，舞阳内援。", "len": 10}
{"sid": "095_樊郦滕灌列传.35.s5", "chapter": "095_樊郦滕灌列传", "para": "35", "seq": 5, "text": "滕灌更王，奕叶繁衍。", "len": 10}
{"sid": "095_樊郦滕灌列传.35.s6", "chapter": "095_樊郦滕灌列传", "para": "35", "seq": 6, "text": ":::", "len": 3}
