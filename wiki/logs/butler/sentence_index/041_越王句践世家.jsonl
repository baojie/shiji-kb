{"sid": "041_越王句践世家.1.s1", "chapter": "041_越王句践世家", "para": "1", "seq": 1, "text": "越王句践，其先禹之苗裔，而夏后帝少康之庶子也。", "len": 23}
{"sid": "041_越王句践世家.1.s2", "chapter": "041_越王句践世家", "para": "1", "seq": 2, "text": "封於会稽，以奉守禹之祀。", "len": 12}
{"sid": "041_越王句践世家.1.s3", "chapter": "041_越王句践世家", "para": "1", "seq": 3, "text": "文身断发，披草莱而邑焉。", "len": 12}
{"sid": "041_越王句践世家.1.s4", "chapter": "041_越王句践世家", "para": "1", "seq": 4, "text": "後二十馀世，至於允常。", "len": 11}
{"sid": "041_越王句践世家.1.s5", "chapter": "041_越王句践世家", "para": "1", "seq": 5, "text": "云：“於，语发声也。”", "len": 11}
{"sid": "041_越王句践世家.2.s1", "chapter": "041_越王句践世家", "para": "2", "seq": 1, "text": "允常之时，与吴王阖庐战而相怨伐。", "len": 16}
{"sid": "041_越王句践世家.2.s2", "chapter": "041_越王句践世家", "para": "2", "seq": 2, "text": "允常卒，子句践立，是为越王。", "len": 14}
{"sid": "041_越王句践世家.3.s1", "chapter": "041_越王句践世家", "para": "3", "seq": 1, "text": "元年，吴王阖庐闻允常死，乃兴师伐越。", "len": 18}
{"sid": "041_越王句践世家.3.s2", "chapter": "041_越王句践世家", "para": "3", "seq": 2, "text": "越王句践使死士挑战，三行，至吴陈，呼而自刭。", "len": 22}
{"sid": "041_越王句践世家.3.s3", "chapter": "041_越王句践世家", "para": "3", "seq": 3, "text": "吴师观之，越因袭击吴师，吴师败於槜李，射伤吴王阖庐。", "len": 26}
{"sid": "041_越王句践世家.3.s4", "chapter": "041_越王句践世家", "para": "3", "seq": 4, "text": "阖庐且死，告其子夫差曰：”必毋忘越。”", "len": 19}
{"sid": "041_越王句践世家.4.s1", "chapter": "041_越王句践世家", "para": "4", "seq": 1, "text": "三年，句践闻吴王夫差日夜勒兵，且以报越，越欲先吴未发往伐之。", "len": 30}
{"sid": "041_越王句践世家.4.s2", "chapter": "041_越王句践世家", "para": "4", "seq": 2, "text": "范蠡谏曰：“不可。", "len": 9}
{"sid": "041_越王句践世家.4.s3", "chapter": "041_越王句践世家", "para": "4", "seq": 3, "text": "臣闻兵者凶器也，战者逆德也，争者事之末也。", "len": 21}
{"sid": "041_越王句践世家.4.s4", "chapter": "041_越王句践世家", "para": "4", "seq": 4, "text": "阴谋逆德，好用凶器，试身於所末，上帝禁之，行者不利。", "len": 26}
{"sid": "041_越王句践世家.4.s5", "chapter": "041_越王句践世家", "para": "4", "seq": 5, "text": "” 越王曰：“吾已决之矣。", "len": 13}
{"sid": "041_越王句践世家.4.s6", "chapter": "041_越王句践世家", "para": "4", "seq": 6, "text": "” 遂兴师。", "len": 6}
{"sid": "041_越王句践世家.5.s1", "chapter": "041_越王句践世家", "para": "5", "seq": 1, "text": "吴王闻之，悉发精兵击越，败之夫椒。", "len": 17}
{"sid": "041_越王句践世家.5.s2", "chapter": "041_越王句践世家", "para": "5", "seq": 2, "text": "越王乃以馀兵五千人保栖於会稽。", "len": 15}
{"sid": "041_越王句践世家.5.s3", "chapter": "041_越王句践世家", "para": "5", "seq": 3, "text": "吴王追而围之。", "len": 7}
{"sid": "041_越王句践世家.6.s1", "chapter": "041_越王句践世家", "para": "6", "seq": 1, "text": "越王谓范蠡曰：“以不听子故至於此，为之柰何？", "len": 22}
{"sid": "041_越王句践世家.6.s2", "chapter": "041_越王句践世家", "para": "6", "seq": 2, "text": "” 蠡对曰：“持满者与天，定倾者与人，节事者以地。", "len": 25}
{"sid": "041_越王句践世家.6.s3", "chapter": "041_越王句践世家", "para": "6", "seq": 3, "text": "卑辞厚礼以遗之，不许，而身与之市。", "len": 17}
{"sid": "041_越王句践世家.6.s4", "chapter": "041_越王句践世家", "para": "6", "seq": 4, "text": "” 句践曰：“诺。”", "len": 10}
{"sid": "041_越王句践世家.7.s1", "chapter": "041_越王句践世家", "para": "7", "seq": 1, "text": "乃令大夫种行成於吴，膝行顿首曰：“君王亡臣句践使陪臣种敢告下执事：句践请为臣，妻为妾。", "len": 43}
{"sid": "041_越王句践世家.7.s2", "chapter": "041_越王句践世家", "para": "7", "seq": 2, "text": "” 吴王将许之。", "len": 8}
{"sid": "041_越王句践世家.7.s3", "chapter": "041_越王句践世家", "para": "7", "seq": 3, "text": "子胥言於吴王曰：“天以越赐吴，勿许也。", "len": 19}
{"sid": "041_越王句践世家.7.s4", "chapter": "041_越王句践世家", "para": "7", "seq": 4, "text": "” 种还，以报句践。", "len": 10}
{"sid": "041_越王句践世家.8.s1", "chapter": "041_越王句践世家", "para": "8", "seq": 1, "text": "句践欲杀妻子，燔宝器，触战以死。", "len": 16}
{"sid": "041_越王句践世家.8.s2", "chapter": "041_越王句践世家", "para": "8", "seq": 2, "text": "种止句践曰：“夫吴太宰嚭贪，可诱以利，请间行言之。", "len": 25}
{"sid": "041_越王句践世家.8.s3", "chapter": "041_越王句践世家", "para": "8", "seq": 3, "text": "” 於是句践以美女宝器令种间献吴太宰嚭。", "len": 20}
{"sid": "041_越王句践世家.8.s4", "chapter": "041_越王句践世家", "para": "8", "seq": 4, "text": "嚭受，乃见大夫种於吴王。", "len": 12}
{"sid": "041_越王句践世家.8.s5", "chapter": "041_越王句践世家", "para": "8", "seq": 5, "text": "种顿首言曰：“原大王赦句践之罪，尽入其宝器。", "len": 22}
{"sid": "041_越王句践世家.8.s6", "chapter": "041_越王句践世家", "para": "8", "seq": 6, "text": "不幸不赦，句践将尽杀其妻子，燔其宝器，悉五千人触战，必有当也。", "len": 31}
{"sid": "041_越王句践世家.8.s7", "chapter": "041_越王句践世家", "para": "8", "seq": 7, "text": "” 嚭因说吴王曰：“越以服为臣，若将赦之，此国之利也。”", "len": 28}
{"sid": "041_越王句践世家.9.s1", "chapter": "041_越王句践世家", "para": "9", "seq": 1, "text": "吴王将许之。", "len": 6}
{"sid": "041_越王句践世家.9.s2", "chapter": "041_越王句践世家", "para": "9", "seq": 2, "text": "子胥进谏曰：“今不灭越，後必悔之。", "len": 17}
{"sid": "041_越王句践世家.9.s3", "chapter": "041_越王句践世家", "para": "9", "seq": 3, "text": "句践贤君，种、蠡良臣，若反国，将为乱。", "len": 19}
{"sid": "041_越王句践世家.9.s4", "chapter": "041_越王句践世家", "para": "9", "seq": 4, "text": "” 吴王弗听，卒赦越，罢兵而归。", "len": 16}
{"sid": "041_越王句践世家.10.s1", "chapter": "041_越王句践世家", "para": "10", "seq": 1, "text": "句践之困会稽也，喟然叹曰：“吾终於此乎？", "len": 20}
{"sid": "041_越王句践世家.10.s2", "chapter": "041_越王句践世家", "para": "10", "seq": 2, "text": "” 种曰：”汤系夏台，文王囚羑里，晋重耳奔翟，齐小白奔莒，其卒王霸。", "len": 34}
{"sid": "041_越王句践世家.10.s3", "chapter": "041_越王句践世家", "para": "10", "seq": 3, "text": "由是观之，何遽不为福乎？”", "len": 13}
{"sid": "041_越王句践世家.11.s1", "chapter": "041_越王句践世家", "para": "11", "seq": 1, "text": "吴既赦越，越王句践反国，乃苦身焦思，置胆於坐，坐卧即仰胆，饮食亦尝胆也。", "len": 36}
{"sid": "041_越王句践世家.11.s2", "chapter": "041_越王句践世家", "para": "11", "seq": 2, "text": "曰：“女忘会稽之耻邪？", "len": 11}
{"sid": "041_越王句践世家.11.s3", "chapter": "041_越王句践世家", "para": "11", "seq": 3, "text": "” 身自耕作，夫人自织，食不加肉，衣不重采，折节下贤人，厚遇宾客，振贫吊死，与百姓同其劳。", "len": 45}
{"sid": "041_越王句践世家.12.s1", "chapter": "041_越王句践世家", "para": "12", "seq": 1, "text": "欲使范蠡治国政，蠡对曰：“兵甲之事，种不如蠡；填抚国家，亲附百姓，蠡不如种。", "len": 38}
{"sid": "041_越王句践世家.12.s2", "chapter": "041_越王句践世家", "para": "12", "seq": 2, "text": "” 於是举国政属大夫种，而使范蠡与大夫柘稽行成，为质於吴。", "len": 29}
{"sid": "041_越王句践世家.12.s3", "chapter": "041_越王句践世家", "para": "12", "seq": 3, "text": "二岁而吴归蠡。", "len": 7}
{"sid": "041_越王句践世家.13.s1", "chapter": "041_越王句践世家", "para": "13", "seq": 1, "text": "句践自会稽归七年，拊循其士民，欲用以报吴。", "len": 21}
{"sid": "041_越王句践世家.13.s2", "chapter": "041_越王句践世家", "para": "13", "seq": 2, "text": "大夫逢同谏曰：“国新流亡，今乃复殷给，缮饰备利，吴必惧，惧则难必至。", "len": 34}
{"sid": "041_越王句践世家.13.s3", "chapter": "041_越王句践世家", "para": "13", "seq": 3, "text": "且鸷鸟之击也，必匿其形。", "len": 12}
{"sid": "041_越王句践世家.13.s4", "chapter": "041_越王句践世家", "para": "13", "seq": 4, "text": "今夫吴兵加齐、晋，怨深於楚、越，名高天下，实害周室，德少而功多，必淫自矜。", "len": 37}
{"sid": "041_越王句践世家.13.s5", "chapter": "041_越王句践世家", "para": "13", "seq": 5, "text": "为越计，莫若结齐，亲楚，附晋，以厚吴。", "len": 19}
{"sid": "041_越王句践世家.13.s6", "chapter": "041_越王句践世家", "para": "13", "seq": 6, "text": "吴之志广，必轻战。", "len": 9}
{"sid": "041_越王句践世家.13.s7", "chapter": "041_越王句践世家", "para": "13", "seq": 7, "text": "是我连其权，三国伐之，越承其弊，可克也。", "len": 20}
{"sid": "041_越王句践世家.13.s8", "chapter": "041_越王句践世家", "para": "13", "seq": 8, "text": "” 句践曰：“善。”", "len": 10}
{"sid": "041_越王句践世家.14.s1", "chapter": "041_越王句践世家", "para": "14", "seq": 1, "text": "居二年，吴王将伐齐。", "len": 10}
{"sid": "041_越王句践世家.14.s2", "chapter": "041_越王句践世家", "para": "14", "seq": 2, "text": "子胥谏曰：“未可。", "len": 9}
{"sid": "041_越王句践世家.14.s3", "chapter": "041_越王句践世家", "para": "14", "seq": 3, "text": "臣闻句践食不重味，与百姓同苦乐。", "len": 16}
{"sid": "041_越王句践世家.14.s4", "chapter": "041_越王句践世家", "para": "14", "seq": 4, "text": "此人不死，必为国患。", "len": 10}
{"sid": "041_越王句践世家.14.s5", "chapter": "041_越王句践世家", "para": "14", "seq": 5, "text": "吴有越，腹心之疾，齐与吴，疥甪也。", "len": 17}
{"sid": "041_越王句践世家.14.s6", "chapter": "041_越王句践世家", "para": "14", "seq": 6, "text": "原王释齐先越。", "len": 7}
{"sid": "041_越王句践世家.14.s7", "chapter": "041_越王句践世家", "para": "14", "seq": 7, "text": "” 吴王弗听，遂伐齐，败之艾陵，虏齐高、国以归。", "len": 24}
{"sid": "041_越王句践世家.14.s8", "chapter": "041_越王句践世家", "para": "14", "seq": 8, "text": "让子胥。", "len": 4}
{"sid": "041_越王句践世家.14.s9", "chapter": "041_越王句践世家", "para": "14", "seq": 9, "text": "子胥曰：“王毋喜！", "len": 9}
{"sid": "041_越王句践世家.14.s10", "chapter": "041_越王句践世家", "para": "14", "seq": 10, "text": "” 王怒，子胥欲自杀，王闻而止之。", "len": 17}
{"sid": "041_越王句践世家.15.s1", "chapter": "041_越王句践世家", "para": "15", "seq": 1, "text": "越大夫种曰：“臣观吴王政骄矣，请试尝之贷粟，以卜其事。", "len": 27}
{"sid": "041_越王句践世家.15.s2", "chapter": "041_越王句践世家", "para": "15", "seq": 2, "text": "” 请贷，吴王欲与，子胥谏勿与，王遂与之，越乃私喜。", "len": 26}
{"sid": "041_越王句践世家.15.s3", "chapter": "041_越王句践世家", "para": "15", "seq": 3, "text": "子胥言曰：“王不听谏，後三年吴其墟乎！”", "len": 20}
{"sid": "041_越王句践世家.16.s1", "chapter": "041_越王句践世家", "para": "16", "seq": 1, "text": "太宰嚭闻之，乃数与子胥争越议，因谗子胥曰：“伍员貌忠而实忍人，其父兄不顾，安能顾王？", "len": 42}
{"sid": "041_越王句践世家.16.s2", "chapter": "041_越王句践世家", "para": "16", "seq": 2, "text": "王前欲伐齐，员彊谏，已而有功，用是反怨王。", "len": 21}
{"sid": "041_越王句践世家.16.s3", "chapter": "041_越王句践世家", "para": "16", "seq": 3, "text": "王不备伍员，员必为乱。", "len": 11}
{"sid": "041_越王句践世家.16.s4", "chapter": "041_越王句践世家", "para": "16", "seq": 4, "text": "” 与逢同共谋，谗之王。", "len": 12}
{"sid": "041_越王句践世家.16.s5", "chapter": "041_越王句践世家", "para": "16", "seq": 5, "text": "王始不从，乃使子胥於齐，闻其讬子於鲍氏，王乃大怒，曰：”伍员果欺寡人！", "len": 35}
{"sid": "041_越王句践世家.16.s6", "chapter": "041_越王句践世家", "para": "16", "seq": 6, "text": "” 役反，使人赐子胥属镂剑以自杀。", "len": 17}
{"sid": "041_越王句践世家.17.s1", "chapter": "041_越王句践世家", "para": "17", "seq": 1, "text": "子胥大笑曰：“我令而父霸，我又立若，若初欲分吴国半予我，我不受，已，今若反以谗诛我。", "len": 42}
{"sid": "041_越王句践世家.17.s2", "chapter": "041_越王句践世家", "para": "17", "seq": 2, "text": "嗟乎，嗟乎，一人固不能独立！", "len": 14}
{"sid": "041_越王句践世家.17.s3", "chapter": "041_越王句践世家", "para": "17", "seq": 3, "text": "” 报使者曰：“必取吾眼置吴东门，以观越兵入也！", "len": 24}
{"sid": "041_越王句践世家.17.s4", "chapter": "041_越王句践世家", "para": "17", "seq": 4, "text": "” 於是吴任嚭政。", "len": 9}
{"sid": "041_越王句践世家.18.s1", "chapter": "041_越王句践世家", "para": "18", "seq": 1, "text": "居三年，句践召范蠡曰：“吴已杀子胥，导谀者众，可乎？", "len": 26}
{"sid": "041_越王句践世家.18.s2", "chapter": "041_越王句践世家", "para": "18", "seq": 2, "text": "” 对曰：“未可。", "len": 9}
{"sid": "041_越王句践世家.18.s3", "chapter": "041_越王句践世家", "para": "18", "seq": 3, "text": "” 至明年春，吴王北会诸侯於黄池，吴国精兵从王，惟独老弱与太子留守。", "len": 34}
{"sid": "041_越王句践世家.18.s4", "chapter": "041_越王句践世家", "para": "18", "seq": 4, "text": "句践复问范蠡，蠡曰“可矣”。", "len": 14}
{"sid": "041_越王句践世家.19.s1", "chapter": "041_越王句践世家", "para": "19", "seq": 1, "text": "乃发习流二千人，教士四万人，君子六千人，诸御千人，伐吴。", "len": 28}
{"sid": "041_越王句践世家.19.s2", "chapter": "041_越王句践世家", "para": "19", "seq": 2, "text": "吴师败，遂杀吴太子。", "len": 10}
{"sid": "041_越王句践世家.19.s3", "chapter": "041_越王句践世家", "para": "19", "seq": 3, "text": "吴告急於王，王方会诸侯於黄池，惧天下闻之，乃祕之。", "len": 25}
{"sid": "041_越王句践世家.19.s4", "chapter": "041_越王句践世家", "para": "19", "seq": 4, "text": "吴王已盟黄池，乃使人厚礼以请成越。", "len": 17}
{"sid": "041_越王句践世家.19.s5", "chapter": "041_越王句践世家", "para": "19", "seq": 5, "text": "越自度亦未能灭吴，乃与吴平。", "len": 14}
{"sid": "041_越王句践世家.20.s1", "chapter": "041_越王句践世家", "para": "20", "seq": 1, "text": "其後四年，越复伐吴。", "len": 10}
{"sid": "041_越王句践世家.20.s2", "chapter": "041_越王句践世家", "para": "20", "seq": 2, "text": "吴士民罢弊，轻锐尽死於齐、晋。", "len": 15}
{"sid": "041_越王句践世家.20.s3", "chapter": "041_越王句践世家", "para": "20", "seq": 3, "text": "而越大破吴，因而留围之三年，吴师败，越遂复栖吴王於姑苏之山。", "len": 30}
{"sid": "041_越王句践世家.21.s1", "chapter": "041_越王句践世家", "para": "21", "seq": 1, "text": "吴王使公孙雄肉袒膝行而前，请成越王曰：“孤臣夫差敢布腹心，异日尝得罪於会稽，夫差不敢逆命，得与君王成以归。", "len": 53}
{"sid": "041_越王句践世家.21.s2", "chapter": "041_越王句践世家", "para": "21", "seq": 2, "text": "今君王举玉趾而诛孤臣，孤臣惟命是听，意者亦欲如会稽之赦孤臣之罪乎？", "len": 33}
{"sid": "041_越王句践世家.21.s3", "chapter": "041_越王句践世家", "para": "21", "seq": 3, "text": "” 句践不忍，欲许之。", "len": 11}
{"sid": "041_越王句践世家.21.s4", "chapter": "041_越王句践世家", "para": "21", "seq": 4, "text": "范蠡曰：“会稽之事，天以越赐吴，吴不取。", "len": 20}
{"sid": "041_越王句践世家.21.s5", "chapter": "041_越王句践世家", "para": "21", "seq": 5, "text": "今天以吴赐越，越其可逆天乎？", "len": 14}
{"sid": "041_越王句践世家.21.s6", "chapter": "041_越王句践世家", "para": "21", "seq": 6, "text": "且夫君王蚤朝晏罢，非为吴邪？", "len": 14}
{"sid": "041_越王句践世家.21.s7", "chapter": "041_越王句践世家", "para": "21", "seq": 7, "text": "谋之二十二年，一旦而弃之，可乎？", "len": 16}
{"sid": "041_越王句践世家.21.s8", "chapter": "041_越王句践世家", "para": "21", "seq": 8, "text": "且夫天与弗取，反受其咎。", "len": 12}
{"sid": "041_越王句践世家.21.s9", "chapter": "041_越王句践世家", "para": "21", "seq": 9, "text": "‘伐柯者其则不远’，君忘会稽之戹乎？", "len": 18}
{"sid": "041_越王句践世家.21.s10", "chapter": "041_越王句践世家", "para": "21", "seq": 10, "text": "” 句践曰：“吾欲听子言，吾不忍其使者。", "len": 20}
{"sid": "041_越王句践世家.21.s11", "chapter": "041_越王句践世家", "para": "21", "seq": 11, "text": "” 范蠡乃鼓进兵，曰：“王已属政於执事，使者去，不者且得罪。”", "len": 31}
{"sid": "041_越王句践世家.22.s1", "chapter": "041_越王句践世家", "para": "22", "seq": 1, "text": "吴使者泣而去。", "len": 7}
{"sid": "041_越王句践世家.22.s2", "chapter": "041_越王句践世家", "para": "22", "seq": 2, "text": "句践怜之，乃使人谓吴王曰：“吾置王甬东，君百家。", "len": 24}
{"sid": "041_越王句践世家.22.s3", "chapter": "041_越王句践世家", "para": "22", "seq": 3, "text": "” 吴王谢曰：“吾老矣，不能事君王！", "len": 18}
{"sid": "041_越王句践世家.22.s4", "chapter": "041_越王句践世家", "para": "22", "seq": 4, "text": "” 遂自杀。", "len": 6}
{"sid": "041_越王句践世家.22.s5", "chapter": "041_越王句践世家", "para": "22", "seq": 5, "text": "乃蔽其面，曰：“吾无面以见子胥也！", "len": 17}
{"sid": "041_越王句践世家.22.s6", "chapter": "041_越王句践世家", "para": "22", "seq": 6, "text": "” 越王乃葬吴王而诛太宰嚭。", "len": 14}
{"sid": "041_越王句践世家.23.s1", "chapter": "041_越王句践世家", "para": "23", "seq": 1, "text": "句践已平吴，乃以兵北渡淮，与齐、晋诸侯会於徐州，致贡於周。", "len": 29}
{"sid": "041_越王句践世家.23.s2", "chapter": "041_越王句践世家", "para": "23", "seq": 2, "text": "周元王使人赐句践胙，命为伯。", "len": 14}
{"sid": "041_越王句践世家.23.s3", "chapter": "041_越王句践世家", "para": "23", "seq": 3, "text": "句践已去，渡淮南，以淮上地与楚，归吴所侵宋地於宋，与鲁泗东方百里。", "len": 33}
{"sid": "041_越王句践世家.23.s4", "chapter": "041_越王句践世家", "para": "23", "seq": 4, "text": "当是时，越兵横行於江、淮东，诸侯毕贺，号称霸王。", "len": 24}
{"sid": "041_越王句践世家.24.s1", "chapter": "041_越王句践世家", "para": "24", "seq": 1, "text": "范蠡遂去，自齐遗大夫种书曰：“蜚鸟尽，良弓藏；狡兔死，走狗烹。", "len": 31}
{"sid": "041_越王句践世家.24.s2", "chapter": "041_越王句践世家", "para": "24", "seq": 2, "text": "越王为人长颈鸟喙，可与共患难，不可与共乐。", "len": 21}
{"sid": "041_越王句践世家.24.s3", "chapter": "041_越王句践世家", "para": "24", "seq": 3, "text": "子何不去？", "len": 5}
{"sid": "041_越王句践世家.24.s4", "chapter": "041_越王句践世家", "para": "24", "seq": 4, "text": "” 种见书，称病不朝。", "len": 11}
{"sid": "041_越王句践世家.24.s5", "chapter": "041_越王句践世家", "para": "24", "seq": 5, "text": "人或谗种且作乱，越王乃赐种剑曰：“子教寡人伐吴七术，寡人用其三而败吴，其四在子，子为我从先王试之。", "len": 49}
{"sid": "041_越王句践世家.24.s6", "chapter": "041_越王句践世家", "para": "24", "seq": 6, "text": "” 种遂自杀。", "len": 7}
{"sid": "041_越王句践世家.25.s1", "chapter": "041_越王句践世家", "para": "25", "seq": 1, "text": "句践卒，子王鼫与立。", "len": 10}
{"sid": "041_越王句践世家.25.s2", "chapter": "041_越王句践世家", "para": "25", "seq": 2, "text": "王鼫与卒，子王不寿立。", "len": 11}
{"sid": "041_越王句践世家.25.s3", "chapter": "041_越王句践世家", "para": "25", "seq": 3, "text": "王不寿卒，子王翁立。", "len": 10}
{"sid": "041_越王句践世家.25.s4", "chapter": "041_越王句践世家", "para": "25", "seq": 4, "text": "王翁卒，子王翳立。", "len": 9}
{"sid": "041_越王句践世家.25.s5", "chapter": "041_越王句践世家", "para": "25", "seq": 5, "text": "王翳卒，子王之侯立。", "len": 10}
{"sid": "041_越王句践世家.25.s6", "chapter": "041_越王句践世家", "para": "25", "seq": 6, "text": "王之侯卒，子王无彊立。", "len": 11}
{"sid": "041_越王句践世家.26.s1", "chapter": "041_越王句践世家", "para": "26", "seq": 1, "text": "王无彊时，越兴师北伐齐，西伐楚，与中国争彊。", "len": 22}
{"sid": "041_越王句践世家.27.s1", "chapter": "041_越王句践世家", "para": "27", "seq": 1, "text": "当楚威王之时，越北伐齐，齐威王使人说越王曰：“越不伐楚，大不王，小不伯。", "len": 36}
{"sid": "041_越王句践世家.27.s2", "chapter": "041_越王句践世家", "para": "27", "seq": 2, "text": "图越之所为不伐楚者，为不得晋也。", "len": 16}
{"sid": "041_越王句践世家.27.s3", "chapter": "041_越王句践世家", "para": "27", "seq": 3, "text": "韩、魏固不攻楚。", "len": 8}
{"sid": "041_越王句践世家.27.s4", "chapter": "041_越王句践世家", "para": "27", "seq": 4, "text": "韩之攻楚，覆其军，杀其将，则叶、阳翟危；魏亦覆其军，杀其将，则陈、上蔡不安。", "len": 38}
{"sid": "041_越王句践世家.27.s5", "chapter": "041_越王句践世家", "para": "27", "seq": 5, "text": "故二晋之事越也，不至於覆军杀将，马汗之力不效。", "len": 23}
{"sid": "041_越王句践世家.27.s6", "chapter": "041_越王句践世家", "para": "27", "seq": 6, "text": "所重於得晋者何也？", "len": 9}
{"sid": "041_越王句践世家.27.s7", "chapter": "041_越王句践世家", "para": "27", "seq": 7, "text": "” 越王曰：“所求於晋者，不至顿刃接兵，而况于攻城围邑乎？", "len": 29}
{"sid": "041_越王句践世家.27.s8", "chapter": "041_越王句践世家", "para": "27", "seq": 8, "text": "原魏以聚大梁之下，原齐之试兵南阳莒地，以聚常、郯之境，则方城之外不南，淮、泗之间不东，商、於、析、郦、宗胡之地，夏路以左，不足以备秦，江南、泗上不足以待越矣。", "len": 79}
{"sid": "041_越王句践世家.27.s9", "chapter": "041_越王句践世家", "para": "27", "seq": 9, "text": "则齐、秦、韩、魏得志於楚也，是二晋不战分地，不耕而穫之。", "len": 28}
{"sid": "041_越王句践世家.27.s10", "chapter": "041_越王句践世家", "para": "27", "seq": 10, "text": "不此之为，而顿刃於河山之间以为齐秦用，所待者如此其失计，柰何其以此王也！", "len": 36}
{"sid": "041_越王句践世家.27.s11", "chapter": "041_越王句践世家", "para": "27", "seq": 11, "text": "” 齐使者曰：“幸也越之不亡也！", "len": 16}
{"sid": "041_越王句践世家.27.s12", "chapter": "041_越王句践世家", "para": "27", "seq": 12, "text": "吾不贵其用智之如目，见豪毛而不见其睫|目不见睫也。", "len": 25}
{"sid": "041_越王句践世家.27.s13", "chapter": "041_越王句践世家", "para": "27", "seq": 13, "text": "今王知晋之失计，而不自知越之过，是目论也。", "len": 21}
{"sid": "041_越王句践世家.27.s14", "chapter": "041_越王句践世家", "para": "27", "seq": 14, "text": "王所待於晋者，非有马汗之力也，又非可与合军连和也，将待之以分楚众也。", "len": 34}
{"sid": "041_越王句践世家.27.s15", "chapter": "041_越王句践世家", "para": "27", "seq": 15, "text": "今楚众已分，何待於晋？", "len": 11}
{"sid": "041_越王句践世家.27.s16", "chapter": "041_越王句践世家", "para": "27", "seq": 16, "text": "” 越王曰：“柰何？", "len": 10}
{"sid": "041_越王句践世家.27.s17", "chapter": "041_越王句践世家", "para": "27", "seq": 17, "text": "” 曰：“楚三大夫张九军，北围曲沃、於中，以至无假之关者三千七百里，景翠之军北聚鲁、齐、南阳，分有大此者乎？", "len": 54}
{"sid": "041_越王句践世家.27.s18", "chapter": "041_越王句践世家", "para": "27", "seq": 18, "text": "且王之所求者，斗晋楚也；晋楚不斗，越兵不起，是知二五而不知十也。", "len": 32}
{"sid": "041_越王句践世家.27.s19", "chapter": "041_越王句践世家", "para": "27", "seq": 19, "text": "此时不攻楚，臣以是知越大不王，小不伯。", "len": 19}
{"sid": "041_越王句践世家.27.s20", "chapter": "041_越王句践世家", "para": "27", "seq": 20, "text": "复雠、庞、长沙，楚之粟也；竟泽陵，楚之材也。", "len": 22}
{"sid": "041_越王句践世家.27.s21", "chapter": "041_越王句践世家", "para": "27", "seq": 21, "text": "越窥兵通无假之关，此四邑者不上贡事於郢矣。", "len": 21}
{"sid": "041_越王句践世家.27.s22", "chapter": "041_越王句践世家", "para": "27", "seq": 22, "text": "臣闻之，图王不王，其敝可以伯。", "len": 15}
{"sid": "041_越王句践世家.27.s23", "chapter": "041_越王句践世家", "para": "27", "seq": 23, "text": "然而不伯者，王道失也。", "len": 11}
{"sid": "041_越王句践世家.27.s24", "chapter": "041_越王句践世家", "para": "27", "seq": 24, "text": "故原大王之转攻楚也。”", "len": 11}
{"sid": "041_越王句践世家.28.s1", "chapter": "041_越王句践世家", "para": "28", "seq": 1, "text": "於是越遂释齐而伐楚。", "len": 10}
{"sid": "041_越王句践世家.28.s2", "chapter": "041_越王句践世家", "para": "28", "seq": 2, "text": "楚威王兴兵而伐之，大败越，杀王无彊，尽取故吴地至浙江，北破齐於徐州。", "len": 34}
{"sid": "041_越王句践世家.28.s3", "chapter": "041_越王句践世家", "para": "28", "seq": 3, "text": "而越以此散，诸族子争立，或为王，或为君，滨於江南海上，服朝於楚。", "len": 32}
{"sid": "041_越王句践世家.29.s1", "chapter": "041_越王句践世家", "para": "29", "seq": 1, "text": "後七世，至闽君摇，佐诸侯平秦。", "len": 15}
{"sid": "041_越王句践世家.29.s2", "chapter": "041_越王句践世家", "para": "29", "seq": 2, "text": "汉高帝复以摇为越王，以奉越後。", "len": 15}
{"sid": "041_越王句践世家.29.s3", "chapter": "041_越王句践世家", "para": "29", "seq": 3, "text": "东越，闽君，皆其後也。", "len": 11}
{"sid": "041_越王句践世家.30.s1", "chapter": "041_越王句践世家", "para": "30", "seq": 1, "text": "范蠡事越王句践，既苦身戮力，与句践深谋二十馀年，竟灭吴，报会稽之耻，北渡兵於淮以临齐、晋，号令中国，以尊周室，句践以霸，而范蠡称上将军。", "len": 68}
{"sid": "041_越王句践世家.30.s2", "chapter": "041_越王句践世家", "para": "30", "seq": 2, "text": "还反国，范蠡以为大名之下，难以久居，且句践为人可与同患，难与处安，为书辞句践曰：“臣闻主忧臣劳，主辱臣死。", "len": 53}
{"sid": "041_越王句践世家.30.s3", "chapter": "041_越王句践世家", "para": "30", "seq": 3, "text": "昔者君王辱於会稽，所以不死，为此事也。", "len": 19}
{"sid": "041_越王句践世家.30.s4", "chapter": "041_越王句践世家", "para": "30", "seq": 4, "text": "今既以雪耻，臣请从会稽之诛。", "len": 14}
{"sid": "041_越王句践世家.30.s5", "chapter": "041_越王句践世家", "para": "30", "seq": 5, "text": "” 句践曰：“孤将与子分国而有之。", "len": 17}
{"sid": "041_越王句践世家.30.s6", "chapter": "041_越王句践世家", "para": "30", "seq": 6, "text": "不然，将加诛于子。", "len": 9}
{"sid": "041_越王句践世家.30.s7", "chapter": "041_越王句践世家", "para": "30", "seq": 7, "text": "” 范蠡曰：“君行令，臣行意。”", "len": 16}
{"sid": "041_越王句践世家.31.s1", "chapter": "041_越王句践世家", "para": "31", "seq": 1, "text": "乃装其轻宝珠玉，自与其私徒属乘舟浮海以行，终不反。", "len": 25}
{"sid": "041_越王句践世家.31.s2", "chapter": "041_越王句践世家", "para": "31", "seq": 2, "text": "於是句践表会稽山以为范蠡奉邑。", "len": 15}
{"sid": "041_越王句践世家.32.s1", "chapter": "041_越王句践世家", "para": "32", "seq": 1, "text": "范蠡浮海出齐，变姓名，自谓鸱夷子皮，耕于海畔，苦身戮力，父子治产。", "len": 33}
{"sid": "041_越王句践世家.32.s2", "chapter": "041_越王句践世家", "para": "32", "seq": 2, "text": "居无几何，致产数十万。", "len": 11}
{"sid": "041_越王句践世家.32.s3", "chapter": "041_越王句践世家", "para": "32", "seq": 3, "text": "齐人闻其贤，以为相。", "len": 10}
{"sid": "041_越王句践世家.32.s4", "chapter": "041_越王句践世家", "para": "32", "seq": 4, "text": "范蠡喟然叹曰：“居家则致千金，居官则至卿相，此布衣之极也。", "len": 29}
{"sid": "041_越王句践世家.32.s5", "chapter": "041_越王句践世家", "para": "32", "seq": 5, "text": "久受尊名，不祥。”", "len": 9}
{"sid": "041_越王句践世家.33.s1", "chapter": "041_越王句践世家", "para": "33", "seq": 1, "text": "乃归相印，尽散其财，以分与知友乡党，而怀其重宝，间行以去，止于陶，以为此天下之中，交易有无之路通，为生可以致富矣。", "len": 57}
{"sid": "041_越王句践世家.33.s2", "chapter": "041_越王句践世家", "para": "33", "seq": 2, "text": "於是自谓陶硃公。", "len": 8}
{"sid": "041_越王句践世家.33.s3", "chapter": "041_越王句践世家", "para": "33", "seq": 3, "text": "复约要父子耕畜，废居，候时转物，逐什一之利。", "len": 22}
{"sid": "041_越王句践世家.33.s4", "chapter": "041_越王句践世家", "para": "33", "seq": 4, "text": "居无何，则致赀累巨万。", "len": 11}
{"sid": "041_越王句践世家.33.s5", "chapter": "041_越王句践世家", "para": "33", "seq": 5, "text": "天下称陶硃公。", "len": 7}
{"sid": "041_越王句践世家.34.s1", "chapter": "041_越王句践世家", "para": "34", "seq": 1, "text": "硃公居陶，生少子。", "len": 9}
{"sid": "041_越王句践世家.34.s2", "chapter": "041_越王句践世家", "para": "34", "seq": 2, "text": "少子及壮，而硃公中男杀人，囚於楚。", "len": 17}
{"sid": "041_越王句践世家.34.s3", "chapter": "041_越王句践世家", "para": "34", "seq": 3, "text": "硃公曰：“杀人而死，职也。", "len": 13}
{"sid": "041_越王句践世家.34.s4", "chapter": "041_越王句践世家", "para": "34", "seq": 4, "text": "然吾闻千金之子不死於市。", "len": 12}
{"sid": "041_越王句践世家.34.s5", "chapter": "041_越王句践世家", "para": "34", "seq": 5, "text": "” 告其少子往视之。", "len": 10}
{"sid": "041_越王句践世家.34.s6", "chapter": "041_越王句践世家", "para": "34", "seq": 6, "text": "乃装黄金千溢，置褐器中，载以一牛车。", "len": 18}
{"sid": "041_越王句践世家.34.s7", "chapter": "041_越王句践世家", "para": "34", "seq": 7, "text": "且遣其少子，硃公长男固请欲行，硃公不听。", "len": 20}
{"sid": "041_越王句践世家.35.s1", "chapter": "041_越王句践世家", "para": "35", "seq": 1, "text": "长男曰：“家有长子曰家督，今弟有罪，大人不遣，乃遗少弟，是吾不肖。", "len": 33}
{"sid": "041_越王句践世家.35.s2", "chapter": "041_越王句践世家", "para": "35", "seq": 2, "text": "” 欲自杀。", "len": 6}
{"sid": "041_越王句践世家.35.s3", "chapter": "041_越王句践世家", "para": "35", "seq": 3, "text": "其母为言曰：”今遣少子，未必能生中子也，而先空亡长男，柰何？", "len": 30}
{"sid": "041_越王句践世家.35.s4", "chapter": "041_越王句践世家", "para": "35", "seq": 4, "text": "” 硃公不得已而遣长男，为一封书遗故所善庄生。", "len": 23}
{"sid": "041_越王句践世家.35.s5", "chapter": "041_越王句践世家", "para": "35", "seq": 5, "text": "曰：“至则进千金于庄生所，听其所为，慎无与争事。", "len": 24}
{"sid": "041_越王句践世家.35.s6", "chapter": "041_越王句践世家", "para": "35", "seq": 6, "text": "” 长男既行，亦自私赍数百金。", "len": 15}
{"sid": "041_越王句践世家.36.s1", "chapter": "041_越王句践世家", "para": "36", "seq": 1, "text": "至楚，庄生家负郭，披藜藋到门，居甚贫。", "len": 19}
{"sid": "041_越王句践世家.36.s2", "chapter": "041_越王句践世家", "para": "36", "seq": 2, "text": "然长男发书进千金，如其父言。", "len": 14}
{"sid": "041_越王句践世家.36.s3", "chapter": "041_越王句践世家", "para": "36", "seq": 3, "text": "庄生曰：“可疾去矣，慎毋留！", "len": 14}
{"sid": "041_越王句践世家.36.s4", "chapter": "041_越王句践世家", "para": "36", "seq": 4, "text": "即弟出，勿问所以然。", "len": 10}
{"sid": "041_越王句践世家.36.s5", "chapter": "041_越王句践世家", "para": "36", "seq": 5, "text": "” 长男既去，不过庄生而私留，以其私赍献遗楚国贵人用事者。", "len": 29}
{"sid": "041_越王句践世家.36.s6", "chapter": "041_越王句践世家", "para": "36", "seq": 6, "text": "庄生虽居穷阎，然以廉直闻於国，自楚王以下皆师尊之。", "len": 25}
{"sid": "041_越王句践世家.36.s7", "chapter": "041_越王句践世家", "para": "36", "seq": 7, "text": "及硃公进金，非有意受也，欲以成事後复归之以为信耳。", "len": 25}
{"sid": "041_越王句践世家.36.s8", "chapter": "041_越王句践世家", "para": "36", "seq": 8, "text": "故金至，谓其妇曰：”此硃公之金。", "len": 16}
{"sid": "041_越王句践世家.36.s9", "chapter": "041_越王句践世家", "para": "36", "seq": 9, "text": "有如病不宿诫，後复归，勿动。", "len": 14}
{"sid": "041_越王句践世家.36.s10", "chapter": "041_越王句践世家", "para": "36", "seq": 10, "text": "” 而硃公长男不知其意，以为殊无短长也。", "len": 20}
{"sid": "041_越王句践世家.37.s1", "chapter": "041_越王句践世家", "para": "37", "seq": 1, "text": "庄生间时入见楚王，言” 某星宿某，此则害於楚”。", "len": 24}
{"sid": "041_越王句践世家.37.s2", "chapter": "041_越王句践世家", "para": "37", "seq": 2, "text": "楚王素信庄生，曰：“今为柰何？", "len": 15}
{"sid": "041_越王句践世家.37.s3", "chapter": "041_越王句践世家", "para": "37", "seq": 3, "text": "” 庄生曰：“独以德为可以除之。", "len": 16}
{"sid": "041_越王句践世家.37.s4", "chapter": "041_越王句践世家", "para": "37", "seq": 4, "text": "” 楚王曰：“生休矣，寡人将行之。", "len": 17}
{"sid": "041_越王句践世家.37.s5", "chapter": "041_越王句践世家", "para": "37", "seq": 5, "text": "” 王乃使使者封三钱之府。", "len": 13}
{"sid": "041_越王句践世家.38.s1", "chapter": "041_越王句践世家", "para": "38", "seq": 1, "text": "楚贵人惊告硃公长男曰：“王且赦。", "len": 16}
{"sid": "041_越王句践世家.38.s2", "chapter": "041_越王句践世家", "para": "38", "seq": 2, "text": "” 曰：“何以也？", "len": 9}
{"sid": "041_越王句践世家.38.s3", "chapter": "041_越王句践世家", "para": "38", "seq": 3, "text": "” 曰：“每王且赦，常封三钱之府。", "len": 17}
{"sid": "041_越王句践世家.38.s4", "chapter": "041_越王句践世家", "para": "38", "seq": 4, "text": "昨暮王使使封之。", "len": 8}
{"sid": "041_越王句践世家.38.s5", "chapter": "041_越王句践世家", "para": "38", "seq": 5, "text": "” 硃公长男以为赦，弟固当出也，重千金虚弃庄生，无所为也，乃复见庄生。", "len": 35}
{"sid": "041_越王句践世家.38.s6", "chapter": "041_越王句践世家", "para": "38", "seq": 6, "text": "庄生惊曰：“若不去邪？", "len": 11}
{"sid": "041_越王句践世家.38.s7", "chapter": "041_越王句践世家", "para": "38", "seq": 7, "text": "” 长男曰：“固未也。", "len": 11}
{"sid": "041_越王句践世家.38.s8", "chapter": "041_越王句践世家", "para": "38", "seq": 8, "text": "初为事弟，弟今议自赦，故辞生去。", "len": 16}
{"sid": "041_越王句践世家.38.s9", "chapter": "041_越王句践世家", "para": "38", "seq": 9, "text": "” 庄生知其意欲复得其金，曰：“若自入室取金。", "len": 23}
{"sid": "041_越王句践世家.38.s10", "chapter": "041_越王句践世家", "para": "38", "seq": 10, "text": "” 长男即自入室取金持去，独自欢幸。", "len": 18}
{"sid": "041_越王句践世家.39.s1", "chapter": "041_越王句践世家", "para": "39", "seq": 1, "text": "庄生羞为兒子所卖，乃入见楚王曰：“臣前言某星事，王言欲以修德报之。", "len": 33}
{"sid": "041_越王句践世家.39.s2", "chapter": "041_越王句践世家", "para": "39", "seq": 2, "text": "今臣出，道路皆言陶之富人硃公之子杀人囚楚，其家多持金钱赂王左右，故王非能恤楚国而赦，乃以硃公子故也。", "len": 50}
{"sid": "041_越王句践世家.39.s3", "chapter": "041_越王句践世家", "para": "39", "seq": 3, "text": "” 楚王大怒曰：“寡人虽不德耳，柰何以硃公之子故而施惠乎！", "len": 29}
{"sid": "041_越王句践世家.39.s4", "chapter": "041_越王句践世家", "para": "39", "seq": 4, "text": "” 令论杀硃公子，明日遂下赦令。", "len": 16}
{"sid": "041_越王句践世家.39.s5", "chapter": "041_越王句践世家", "para": "39", "seq": 5, "text": "硃公长男竟持其弟丧归。", "len": 11}
{"sid": "041_越王句践世家.40.s1", "chapter": "041_越王句践世家", "para": "40", "seq": 1, "text": "至，其母及邑人尽哀之，唯硃公独笑，曰：“吾固知必杀其弟也！", "len": 29}
{"sid": "041_越王句践世家.40.s2", "chapter": "041_越王句践世家", "para": "40", "seq": 2, "text": "彼非不爱其弟，顾有所不能忍者也。", "len": 16}
{"sid": "041_越王句践世家.40.s3", "chapter": "041_越王句践世家", "para": "40", "seq": 3, "text": "是少与我俱，见苦，为生难，故重弃财。", "len": 18}
{"sid": "041_越王句践世家.40.s4", "chapter": "041_越王句践世家", "para": "40", "seq": 4, "text": "至如少弟者，生而见我富，乘坚驱良逐狡兔，岂知财所从来，故轻弃之，非所惜吝。", "len": 37}
{"sid": "041_越王句践世家.40.s5", "chapter": "041_越王句践世家", "para": "40", "seq": 5, "text": "前日吾所为欲遣少子，固为其能弃财故也。", "len": 19}
{"sid": "041_越王句践世家.40.s6", "chapter": "041_越王句践世家", "para": "40", "seq": 6, "text": "而长者不能，故卒以杀其弟，事之理也，无足悲者。", "len": 23}
{"sid": "041_越王句践世家.40.s7", "chapter": "041_越王句践世家", "para": "40", "seq": 7, "text": "吾日夜固以望其丧之来也。", "len": 12}
{"sid": "041_越王句践世家.40.s8", "chapter": "041_越王句践世家", "para": "40", "seq": 8, "text": "” 故范蠡三徙，成名於天下，非苟去而已，所止必成名。", "len": 26}
{"sid": "041_越王句践世家.40.s9", "chapter": "041_越王句践世家", "para": "40", "seq": 9, "text": "卒老死于陶，故世传曰陶硃公。", "len": 14}
{"sid": "041_越王句践世家.40.s10", "chapter": "041_越王句践世家", "para": "40", "seq": 10, "text": "::: 太史公曰", "len": 8}
{"sid": "041_越王句践世家.41.s1", "chapter": "041_越王句践世家", "para": "41", "seq": 1, "text": "太史公曰： 禹之功大矣，渐九川，定九州，至于今诸夏艾安。", "len": 28}
{"sid": "041_越王句践世家.41.s2", "chapter": "041_越王句践世家", "para": "41", "seq": 2, "text": "及苗裔句践，苦身焦思，终灭彊吴，北观兵中国，以尊周室，号称霸王。", "len": 32}
{"sid": "041_越王句践世家.41.s3", "chapter": "041_越王句践世家", "para": "41", "seq": 3, "text": "句践可不谓贤哉！", "len": 8}
{"sid": "041_越王句践世家.41.s4", "chapter": "041_越王句践世家", "para": "41", "seq": 4, "text": "盖有禹之遗烈焉。", "len": 8}
{"sid": "041_越王句践世家.41.s5", "chapter": "041_越王句践世家", "para": "41", "seq": 5, "text": "范蠡三迁皆有荣名，名垂後世。", "len": 14}
{"sid": "041_越王句践世家.41.s6", "chapter": "041_越王句践世家", "para": "41", "seq": 6, "text": "臣主若此，欲毋显得乎！", "len": 11}
{"sid": "041_越王句践世家.41.s7", "chapter": "041_越王句践世家", "para": "41", "seq": 7, "text": "::: ::: 赞", "len": 9}
{"sid": "041_越王句践世家.42.s1", "chapter": "041_越王句践世家", "para": "42", "seq": 1, "text": "越祖少康，至于允常。", "len": 10}
{"sid": "041_越王句践世家.42.s2", "chapter": "041_越王句践世家", "para": "42", "seq": 2, "text": "其子始霸，与吴争彊。", "len": 10}
{"sid": "041_越王句践世家.42.s3", "chapter": "041_越王句践世家", "para": "42", "seq": 3, "text": "槜李之役，阖闾见伤。", "len": 10}
{"sid": "041_越王句践世家.42.s4", "chapter": "041_越王句践世家", "para": "42", "seq": 4, "text": "会稽之耻，句践欲当。", "len": 10}
{"sid": "041_越王句践世家.42.s5", "chapter": "041_越王句践世家", "para": "42", "seq": 5, "text": "种诱以利，蠡悉其良。", "len": 10}
{"sid": "041_越王句践世家.42.s6", "chapter": "041_越王句践世家", "para": "42", "seq": 6, "text": "折节下士，致胆思尝。", "len": 10}
{"sid": "041_越王句践世家.42.s7", "chapter": "041_越王句践世家", "para": "42", "seq": 7, "text": "卒复雠寇，遂殄大邦。", "len": 10}
{"sid": "041_越王句践世家.42.s8", "chapter": "041_越王句践世家", "para": "42", "seq": 8, "text": "後不量力，灭於无彊。", "len": 10}
{"sid": "041_越王句践世家.42.s9", "chapter": "041_越王句践世家", "para": "42", "seq": 9, "text": ":::", "len": 3}
