{"sid": "125_佞幸列传.1.s1", "chapter": "125_佞幸列传", "para": "1", "seq": 1, "text": "谚曰“力田不如逢年，善仕不如遇合”，固无虚言。", "len": 23}
{"sid": "125_佞幸列传.1.s2", "chapter": "125_佞幸列传", "para": "1", "seq": 2, "text": "非独女以色媚，而士宦亦有之。", "len": 14}
{"sid": "125_佞幸列传.2.s1", "chapter": "125_佞幸列传", "para": "2", "seq": 1, "text": "昔以色幸者多矣。", "len": 8}
{"sid": "125_佞幸列传.2.s2", "chapter": "125_佞幸列传", "para": "2", "seq": 2, "text": "至汉兴，高祖至暴抗也，然籍孺以佞幸；孝惠时有闳孺。", "len": 25}
{"sid": "125_佞幸列传.2.s3", "chapter": "125_佞幸列传", "para": "2", "seq": 3, "text": "此两人非有材能，徒以婉佞贵幸，与上卧起，公卿皆因关说。", "len": 27}
{"sid": "125_佞幸列传.2.s4", "chapter": "125_佞幸列传", "para": "2", "seq": 4, "text": "故孝惠时郎侍中皆冠鵕璘，贝带，傅脂粉，化闳、籍之属也。", "len": 27}
{"sid": "125_佞幸列传.2.s5", "chapter": "125_佞幸列传", "para": "2", "seq": 5, "text": "两人徙家安陵。", "len": 7}
{"sid": "125_佞幸列传.3.s1", "chapter": "125_佞幸列传", "para": "3", "seq": 1, "text": "孝文时中宠臣，士人则邓通，宦者则赵同、北宫伯子。", "len": 24}
{"sid": "125_佞幸列传.3.s2", "chapter": "125_佞幸列传", "para": "3", "seq": 2, "text": "北宫伯子以爱人长者；而赵同以星气幸，常为文帝参乘；邓通无伎能。", "len": 31}
{"sid": "125_佞幸列传.3.s3", "chapter": "125_佞幸列传", "para": "3", "seq": 3, "text": "邓通，蜀郡南安人也，以濯船为黄头郎。", "len": 18}
{"sid": "125_佞幸列传.3.s4", "chapter": "125_佞幸列传", "para": "3", "seq": 4, "text": "孝文帝梦欲上天，不能，有一黄头郎从後推之上天，顾见其衣裻带後穿。", "len": 32}
{"sid": "125_佞幸列传.3.s5", "chapter": "125_佞幸列传", "para": "3", "seq": 5, "text": "觉而之渐台，以梦中阴目求推者郎，即见邓通，其衣後穿，梦中所见也。", "len": 32}
{"sid": "125_佞幸列传.3.s6", "chapter": "125_佞幸列传", "para": "3", "seq": 6, "text": "召问其名姓，姓邓氏，名通，文帝说焉，尊幸之日异。", "len": 24}
{"sid": "125_佞幸列传.3.s7", "chapter": "125_佞幸列传", "para": "3", "seq": 7, "text": "通亦愿谨，不好外交，虽赐洗沐，不欲出。", "len": 19}
{"sid": "125_佞幸列传.3.s8", "chapter": "125_佞幸列传", "para": "3", "seq": 8, "text": "於是文帝赏赐通巨万以十数，官至上大夫。", "len": 19}
{"sid": "125_佞幸列传.3.s9", "chapter": "125_佞幸列传", "para": "3", "seq": 9, "text": "文帝时时如邓通家游戏。", "len": 11}
{"sid": "125_佞幸列传.3.s10", "chapter": "125_佞幸列传", "para": "3", "seq": 10, "text": "然邓通无他能，不能有所荐士，独自谨其身以媚上而已。", "len": 25}
{"sid": "125_佞幸列传.3.s11", "chapter": "125_佞幸列传", "para": "3", "seq": 11, "text": "上使善相者相通，曰“当贫饿死”。", "len": 16}
{"sid": "125_佞幸列传.3.s12", "chapter": "125_佞幸列传", "para": "3", "seq": 12, "text": "文帝曰：“能富通者在我也。", "len": 13}
{"sid": "125_佞幸列传.3.s13", "chapter": "125_佞幸列传", "para": "3", "seq": 13, "text": "何谓贫乎？", "len": 5}
{"sid": "125_佞幸列传.3.s14", "chapter": "125_佞幸列传", "para": "3", "seq": 14, "text": "” 於是赐邓通蜀严道铜山，得自铸钱，“邓氏钱” 布天下。", "len": 28}
{"sid": "125_佞幸列传.3.s15", "chapter": "125_佞幸列传", "para": "3", "seq": 15, "text": "其富如此。", "len": 5}
{"sid": "125_佞幸列传.4.s1", "chapter": "125_佞幸列传", "para": "4", "seq": 1, "text": "文帝尝病痈，邓通常为帝唶吮之。", "len": 15}
{"sid": "125_佞幸列传.4.s2", "chapter": "125_佞幸列传", "para": "4", "seq": 2, "text": "文帝不乐，从容问通曰：“天下谁最爱我者乎？", "len": 21}
{"sid": "125_佞幸列传.4.s3", "chapter": "125_佞幸列传", "para": "4", "seq": 3, "text": "” 通曰：“宜莫如太子。", "len": 12}
{"sid": "125_佞幸列传.4.s4", "chapter": "125_佞幸列传", "para": "4", "seq": 4, "text": "” 太子入问病，文帝使唶痈，唶痈而色难之。", "len": 21}
{"sid": "125_佞幸列传.4.s5", "chapter": "125_佞幸列传", "para": "4", "seq": 5, "text": "已而闻邓通常为帝唶吮之，心惭，由此怨通矣。", "len": 21}
{"sid": "125_佞幸列传.4.s6", "chapter": "125_佞幸列传", "para": "4", "seq": 6, "text": "及文帝崩，景帝立，邓通免，家居。", "len": 16}
{"sid": "125_佞幸列传.4.s7", "chapter": "125_佞幸列传", "para": "4", "seq": 7, "text": "居无何，人有告邓通盗出徼外铸钱。", "len": 16}
{"sid": "125_佞幸列传.4.s8", "chapter": "125_佞幸列传", "para": "4", "seq": 8, "text": "下吏验问，颇有之，遂竟案，尽没入邓通家，尚负责数巨万。", "len": 27}
{"sid": "125_佞幸列传.4.s9", "chapter": "125_佞幸列传", "para": "4", "seq": 9, "text": "长公主赐邓通，吏辄随没入之，一簪不得著身。", "len": 21}
{"sid": "125_佞幸列传.4.s10", "chapter": "125_佞幸列传", "para": "4", "seq": 10, "text": "於是长公主乃令假衣食。", "len": 11}
{"sid": "125_佞幸列传.4.s11", "chapter": "125_佞幸列传", "para": "4", "seq": 11, "text": "竟不得名一钱，寄死人家。", "len": 12}
{"sid": "125_佞幸列传.5.s1", "chapter": "125_佞幸列传", "para": "5", "seq": 1, "text": "孝景帝时，中无宠臣，然独郎中令周文仁，仁宠最过庸，乃不甚笃。", "len": 30}
{"sid": "125_佞幸列传.6.s1", "chapter": "125_佞幸列传", "para": "6", "seq": 1, "text": "今天子中宠臣，士人则韩王孙嫣，宦者则李延年。", "len": 22}
{"sid": "125_佞幸列传.6.s2", "chapter": "125_佞幸列传", "para": "6", "seq": 2, "text": "嫣者，弓高侯孽孙也。", "len": 10}
{"sid": "125_佞幸列传.6.s3", "chapter": "125_佞幸列传", "para": "6", "seq": 3, "text": "今上为胶东王时，嫣与上学书相爱。", "len": 16}
{"sid": "125_佞幸列传.6.s4", "chapter": "125_佞幸列传", "para": "6", "seq": 4, "text": "及上为太子，愈益亲嫣。", "len": 11}
{"sid": "125_佞幸列传.6.s5", "chapter": "125_佞幸列传", "para": "6", "seq": 5, "text": "嫣善骑射，善佞。", "len": 8}
{"sid": "125_佞幸列传.6.s6", "chapter": "125_佞幸列传", "para": "6", "seq": 6, "text": "上即位，欲事伐匈奴，而嫣先习胡兵，以故益尊贵，官至上大夫，赏赐拟於邓通。", "len": 36}
{"sid": "125_佞幸列传.6.s7", "chapter": "125_佞幸列传", "para": "6", "seq": 7, "text": "时嫣常与上卧起。", "len": 8}
{"sid": "125_佞幸列传.6.s8", "chapter": "125_佞幸列传", "para": "6", "seq": 8, "text": "江都王入朝，有诏得从入猎上林中。", "len": 16}
{"sid": "125_佞幸列传.6.s9", "chapter": "125_佞幸列传", "para": "6", "seq": 9, "text": "天子车驾跸道未行，而先使嫣乘副车，从数十百骑，骛驰视兽。", "len": 28}
{"sid": "125_佞幸列传.6.s10", "chapter": "125_佞幸列传", "para": "6", "seq": 10, "text": "江都王望见，以为天子，辟从者，伏谒道傍。", "len": 20}
{"sid": "125_佞幸列传.6.s11", "chapter": "125_佞幸列传", "para": "6", "seq": 11, "text": "嫣驱不见。", "len": 5}
{"sid": "125_佞幸列传.6.s12", "chapter": "125_佞幸列传", "para": "6", "seq": 12, "text": "既过，江都王怒，为皇太后泣曰：“请得归国入宿卫，比韩嫣。", "len": 28}
{"sid": "125_佞幸列传.6.s13", "chapter": "125_佞幸列传", "para": "6", "seq": 13, "text": "” 太后由此嗛嫣。", "len": 9}
{"sid": "125_佞幸列传.6.s14", "chapter": "125_佞幸列传", "para": "6", "seq": 14, "text": "嫣侍上，出入永巷不禁，以奸闻皇太后。", "len": 18}
{"sid": "125_佞幸列传.6.s15", "chapter": "125_佞幸列传", "para": "6", "seq": 15, "text": "皇太后怒，使使赐嫣死。", "len": 11}
{"sid": "125_佞幸列传.6.s16", "chapter": "125_佞幸列传", "para": "6", "seq": 16, "text": "上为谢，终不能得，嫣遂死。", "len": 13}
{"sid": "125_佞幸列传.6.s17", "chapter": "125_佞幸列传", "para": "6", "seq": 17, "text": "而案道侯韩说，其弟也，亦佞幸。", "len": 15}
{"sid": "125_佞幸列传.7.s1", "chapter": "125_佞幸列传", "para": "7", "seq": 1, "text": "李延年，中山人也。", "len": 9}
{"sid": "125_佞幸列传.7.s2", "chapter": "125_佞幸列传", "para": "7", "seq": 2, "text": "父母及身兄弟及女，皆故倡也。", "len": 14}
{"sid": "125_佞幸列传.7.s3", "chapter": "125_佞幸列传", "para": "7", "seq": 3, "text": "延年坐法腐，给事狗中。", "len": 11}
{"sid": "125_佞幸列传.7.s4", "chapter": "125_佞幸列传", "para": "7", "seq": 4, "text": "而平阳公主言延年女弟善舞，上见，心说之，及入永巷，而召贵延年。", "len": 31}
{"sid": "125_佞幸列传.7.s5", "chapter": "125_佞幸列传", "para": "7", "seq": 5, "text": "延年善歌，为变新声，而上方兴天地祠，欲造乐诗歌弦之。", "len": 26}
{"sid": "125_佞幸列传.7.s6", "chapter": "125_佞幸列传", "para": "7", "seq": 6, "text": "延年善承意，弦次初诗。", "len": 11}
{"sid": "125_佞幸列传.7.s7", "chapter": "125_佞幸列传", "para": "7", "seq": 7, "text": "其女弟亦幸，有子男。", "len": 10}
{"sid": "125_佞幸列传.7.s8", "chapter": "125_佞幸列传", "para": "7", "seq": 8, "text": "延年佩二千石印，号协声律。", "len": 13}
{"sid": "125_佞幸列传.7.s9", "chapter": "125_佞幸列传", "para": "7", "seq": 9, "text": "与上卧起，甚贵幸，埒如韩嫣也。", "len": 15}
{"sid": "125_佞幸列传.7.s10", "chapter": "125_佞幸列传", "para": "7", "seq": 10, "text": "久之，浸与中人乱，出入骄恣。", "len": 14}
{"sid": "125_佞幸列传.7.s11", "chapter": "125_佞幸列传", "para": "7", "seq": 11, "text": "及其女弟李夫人卒後，爱弛，则禽诛延年昆弟也。", "len": 22}
{"sid": "125_佞幸列传.8.s1", "chapter": "125_佞幸列传", "para": "8", "seq": 1, "text": "自是之後，内宠嬖臣大底外戚之家，然不足数也。", "len": 22}
{"sid": "125_佞幸列传.8.s2", "chapter": "125_佞幸列传", "para": "8", "seq": 2, "text": "卫青、霍去病亦以外戚贵幸，然颇用材能自进。", "len": 21}
{"sid": "125_佞幸列传.8.s3", "chapter": "125_佞幸列传", "para": "8", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "125_佞幸列传.9.s1", "chapter": "125_佞幸列传", "para": "9", "seq": 1, "text": "太史公曰：甚哉爱憎之时！", "len": 12}
{"sid": "125_佞幸列传.9.s2", "chapter": "125_佞幸列传", "para": "9", "seq": 2, "text": "弥子瑕之行，足以观後人佞幸矣。", "len": 15}
{"sid": "125_佞幸列传.9.s3", "chapter": "125_佞幸列传", "para": "9", "seq": 3, "text": "虽百世可知也。", "len": 7}
{"sid": "125_佞幸列传.9.s4", "chapter": "125_佞幸列传", "para": "9", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "125_佞幸列传.9.1.s1", "chapter": "125_佞幸列传", "para": "9.1", "seq": 1, "text": "传称令色，诗刺巧言。", "len": 10}
{"sid": "125_佞幸列传.9.1.s2", "chapter": "125_佞幸列传", "para": "9.1", "seq": 2, "text": "冠璘入侍，傅粉承恩。", "len": 10}
{"sid": "125_佞幸列传.9.1.s3", "chapter": "125_佞幸列传", "para": "9.1", "seq": 3, "text": "黄头赐蜀，宦者同轩。", "len": 10}
{"sid": "125_佞幸列传.9.1.s4", "chapter": "125_佞幸列传", "para": "9.1", "seq": 4, "text": "新声都尉，挟弹王孙。", "len": 10}
{"sid": "125_佞幸列传.9.1.s5", "chapter": "125_佞幸列传", "para": "9.1", "seq": 5, "text": "泣鱼窃驾，著自前论。", "len": 10}
{"sid": "125_佞幸列传.9.1.s6", "chapter": "125_佞幸列传", "para": "9.1", "seq": 6, "text": ":::", "len": 3}
