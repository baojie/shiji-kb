{"sid": "056_陈丞相世家.1.s1", "chapter": "056_陈丞相世家", "para": "1", "seq": 1, "text": "陈丞相平者，阳武户牖乡人也。", "len": 14}
{"sid": "056_陈丞相世家.1.s2", "chapter": "056_陈丞相世家", "para": "1", "seq": 2, "text": "少时家贫，好读书，有田三十亩，独与兄伯居。", "len": 21}
{"sid": "056_陈丞相世家.1.s3", "chapter": "056_陈丞相世家", "para": "1", "seq": 3, "text": "伯常耕田，纵平使游学。", "len": 11}
{"sid": "056_陈丞相世家.1.s4", "chapter": "056_陈丞相世家", "para": "1", "seq": 4, "text": "平为人长美色。", "len": 7}
{"sid": "056_陈丞相世家.1.s5", "chapter": "056_陈丞相世家", "para": "1", "seq": 5, "text": "人或谓陈平曰：“贫何食而肥若是？", "len": 16}
{"sid": "056_陈丞相世家.1.s6", "chapter": "056_陈丞相世家", "para": "1", "seq": 6, "text": "” 其嫂嫉平之不视家生产，曰：“亦食糠覈耳。", "len": 22}
{"sid": "056_陈丞相世家.1.s7", "chapter": "056_陈丞相世家", "para": "1", "seq": 7, "text": "有叔如此，不如无有。", "len": 10}
{"sid": "056_陈丞相世家.1.s8", "chapter": "056_陈丞相世家", "para": "1", "seq": 8, "text": "” 伯闻之，逐其妇而弃之。", "len": 13}
{"sid": "056_陈丞相世家.2.s1", "chapter": "056_陈丞相世家", "para": "2", "seq": 1, "text": "及平长，可娶妻，富人莫肯与者，贫者平亦耻之。", "len": 22}
{"sid": "056_陈丞相世家.2.s2", "chapter": "056_陈丞相世家", "para": "2", "seq": 2, "text": "久之，户牖富人有张负，张负女孙五嫁而夫辄死，人莫敢娶。", "len": 27}
{"sid": "056_陈丞相世家.2.s3", "chapter": "056_陈丞相世家", "para": "2", "seq": 3, "text": "平欲得之。", "len": 5}
{"sid": "056_陈丞相世家.2.s4", "chapter": "056_陈丞相世家", "para": "2", "seq": 4, "text": "邑中有丧，平贫，侍丧，以先往後罢为助。", "len": 19}
{"sid": "056_陈丞相世家.2.s5", "chapter": "056_陈丞相世家", "para": "2", "seq": 5, "text": "张负既见之丧所，独视伟平，平亦以故後去。", "len": 20}
{"sid": "056_陈丞相世家.2.s6", "chapter": "056_陈丞相世家", "para": "2", "seq": 6, "text": "负随平至其家，家乃负郭穷巷，以弊席为门，然门外多有长者车辙。", "len": 30}
{"sid": "056_陈丞相世家.2.s7", "chapter": "056_陈丞相世家", "para": "2", "seq": 7, "text": "张负归，谓其子仲曰：“吾欲以女孙予陈平。", "len": 20}
{"sid": "056_陈丞相世家.2.s8", "chapter": "056_陈丞相世家", "para": "2", "seq": 8, "text": "” 张仲曰：“平贫不事事，一县中尽笑其所为，独柰何予女乎？", "len": 29}
{"sid": "056_陈丞相世家.2.s9", "chapter": "056_陈丞相世家", "para": "2", "seq": 9, "text": "” 负曰：“人固有好美如陈平而长贫贱者乎？", "len": 21}
{"sid": "056_陈丞相世家.2.s10", "chapter": "056_陈丞相世家", "para": "2", "seq": 10, "text": "” 卒与女。", "len": 6}
{"sid": "056_陈丞相世家.2.s11", "chapter": "056_陈丞相世家", "para": "2", "seq": 11, "text": "为平贫，乃假贷币以聘，予酒肉之资以内妇。", "len": 20}
{"sid": "056_陈丞相世家.2.s12", "chapter": "056_陈丞相世家", "para": "2", "seq": 12, "text": "负诫其孙曰：“毋以贫故，事人不谨。", "len": 17}
{"sid": "056_陈丞相世家.2.s13", "chapter": "056_陈丞相世家", "para": "2", "seq": 13, "text": "事兄伯如事父，事嫂如母。", "len": 12}
{"sid": "056_陈丞相世家.2.s14", "chapter": "056_陈丞相世家", "para": "2", "seq": 14, "text": "” 平既娶张氏女，赍用益饶，游道日广。", "len": 19}
{"sid": "056_陈丞相世家.3.s1", "chapter": "056_陈丞相世家", "para": "3", "seq": 1, "text": "里中社，平为宰，分肉食甚均。", "len": 14}
{"sid": "056_陈丞相世家.3.s2", "chapter": "056_陈丞相世家", "para": "3", "seq": 2, "text": "父老曰：“善，陈孺子之为宰！", "len": 14}
{"sid": "056_陈丞相世家.3.s3", "chapter": "056_陈丞相世家", "para": "3", "seq": 3, "text": "” 平曰：“嗟乎，使平得宰天下，亦如是肉矣！”", "len": 23}
{"sid": "056_陈丞相世家.4.s1", "chapter": "056_陈丞相世家", "para": "4", "seq": 1, "text": "陈涉起而王陈，使周市略定魏地，立魏咎为魏王，与秦军相攻於临济。", "len": 31}
{"sid": "056_陈丞相世家.4.s2", "chapter": "056_陈丞相世家", "para": "4", "seq": 2, "text": "陈平固已前谢其兄伯，从少年往事魏王咎於临济。", "len": 22}
{"sid": "056_陈丞相世家.4.s3", "chapter": "056_陈丞相世家", "para": "4", "seq": 3, "text": "魏王以为太仆。", "len": 7}
{"sid": "056_陈丞相世家.4.s4", "chapter": "056_陈丞相世家", "para": "4", "seq": 4, "text": "说魏王不听，人或谗之，陈平亡去。", "len": 16}
{"sid": "056_陈丞相世家.5.s1", "chapter": "056_陈丞相世家", "para": "5", "seq": 1, "text": "久之，项羽略地至河上，陈平往归之，从入破秦，赐平爵卿。", "len": 27}
{"sid": "056_陈丞相世家.5.s2", "chapter": "056_陈丞相世家", "para": "5", "seq": 2, "text": "项羽之东王彭城也，汉王还定三秦而东，殷王反楚。", "len": 23}
{"sid": "056_陈丞相世家.5.s3", "chapter": "056_陈丞相世家", "para": "5", "seq": 3, "text": "项羽乃以平为信武君，将魏王咎客在楚者以往，击降殷王而还。", "len": 28}
{"sid": "056_陈丞相世家.5.s4", "chapter": "056_陈丞相世家", "para": "5", "seq": 4, "text": "项王使项悍拜平为都尉，赐金二十溢。", "len": 17}
{"sid": "056_陈丞相世家.5.s5", "chapter": "056_陈丞相世家", "para": "5", "seq": 5, "text": "居无何，汉王攻下殷。", "len": 10}
{"sid": "056_陈丞相世家.5.s6", "chapter": "056_陈丞相世家", "para": "5", "seq": 6, "text": "项王怒，将诛定殷者将吏。", "len": 12}
{"sid": "056_陈丞相世家.5.s7", "chapter": "056_陈丞相世家", "para": "5", "seq": 7, "text": "陈平惧诛，乃封其金与印，使使归项王，而平身间行杖剑亡。", "len": 27}
{"sid": "056_陈丞相世家.5.s8", "chapter": "056_陈丞相世家", "para": "5", "seq": 8, "text": "渡河，船人见其美丈夫独行，疑其亡将，要中当有金玉宝器，目之，欲杀平。", "len": 34}
{"sid": "056_陈丞相世家.5.s9", "chapter": "056_陈丞相世家", "para": "5", "seq": 9, "text": "平恐，乃解衣裸而佐刺船。", "len": 12}
{"sid": "056_陈丞相世家.5.s10", "chapter": "056_陈丞相世家", "para": "5", "seq": 10, "text": "船人知其无有，乃止。", "len": 10}
{"sid": "056_陈丞相世家.6.s1", "chapter": "056_陈丞相世家", "para": "6", "seq": 1, "text": "平遂至修武降汉，因魏无知求见汉王，汉王召入。", "len": 22}
{"sid": "056_陈丞相世家.6.s2", "chapter": "056_陈丞相世家", "para": "6", "seq": 2, "text": "是时万石君奋为汉王中涓，受平谒，入见平。", "len": 20}
{"sid": "056_陈丞相世家.6.s3", "chapter": "056_陈丞相世家", "para": "6", "seq": 3, "text": "平等七人俱进，赐食。", "len": 10}
{"sid": "056_陈丞相世家.6.s4", "chapter": "056_陈丞相世家", "para": "6", "seq": 4, "text": "王曰：“罢，就舍矣。", "len": 10}
{"sid": "056_陈丞相世家.6.s5", "chapter": "056_陈丞相世家", "para": "6", "seq": 5, "text": "” 平曰：“臣为事来，所言不可以过今日。", "len": 20}
{"sid": "056_陈丞相世家.6.s6", "chapter": "056_陈丞相世家", "para": "6", "seq": 6, "text": "” 於是汉王与语而说之，问曰：“子之居楚何官？", "len": 23}
{"sid": "056_陈丞相世家.6.s7", "chapter": "056_陈丞相世家", "para": "6", "seq": 7, "text": "” 曰：“为都尉。", "len": 9}
{"sid": "056_陈丞相世家.6.s8", "chapter": "056_陈丞相世家", "para": "6", "seq": 8, "text": "” 是日乃拜平为都尉，使为参乘，典护军。", "len": 20}
{"sid": "056_陈丞相世家.6.s9", "chapter": "056_陈丞相世家", "para": "6", "seq": 9, "text": "诸将尽讙，曰：“大王一日得楚之亡卒，未知其高下，而即与同载，反使监护军长者！", "len": 38}
{"sid": "056_陈丞相世家.6.s10", "chapter": "056_陈丞相世家", "para": "6", "seq": 10, "text": "” 汉王闻之，愈益幸平。", "len": 12}
{"sid": "056_陈丞相世家.6.s11", "chapter": "056_陈丞相世家", "para": "6", "seq": 11, "text": "遂与东伐项王。", "len": 7}
{"sid": "056_陈丞相世家.6.s12", "chapter": "056_陈丞相世家", "para": "6", "seq": 12, "text": "至彭城，为楚所败。", "len": 9}
{"sid": "056_陈丞相世家.6.s13", "chapter": "056_陈丞相世家", "para": "6", "seq": 13, "text": "引而还，收散兵至荥阳，以平为亚将，属於韩王信，军广武。", "len": 27}
{"sid": "056_陈丞相世家.7.s1", "chapter": "056_陈丞相世家", "para": "7", "seq": 1, "text": "绛侯、灌婴等咸谗陈平曰：“平虽美丈夫，如冠玉耳，其中未必有也。", "len": 31}
{"sid": "056_陈丞相世家.7.s2", "chapter": "056_陈丞相世家", "para": "7", "seq": 2, "text": "臣闻平居家时，盗其嫂；事魏不容，亡归楚；归楚不中，又亡归汉。", "len": 30}
{"sid": "056_陈丞相世家.7.s3", "chapter": "056_陈丞相世家", "para": "7", "seq": 3, "text": "今日大王尊官之，令护军。", "len": 12}
{"sid": "056_陈丞相世家.7.s4", "chapter": "056_陈丞相世家", "para": "7", "seq": 4, "text": "臣闻平受诸将金，金多者得善处，金少者得恶处。", "len": 22}
{"sid": "056_陈丞相世家.7.s5", "chapter": "056_陈丞相世家", "para": "7", "seq": 5, "text": "平，反覆乱臣也，原王察之。", "len": 13}
{"sid": "056_陈丞相世家.7.s6", "chapter": "056_陈丞相世家", "para": "7", "seq": 6, "text": "” 汉王疑之，召让魏无知。", "len": 13}
{"sid": "056_陈丞相世家.7.s7", "chapter": "056_陈丞相世家", "para": "7", "seq": 7, "text": "无知曰：“臣所言者，能也；陛下所问者，行也。", "len": 22}
{"sid": "056_陈丞相世家.7.s8", "chapter": "056_陈丞相世家", "para": "7", "seq": 8, "text": "今有尾生、孝己之行而无益处於胜负之数，陛下何暇用之乎？", "len": 27}
{"sid": "056_陈丞相世家.7.s9", "chapter": "056_陈丞相世家", "para": "7", "seq": 9, "text": "楚汉相距，臣进奇谋之士，顾其计诚足以利国家不耳。", "len": 24}
{"sid": "056_陈丞相世家.7.s10", "chapter": "056_陈丞相世家", "para": "7", "seq": 10, "text": "且盗嫂受金又何足疑乎？", "len": 11}
{"sid": "056_陈丞相世家.7.s11", "chapter": "056_陈丞相世家", "para": "7", "seq": 11, "text": "” 汉王召让平曰：“先生事魏不中，遂事楚而去，今又从吾游，信者固多心乎？", "len": 36}
{"sid": "056_陈丞相世家.7.s12", "chapter": "056_陈丞相世家", "para": "7", "seq": 12, "text": "” 平曰：“臣事魏王，魏王不能用臣说，故去事项王。", "len": 25}
{"sid": "056_陈丞相世家.7.s13", "chapter": "056_陈丞相世家", "para": "7", "seq": 13, "text": "项王不能信人，其所任爱，非诸项即妻之昆弟，虽有奇士不能用，平乃去楚。", "len": 34}
{"sid": "056_陈丞相世家.7.s14", "chapter": "056_陈丞相世家", "para": "7", "seq": 14, "text": "闻汉王之能用人，故归大王。", "len": 13}
{"sid": "056_陈丞相世家.7.s15", "chapter": "056_陈丞相世家", "para": "7", "seq": 15, "text": "臣裸身来，不受金无以为资。", "len": 13}
{"sid": "056_陈丞相世家.7.s16", "chapter": "056_陈丞相世家", "para": "7", "seq": 16, "text": "诚臣计画有可采者，大王用之；使无可用者，金具在，请封输官，得请骸骨。", "len": 34}
{"sid": "056_陈丞相世家.7.s17", "chapter": "056_陈丞相世家", "para": "7", "seq": 17, "text": "” 汉王乃谢，厚赐，拜为护军中尉，尽护诸将。", "len": 22}
{"sid": "056_陈丞相世家.7.s18", "chapter": "056_陈丞相世家", "para": "7", "seq": 18, "text": "诸将乃不敢复言。", "len": 8}
{"sid": "056_陈丞相世家.8.s1", "chapter": "056_陈丞相世家", "para": "8", "seq": 1, "text": "其後，楚急攻，绝汉甬道，围汉王於荥阳城。", "len": 20}
{"sid": "056_陈丞相世家.8.s2", "chapter": "056_陈丞相世家", "para": "8", "seq": 2, "text": "久之，汉王患之，请割荥阳以西以和。", "len": 17}
{"sid": "056_陈丞相世家.8.s3", "chapter": "056_陈丞相世家", "para": "8", "seq": 3, "text": "项王不听。", "len": 5}
{"sid": "056_陈丞相世家.8.s4", "chapter": "056_陈丞相世家", "para": "8", "seq": 4, "text": "汉王谓陈平曰：“天下纷纷，何时定乎？", "len": 18}
{"sid": "056_陈丞相世家.8.s5", "chapter": "056_陈丞相世家", "para": "8", "seq": 5, "text": "” 陈平曰：“项王为人，恭敬爱人，士之廉节好礼者多归之。", "len": 28}
{"sid": "056_陈丞相世家.8.s6", "chapter": "056_陈丞相世家", "para": "8", "seq": 6, "text": "至於行功爵邑，重之，士亦以此不附。", "len": 17}
{"sid": "056_陈丞相世家.8.s7", "chapter": "056_陈丞相世家", "para": "8", "seq": 7, "text": "今大王慢而少礼，士廉节者不来；然大王能饶人以爵邑，士之顽钝嗜利无耻者亦多归汉。", "len": 39}
{"sid": "056_陈丞相世家.8.s8", "chapter": "056_陈丞相世家", "para": "8", "seq": 8, "text": "诚各去其两短，袭其两长，天下指麾则定矣。", "len": 20}
{"sid": "056_陈丞相世家.8.s9", "chapter": "056_陈丞相世家", "para": "8", "seq": 9, "text": "然大王恣侮人，不能得廉节之士。", "len": 15}
{"sid": "056_陈丞相世家.8.s10", "chapter": "056_陈丞相世家", "para": "8", "seq": 10, "text": "顾楚有可乱者，彼项王骨鲠之臣亚父、锺离眛、龙且、周殷之属，不过数人耳。", "len": 35}
{"sid": "056_陈丞相世家.8.s11", "chapter": "056_陈丞相世家", "para": "8", "seq": 11, "text": "大王诚能出捐数万斤金，行反间，间其君臣，以疑其心，项王为人意忌信谗，必内相诛。", "len": 39}
{"sid": "056_陈丞相世家.8.s12", "chapter": "056_陈丞相世家", "para": "8", "seq": 12, "text": "汉因举兵而攻之，破楚必矣。", "len": 13}
{"sid": "056_陈丞相世家.8.s13", "chapter": "056_陈丞相世家", "para": "8", "seq": 13, "text": "” 汉王以为然，乃出黄金四万斤，与陈平，恣所为，不问其出入。", "len": 30}
{"sid": "056_陈丞相世家.9.s1", "chapter": "056_陈丞相世家", "para": "9", "seq": 1, "text": "陈平既多以金纵反间於楚军，宣言诸将锺离眛等为项王将，功多矣，然而终不得裂地而王，欲与汉为一，以灭项氏而分王其地。", "len": 56}
{"sid": "056_陈丞相世家.9.s2", "chapter": "056_陈丞相世家", "para": "9", "seq": 2, "text": "项羽果意不信锺离眜等。", "len": 11}
{"sid": "056_陈丞相世家.9.s3", "chapter": "056_陈丞相世家", "para": "9", "seq": 3, "text": "项王既疑之，使使至汉。", "len": 11}
{"sid": "056_陈丞相世家.9.s4", "chapter": "056_陈丞相世家", "para": "9", "seq": 4, "text": "汉王为太牢具，举进。", "len": 10}
{"sid": "056_陈丞相世家.9.s5", "chapter": "056_陈丞相世家", "para": "9", "seq": 5, "text": "见楚使，即详惊曰：“吾以为亚父使，乃项王使！", "len": 22}
{"sid": "056_陈丞相世家.9.s6", "chapter": "056_陈丞相世家", "para": "9", "seq": 6, "text": "” 复持去，更以恶草具进楚使。", "len": 15}
{"sid": "056_陈丞相世家.9.s7", "chapter": "056_陈丞相世家", "para": "9", "seq": 7, "text": "楚使归，具以报项王。", "len": 10}
{"sid": "056_陈丞相世家.9.s8", "chapter": "056_陈丞相世家", "para": "9", "seq": 8, "text": "项王果大疑亚父。", "len": 8}
{"sid": "056_陈丞相世家.9.s9", "chapter": "056_陈丞相世家", "para": "9", "seq": 9, "text": "亚父欲急攻下荥阳城，项王不信，不肯听。", "len": 19}
{"sid": "056_陈丞相世家.9.s10", "chapter": "056_陈丞相世家", "para": "9", "seq": 10, "text": "亚父闻项王疑之，乃怒曰：“天下事大定矣，君王自为之！", "len": 26}
{"sid": "056_陈丞相世家.9.s11", "chapter": "056_陈丞相世家", "para": "9", "seq": 11, "text": "原请骸骨归！", "len": 6}
{"sid": "056_陈丞相世家.9.s12", "chapter": "056_陈丞相世家", "para": "9", "seq": 12, "text": "” 归未至彭城，疽发背而死。", "len": 14}
{"sid": "056_陈丞相世家.9.s13", "chapter": "056_陈丞相世家", "para": "9", "seq": 13, "text": "陈平乃夜出女子二千人荥阳城东门，楚因击之，陈平乃与汉王从城西门夜出去。", "len": 35}
{"sid": "056_陈丞相世家.9.s14", "chapter": "056_陈丞相世家", "para": "9", "seq": 14, "text": "遂入关，收散兵复东。", "len": 10}
{"sid": "056_陈丞相世家.10.s1", "chapter": "056_陈丞相世家", "para": "10", "seq": 1, "text": "其明年，淮阴侯破齐，自立为齐王，使使言之汉王。", "len": 23}
{"sid": "056_陈丞相世家.10.s2", "chapter": "056_陈丞相世家", "para": "10", "seq": 2, "text": "汉王大怒而骂，陈平蹑汉王。", "len": 13}
{"sid": "056_陈丞相世家.10.s3", "chapter": "056_陈丞相世家", "para": "10", "seq": 3, "text": "汉王亦悟，乃厚遇齐使，使张子房卒立信为齐王。", "len": 22}
{"sid": "056_陈丞相世家.10.s4", "chapter": "056_陈丞相世家", "para": "10", "seq": 4, "text": "封平以户牖乡。", "len": 7}
{"sid": "056_陈丞相世家.10.s5", "chapter": "056_陈丞相世家", "para": "10", "seq": 5, "text": "用其奇计策，卒灭楚。", "len": 10}
{"sid": "056_陈丞相世家.10.s6", "chapter": "056_陈丞相世家", "para": "10", "seq": 6, "text": "常以护军中尉从定燕王臧荼。", "len": 13}
{"sid": "056_陈丞相世家.11.s1", "chapter": "056_陈丞相世家", "para": "11", "seq": 1, "text": "汉六年，人有上书告楚王韩信反。", "len": 15}
{"sid": "056_陈丞相世家.11.s2", "chapter": "056_陈丞相世家", "para": "11", "seq": 2, "text": "高帝问诸将，诸将曰：“亟发兵阬竖子耳。", "len": 19}
{"sid": "056_陈丞相世家.11.s3", "chapter": "056_陈丞相世家", "para": "11", "seq": 3, "text": "” 高帝默然。", "len": 7}
{"sid": "056_陈丞相世家.11.s4", "chapter": "056_陈丞相世家", "para": "11", "seq": 4, "text": "问陈平，平固辞谢，曰：“诸将云何？", "len": 17}
{"sid": "056_陈丞相世家.11.s5", "chapter": "056_陈丞相世家", "para": "11", "seq": 5, "text": "” 上具告之。", "len": 7}
{"sid": "056_陈丞相世家.11.s6", "chapter": "056_陈丞相世家", "para": "11", "seq": 6, "text": "陈平曰：“人之上书言信反，有知之者乎？", "len": 19}
{"sid": "056_陈丞相世家.11.s7", "chapter": "056_陈丞相世家", "para": "11", "seq": 7, "text": "” 曰：“未有。", "len": 8}
{"sid": "056_陈丞相世家.11.s8", "chapter": "056_陈丞相世家", "para": "11", "seq": 8, "text": "” 曰：“信知之乎？", "len": 10}
{"sid": "056_陈丞相世家.11.s9", "chapter": "056_陈丞相世家", "para": "11", "seq": 9, "text": "” 曰：“不知。", "len": 8}
{"sid": "056_陈丞相世家.11.s10", "chapter": "056_陈丞相世家", "para": "11", "seq": 10, "text": "” 陈平曰：“陛下精兵孰与楚？", "len": 15}
{"sid": "056_陈丞相世家.11.s11", "chapter": "056_陈丞相世家", "para": "11", "seq": 11, "text": "” 上曰：“不能过。", "len": 10}
{"sid": "056_陈丞相世家.11.s12", "chapter": "056_陈丞相世家", "para": "11", "seq": 12, "text": "” 平曰：“陛下将用兵有能过韩信者乎？", "len": 19}
{"sid": "056_陈丞相世家.11.s13", "chapter": "056_陈丞相世家", "para": "11", "seq": 13, "text": "” 上曰：“莫及也。", "len": 10}
{"sid": "056_陈丞相世家.11.s14", "chapter": "056_陈丞相世家", "para": "11", "seq": 14, "text": "” 平曰：“今兵不如楚精，而将不能及，而举兵攻之，是趣之战也，窃为陛下危之。", "len": 38}
{"sid": "056_陈丞相世家.11.s15", "chapter": "056_陈丞相世家", "para": "11", "seq": 15, "text": "” 上曰：“为之柰何？", "len": 11}
{"sid": "056_陈丞相世家.11.s16", "chapter": "056_陈丞相世家", "para": "11", "seq": 16, "text": "” 平曰：“古者天子巡狩，会诸侯。", "len": 17}
{"sid": "056_陈丞相世家.11.s17", "chapter": "056_陈丞相世家", "para": "11", "seq": 17, "text": "南方有云梦，陛下弟出伪游云梦，会诸侯於陈。", "len": 21}
{"sid": "056_陈丞相世家.11.s18", "chapter": "056_陈丞相世家", "para": "11", "seq": 18, "text": "陈，楚之西界，信闻天子以好出游，其势必无事而郊迎谒。", "len": 26}
{"sid": "056_陈丞相世家.11.s19", "chapter": "056_陈丞相世家", "para": "11", "seq": 19, "text": "谒，而陛下因禽之，此特一力士之事耳。", "len": 18}
{"sid": "056_陈丞相世家.11.s20", "chapter": "056_陈丞相世家", "para": "11", "seq": 20, "text": "” 高帝以为然，乃发使告诸侯会陈，“吾将南游云梦”。", "len": 26}
{"sid": "056_陈丞相世家.11.s21", "chapter": "056_陈丞相世家", "para": "11", "seq": 21, "text": "上因随以行。", "len": 6}
{"sid": "056_陈丞相世家.11.s22", "chapter": "056_陈丞相世家", "para": "11", "seq": 22, "text": "行未至陈，楚王信果郊迎道中。", "len": 14}
{"sid": "056_陈丞相世家.11.s23", "chapter": "056_陈丞相世家", "para": "11", "seq": 23, "text": "高帝豫具武士，见信至，即执缚之，载後车。", "len": 20}
{"sid": "056_陈丞相世家.11.s24", "chapter": "056_陈丞相世家", "para": "11", "seq": 24, "text": "信呼曰：“天下已定，我固当烹！", "len": 15}
{"sid": "056_陈丞相世家.11.s25", "chapter": "056_陈丞相世家", "para": "11", "seq": 25, "text": "” 高帝顾谓信曰：“若毋声！", "len": 14}
{"sid": "056_陈丞相世家.11.s26", "chapter": "056_陈丞相世家", "para": "11", "seq": 26, "text": "而反，明矣！", "len": 6}
{"sid": "056_陈丞相世家.11.s27", "chapter": "056_陈丞相世家", "para": "11", "seq": 27, "text": "” 武士反接之。", "len": 8}
{"sid": "056_陈丞相世家.11.s28", "chapter": "056_陈丞相世家", "para": "11", "seq": 28, "text": "遂会诸侯于陈，尽定楚地。", "len": 12}
{"sid": "056_陈丞相世家.11.s29", "chapter": "056_陈丞相世家", "para": "11", "seq": 29, "text": "还至雒阳，赦信以为淮阴侯，而与功臣剖符定封。", "len": 22}
{"sid": "056_陈丞相世家.12.s1", "chapter": "056_陈丞相世家", "para": "12", "seq": 1, "text": "於是与平剖符，世世勿绝，为户牖侯。", "len": 17}
{"sid": "056_陈丞相世家.12.s2", "chapter": "056_陈丞相世家", "para": "12", "seq": 2, "text": "平辞曰：“此非臣之功也。", "len": 12}
{"sid": "056_陈丞相世家.12.s3", "chapter": "056_陈丞相世家", "para": "12", "seq": 3, "text": "” 上曰：“吾用先生谋计，战胜剋敌，非功而何？", "len": 23}
{"sid": "056_陈丞相世家.12.s4", "chapter": "056_陈丞相世家", "para": "12", "seq": 4, "text": "” 平曰：“非魏无知臣安得进？", "len": 15}
{"sid": "056_陈丞相世家.12.s5", "chapter": "056_陈丞相世家", "para": "12", "seq": 5, "text": "” 上曰；“若子可谓不背本矣。", "len": 15}
{"sid": "056_陈丞相世家.12.s6", "chapter": "056_陈丞相世家", "para": "12", "seq": 6, "text": "” 乃复赏魏无知。", "len": 9}
{"sid": "056_陈丞相世家.12.s7", "chapter": "056_陈丞相世家", "para": "12", "seq": 7, "text": "其明年，以护军中尉从攻反者韩王信於代。", "len": 19}
{"sid": "056_陈丞相世家.12.s8", "chapter": "056_陈丞相世家", "para": "12", "seq": 8, "text": "卒至平城，为匈奴所围，七日不得食。", "len": 17}
{"sid": "056_陈丞相世家.12.s9", "chapter": "056_陈丞相世家", "para": "12", "seq": 9, "text": "高帝用陈平奇计，使单于阏氏，围以得开。", "len": 19}
{"sid": "056_陈丞相世家.12.s10", "chapter": "056_陈丞相世家", "para": "12", "seq": 10, "text": "高帝既出，其计礻必，世莫得闻。", "len": 15}
{"sid": "056_陈丞相世家.13.s1", "chapter": "056_陈丞相世家", "para": "13", "seq": 1, "text": "高帝南过曲逆，上其城，望见其屋室甚大，曰：“壮哉县！", "len": 26}
{"sid": "056_陈丞相世家.13.s2", "chapter": "056_陈丞相世家", "para": "13", "seq": 2, "text": "吾行天下，独见洛阳与是耳。", "len": 13}
{"sid": "056_陈丞相世家.13.s3", "chapter": "056_陈丞相世家", "para": "13", "seq": 3, "text": "” 顾问御史曰：“曲逆户口几何？", "len": 16}
{"sid": "056_陈丞相世家.13.s4", "chapter": "056_陈丞相世家", "para": "13", "seq": 4, "text": "” 对曰：“始秦时三万馀户，间者兵数起，多亡匿，今见五千户。", "len": 30}
{"sid": "056_陈丞相世家.13.s5", "chapter": "056_陈丞相世家", "para": "13", "seq": 5, "text": "” 於是乃诏御史，更以陈平为曲逆侯，尽食之，除前所食户牖。", "len": 29}
{"sid": "056_陈丞相世家.14.s1", "chapter": "056_陈丞相世家", "para": "14", "seq": 1, "text": "其後常以护军中尉从攻陈豨及黥布。", "len": 16}
{"sid": "056_陈丞相世家.14.s2", "chapter": "056_陈丞相世家", "para": "14", "seq": 2, "text": "凡六出奇计，辄益邑，凡六益封。", "len": 15}
{"sid": "056_陈丞相世家.14.s3", "chapter": "056_陈丞相世家", "para": "14", "seq": 3, "text": "奇计或颇祕，世莫能闻也。", "len": 12}
{"sid": "056_陈丞相世家.15.s1", "chapter": "056_陈丞相世家", "para": "15", "seq": 1, "text": "高帝从破布军还，病创，徐行至长安。", "len": 17}
{"sid": "056_陈丞相世家.15.s2", "chapter": "056_陈丞相世家", "para": "15", "seq": 2, "text": "燕王卢绾反，上使樊哙以相国将兵攻之。", "len": 18}
{"sid": "056_陈丞相世家.15.s3", "chapter": "056_陈丞相世家", "para": "15", "seq": 3, "text": "既行，人有短恶哙者。", "len": 10}
{"sid": "056_陈丞相世家.15.s4", "chapter": "056_陈丞相世家", "para": "15", "seq": 4, "text": "高帝怒曰：“哙见吾病，乃冀我死也。", "len": 17}
{"sid": "056_陈丞相世家.15.s5", "chapter": "056_陈丞相世家", "para": "15", "seq": 5, "text": "” 用陈平谋而召绛侯周勃受诏床下，曰：“陈平亟驰传载勃代哙将，平至军中即斩哙头！", "len": 40}
{"sid": "056_陈丞相世家.15.s6", "chapter": "056_陈丞相世家", "para": "15", "seq": 6, "text": "” 二人既受诏，驰传未至军，行计之曰：“樊哙，帝之故人也，功多，且又乃吕后弟吕嬃之夫，有亲且贵，帝以忿怒故，欲斩之，则恐後悔。", "len": 63}
{"sid": "056_陈丞相世家.15.s7", "chapter": "056_陈丞相世家", "para": "15", "seq": 7, "text": "宁囚而致上，上自诛之。", "len": 11}
{"sid": "056_陈丞相世家.15.s8", "chapter": "056_陈丞相世家", "para": "15", "seq": 8, "text": "” 未至军，为坛，以节召樊哙。", "len": 15}
{"sid": "056_陈丞相世家.15.s9", "chapter": "056_陈丞相世家", "para": "15", "seq": 9, "text": "哙受诏，即反接载槛车，传诣长安，而令绛侯勃代将，将兵定燕反县。", "len": 31}
{"sid": "056_陈丞相世家.16.s1", "chapter": "056_陈丞相世家", "para": "16", "seq": 1, "text": "平行闻高帝崩，平恐吕太后及吕嬃谗怒，乃驰传先去。", "len": 24}
{"sid": "056_陈丞相世家.16.s2", "chapter": "056_陈丞相世家", "para": "16", "seq": 2, "text": "逢使者诏平与灌婴屯於荥阳。", "len": 13}
{"sid": "056_陈丞相世家.16.s3", "chapter": "056_陈丞相世家", "para": "16", "seq": 3, "text": "平受诏，立复驰至宫，哭甚哀，因奏事丧前。", "len": 20}
{"sid": "056_陈丞相世家.16.s4", "chapter": "056_陈丞相世家", "para": "16", "seq": 4, "text": "吕太后哀之，曰：“君劳，出休矣。", "len": 16}
{"sid": "056_陈丞相世家.16.s5", "chapter": "056_陈丞相世家", "para": "16", "seq": 5, "text": "” 平畏谗之就，因固请得宿卫中。", "len": 16}
{"sid": "056_陈丞相世家.16.s6", "chapter": "056_陈丞相世家", "para": "16", "seq": 6, "text": "太后乃以为郎中令，曰：“傅教孝惠。", "len": 17}
{"sid": "056_陈丞相世家.16.s7", "chapter": "056_陈丞相世家", "para": "16", "seq": 7, "text": "” 是後吕嬃谗乃不得行。", "len": 12}
{"sid": "056_陈丞相世家.16.s8", "chapter": "056_陈丞相世家", "para": "16", "seq": 8, "text": "樊哙至，则赦复爵邑。", "len": 10}
{"sid": "056_陈丞相世家.17.s1", "chapter": "056_陈丞相世家", "para": "17", "seq": 1, "text": "孝惠帝六年，相国曹参卒，以安国侯王陵为右丞相，陈平为左丞相。", "len": 30}
{"sid": "056_陈丞相世家.18.s1", "chapter": "056_陈丞相世家", "para": "18", "seq": 1, "text": "王陵者，故沛人，始为县豪，高祖微时，兄事陵。", "len": 22}
{"sid": "056_陈丞相世家.18.s2", "chapter": "056_陈丞相世家", "para": "18", "seq": 2, "text": "陵少文，任气，好直言。", "len": 11}
{"sid": "056_陈丞相世家.18.s3", "chapter": "056_陈丞相世家", "para": "18", "seq": 3, "text": "及高祖起沛，入至咸阳，陵亦自聚党数千人，居南阳，不肯从沛公。", "len": 30}
{"sid": "056_陈丞相世家.18.s4", "chapter": "056_陈丞相世家", "para": "18", "seq": 4, "text": "及汉王之还攻项籍，陵乃以兵属汉。", "len": 16}
{"sid": "056_陈丞相世家.18.s5", "chapter": "056_陈丞相世家", "para": "18", "seq": 5, "text": "项羽取陵母置军中，陵使至，则东乡坐陵母，欲以招陵。", "len": 25}
{"sid": "056_陈丞相世家.18.s6", "chapter": "056_陈丞相世家", "para": "18", "seq": 6, "text": "陵母既私送使者，泣曰：“为老妾语陵，谨事汉王。", "len": 23}
{"sid": "056_陈丞相世家.18.s7", "chapter": "056_陈丞相世家", "para": "18", "seq": 7, "text": "汉王，长者也，无以老妾故，持二心。", "len": 17}
{"sid": "056_陈丞相世家.18.s8", "chapter": "056_陈丞相世家", "para": "18", "seq": 8, "text": "妾以死送使者。", "len": 7}
{"sid": "056_陈丞相世家.18.s9", "chapter": "056_陈丞相世家", "para": "18", "seq": 9, "text": "” 遂伏剑而死。", "len": 8}
{"sid": "056_陈丞相世家.18.s10", "chapter": "056_陈丞相世家", "para": "18", "seq": 10, "text": "项王怒，烹陵母。", "len": 8}
{"sid": "056_陈丞相世家.18.s11", "chapter": "056_陈丞相世家", "para": "18", "seq": 11, "text": "陵卒从汉王定天下。", "len": 9}
{"sid": "056_陈丞相世家.18.s12", "chapter": "056_陈丞相世家", "para": "18", "seq": 12, "text": "以善雍齿，雍齿，高帝之仇，而陵本无意从高帝，以故晚封，为安国侯。", "len": 32}
{"sid": "056_陈丞相世家.19.s1", "chapter": "056_陈丞相世家", "para": "19", "seq": 1, "text": "安国侯既为右丞相，二岁，孝惠帝崩。", "len": 17}
{"sid": "056_陈丞相世家.19.s2", "chapter": "056_陈丞相世家", "para": "19", "seq": 2, "text": "高后欲立诸吕为王，问王陵，王陵曰：“不可。", "len": 21}
{"sid": "056_陈丞相世家.19.s3", "chapter": "056_陈丞相世家", "para": "19", "seq": 3, "text": "” 问陈平，陈平曰：“可。", "len": 13}
{"sid": "056_陈丞相世家.19.s4", "chapter": "056_陈丞相世家", "para": "19", "seq": 4, "text": "” 吕太后怒，乃详迁陵为帝太傅，实不用陵。", "len": 21}
{"sid": "056_陈丞相世家.19.s5", "chapter": "056_陈丞相世家", "para": "19", "seq": 5, "text": "陵怒，谢疾免，杜门竟不朝请，七年而卒。", "len": 19}
{"sid": "056_陈丞相世家.20.s1", "chapter": "056_陈丞相世家", "para": "20", "seq": 1, "text": "陵之免丞相，吕太后乃徙平为右丞相，以辟阳侯审食其为左丞相。", "len": 29}
{"sid": "056_陈丞相世家.20.s2", "chapter": "056_陈丞相世家", "para": "20", "seq": 2, "text": "左丞相不治，常给事於中。", "len": 12}
{"sid": "056_陈丞相世家.21.s1", "chapter": "056_陈丞相世家", "para": "21", "seq": 1, "text": "食其亦沛人。", "len": 6}
{"sid": "056_陈丞相世家.21.s2", "chapter": "056_陈丞相世家", "para": "21", "seq": 2, "text": "汉王之败彭城西，楚取太上皇、吕后为质，食其以舍人侍吕后。", "len": 28}
{"sid": "056_陈丞相世家.21.s3", "chapter": "056_陈丞相世家", "para": "21", "seq": 3, "text": "其後从破项籍为侯，幸於吕太后。", "len": 15}
{"sid": "056_陈丞相世家.21.s4", "chapter": "056_陈丞相世家", "para": "21", "seq": 4, "text": "及为相，居中，百官皆因决事。", "len": 14}
{"sid": "056_陈丞相世家.22.s1", "chapter": "056_陈丞相世家", "para": "22", "seq": 1, "text": "吕嬃常以前陈平为高帝谋执樊哙，数谗曰：“陈平为相非治事，日饮醇酒，戏妇女。", "len": 37}
{"sid": "056_陈丞相世家.22.s2", "chapter": "056_陈丞相世家", "para": "22", "seq": 2, "text": "” 陈平闻，日益甚。", "len": 10}
{"sid": "056_陈丞相世家.22.s3", "chapter": "056_陈丞相世家", "para": "22", "seq": 3, "text": "吕太后闻之，私独喜。", "len": 10}
{"sid": "056_陈丞相世家.22.s4", "chapter": "056_陈丞相世家", "para": "22", "seq": 4, "text": "面质吕嬃於陈平曰：“鄙语曰‘兒妇人口不可用’，顾君与我何如耳。", "len": 31}
{"sid": "056_陈丞相世家.22.s5", "chapter": "056_陈丞相世家", "para": "22", "seq": 5, "text": "无畏吕嬃之谗也。”", "len": 9}
{"sid": "056_陈丞相世家.23.s1", "chapter": "056_陈丞相世家", "para": "23", "seq": 1, "text": "吕太后立诸吕为王，陈平伪听之。", "len": 15}
{"sid": "056_陈丞相世家.23.s2", "chapter": "056_陈丞相世家", "para": "23", "seq": 2, "text": "及吕太后崩，平与太尉勃合谋，卒诛诸吕，立孝文皇帝，陈平本谋也。", "len": 31}
{"sid": "056_陈丞相世家.23.s3", "chapter": "056_陈丞相世家", "para": "23", "seq": 3, "text": "审食其免相。", "len": 6}
{"sid": "056_陈丞相世家.24.s1", "chapter": "056_陈丞相世家", "para": "24", "seq": 1, "text": "孝文帝立，以为太尉勃亲以兵诛吕氏，功多；陈平欲让勃尊位，乃谢病。", "len": 32}
{"sid": "056_陈丞相世家.24.s2", "chapter": "056_陈丞相世家", "para": "24", "seq": 2, "text": "孝文帝初立，怪平病，问之。", "len": 13}
{"sid": "056_陈丞相世家.24.s3", "chapter": "056_陈丞相世家", "para": "24", "seq": 3, "text": "平曰：“高祖时，勃功不如臣平。", "len": 15}
{"sid": "056_陈丞相世家.24.s4", "chapter": "056_陈丞相世家", "para": "24", "seq": 4, "text": "及诛诸吕，臣功亦不如勃。", "len": 12}
{"sid": "056_陈丞相世家.24.s5", "chapter": "056_陈丞相世家", "para": "24", "seq": 5, "text": "原以右丞相让勃。", "len": 8}
{"sid": "056_陈丞相世家.24.s6", "chapter": "056_陈丞相世家", "para": "24", "seq": 6, "text": "” 於是孝文帝乃以绛侯勃为右丞相，位次第一；平徙为左丞相，位次第二。", "len": 34}
{"sid": "056_陈丞相世家.24.s7", "chapter": "056_陈丞相世家", "para": "24", "seq": 7, "text": "赐平金千斤，益封三千户。", "len": 12}
{"sid": "056_陈丞相世家.25.s1", "chapter": "056_陈丞相世家", "para": "25", "seq": 1, "text": "居顷之，孝文皇帝既益明习国家事，朝而问右丞相勃曰：“天下一岁决狱几何？", "len": 35}
{"sid": "056_陈丞相世家.25.s2", "chapter": "056_陈丞相世家", "para": "25", "seq": 2, "text": "” 勃谢曰：“不知。", "len": 10}
{"sid": "056_陈丞相世家.25.s3", "chapter": "056_陈丞相世家", "para": "25", "seq": 3, "text": "” 问：“天下一岁钱穀出入几何？", "len": 16}
{"sid": "056_陈丞相世家.25.s4", "chapter": "056_陈丞相世家", "para": "25", "seq": 4, "text": "” 勃又谢不知，汗出沾背，愧不能对。", "len": 18}
{"sid": "056_陈丞相世家.25.s5", "chapter": "056_陈丞相世家", "para": "25", "seq": 5, "text": "於是上亦问左丞相平。", "len": 10}
{"sid": "056_陈丞相世家.25.s6", "chapter": "056_陈丞相世家", "para": "25", "seq": 6, "text": "平曰：“有主者。", "len": 8}
{"sid": "056_陈丞相世家.25.s7", "chapter": "056_陈丞相世家", "para": "25", "seq": 7, "text": "” 上曰：“主者谓谁？", "len": 11}
{"sid": "056_陈丞相世家.25.s8", "chapter": "056_陈丞相世家", "para": "25", "seq": 8, "text": "” 平曰：“陛下即问决狱，责廷尉；问钱穀，责治粟内史。", "len": 27}
{"sid": "056_陈丞相世家.25.s9", "chapter": "056_陈丞相世家", "para": "25", "seq": 9, "text": "” 上曰：“苟各有主者，而君所主者何事也？", "len": 21}
{"sid": "056_陈丞相世家.25.s10", "chapter": "056_陈丞相世家", "para": "25", "seq": 10, "text": "” 平谢曰：“主臣！", "len": 10}
{"sid": "056_陈丞相世家.25.s11", "chapter": "056_陈丞相世家", "para": "25", "seq": 11, "text": "陛下不知其驽下，使待罪宰相。", "len": 14}
{"sid": "056_陈丞相世家.25.s12", "chapter": "056_陈丞相世家", "para": "25", "seq": 12, "text": "宰相者，上佐天子理阴阳，顺四时，下育万物之宜，外镇抚四夷诸侯，内亲附百姓，使卿大夫各得任其职焉。", "len": 48}
{"sid": "056_陈丞相世家.25.s13", "chapter": "056_陈丞相世家", "para": "25", "seq": 13, "text": "” 孝文帝乃称善。", "len": 9}
{"sid": "056_陈丞相世家.25.s14", "chapter": "056_陈丞相世家", "para": "25", "seq": 14, "text": "右丞相大惭，出而让陈平曰：“君独不素教我对！", "len": 22}
{"sid": "056_陈丞相世家.25.s15", "chapter": "056_陈丞相世家", "para": "25", "seq": 15, "text": "” 陈平笑曰：“君居其位，不知其任邪？", "len": 19}
{"sid": "056_陈丞相世家.25.s16", "chapter": "056_陈丞相世家", "para": "25", "seq": 16, "text": "且陛下即问长安中盗贼数，君欲彊对邪？", "len": 18}
{"sid": "056_陈丞相世家.25.s17", "chapter": "056_陈丞相世家", "para": "25", "seq": 17, "text": "” 於是绛侯自知其能不如平远矣。", "len": 16}
{"sid": "056_陈丞相世家.25.s18", "chapter": "056_陈丞相世家", "para": "25", "seq": 18, "text": "居顷之，绛侯谢病请免相，陈平专为一丞相。", "len": 20}
{"sid": "056_陈丞相世家.26.s1", "chapter": "056_陈丞相世家", "para": "26", "seq": 1, "text": "孝文帝二年，丞相陈平卒，谥为献侯。", "len": 17}
{"sid": "056_陈丞相世家.26.s2", "chapter": "056_陈丞相世家", "para": "26", "seq": 2, "text": "子共侯买代侯。", "len": 7}
{"sid": "056_陈丞相世家.26.s3", "chapter": "056_陈丞相世家", "para": "26", "seq": 3, "text": "二年卒，子简侯恢代侯。", "len": 11}
{"sid": "056_陈丞相世家.26.s4", "chapter": "056_陈丞相世家", "para": "26", "seq": 4, "text": "二十三年卒，子何代侯。", "len": 11}
{"sid": "056_陈丞相世家.26.s5", "chapter": "056_陈丞相世家", "para": "26", "seq": 5, "text": "二十三年，何坐略人妻，弃市，国除。", "len": 17}
{"sid": "056_陈丞相世家.27.s1", "chapter": "056_陈丞相世家", "para": "27", "seq": 1, "text": "始陈平曰：“我多阴谋，是道家之所禁。", "len": 18}
{"sid": "056_陈丞相世家.27.s2", "chapter": "056_陈丞相世家", "para": "27", "seq": 2, "text": "吾世即废，亦已矣，终不能复起，以吾多阴祸也。", "len": 22}
{"sid": "056_陈丞相世家.27.s3", "chapter": "056_陈丞相世家", "para": "27", "seq": 3, "text": "” 然其後曾孙陈掌以卫氏亲贵戚，原得续封陈氏，然终不得。", "len": 28}
{"sid": "056_陈丞相世家.27.s4", "chapter": "056_陈丞相世家", "para": "27", "seq": 4, "text": "::: 太史公曰", "len": 8}
{"sid": "056_陈丞相世家.28.s1", "chapter": "056_陈丞相世家", "para": "28", "seq": 1, "text": "太史公曰：陈丞相平少时，本好黄帝、老子之术。", "len": 22}
{"sid": "056_陈丞相世家.28.s2", "chapter": "056_陈丞相世家", "para": "28", "seq": 2, "text": "方其割肉俎上之时，其意固已远矣。", "len": 16}
{"sid": "056_陈丞相世家.28.s3", "chapter": "056_陈丞相世家", "para": "28", "seq": 3, "text": "倾侧扰攘楚魏之间，卒归高帝。", "len": 14}
{"sid": "056_陈丞相世家.28.s4", "chapter": "056_陈丞相世家", "para": "28", "seq": 4, "text": "常出奇计，救纷纠之难，振国家之患。", "len": 17}
{"sid": "056_陈丞相世家.28.s5", "chapter": "056_陈丞相世家", "para": "28", "seq": 5, "text": "及吕后时，事多故矣，然平竟自脱，定宗庙，以荣名终，称贤相，岂不善始善终哉！", "len": 37}
{"sid": "056_陈丞相世家.28.s6", "chapter": "056_陈丞相世家", "para": "28", "seq": 6, "text": "非知谋孰能当此者乎？", "len": 10}
{"sid": "056_陈丞相世家.28.s7", "chapter": "056_陈丞相世家", "para": "28", "seq": 7, "text": "::: ::: 赞", "len": 9}
{"sid": "056_陈丞相世家.29.s1", "chapter": "056_陈丞相世家", "para": "29", "seq": 1, "text": "曲逆穷巷，门多长者。", "len": 10}
{"sid": "056_陈丞相世家.29.s2", "chapter": "056_陈丞相世家", "para": "29", "seq": 2, "text": "宰肉先均，佐丧後罢。", "len": 10}
{"sid": "056_陈丞相世家.29.s3", "chapter": "056_陈丞相世家", "para": "29", "seq": 3, "text": "魏楚更用，腹心难假。", "len": 10}
{"sid": "056_陈丞相世家.29.s4", "chapter": "056_陈丞相世家", "para": "29", "seq": 4, "text": "弃印封金，刺船露裸。", "len": 10}
{"sid": "056_陈丞相世家.29.s5", "chapter": "056_陈丞相世家", "para": "29", "seq": 5, "text": "间行归汉，委质麾下。", "len": 10}
{"sid": "056_陈丞相世家.29.s6", "chapter": "056_陈丞相世家", "para": "29", "seq": 6, "text": "荥阳计全，平城围解。", "len": 10}
{"sid": "056_陈丞相世家.29.s7", "chapter": "056_陈丞相世家", "para": "29", "seq": 7, "text": "推陵让勃，裒多益寡。", "len": 10}
{"sid": "056_陈丞相世家.29.s8", "chapter": "056_陈丞相世家", "para": "29", "seq": 8, "text": "应变合权，克定宗社。", "len": 10}
{"sid": "056_陈丞相世家.29.s9", "chapter": "056_陈丞相世家", "para": "29", "seq": 9, "text": ":::", "len": 3}
