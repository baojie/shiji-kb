{"sid": "051_荆燕世家.1.s1", "chapter": "051_荆燕世家", "para": "1", "seq": 1, "text": "荆王刘贾者，诸刘，不知其何属初起时。", "len": 18}
{"sid": "051_荆燕世家.1.s2", "chapter": "051_荆燕世家", "para": "1", "seq": 2, "text": "汉王元年，还定三秦，刘贾为将军，定塞地，从东击项籍。", "len": 26}
{"sid": "051_荆燕世家.2.s1", "chapter": "051_荆燕世家", "para": "2", "seq": 1, "text": "汉四年，汉王之败成皋，北渡河，得张耳、韩信军，军脩武，深沟高垒，使刘贾将二万人，骑数百，渡白马津入楚地，烧其积聚，以破其业，无以给项王军食。", "len": 70}
{"sid": "051_荆燕世家.2.s2", "chapter": "051_荆燕世家", "para": "2", "seq": 2, "text": "已而楚兵击刘贾，贾辄壁不肯与战，而与彭越相保。", "len": 23}
{"sid": "051_荆燕世家.3.s1", "chapter": "051_荆燕世家", "para": "3", "seq": 1, "text": "汉五年，汉王追项籍至固陵，使刘贾南渡淮围寿春。", "len": 23}
{"sid": "051_荆燕世家.3.s2", "chapter": "051_荆燕世家", "para": "3", "seq": 2, "text": "还至，使人间招楚大司马周殷。", "len": 14}
{"sid": "051_荆燕世家.3.s3", "chapter": "051_荆燕世家", "para": "3", "seq": 3, "text": "周殷反楚，佐刘贾举九江，迎武王黥布兵，皆会垓下，共击项籍。", "len": 29}
{"sid": "051_荆燕世家.3.s4", "chapter": "051_荆燕世家", "para": "3", "seq": 4, "text": "汉王因使刘贾将九江兵，与太尉卢绾西南击临江王共尉。", "len": 25}
{"sid": "051_荆燕世家.3.s5", "chapter": "051_荆燕世家", "para": "3", "seq": 5, "text": "共尉已死，以临江为南郡。", "len": 12}
{"sid": "051_荆燕世家.4.s1", "chapter": "051_荆燕世家", "para": "4", "seq": 1, "text": "汉六年春，会诸侯於陈，废楚王信，囚之，分其地为二国。", "len": 26}
{"sid": "051_荆燕世家.4.s2", "chapter": "051_荆燕世家", "para": "4", "seq": 2, "text": "当是时也，高祖子幼，昆弟少，又不贤，欲王同姓以镇天下，乃诏曰：“将军刘贾有功，及择子弟可以为王者。", "len": 49}
{"sid": "051_荆燕世家.4.s3", "chapter": "051_荆燕世家", "para": "4", "seq": 3, "text": "” 群臣皆曰：“立刘贾为荆王，王淮东五十二城；高祖弟交为楚王，王淮西三十六城。", "len": 39}
{"sid": "051_荆燕世家.4.s4", "chapter": "051_荆燕世家", "para": "4", "seq": 4, "text": "” 因立子肥为齐王。", "len": 10}
{"sid": "051_荆燕世家.4.s5", "chapter": "051_荆燕世家", "para": "4", "seq": 5, "text": "始王昆弟刘氏也。", "len": 8}
{"sid": "051_荆燕世家.5.s1", "chapter": "051_荆燕世家", "para": "5", "seq": 1, "text": "高祖十一年秋，淮南王黥布反，东击荆。", "len": 18}
{"sid": "051_荆燕世家.5.s2", "chapter": "051_荆燕世家", "para": "5", "seq": 2, "text": "荆王贾与战，不胜，走富陵，为布军所杀。", "len": 19}
{"sid": "051_荆燕世家.5.s3", "chapter": "051_荆燕世家", "para": "5", "seq": 3, "text": "高祖自击破布。", "len": 7}
{"sid": "051_荆燕世家.5.s4", "chapter": "051_荆燕世家", "para": "5", "seq": 4, "text": "十二年，立沛侯刘濞为吴王，王故荆地。", "len": 18}
{"sid": "051_荆燕世家.6.s1", "chapter": "051_荆燕世家", "para": "6", "seq": 1, "text": "燕王刘泽者，诸刘远属也。", "len": 12}
{"sid": "051_荆燕世家.6.s2", "chapter": "051_荆燕世家", "para": "6", "seq": 2, "text": "高帝三年，泽为郎中。", "len": 10}
{"sid": "051_荆燕世家.6.s3", "chapter": "051_荆燕世家", "para": "6", "seq": 3, "text": "高帝十一年，泽以将军击陈豨，得王黄，为营陵侯。", "len": 23}
{"sid": "051_荆燕世家.7.s1", "chapter": "051_荆燕世家", "para": "7", "seq": 1, "text": "高后时，齐人田生游乏资，以画干营陵侯泽。", "len": 20}
{"sid": "051_荆燕世家.7.s2", "chapter": "051_荆燕世家", "para": "7", "seq": 2, "text": "泽大说之，用金二百斤为田生寿。", "len": 15}
{"sid": "051_荆燕世家.7.s3", "chapter": "051_荆燕世家", "para": "7", "seq": 3, "text": "田生已得金，即归齐。", "len": 10}
{"sid": "051_荆燕世家.7.s4", "chapter": "051_荆燕世家", "para": "7", "seq": 4, "text": "二年，泽使人谓田生曰：“弗与矣。", "len": 16}
{"sid": "051_荆燕世家.7.s5", "chapter": "051_荆燕世家", "para": "7", "seq": 5, "text": "” 田生如长安，不见泽，而假大宅，令其子求事吕后所幸大谒者张子卿。", "len": 33}
{"sid": "051_荆燕世家.7.s6", "chapter": "051_荆燕世家", "para": "7", "seq": 6, "text": "居数月，田生子请张卿临，亲脩具。", "len": 16}
{"sid": "051_荆燕世家.7.s7", "chapter": "051_荆燕世家", "para": "7", "seq": 7, "text": "张卿许往。", "len": 5}
{"sid": "051_荆燕世家.7.s8", "chapter": "051_荆燕世家", "para": "7", "seq": 8, "text": "田生盛帷帐共具，譬如列侯。", "len": 13}
{"sid": "051_荆燕世家.7.s9", "chapter": "051_荆燕世家", "para": "7", "seq": 9, "text": "张卿惊。", "len": 4}
{"sid": "051_荆燕世家.7.s10", "chapter": "051_荆燕世家", "para": "7", "seq": 10, "text": "酒酣，乃屏人说张卿曰：“臣观诸侯王邸弟百馀，皆高祖一切功臣。", "len": 30}
{"sid": "051_荆燕世家.7.s11", "chapter": "051_荆燕世家", "para": "7", "seq": 11, "text": "今吕氏雅故本推毂高帝就天下，功至大，又亲戚太后之重。", "len": 26}
{"sid": "051_荆燕世家.7.s12", "chapter": "051_荆燕世家", "para": "7", "seq": 12, "text": "太后春秋长，诸吕弱，太后欲立吕产为王，王代。", "len": 22}
{"sid": "051_荆燕世家.7.s13", "chapter": "051_荆燕世家", "para": "7", "seq": 13, "text": "太后又重发之，恐大臣不听。", "len": 13}
{"sid": "051_荆燕世家.7.s14", "chapter": "051_荆燕世家", "para": "7", "seq": 14, "text": "今卿最幸，大臣所敬，何不风大臣以闻太后，太后必喜。", "len": 25}
{"sid": "051_荆燕世家.7.s15", "chapter": "051_荆燕世家", "para": "7", "seq": 15, "text": "诸吕已王，万户侯亦卿之有。", "len": 13}
{"sid": "051_荆燕世家.7.s16", "chapter": "051_荆燕世家", "para": "7", "seq": 16, "text": "太后心欲之，而卿为内臣，不急发，恐祸及身矣。", "len": 22}
{"sid": "051_荆燕世家.7.s17", "chapter": "051_荆燕世家", "para": "7", "seq": 17, "text": "” 张卿大然之，乃风大臣语太后。", "len": 16}
{"sid": "051_荆燕世家.7.s18", "chapter": "051_荆燕世家", "para": "7", "seq": 18, "text": "太后朝，因问大臣。", "len": 9}
{"sid": "051_荆燕世家.7.s19", "chapter": "051_荆燕世家", "para": "7", "seq": 19, "text": "大臣请立吕产为吕王。", "len": 10}
{"sid": "051_荆燕世家.7.s20", "chapter": "051_荆燕世家", "para": "7", "seq": 20, "text": "太后赐张卿千斤金，张卿以其半与田生。", "len": 18}
{"sid": "051_荆燕世家.7.s21", "chapter": "051_荆燕世家", "para": "7", "seq": 21, "text": "田生弗受，因说之曰：“吕产王也，诸大臣未大服。", "len": 23}
{"sid": "051_荆燕世家.7.s22", "chapter": "051_荆燕世家", "para": "7", "seq": 22, "text": "今营陵侯泽，诸刘，为大将军，独此尚觖望。", "len": 20}
{"sid": "051_荆燕世家.7.s23", "chapter": "051_荆燕世家", "para": "7", "seq": 23, "text": "今卿言太后，列十馀县王之，彼得王，喜去，诸吕王益固矣。", "len": 27}
{"sid": "051_荆燕世家.7.s24", "chapter": "051_荆燕世家", "para": "7", "seq": 24, "text": "” 张卿入言，太后然之。", "len": 12}
{"sid": "051_荆燕世家.7.s25", "chapter": "051_荆燕世家", "para": "7", "seq": 25, "text": "乃以营陵侯刘泽为琅邪王。", "len": 12}
{"sid": "051_荆燕世家.7.s26", "chapter": "051_荆燕世家", "para": "7", "seq": 26, "text": "琅邪王乃与田生之国。", "len": 10}
{"sid": "051_荆燕世家.7.s27", "chapter": "051_荆燕世家", "para": "7", "seq": 27, "text": "田生劝泽急行，毋留。", "len": 10}
{"sid": "051_荆燕世家.7.s28", "chapter": "051_荆燕世家", "para": "7", "seq": 28, "text": "出关，太后果使人追止之，已出，即还。", "len": 18}
{"sid": "051_荆燕世家.8.s1", "chapter": "051_荆燕世家", "para": "8", "seq": 1, "text": "及太后崩，琅邪王泽乃曰：“帝少，诸吕用事，刘氏孤弱。", "len": 26}
{"sid": "051_荆燕世家.8.s2", "chapter": "051_荆燕世家", "para": "8", "seq": 2, "text": "” 乃引兵与齐王合谋西，欲诛诸吕。", "len": 17}
{"sid": "051_荆燕世家.8.s3", "chapter": "051_荆燕世家", "para": "8", "seq": 3, "text": "至梁，闻汉遣灌将军屯荥阳，泽还兵备西界，遂跳驱至长安。", "len": 27}
{"sid": "051_荆燕世家.8.s4", "chapter": "051_荆燕世家", "para": "8", "seq": 4, "text": "代王亦从代至。", "len": 7}
{"sid": "051_荆燕世家.8.s5", "chapter": "051_荆燕世家", "para": "8", "seq": 5, "text": "诸将相与琅邪王共立代王为天子。", "len": 15}
{"sid": "051_荆燕世家.8.s6", "chapter": "051_荆燕世家", "para": "8", "seq": 6, "text": "天子乃徙泽为燕王，乃复以琅邪予齐，复故地。", "len": 21}
{"sid": "051_荆燕世家.9.s1", "chapter": "051_荆燕世家", "para": "9", "seq": 1, "text": "泽王燕二年，薨，谥为敬王。", "len": 13}
{"sid": "051_荆燕世家.9.s2", "chapter": "051_荆燕世家", "para": "9", "seq": 2, "text": "传子嘉，为康王。", "len": 8}
{"sid": "051_荆燕世家.10.s1", "chapter": "051_荆燕世家", "para": "10", "seq": 1, "text": "至孙定国，与父康王姬奸，生子男一人。", "len": 18}
{"sid": "051_荆燕世家.10.s2", "chapter": "051_荆燕世家", "para": "10", "seq": 2, "text": "夺弟妻为姬。", "len": 6}
{"sid": "051_荆燕世家.10.s3", "chapter": "051_荆燕世家", "para": "10", "seq": 3, "text": "与子女三人奸。", "len": 7}
{"sid": "051_荆燕世家.10.s4", "chapter": "051_荆燕世家", "para": "10", "seq": 4, "text": "定国有所欲诛杀臣肥如令郢人，郢人等告定国，定国使谒者以他法劾捕格杀郢人以灭口。", "len": 39}
{"sid": "051_荆燕世家.10.s5", "chapter": "051_荆燕世家", "para": "10", "seq": 5, "text": "至元朔元年，郢人昆弟复上书具言定国阴事，以此发觉。", "len": 25}
{"sid": "051_荆燕世家.10.s6", "chapter": "051_荆燕世家", "para": "10", "seq": 6, "text": "诏下公卿，皆议曰：“定国禽兽行，乱人伦，逆天，当诛。", "len": 26}
{"sid": "051_荆燕世家.10.s7", "chapter": "051_荆燕世家", "para": "10", "seq": 7, "text": "” 上许之。", "len": 6}
{"sid": "051_荆燕世家.10.s8", "chapter": "051_荆燕世家", "para": "10", "seq": 8, "text": "定国自杀，国除为郡。", "len": 10}
{"sid": "051_荆燕世家.10.s9", "chapter": "051_荆燕世家", "para": "10", "seq": 9, "text": "::: 太史公曰", "len": 8}
{"sid": "051_荆燕世家.11.s1", "chapter": "051_荆燕世家", "para": "11", "seq": 1, "text": "太史公曰：荆王王也，由汉初定，天下未集，故刘贾虽属疏，然以策为王，填江淮之间。", "len": 39}
{"sid": "051_荆燕世家.11.s2", "chapter": "051_荆燕世家", "para": "11", "seq": 2, "text": "刘泽之王，权激吕氏，然刘泽卒南面称孤者三世。", "len": 22}
{"sid": "051_荆燕世家.11.s3", "chapter": "051_荆燕世家", "para": "11", "seq": 3, "text": "事发相重，岂不为伟乎！", "len": 11}
{"sid": "051_荆燕世家.11.s4", "chapter": "051_荆燕世家", "para": "11", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "051_荆燕世家.12.s1", "chapter": "051_荆燕世家", "para": "12", "seq": 1, "text": "刘贾初从，首定三秦。", "len": 10}
{"sid": "051_荆燕世家.12.s2", "chapter": "051_荆燕世家", "para": "12", "seq": 2, "text": "既渡白马，遂围寿春。", "len": 10}
{"sid": "051_荆燕世家.12.s3", "chapter": "051_荆燕世家", "para": "12", "seq": 3, "text": "始迎黥布，绝间周殷。", "len": 10}
{"sid": "051_荆燕世家.12.s4", "chapter": "051_荆燕世家", "para": "12", "seq": 4, "text": "赏功胙士，与楚为邻。", "len": 10}
{"sid": "051_荆燕世家.12.s5", "chapter": "051_荆燕世家", "para": "12", "seq": 5, "text": "营陵始爵，勋由击陈。", "len": 10}
{"sid": "051_荆燕世家.12.s6", "chapter": "051_荆燕世家", "para": "12", "seq": 6, "text": "田生游说，受赐千斤。", "len": 10}
{"sid": "051_荆燕世家.12.s7", "chapter": "051_荆燕世家", "para": "12", "seq": 7, "text": "权激诸吕，事发荣身。", "len": 10}
{"sid": "051_荆燕世家.12.s8", "chapter": "051_荆燕世家", "para": "12", "seq": 8, "text": "徙封传嗣，亡於郢人。", "len": 10}
{"sid": "051_荆燕世家.12.s9", "chapter": "051_荆燕世家", "para": "12", "seq": 9, "text": ":::", "len": 3}
