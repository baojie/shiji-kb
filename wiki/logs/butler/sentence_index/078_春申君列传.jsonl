{"sid": "078_春申君列传.1.s1", "chapter": "078_春申君列传", "para": "1", "seq": 1, "text": "春申君者，楚人也，名歇，姓黄氏。", "len": 16}
{"sid": "078_春申君列传.1.s2", "chapter": "078_春申君列传", "para": "1", "seq": 2, "text": "游学博闻，事楚顷襄王。", "len": 11}
{"sid": "078_春申君列传.1.s3", "chapter": "078_春申君列传", "para": "1", "seq": 3, "text": "顷襄王以歇为辩，使於秦。", "len": 12}
{"sid": "078_春申君列传.1.s4", "chapter": "078_春申君列传", "para": "1", "seq": 4, "text": "秦昭王使白起攻韩、魏，败之於华阳，禽魏将芒卯，韩、魏服而事秦。", "len": 31}
{"sid": "078_春申君列传.1.s5", "chapter": "078_春申君列传", "para": "1", "seq": 5, "text": "秦昭王方令白起与韩、魏共伐楚，未行，而楚使黄歇適至於秦，闻秦之计。", "len": 33}
{"sid": "078_春申君列传.1.s6", "chapter": "078_春申君列传", "para": "1", "seq": 6, "text": "当是之时，秦已前使白起攻楚，取巫、黔中之郡，拔鄢郢，东至竟陵，楚顷襄王东徙治於陈县。", "len": 42}
{"sid": "078_春申君列传.1.s7", "chapter": "078_春申君列传", "para": "1", "seq": 7, "text": "黄歇见楚怀王之为秦所诱而入朝，遂见欺，留死於秦。", "len": 24}
{"sid": "078_春申君列传.1.s8", "chapter": "078_春申君列传", "para": "1", "seq": 8, "text": "顷襄王，其子也，秦轻之，恐壹举兵而灭楚。", "len": 20}
{"sid": "078_春申君列传.1.s9", "chapter": "078_春申君列传", "para": "1", "seq": 9, "text": "歇乃上书说秦昭王曰：", "len": 10}
{"sid": "078_春申君列传.2.s1", "chapter": "078_春申君列传", "para": "2", "seq": 1, "text": "天下莫彊於秦、楚。", "len": 9}
{"sid": "078_春申君列传.2.s2", "chapter": "078_春申君列传", "para": "2", "seq": 2, "text": "今闻大王欲伐楚，此犹两虎相与斗。", "len": 16}
{"sid": "078_春申君列传.2.s3", "chapter": "078_春申君列传", "para": "2", "seq": 3, "text": "两虎相与斗而驽犬受其弊，不如善楚。", "len": 17}
{"sid": "078_春申君列传.2.s4", "chapter": "078_春申君列传", "para": "2", "seq": 4, "text": "臣请言其说：臣闻物至则反，冬夏是也；致至则危，累釭是也。", "len": 28}
{"sid": "078_春申君列传.2.s5", "chapter": "078_春申君列传", "para": "2", "seq": 5, "text": "今大国之地，遍天下有其二垂，此从生民已来，万乘之地未尝有也。", "len": 30}
{"sid": "078_春申君列传.2.s6", "chapter": "078_春申君列传", "para": "2", "seq": 6, "text": "先帝文王、庄王之身，三世不妄接地於齐，以绝从亲之要。", "len": 26}
{"sid": "078_春申君列传.2.s7", "chapter": "078_春申君列传", "para": "2", "seq": 7, "text": "今王使盛桥守事於韩，盛桥以其地入秦，是王不用甲，不信威，而得百里之地。", "len": 35}
{"sid": "078_春申君列传.2.s8", "chapter": "078_春申君列传", "para": "2", "seq": 8, "text": "王可谓能矣。", "len": 6}
{"sid": "078_春申君列传.2.s9", "chapter": "078_春申君列传", "para": "2", "seq": 9, "text": "王又举甲而攻魏，杜大梁之门，举河内，拔燕、酸枣、虚、桃，入邢，魏之兵云翔而不敢捄。", "len": 41}
{"sid": "078_春申君列传.2.s10", "chapter": "078_春申君列传", "para": "2", "seq": 10, "text": "王之功亦多矣。", "len": 7}
{"sid": "078_春申君列传.2.s11", "chapter": "078_春申君列传", "para": "2", "seq": 11, "text": "王休甲息众，二年而後复之；又并蒲、衍、首、垣，以临仁、平丘，黄、济阳婴城而魏氏服；王又割濮", "len": 45}
{"sid": "078_春申君列传.3.s1", "chapter": "078_春申君列传", "para": "3", "seq": 1, "text": "之北，注齐秦之要，绝楚赵之脊，天下五合六聚而不敢救。", "len": 26}
{"sid": "078_春申君列传.3.s2", "chapter": "078_春申君列传", "para": "3", "seq": 2, "text": "王之威亦单矣。", "len": 7}
{"sid": "078_春申君列传.4.s1", "chapter": "078_春申君列传", "para": "4", "seq": 1, "text": "王若能持功守威，绌攻取之心而肥仁义之地，使无後患，三王不足四，五伯不足六也。", "len": 38}
{"sid": "078_春申君列传.4.s2", "chapter": "078_春申君列传", "para": "4", "seq": 2, "text": "王若负人徒之众，仗兵革之彊，乘毁魏之威，而欲以力臣天下之主，臣恐其有後患也。", "len": 38}
{"sid": "078_春申君列传.4.s3", "chapter": "078_春申君列传", "para": "4", "seq": 3, "text": "诗曰“靡不有初，鲜克有终”。", "len": 14}
{"sid": "078_春申君列传.4.s4", "chapter": "078_春申君列传", "para": "4", "seq": 4, "text": "易曰“狐涉水，濡其尾”。", "len": 12}
{"sid": "078_春申君列传.4.s5", "chapter": "078_春申君列传", "para": "4", "seq": 5, "text": "此言始之易，终之难也。", "len": 11}
{"sid": "078_春申君列传.4.s6", "chapter": "078_春申君列传", "para": "4", "seq": 6, "text": "何以知其然也？", "len": 7}
{"sid": "078_春申君列传.4.s7", "chapter": "078_春申君列传", "para": "4", "seq": 7, "text": "昔智氏见伐赵之利而不知榆次之祸，吴见伐齐之便而不知干隧之败。", "len": 30}
{"sid": "078_春申君列传.4.s8", "chapter": "078_春申君列传", "para": "4", "seq": 8, "text": "此二国者，非无大功也，没利於前而易患於後也。", "len": 22}
{"sid": "078_春申君列传.4.s9", "chapter": "078_春申君列传", "para": "4", "seq": 9, "text": "吴之信越也，从而伐齐，既胜齐人於艾陵，还为越王禽三渚之浦。", "len": 29}
{"sid": "078_春申君列传.4.s10", "chapter": "078_春申君列传", "para": "4", "seq": 10, "text": "智氏之信韩、魏也，从而伐赵，攻晋阳城，胜有日矣，韩、魏叛之，杀智伯瑶於凿台之下。", "len": 40}
{"sid": "078_春申君列传.4.s11", "chapter": "078_春申君列传", "para": "4", "seq": 11, "text": "今王妒楚之不毁也，而忘毁楚之彊韩、魏也，臣为王虑而不取也。", "len": 29}
{"sid": "078_春申君列传.5.s1", "chapter": "078_春申君列传", "para": "5", "seq": 1, "text": "诗曰“大武远宅而不涉”。", "len": 12}
{"sid": "078_春申君列传.5.s2", "chapter": "078_春申君列传", "para": "5", "seq": 2, "text": "从此观之，楚国，援也；邻国，敌也。", "len": 17}
{"sid": "078_春申君列传.5.s3", "chapter": "078_春申君列传", "para": "5", "seq": 3, "text": "诗云“趯趯", "len": 5}
{"sid": "078_春申君列传.6.s1", "chapter": "078_春申君列传", "para": "6", "seq": 1, "text": "免，还犬获之。", "len": 7}
{"sid": "078_春申君列传.6.s2", "chapter": "078_春申君列传", "para": "6", "seq": 2, "text": "他人有心，余忖度之”。", "len": 11}
{"sid": "078_春申君列传.6.s3", "chapter": "078_春申君列传", "para": "6", "seq": 3, "text": "今王中道而信韩、魏之善王也，此正吴之信越也。", "len": 22}
{"sid": "078_春申君列传.6.s4", "chapter": "078_春申君列传", "para": "6", "seq": 4, "text": "臣闻之，敌不可假，时不可失。", "len": 14}
{"sid": "078_春申君列传.6.s5", "chapter": "078_春申君列传", "para": "6", "seq": 5, "text": "臣恐韩、魏卑辞除患而实欲欺大国也。", "len": 17}
{"sid": "078_春申君列传.6.s6", "chapter": "078_春申君列传", "para": "6", "seq": 6, "text": "何则？", "len": 3}
{"sid": "078_春申君列传.6.s7", "chapter": "078_春申君列传", "para": "6", "seq": 7, "text": "王无重世之德於韩、魏，而有累世之怨焉。", "len": 19}
{"sid": "078_春申君列传.6.s8", "chapter": "078_春申君列传", "para": "6", "seq": 8, "text": "夫韩、魏父子兄弟接踵而死於秦者将十世矣。", "len": 20}
{"sid": "078_春申君列传.6.s9", "chapter": "078_春申君列传", "para": "6", "seq": 9, "text": "本国残，社稷坏，宗庙毁。", "len": 12}
{"sid": "078_春申君列传.6.s10", "chapter": "078_春申君列传", "para": "6", "seq": 10, "text": "刳腹绝肠，折颈摺颐，首身分离，暴骸骨於草泽，头颅僵仆，相望於境，父子老弱系脰束手为群虏者相及於路。", "len": 49}
{"sid": "078_春申君列传.6.s11", "chapter": "078_春申君列传", "para": "6", "seq": 11, "text": "鬼神孤伤，无所血食。", "len": 10}
{"sid": "078_春申君列传.6.s12", "chapter": "078_春申君列传", "para": "6", "seq": 12, "text": "人民不聊生，族类离散，流亡为仆妾者，盈满海内矣。", "len": 24}
{"sid": "078_春申君列传.6.s13", "chapter": "078_春申君列传", "para": "6", "seq": 13, "text": "故韩、魏之不亡，秦社稷之忧也，今王资之与攻楚，不亦过乎！", "len": 28}
{"sid": "078_春申君列传.7.s1", "chapter": "078_春申君列传", "para": "7", "seq": 1, "text": "且王攻楚将恶出兵？", "len": 9}
{"sid": "078_春申君列传.7.s2", "chapter": "078_春申君列传", "para": "7", "seq": 2, "text": "王将借路於仇雠之韩、魏乎？", "len": 13}
{"sid": "078_春申君列传.7.s3", "chapter": "078_春申君列传", "para": "7", "seq": 3, "text": "兵出之日而王忧其不返也，是王以兵资於仇雠之韩、魏也。", "len": 26}
{"sid": "078_春申君列传.7.s4", "chapter": "078_春申君列传", "para": "7", "seq": 4, "text": "王若不借路於仇雠之韩、魏，必攻随水右壤。", "len": 20}
{"sid": "078_春申君列传.7.s5", "chapter": "078_春申君列传", "para": "7", "seq": 5, "text": "随水右壤，此皆广川大水，山林谿谷，不食之地也，王虽有之，不为得地。", "len": 33}
{"sid": "078_春申君列传.7.s6", "chapter": "078_春申君列传", "para": "7", "seq": 6, "text": "是王有毁楚之名而无得地之实也。", "len": 15}
{"sid": "078_春申君列传.8.s1", "chapter": "078_春申君列传", "para": "8", "seq": 1, "text": "且王攻楚之日，四国必悉起兵以应王。", "len": 17}
{"sid": "078_春申君列传.8.s2", "chapter": "078_春申君列传", "para": "8", "seq": 2, "text": "秦、楚之兵构而不离，魏氏将出而攻留、方与、铚、湖陵、砀、萧、相，故宋必尽。", "len": 37}
{"sid": "078_春申君列传.8.s3", "chapter": "078_春申君列传", "para": "8", "seq": 3, "text": "齐人南面攻楚，泗上必举。", "len": 12}
{"sid": "078_春申君列传.8.s4", "chapter": "078_春申君列传", "para": "8", "seq": 4, "text": "此皆平原四达，膏腴之地，而使独攻。", "len": 17}
{"sid": "078_春申君列传.8.s5", "chapter": "078_春申君列传", "para": "8", "seq": 5, "text": "王破楚以肥韩、魏於中国而劲齐。", "len": 15}
{"sid": "078_春申君列传.8.s6", "chapter": "078_春申君列传", "para": "8", "seq": 6, "text": "韩、魏之彊，足以校於秦。", "len": 12}
{"sid": "078_春申君列传.8.s7", "chapter": "078_春申君列传", "para": "8", "seq": 7, "text": "齐南以泗水为境，东负海，北倚河，而无後患，天下之国莫彊於齐、魏，齐、魏得地葆利而详事下吏，一年之後，为帝未能，其於禁王之为帝有馀矣。", "len": 66}
{"sid": "078_春申君列传.9.s1", "chapter": "078_春申君列传", "para": "9", "seq": 1, "text": "夫以王壤土之博，人徒之众，兵革之彊，壹举事而树怨於楚，迟令韩、魏归帝重於齐，是王失计也。", "len": 44}
{"sid": "078_春申君列传.9.s2", "chapter": "078_春申君列传", "para": "9", "seq": 2, "text": "臣为王虑，莫若善楚。", "len": 10}
{"sid": "078_春申君列传.9.s3", "chapter": "078_春申君列传", "para": "9", "seq": 3, "text": "秦、楚合而为一以临韩，韩必敛手。", "len": 16}
{"sid": "078_春申君列传.9.s4", "chapter": "078_春申君列传", "para": "9", "seq": 4, "text": "王施以东山之险，带以曲河之利，韩必为关内之侯。", "len": 23}
{"sid": "078_春申君列传.9.s5", "chapter": "078_春申君列传", "para": "9", "seq": 5, "text": "若是而王以十万戍郑，梁氏寒心，许、鄢陵婴城，而上蔡、召陵不往来也，如此而魏亦关内侯矣。", "len": 43}
{"sid": "078_春申君列传.9.s6", "chapter": "078_春申君列传", "para": "9", "seq": 6, "text": "王壹善楚，而关内两万乘之主注地於齐，齐右壤可拱手而取也。", "len": 28}
{"sid": "078_春申君列传.9.s7", "chapter": "078_春申君列传", "para": "9", "seq": 7, "text": "王之地一经两海，要约天下，是燕、赵无齐、楚，齐、楚无燕、赵也。", "len": 31}
{"sid": "078_春申君列传.9.s8", "chapter": "078_春申君列传", "para": "9", "seq": 8, "text": "然後危动燕、赵，直摇齐、楚，此四国者不待痛而服矣。", "len": 25}
{"sid": "078_春申君列传.10.s1", "chapter": "078_春申君列传", "para": "10", "seq": 1, "text": "昭王曰：“善。", "len": 7}
{"sid": "078_春申君列传.10.s2", "chapter": "078_春申君列传", "para": "10", "seq": 2, "text": "” 於是乃止白起而谢韩、魏。", "len": 14}
{"sid": "078_春申君列传.10.s3", "chapter": "078_春申君列传", "para": "10", "seq": 3, "text": "发使赂楚，约为与国。", "len": 10}
{"sid": "078_春申君列传.11.s1", "chapter": "078_春申君列传", "para": "11", "seq": 1, "text": "黄歇受约归楚，楚使歇与太子完入质於秦，秦留之数年。", "len": 25}
{"sid": "078_春申君列传.11.s2", "chapter": "078_春申君列传", "para": "11", "seq": 2, "text": "楚顷襄王病，太子不得归。", "len": 12}
{"sid": "078_春申君列传.11.s3", "chapter": "078_春申君列传", "para": "11", "seq": 3, "text": "而楚太子与秦相应侯善，於是黄歇乃说应侯曰：“相国诚善楚太子乎？", "len": 31}
{"sid": "078_春申君列传.11.s4", "chapter": "078_春申君列传", "para": "11", "seq": 4, "text": "” 应侯曰：“然。", "len": 9}
{"sid": "078_春申君列传.11.s5", "chapter": "078_春申君列传", "para": "11", "seq": 5, "text": "” 歇曰：“今楚王恐不起疾，秦不如归其太子。", "len": 22}
{"sid": "078_春申君列传.11.s6", "chapter": "078_春申君列传", "para": "11", "seq": 6, "text": "太子得立，其事秦必重而德相国无穷，是亲与国而得储万乘也。", "len": 28}
{"sid": "078_春申君列传.11.s7", "chapter": "078_春申君列传", "para": "11", "seq": 7, "text": "若不归，则咸阳一布衣耳；楚更立太子，必不事秦。", "len": 23}
{"sid": "078_春申君列传.11.s8", "chapter": "078_春申君列传", "para": "11", "seq": 8, "text": "夫失与国而绝万乘之和，非计也。", "len": 15}
{"sid": "078_春申君列传.11.s9", "chapter": "078_春申君列传", "para": "11", "seq": 9, "text": "原相国孰虑之。", "len": 7}
{"sid": "078_春申君列传.11.s10", "chapter": "078_春申君列传", "para": "11", "seq": 10, "text": "” 应侯以闻秦王。", "len": 9}
{"sid": "078_春申君列传.11.s11", "chapter": "078_春申君列传", "para": "11", "seq": 11, "text": "秦王曰：“令楚太子之傅先往问楚王之疾，返而後图之。", "len": 25}
{"sid": "078_春申君列传.11.s12", "chapter": "078_春申君列传", "para": "11", "seq": 12, "text": "” 黄歇为楚太子计曰：“秦之留太子也，欲以求利也。", "len": 25}
{"sid": "078_春申君列传.11.s13", "chapter": "078_春申君列传", "para": "11", "seq": 13, "text": "今太子力未能有以利秦也，歇忧之甚。", "len": 17}
{"sid": "078_春申君列传.11.s14", "chapter": "078_春申君列传", "para": "11", "seq": 14, "text": "而阳文君子二人在中，王若卒大命，太子不在，阳文君子必立为後，太子不得奉宗庙矣。", "len": 39}
{"sid": "078_春申君列传.11.s15", "chapter": "078_春申君列传", "para": "11", "seq": 15, "text": "不如亡秦，与使者俱出；臣请止，以死当之。", "len": 20}
{"sid": "078_春申君列传.11.s16", "chapter": "078_春申君列传", "para": "11", "seq": 16, "text": "” 楚太子因变衣服为楚使者御以出关，而黄歇守舍，常为谢病。", "len": 29}
{"sid": "078_春申君列传.11.s17", "chapter": "078_春申君列传", "para": "11", "seq": 17, "text": "度太子已远，秦不能追，歇乃自言秦昭王曰：“楚太子已归，出远矣。", "len": 31}
{"sid": "078_春申君列传.11.s18", "chapter": "078_春申君列传", "para": "11", "seq": 18, "text": "歇当死，原赐死。", "len": 8}
{"sid": "078_春申君列传.11.s19", "chapter": "078_春申君列传", "para": "11", "seq": 19, "text": "” 昭王大怒，欲听其自杀也。", "len": 14}
{"sid": "078_春申君列传.11.s20", "chapter": "078_春申君列传", "para": "11", "seq": 20, "text": "应侯曰：“歇为人臣，出身以徇其主，太子立，必用歇，故不如无罪而归之，以亲楚。", "len": 38}
{"sid": "078_春申君列传.11.s21", "chapter": "078_春申君列传", "para": "11", "seq": 21, "text": "” 秦因遣黄歇。", "len": 8}
{"sid": "078_春申君列传.12.s1", "chapter": "078_春申君列传", "para": "12", "seq": 1, "text": "歇至楚三月，楚顷襄王卒，太子完立，是为考烈王。", "len": 23}
{"sid": "078_春申君列传.12.s2", "chapter": "078_春申君列传", "para": "12", "seq": 2, "text": "考烈王元年，以黄歇为相，封为春申君，赐淮北地十二县。", "len": 26}
{"sid": "078_春申君列传.12.s3", "chapter": "078_春申君列传", "para": "12", "seq": 3, "text": "後十五岁，黄歇言之楚王曰：“淮北地边齐，其事急，请以为郡便。", "len": 30}
{"sid": "078_春申君列传.12.s4", "chapter": "078_春申君列传", "para": "12", "seq": 4, "text": "” 因并献淮北十二县。", "len": 11}
{"sid": "078_春申君列传.12.s5", "chapter": "078_春申君列传", "para": "12", "seq": 5, "text": "请封於江东。", "len": 6}
{"sid": "078_春申君列传.12.s6", "chapter": "078_春申君列传", "para": "12", "seq": 6, "text": "考烈王许之。", "len": 6}
{"sid": "078_春申君列传.12.s7", "chapter": "078_春申君列传", "para": "12", "seq": 7, "text": "春申君因城故吴墟，以自为都邑。", "len": 15}
{"sid": "078_春申君列传.13.s1", "chapter": "078_春申君列传", "para": "13", "seq": 1, "text": "春申君既相楚，是时齐有孟尝君，赵有平原君，魏有信陵君，方争下士，招致宾客，以相倾夺，辅国持权。", "len": 47}
{"sid": "078_春申君列传.14.s1", "chapter": "078_春申君列传", "para": "14", "seq": 1, "text": "春申君为楚相四年，秦破赵之长平军四十馀万。", "len": 21}
{"sid": "078_春申君列传.14.s2", "chapter": "078_春申君列传", "para": "14", "seq": 2, "text": "五年，围邯郸。", "len": 7}
{"sid": "078_春申君列传.14.s3", "chapter": "078_春申君列传", "para": "14", "seq": 3, "text": "邯郸告急於楚，楚使春申君将兵往救之，秦兵亦去，春申君归。", "len": 28}
{"sid": "078_春申君列传.14.s4", "chapter": "078_春申君列传", "para": "14", "seq": 4, "text": "春申君相楚八年，为楚北伐灭鲁，以荀卿为兰陵令。", "len": 23}
{"sid": "078_春申君列传.14.s5", "chapter": "078_春申君列传", "para": "14", "seq": 5, "text": "当是时，楚复彊。", "len": 8}
{"sid": "078_春申君列传.15.s1", "chapter": "078_春申君列传", "para": "15", "seq": 1, "text": "赵平原君使人於春申君，春申君舍之於上舍。", "len": 20}
{"sid": "078_春申君列传.15.s2", "chapter": "078_春申君列传", "para": "15", "seq": 2, "text": "赵使欲夸楚，为玳瑁簪，刀剑室以珠玉饰之，请命春申君客。", "len": 27}
{"sid": "078_春申君列传.15.s3", "chapter": "078_春申君列传", "para": "15", "seq": 3, "text": "春申君客三千馀人，其上客皆蹑珠履以见赵使，赵使大惭。", "len": 26}
{"sid": "078_春申君列传.16.s1", "chapter": "078_春申君列传", "para": "16", "seq": 1, "text": "春申君相十四年，秦庄襄王立，以吕不韦为相，封为文信侯。", "len": 27}
{"sid": "078_春申君列传.16.s2", "chapter": "078_春申君列传", "para": "16", "seq": 2, "text": "取东周。", "len": 4}
{"sid": "078_春申君列传.17.s1", "chapter": "078_春申君列传", "para": "17", "seq": 1, "text": "春申君相二十二年，诸侯患秦攻伐无已时，乃相与合从，西伐秦，而楚王为从长，春申君用事。", "len": 42}
{"sid": "078_春申君列传.17.s2", "chapter": "078_春申君列传", "para": "17", "seq": 2, "text": "至函谷关，秦出兵攻，诸侯兵皆败走。", "len": 17}
{"sid": "078_春申君列传.17.s3", "chapter": "078_春申君列传", "para": "17", "seq": 3, "text": "楚考烈王以咎春申君，春申君以此益疏。", "len": 18}
{"sid": "078_春申君列传.18.s1", "chapter": "078_春申君列传", "para": "18", "seq": 1, "text": "客有观津人硃英，谓春申君曰：“人皆以楚为彊而君用之弱，其於英不然。", "len": 33}
{"sid": "078_春申君列传.18.s2", "chapter": "078_春申君列传", "para": "18", "seq": 2, "text": "先君时善秦二十年而不攻楚，何也？", "len": 16}
{"sid": "078_春申君列传.18.s3", "chapter": "078_春申君列传", "para": "18", "seq": 3, "text": "秦逾黾隘之塞而攻楚，不便；假道於两周，背韩、魏而攻楚，不可。", "len": 30}
{"sid": "078_春申君列传.18.s4", "chapter": "078_春申君列传", "para": "18", "seq": 4, "text": "今则不然，魏旦暮亡，不能爱许、鄢陵，其许魏割以与秦。", "len": 26}
{"sid": "078_春申君列传.18.s5", "chapter": "078_春申君列传", "para": "18", "seq": 5, "text": "秦兵去陈百六十里，臣之所观者，见秦、楚之日斗也。", "len": 24}
{"sid": "078_春申君列传.18.s6", "chapter": "078_春申君列传", "para": "18", "seq": 6, "text": "” 楚於是去陈徙寿春；而秦徙卫野王，作置东郡。", "len": 23}
{"sid": "078_春申君列传.18.s7", "chapter": "078_春申君列传", "para": "18", "seq": 7, "text": "春申君由此就封於吴，行相事。", "len": 14}
{"sid": "078_春申君列传.19.s1", "chapter": "078_春申君列传", "para": "19", "seq": 1, "text": "楚考烈王无子，春申君患之，求妇人宜子者进之，甚众，卒无子。", "len": 29}
{"sid": "078_春申君列传.19.s2", "chapter": "078_春申君列传", "para": "19", "seq": 2, "text": "赵人李园持其女弟，欲进之楚王，闻其不宜子，恐久毋宠。", "len": 26}
{"sid": "078_春申君列传.19.s3", "chapter": "078_春申君列传", "para": "19", "seq": 3, "text": "李园求事春申君为舍人，已而谒归，故失期。", "len": 20}
{"sid": "078_春申君列传.19.s4", "chapter": "078_春申君列传", "para": "19", "seq": 4, "text": "还谒，春申君问之状，对曰：“齐王使使求臣之女弟，与其使者饮，故失期。", "len": 34}
{"sid": "078_春申君列传.19.s5", "chapter": "078_春申君列传", "para": "19", "seq": 5, "text": "” 春申君曰：“娉入乎？", "len": 12}
{"sid": "078_春申君列传.19.s6", "chapter": "078_春申君列传", "para": "19", "seq": 6, "text": "” 对曰：“未也。", "len": 9}
{"sid": "078_春申君列传.19.s7", "chapter": "078_春申君列传", "para": "19", "seq": 7, "text": "” 春申君曰：“可得见乎？", "len": 13}
{"sid": "078_春申君列传.19.s8", "chapter": "078_春申君列传", "para": "19", "seq": 8, "text": "” 曰：“可。", "len": 7}
{"sid": "078_春申君列传.19.s9", "chapter": "078_春申君列传", "para": "19", "seq": 9, "text": "” 於是李园乃进其女弟，即幸於春申君。", "len": 19}
{"sid": "078_春申君列传.19.s10", "chapter": "078_春申君列传", "para": "19", "seq": 10, "text": "知其有身，李园乃与其女弟谋。", "len": 14}
{"sid": "078_春申君列传.19.s11", "chapter": "078_春申君列传", "para": "19", "seq": 11, "text": "园女弟承间以说春申君曰：“楚王之贵幸君，虽兄弟不如也。", "len": 27}
{"sid": "078_春申君列传.19.s12", "chapter": "078_春申君列传", "para": "19", "seq": 12, "text": "今君相楚二十馀年，而王无子，即百岁後将更立兄弟，则楚更立君後，亦各贵其故所亲，君又安得长有宠乎？", "len": 48}
{"sid": "078_春申君列传.19.s13", "chapter": "078_春申君列传", "para": "19", "seq": 13, "text": "非徒然也，君贵用事久，多失礼於王兄弟，兄弟诚立，祸且及身，何以保相印江东之封乎？", "len": 40}
{"sid": "078_春申君列传.19.s14", "chapter": "078_春申君列传", "para": "19", "seq": 14, "text": "今妾自知有身矣，而人莫知。", "len": 13}
{"sid": "078_春申君列传.19.s15", "chapter": "078_春申君列传", "para": "19", "seq": 15, "text": "妾幸君未久，诚以君之重而进妾於楚王，王必幸妾；妾赖天有子男，则是君之子为王也，楚国尽可得，孰与身临不测之罪乎？", "len": 55}
{"sid": "078_春申君列传.19.s16", "chapter": "078_春申君列传", "para": "19", "seq": 16, "text": "” 春申君大然之，乃出李园女弟，谨舍而言之楚王。", "len": 24}
{"sid": "078_春申君列传.19.s17", "chapter": "078_春申君列传", "para": "19", "seq": 17, "text": "楚王召入幸之，遂生子男，立为太子，以李园女弟为王后。", "len": 26}
{"sid": "078_春申君列传.19.s18", "chapter": "078_春申君列传", "para": "19", "seq": 18, "text": "楚王贵李园，园用事。", "len": 10}
{"sid": "078_春申君列传.20.s1", "chapter": "078_春申君列传", "para": "20", "seq": 1, "text": "李园既入其女弟，立为王后，子为太子，恐春申君语泄而益骄，阴养死士，欲杀春申君以灭口，而国人颇有知之者。", "len": 51}
{"sid": "078_春申君列传.21.s1", "chapter": "078_春申君列传", "para": "21", "seq": 1, "text": "春申君相二十五年，楚考烈王病。", "len": 15}
{"sid": "078_春申君列传.21.s2", "chapter": "078_春申君列传", "para": "21", "seq": 2, "text": "硃英谓春申君曰：“世有毋望之福，又有毋望之祸。", "len": 23}
{"sid": "078_春申君列传.21.s3", "chapter": "078_春申君列传", "para": "21", "seq": 3, "text": "今君处毋望之世，事毋望之主，安可以无毋望之人乎？", "len": 24}
{"sid": "078_春申君列传.21.s4", "chapter": "078_春申君列传", "para": "21", "seq": 4, "text": "” 春申君曰：“何谓毋望之福？", "len": 15}
{"sid": "078_春申君列传.21.s5", "chapter": "078_春申君列传", "para": "21", "seq": 5, "text": "” 曰：“君相楚二十馀年矣，虽名相国，实楚王也。", "len": 24}
{"sid": "078_春申君列传.21.s6", "chapter": "078_春申君列传", "para": "21", "seq": 6, "text": "今楚王病，旦暮且卒，而君相少主，因而代立当国，如伊尹、周公，王长而反政，不即遂南面称孤而有楚国？", "len": 48}
{"sid": "078_春申君列传.21.s7", "chapter": "078_春申君列传", "para": "21", "seq": 7, "text": "此所谓毋望之福也。", "len": 9}
{"sid": "078_春申君列传.21.s8", "chapter": "078_春申君列传", "para": "21", "seq": 8, "text": "” 春申君曰：“何谓毋望之祸？", "len": 15}
{"sid": "078_春申君列传.21.s9", "chapter": "078_春申君列传", "para": "21", "seq": 9, "text": "” 曰：“李园不治国而君之仇也，不为兵而养死士之日久矣，楚王卒，李园必先入据权而杀君以灭口。", "len": 46}
{"sid": "078_春申君列传.21.s10", "chapter": "078_春申君列传", "para": "21", "seq": 10, "text": "此所谓毋望之祸也。", "len": 9}
{"sid": "078_春申君列传.21.s11", "chapter": "078_春申君列传", "para": "21", "seq": 11, "text": "” 春申君曰：“何谓毋望之人？", "len": 15}
{"sid": "078_春申君列传.21.s12", "chapter": "078_春申君列传", "para": "21", "seq": 12, "text": "” 对曰：“君置臣郎中，楚王卒，李园必先入，臣为君杀李园。", "len": 29}
{"sid": "078_春申君列传.21.s13", "chapter": "078_春申君列传", "para": "21", "seq": 13, "text": "此所谓毋望之人也。", "len": 9}
{"sid": "078_春申君列传.21.s14", "chapter": "078_春申君列传", "para": "21", "seq": 14, "text": "” 春申君曰：“足下置之，李园，弱人也，仆又善之，且又何至此！", "len": 31}
{"sid": "078_春申君列传.21.s15", "chapter": "078_春申君列传", "para": "21", "seq": 15, "text": "” 硃英知言不用，恐祸及身，乃亡去。", "len": 18}
{"sid": "078_春申君列传.22.s1", "chapter": "078_春申君列传", "para": "22", "seq": 1, "text": "後十七日，楚考烈王卒，李园果先入，伏死士於棘门之内。", "len": 26}
{"sid": "078_春申君列传.22.s2", "chapter": "078_春申君列传", "para": "22", "seq": 2, "text": "春申君入棘门，园死士侠刺春申君，斩其头，投之棘门外。", "len": 26}
{"sid": "078_春申君列传.22.s3", "chapter": "078_春申君列传", "para": "22", "seq": 3, "text": "於是遂使吏尽灭春申君之家。", "len": 13}
{"sid": "078_春申君列传.22.s4", "chapter": "078_春申君列传", "para": "22", "seq": 4, "text": "而李园女弟初幸春申君有身而入之王所生子者遂立，是为楚幽王。", "len": 29}
{"sid": "078_春申君列传.23.s1", "chapter": "078_春申君列传", "para": "23", "seq": 1, "text": "是岁也，秦始皇帝立九年矣。", "len": 13}
{"sid": "078_春申君列传.23.s2", "chapter": "078_春申君列传", "para": "23", "seq": 2, "text": "嫪毐亦为乱於秦，觉，夷其三族，而吕不韦废。", "len": 21}
{"sid": "078_春申君列传.23.s3", "chapter": "078_春申君列传", "para": "23", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "078_春申君列传.24.s1", "chapter": "078_春申君列传", "para": "24", "seq": 1, "text": "太史公曰：吾適楚，观春申君故城，宫室盛矣哉！", "len": 22}
{"sid": "078_春申君列传.24.s2", "chapter": "078_春申君列传", "para": "24", "seq": 2, "text": "初，春申君之说秦昭王，及出身遣楚太子归，何其智之明也！", "len": 27}
{"sid": "078_春申君列传.24.s3", "chapter": "078_春申君列传", "para": "24", "seq": 3, "text": "後制於李园，旄矣。", "len": 9}
{"sid": "078_春申君列传.24.s4", "chapter": "078_春申君列传", "para": "24", "seq": 4, "text": "语曰：“当断不断，反受其乱。", "len": 14}
{"sid": "078_春申君列传.24.s5", "chapter": "078_春申君列传", "para": "24", "seq": 5, "text": "” 春申君失硃英之谓邪？", "len": 12}
{"sid": "078_春申君列传.24.s6", "chapter": "078_春申君列传", "para": "24", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "078_春申君列传.25.s1", "chapter": "078_春申君列传", "para": "25", "seq": 1, "text": "黄歇辩智，权略秦、楚。", "len": 11}
{"sid": "078_春申君列传.25.s2", "chapter": "078_春申君列传", "para": "25", "seq": 2, "text": "太子获归，身作宰辅。", "len": 10}
{"sid": "078_春申君列传.25.s3", "chapter": "078_春申君列传", "para": "25", "seq": 3, "text": "珠炫赵客，邑开吴土。", "len": 10}
{"sid": "078_春申君列传.25.s4", "chapter": "078_春申君列传", "para": "25", "seq": 4, "text": "烈王寡胤，李园献女。", "len": 10}
{"sid": "078_春申君列传.25.s5", "chapter": "078_春申君列传", "para": "25", "seq": 5, "text": "无妄成灾，硃英徒语。", "len": 10}
{"sid": "078_春申君列传.25.s6", "chapter": "078_春申君列传", "para": "25", "seq": 6, "text": ":::", "len": 3}
