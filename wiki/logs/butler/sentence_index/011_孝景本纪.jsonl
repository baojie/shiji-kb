{"sid": "011_孝景本纪.1.1.s1", "chapter": "011_孝景本纪", "para": "1.1", "seq": 1, "text": "孝景皇帝者，孝文之中子也。", "len": 13}
{"sid": "011_孝景本纪.1.1.s2", "chapter": "011_孝景本纪", "para": "1.1", "seq": 2, "text": "母窦太后。", "len": 5}
{"sid": "011_孝景本纪.1.2.s1", "chapter": "011_孝景本纪", "para": "1.2", "seq": 1, "text": "孝文在代时，前后有三男，及窦太后得幸，前后死，及三子更死，故孝景得立。", "len": 35}
{"sid": "011_孝景本纪.2.1.s1", "chapter": "011_孝景本纪", "para": "2.1", "seq": 1, "text": "元年四月乙卯，赦天下。", "len": 11}
{"sid": "011_孝景本纪.2.1.s2", "chapter": "011_孝景本纪", "para": "2.1", "seq": 2, "text": "乙巳，赐民爵一级。", "len": 9}
{"sid": "011_孝景本纪.2.2.s1", "chapter": "011_孝景本纪", "para": "2.2", "seq": 1, "text": "五月，除田半租，为孝文立太宗庙。", "len": 16}
{"sid": "011_孝景本纪.2.2.s2", "chapter": "011_孝景本纪", "para": "2.2", "seq": 2, "text": "令群臣无朝贺。", "len": 7}
{"sid": "011_孝景本纪.2.3.s1", "chapter": "011_孝景本纪", "para": "2.3", "seq": 1, "text": "匈奴入代，与约和亲。", "len": 10}
{"sid": "011_孝景本纪.3.1.s1", "chapter": "011_孝景本纪", "para": "3.1", "seq": 1, "text": "二年春，封故相国萧何孙系为武陵侯。", "len": 17}
{"sid": "011_孝景本纪.3.2.s1", "chapter": "011_孝景本纪", "para": "3.2", "seq": 1, "text": "男子二十而得傅。", "len": 8}
{"sid": "011_孝景本纪.3.3.s1", "chapter": "011_孝景本纪", "para": "3.3", "seq": 1, "text": "四月壬午，孝文太后崩。", "len": 11}
{"sid": "011_孝景本纪.3.4.s1", "chapter": "011_孝景本纪", "para": "3.4", "seq": 1, "text": "广川、长沙王皆之国。", "len": 10}
{"sid": "011_孝景本纪.3.5.s1", "chapter": "011_孝景本纪", "para": "3.5", "seq": 1, "text": "丞相申屠嘉卒。", "len": 7}
{"sid": "011_孝景本纪.3.6.s1", "chapter": "011_孝景本纪", "para": "3.6", "seq": 1, "text": "八月，以御史大夫开封陶青为丞相。", "len": 16}
{"sid": "011_孝景本纪.3.7.s1", "chapter": "011_孝景本纪", "para": "3.7", "seq": 1, "text": "彗星出东北。", "len": 6}
{"sid": "011_孝景本纪.4.1.s1", "chapter": "011_孝景本纪", "para": "4.1", "seq": 1, "text": "秋，衡山雨雹，大者五寸，深者二尺。", "len": 17}
{"sid": "011_孝景本纪.4.2.s1", "chapter": "011_孝景本纪", "para": "4.2", "seq": 1, "text": "荧惑逆行，守北辰。", "len": 9}
{"sid": "011_孝景本纪.4.3.s1", "chapter": "011_孝景本纪", "para": "4.3", "seq": 1, "text": "月出北辰间。", "len": 6}
{"sid": "011_孝景本纪.4.4.s1", "chapter": "011_孝景本纪", "para": "4.4", "seq": 1, "text": "岁星逆行天廷中。", "len": 8}
{"sid": "011_孝景本纪.4.5.s1", "chapter": "011_孝景本纪", "para": "4.5", "seq": 1, "text": "置南陵及内史、祋祤为县。", "len": 12}
{"sid": "011_孝景本纪.5.1.s1", "chapter": "011_孝景本纪", "para": "5.1", "seq": 1, "text": "三年正月乙巳，赦天下。", "len": 11}
{"sid": "011_孝景本纪.5.2.s1", "chapter": "011_孝景本纪", "para": "5.2", "seq": 1, "text": "长星出西方。", "len": 6}
{"sid": "011_孝景本纪.5.3.s1", "chapter": "011_孝景本纪", "para": "5.3", "seq": 1, "text": "天火燔雒阳东宫大殿城室。", "len": 12}
{"sid": "011_孝景本纪.6.1.s1", "chapter": "011_孝景本纪", "para": "6.1", "seq": 1, "text": "吴王濞、楚王戊、赵王遂、胶西王卬、济南王辟光、菑川王贤、胶东王雄渠反，发兵西乡。", "len": 40}
{"sid": "011_孝景本纪.6.2.s1", "chapter": "011_孝景本纪", "para": "6.2", "seq": 1, "text": "天子为诛晁错，遣袁盎谕告，不止，遂西围梁。", "len": 21}
{"sid": "011_孝景本纪.6.3.s1", "chapter": "011_孝景本纪", "para": "6.3", "seq": 1, "text": "上乃遣大将军窦婴、太尉周亚夫将兵诛之。", "len": 19}
{"sid": "011_孝景本纪.7.1.s1", "chapter": "011_孝景本纪", "para": "7.1", "seq": 1, "text": "六月乙亥。", "len": 5}
{"sid": "011_孝景本纪.7.1.s2", "chapter": "011_孝景本纪", "para": "7.1", "seq": 2, "text": "赦亡军及楚元王子艺等与谋反者。", "len": 15}
{"sid": "011_孝景本纪.7.2.s1", "chapter": "011_孝景本纪", "para": "7.2", "seq": 1, "text": "封大将军窦婴为魏其侯。", "len": 11}
{"sid": "011_孝景本纪.7.3.s1", "chapter": "011_孝景本纪", "para": "7.3", "seq": 1, "text": "立楚元王子平陆侯礼为楚王。", "len": 13}
{"sid": "011_孝景本纪.8.1.s1", "chapter": "011_孝景本纪", "para": "8.1", "seq": 1, "text": "立皇子端为胶西王，子胜为中山王。", "len": 16}
{"sid": "011_孝景本纪.8.2.s1", "chapter": "011_孝景本纪", "para": "8.2", "seq": 1, "text": "徙济北王志为菑川王，淮阳王馀为鲁王，汝南王非为江都王。", "len": 27}
{"sid": "011_孝景本纪.8.3.s1", "chapter": "011_孝景本纪", "para": "8.3", "seq": 1, "text": "齐王将庐、燕王嘉皆薨。", "len": 11}
{"sid": "011_孝景本纪.9.1.s1", "chapter": "011_孝景本纪", "para": "9.1", "seq": 1, "text": "四年夏，立太子。", "len": 8}
{"sid": "011_孝景本纪.9.2.s1", "chapter": "011_孝景本纪", "para": "9.2", "seq": 1, "text": "立皇子彻为胶东王。", "len": 9}
{"sid": "011_孝景本纪.9.3.s1", "chapter": "011_孝景本纪", "para": "9.3", "seq": 1, "text": "六月甲戌，赦天下。", "len": 9}
{"sid": "011_孝景本纪.9.4.s1", "chapter": "011_孝景本纪", "para": "9.4", "seq": 1, "text": "後九月，更以阳为阳陵。", "len": 11}
{"sid": "011_孝景本纪.9.5.s1", "chapter": "011_孝景本纪", "para": "9.5", "seq": 1, "text": "复置津关，用传出入。", "len": 10}
{"sid": "011_孝景本纪.9.6.s1", "chapter": "011_孝景本纪", "para": "9.6", "seq": 1, "text": "冬，以赵国为邯郸郡。", "len": 10}
{"sid": "011_孝景本纪.10.1.s1", "chapter": "011_孝景本纪", "para": "10.1", "seq": 1, "text": "五年三月，作阳陵、渭桥。", "len": 12}
{"sid": "011_孝景本纪.10.2.s1", "chapter": "011_孝景本纪", "para": "10.2", "seq": 1, "text": "五月，募徙阳陵，予钱二十万。", "len": 14}
{"sid": "011_孝景本纪.10.3.s1", "chapter": "011_孝景本纪", "para": "10.3", "seq": 1, "text": "江都大暴风从西方来，坏城十二丈。", "len": 16}
{"sid": "011_孝景本纪.10.4.s1", "chapter": "011_孝景本纪", "para": "10.4", "seq": 1, "text": "丁卯，封长公主子蟜为隆虑侯。", "len": 14}
{"sid": "011_孝景本纪.10.5.s1", "chapter": "011_孝景本纪", "para": "10.5", "seq": 1, "text": "徙广川王为赵王。", "len": 8}
{"sid": "011_孝景本纪.11.1.s1", "chapter": "011_孝景本纪", "para": "11.1", "seq": 1, "text": "六年春，封中尉绾为建陵侯，江都丞相嘉为建平侯，陇西太守浑邪为平曲侯，赵丞相嘉为江陵侯，故将军布为鄃侯。", "len": 51}
{"sid": "011_孝景本纪.11.2.s1", "chapter": "011_孝景本纪", "para": "11.2", "seq": 1, "text": "梁楚二王皆薨。", "len": 7}
{"sid": "011_孝景本纪.11.3.s1", "chapter": "011_孝景本纪", "para": "11.3", "seq": 1, "text": "後九月，伐驰道树，殖兰池。", "len": 13}
{"sid": "011_孝景本纪.12.1.s1", "chapter": "011_孝景本纪", "para": "12.1", "seq": 1, "text": "七年冬，废栗太子为临江王。", "len": 13}
{"sid": "011_孝景本纪.12.2.s1", "chapter": "011_孝景本纪", "para": "12.2", "seq": 1, "text": "十月晦，日有食之。", "len": 9}
{"sid": "011_孝景本纪.12.3.s1", "chapter": "011_孝景本纪", "para": "12.3", "seq": 1, "text": "春，免徒隶作阳陵者。", "len": 10}
{"sid": "011_孝景本纪.12.4.s1", "chapter": "011_孝景本纪", "para": "12.4", "seq": 1, "text": "丞相青免。", "len": 5}
{"sid": "011_孝景本纪.12.5.s1", "chapter": "011_孝景本纪", "para": "12.5", "seq": 1, "text": "二月乙巳，以太尉条侯周亚夫为丞相。", "len": 17}
{"sid": "011_孝景本纪.13.1.s1", "chapter": "011_孝景本纪", "para": "13.1", "seq": 1, "text": "四月乙巳，立胶东王太后为皇后。", "len": 15}
{"sid": "011_孝景本纪.13.2.s1", "chapter": "011_孝景本纪", "para": "13.2", "seq": 1, "text": "丁巳，立胶东王为太子。", "len": 11}
{"sid": "011_孝景本纪.13.2.s2", "chapter": "011_孝景本纪", "para": "13.2", "seq": 2, "text": "名彻。", "len": 3}
{"sid": "011_孝景本纪.14.1.s1", "chapter": "011_孝景本纪", "para": "14.1", "seq": 1, "text": "中元年，封故御史大夫周苛孙平为绳侯，故御史大夫周昌左车为安阳侯，", "len": 32}
{"sid": "011_孝景本纪.14.2.s1", "chapter": "011_孝景本纪", "para": "14.2", "seq": 1, "text": "四月乙巳，赦天下，赐爵一级。", "len": 14}
{"sid": "011_孝景本纪.14.2.s2", "chapter": "011_孝景本纪", "para": "14.2", "seq": 2, "text": "除禁锢。", "len": 4}
{"sid": "011_孝景本纪.14.3.s1", "chapter": "011_孝景本纪", "para": "14.3", "seq": 1, "text": "地动。", "len": 3}
{"sid": "011_孝景本纪.14.3.s2", "chapter": "011_孝景本纪", "para": "14.3", "seq": 2, "text": "衡山、原都雨雹，大者尺八寸。", "len": 14}
{"sid": "011_孝景本纪.15.1.s1", "chapter": "011_孝景本纪", "para": "15.1", "seq": 1, "text": "中二年二月，匈奴入燕，遂不和亲。", "len": 16}
{"sid": "011_孝景本纪.15.2.s1", "chapter": "011_孝景本纪", "para": "15.2", "seq": 1, "text": "三月，召临江王来。", "len": 9}
{"sid": "011_孝景本纪.15.2.s2", "chapter": "011_孝景本纪", "para": "15.2", "seq": 2, "text": "即死中尉府中。", "len": 7}
{"sid": "011_孝景本纪.15.3.s1", "chapter": "011_孝景本纪", "para": "15.3", "seq": 1, "text": "夏，立皇子越为广川王，子寄为胶东王。", "len": 18}
{"sid": "011_孝景本纪.15.3.s2", "chapter": "011_孝景本纪", "para": "15.3", "seq": 2, "text": "封四侯。", "len": 4}
{"sid": "011_孝景本纪.15.4.s1", "chapter": "011_孝景本纪", "para": "15.4", "seq": 1, "text": "九月甲戌，日食。", "len": 8}
{"sid": "011_孝景本纪.16.1.s1", "chapter": "011_孝景本纪", "para": "16.1", "seq": 1, "text": "中三年冬，罢诸侯御史中丞。", "len": 13}
{"sid": "011_孝景本纪.16.2.s1", "chapter": "011_孝景本纪", "para": "16.2", "seq": 1, "text": "春，匈奴王二人率其徒来降，皆封为列侯。", "len": 19}
{"sid": "011_孝景本纪.16.3.s1", "chapter": "011_孝景本纪", "para": "16.3", "seq": 1, "text": "立皇子方乘为清河王。", "len": 10}
{"sid": "011_孝景本纪.16.4.s1", "chapter": "011_孝景本纪", "para": "16.4", "seq": 1, "text": "三月，彗星出西北。", "len": 9}
{"sid": "011_孝景本纪.16.5.s1", "chapter": "011_孝景本纪", "para": "16.5", "seq": 1, "text": "丞相周亚夫免，以御史大夫桃侯刘舍为丞相。", "len": 20}
{"sid": "011_孝景本纪.16.6.s1", "chapter": "011_孝景本纪", "para": "16.6", "seq": 1, "text": "四月，地动。", "len": 6}
{"sid": "011_孝景本纪.16.7.s1", "chapter": "011_孝景本纪", "para": "16.7", "seq": 1, "text": "九月戊戌晦，日食。", "len": 9}
{"sid": "011_孝景本纪.16.7.s2", "chapter": "011_孝景本纪", "para": "16.7", "seq": 2, "text": "军东都门外。", "len": 6}
{"sid": "011_孝景本纪.17.1.s1", "chapter": "011_孝景本纪", "para": "17.1", "seq": 1, "text": "中四年三月，置德阳宫。", "len": 11}
{"sid": "011_孝景本纪.17.2.s1", "chapter": "011_孝景本纪", "para": "17.2", "seq": 1, "text": "大蝗。", "len": 3}
{"sid": "011_孝景本纪.17.3.s1", "chapter": "011_孝景本纪", "para": "17.3", "seq": 1, "text": "秋，赦徒作阳陵者。", "len": 9}
{"sid": "011_孝景本纪.18.1.s1", "chapter": "011_孝景本纪", "para": "18.1", "seq": 1, "text": "中五年夏，立皇子舜为常山王。", "len": 14}
{"sid": "011_孝景本纪.18.1.s2", "chapter": "011_孝景本纪", "para": "18.1", "seq": 2, "text": "封十侯。", "len": 4}
{"sid": "011_孝景本纪.18.2.s1", "chapter": "011_孝景本纪", "para": "18.2", "seq": 1, "text": "六月丁巳，赦天下，赐爵一级。", "len": 14}
{"sid": "011_孝景本纪.18.3.s1", "chapter": "011_孝景本纪", "para": "18.3", "seq": 1, "text": "天下大潦。", "len": 5}
{"sid": "011_孝景本纪.18.4.s1", "chapter": "011_孝景本纪", "para": "18.4", "seq": 1, "text": "更命诸侯丞相曰相。", "len": 9}
{"sid": "011_孝景本纪.18.5.s1", "chapter": "011_孝景本纪", "para": "18.5", "seq": 1, "text": "秋，地动。", "len": 5}
{"sid": "011_孝景本纪.19.1.s1", "chapter": "011_孝景本纪", "para": "19.1", "seq": 1, "text": "中六年二月己卯，行幸雍，郊见五帝。", "len": 17}
{"sid": "011_孝景本纪.19.2.s1", "chapter": "011_孝景本纪", "para": "19.2", "seq": 1, "text": "三月，雨雹。", "len": 6}
{"sid": "011_孝景本纪.19.3.s1", "chapter": "011_孝景本纪", "para": "19.3", "seq": 1, "text": "四月，梁孝王、城阳共王、汝南王皆薨。", "len": 18}
{"sid": "011_孝景本纪.20.1.s1", "chapter": "011_孝景本纪", "para": "20.1", "seq": 1, "text": "立梁孝王子明为济川王，子彭离为济东王，子定为山阳王，子不识为济阴王。", "len": 34}
{"sid": "011_孝景本纪.20.1.s2", "chapter": "011_孝景本纪", "para": "20.1", "seq": 2, "text": "梁分为五。", "len": 5}
{"sid": "011_孝景本纪.20.2.s1", "chapter": "011_孝景本纪", "para": "20.2", "seq": 1, "text": "封四侯。", "len": 4}
{"sid": "011_孝景本纪.21.1.s1", "chapter": "011_孝景本纪", "para": "21.1", "seq": 1, "text": "更命廷尉为大理，将作少府为将作大匠，主爵中尉为都尉，长信詹事为长信少府，将行为大长秋，大行为行人，奉常为太常，典客为大行，治粟内史为大农。", "len": 69}
{"sid": "011_孝景本纪.21.2.s1", "chapter": "011_孝景本纪", "para": "21.2", "seq": 1, "text": "以大内为二千石，置左右内官，属大内。", "len": 18}
{"sid": "011_孝景本纪.21.3.s1", "chapter": "011_孝景本纪", "para": "21.3", "seq": 1, "text": "七月辛亥，日食。", "len": 8}
{"sid": "011_孝景本纪.21.4.s1", "chapter": "011_孝景本纪", "para": "21.4", "seq": 1, "text": "八月，匈奴入上郡。", "len": 9}
{"sid": "011_孝景本纪.22.1.s1", "chapter": "011_孝景本纪", "para": "22.1", "seq": 1, "text": "後元年冬，更命中大夫令为卫尉。", "len": 15}
{"sid": "011_孝景本纪.22.2.s1", "chapter": "011_孝景本纪", "para": "22.2", "seq": 1, "text": "三月丁酉，赦天下，赐爵一级，中二千石、诸侯相爵右庶长。", "len": 27}
{"sid": "011_孝景本纪.22.3.s1", "chapter": "011_孝景本纪", "para": "22.3", "seq": 1, "text": "四月，大酺。", "len": 6}
{"sid": "011_孝景本纪.22.4.s1", "chapter": "011_孝景本纪", "para": "22.4", "seq": 1, "text": "五月丙戌，地动，其蚤食时复动。", "len": 15}
{"sid": "011_孝景本纪.22.5.s1", "chapter": "011_孝景本纪", "para": "22.5", "seq": 1, "text": "上庸地动二十二日，坏城垣。", "len": 13}
{"sid": "011_孝景本纪.22.6.s1", "chapter": "011_孝景本纪", "para": "22.6", "seq": 1, "text": "七月乙巳，日食。", "len": 8}
{"sid": "011_孝景本纪.22.7.s1", "chapter": "011_孝景本纪", "para": "22.7", "seq": 1, "text": "丞相刘舍免。", "len": 6}
{"sid": "011_孝景本纪.22.8.s1", "chapter": "011_孝景本纪", "para": "22.8", "seq": 1, "text": "八月壬辰，以御史大夫绾为丞相，封建陵侯。", "len": 20}
{"sid": "011_孝景本纪.23.1.s1", "chapter": "011_孝景本纪", "para": "23.1", "seq": 1, "text": "後二年正月，地一日三动。", "len": 12}
{"sid": "011_孝景本纪.23.2.s1", "chapter": "011_孝景本纪", "para": "23.2", "seq": 1, "text": "郅将军击匈奴。", "len": 7}
{"sid": "011_孝景本纪.23.2.s2", "chapter": "011_孝景本纪", "para": "23.2", "seq": 2, "text": "酺五日。", "len": 4}
{"sid": "011_孝景本纪.23.3.s1", "chapter": "011_孝景本纪", "para": "23.3", "seq": 1, "text": "令内史郡不得食马粟，没入县官。", "len": 15}
{"sid": "011_孝景本纪.23.4.s1", "chapter": "011_孝景本纪", "para": "23.4", "seq": 1, "text": "令徒隶衣七布。", "len": 7}
{"sid": "011_孝景本纪.23.4.s2", "chapter": "011_孝景本纪", "para": "23.4", "seq": 2, "text": "止马舂。", "len": 4}
{"sid": "011_孝景本纪.24.1.s1", "chapter": "011_孝景本纪", "para": "24.1", "seq": 1, "text": "为岁不登，禁天下食不造岁。", "len": 13}
{"sid": "011_孝景本纪.24.2.s1", "chapter": "011_孝景本纪", "para": "24.2", "seq": 1, "text": "省列侯遣之国。", "len": 7}
{"sid": "011_孝景本纪.24.3.s1", "chapter": "011_孝景本纪", "para": "24.3", "seq": 1, "text": "三月，匈奴入雁门。", "len": 9}
{"sid": "011_孝景本纪.24.4.s1", "chapter": "011_孝景本纪", "para": "24.4", "seq": 1, "text": "十月，租长陵田。", "len": 8}
{"sid": "011_孝景本纪.24.4.s2", "chapter": "011_孝景本纪", "para": "24.4", "seq": 2, "text": "大旱。", "len": 3}
{"sid": "011_孝景本纪.24.5.s1", "chapter": "011_孝景本纪", "para": "24.5", "seq": 1, "text": "衡山国、河东、云中郡民疫。", "len": 13}
{"sid": "011_孝景本纪.25.1.s1", "chapter": "011_孝景本纪", "para": "25.1", "seq": 1, "text": "後三年十月，日月皆赤五日。", "len": 13}
{"sid": "011_孝景本纪.25.2.s1", "chapter": "011_孝景本纪", "para": "25.2", "seq": 1, "text": "十二月晦，雷。", "len": 7}
{"sid": "011_孝景本纪.25.2.s2", "chapter": "011_孝景本纪", "para": "25.2", "seq": 2, "text": "日如紫。", "len": 4}
{"sid": "011_孝景本纪.25.3.s1", "chapter": "011_孝景本纪", "para": "25.3", "seq": 1, "text": "五星逆行守太微。", "len": 8}
{"sid": "011_孝景本纪.25.4.s1", "chapter": "011_孝景本纪", "para": "25.4", "seq": 1, "text": "月贯天廷中。", "len": 6}
{"sid": "011_孝景本纪.26.1.s1", "chapter": "011_孝景本纪", "para": "26.1", "seq": 1, "text": "正月甲寅，皇太子冠。", "len": 10}
{"sid": "011_孝景本纪.26.2.s1", "chapter": "011_孝景本纪", "para": "26.2", "seq": 1, "text": "甲子，孝景皇帝崩。", "len": 9}
{"sid": "011_孝景本纪.27.1.s1", "chapter": "011_孝景本纪", "para": "27.1", "seq": 1, "text": "遗诏赐诸侯王以下至民为父後爵一级，天下户百钱。", "len": 23}
{"sid": "011_孝景本纪.27.2.s1", "chapter": "011_孝景本纪", "para": "27.2", "seq": 1, "text": "出宫人归其家，复无所与。", "len": 12}
{"sid": "011_孝景本纪.27.3.s1", "chapter": "011_孝景本纪", "para": "27.3", "seq": 1, "text": "太子即位，是为孝武皇帝。", "len": 12}
{"sid": "011_孝景本纪.28.1.s1", "chapter": "011_孝景本纪", "para": "28.1", "seq": 1, "text": "三月，封皇太后弟蚡为武安侯，弟胜为周阳侯。", "len": 21}
{"sid": "011_孝景本纪.28.2.s1", "chapter": "011_孝景本纪", "para": "28.2", "seq": 1, "text": "置阳陵。", "len": 4}
{"sid": "011_孝景本纪.28.2.s2", "chapter": "011_孝景本纪", "para": "28.2", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "011_孝景本纪.29.1.s1", "chapter": "011_孝景本纪", "para": "29.1", "seq": 1, "text": "太史公曰：汉兴，孝文施大德，天下怀安，至孝景，不复忧异姓，而晁错刻削诸侯，遂使七国俱起，合从而西乡，以诸侯太盛，而错为之不以渐也。", "len": 65}
{"sid": "011_孝景本纪.29.2.s1", "chapter": "011_孝景本纪", "para": "29.2", "seq": 1, "text": "及主父偃言之，而诸侯以弱，卒以安。", "len": 17}
{"sid": "011_孝景本纪.29.2.s2", "chapter": "011_孝景本纪", "para": "29.2", "seq": 2, "text": "安危之机，岂不以谋哉？", "len": 11}
{"sid": "011_孝景本纪.29.2.s3", "chapter": "011_孝景本纪", "para": "29.2", "seq": 3, "text": "::: ::: 赞 景帝即位，因脩静默。", "len": 20}
{"sid": "011_孝景本纪.29.2.s4", "chapter": "011_孝景本纪", "para": "29.2", "seq": 4, "text": "勉人於农，率下以德。", "len": 10}
{"sid": "011_孝景本纪.29.2.s5", "chapter": "011_孝景本纪", "para": "29.2", "seq": 5, "text": "制度斯创，礼法可则。", "len": 10}
{"sid": "011_孝景本纪.29.2.s6", "chapter": "011_孝景本纪", "para": "29.2", "seq": 6, "text": "一朝吴楚，乍起凶慝。", "len": 10}
{"sid": "011_孝景本纪.29.2.s7", "chapter": "011_孝景本纪", "para": "29.2", "seq": 7, "text": "提局成衅，拒轮致惑。", "len": 10}
{"sid": "011_孝景本纪.29.2.s8", "chapter": "011_孝景本纪", "para": "29.2", "seq": 8, "text": "晁错虽诛，梁城未克。", "len": 10}
{"sid": "011_孝景本纪.29.2.s9", "chapter": "011_孝景本纪", "para": "29.2", "seq": 9, "text": "条侯出将，追奔逐北。", "len": 10}
{"sid": "011_孝景本纪.29.2.s10", "chapter": "011_孝景本纪", "para": "29.2", "seq": 10, "text": "坐见枭黥，立翦牟贼。", "len": 10}
{"sid": "011_孝景本纪.29.2.s11", "chapter": "011_孝景本纪", "para": "29.2", "seq": 11, "text": "如何太尉，後卒下狱。", "len": 10}
{"sid": "011_孝景本纪.29.2.s12", "chapter": "011_孝景本纪", "para": "29.2", "seq": 12, "text": "惜哉明君，斯功不录！", "len": 10}
{"sid": "011_孝景本纪.29.2.s13", "chapter": "011_孝景本纪", "para": "29.2", "seq": 13, "text": ":::", "len": 3}
