{"sid": "060_三王世家.1.s1", "chapter": "060_三王世家", "para": "1", "seq": 1, "text": "“大司马臣去病昧死再拜上疏皇帝陛下：陛下过听，使臣去病待罪行间。", "len": 32}
{"sid": "060_三王世家.1.s2", "chapter": "060_三王世家", "para": "1", "seq": 2, "text": "宜专边塞之思虑，暴骸中野无以报，乃敢惟他议以干用事者，诚见陛下忧劳天下，哀怜百姓以自忘，亏膳贬乐，损郎员。", "len": 53}
{"sid": "060_三王世家.1.s3", "chapter": "060_三王世家", "para": "1", "seq": 3, "text": "皇子赖天，能胜衣趋拜，至今无号位师傅官。", "len": 20}
{"sid": "060_三王世家.1.s4", "chapter": "060_三王世家", "para": "1", "seq": 4, "text": "陛下恭让不恤，群臣私望，不敢越职而言。", "len": 19}
{"sid": "060_三王世家.1.s5", "chapter": "060_三王世家", "para": "1", "seq": 5, "text": "臣窃不胜犬马心，昧死原陛下诏有司，因盛夏吉时定皇子位。", "len": 27}
{"sid": "060_三王世家.1.s6", "chapter": "060_三王世家", "para": "1", "seq": 6, "text": "唯陛下幸察。", "len": 6}
{"sid": "060_三王世家.1.s7", "chapter": "060_三王世家", "para": "1", "seq": 7, "text": "臣去病昧死再拜以闻皇帝陛下。", "len": 14}
{"sid": "060_三王世家.1.s8", "chapter": "060_三王世家", "para": "1", "seq": 8, "text": "” 三月乙亥，御史臣光守尚书令奏未央宫。", "len": 20}
{"sid": "060_三王世家.1.s9", "chapter": "060_三王世家", "para": "1", "seq": 9, "text": "制曰：“下御史。”", "len": 9}
{"sid": "060_三王世家.2.s1", "chapter": "060_三王世家", "para": "2", "seq": 1, "text": "六年三月戊申朔，乙亥，御史臣光守尚书令、丞非，下御史书到，言：“丞相臣青翟、御史大夫臣汤、太常臣充、大行令臣息、太子少傅臣安行宗正事昧死上言：大司马去病上疏曰：‘陛下过听，使臣去病待罪行间。", "len": 95}
{"sid": "060_三王世家.2.s2", "chapter": "060_三王世家", "para": "2", "seq": 2, "text": "宜专边塞之思虑，暴骸中野无以报，乃敢惟他议以干用事者，诚见陛下忧劳天下，哀怜百姓以自忘，亏膳贬乐，损郎员。", "len": 53}
{"sid": "060_三王世家.2.s3", "chapter": "060_三王世家", "para": "2", "seq": 3, "text": "皇子赖天，能胜衣趋拜，至今无号位师傅官。", "len": 20}
{"sid": "060_三王世家.2.s4", "chapter": "060_三王世家", "para": "2", "seq": 4, "text": "陛下恭让不恤，群臣私望，不敢越职而言。", "len": 19}
{"sid": "060_三王世家.2.s5", "chapter": "060_三王世家", "para": "2", "seq": 5, "text": "臣窃不胜犬马心，昧死原陛下诏有司，因盛夏吉时定皇子位。", "len": 27}
{"sid": "060_三王世家.2.s6", "chapter": "060_三王世家", "para": "2", "seq": 6, "text": "唯原陛下幸察。", "len": 7}
{"sid": "060_三王世家.2.s7", "chapter": "060_三王世家", "para": "2", "seq": 7, "text": "’制曰‘下御史’。", "len": 9}
{"sid": "060_三王世家.2.s8", "chapter": "060_三王世家", "para": "2", "seq": 8, "text": "臣谨与中二千石、二千石臣贺等议：古者裂地立国，并建诸侯以承天于，所以尊宗庙重社稷也。", "len": 42}
{"sid": "060_三王世家.2.s9", "chapter": "060_三王世家", "para": "2", "seq": 9, "text": "今臣去病上疏，不忘其职，因以宣恩，乃道天子卑让自贬以劳天下，虑皇子未有号位。", "len": 38}
{"sid": "060_三王世家.2.s10", "chapter": "060_三王世家", "para": "2", "seq": 10, "text": "臣青翟、臣汤等宜奉义遵职，愚憧而不逮事。", "len": 20}
{"sid": "060_三王世家.2.s11", "chapter": "060_三王世家", "para": "2", "seq": 11, "text": "方今盛夏吉时，臣青翟、臣汤等昧死请立皇子臣闳、臣旦、臣胥为诸侯王。", "len": 33}
{"sid": "060_三王世家.2.s12", "chapter": "060_三王世家", "para": "2", "seq": 12, "text": "昧死请所立国名。”", "len": 9}
{"sid": "060_三王世家.3.s1", "chapter": "060_三王世家", "para": "3", "seq": 1, "text": "制曰：“盖闻周封八百，姬姓并列，或子、男、附庸。", "len": 24}
{"sid": "060_三王世家.3.s2", "chapter": "060_三王世家", "para": "3", "seq": 2, "text": "礼‘支子不祭’。", "len": 8}
{"sid": "060_三王世家.3.s3", "chapter": "060_三王世家", "para": "3", "seq": 3, "text": "云并建诸侯所以重社稷，朕无闻焉。", "len": 16}
{"sid": "060_三王世家.3.s4", "chapter": "060_三王世家", "para": "3", "seq": 4, "text": "且天非为君生民也。", "len": 9}
{"sid": "060_三王世家.3.s5", "chapter": "060_三王世家", "para": "3", "seq": 5, "text": "朕之不德，海内未洽，乃以未教成者彊君连城，即股肱何劝？", "len": 27}
{"sid": "060_三王世家.3.s6", "chapter": "060_三王世家", "para": "3", "seq": 6, "text": "其更议以列侯家之。”", "len": 10}
{"sid": "060_三王世家.4.s1", "chapter": "060_三王世家", "para": "4", "seq": 1, "text": "三月丙子，奏未央宫。", "len": 10}
{"sid": "060_三王世家.4.s2", "chapter": "060_三王世家", "para": "4", "seq": 2, "text": "“丞相臣青翟、御史大夫臣汤昧死言：臣谨与列侯臣婴齐、中二千石二千石臣贺、谏大夫博士臣安等议曰：伏闻周封八百，姬姓并列，奉承天子。", "len": 64}
{"sid": "060_三王世家.4.s3", "chapter": "060_三王世家", "para": "4", "seq": 3, "text": "康叔以祖考显，而伯禽以周公立，咸为建国诸侯，以相傅为辅。", "len": 28}
{"sid": "060_三王世家.4.s4", "chapter": "060_三王世家", "para": "4", "seq": 4, "text": "百官奉宪，各遵其职，而国统备矣。", "len": 16}
{"sid": "060_三王世家.4.s5", "chapter": "060_三王世家", "para": "4", "seq": 5, "text": "窃以为并建诸侯所以重社稷者，四海诸侯各以其职奉贡祭。", "len": 26}
{"sid": "060_三王世家.4.s6", "chapter": "060_三王世家", "para": "4", "seq": 6, "text": "支子不得奉祭宗祖，礼也。", "len": 12}
{"sid": "060_三王世家.4.s7", "chapter": "060_三王世家", "para": "4", "seq": 7, "text": "封建使守籓国，帝王所以扶德施化。", "len": 16}
{"sid": "060_三王世家.4.s8", "chapter": "060_三王世家", "para": "4", "seq": 8, "text": "陛下奉承天统，明开圣绪，尊贤显功，兴灭继绝。", "len": 22}
{"sid": "060_三王世家.4.s9", "chapter": "060_三王世家", "para": "4", "seq": 9, "text": "续萧文终之後于酂，襃厉群臣平津侯等。", "len": 18}
{"sid": "060_三王世家.4.s10", "chapter": "060_三王世家", "para": "4", "seq": 10, "text": "昭六亲之序，明天施之属，使诸侯王封君得推私恩分子弟户邑，锡号尊建百有馀国。", "len": 37}
{"sid": "060_三王世家.4.s11", "chapter": "060_三王世家", "para": "4", "seq": 11, "text": "而家皇子为列侯，则尊卑相逾，列位失序，不可以垂统於万世。", "len": 28}
{"sid": "060_三王世家.4.s12", "chapter": "060_三王世家", "para": "4", "seq": 12, "text": "臣请立臣闳、臣旦、臣胥为诸侯王。", "len": 16}
{"sid": "060_三王世家.4.s13", "chapter": "060_三王世家", "para": "4", "seq": 13, "text": "” 三月丙子，奏未央宫。", "len": 12}
{"sid": "060_三王世家.5.s1", "chapter": "060_三王世家", "para": "5", "seq": 1, "text": "制曰：“康叔亲属有十而独尊者，襃有德也。", "len": 20}
{"sid": "060_三王世家.5.s2", "chapter": "060_三王世家", "para": "5", "seq": 2, "text": "周公祭天命郊，故鲁有白牡、骍刚之牲。", "len": 18}
{"sid": "060_三王世家.5.s3", "chapter": "060_三王世家", "para": "5", "seq": 3, "text": "群公不毛，贤不肖差也。", "len": 11}
{"sid": "060_三王世家.5.s4", "chapter": "060_三王世家", "para": "5", "seq": 4, "text": "‘高山仰之，景行乡之’，朕甚慕焉。", "len": 17}
{"sid": "060_三王世家.5.s5", "chapter": "060_三王世家", "para": "5", "seq": 5, "text": "所以抑未成，家以列侯可。”", "len": 13}
{"sid": "060_三王世家.6.s1", "chapter": "060_三王世家", "para": "6", "seq": 1, "text": "四月戊寅，奏未央宫。", "len": 10}
{"sid": "060_三王世家.6.s2", "chapter": "060_三王世家", "para": "6", "seq": 2, "text": "“丞相臣青翟、御史大夫臣汤昧死言：臣青翟等与列侯、吏二千石、谏大夫、博士臣庆等议：昧死奏请立皇子为诸侯王。", "len": 53}
{"sid": "060_三王世家.6.s3", "chapter": "060_三王世家", "para": "6", "seq": 3, "text": "制曰：‘康叔亲属有十而独尊者，襃有德也。", "len": 20}
{"sid": "060_三王世家.6.s4", "chapter": "060_三王世家", "para": "6", "seq": 4, "text": "周公祭天命郊，故鲁有白牡、骍刚之牲。", "len": 18}
{"sid": "060_三王世家.6.s5", "chapter": "060_三王世家", "para": "6", "seq": 5, "text": "群公不毛，贤不肖差也。", "len": 11}
{"sid": "060_三王世家.6.s6", "chapter": "060_三王世家", "para": "6", "seq": 6, "text": "“高山仰之，景行乡之”，朕甚慕焉。", "len": 17}
{"sid": "060_三王世家.6.s7", "chapter": "060_三王世家", "para": "6", "seq": 7, "text": "所以抑未成，家以列侯可。", "len": 12}
{"sid": "060_三王世家.6.s8", "chapter": "060_三王世家", "para": "6", "seq": 8, "text": "’臣青翟、臣汤、博士臣将行等伏闻康叔亲属有十，武王继体，周公辅成王，其八人皆以祖考之尊建为大国。", "len": 48}
{"sid": "060_三王世家.6.s9", "chapter": "060_三王世家", "para": "6", "seq": 9, "text": "康叔之年幼，周公在三公之位，而伯禽据国於鲁，盖爵命之时，未至成人。", "len": 33}
{"sid": "060_三王世家.6.s10", "chapter": "060_三王世家", "para": "6", "seq": 10, "text": "康叔後扞禄父之难，伯禽殄淮夷之乱。", "len": 17}
{"sid": "060_三王世家.6.s11", "chapter": "060_三王世家", "para": "6", "seq": 11, "text": "昔五帝异制，周爵五等，春秋三等，皆因时而序尊卑。", "len": 24}
{"sid": "060_三王世家.6.s12", "chapter": "060_三王世家", "para": "6", "seq": 12, "text": "高皇帝拨乱世反诸正，昭至德，定海内，封建诸侯，爵位二等。", "len": 28}
{"sid": "060_三王世家.6.s13", "chapter": "060_三王世家", "para": "6", "seq": 13, "text": "皇子或在襁褓而立为诸侯王，奉承天子，为万世法则，不可易。", "len": 28}
{"sid": "060_三王世家.6.s14", "chapter": "060_三王世家", "para": "6", "seq": 14, "text": "陛下躬亲仁义，体行圣德，表里文武。", "len": 17}
{"sid": "060_三王世家.6.s15", "chapter": "060_三王世家", "para": "6", "seq": 15, "text": "显慈孝之行，广贤能之路。", "len": 12}
{"sid": "060_三王世家.6.s16", "chapter": "060_三王世家", "para": "6", "seq": 16, "text": "内襃有德，外讨彊暴。", "len": 10}
{"sid": "060_三王世家.6.s17", "chapter": "060_三王世家", "para": "6", "seq": 17, "text": "极临北海，西月氏，匈奴、西域，举国奉师。", "len": 20}
{"sid": "060_三王世家.6.s18", "chapter": "060_三王世家", "para": "6", "seq": 18, "text": "舆械之费，不赋於民。", "len": 10}
{"sid": "060_三王世家.6.s19", "chapter": "060_三王世家", "para": "6", "seq": 19, "text": "虚御府之藏以赏元戎，开禁仓以振贫穷，减戍卒之半。", "len": 24}
{"sid": "060_三王世家.6.s20", "chapter": "060_三王世家", "para": "6", "seq": 20, "text": "百蛮之君，靡不乡风，承流称意。", "len": 15}
{"sid": "060_三王世家.6.s21", "chapter": "060_三王世家", "para": "6", "seq": 21, "text": "远方殊俗，重译而朝，泽及方外。", "len": 15}
{"sid": "060_三王世家.6.s22", "chapter": "060_三王世家", "para": "6", "seq": 22, "text": "故珍兽至，嘉穀兴，天应甚彰。", "len": 14}
{"sid": "060_三王世家.6.s23", "chapter": "060_三王世家", "para": "6", "seq": 23, "text": "今诸侯支子封至诸侯王，而家皇子为列侯，臣青翟、臣汤等窃伏孰计之，皆以为尊卑失序，使天下失望，不可。", "len": 49}
{"sid": "060_三王世家.6.s24", "chapter": "060_三王世家", "para": "6", "seq": 24, "text": "臣请立臣闳、臣旦、臣胥为诸侯王。", "len": 16}
{"sid": "060_三王世家.6.s25", "chapter": "060_三王世家", "para": "6", "seq": 25, "text": "” 四月癸未，奏未央宫，留中不下。", "len": 17}
{"sid": "060_三王世家.7.s1", "chapter": "060_三王世家", "para": "7", "seq": 1, "text": "“丞相臣青翟、太仆臣贺、行御史大夫事太常臣充、太子少傅臣安行宗正事昧死言：臣青翟等前奏大司马臣去病上疏言，皇子未有号位，臣谨与御史大夫臣汤、中二千石、二千石、谏大夫、博士臣庆等昧死请立皇子臣闳等为诸侯王。", "len": 102}
{"sid": "060_三王世家.7.s2", "chapter": "060_三王世家", "para": "7", "seq": 2, "text": "陛下让文武，躬自切，及皇子未教。", "len": 16}
{"sid": "060_三王世家.7.s3", "chapter": "060_三王世家", "para": "7", "seq": 3, "text": "群臣之议，儒者称其术，或誖其心。", "len": 16}
{"sid": "060_三王世家.7.s4", "chapter": "060_三王世家", "para": "7", "seq": 4, "text": "陛下固辞弗许，家皇子为列侯。", "len": 14}
{"sid": "060_三王世家.7.s5", "chapter": "060_三王世家", "para": "7", "seq": 5, "text": "臣青翟等窃与列侯臣寿成等二十七人议，皆曰以为尊卑失序。", "len": 27}
{"sid": "060_三王世家.7.s6", "chapter": "060_三王世家", "para": "7", "seq": 6, "text": "高皇帝建天下，为汉太祖，王子孙，广支辅。", "len": 20}
{"sid": "060_三王世家.7.s7", "chapter": "060_三王世家", "para": "7", "seq": 7, "text": "先帝法则弗改，所以宣至尊也。", "len": 14}
{"sid": "060_三王世家.7.s8", "chapter": "060_三王世家", "para": "7", "seq": 8, "text": "臣请令史官择吉日，具礼仪上，御史奏舆地图，他皆如前故事。", "len": 28}
{"sid": "060_三王世家.7.s9", "chapter": "060_三王世家", "para": "7", "seq": 9, "text": "” 制曰：“可。”", "len": 9}
{"sid": "060_三王世家.8.s1", "chapter": "060_三王世家", "para": "8", "seq": 1, "text": "四月丙申，奏未央宫。", "len": 10}
{"sid": "060_三王世家.8.s2", "chapter": "060_三王世家", "para": "8", "seq": 2, "text": "“太仆臣贺行御史大夫事昧死言：太常臣充言卜入四月二十八日乙巳，可立诸侯王。", "len": 37}
{"sid": "060_三王世家.8.s3", "chapter": "060_三王世家", "para": "8", "seq": 3, "text": "臣昧死奏舆地图，请所立国名。", "len": 14}
{"sid": "060_三王世家.8.s4", "chapter": "060_三王世家", "para": "8", "seq": 4, "text": "礼仪别奏。", "len": 5}
{"sid": "060_三王世家.8.s5", "chapter": "060_三王世家", "para": "8", "seq": 5, "text": "臣昧死请。”", "len": 6}
{"sid": "060_三王世家.9.s1", "chapter": "060_三王世家", "para": "9", "seq": 1, "text": "制曰：“立皇子闳为齐王，旦为燕王，胥为广陵王。”", "len": 24}
{"sid": "060_三王世家.10.s1", "chapter": "060_三王世家", "para": "10", "seq": 1, "text": "四月丁酉，奏未央宫。", "len": 10}
{"sid": "060_三王世家.10.s2", "chapter": "060_三王世家", "para": "10", "seq": 2, "text": "六年四月戊寅朔，癸卯，御史大夫汤下丞相，丞相下中二千石，二千石下郡太守、诸侯相，丞书从事下当用者。", "len": 49}
{"sid": "060_三王世家.10.s3", "chapter": "060_三王世家", "para": "10", "seq": 3, "text": "如律令。", "len": 4}
{"sid": "060_三王世家.11.s1", "chapter": "060_三王世家", "para": "11", "seq": 1, "text": "“维六年四月乙巳，皇帝使御史大夫汤庙立子闳为齐王。", "len": 25}
{"sid": "060_三王世家.11.s2", "chapter": "060_三王世家", "para": "11", "seq": 2, "text": "曰：於戏，小子闳，受兹青社！", "len": 14}
{"sid": "060_三王世家.11.s3", "chapter": "060_三王世家", "para": "11", "seq": 3, "text": "朕承祖考，维稽古建尔国家，封于东土，世为汉籓辅。", "len": 24}
{"sid": "060_三王世家.11.s4", "chapter": "060_三王世家", "para": "11", "seq": 4, "text": "於戏念哉！", "len": 5}
{"sid": "060_三王世家.11.s5", "chapter": "060_三王世家", "para": "11", "seq": 5, "text": "恭朕之诏，惟命不于常。", "len": 11}
{"sid": "060_三王世家.11.s6", "chapter": "060_三王世家", "para": "11", "seq": 6, "text": "人之好德，克明显光。", "len": 10}
{"sid": "060_三王世家.11.s7", "chapter": "060_三王世家", "para": "11", "seq": 7, "text": "义之不图，俾君子怠。", "len": 10}
{"sid": "060_三王世家.11.s8", "chapter": "060_三王世家", "para": "11", "seq": 8, "text": "悉尔心，允执其中，天禄永终。", "len": 14}
{"sid": "060_三王世家.11.s9", "chapter": "060_三王世家", "para": "11", "seq": 9, "text": "厥有炋臧，乃凶于而国，害于尔躬。", "len": 16}
{"sid": "060_三王世家.11.s10", "chapter": "060_三王世家", "para": "11", "seq": 10, "text": "於戏，保国艾民，可不敬与！", "len": 13}
{"sid": "060_三王世家.11.s11", "chapter": "060_三王世家", "para": "11", "seq": 11, "text": "王其戒之。”", "len": 6}
{"sid": "060_三王世家.12.s1", "chapter": "060_三王世家", "para": "12", "seq": 1, "text": "右齐王策。", "len": 5}
{"sid": "060_三王世家.13.s1", "chapter": "060_三王世家", "para": "13", "seq": 1, "text": "“维六年四月乙巳，皇帝使御史大夫汤庙立子旦为燕王。", "len": 25}
{"sid": "060_三王世家.13.s2", "chapter": "060_三王世家", "para": "13", "seq": 2, "text": "曰：於戏，小子旦，受兹玄社！", "len": 14}
{"sid": "060_三王世家.13.s3", "chapter": "060_三王世家", "para": "13", "seq": 3, "text": "朕承祖考，维稽古，建尔国家，封于北土，世为汉籓辅。", "len": 25}
{"sid": "060_三王世家.13.s4", "chapter": "060_三王世家", "para": "13", "seq": 4, "text": "於戏！", "len": 3}
{"sid": "060_三王世家.13.s5", "chapter": "060_三王世家", "para": "13", "seq": 5, "text": "荤粥氏虐老兽心，侵犯寇盗，加以奸巧边萌。", "len": 20}
{"sid": "060_三王世家.13.s6", "chapter": "060_三王世家", "para": "13", "seq": 6, "text": "於戏！", "len": 3}
{"sid": "060_三王世家.13.s7", "chapter": "060_三王世家", "para": "13", "seq": 7, "text": "朕命将率徂征厥罪，万夫长，千夫长，三十有二君皆来，降期奔师。", "len": 30}
{"sid": "060_三王世家.13.s8", "chapter": "060_三王世家", "para": "13", "seq": 8, "text": "荤粥徙域，北州以绥。", "len": 10}
{"sid": "060_三王世家.13.s9", "chapter": "060_三王世家", "para": "13", "seq": 9, "text": "悉尔心，毋作怨，毋俷德，毋乃废备。", "len": 17}
{"sid": "060_三王世家.13.s10", "chapter": "060_三王世家", "para": "13", "seq": 10, "text": "非教士不得从徵。", "len": 8}
{"sid": "060_三王世家.13.s11", "chapter": "060_三王世家", "para": "13", "seq": 11, "text": "於戏，保国艾民，可不敬与！", "len": 13}
{"sid": "060_三王世家.13.s12", "chapter": "060_三王世家", "para": "13", "seq": 12, "text": "王其戒之。”", "len": 6}
{"sid": "060_三王世家.14.s1", "chapter": "060_三王世家", "para": "14", "seq": 1, "text": "右燕王策。", "len": 5}
{"sid": "060_三王世家.15.s1", "chapter": "060_三王世家", "para": "15", "seq": 1, "text": "“维六年四月乙巳，皇帝使御史大夫汤庙立子胥为广陵王。", "len": 26}
{"sid": "060_三王世家.15.s2", "chapter": "060_三王世家", "para": "15", "seq": 2, "text": "曰：於戏，小子胥，受兹赤社！", "len": 14}
{"sid": "060_三王世家.15.s3", "chapter": "060_三王世家", "para": "15", "seq": 3, "text": "朕承祖考，维稽古建尔国家，封于南土，世为汉籓辅。", "len": 24}
{"sid": "060_三王世家.15.s4", "chapter": "060_三王世家", "para": "15", "seq": 4, "text": "古人有言曰：‘大江之南，五湖之间，其人轻心。", "len": 22}
{"sid": "060_三王世家.15.s5", "chapter": "060_三王世家", "para": "15", "seq": 5, "text": "杨州保疆，三代要服，不及以政。", "len": 15}
{"sid": "060_三王世家.15.s6", "chapter": "060_三王世家", "para": "15", "seq": 6, "text": "’於戏！", "len": 4}
{"sid": "060_三王世家.15.s7", "chapter": "060_三王世家", "para": "15", "seq": 7, "text": "悉尔心，战战兢兢，乃惠乃顺，毋侗好轶，毋迩宵人，维法维则。", "len": 29}
{"sid": "060_三王世家.15.s8", "chapter": "060_三王世家", "para": "15", "seq": 8, "text": "书云：‘臣不作威，不作福，靡有後羞。", "len": 18}
{"sid": "060_三王世家.15.s9", "chapter": "060_三王世家", "para": "15", "seq": 9, "text": "’於戏，保国艾民，可不敬与！", "len": 14}
{"sid": "060_三王世家.15.s10", "chapter": "060_三王世家", "para": "15", "seq": 10, "text": "王其戒之。”", "len": 6}
{"sid": "060_三王世家.16.s1", "chapter": "060_三王世家", "para": "16", "seq": 1, "text": "右广陵王策。", "len": 6}
{"sid": "060_三王世家.16.s2", "chapter": "060_三王世家", "para": "16", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "060_三王世家.17.s1", "chapter": "060_三王世家", "para": "17", "seq": 1, "text": "太史公曰：古人有言曰“爱之欲其富，亲之欲其贵”。", "len": 24}
{"sid": "060_三王世家.17.s2", "chapter": "060_三王世家", "para": "17", "seq": 2, "text": "故王者壃土建国，封立子弟，所以襃亲亲，序骨肉，尊先祖，贵支体，广同姓於天下也。", "len": 39}
{"sid": "060_三王世家.17.s3", "chapter": "060_三王世家", "para": "17", "seq": 3, "text": "是以形势彊而王室安。", "len": 10}
{"sid": "060_三王世家.17.s4", "chapter": "060_三王世家", "para": "17", "seq": 4, "text": "自古至今，所由来久矣。", "len": 11}
{"sid": "060_三王世家.17.s5", "chapter": "060_三王世家", "para": "17", "seq": 5, "text": "非有异也，故弗论箸也。", "len": 11}
{"sid": "060_三王世家.17.s6", "chapter": "060_三王世家", "para": "17", "seq": 6, "text": "燕齐之事，无足采者。", "len": 10}
{"sid": "060_三王世家.17.s7", "chapter": "060_三王世家", "para": "17", "seq": 7, "text": "然封立三王，天子恭让，群臣守义，文辞烂然，甚可观也，是以附之世家。", "len": 33}
{"sid": "060_三王世家.17.s8", "chapter": "060_三王世家", "para": "17", "seq": 8, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.18.s1", "chapter": "060_三王世家", "para": "18", "seq": 1, "text": "褚先生曰：臣幸得以文学为侍郎，好览观太史公之列传。", "len": 25}
{"sid": "060_三王世家.18.s2", "chapter": "060_三王世家", "para": "18", "seq": 2, "text": "传中称三王世家文辞可观，求其世家终不能得。", "len": 21}
{"sid": "060_三王世家.18.s3", "chapter": "060_三王世家", "para": "18", "seq": 3, "text": "窃从长老好故事者取其封策书，编列其事而传之，令後世得观贤主之指意。", "len": 33}
{"sid": "060_三王世家.18.s4", "chapter": "060_三王世家", "para": "18", "seq": 4, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.19.s1", "chapter": "060_三王世家", "para": "19", "seq": 1, "text": "盖闻孝武帝之时，同日而俱拜三子为王：封一子於齐，一子於广陵，一子於燕。", "len": 35}
{"sid": "060_三王世家.19.s2", "chapter": "060_三王世家", "para": "19", "seq": 2, "text": "各因子才力智能，及土地之刚柔，人民之轻重，为作策以申戒之。", "len": 29}
{"sid": "060_三王世家.19.s3", "chapter": "060_三王世家", "para": "19", "seq": 3, "text": "谓王：“世为汉籓辅，保国治民，可不敬与！", "len": 20}
{"sid": "060_三王世家.19.s4", "chapter": "060_三王世家", "para": "19", "seq": 4, "text": "王其戒之。", "len": 5}
{"sid": "060_三王世家.19.s5", "chapter": "060_三王世家", "para": "19", "seq": 5, "text": "” 夫贤主所作，固非浅闻者所能知，非博闻彊记君子者所不能究竟其意。", "len": 33}
{"sid": "060_三王世家.19.s6", "chapter": "060_三王世家", "para": "19", "seq": 6, "text": "至其次序分绝，文字之上下，简之参差长短，皆有意，人莫之能知。", "len": 30}
{"sid": "060_三王世家.19.s7", "chapter": "060_三王世家", "para": "19", "seq": 7, "text": "谨论次其真草诏书，编于左方。", "len": 14}
{"sid": "060_三王世家.19.s8", "chapter": "060_三王世家", "para": "19", "seq": 8, "text": "令览者自通其意而解说之。", "len": 12}
{"sid": "060_三王世家.19.s9", "chapter": "060_三王世家", "para": "19", "seq": 9, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.20.s1", "chapter": "060_三王世家", "para": "20", "seq": 1, "text": "王夫人者，赵人也，与卫夫人并幸武帝，而生子闳。", "len": 23}
{"sid": "060_三王世家.20.s2", "chapter": "060_三王世家", "para": "20", "seq": 2, "text": "闳且立为王时，其母病，武帝自临问之。", "len": 18}
{"sid": "060_三王世家.20.s3", "chapter": "060_三王世家", "para": "20", "seq": 3, "text": "曰：“子当为王，欲安所置之？", "len": 14}
{"sid": "060_三王世家.20.s4", "chapter": "060_三王世家", "para": "20", "seq": 4, "text": "” 王夫人曰：“陛下在，妾又何等可言者。", "len": 20}
{"sid": "060_三王世家.20.s5", "chapter": "060_三王世家", "para": "20", "seq": 5, "text": "” 武帝曰：“虽然，意所欲，欲於何所王之？", "len": 21}
{"sid": "060_三王世家.20.s6", "chapter": "060_三王世家", "para": "20", "seq": 6, "text": "” 王夫人曰：“原置之雒阳。", "len": 14}
{"sid": "060_三王世家.20.s7", "chapter": "060_三王世家", "para": "20", "seq": 7, "text": "” 武帝曰：“雒阳有武库敖仓，天下旻阸戹，汉国之大都也。", "len": 28}
{"sid": "060_三王世家.20.s8", "chapter": "060_三王世家", "para": "20", "seq": 8, "text": "先帝以来，无子王於雒阳者。", "len": 13}
{"sid": "060_三王世家.20.s9", "chapter": "060_三王世家", "para": "20", "seq": 9, "text": "去雒阳，馀尽可。", "len": 8}
{"sid": "060_三王世家.20.s10", "chapter": "060_三王世家", "para": "20", "seq": 10, "text": "” 王夫人不应。", "len": 8}
{"sid": "060_三王世家.20.s11", "chapter": "060_三王世家", "para": "20", "seq": 11, "text": "武帝曰：“关东之国无大於齐者。", "len": 15}
{"sid": "060_三王世家.20.s12", "chapter": "060_三王世家", "para": "20", "seq": 12, "text": "齐东负海而城郭大，古时独临菑中十万户，天下膏腴地莫盛於齐者矣。", "len": 31}
{"sid": "060_三王世家.20.s13", "chapter": "060_三王世家", "para": "20", "seq": 13, "text": "” 王夫人以手击头，谢曰：“幸甚。", "len": 17}
{"sid": "060_三王世家.20.s14", "chapter": "060_三王世家", "para": "20", "seq": 14, "text": "” 王夫人死而武帝痛之，使使者拜之曰：“皇帝谨使使太中大夫明奉璧一，赐夫人为齐王太后。", "len": 43}
{"sid": "060_三王世家.20.s15", "chapter": "060_三王世家", "para": "20", "seq": 15, "text": "” 子闳王齐，年少，无有子，立，不幸早死，国绝，为郡。", "len": 27}
{"sid": "060_三王世家.20.s16", "chapter": "060_三王世家", "para": "20", "seq": 16, "text": "天下称齐不宜王云。", "len": 9}
{"sid": "060_三王世家.20.s17", "chapter": "060_三王世家", "para": "20", "seq": 17, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.21.s1", "chapter": "060_三王世家", "para": "21", "seq": 1, "text": "所谓“受此土” 者，诸侯王始封者必受土於天子之社，归立之以为国社，以岁时祠之。", "len": 39}
{"sid": "060_三王世家.21.s2", "chapter": "060_三王世家", "para": "21", "seq": 2, "text": "春秋大传曰：“天子之国有泰社。", "len": 15}
{"sid": "060_三王世家.21.s3", "chapter": "060_三王世家", "para": "21", "seq": 3, "text": "东方青，南方赤，西方白，北方黑，上方黄。", "len": 20}
{"sid": "060_三王世家.21.s4", "chapter": "060_三王世家", "para": "21", "seq": 4, "text": "” 故将封於东方者取青土，封於南方者取赤土，封於西方者取白土，封於北方者取黑土，封於上方者取黄土。", "len": 49}
{"sid": "060_三王世家.21.s5", "chapter": "060_三王世家", "para": "21", "seq": 5, "text": "各取其色物，裹以白茅，封以为社。", "len": 16}
{"sid": "060_三王世家.21.s6", "chapter": "060_三王世家", "para": "21", "seq": 6, "text": "此始受封於天子者也。", "len": 10}
{"sid": "060_三王世家.21.s7", "chapter": "060_三王世家", "para": "21", "seq": 7, "text": "此之为主土。", "len": 6}
{"sid": "060_三王世家.21.s8", "chapter": "060_三王世家", "para": "21", "seq": 8, "text": "主土者，立社而奉之也。", "len": 11}
{"sid": "060_三王世家.21.s9", "chapter": "060_三王世家", "para": "21", "seq": 9, "text": "“朕承祖考”，祖者先也，考者父也。", "len": 17}
{"sid": "060_三王世家.21.s10", "chapter": "060_三王世家", "para": "21", "seq": 10, "text": "“维稽古”，维者度也，念也，稽者当也，当顺古之道也。", "len": 26}
{"sid": "060_三王世家.21.s11", "chapter": "060_三王世家", "para": "21", "seq": 11, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.22.s1", "chapter": "060_三王世家", "para": "22", "seq": 1, "text": "齐地多变诈，不习於礼义，故戒之曰“恭朕之诏，唯命不可为常。", "len": 29}
{"sid": "060_三王世家.22.s2", "chapter": "060_三王世家", "para": "22", "seq": 2, "text": "人之好德，能明显光。", "len": 10}
{"sid": "060_三王世家.22.s3", "chapter": "060_三王世家", "para": "22", "seq": 3, "text": "不图於义，使君子怠慢。", "len": 11}
{"sid": "060_三王世家.22.s4", "chapter": "060_三王世家", "para": "22", "seq": 4, "text": "悉若心，信执其中，天禄长终。", "len": 14}
{"sid": "060_三王世家.22.s5", "chapter": "060_三王世家", "para": "22", "seq": 5, "text": "有过不善，乃凶于而国，而害于若身”。", "len": 18}
{"sid": "060_三王世家.22.s6", "chapter": "060_三王世家", "para": "22", "seq": 6, "text": "齐王之国，左右维持以礼义，不幸中年早夭。", "len": 20}
{"sid": "060_三王世家.22.s7", "chapter": "060_三王世家", "para": "22", "seq": 7, "text": "然全身无过，如其策意。", "len": 11}
{"sid": "060_三王世家.22.s8", "chapter": "060_三王世家", "para": "22", "seq": 8, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.23.s1", "chapter": "060_三王世家", "para": "23", "seq": 1, "text": "传曰“青采出於蓝，而质青於蓝” 者，教使然也。", "len": 23}
{"sid": "060_三王世家.23.s2", "chapter": "060_三王世家", "para": "23", "seq": 2, "text": "远哉贤主，昭然独见：诫齐王以慎内；诫燕王以无作怨，无俷德；诫广陵王以慎外，无作威与福。", "len": 43}
{"sid": "060_三王世家.23.s3", "chapter": "060_三王世家", "para": "23", "seq": 3, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.24.s1", "chapter": "060_三王世家", "para": "24", "seq": 1, "text": "夫广陵在吴越之地，其民精而轻，故诫之曰“江湖之间，其人轻心。", "len": 30}
{"sid": "060_三王世家.24.s2", "chapter": "060_三王世家", "para": "24", "seq": 2, "text": "杨州葆疆，三代之时，迫要使从中国俗服，不大及以政教，以意御之而已。", "len": 33}
{"sid": "060_三王世家.24.s3", "chapter": "060_三王世家", "para": "24", "seq": 3, "text": "无侗好佚，无迩宵人，维法是则。", "len": 15}
{"sid": "060_三王世家.24.s4", "chapter": "060_三王世家", "para": "24", "seq": 4, "text": "无长好佚乐驰骋弋猎淫康，而近小人。", "len": 17}
{"sid": "060_三王世家.24.s5", "chapter": "060_三王世家", "para": "24", "seq": 5, "text": "常念法度，则无羞辱矣”。", "len": 12}
{"sid": "060_三王世家.24.s6", "chapter": "060_三王世家", "para": "24", "seq": 6, "text": "三江、五湖有鱼盐之利，铜山之富，天下所仰。", "len": 21}
{"sid": "060_三王世家.24.s7", "chapter": "060_三王世家", "para": "24", "seq": 7, "text": "故诫之曰“臣不作福” 者，勿使行财币，厚赏赐，以立声誉，为四方所归也。", "len": 35}
{"sid": "060_三王世家.24.s8", "chapter": "060_三王世家", "para": "24", "seq": 8, "text": "又曰“臣不作威” 者，勿使因轻以倍义也。", "len": 20}
{"sid": "060_三王世家.24.s9", "chapter": "060_三王世家", "para": "24", "seq": 9, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.25.s1", "chapter": "060_三王世家", "para": "25", "seq": 1, "text": "会孝武帝崩，孝昭帝初立，先朝广陵王胥，厚赏赐金钱财币，直三千馀万，益地百里，邑万户。", "len": 42}
{"sid": "060_三王世家.25.s2", "chapter": "060_三王世家", "para": "25", "seq": 2, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.26.s1", "chapter": "060_三王世家", "para": "26", "seq": 1, "text": "会昭帝崩，宣帝初立，缘恩行义，以本始元年中，裂汉地，尽以封广陵王胥四子：一子为朝阳侯；一子为平曲侯；一子为南利侯；最爱少子弘，立以为高密王。", "len": 70}
{"sid": "060_三王世家.26.s2", "chapter": "060_三王世家", "para": "26", "seq": 2, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.27.s1", "chapter": "060_三王世家", "para": "27", "seq": 1, "text": "其後胥果作威福，通楚王使者。", "len": 14}
{"sid": "060_三王世家.27.s2", "chapter": "060_三王世家", "para": "27", "seq": 2, "text": "楚王宣言曰：“我先元王，高帝少弟也，封三十二城。", "len": 24}
{"sid": "060_三王世家.27.s3", "chapter": "060_三王世家", "para": "27", "seq": 3, "text": "今地邑益少，我欲与广陵王共发兵云。", "len": 17}
{"sid": "060_三王世家.27.s4", "chapter": "060_三王世家", "para": "27", "seq": 4, "text": "广陵王为上，我复王楚三十二城，如元王时。", "len": 20}
{"sid": "060_三王世家.27.s5", "chapter": "060_三王世家", "para": "27", "seq": 5, "text": "” 事发觉，公卿有司请行罚诛。", "len": 15}
{"sid": "060_三王世家.27.s6", "chapter": "060_三王世家", "para": "27", "seq": 6, "text": "天子以骨肉之故，不忍致法於胥，下诏书无治广陵王，独诛首恶楚王。", "len": 31}
{"sid": "060_三王世家.27.s7", "chapter": "060_三王世家", "para": "27", "seq": 7, "text": "传曰“蓬生麻中，不扶自直；白沙在泥中，与之皆黑” 者，土地教化使之然也。", "len": 36}
{"sid": "060_三王世家.27.s8", "chapter": "060_三王世家", "para": "27", "seq": 8, "text": "其後胥复祝诅谋反，自杀，国除。", "len": 15}
{"sid": "060_三王世家.27.s9", "chapter": "060_三王世家", "para": "27", "seq": 9, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.28.s1", "chapter": "060_三王世家", "para": "28", "seq": 1, "text": "燕土墝埆，北迫匈奴，其人民勇而少虑，故诫之曰“荤粥氏无有孝行而禽兽心，以窃盗侵犯边民。", "len": 43}
{"sid": "060_三王世家.28.s2", "chapter": "060_三王世家", "para": "28", "seq": 2, "text": "朕诏将军往征其罪，万夫长，千夫长，三十有二君皆来，降旗奔师。", "len": 30}
{"sid": "060_三王世家.28.s3", "chapter": "060_三王世家", "para": "28", "seq": 3, "text": "荤粥徙域远处，北州以安矣”。", "len": 14}
{"sid": "060_三王世家.28.s4", "chapter": "060_三王世家", "para": "28", "seq": 4, "text": "“悉若心，无作怨” 者，勿使从俗以怨望也。", "len": 21}
{"sid": "060_三王世家.28.s5", "chapter": "060_三王世家", "para": "28", "seq": 5, "text": "“无俷德” 者，勿使背德也。", "len": 14}
{"sid": "060_三王世家.28.s6", "chapter": "060_三王世家", "para": "28", "seq": 6, "text": "“无废备” 者，无乏武备，常备匈奴也。", "len": 19}
{"sid": "060_三王世家.28.s7", "chapter": "060_三王世家", "para": "28", "seq": 7, "text": "“非教士不得从徵” 者，言非习礼义不得在於侧也。", "len": 24}
{"sid": "060_三王世家.28.s8", "chapter": "060_三王世家", "para": "28", "seq": 8, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.29.s1", "chapter": "060_三王世家", "para": "29", "seq": 1, "text": "会武帝年老长，而太子不幸薨，未有所立，而旦使来上书，请身入宿卫於长安。", "len": 35}
{"sid": "060_三王世家.29.s2", "chapter": "060_三王世家", "para": "29", "seq": 2, "text": "孝武见其书，击地，怒曰：“生子当置之齐鲁礼义之乡，乃置之燕赵，果有争心，不让之端见矣。", "len": 43}
{"sid": "060_三王世家.29.s3", "chapter": "060_三王世家", "para": "29", "seq": 3, "text": "” 於是使使即斩其使者於阙下。", "len": 15}
{"sid": "060_三王世家.29.s4", "chapter": "060_三王世家", "para": "29", "seq": 4, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.30.s1", "chapter": "060_三王世家", "para": "30", "seq": 1, "text": "会武帝崩，昭帝初立，旦果作怨而望大臣。", "len": 19}
{"sid": "060_三王世家.30.s2", "chapter": "060_三王世家", "para": "30", "seq": 2, "text": "自以长子当立，与齐王子刘泽等谋为叛逆，出言曰：“我安得弟在者！", "len": 31}
{"sid": "060_三王世家.30.s3", "chapter": "060_三王世家", "para": "30", "seq": 3, "text": "今立者乃大将军子也。", "len": 10}
{"sid": "060_三王世家.30.s4", "chapter": "060_三王世家", "para": "30", "seq": 4, "text": "” 欲发兵。", "len": 6}
{"sid": "060_三王世家.30.s5", "chapter": "060_三王世家", "para": "30", "seq": 5, "text": "事发觉，当诛。", "len": 7}
{"sid": "060_三王世家.30.s6", "chapter": "060_三王世家", "para": "30", "seq": 6, "text": "昭帝缘恩宽忍，抑案不扬。", "len": 12}
{"sid": "060_三王世家.30.s7", "chapter": "060_三王世家", "para": "30", "seq": 7, "text": "公卿使大臣请，遣宗正与太中大夫公户满意、御史二人，偕往使燕，风喻之。", "len": 34}
{"sid": "060_三王世家.30.s8", "chapter": "060_三王世家", "para": "30", "seq": 8, "text": "到燕，各异日，更见责王。", "len": 12}
{"sid": "060_三王世家.30.s9", "chapter": "060_三王世家", "para": "30", "seq": 9, "text": "宗正者，主宗室诸刘属籍，先见王，为列陈道昭帝实武帝子状。", "len": 28}
{"sid": "060_三王世家.30.s10", "chapter": "060_三王世家", "para": "30", "seq": 10, "text": "侍御史乃复见王，责之以正法，问：“王欲发兵罪名明白，当坐之。", "len": 30}
{"sid": "060_三王世家.30.s11", "chapter": "060_三王世家", "para": "30", "seq": 11, "text": "汉家有正法，王犯纤介小罪过，即行法直断耳，安能宽王。", "len": 26}
{"sid": "060_三王世家.30.s12", "chapter": "060_三王世家", "para": "30", "seq": 12, "text": "” 惊动以文法。", "len": 8}
{"sid": "060_三王世家.30.s13", "chapter": "060_三王世家", "para": "30", "seq": 13, "text": "王意益下，心恐。", "len": 8}
{"sid": "060_三王世家.30.s14", "chapter": "060_三王世家", "para": "30", "seq": 14, "text": "公户满意习於经术，最後见王，称引古今通义，国家大礼，文章尔雅。", "len": 31}
{"sid": "060_三王世家.30.s15", "chapter": "060_三王世家", "para": "30", "seq": 15, "text": "谓王曰：“古者天子必内有异姓大夫，所以正骨肉也；外有同姓大夫，所以正异族也。", "len": 38}
{"sid": "060_三王世家.30.s16", "chapter": "060_三王世家", "para": "30", "seq": 16, "text": "周公辅成王，诛其两弟，故治。", "len": 14}
{"sid": "060_三王世家.30.s17", "chapter": "060_三王世家", "para": "30", "seq": 17, "text": "武帝在时，尚能宽王。", "len": 10}
{"sid": "060_三王世家.30.s18", "chapter": "060_三王世家", "para": "30", "seq": 18, "text": "今昭帝始立，年幼，富於春秋，未临政，委任大臣。", "len": 23}
{"sid": "060_三王世家.30.s19", "chapter": "060_三王世家", "para": "30", "seq": 19, "text": "古者诛罚不阿亲戚，故天下治。", "len": 14}
{"sid": "060_三王世家.30.s20", "chapter": "060_三王世家", "para": "30", "seq": 20, "text": "方今大臣辅政，奉法直行，无敢所阿，恐不能宽王。", "len": 23}
{"sid": "060_三王世家.30.s21", "chapter": "060_三王世家", "para": "30", "seq": 21, "text": "王可自谨，无自令身死国灭，为天下笑。", "len": 18}
{"sid": "060_三王世家.30.s22", "chapter": "060_三王世家", "para": "30", "seq": 22, "text": "” 於是燕王旦乃恐惧服罪，叩头谢过。", "len": 18}
{"sid": "060_三王世家.30.s23", "chapter": "060_三王世家", "para": "30", "seq": 23, "text": "大臣欲和合骨肉，难伤之以法。", "len": 14}
{"sid": "060_三王世家.30.s24", "chapter": "060_三王世家", "para": "30", "seq": 24, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.31.s1", "chapter": "060_三王世家", "para": "31", "seq": 1, "text": "其後旦复与左将军上官桀等谋反，宣言曰“我次太子，太子不在，我当立，大臣共抑我” 云云。", "len": 43}
{"sid": "060_三王世家.31.s2", "chapter": "060_三王世家", "para": "31", "seq": 2, "text": "大将军光辅政，与公卿大臣议曰：“燕王旦不改过悔正，行恶不变。", "len": 30}
{"sid": "060_三王世家.31.s3", "chapter": "060_三王世家", "para": "31", "seq": 3, "text": "” 於是脩法直断，行罚诛。", "len": 13}
{"sid": "060_三王世家.31.s4", "chapter": "060_三王世家", "para": "31", "seq": 4, "text": "旦自杀，国除，如其策指。", "len": 12}
{"sid": "060_三王世家.31.s5", "chapter": "060_三王世家", "para": "31", "seq": 5, "text": "有司请诛旦妻子。", "len": 8}
{"sid": "060_三王世家.31.s6", "chapter": "060_三王世家", "para": "31", "seq": 6, "text": "孝昭以骨肉之亲，不忍致法，宽赦旦妻子，免为庶人。", "len": 24}
{"sid": "060_三王世家.31.s7", "chapter": "060_三王世家", "para": "31", "seq": 7, "text": "传曰“兰根与白芷，渐之滫中，君子不近，庶人不服” 者，所以渐然也。", "len": 33}
{"sid": "060_三王世家.31.s8", "chapter": "060_三王世家", "para": "31", "seq": 8, "text": "::: :::", "len": 7}
{"sid": "060_三王世家.32.s1", "chapter": "060_三王世家", "para": "32", "seq": 1, "text": "宣帝初立，推恩宣德，以本始元年中尽复封燕王旦两子：一子为安定侯；立燕故太子建为广阳王，以奉燕王祭祀。", "len": 50}
{"sid": "060_三王世家.32.s2", "chapter": "060_三王世家", "para": "32", "seq": 2, "text": "::: ::: 赞", "len": 9}
{"sid": "060_三王世家.33.s1", "chapter": "060_三王世家", "para": "33", "seq": 1, "text": "三王封系，旧史烂然。", "len": 10}
{"sid": "060_三王世家.33.s2", "chapter": "060_三王世家", "para": "33", "seq": 2, "text": "褚氏後补，册书存焉。", "len": 10}
{"sid": "060_三王世家.33.s3", "chapter": "060_三王世家", "para": "33", "seq": 3, "text": "去病建议，青翟上言。", "len": 10}
{"sid": "060_三王世家.33.s4", "chapter": "060_三王世家", "para": "33", "seq": 4, "text": "天子冲挹，志在急贤。", "len": 10}
{"sid": "060_三王世家.33.s5", "chapter": "060_三王世家", "para": "33", "seq": 5, "text": "太常具礼，请立齐燕； 闳国负海，旦社惟玄。", "len": 21}
{"sid": "060_三王世家.33.s6", "chapter": "060_三王世家", "para": "33", "seq": 6, "text": "宵人不迩，荤粥远边。", "len": 10}
{"sid": "060_三王世家.33.s7", "chapter": "060_三王世家", "para": "33", "seq": 7, "text": "明哉监戒，式防厥愆。", "len": 10}
{"sid": "060_三王世家.33.s8", "chapter": "060_三王世家", "para": "33", "seq": 8, "text": ":::", "len": 3}
