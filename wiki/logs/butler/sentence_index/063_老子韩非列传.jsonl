{"sid": "063_老子韩非列传.1.s1", "chapter": "063_老子韩非列传", "para": "1", "seq": 1, "text": "老子者，楚苦县厉乡曲仁里人也，姓李氏，名耳，字摐，周守藏室之史也。", "len": 33}
{"sid": "063_老子韩非列传.2.s1", "chapter": "063_老子韩非列传", "para": "2", "seq": 1, "text": "孔子適周，将问礼於老子。", "len": 12}
{"sid": "063_老子韩非列传.2.s2", "chapter": "063_老子韩非列传", "para": "2", "seq": 2, "text": "老子曰：“子所言者，其人与骨皆已朽矣，独其言在耳。", "len": 25}
{"sid": "063_老子韩非列传.2.s3", "chapter": "063_老子韩非列传", "para": "2", "seq": 3, "text": "且君子得其时则驾，不得其时则蓬累而行。", "len": 19}
{"sid": "063_老子韩非列传.2.s4", "chapter": "063_老子韩非列传", "para": "2", "seq": 4, "text": "吾闻之，良贾深藏若虚，君子盛德容貌若愚。", "len": 20}
{"sid": "063_老子韩非列传.2.s5", "chapter": "063_老子韩非列传", "para": "2", "seq": 5, "text": "去子之骄气与多欲，态色与淫志，是皆无益於子之身。", "len": 24}
{"sid": "063_老子韩非列传.2.s6", "chapter": "063_老子韩非列传", "para": "2", "seq": 6, "text": "吾所以告子，若是而已。", "len": 11}
{"sid": "063_老子韩非列传.2.s7", "chapter": "063_老子韩非列传", "para": "2", "seq": 7, "text": "” 孔子去，谓弟子曰：“鸟，吾知其能飞；鱼，吾知其能游；兽，吾知其能走。", "len": 36}
{"sid": "063_老子韩非列传.2.s8", "chapter": "063_老子韩非列传", "para": "2", "seq": 8, "text": "走者可以为罔，游者可以为纶，飞者可以为矰。", "len": 21}
{"sid": "063_老子韩非列传.2.s9", "chapter": "063_老子韩非列传", "para": "2", "seq": 9, "text": "至於龙，吾不能知其乘风云而上天。", "len": 16}
{"sid": "063_老子韩非列传.2.s10", "chapter": "063_老子韩非列传", "para": "2", "seq": 10, "text": "吾今日见老子，其犹龙邪！”", "len": 13}
{"sid": "063_老子韩非列传.3.s1", "chapter": "063_老子韩非列传", "para": "3", "seq": 1, "text": "老子脩道德，其学以自隐无名为务。", "len": 16}
{"sid": "063_老子韩非列传.3.s2", "chapter": "063_老子韩非列传", "para": "3", "seq": 2, "text": "居周久之，见周之衰，乃遂去。", "len": 14}
{"sid": "063_老子韩非列传.3.s3", "chapter": "063_老子韩非列传", "para": "3", "seq": 3, "text": "至关，关令尹喜曰：“子将隐矣，彊为我著书。", "len": 21}
{"sid": "063_老子韩非列传.3.s4", "chapter": "063_老子韩非列传", "para": "3", "seq": 4, "text": "” 於是老子乃著书上下篇，言道德之意五千馀言而去，莫知其所终。", "len": 31}
{"sid": "063_老子韩非列传.4.s1", "chapter": "063_老子韩非列传", "para": "4", "seq": 1, "text": "或曰：老莱子亦楚人也，著书十五篇，言道家之用，与孔子同时云。", "len": 30}
{"sid": "063_老子韩非列传.5.s1", "chapter": "063_老子韩非列传", "para": "5", "seq": 1, "text": "盖老子百有六十馀岁，或言二百馀岁，以其脩道而养寿也。", "len": 26}
{"sid": "063_老子韩非列传.6.s1", "chapter": "063_老子韩非列传", "para": "6", "seq": 1, "text": "自孔子死之後百二十九年，而史记周太史儋见秦献公曰：“始秦与周合，合五百岁而离，离七十岁而霸王者出焉。", "len": 50}
{"sid": "063_老子韩非列传.6.s2", "chapter": "063_老子韩非列传", "para": "6", "seq": 2, "text": "” 或曰儋即老子，或曰非也，世莫知其然否。", "len": 21}
{"sid": "063_老子韩非列传.6.s3", "chapter": "063_老子韩非列传", "para": "6", "seq": 3, "text": "老子，隐君子也。", "len": 8}
{"sid": "063_老子韩非列传.7.s1", "chapter": "063_老子韩非列传", "para": "7", "seq": 1, "text": "老子之子名宗，宗为魏将，封於段干。", "len": 17}
{"sid": "063_老子韩非列传.7.s2", "chapter": "063_老子韩非列传", "para": "7", "seq": 2, "text": "宗子注，注子宫，宫玄孙假，假仕於汉孝文帝。", "len": 21}
{"sid": "063_老子韩非列传.7.s3", "chapter": "063_老子韩非列传", "para": "7", "seq": 3, "text": "而假之子解为胶西王卬太傅，因家于齐焉。", "len": 19}
{"sid": "063_老子韩非列传.8.s1", "chapter": "063_老子韩非列传", "para": "8", "seq": 1, "text": "世之学老子者则绌儒学，儒学亦绌老子。", "len": 18}
{"sid": "063_老子韩非列传.8.s2", "chapter": "063_老子韩非列传", "para": "8", "seq": 2, "text": "“道不同不相为谋”，岂谓是邪？", "len": 15}
{"sid": "063_老子韩非列传.8.s3", "chapter": "063_老子韩非列传", "para": "8", "seq": 3, "text": "李耳无为自化，清静自正。", "len": 12}
{"sid": "063_老子韩非列传.9.s1", "chapter": "063_老子韩非列传", "para": "9", "seq": 1, "text": "庄子者，蒙人也，名周。", "len": 11}
{"sid": "063_老子韩非列传.9.s2", "chapter": "063_老子韩非列传", "para": "9", "seq": 2, "text": "周尝为蒙漆园吏，与梁惠王、齐宣王同时。", "len": 19}
{"sid": "063_老子韩非列传.9.s3", "chapter": "063_老子韩非列传", "para": "9", "seq": 3, "text": "其学无所不闚，然其要本归於老子之言。", "len": 18}
{"sid": "063_老子韩非列传.9.s4", "chapter": "063_老子韩非列传", "para": "9", "seq": 4, "text": "故其著书十馀万言，大抵率寓言也。", "len": 16}
{"sid": "063_老子韩非列传.9.s5", "chapter": "063_老子韩非列传", "para": "9", "seq": 5, "text": "作渔父、盗跖、胠箧，以诋訿孔子之徒，以明老子之术。", "len": 25}
{"sid": "063_老子韩非列传.9.s6", "chapter": "063_老子韩非列传", "para": "9", "seq": 6, "text": "畏累虚、亢桑子之属，皆空语无事实。", "len": 17}
{"sid": "063_老子韩非列传.9.s7", "chapter": "063_老子韩非列传", "para": "9", "seq": 7, "text": "然善属书离辞，指事类情，用剽剥儒、墨，虽当世宿学不能自解免也。", "len": 31}
{"sid": "063_老子韩非列传.9.s8", "chapter": "063_老子韩非列传", "para": "9", "seq": 8, "text": "其言洸洋自恣以適己，故自王公大人不能器之。", "len": 21}
{"sid": "063_老子韩非列传.10.s1", "chapter": "063_老子韩非列传", "para": "10", "seq": 1, "text": "楚威王闻庄周贤，使使厚币迎之，许以为相。", "len": 20}
{"sid": "063_老子韩非列传.10.s2", "chapter": "063_老子韩非列传", "para": "10", "seq": 2, "text": "庄周笑谓楚使者曰：“千金，重利；卿相，尊位也。", "len": 23}
{"sid": "063_老子韩非列传.10.s3", "chapter": "063_老子韩非列传", "para": "10", "seq": 3, "text": "子独不见郊祭之牺牛乎？", "len": 11}
{"sid": "063_老子韩非列传.10.s4", "chapter": "063_老子韩非列传", "para": "10", "seq": 4, "text": "养食之数岁，衣以文绣，以入大庙。", "len": 16}
{"sid": "063_老子韩非列传.10.s5", "chapter": "063_老子韩非列传", "para": "10", "seq": 5, "text": "当是之时，虽欲为孤豚，岂可得乎？", "len": 16}
{"sid": "063_老子韩非列传.10.s6", "chapter": "063_老子韩非列传", "para": "10", "seq": 6, "text": "子亟去，无污我。", "len": 8}
{"sid": "063_老子韩非列传.10.s7", "chapter": "063_老子韩非列传", "para": "10", "seq": 7, "text": "我宁游戏污渎之中自快，无为有国者所羁，终身不仕，以快吾志焉。”", "len": 31}
{"sid": "063_老子韩非列传.11.s1", "chapter": "063_老子韩非列传", "para": "11", "seq": 1, "text": "申不害者，京人也，故郑之贱臣。", "len": 15}
{"sid": "063_老子韩非列传.11.s2", "chapter": "063_老子韩非列传", "para": "11", "seq": 2, "text": "学术以干韩昭侯，昭侯用为相。", "len": 14}
{"sid": "063_老子韩非列传.11.s3", "chapter": "063_老子韩非列传", "para": "11", "seq": 3, "text": "内脩政教，外应诸侯，十五年。", "len": 14}
{"sid": "063_老子韩非列传.11.s4", "chapter": "063_老子韩非列传", "para": "11", "seq": 4, "text": "终申子之身，国治兵彊，无侵韩者。", "len": 16}
{"sid": "063_老子韩非列传.12.s1", "chapter": "063_老子韩非列传", "para": "12", "seq": 1, "text": "申子之学本於黄老而主刑名。", "len": 13}
{"sid": "063_老子韩非列传.12.s2", "chapter": "063_老子韩非列传", "para": "12", "seq": 2, "text": "著书二篇，号曰申子。", "len": 10}
{"sid": "063_老子韩非列传.13.s1", "chapter": "063_老子韩非列传", "para": "13", "seq": 1, "text": "韩非者，韩之诸公子也。", "len": 11}
{"sid": "063_老子韩非列传.13.s2", "chapter": "063_老子韩非列传", "para": "13", "seq": 2, "text": "喜刑名法术之学，而其归本於黄老。", "len": 16}
{"sid": "063_老子韩非列传.13.s3", "chapter": "063_老子韩非列传", "para": "13", "seq": 3, "text": "非为人口吃，不能道说，而善著书。", "len": 16}
{"sid": "063_老子韩非列传.13.s4", "chapter": "063_老子韩非列传", "para": "13", "seq": 4, "text": "与李斯俱事荀卿，斯自以为不如非。", "len": 16}
{"sid": "063_老子韩非列传.14.s1", "chapter": "063_老子韩非列传", "para": "14", "seq": 1, "text": "非见韩之削弱，数以书谏韩王，韩王不能用。", "len": 20}
{"sid": "063_老子韩非列传.14.s2", "chapter": "063_老子韩非列传", "para": "14", "seq": 2, "text": "於是韩非疾治国不务脩明其法制，执势以御其臣下，富国彊兵而以求人任贤，反举浮淫之蠹而加之於功实之上。", "len": 49}
{"sid": "063_老子韩非列传.14.s3", "chapter": "063_老子韩非列传", "para": "14", "seq": 3, "text": "以为儒者用文乱法，而侠者以武犯禁。", "len": 17}
{"sid": "063_老子韩非列传.14.s4", "chapter": "063_老子韩非列传", "para": "14", "seq": 4, "text": "宽则宠名誉之人，急则用介胄之士。", "len": 16}
{"sid": "063_老子韩非列传.14.s5", "chapter": "063_老子韩非列传", "para": "14", "seq": 5, "text": "今者所养非所用，所用非所养。", "len": 14}
{"sid": "063_老子韩非列传.14.s6", "chapter": "063_老子韩非列传", "para": "14", "seq": 6, "text": "悲廉直不容於邪枉之臣，观往者得失之变，故作孤愤、五蠹、内外储、说林、说难十馀万言。", "len": 41}
{"sid": "063_老子韩非列传.15.s1", "chapter": "063_老子韩非列传", "para": "15", "seq": 1, "text": "然韩非知说之难，为说难书甚具，终死於秦，不能自脱。", "len": 25}
{"sid": "063_老子韩非列传.16.s1", "chapter": "063_老子韩非列传", "para": "16", "seq": 1, "text": "说难曰：", "len": 4}
{"sid": "063_老子韩非列传.17.s1", "chapter": "063_老子韩非列传", "para": "17", "seq": 1, "text": "凡说之难，非吾知之有以说之难也；又非吾辩之难能明吾意之难也；又非吾敢横失能尽之难也。", "len": 42}
{"sid": "063_老子韩非列传.17.s2", "chapter": "063_老子韩非列传", "para": "17", "seq": 2, "text": "凡说之难，在知所说之心，可以吾说当之。", "len": 19}
{"sid": "063_老子韩非列传.18.s1", "chapter": "063_老子韩非列传", "para": "18", "seq": 1, "text": "所说出於为名高者也，而说之以厚利，则见下节而遇卑贱，必弃远矣。", "len": 31}
{"sid": "063_老子韩非列传.18.s2", "chapter": "063_老子韩非列传", "para": "18", "seq": 2, "text": "所说出於厚利者也。", "len": 9}
{"sid": "063_老子韩非列传.18.s3", "chapter": "063_老子韩非列传", "para": "18", "seq": 3, "text": "而说之以名高，则见无心而远事情，必不收矣。", "len": 21}
{"sid": "063_老子韩非列传.18.s4", "chapter": "063_老子韩非列传", "para": "18", "seq": 4, "text": "所说实为厚利而显为名高者也，而说之以名高，则阳收其身而实疏之；若说之以厚利，则阴用其言而显弃其身。", "len": 49}
{"sid": "063_老子韩非列传.18.s5", "chapter": "063_老子韩非列传", "para": "18", "seq": 5, "text": "此之不可不知也。", "len": 8}
{"sid": "063_老子韩非列传.19.s1", "chapter": "063_老子韩非列传", "para": "19", "seq": 1, "text": "夫事以密成，语以泄败。", "len": 11}
{"sid": "063_老子韩非列传.19.s2", "chapter": "063_老子韩非列传", "para": "19", "seq": 2, "text": "未必其身泄之也，而语及其所匿之事，如是者身危。", "len": 23}
{"sid": "063_老子韩非列传.19.s3", "chapter": "063_老子韩非列传", "para": "19", "seq": 3, "text": "贵人有过端，而说者明言善议以推其恶者，则身危。", "len": 23}
{"sid": "063_老子韩非列传.19.s4", "chapter": "063_老子韩非列传", "para": "19", "seq": 4, "text": "周泽未渥也而语极知，说行而有功则德亡，说不行而有败则见疑，如是者身危。", "len": 35}
{"sid": "063_老子韩非列传.19.s5", "chapter": "063_老子韩非列传", "para": "19", "seq": 5, "text": "夫贵人得计而欲自以为功，说者与知焉，则身危。", "len": 22}
{"sid": "063_老子韩非列传.19.s6", "chapter": "063_老子韩非列传", "para": "19", "seq": 6, "text": "彼显有所出事，乃自以为也故，说者与知焉，则身危。", "len": 24}
{"sid": "063_老子韩非列传.19.s7", "chapter": "063_老子韩非列传", "para": "19", "seq": 7, "text": "彊之以其所必不为，止之以其所不能已者，身危。", "len": 22}
{"sid": "063_老子韩非列传.19.s8", "chapter": "063_老子韩非列传", "para": "19", "seq": 8, "text": "故曰：与之论大人，则以为间己；与之论细人，则以为粥权。", "len": 27}
{"sid": "063_老子韩非列传.19.s9", "chapter": "063_老子韩非列传", "para": "19", "seq": 9, "text": "论其所爱，则以为借资；论其所憎，则以为尝己。", "len": 22}
{"sid": "063_老子韩非列传.19.s10", "chapter": "063_老子韩非列传", "para": "19", "seq": 10, "text": "径省其辞，则不知而屈之；汎滥博文，则多而久之。", "len": 23}
{"sid": "063_老子韩非列传.19.s11", "chapter": "063_老子韩非列传", "para": "19", "seq": 11, "text": "顺事陈意，则曰怯懦而不尽；虑事广肆，则曰草野而倨侮。", "len": 26}
{"sid": "063_老子韩非列传.19.s12", "chapter": "063_老子韩非列传", "para": "19", "seq": 12, "text": "此说之难，不可不知也。", "len": 11}
{"sid": "063_老子韩非列传.20.s1", "chapter": "063_老子韩非列传", "para": "20", "seq": 1, "text": "凡说之务，在知饰所说之所敬，而灭其所丑。", "len": 20}
{"sid": "063_老子韩非列传.20.s2", "chapter": "063_老子韩非列传", "para": "20", "seq": 2, "text": "彼自知其计，则毋以其失穷之；自勇其断，则毋以其敌怒之；自多其力，则毋以其难概之。", "len": 40}
{"sid": "063_老子韩非列传.20.s3", "chapter": "063_老子韩非列传", "para": "20", "seq": 3, "text": "规异事与同计，誉异人与同行者，则以饰之无伤也。", "len": 23}
{"sid": "063_老子韩非列传.20.s4", "chapter": "063_老子韩非列传", "para": "20", "seq": 4, "text": "有与同失者，则明饰其无失也。", "len": 14}
{"sid": "063_老子韩非列传.20.s5", "chapter": "063_老子韩非列传", "para": "20", "seq": 5, "text": "大忠无所拂悟，辞言无所击排，乃後申其辩知焉。", "len": 22}
{"sid": "063_老子韩非列传.20.s6", "chapter": "063_老子韩非列传", "para": "20", "seq": 6, "text": "此所以亲近不疑，知尽之难也。", "len": 14}
{"sid": "063_老子韩非列传.20.s7", "chapter": "063_老子韩非列传", "para": "20", "seq": 7, "text": "得旷日弥久，而周泽既渥，深计而不疑，交争而不罪，乃明计利害以致其功，直指是非以饰其身，以此相持，此说之成也。", "len": 54}
{"sid": "063_老子韩非列传.21.s1", "chapter": "063_老子韩非列传", "para": "21", "seq": 1, "text": "伊尹为庖，百里奚为虏，皆所由干其上也。", "len": 19}
{"sid": "063_老子韩非列传.21.s2", "chapter": "063_老子韩非列传", "para": "21", "seq": 2, "text": "故此二子者，皆圣人也，犹不能无役身而涉世如此其汙也，则非能仕之所设也。", "len": 35}
{"sid": "063_老子韩非列传.22.s1", "chapter": "063_老子韩非列传", "para": "22", "seq": 1, "text": "宋有富人，天雨墙坏。", "len": 10}
{"sid": "063_老子韩非列传.22.s2", "chapter": "063_老子韩非列传", "para": "22", "seq": 2, "text": "其子曰“不筑且有盗”，其邻人之父亦云，暮而果大亡其财，其家甚知其子而疑邻人之父。", "len": 40}
{"sid": "063_老子韩非列传.22.s3", "chapter": "063_老子韩非列传", "para": "22", "seq": 3, "text": "昔者郑武公欲伐胡，乃以其子妻之。", "len": 16}
{"sid": "063_老子韩非列传.22.s4", "chapter": "063_老子韩非列传", "para": "22", "seq": 4, "text": "因问群臣曰：“吾欲用兵，谁可伐者？", "len": 17}
{"sid": "063_老子韩非列传.22.s5", "chapter": "063_老子韩非列传", "para": "22", "seq": 5, "text": "” 关其思曰：“胡可伐。", "len": 12}
{"sid": "063_老子韩非列传.22.s6", "chapter": "063_老子韩非列传", "para": "22", "seq": 6, "text": "” 乃戮关其思，曰：“胡，兄弟之国也，子言伐之，何也？", "len": 27}
{"sid": "063_老子韩非列传.22.s7", "chapter": "063_老子韩非列传", "para": "22", "seq": 7, "text": "” 胡君闻之，以郑为亲己而不备郑。", "len": 17}
{"sid": "063_老子韩非列传.22.s8", "chapter": "063_老子韩非列传", "para": "22", "seq": 8, "text": "郑人袭胡，取之。", "len": 8}
{"sid": "063_老子韩非列传.22.s9", "chapter": "063_老子韩非列传", "para": "22", "seq": 9, "text": "此二说者，其知皆当矣，然而甚者为戮，薄者见疑。", "len": 23}
{"sid": "063_老子韩非列传.22.s10", "chapter": "063_老子韩非列传", "para": "22", "seq": 10, "text": "非知之难也，处知则难矣。", "len": 12}
{"sid": "063_老子韩非列传.23.s1", "chapter": "063_老子韩非列传", "para": "23", "seq": 1, "text": "昔者弥子瑕见爱於卫君。", "len": 11}
{"sid": "063_老子韩非列传.23.s2", "chapter": "063_老子韩非列传", "para": "23", "seq": 2, "text": "卫国之法，窃驾君车者罪至刖。", "len": 14}
{"sid": "063_老子韩非列传.23.s3", "chapter": "063_老子韩非列传", "para": "23", "seq": 3, "text": "既而弥子之母病，人闻，往夜告之，弥子矫驾君车而出。", "len": 25}
{"sid": "063_老子韩非列传.23.s4", "chapter": "063_老子韩非列传", "para": "23", "seq": 4, "text": "君闻之而贤之曰：“孝哉，为母之故而犯刖罪！", "len": 21}
{"sid": "063_老子韩非列传.23.s5", "chapter": "063_老子韩非列传", "para": "23", "seq": 5, "text": "” 与君游果园，弥子食桃而甘，不尽而奉君。", "len": 21}
{"sid": "063_老子韩非列传.23.s6", "chapter": "063_老子韩非列传", "para": "23", "seq": 6, "text": "君曰：“爱我哉，忘其口而念我！", "len": 15}
{"sid": "063_老子韩非列传.23.s7", "chapter": "063_老子韩非列传", "para": "23", "seq": 7, "text": "” 及弥子色衰而爱弛，得罪於君。", "len": 16}
{"sid": "063_老子韩非列传.23.s8", "chapter": "063_老子韩非列传", "para": "23", "seq": 8, "text": "君曰：“是尝矫驾吾车，又尝食我以其馀桃。", "len": 20}
{"sid": "063_老子韩非列传.23.s9", "chapter": "063_老子韩非列传", "para": "23", "seq": 9, "text": "” 故弥子之行未变於初也，前见贤而後获罪者，爱憎之至变也。", "len": 29}
{"sid": "063_老子韩非列传.23.s10", "chapter": "063_老子韩非列传", "para": "23", "seq": 10, "text": "故有爱於主，则知当而加亲；见憎於主，则罪当而加疏。", "len": 25}
{"sid": "063_老子韩非列传.23.s11", "chapter": "063_老子韩非列传", "para": "23", "seq": 11, "text": "故谏说之士不可不察爱憎之主而後说之矣。", "len": 19}
{"sid": "063_老子韩非列传.24.s1", "chapter": "063_老子韩非列传", "para": "24", "seq": 1, "text": "夫龙之为蟲也，可扰狎而骑也。", "len": 14}
{"sid": "063_老子韩非列传.24.s2", "chapter": "063_老子韩非列传", "para": "24", "seq": 2, "text": "然其喉下有逆鳞径尺，人有婴之，则必杀人。", "len": 20}
{"sid": "063_老子韩非列传.24.s3", "chapter": "063_老子韩非列传", "para": "24", "seq": 3, "text": "人主亦有逆鳞，说之者能无婴人主之逆鳞，则几矣。", "len": 23}
{"sid": "063_老子韩非列传.25.s1", "chapter": "063_老子韩非列传", "para": "25", "seq": 1, "text": "人或传其书至秦。", "len": 8}
{"sid": "063_老子韩非列传.25.s2", "chapter": "063_老子韩非列传", "para": "25", "seq": 2, "text": "秦王见孤愤、五蠹之书，曰：“嗟乎，寡人得见此人与之游，死不恨矣！", "len": 32}
{"sid": "063_老子韩非列传.25.s3", "chapter": "063_老子韩非列传", "para": "25", "seq": 3, "text": "” 李斯曰：“此韩非之所著书也。", "len": 16}
{"sid": "063_老子韩非列传.25.s4", "chapter": "063_老子韩非列传", "para": "25", "seq": 4, "text": "” 秦因急攻韩。", "len": 8}
{"sid": "063_老子韩非列传.25.s5", "chapter": "063_老子韩非列传", "para": "25", "seq": 5, "text": "韩王始不用非，及急，乃遣非使秦。", "len": 16}
{"sid": "063_老子韩非列传.25.s6", "chapter": "063_老子韩非列传", "para": "25", "seq": 6, "text": "秦王悦之，未信用。", "len": 9}
{"sid": "063_老子韩非列传.25.s7", "chapter": "063_老子韩非列传", "para": "25", "seq": 7, "text": "李斯、姚贾害之，毁之曰：“韩非，韩之诸公子也。", "len": 23}
{"sid": "063_老子韩非列传.25.s8", "chapter": "063_老子韩非列传", "para": "25", "seq": 8, "text": "今王欲并诸侯，非终为韩不为秦，此人之情也。", "len": 21}
{"sid": "063_老子韩非列传.25.s9", "chapter": "063_老子韩非列传", "para": "25", "seq": 9, "text": "今王不用，久留而归之，此自遗患也，不如以过法诛之。", "len": 25}
{"sid": "063_老子韩非列传.25.s10", "chapter": "063_老子韩非列传", "para": "25", "seq": 10, "text": "” 秦王以为然，下吏治非。", "len": 13}
{"sid": "063_老子韩非列传.25.s11", "chapter": "063_老子韩非列传", "para": "25", "seq": 11, "text": "李斯使人遗非药，使自杀。", "len": 12}
{"sid": "063_老子韩非列传.25.s12", "chapter": "063_老子韩非列传", "para": "25", "seq": 12, "text": "韩非欲自陈，不得见。", "len": 10}
{"sid": "063_老子韩非列传.25.s13", "chapter": "063_老子韩非列传", "para": "25", "seq": 13, "text": "秦王後悔之，使人赦之，非已死矣。", "len": 16}
{"sid": "063_老子韩非列传.26.s1", "chapter": "063_老子韩非列传", "para": "26", "seq": 1, "text": "申子、韩子皆著书，传於後世，学者多有。", "len": 19}
{"sid": "063_老子韩非列传.26.s2", "chapter": "063_老子韩非列传", "para": "26", "seq": 2, "text": "余独悲韩子为说难而不能自脱耳。", "len": 15}
{"sid": "063_老子韩非列传.26.s3", "chapter": "063_老子韩非列传", "para": "26", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "063_老子韩非列传.27.s1", "chapter": "063_老子韩非列传", "para": "27", "seq": 1, "text": "太史公曰：老子所贵道，虚无，因应变化於无为，故著书辞称微妙难识。", "len": 32}
{"sid": "063_老子韩非列传.27.s2", "chapter": "063_老子韩非列传", "para": "27", "seq": 2, "text": "庄子散道德，放论，要亦归之自然。", "len": 16}
{"sid": "063_老子韩非列传.27.s3", "chapter": "063_老子韩非列传", "para": "27", "seq": 3, "text": "申子卑卑，施之於名实。", "len": 11}
{"sid": "063_老子韩非列传.27.s4", "chapter": "063_老子韩非列传", "para": "27", "seq": 4, "text": "韩子引绳墨，切事情，明是非，其极惨礉少恩。", "len": 21}
{"sid": "063_老子韩非列传.27.s5", "chapter": "063_老子韩非列传", "para": "27", "seq": 5, "text": "皆原於道德之意，而老子深远矣。", "len": 15}
{"sid": "063_老子韩非列传.27.s6", "chapter": "063_老子韩非列传", "para": "27", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "063_老子韩非列传.28.s1", "chapter": "063_老子韩非列传", "para": "28", "seq": 1, "text": "伯阳立教，清净无为。", "len": 10}
{"sid": "063_老子韩非列传.28.s2", "chapter": "063_老子韩非列传", "para": "28", "seq": 2, "text": "道尊东鲁，迹窜西垂。", "len": 10}
{"sid": "063_老子韩非列传.28.s3", "chapter": "063_老子韩非列传", "para": "28", "seq": 3, "text": "庄蒙栩栩，申害卑卑。", "len": 10}
{"sid": "063_老子韩非列传.28.s4", "chapter": "063_老子韩非列传", "para": "28", "seq": 4, "text": "刑名有术，说难极知。", "len": 10}
{"sid": "063_老子韩非列传.28.s5", "chapter": "063_老子韩非列传", "para": "28", "seq": 5, "text": "悲彼周防，终亡李斯。", "len": 10}
{"sid": "063_老子韩非列传.28.s6", "chapter": "063_老子韩非列传", "para": "28", "seq": 6, "text": ":::", "len": 3}
