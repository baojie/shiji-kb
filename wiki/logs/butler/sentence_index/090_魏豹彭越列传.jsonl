{"sid": "090_魏豹彭越列传.1.s1", "chapter": "090_魏豹彭越列传", "para": "1", "seq": 1, "text": "魏豹者，故魏诸公子也。", "len": 11}
{"sid": "090_魏豹彭越列传.1.s2", "chapter": "090_魏豹彭越列传", "para": "1", "seq": 2, "text": "其兄魏咎，故魏时封为宁陵君。", "len": 14}
{"sid": "090_魏豹彭越列传.1.s3", "chapter": "090_魏豹彭越列传", "para": "1", "seq": 3, "text": "秦灭魏，迁咎为家人。", "len": 10}
{"sid": "090_魏豹彭越列传.1.s4", "chapter": "090_魏豹彭越列传", "para": "1", "seq": 4, "text": "陈胜之起王也，咎往从之。", "len": 12}
{"sid": "090_魏豹彭越列传.1.s5", "chapter": "090_魏豹彭越列传", "para": "1", "seq": 5, "text": "陈王使魏人周市徇魏地，魏地已下，欲相与立周市为魏王。", "len": 26}
{"sid": "090_魏豹彭越列传.1.s6", "chapter": "090_魏豹彭越列传", "para": "1", "seq": 6, "text": "周市曰：“天下昬乱，忠臣乃见。", "len": 15}
{"sid": "090_魏豹彭越列传.1.s7", "chapter": "090_魏豹彭越列传", "para": "1", "seq": 7, "text": "今天下共畔秦，其义必立魏王後乃可。", "len": 17}
{"sid": "090_魏豹彭越列传.1.s8", "chapter": "090_魏豹彭越列传", "para": "1", "seq": 8, "text": "” 齐、赵使车各五十乘，立周市为魏王。", "len": 19}
{"sid": "090_魏豹彭越列传.1.s9", "chapter": "090_魏豹彭越列传", "para": "1", "seq": 9, "text": "市辞不受，迎魏咎於陈。", "len": 11}
{"sid": "090_魏豹彭越列传.1.s10", "chapter": "090_魏豹彭越列传", "para": "1", "seq": 10, "text": "五反，陈王乃遣立咎为魏王。", "len": 13}
{"sid": "090_魏豹彭越列传.2.s1", "chapter": "090_魏豹彭越列传", "para": "2", "seq": 1, "text": "章邯已破陈王，乃进兵击魏王於临济。", "len": 17}
{"sid": "090_魏豹彭越列传.2.s2", "chapter": "090_魏豹彭越列传", "para": "2", "seq": 2, "text": "魏王乃使周市出请救於齐、楚。", "len": 14}
{"sid": "090_魏豹彭越列传.2.s3", "chapter": "090_魏豹彭越列传", "para": "2", "seq": 3, "text": "齐、楚遣项它、田巴将兵随市救魏。", "len": 16}
{"sid": "090_魏豹彭越列传.2.s4", "chapter": "090_魏豹彭越列传", "para": "2", "seq": 4, "text": "章邯遂击破杀周市等军，围临济。", "len": 15}
{"sid": "090_魏豹彭越列传.2.s5", "chapter": "090_魏豹彭越列传", "para": "2", "seq": 5, "text": "咎为其民约降。", "len": 7}
{"sid": "090_魏豹彭越列传.2.s6", "chapter": "090_魏豹彭越列传", "para": "2", "seq": 6, "text": "约定，咎自烧杀。", "len": 8}
{"sid": "090_魏豹彭越列传.3.s1", "chapter": "090_魏豹彭越列传", "para": "3", "seq": 1, "text": "魏豹亡走楚。", "len": 6}
{"sid": "090_魏豹彭越列传.3.s2", "chapter": "090_魏豹彭越列传", "para": "3", "seq": 2, "text": "楚怀王予魏豹数千人，复徇魏地。", "len": 15}
{"sid": "090_魏豹彭越列传.3.s3", "chapter": "090_魏豹彭越列传", "para": "3", "seq": 3, "text": "项羽已破秦，降章邯。", "len": 10}
{"sid": "090_魏豹彭越列传.3.s4", "chapter": "090_魏豹彭越列传", "para": "3", "seq": 4, "text": "豹下魏二十馀城，立豹为魏王。", "len": 14}
{"sid": "090_魏豹彭越列传.3.s5", "chapter": "090_魏豹彭越列传", "para": "3", "seq": 5, "text": "豹引精兵从项羽入关。", "len": 10}
{"sid": "090_魏豹彭越列传.3.s6", "chapter": "090_魏豹彭越列传", "para": "3", "seq": 6, "text": "汉元年，项羽封诸侯，欲有梁地，乃徙魏王豹於河东，都平阳，为西魏王。", "len": 33}
{"sid": "090_魏豹彭越列传.4.s1", "chapter": "090_魏豹彭越列传", "para": "4", "seq": 1, "text": "汉王还定三秦，渡临晋，魏王豹以国属焉，遂从击楚於彭城。", "len": 27}
{"sid": "090_魏豹彭越列传.4.s2", "chapter": "090_魏豹彭越列传", "para": "4", "seq": 2, "text": "汉败，还至荥阳，豹请归视亲病，至国，即绝河津畔汉。", "len": 25}
{"sid": "090_魏豹彭越列传.4.s3", "chapter": "090_魏豹彭越列传", "para": "4", "seq": 3, "text": "汉王闻魏豹反，方东忧楚，未及击，谓郦生曰：“缓颊往说魏豹，能下之，吾以万户封若。", "len": 40}
{"sid": "090_魏豹彭越列传.4.s4", "chapter": "090_魏豹彭越列传", "para": "4", "seq": 4, "text": "” 郦生说豹。", "len": 7}
{"sid": "090_魏豹彭越列传.4.s5", "chapter": "090_魏豹彭越列传", "para": "4", "seq": 5, "text": "豹谢曰：“人生一世间，如白驹过隙耳。", "len": 18}
{"sid": "090_魏豹彭越列传.4.s6", "chapter": "090_魏豹彭越列传", "para": "4", "seq": 6, "text": "今汉王慢而侮人，骂詈诸侯群臣如骂奴耳，非有上下礼节也，吾不忍复见也。", "len": 34}
{"sid": "090_魏豹彭越列传.4.s7", "chapter": "090_魏豹彭越列传", "para": "4", "seq": 7, "text": "” 於是汉王遣韩信击虏豹於河东，传诣荥阳，以豹国为郡。", "len": 27}
{"sid": "090_魏豹彭越列传.4.s8", "chapter": "090_魏豹彭越列传", "para": "4", "seq": 8, "text": "汉王令豹守荥阳。", "len": 8}
{"sid": "090_魏豹彭越列传.4.s9", "chapter": "090_魏豹彭越列传", "para": "4", "seq": 9, "text": "楚围之急，周苛遂杀魏豹。", "len": 12}
{"sid": "090_魏豹彭越列传.5.s1", "chapter": "090_魏豹彭越列传", "para": "5", "seq": 1, "text": "彭越者，昌邑人也，字仲。", "len": 12}
{"sid": "090_魏豹彭越列传.5.s2", "chapter": "090_魏豹彭越列传", "para": "5", "seq": 2, "text": "常渔钜野泽中，为群盗。", "len": 11}
{"sid": "090_魏豹彭越列传.5.s3", "chapter": "090_魏豹彭越列传", "para": "5", "seq": 3, "text": "陈胜、项梁之起，少年或谓越曰：“诸豪桀相立畔秦，仲可以来，亦效之。", "len": 33}
{"sid": "090_魏豹彭越列传.5.s4", "chapter": "090_魏豹彭越列传", "para": "5", "seq": 4, "text": "” 彭越曰：“两龙方斗，且待之。”", "len": 17}
{"sid": "090_魏豹彭越列传.6.s1", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 1, "text": "居岁馀，泽间少年相聚百馀人，往从彭越，曰：“请仲为长。", "len": 27}
{"sid": "090_魏豹彭越列传.6.s2", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 2, "text": "” 越谢曰：“臣不原与诸君。", "len": 14}
{"sid": "090_魏豹彭越列传.6.s3", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 3, "text": "” 少年彊请，乃许。", "len": 10}
{"sid": "090_魏豹彭越列传.6.s4", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 4, "text": "与期旦日日出会，後期者斩。", "len": 13}
{"sid": "090_魏豹彭越列传.6.s5", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 5, "text": "旦日日出，十馀人後，後者至日中。", "len": 16}
{"sid": "090_魏豹彭越列传.6.s6", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 6, "text": "於是越谢曰：“臣老，诸君彊以为长。", "len": 17}
{"sid": "090_魏豹彭越列传.6.s7", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 7, "text": "今期而多後，不可尽诛，诛最後者一人。", "len": 18}
{"sid": "090_魏豹彭越列传.6.s8", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 8, "text": "” 令校长斩之。", "len": 8}
{"sid": "090_魏豹彭越列传.6.s9", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 9, "text": "皆笑曰：“何至是？", "len": 9}
{"sid": "090_魏豹彭越列传.6.s10", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 10, "text": "请後不敢。", "len": 5}
{"sid": "090_魏豹彭越列传.6.s11", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 11, "text": "” 於是越乃引一人斩之，设坛祭，乃令徒属。", "len": 21}
{"sid": "090_魏豹彭越列传.6.s12", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 12, "text": "徒属皆大惊，畏越，莫敢仰视。", "len": 14}
{"sid": "090_魏豹彭越列传.6.s13", "chapter": "090_魏豹彭越列传", "para": "6", "seq": 13, "text": "乃行略地，收诸侯散卒，得千馀人。", "len": 16}
{"sid": "090_魏豹彭越列传.7.s1", "chapter": "090_魏豹彭越列传", "para": "7", "seq": 1, "text": "沛公之从砀北击昌邑，彭越助之。", "len": 15}
{"sid": "090_魏豹彭越列传.7.s2", "chapter": "090_魏豹彭越列传", "para": "7", "seq": 2, "text": "昌邑未下，沛公引兵西。", "len": 11}
{"sid": "090_魏豹彭越列传.7.s3", "chapter": "090_魏豹彭越列传", "para": "7", "seq": 3, "text": "彭越亦将其众居钜野中，收魏散卒。", "len": 16}
{"sid": "090_魏豹彭越列传.7.s4", "chapter": "090_魏豹彭越列传", "para": "7", "seq": 4, "text": "项籍入关，王诸侯，还归，彭越众万馀人毋所属。", "len": 22}
{"sid": "090_魏豹彭越列传.7.s5", "chapter": "090_魏豹彭越列传", "para": "7", "seq": 5, "text": "汉元年秋，齐王田荣畔项王，乃使人赐彭越将军印，使下济阴以击楚。", "len": 31}
{"sid": "090_魏豹彭越列传.7.s6", "chapter": "090_魏豹彭越列传", "para": "7", "seq": 6, "text": "楚命萧公角将兵击越，越大破楚军。", "len": 16}
{"sid": "090_魏豹彭越列传.7.s7", "chapter": "090_魏豹彭越列传", "para": "7", "seq": 7, "text": "汉王二年春，与魏王豹及诸侯东击楚，彭越将其兵三万馀人归汉於外黄。", "len": 32}
{"sid": "090_魏豹彭越列传.7.s8", "chapter": "090_魏豹彭越列传", "para": "7", "seq": 8, "text": "汉王曰：“彭将军收魏地得十馀城，欲急立魏後。", "len": 22}
{"sid": "090_魏豹彭越列传.7.s9", "chapter": "090_魏豹彭越列传", "para": "7", "seq": 9, "text": "今西魏王豹亦魏王咎从弟也，真魏後。", "len": 17}
{"sid": "090_魏豹彭越列传.7.s10", "chapter": "090_魏豹彭越列传", "para": "7", "seq": 10, "text": "” 乃拜彭越为魏相国，擅将其兵，略定梁地。", "len": 21}
{"sid": "090_魏豹彭越列传.8.s1", "chapter": "090_魏豹彭越列传", "para": "8", "seq": 1, "text": "汉王之败彭城解而西也，彭越皆复亡其所下城，独将其兵北居河上。", "len": 30}
{"sid": "090_魏豹彭越列传.8.s2", "chapter": "090_魏豹彭越列传", "para": "8", "seq": 2, "text": "汉王三年，彭越常往来为汉游兵，击楚，绝其後粮於梁地。", "len": 26}
{"sid": "090_魏豹彭越列传.8.s3", "chapter": "090_魏豹彭越列传", "para": "8", "seq": 3, "text": "汉四年冬，项王与汉王相距荥阳，彭越攻下睢阳、外黄十七城。", "len": 28}
{"sid": "090_魏豹彭越列传.8.s4", "chapter": "090_魏豹彭越列传", "para": "8", "seq": 4, "text": "项王闻之，乃使曹咎守成皋，自东收彭越所下城邑，皆复为楚。", "len": 28}
{"sid": "090_魏豹彭越列传.8.s5", "chapter": "090_魏豹彭越列传", "para": "8", "seq": 5, "text": "越将其兵北走穀城。", "len": 9}
{"sid": "090_魏豹彭越列传.8.s6", "chapter": "090_魏豹彭越列传", "para": "8", "seq": 6, "text": "汉五年秋，项王之南走阳夏，彭越复下昌邑旁二十馀城，得穀十馀万斛，以给汉王食。", "len": 38}
{"sid": "090_魏豹彭越列传.9.s1", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 1, "text": "汉王败，使使召彭越并力击楚。", "len": 14}
{"sid": "090_魏豹彭越列传.9.s2", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 2, "text": "越曰：“魏地初定，尚畏楚，未可去。", "len": 17}
{"sid": "090_魏豹彭越列传.9.s3", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 3, "text": "” 汉王追楚，为项籍所败固陵。", "len": 15}
{"sid": "090_魏豹彭越列传.9.s4", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 4, "text": "乃谓留侯曰：“诸侯兵不从，为之柰何？", "len": 18}
{"sid": "090_魏豹彭越列传.9.s5", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 5, "text": "” 留侯曰：“齐王信之立，非君王之意，信亦不自坚。", "len": 25}
{"sid": "090_魏豹彭越列传.9.s6", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 6, "text": "彭越本定梁地，功多，始君王以魏豹故，拜彭越为魏相国。", "len": 26}
{"sid": "090_魏豹彭越列传.9.s7", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 7, "text": "今豹死毋後，且越亦欲王，而君王不蚤定。", "len": 19}
{"sid": "090_魏豹彭越列传.9.s8", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 8, "text": "与此两国约：即胜楚，睢阳以北至穀城，皆以王彭相国；从陈以东傅海，与齐王信。", "len": 37}
{"sid": "090_魏豹彭越列传.9.s9", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 9, "text": "齐王信家在楚，此其意欲复得故邑。", "len": 16}
{"sid": "090_魏豹彭越列传.9.s10", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 10, "text": "君王能出捐此地许二人，二人今可致；即不能，事未可知也。", "len": 27}
{"sid": "090_魏豹彭越列传.9.s11", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 11, "text": "” 於是汉王乃发使使彭越，如留侯策。", "len": 18}
{"sid": "090_魏豹彭越列传.9.s12", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 12, "text": "使者至，彭越乃悉引兵会垓下，遂破楚。", "len": 18}
{"sid": "090_魏豹彭越列传.9.s13", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 13, "text": "项籍已死。", "len": 5}
{"sid": "090_魏豹彭越列传.9.s14", "chapter": "090_魏豹彭越列传", "para": "9", "seq": 14, "text": "春，立彭越为梁王，都定陶。", "len": 13}
{"sid": "090_魏豹彭越列传.10.s1", "chapter": "090_魏豹彭越列传", "para": "10", "seq": 1, "text": "六年，朝陈。", "len": 6}
{"sid": "090_魏豹彭越列传.10.s2", "chapter": "090_魏豹彭越列传", "para": "10", "seq": 2, "text": "九年，十年，皆来朝长安。", "len": 12}
{"sid": "090_魏豹彭越列传.11.s1", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 1, "text": "十年秋，陈豨反代地，高帝自往击，至邯郸，徵兵梁王。", "len": 25}
{"sid": "090_魏豹彭越列传.11.s2", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 2, "text": "梁王称病，使将将兵诣邯郸。", "len": 13}
{"sid": "090_魏豹彭越列传.11.s3", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 3, "text": "高帝怒，使人让梁王。", "len": 10}
{"sid": "090_魏豹彭越列传.11.s4", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 4, "text": "梁王恐，欲自往谢。", "len": 9}
{"sid": "090_魏豹彭越列传.11.s5", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 5, "text": "其将扈辄曰：“王始不往，见让而往，往则为禽矣。", "len": 23}
{"sid": "090_魏豹彭越列传.11.s6", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 6, "text": "不如遂发兵反。", "len": 7}
{"sid": "090_魏豹彭越列传.11.s7", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 7, "text": "” 梁王不听，称病。", "len": 10}
{"sid": "090_魏豹彭越列传.11.s8", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 8, "text": "梁王怒其太仆，欲斩之。", "len": 11}
{"sid": "090_魏豹彭越列传.11.s9", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 9, "text": "太仆亡走汉，告梁王与扈辄谋反。", "len": 15}
{"sid": "090_魏豹彭越列传.11.s10", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 10, "text": "於是上使使掩梁王，梁王不觉，捕梁王，囚之雒阳。", "len": 23}
{"sid": "090_魏豹彭越列传.11.s11", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 11, "text": "有司治反形己具，请论如法。", "len": 13}
{"sid": "090_魏豹彭越列传.11.s12", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 12, "text": "上赦以为庶人，传处蜀青衣。", "len": 13}
{"sid": "090_魏豹彭越列传.11.s13", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 13, "text": "西至郑，逢吕后从长安来，欲之雒阳，道见彭王。", "len": 22}
{"sid": "090_魏豹彭越列传.11.s14", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 14, "text": "彭王为吕后泣涕，自言无罪，原处故昌邑。", "len": 19}
{"sid": "090_魏豹彭越列传.11.s15", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 15, "text": "吕后许诺，与俱东至雒阳。", "len": 12}
{"sid": "090_魏豹彭越列传.11.s16", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 16, "text": "吕后白上曰：“彭王壮士，今徙之蜀，此自遗患，不如遂诛之。", "len": 28}
{"sid": "090_魏豹彭越列传.11.s17", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 17, "text": "妾谨与俱来。", "len": 6}
{"sid": "090_魏豹彭越列传.11.s18", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 18, "text": "” 於是吕后乃令其舍人彭越复谋反。", "len": 17}
{"sid": "090_魏豹彭越列传.11.s19", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 19, "text": "廷尉王恬开奏请族之。", "len": 10}
{"sid": "090_魏豹彭越列传.11.s20", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 20, "text": "上乃可，遂夷越宗族，国除。", "len": 13}
{"sid": "090_魏豹彭越列传.11.s21", "chapter": "090_魏豹彭越列传", "para": "11", "seq": 21, "text": "::: 太史公曰", "len": 8}
{"sid": "090_魏豹彭越列传.12.s1", "chapter": "090_魏豹彭越列传", "para": "12", "seq": 1, "text": "太史公曰：魏豹、彭越虽故贱，然已席卷千里，南面称孤，喋血乘胜日有闻矣。", "len": 35}
{"sid": "090_魏豹彭越列传.12.s2", "chapter": "090_魏豹彭越列传", "para": "12", "seq": 2, "text": "怀畔逆之意，及败，不死而虏囚，身被刑戮，何哉？", "len": 23}
{"sid": "090_魏豹彭越列传.12.s3", "chapter": "090_魏豹彭越列传", "para": "12", "seq": 3, "text": "中材已上且羞其行，况王者乎！", "len": 14}
{"sid": "090_魏豹彭越列传.12.s4", "chapter": "090_魏豹彭越列传", "para": "12", "seq": 4, "text": "彼无异故，智略绝人，独患无身耳。", "len": 16}
{"sid": "090_魏豹彭越列传.12.s5", "chapter": "090_魏豹彭越列传", "para": "12", "seq": 5, "text": "得摄尺寸之柄，其云蒸龙变，欲有所会其度，以故幽囚而不辞云。", "len": 29}
{"sid": "090_魏豹彭越列传.12.s6", "chapter": "090_魏豹彭越列传", "para": "12", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "090_魏豹彭越列传.13.s1", "chapter": "090_魏豹彭越列传", "para": "13", "seq": 1, "text": "魏咎兄弟，因时而王。", "len": 10}
{"sid": "090_魏豹彭越列传.13.s2", "chapter": "090_魏豹彭越列传", "para": "13", "seq": 2, "text": "豹後属楚，其国遂亡。", "len": 10}
{"sid": "090_魏豹彭越列传.13.s3", "chapter": "090_魏豹彭越列传", "para": "13", "seq": 3, "text": "仲起昌邑，归汉外黄。", "len": 10}
{"sid": "090_魏豹彭越列传.13.s4", "chapter": "090_魏豹彭越列传", "para": "13", "seq": 4, "text": "往来声援，再续军粮。", "len": 10}
{"sid": "090_魏豹彭越列传.13.s5", "chapter": "090_魏豹彭越列传", "para": "13", "seq": 5, "text": "徵兵不往，菹醢何伤。", "len": 10}
{"sid": "090_魏豹彭越列传.13.s6", "chapter": "090_魏豹彭越列传", "para": "13", "seq": 6, "text": ":::", "len": 3}
