{"sid": "111_卫将军骠骑列传.1.s1", "chapter": "111_卫将军骠骑列传", "para": "1", "seq": 1, "text": "大将军卫青者，平阳人也。", "len": 12}
{"sid": "111_卫将军骠骑列传.1.s2", "chapter": "111_卫将军骠骑列传", "para": "1", "seq": 2, "text": "其父郑季，为吏，给事平阳侯家，与侯妾卫媪通，生青。", "len": 25}
{"sid": "111_卫将军骠骑列传.2.s1", "chapter": "111_卫将军骠骑列传", "para": "2", "seq": 1, "text": "青同母兄卫长子，而姊卫子夫自平阳公主家得幸天子，故冒姓为卫氏。", "len": 31}
{"sid": "111_卫将军骠骑列传.2.s2", "chapter": "111_卫将军骠骑列传", "para": "2", "seq": 2, "text": "字仲卿。", "len": 4}
{"sid": "111_卫将军骠骑列传.2.s3", "chapter": "111_卫将军骠骑列传", "para": "2", "seq": 3, "text": "长子更字长君。", "len": 7}
{"sid": "111_卫将军骠骑列传.2.s4", "chapter": "111_卫将军骠骑列传", "para": "2", "seq": 4, "text": "长君母号为卫媪。", "len": 8}
{"sid": "111_卫将军骠骑列传.2.s5", "chapter": "111_卫将军骠骑列传", "para": "2", "seq": 5, "text": "媪长女卫孺，次女少兒，次女卫子夫。", "len": 17}
{"sid": "111_卫将军骠骑列传.2.s6", "chapter": "111_卫将军骠骑列传", "para": "2", "seq": 6, "text": "後子夫男弟步、广皆冒卫氏。", "len": 13}
{"sid": "111_卫将军骠骑列传.3.s1", "chapter": "111_卫将军骠骑列传", "para": "3", "seq": 1, "text": "青为侯家人，少时归其父，其父使牧羊。", "len": 18}
{"sid": "111_卫将军骠骑列传.3.s2", "chapter": "111_卫将军骠骑列传", "para": "3", "seq": 2, "text": "先母之子皆奴畜之，不以为兄弟数。", "len": 16}
{"sid": "111_卫将军骠骑列传.4.s1", "chapter": "111_卫将军骠骑列传", "para": "4", "seq": 1, "text": "青尝从入至甘泉居室，有一钳徒相青曰：“贵人也，官至封侯。", "len": 28}
{"sid": "111_卫将军骠骑列传.4.s2", "chapter": "111_卫将军骠骑列传", "para": "4", "seq": 2, "text": "” 青笑曰：“人奴之生，得毋笞骂即足矣，安得封侯事乎！”", "len": 28}
{"sid": "111_卫将军骠骑列传.5.s1", "chapter": "111_卫将军骠骑列传", "para": "5", "seq": 1, "text": "青壮，为侯家骑，从平阳主。", "len": 13}
{"sid": "111_卫将军骠骑列传.5.s2", "chapter": "111_卫将军骠骑列传", "para": "5", "seq": 2, "text": "建元二年春，青姊子夫得入宫幸上。", "len": 16}
{"sid": "111_卫将军骠骑列传.6.s1", "chapter": "111_卫将军骠骑列传", "para": "6", "seq": 1, "text": "皇后，堂邑大长公主女也，无子，妒。", "len": 17}
{"sid": "111_卫将军骠骑列传.6.s2", "chapter": "111_卫将军骠骑列传", "para": "6", "seq": 2, "text": "大长公主闻卫子夫幸，有身，妒之，乃使人捕青。", "len": 22}
{"sid": "111_卫将军骠骑列传.6.s3", "chapter": "111_卫将军骠骑列传", "para": "6", "seq": 3, "text": "青时给事建章，未知名。", "len": 11}
{"sid": "111_卫将军骠骑列传.7.s1", "chapter": "111_卫将军骠骑列传", "para": "7", "seq": 1, "text": "大长公主执囚青，欲杀之。", "len": 12}
{"sid": "111_卫将军骠骑列传.7.s2", "chapter": "111_卫将军骠骑列传", "para": "7", "seq": 2, "text": "其友骑郎公孙敖与壮士往篡取之，以故得不死。", "len": 21}
{"sid": "111_卫将军骠骑列传.8.s1", "chapter": "111_卫将军骠骑列传", "para": "8", "seq": 1, "text": "上闻，乃召青为建章监，侍中，及同母昆弟贵，赏赐数日间累千金。", "len": 30}
{"sid": "111_卫将军骠骑列传.8.s2", "chapter": "111_卫将军骠骑列传", "para": "8", "seq": 2, "text": "孺为太仆公孙贺妻。", "len": 9}
{"sid": "111_卫将军骠骑列传.8.s3", "chapter": "111_卫将军骠骑列传", "para": "8", "seq": 3, "text": "少兒故与陈掌通，上召贵掌。", "len": 13}
{"sid": "111_卫将军骠骑列传.8.s4", "chapter": "111_卫将军骠骑列传", "para": "8", "seq": 4, "text": "公孙敖由此益贵。", "len": 8}
{"sid": "111_卫将军骠骑列传.8.s5", "chapter": "111_卫将军骠骑列传", "para": "8", "seq": 5, "text": "子夫为夫人。", "len": 6}
{"sid": "111_卫将军骠骑列传.8.s6", "chapter": "111_卫将军骠骑列传", "para": "8", "seq": 6, "text": "青为大中大夫。", "len": 7}
{"sid": "111_卫将军骠骑列传.9.s1", "chapter": "111_卫将军骠骑列传", "para": "9", "seq": 1, "text": "元光五年，青为车骑将军，击匈奴，出上谷；太仆公孙贺为轻车将军，出云中；大中大夫公孙敖为骑将军，出代郡；卫尉李广为骁骑将军，出雁门：军各万骑。", "len": 70}
{"sid": "111_卫将军骠骑列传.10.s1", "chapter": "111_卫将军骠骑列传", "para": "10", "seq": 1, "text": "青至茏城，斩首虏数百。", "len": 11}
{"sid": "111_卫将军骠骑列传.10.s2", "chapter": "111_卫将军骠骑列传", "para": "10", "seq": 2, "text": "骑将军敖亡七千骑；卫尉李广为虏所得，得脱归：皆当斩，赎为庶人。", "len": 31}
{"sid": "111_卫将军骠骑列传.10.s3", "chapter": "111_卫将军骠骑列传", "para": "10", "seq": 3, "text": "贺亦无功。", "len": 5}
{"sid": "111_卫将军骠骑列传.11.s1", "chapter": "111_卫将军骠骑列传", "para": "11", "seq": 1, "text": "元朔元年春，卫夫人有男，立为皇后。", "len": 17}
{"sid": "111_卫将军骠骑列传.12.s1", "chapter": "111_卫将军骠骑列传", "para": "12", "seq": 1, "text": "其秋，青为车骑将军，出雁门，三万骑击匈奴，斩首虏数千人。", "len": 28}
{"sid": "111_卫将军骠骑列传.13.s1", "chapter": "111_卫将军骠骑列传", "para": "13", "seq": 1, "text": "明年，匈奴入杀辽西太守，虏略渔阳二千馀人，败韩将军军。", "len": 27}
{"sid": "111_卫将军骠骑列传.13.s2", "chapter": "111_卫将军骠骑列传", "para": "13", "seq": 2, "text": "汉令将军李息击之，出代；令车骑将军青出云中以西至高阙。", "len": 27}
{"sid": "111_卫将军骠骑列传.14.s1", "chapter": "111_卫将军骠骑列传", "para": "14", "seq": 1, "text": "遂略河南地，至于陇西，捕首虏数千，畜数十万，走白羊、楼烦王。", "len": 30}
{"sid": "111_卫将军骠骑列传.14.s2", "chapter": "111_卫将军骠骑列传", "para": "14", "seq": 2, "text": "遂以河南地为朔方郡。", "len": 10}
{"sid": "111_卫将军骠骑列传.15.s1", "chapter": "111_卫将军骠骑列传", "para": "15", "seq": 1, "text": "以三千八百户封青为长平侯。", "len": 13}
{"sid": "111_卫将军骠骑列传.15.s2", "chapter": "111_卫将军骠骑列传", "para": "15", "seq": 2, "text": "青校尉苏建有功，以千一百户封建为平陵侯。", "len": 20}
{"sid": "111_卫将军骠骑列传.15.s3", "chapter": "111_卫将军骠骑列传", "para": "15", "seq": 3, "text": "使建筑朔方城。", "len": 7}
{"sid": "111_卫将军骠骑列传.15.s4", "chapter": "111_卫将军骠骑列传", "para": "15", "seq": 4, "text": "青校尉张次公有功，封为岸头侯。", "len": 15}
{"sid": "111_卫将军骠骑列传.16.s1", "chapter": "111_卫将军骠骑列传", "para": "16", "seq": 1, "text": "天子曰：“匈奴逆天理，乱人伦，暴长虐老，以盗窃为务，行诈诸蛮夷，造谋藉兵，数为边害，故兴师遣将，以征厥罪。", "len": 53}
{"sid": "111_卫将军骠骑列传.17.s1", "chapter": "111_卫将军骠骑列传", "para": "17", "seq": 1, "text": "诗不云乎，“薄伐玁狁，至于太原”，“出车彭彭，城彼朔方”。", "len": 29}
{"sid": "111_卫将军骠骑列传.17.s2", "chapter": "111_卫将军骠骑列传", "para": "17", "seq": 2, "text": "今车骑将军青度西河至高阙，获首虏二千三百级，车辎畜产毕收为卤，已封为列侯，遂西定河南地，按榆谿旧塞，绝梓领，梁北河，讨蒲泥，破符离，斩轻锐之卒，捕伏听者三千七十一级，执讯获丑，驱马牛羊百有馀万，全甲兵而还，益封青三千户。”", "len": 111}
{"sid": "111_卫将军骠骑列传.18.s1", "chapter": "111_卫将军骠骑列传", "para": "18", "seq": 1, "text": "其明年，匈奴入杀代郡太守友，入略雁门千馀人。", "len": 22}
{"sid": "111_卫将军骠骑列传.18.s2", "chapter": "111_卫将军骠骑列传", "para": "18", "seq": 2, "text": "其明年，匈奴大入代、定襄、上郡，杀略汉数千人。", "len": 23}
{"sid": "111_卫将军骠骑列传.19.s1", "chapter": "111_卫将军骠骑列传", "para": "19", "seq": 1, "text": "其明年，元朔之五年春，汉令车骑将军青将三万骑，出高阙；卫尉苏建为游击将军，左内史李沮为彊弩将军，太仆公孙贺为骑将军，代相李蔡为轻车将军，皆领属车骑将军，俱出朔方；大行李息、岸头侯张次公为将军，出右北平：咸击匈奴。", "len": 106}
{"sid": "111_卫将军骠骑列传.20.s1", "chapter": "111_卫将军骠骑列传", "para": "20", "seq": 1, "text": "匈奴右贤王当卫青等兵，以为汉兵不能至此，饮醉。", "len": 23}
{"sid": "111_卫将军骠骑列传.20.s2", "chapter": "111_卫将军骠骑列传", "para": "20", "seq": 2, "text": "汉兵夜至，围右贤王，右贤王惊，夜逃，独与其爱妾一人壮骑数百驰，溃围北去。", "len": 36}
{"sid": "111_卫将军骠骑列传.21.s1", "chapter": "111_卫将军骠骑列传", "para": "21", "seq": 1, "text": "汉轻骑校尉郭成等逐数百里，不及，得右贤裨王十馀人，众男女万五千馀人，畜数千百万，於是引兵而还。", "len": 47}
{"sid": "111_卫将军骠骑列传.22.s1", "chapter": "111_卫将军骠骑列传", "para": "22", "seq": 1, "text": "至塞，天子使使者持大将军印，即军中拜车骑将军青为大将军，诸将皆以兵属大将军，大将军立号而归。", "len": 46}
{"sid": "111_卫将军骠骑列传.23.s1", "chapter": "111_卫将军骠骑列传", "para": "23", "seq": 1, "text": "天子曰：“大将军青躬率戎士，师大捷，获匈奴王十有馀人，益封青六千户。", "len": 34}
{"sid": "111_卫将军骠骑列传.23.s2", "chapter": "111_卫将军骠骑列传", "para": "23", "seq": 2, "text": "” 而封青子伉为宜春侯，青子不疑为阴安侯，青子登为发干侯。", "len": 29}
{"sid": "111_卫将军骠骑列传.24.s1", "chapter": "111_卫将军骠骑列传", "para": "24", "seq": 1, "text": "青固谢曰：“臣幸得待罪行间，赖陛下神灵，军大捷，皆诸校尉力战之功也。", "len": 34}
{"sid": "111_卫将军骠骑列传.24.s2", "chapter": "111_卫将军骠骑列传", "para": "24", "seq": 2, "text": "陛下幸已益封臣青。", "len": 9}
{"sid": "111_卫将军骠骑列传.24.s3", "chapter": "111_卫将军骠骑列传", "para": "24", "seq": 3, "text": "臣青子在唡褓中，未有勤劳，上幸列地封为三侯，非臣待罪行间所以劝士力战之意也。", "len": 38}
{"sid": "111_卫将军骠骑列传.24.s4", "chapter": "111_卫将军骠骑列传", "para": "24", "seq": 4, "text": "伉等三人何敢受封！”", "len": 10}
{"sid": "111_卫将军骠骑列传.25.s1", "chapter": "111_卫将军骠骑列传", "para": "25", "seq": 1, "text": "天子曰：“我非忘诸校尉功也，今固且图之。”", "len": 21}
{"sid": "111_卫将军骠骑列传.26.s1", "chapter": "111_卫将军骠骑列传", "para": "26", "seq": 1, "text": "乃诏御史曰：“护军都尉公孙敖三从大将军击匈奴，常护军，傅校获王，以千五百户封敖为合骑侯。", "len": 44}
{"sid": "111_卫将军骠骑列传.26.s2", "chapter": "111_卫将军骠骑列传", "para": "26", "seq": 2, "text": "都尉韩说从大将军出窳浑，至匈奴右贤王庭，为麾下搏战获王，以千三百户封说为龙嵒侯。", "len": 40}
{"sid": "111_卫将军骠骑列传.26.s3", "chapter": "111_卫将军骠骑列传", "para": "26", "seq": 3, "text": "骑将军公孙贺从大将军获王，以千三百户封贺为南窌侯。", "len": 25}
{"sid": "111_卫将军骠骑列传.26.s4", "chapter": "111_卫将军骠骑列传", "para": "26", "seq": 4, "text": "轻车将军李蔡再从大将军获王，以千六百户封蔡为乐安侯。", "len": 26}
{"sid": "111_卫将军骠骑列传.26.s5", "chapter": "111_卫将军骠骑列传", "para": "26", "seq": 5, "text": "校尉李朔，校尉赵不虞，校尉公孙戎奴，各三从大将军获王，以千三百户封朔为涉轵侯，以千三百户封不虞为随成侯，以千三百户封戎奴为从平侯。", "len": 65}
{"sid": "111_卫将军骠骑列传.26.s6", "chapter": "111_卫将军骠骑列传", "para": "26", "seq": 6, "text": "将军李沮、李息及校尉豆如意有功，赐爵关内侯，食邑各三百户。”", "len": 30}
{"sid": "111_卫将军骠骑列传.27.s1", "chapter": "111_卫将军骠骑列传", "para": "27", "seq": 1, "text": "其秋，匈奴入代，杀都尉硃英。", "len": 14}
{"sid": "111_卫将军骠骑列传.28.s1", "chapter": "111_卫将军骠骑列传", "para": "28", "seq": 1, "text": "其明年春，大将军青出定襄，合骑侯敖为中将军，太仆贺为左将军，翕侯赵信为前将军，卫尉苏建为右将军，郎中令李广为後将军，右内史李沮为彊弩将军，咸属大将军，斩首数千级而还。", "len": 83}
{"sid": "111_卫将军骠骑列传.29.s1", "chapter": "111_卫将军骠骑列传", "para": "29", "seq": 1, "text": "月馀，悉复出定襄击匈奴，斩首虏万馀人。", "len": 19}
{"sid": "111_卫将军骠骑列传.30.s1", "chapter": "111_卫将军骠骑列传", "para": "30", "seq": 1, "text": "右将军建、前将军信并军三千馀骑，独逢单于兵，与战一日馀，汉兵且尽。", "len": 33}
{"sid": "111_卫将军骠骑列传.31.s1", "chapter": "111_卫将军骠骑列传", "para": "31", "seq": 1, "text": "前将军故胡人，降为翕侯，见急，匈奴诱之，遂将其馀骑可八百，饹降单于。", "len": 34}
{"sid": "111_卫将军骠骑列传.32.s1", "chapter": "111_卫将军骠骑列传", "para": "32", "seq": 1, "text": "右将军苏建尽亡其军，独以身得亡去，自归大将军。", "len": 23}
{"sid": "111_卫将军骠骑列传.33.s1", "chapter": "111_卫将军骠骑列传", "para": "33", "seq": 1, "text": "大将军问其罪正闳、长史安、议郎周霸等：“建当云何？”", "len": 26}
{"sid": "111_卫将军骠骑列传.34.s1", "chapter": "111_卫将军骠骑列传", "para": "34", "seq": 1, "text": "霸曰：“自大将军出，未尝斩裨将。", "len": 16}
{"sid": "111_卫将军骠骑列传.34.s2", "chapter": "111_卫将军骠骑列传", "para": "34", "seq": 2, "text": "今建弃军，可斩以明将军之威。”", "len": 15}
{"sid": "111_卫将军骠骑列传.35.s1", "chapter": "111_卫将军骠骑列传", "para": "35", "seq": 1, "text": "闳、安曰：“不然。", "len": 9}
{"sid": "111_卫将军骠骑列传.35.s2", "chapter": "111_卫将军骠骑列传", "para": "35", "seq": 2, "text": "兵法” 小敌之坚，大敌之禽也”。", "len": 16}
{"sid": "111_卫将军骠骑列传.35.s3", "chapter": "111_卫将军骠骑列传", "para": "35", "seq": 3, "text": "今建以数千当单于数万，力战一日馀，士尽，不敢有二心，自归。", "len": 29}
{"sid": "111_卫将军骠骑列传.35.s4", "chapter": "111_卫将军骠骑列传", "para": "35", "seq": 4, "text": "自归而斩之，是示後无反意也。", "len": 14}
{"sid": "111_卫将军骠骑列传.35.s5", "chapter": "111_卫将军骠骑列传", "para": "35", "seq": 5, "text": "不当斩。”", "len": 5}
{"sid": "111_卫将军骠骑列传.36.s1", "chapter": "111_卫将军骠骑列传", "para": "36", "seq": 1, "text": "大将军曰：“青幸得以肺腑待罪行间，不患无威，而霸说我以明威，甚失臣意。", "len": 35}
{"sid": "111_卫将军骠骑列传.36.s2", "chapter": "111_卫将军骠骑列传", "para": "36", "seq": 2, "text": "且使臣职虽当斩将，以臣之尊宠而不敢自擅专诛於境外，而具归天子，天子自裁之，於是以见为人臣不敢专权，不亦可乎？”", "len": 55}
{"sid": "111_卫将军骠骑列传.37.s1", "chapter": "111_卫将军骠骑列传", "para": "37", "seq": 1, "text": "军吏皆曰“善”。", "len": 8}
{"sid": "111_卫将军骠骑列传.37.s2", "chapter": "111_卫将军骠骑列传", "para": "37", "seq": 2, "text": "遂囚建诣行在所。", "len": 8}
{"sid": "111_卫将军骠骑列传.37.s3", "chapter": "111_卫将军骠骑列传", "para": "37", "seq": 3, "text": "入塞罢兵。", "len": 5}
{"sid": "111_卫将军骠骑列传.38.s1", "chapter": "111_卫将军骠骑列传", "para": "38", "seq": 1, "text": "是岁也，大将军姊子霍去病年十八，幸，为天子侍中。", "len": 24}
{"sid": "111_卫将军骠骑列传.38.s2", "chapter": "111_卫将军骠骑列传", "para": "38", "seq": 2, "text": "善骑射，再从大将军，受诏与壮士，为剽姚校尉，与轻勇骑八百直弃大军数百里赴利，斩捕首虏过当。", "len": 45}
{"sid": "111_卫将军骠骑列传.39.s1", "chapter": "111_卫将军骠骑列传", "para": "39", "seq": 1, "text": "於是天子曰：“剽姚校尉去病斩首虏二千二十八级，及相国、当户，斩单于大父行籍若侯产，生捕季父罗姑比，再冠军，以千六百户封去病为冠军侯。", "len": 66}
{"sid": "111_卫将军骠骑列传.39.s2", "chapter": "111_卫将军骠骑列传", "para": "39", "seq": 2, "text": "上谷太守郝贤四从大将军，捕斩首虏二千馀人，以千一百户封贤为众利侯。”", "len": 34}
{"sid": "111_卫将军骠骑列传.40.s1", "chapter": "111_卫将军骠骑列传", "para": "40", "seq": 1, "text": "是岁，失两将军军，亡翕侯，军功不多，故大将军不益封。", "len": 26}
{"sid": "111_卫将军骠骑列传.40.s2", "chapter": "111_卫将军骠骑列传", "para": "40", "seq": 2, "text": "右将军建至，天子不诛，赦其罪，赎为庶人。", "len": 20}
{"sid": "111_卫将军骠骑列传.41.s1", "chapter": "111_卫将军骠骑列传", "para": "41", "seq": 1, "text": "大将军既还，赐千金。", "len": 10}
{"sid": "111_卫将军骠骑列传.41.s2", "chapter": "111_卫将军骠骑列传", "para": "41", "seq": 2, "text": "是时王夫人方幸於上，甯乘说大将军曰：“将军所以功未甚多，身食万户，三子皆为侯者，徒以皇后故也。", "len": 47}
{"sid": "111_卫将军骠骑列传.41.s3", "chapter": "111_卫将军骠骑列传", "para": "41", "seq": 3, "text": "今王夫人幸而宗族未富贵，原将军奉所赐千金为王夫人亲寿。”", "len": 28}
{"sid": "111_卫将军骠骑列传.42.s1", "chapter": "111_卫将军骠骑列传", "para": "42", "seq": 1, "text": "大将军乃以五百金为寿。", "len": 11}
{"sid": "111_卫将军骠骑列传.42.s2", "chapter": "111_卫将军骠骑列传", "para": "42", "seq": 2, "text": "天子闻之，问大将军，大将军以实言，上乃拜甯乘为东海都尉。", "len": 28}
{"sid": "111_卫将军骠骑列传.43.s1", "chapter": "111_卫将军骠骑列传", "para": "43", "seq": 1, "text": "张骞从大将军，以尝使大夏，留匈奴中久，导军，知善水草处，军得以无饥渴，因前使绝国功，封骞博望侯。", "len": 48}
{"sid": "111_卫将军骠骑列传.44.s1", "chapter": "111_卫将军骠骑列传", "para": "44", "seq": 1, "text": "冠军侯去病既侯三岁，元狩二年春，以冠军侯去病为骠骑将军，将万骑出陇西，有功。", "len": 38}
{"sid": "111_卫将军骠骑列传.45.s1", "chapter": "111_卫将军骠骑列传", "para": "45", "seq": 1, "text": "天子曰：“骠骑将军率戎士逾乌盭，讨遫濮，涉狐奴，历五王国，辎重人众慑慴者弗取，冀获单于子。", "len": 45}
{"sid": "111_卫将军骠骑列传.45.s2", "chapter": "111_卫将军骠骑列传", "para": "45", "seq": 2, "text": "转战六日，过焉支山千有馀里，合短兵，杀折兰王，斩卢胡王，诛全甲，执浑邪王子及相国、都尉，首虏八千馀级，收休屠祭天金人，益封去病二千户。”", "len": 68}
{"sid": "111_卫将军骠骑列传.46.s1", "chapter": "111_卫将军骠骑列传", "para": "46", "seq": 1, "text": "其夏，骠骑将军与合骑侯敖俱出北地，异道；博望侯张骞、郎中令李广俱出右北平，异道：皆击匈奴。", "len": 45}
{"sid": "111_卫将军骠骑列传.47.s1", "chapter": "111_卫将军骠骑列传", "para": "47", "seq": 1, "text": "郎中令将四千骑先至，博望侯将万骑在後至。", "len": 20}
{"sid": "111_卫将军骠骑列传.47.s2", "chapter": "111_卫将军骠骑列传", "para": "47", "seq": 2, "text": "匈奴左贤王将数万骑围郎中令，郎中令与战二日，死者过半，所杀亦过当。", "len": 33}
{"sid": "111_卫将军骠骑列传.47.s3", "chapter": "111_卫将军骠骑列传", "para": "47", "seq": 3, "text": "博望侯至，匈奴兵引去。", "len": 11}
{"sid": "111_卫将军骠骑列传.48.s1", "chapter": "111_卫将军骠骑列传", "para": "48", "seq": 1, "text": "博望侯坐行留，当斩，赎为庶人。", "len": 15}
{"sid": "111_卫将军骠骑列传.49.s1", "chapter": "111_卫将军骠骑列传", "para": "49", "seq": 1, "text": "而骠骑将军出北地，已遂深入，与合骑侯失道，不相得，骠骑将军逾居延至祁连山，捕首虏甚多。", "len": 43}
{"sid": "111_卫将军骠骑列传.50.s1", "chapter": "111_卫将军骠骑列传", "para": "50", "seq": 1, "text": "天子曰：“骠骑将军逾居延，遂过小月氏，攻祁连山，得酋涂王，以众降者二千五百人，斩首虏三万二百级，获五王，五王母，单于阏氏、王子五十九人，相国、将军、当户、都尉六十三人，师大率减什三，益封去病五千户。", "len": 99}
{"sid": "111_卫将军骠骑列传.50.s2", "chapter": "111_卫将军骠骑列传", "para": "50", "seq": 2, "text": "赐校尉从至小月氏爵左庶长。", "len": 13}
{"sid": "111_卫将军骠骑列传.50.s3", "chapter": "111_卫将军骠骑列传", "para": "50", "seq": 3, "text": "鹰击司马破奴再从骠骑将军斩濮王，捕稽沮王，千骑将得王、王母各一人，王子以下四十一人，捕虏三千三百三十人，前行捕虏千四百人，以千五百户封破奴为从骠侯。", "len": 74}
{"sid": "111_卫将军骠骑列传.50.s4", "chapter": "111_卫将军骠骑列传", "para": "50", "seq": 4, "text": "校尉句王高不识，从骠骑将军捕呼于屠王王子以下十一人，捕虏千七百六十八人，以千一百户封不识为宜冠侯。", "len": 49}
{"sid": "111_卫将军骠骑列传.50.s5", "chapter": "111_卫将军骠骑列传", "para": "50", "seq": 5, "text": "校尉仆多有功，封为煇渠侯。”", "len": 14}
{"sid": "111_卫将军骠骑列传.51.s1", "chapter": "111_卫将军骠骑列传", "para": "51", "seq": 1, "text": "合骑侯敖坐行留不与骠骑会，当斩，赎为庶人。", "len": 21}
{"sid": "111_卫将军骠骑列传.51.s2", "chapter": "111_卫将军骠骑列传", "para": "51", "seq": 2, "text": "诸宿将所将士马兵亦不如骠骑，骠骑所将常选，然亦敢深入，常与壮骑先其大军，军亦有天幸，未尝困绝也。", "len": 48}
{"sid": "111_卫将军骠骑列传.51.s3", "chapter": "111_卫将军骠骑列传", "para": "51", "seq": 3, "text": "然而诸宿将常坐留落不遇。", "len": 12}
{"sid": "111_卫将军骠骑列传.51.s4", "chapter": "111_卫将军骠骑列传", "para": "51", "seq": 4, "text": "由此骠骑日以亲贵，比大将军。", "len": 14}
{"sid": "111_卫将军骠骑列传.52.s1", "chapter": "111_卫将军骠骑列传", "para": "52", "seq": 1, "text": "其秋，单于怒浑邪王居西方数为汉所破，亡数万人，以骠骑之兵也。", "len": 30}
{"sid": "111_卫将军骠骑列传.52.s2", "chapter": "111_卫将军骠骑列传", "para": "52", "seq": 2, "text": "单于怒，欲召诛浑邪王。", "len": 11}
{"sid": "111_卫将军骠骑列传.53.s1", "chapter": "111_卫将军骠骑列传", "para": "53", "seq": 1, "text": "浑邪王与休屠王等谋欲降汉，使人先要边。", "len": 19}
{"sid": "111_卫将军骠骑列传.53.s2", "chapter": "111_卫将军骠骑列传", "para": "53", "seq": 2, "text": "是时大行李息将城河上，得浑邪王使，即驰传以闻。", "len": 23}
{"sid": "111_卫将军骠骑列传.54.s1", "chapter": "111_卫将军骠骑列传", "para": "54", "seq": 1, "text": "天子闻之，於是恐其以诈降而袭边，乃令骠骑将军将兵往迎之。", "len": 28}
{"sid": "111_卫将军骠骑列传.55.s1", "chapter": "111_卫将军骠骑列传", "para": "55", "seq": 1, "text": "骠骑既渡河，与浑邪王众相望。", "len": 14}
{"sid": "111_卫将军骠骑列传.55.s2", "chapter": "111_卫将军骠骑列传", "para": "55", "seq": 2, "text": "浑邪王裨将见汉军而多欲不降者，颇遁去。", "len": 19}
{"sid": "111_卫将军骠骑列传.56.s1", "chapter": "111_卫将军骠骑列传", "para": "56", "seq": 1, "text": "骠骑乃驰入与浑邪王相见，斩其欲亡者八千人，遂独遣浑邪王乘传先诣行在所，尽将其众渡河，降者数万，号称十万。", "len": 52}
{"sid": "111_卫将军骠骑列传.57.s1", "chapter": "111_卫将军骠骑列传", "para": "57", "seq": 1, "text": "既至长安，天子所以赏赐者数十巨万。", "len": 17}
{"sid": "111_卫将军骠骑列传.57.s2", "chapter": "111_卫将军骠骑列传", "para": "57", "seq": 2, "text": "封浑邪王万户，为漯阴侯。", "len": 12}
{"sid": "111_卫将军骠骑列传.57.s3", "chapter": "111_卫将军骠骑列传", "para": "57", "seq": 3, "text": "封其裨王呼毒尼为下摩侯，鹰庇为煇渠侯，禽犁为河綦侯，大当户铜离为常乐侯。", "len": 36}
{"sid": "111_卫将军骠骑列传.58.s1", "chapter": "111_卫将军骠骑列传", "para": "58", "seq": 1, "text": "於是天子嘉骠骑之功曰：“骠骑将军去病率师攻匈奴西域王浑邪，王及厥众萌咸相饹，率以军粮接食，并将控弦万有馀人，诛獟駻，获首虏八千馀级，降异国之王三十二人，战士不离伤，十万之众咸怀集服，仍与之劳，爰及河塞，庶几无患，幸既永绥矣。", "len": 112}
{"sid": "111_卫将军骠骑列传.58.s2", "chapter": "111_卫将军骠骑列传", "para": "58", "seq": 2, "text": "以千七百户益封骠骑将军。”", "len": 13}
{"sid": "111_卫将军骠骑列传.59.s1", "chapter": "111_卫将军骠骑列传", "para": "59", "seq": 1, "text": "减陇西、北地、上郡戍卒之半，以宽天下之繇。", "len": 21}
{"sid": "111_卫将军骠骑列传.60.s1", "chapter": "111_卫将军骠骑列传", "para": "60", "seq": 1, "text": "居顷之，乃分徙降者边五郡故塞外，而皆在河南，因其故俗，为属国。", "len": 31}
{"sid": "111_卫将军骠骑列传.61.s1", "chapter": "111_卫将军骠骑列传", "para": "61", "seq": 1, "text": "其明年，匈奴入右北平、定襄，杀略汉千馀人。", "len": 21}
{"sid": "111_卫将军骠骑列传.62.s1", "chapter": "111_卫将军骠骑列传", "para": "62", "seq": 1, "text": "其明年，天子与诸将议曰：“翕侯赵信为单于画计，常以为汉兵不能度幕轻留，今大发士卒，其势必得所欲。", "len": 48}
{"sid": "111_卫将军骠骑列传.62.s2", "chapter": "111_卫将军骠骑列传", "para": "62", "seq": 2, "text": "” 是岁元狩四年也。", "len": 10}
{"sid": "111_卫将军骠骑列传.63.s1", "chapter": "111_卫将军骠骑列传", "para": "63", "seq": 1, "text": "元狩四年春，上令大将军青、骠骑将军去病将各五万骑，步兵转者踵军数十万，而敢力战深入之士皆属骠骑。", "len": 48}
{"sid": "111_卫将军骠骑列传.64.s1", "chapter": "111_卫将军骠骑列传", "para": "64", "seq": 1, "text": "骠骑始为出定襄，当单于。", "len": 12}
{"sid": "111_卫将军骠骑列传.64.s2", "chapter": "111_卫将军骠骑列传", "para": "64", "seq": 2, "text": "捕虏言单于东，乃更令骠骑出代郡，令大将军出定襄。", "len": 24}
{"sid": "111_卫将军骠骑列传.65.s1", "chapter": "111_卫将军骠骑列传", "para": "65", "seq": 1, "text": "郎中令为前将军，太仆为左将军，主爵赵食其为右将军，平阳侯襄为後将军，皆属大将军。", "len": 40}
{"sid": "111_卫将军骠骑列传.66.s1", "chapter": "111_卫将军骠骑列传", "para": "66", "seq": 1, "text": "兵即度幕，人马凡五万骑，与骠骑等咸击匈奴单于。", "len": 23}
{"sid": "111_卫将军骠骑列传.67.s1", "chapter": "111_卫将军骠骑列传", "para": "67", "seq": 1, "text": "赵信为单于谋曰：“汉兵既度幕，人马罢，匈奴可坐收虏耳。", "len": 27}
{"sid": "111_卫将军骠骑列传.67.s2", "chapter": "111_卫将军骠骑列传", "para": "67", "seq": 2, "text": "” 乃悉远北其辎重，皆以精兵待幕北。", "len": 18}
{"sid": "111_卫将军骠骑列传.68.s1", "chapter": "111_卫将军骠骑列传", "para": "68", "seq": 1, "text": "而適值大将军军出塞千馀里，见单于兵陈而待，於是大将军令武刚车自环为营，而纵五千骑往当匈奴。", "len": 45}
{"sid": "111_卫将军骠骑列传.68.s2", "chapter": "111_卫将军骠骑列传", "para": "68", "seq": 2, "text": "匈奴亦纵可万骑。", "len": 8}
{"sid": "111_卫将军骠骑列传.69.s1", "chapter": "111_卫将军骠骑列传", "para": "69", "seq": 1, "text": "会日且入，大风起，沙砾击面，两军不相见，汉益纵左右翼绕单于。", "len": 30}
{"sid": "111_卫将军骠骑列传.70.s1", "chapter": "111_卫将军骠骑列传", "para": "70", "seq": 1, "text": "单于视汉兵多，而士马尚彊，战而匈奴不利，薄莫，单于遂乘六，壮骑可数百，直冒汉围西北驰去。", "len": 44}
{"sid": "111_卫将军骠骑列传.71.s1", "chapter": "111_卫将军骠骑列传", "para": "71", "seq": 1, "text": "时已昏，汉匈奴相纷挐，杀伤大当。", "len": 16}
{"sid": "111_卫将军骠骑列传.71.s2", "chapter": "111_卫将军骠骑列传", "para": "71", "seq": 2, "text": "汉军左校捕虏言单于未昏而去，汉军因发轻骑夜追之，大将军军因随其後。", "len": 33}
{"sid": "111_卫将军骠骑列传.71.s3", "chapter": "111_卫将军骠骑列传", "para": "71", "seq": 3, "text": "匈奴兵亦散走。", "len": 7}
{"sid": "111_卫将军骠骑列传.72.s1", "chapter": "111_卫将军骠骑列传", "para": "72", "seq": 1, "text": "迟明，行二百馀里，不得单于，颇捕斩首虏万馀级，遂至窴颜山赵信城，得匈奴积粟食军。", "len": 40}
{"sid": "111_卫将军骠骑列传.72.s2", "chapter": "111_卫将军骠骑列传", "para": "72", "seq": 2, "text": "军留一日而还，悉烧其城馀粟以归。", "len": 16}
{"sid": "111_卫将军骠骑列传.73.s1", "chapter": "111_卫将军骠骑列传", "para": "73", "seq": 1, "text": "大将军之与单于会也，而前将军广、右将军食其军别从东道，或失道，後击单于。", "len": 36}
{"sid": "111_卫将军骠骑列传.74.s1", "chapter": "111_卫将军骠骑列传", "para": "74", "seq": 1, "text": "大将军引还过幕南，乃得前将军、右将军。", "len": 19}
{"sid": "111_卫将军骠骑列传.74.s2", "chapter": "111_卫将军骠骑列传", "para": "74", "seq": 2, "text": "大将军欲使使归报，令长史簿责前将军广，广自杀。", "len": 23}
{"sid": "111_卫将军骠骑列传.74.s3", "chapter": "111_卫将军骠骑列传", "para": "74", "seq": 3, "text": "右将军至，下吏，赎为庶人。", "len": 13}
{"sid": "111_卫将军骠骑列传.75.s1", "chapter": "111_卫将军骠骑列传", "para": "75", "seq": 1, "text": "大将军军入塞，凡斩捕首虏万九千级。", "len": 17}
{"sid": "111_卫将军骠骑列传.76.s1", "chapter": "111_卫将军骠骑列传", "para": "76", "seq": 1, "text": "是时匈奴众失单于十馀日，右谷蠡王闻之，自立为单于。", "len": 25}
{"sid": "111_卫将军骠骑列传.76.s2", "chapter": "111_卫将军骠骑列传", "para": "76", "seq": 2, "text": "单于後得其众，右王乃去单于之号。", "len": 16}
{"sid": "111_卫将军骠骑列传.77.s1", "chapter": "111_卫将军骠骑列传", "para": "77", "seq": 1, "text": "骠骑将军亦将五万骑，车重与大将军军等，而无裨将。", "len": 24}
{"sid": "111_卫将军骠骑列传.77.s2", "chapter": "111_卫将军骠骑列传", "para": "77", "seq": 2, "text": "悉以李敢等为大校，当裨将，出代、右北平千馀里，直左方兵，所斩捕功已多大将军。", "len": 38}
{"sid": "111_卫将军骠骑列传.78.s1", "chapter": "111_卫将军骠骑列传", "para": "78", "seq": 1, "text": "军既还，天子曰：“骠骑将军去病率师，躬将所获荤粥之士，约轻赍，绝大幕，涉获章渠，以诛比车耆，转击左大将，斩获旗鼓，历涉离侯。", "len": 62}
{"sid": "111_卫将军骠骑列传.78.s2", "chapter": "111_卫将军骠骑列传", "para": "78", "seq": 2, "text": "济弓闾，获屯头王、韩王等三人，将军、相国、当户、都尉八十三人，封狼居胥山，禅於姑衍，登临翰海。", "len": 47}
{"sid": "111_卫将军骠骑列传.78.s3", "chapter": "111_卫将军骠骑列传", "para": "78", "seq": 3, "text": "执卤获丑七万有四百四十三级，师率减什三，取食於敌，逴行殊远而粮不绝，以五千八百户益封骠骑将军。”", "len": 48}
{"sid": "111_卫将军骠骑列传.79.s1", "chapter": "111_卫将军骠骑列传", "para": "79", "seq": 1, "text": "右北平太守路博德属骠骑将军，会与城，不失期，从至檮余山，斩首捕虏二千七百级，以千六百户封博德为符离侯。", "len": 51}
{"sid": "111_卫将军骠骑列传.80.s1", "chapter": "111_卫将军骠骑列传", "para": "80", "seq": 1, "text": "北地都尉邢山从骠骑将军获王，以千二百户封山为义阳侯。", "len": 26}
{"sid": "111_卫将军骠骑列传.81.s1", "chapter": "111_卫将军骠骑列传", "para": "81", "seq": 1, "text": "故归义因淳王复陆支、楼专王伊即靬皆从骠骑将军有功，以千三百户封复陆支为壮侯，以千八百户封伊即靬为众利侯。", "len": 52}
{"sid": "111_卫将军骠骑列传.82.s1", "chapter": "111_卫将军骠骑列传", "para": "82", "seq": 1, "text": "从骠侯破奴、昌武侯安稽从骠骑有功，益封各三百户。", "len": 24}
{"sid": "111_卫将军骠骑列传.82.s2", "chapter": "111_卫将军骠骑列传", "para": "82", "seq": 2, "text": "校尉敢得旗鼓，为关内侯，食邑二百户。", "len": 18}
{"sid": "111_卫将军骠骑列传.82.s3", "chapter": "111_卫将军骠骑列传", "para": "82", "seq": 3, "text": "校尉自为爵大庶长。", "len": 9}
{"sid": "111_卫将军骠骑列传.83.s1", "chapter": "111_卫将军骠骑列传", "para": "83", "seq": 1, "text": "军吏卒为官，赏赐甚多。", "len": 11}
{"sid": "111_卫将军骠骑列传.83.s2", "chapter": "111_卫将军骠骑列传", "para": "83", "seq": 2, "text": "而大将军不得益封，军吏卒皆无封侯者。", "len": 18}
{"sid": "111_卫将军骠骑列传.84.s1", "chapter": "111_卫将军骠骑列传", "para": "84", "seq": 1, "text": "两军之出塞，塞阅官及私马凡十四万匹，而复入塞者不满三万匹。", "len": 29}
{"sid": "111_卫将军骠骑列传.85.s1", "chapter": "111_卫将军骠骑列传", "para": "85", "seq": 1, "text": "乃益置大司马位，大将军、骠骑将军皆为大司马。", "len": 22}
{"sid": "111_卫将军骠骑列传.85.s2", "chapter": "111_卫将军骠骑列传", "para": "85", "seq": 2, "text": "定令，令骠骑将军秩禄与大将军等。", "len": 16}
{"sid": "111_卫将军骠骑列传.86.s1", "chapter": "111_卫将军骠骑列传", "para": "86", "seq": 1, "text": "自是之後，大将军青日退，而骠骑日益贵。", "len": 19}
{"sid": "111_卫将军骠骑列传.86.s2", "chapter": "111_卫将军骠骑列传", "para": "86", "seq": 2, "text": "举大将军故人门下多去事骠骑，辄得官爵，唯任安不肯。", "len": 25}
{"sid": "111_卫将军骠骑列传.87.s1", "chapter": "111_卫将军骠骑列传", "para": "87", "seq": 1, "text": "骠骑将军为人少言不泄，有气敢任。", "len": 16}
{"sid": "111_卫将军骠骑列传.87.s2", "chapter": "111_卫将军骠骑列传", "para": "87", "seq": 2, "text": "天子尝欲教之孙吴兵法，对曰：“顾方略何如耳，不至学古兵法。”", "len": 30}
{"sid": "111_卫将军骠骑列传.88.s1", "chapter": "111_卫将军骠骑列传", "para": "88", "seq": 1, "text": "天子为治第，令骠骑视之，对曰：“匈奴未灭，无以家为也。", "len": 27}
{"sid": "111_卫将军骠骑列传.88.s2", "chapter": "111_卫将军骠骑列传", "para": "88", "seq": 2, "text": "” 由此上益重爱之。", "len": 10}
{"sid": "111_卫将军骠骑列传.89.s1", "chapter": "111_卫将军骠骑列传", "para": "89", "seq": 1, "text": "然少而侍中，贵，不省士。", "len": 12}
{"sid": "111_卫将军骠骑列传.89.s2", "chapter": "111_卫将军骠骑列传", "para": "89", "seq": 2, "text": "其从军，天子为遣太官赍数十乘，既还，重车馀弃粱肉，而士有饥者。", "len": 31}
{"sid": "111_卫将军骠骑列传.89.s3", "chapter": "111_卫将军骠骑列传", "para": "89", "seq": 3, "text": "其在塞外，卒乏粮，或不能自振，而骠骑尚穿域蹋鞠。", "len": 24}
{"sid": "111_卫将军骠骑列传.89.s4", "chapter": "111_卫将军骠骑列传", "para": "89", "seq": 4, "text": "事多此类。", "len": 5}
{"sid": "111_卫将军骠骑列传.90.s1", "chapter": "111_卫将军骠骑列传", "para": "90", "seq": 1, "text": "大将军为人仁善退让，以和柔自媚於上，然天下未有称也。", "len": 26}
{"sid": "111_卫将军骠骑列传.91.s1", "chapter": "111_卫将军骠骑列传", "para": "91", "seq": 1, "text": "骠骑将军自四年军後三年，元狩六年而卒。", "len": 19}
{"sid": "111_卫将军骠骑列传.92.s1", "chapter": "111_卫将军骠骑列传", "para": "92", "seq": 1, "text": "天子悼之，发属国玄甲军，陈自长安至茂陵，为冢象祁连山。", "len": 27}
{"sid": "111_卫将军骠骑列传.92.s2", "chapter": "111_卫将军骠骑列传", "para": "92", "seq": 2, "text": "谥之，并武与广地曰景桓侯。", "len": 13}
{"sid": "111_卫将军骠骑列传.93.s1", "chapter": "111_卫将军骠骑列传", "para": "93", "seq": 1, "text": "子嬗代侯。", "len": 5}
{"sid": "111_卫将军骠骑列传.93.s2", "chapter": "111_卫将军骠骑列传", "para": "93", "seq": 2, "text": "嬗少，字子侯，上爱之，幸其壮而将之。", "len": 18}
{"sid": "111_卫将军骠骑列传.93.s3", "chapter": "111_卫将军骠骑列传", "para": "93", "seq": 3, "text": "居六岁，元封元年，嬗卒，谥哀侯。", "len": 16}
{"sid": "111_卫将军骠骑列传.93.s4", "chapter": "111_卫将军骠骑列传", "para": "93", "seq": 4, "text": "无子，绝，国除。", "len": 8}
{"sid": "111_卫将军骠骑列传.94.s1", "chapter": "111_卫将军骠骑列传", "para": "94", "seq": 1, "text": "自骠骑将军死後，大将军长子宜春侯伉坐法失侯。", "len": 22}
{"sid": "111_卫将军骠骑列传.95.s1", "chapter": "111_卫将军骠骑列传", "para": "95", "seq": 1, "text": "後五岁，伉弟二人，阴安侯不疑及发干侯登皆坐酎金失侯。", "len": 26}
{"sid": "111_卫将军骠骑列传.95.s2", "chapter": "111_卫将军骠骑列传", "para": "95", "seq": 2, "text": "失侯後二岁，冠军侯国除。", "len": 12}
{"sid": "111_卫将军骠骑列传.96.s1", "chapter": "111_卫将军骠骑列传", "para": "96", "seq": 1, "text": "其後四年，大将军青卒，谥为烈侯。", "len": 16}
{"sid": "111_卫将军骠骑列传.96.s2", "chapter": "111_卫将军骠骑列传", "para": "96", "seq": 2, "text": "子伉代为长平侯。", "len": 8}
{"sid": "111_卫将军骠骑列传.97.s1", "chapter": "111_卫将军骠骑列传", "para": "97", "seq": 1, "text": "自大将军围单于之後，十四年而卒。", "len": 16}
{"sid": "111_卫将军骠骑列传.97.s2", "chapter": "111_卫将军骠骑列传", "para": "97", "seq": 2, "text": "竟不复击匈奴者，以汉马少，而方南诛两越，东伐朝鲜，击羌、西南夷，以故久不伐胡。", "len": 39}
{"sid": "111_卫将军骠骑列传.98.s1", "chapter": "111_卫将军骠骑列传", "para": "98", "seq": 1, "text": "大将军以其得尚平阳长公主故，长平侯伉代侯。", "len": 21}
{"sid": "111_卫将军骠骑列传.98.s2", "chapter": "111_卫将军骠骑列传", "para": "98", "seq": 2, "text": "六岁，坐法失侯。", "len": 8}
{"sid": "111_卫将军骠骑列传.99.s1", "chapter": "111_卫将军骠骑列传", "para": "99", "seq": 1, "text": "左方两大将军及诸裨将名：", "len": 12}
{"sid": "111_卫将军骠骑列传.100.s1", "chapter": "111_卫将军骠骑列传", "para": "100", "seq": 1, "text": "最大将军青，凡七出击匈奴，斩捕首虏五万馀级。", "len": 22}
{"sid": "111_卫将军骠骑列传.100.s2", "chapter": "111_卫将军骠骑列传", "para": "100", "seq": 2, "text": "一与单于战，收河南地，遂置朔方郡，再益封，凡万一千八百户。", "len": 29}
{"sid": "111_卫将军骠骑列传.100.s3", "chapter": "111_卫将军骠骑列传", "para": "100", "seq": 3, "text": "封三子为侯，侯千三百户。", "len": 12}
{"sid": "111_卫将军骠骑列传.100.s4", "chapter": "111_卫将军骠骑列传", "para": "100", "seq": 4, "text": "并之，万五千七百户。", "len": 10}
{"sid": "111_卫将军骠骑列传.100.s5", "chapter": "111_卫将军骠骑列传", "para": "100", "seq": 5, "text": "其校尉裨将以从大将军侯者九人。", "len": 15}
{"sid": "111_卫将军骠骑列传.100.s6", "chapter": "111_卫将军骠骑列传", "para": "100", "seq": 6, "text": "其裨将及校尉已为将者十四人。", "len": 14}
{"sid": "111_卫将军骠骑列传.100.s7", "chapter": "111_卫将军骠骑列传", "para": "100", "seq": 7, "text": "为裨将者曰李广，自有传。", "len": 12}
{"sid": "111_卫将军骠骑列传.100.s8", "chapter": "111_卫将军骠骑列传", "para": "100", "seq": 8, "text": "无传者曰：", "len": 5}
{"sid": "111_卫将军骠骑列传.101.s1", "chapter": "111_卫将军骠骑列传", "para": "101", "seq": 1, "text": "将军公孙贺。", "len": 6}
{"sid": "111_卫将军骠骑列传.101.s2", "chapter": "111_卫将军骠骑列传", "para": "101", "seq": 2, "text": "贺，义渠人，其先胡种。", "len": 11}
{"sid": "111_卫将军骠骑列传.101.s3", "chapter": "111_卫将军骠骑列传", "para": "101", "seq": 3, "text": "贺父浑邪，景帝时为平曲侯，坐法失侯。", "len": 18}
{"sid": "111_卫将军骠骑列传.102.s1", "chapter": "111_卫将军骠骑列传", "para": "102", "seq": 1, "text": "贺，武帝为太子时舍人。", "len": 11}
{"sid": "111_卫将军骠骑列传.102.s2", "chapter": "111_卫将军骠骑列传", "para": "102", "seq": 2, "text": "武帝立八岁，以太仆为轻车将军，军马邑。", "len": 19}
{"sid": "111_卫将军骠骑列传.102.s3", "chapter": "111_卫将军骠骑列传", "para": "102", "seq": 3, "text": "後四岁，以轻车将军出云中。", "len": 13}
{"sid": "111_卫将军骠骑列传.102.s4", "chapter": "111_卫将军骠骑列传", "para": "102", "seq": 4, "text": "後五岁，以骑将军从大将军有功，封为南窌侯。", "len": 21}
{"sid": "111_卫将军骠骑列传.103.s1", "chapter": "111_卫将军骠骑列传", "para": "103", "seq": 1, "text": "後一岁，以左将军再从大将军出定襄，无功。", "len": 20}
{"sid": "111_卫将军骠骑列传.103.s2", "chapter": "111_卫将军骠骑列传", "para": "103", "seq": 2, "text": "後四岁，以坐酎金失侯。", "len": 11}
{"sid": "111_卫将军骠骑列传.103.s3", "chapter": "111_卫将军骠骑列传", "para": "103", "seq": 3, "text": "後八岁，以浮沮将军出五原二千馀里，无功。", "len": 20}
{"sid": "111_卫将军骠骑列传.104.s1", "chapter": "111_卫将军骠骑列传", "para": "104", "seq": 1, "text": "後八岁，以太仆为丞相，封葛绎侯。", "len": 16}
{"sid": "111_卫将军骠骑列传.104.s2", "chapter": "111_卫将军骠骑列传", "para": "104", "seq": 2, "text": "贺七为将军，出击匈奴无大功，而再侯，为丞相。", "len": 22}
{"sid": "111_卫将军骠骑列传.104.s3", "chapter": "111_卫将军骠骑列传", "para": "104", "seq": 3, "text": "坐子敬声与阳石公主奸，为巫蛊，族灭，无後。", "len": 21}
{"sid": "111_卫将军骠骑列传.105.s1", "chapter": "111_卫将军骠骑列传", "para": "105", "seq": 1, "text": "将军李息，郁郅人。", "len": 9}
{"sid": "111_卫将军骠骑列传.105.s2", "chapter": "111_卫将军骠骑列传", "para": "105", "seq": 2, "text": "事景帝。", "len": 4}
{"sid": "111_卫将军骠骑列传.105.s3", "chapter": "111_卫将军骠骑列传", "para": "105", "seq": 3, "text": "至武帝立八岁，为材官将军，军马邑；後六岁，为将军，出代；後三岁，为将军，从大将军出朔方：皆无功。", "len": 48}
{"sid": "111_卫将军骠骑列传.105.s4", "chapter": "111_卫将军骠骑列传", "para": "105", "seq": 4, "text": "凡三为将军，其後常为大行。", "len": 13}
{"sid": "111_卫将军骠骑列传.106.s1", "chapter": "111_卫将军骠骑列传", "para": "106", "seq": 1, "text": "将军公孙敖，义渠人。", "len": 10}
{"sid": "111_卫将军骠骑列传.106.s2", "chapter": "111_卫将军骠骑列传", "para": "106", "seq": 2, "text": "以郎事武帝。", "len": 6}
{"sid": "111_卫将军骠骑列传.106.s3", "chapter": "111_卫将军骠骑列传", "para": "106", "seq": 3, "text": "武帝立十二岁，为骑将军，出代，亡卒七千人，当斩，赎为庶人。", "len": 29}
{"sid": "111_卫将军骠骑列传.107.s1", "chapter": "111_卫将军骠骑列传", "para": "107", "seq": 1, "text": "後五岁，以校尉从大将军有功，封为合骑侯。", "len": 20}
{"sid": "111_卫将军骠骑列传.107.s2", "chapter": "111_卫将军骠骑列传", "para": "107", "seq": 2, "text": "後一岁，以中将军从大将军，再出定襄，无功。", "len": 21}
{"sid": "111_卫将军骠骑列传.108.s1", "chapter": "111_卫将军骠骑列传", "para": "108", "seq": 1, "text": "後二岁，以将军出北地，後骠骑期，当斩，赎为庶人。", "len": 24}
{"sid": "111_卫将军骠骑列传.108.s2", "chapter": "111_卫将军骠骑列传", "para": "108", "seq": 2, "text": "後二岁，以校尉从大将军，无功。", "len": 15}
{"sid": "111_卫将军骠骑列传.109.s1", "chapter": "111_卫将军骠骑列传", "para": "109", "seq": 1, "text": "後十四岁，以因杅将军筑受降城。", "len": 15}
{"sid": "111_卫将军骠骑列传.109.s2", "chapter": "111_卫将军骠骑列传", "para": "109", "seq": 2, "text": "七岁，复以因杅将军再出击匈奴，至余吾，亡士卒多，下吏，当斩，诈死，亡居民间五六岁。", "len": 41}
{"sid": "111_卫将军骠骑列传.110.s1", "chapter": "111_卫将军骠骑列传", "para": "110", "seq": 1, "text": "後发觉，复系。", "len": 7}
{"sid": "111_卫将军骠骑列传.110.s2", "chapter": "111_卫将军骠骑列传", "para": "110", "seq": 2, "text": "坐妻为巫蛊，族。", "len": 8}
{"sid": "111_卫将军骠骑列传.110.s3", "chapter": "111_卫将军骠骑列传", "para": "110", "seq": 3, "text": "凡四为将军，出击匈奴，一侯。", "len": 14}
{"sid": "111_卫将军骠骑列传.111.s1", "chapter": "111_卫将军骠骑列传", "para": "111", "seq": 1, "text": "将军李沮，云中人。", "len": 9}
{"sid": "111_卫将军骠骑列传.111.s2", "chapter": "111_卫将军骠骑列传", "para": "111", "seq": 2, "text": "事景帝。", "len": 4}
{"sid": "111_卫将军骠骑列传.111.s3", "chapter": "111_卫将军骠骑列传", "para": "111", "seq": 3, "text": "武帝立十七岁，以左内史为彊弩将军。", "len": 17}
{"sid": "111_卫将军骠骑列传.111.s4", "chapter": "111_卫将军骠骑列传", "para": "111", "seq": 4, "text": "後一岁，复为彊弩将军。", "len": 11}
{"sid": "111_卫将军骠骑列传.112.s1", "chapter": "111_卫将军骠骑列传", "para": "112", "seq": 1, "text": "将军李蔡，成纪人也。", "len": 10}
{"sid": "111_卫将军骠骑列传.112.s2", "chapter": "111_卫将军骠骑列传", "para": "112", "seq": 2, "text": "事孝文帝、景帝、武帝。", "len": 11}
{"sid": "111_卫将军骠骑列传.112.s3", "chapter": "111_卫将军骠骑列传", "para": "112", "seq": 3, "text": "以轻车将军从大将军有功，封为乐安侯。", "len": 18}
{"sid": "111_卫将军骠骑列传.112.s4", "chapter": "111_卫将军骠骑列传", "para": "112", "seq": 4, "text": "已为丞相，坐法死。", "len": 9}
{"sid": "111_卫将军骠骑列传.113.s1", "chapter": "111_卫将军骠骑列传", "para": "113", "seq": 1, "text": "将军张次公，河东人。", "len": 10}
{"sid": "111_卫将军骠骑列传.113.s2", "chapter": "111_卫将军骠骑列传", "para": "113", "seq": 2, "text": "以校尉从卫将军青有功，封为岸头侯。", "len": 17}
{"sid": "111_卫将军骠骑列传.113.s3", "chapter": "111_卫将军骠骑列传", "para": "113", "seq": 3, "text": "其後太后崩，为将军，军北军。", "len": 14}
{"sid": "111_卫将军骠骑列传.114.s1", "chapter": "111_卫将军骠骑列传", "para": "114", "seq": 1, "text": "後一岁，为将军，从大将军，再为将军，坐法失侯。", "len": 23}
{"sid": "111_卫将军骠骑列传.114.s2", "chapter": "111_卫将军骠骑列传", "para": "114", "seq": 2, "text": "次公父隆，轻车武射也。", "len": 11}
{"sid": "111_卫将军骠骑列传.114.s3", "chapter": "111_卫将军骠骑列传", "para": "114", "seq": 3, "text": "以善射，景帝幸近之也。", "len": 11}
{"sid": "111_卫将军骠骑列传.115.s1", "chapter": "111_卫将军骠骑列传", "para": "115", "seq": 1, "text": "将军苏建，杜陵人。", "len": 9}
{"sid": "111_卫将军骠骑列传.115.s2", "chapter": "111_卫将军骠骑列传", "para": "115", "seq": 2, "text": "以校尉从卫将军青，有功，为平陵侯，以将军筑朔方。", "len": 24}
{"sid": "111_卫将军骠骑列传.116.s1", "chapter": "111_卫将军骠骑列传", "para": "116", "seq": 1, "text": "後四岁，为游击将军，从大将军出朔方。", "len": 18}
{"sid": "111_卫将军骠骑列传.116.s2", "chapter": "111_卫将军骠骑列传", "para": "116", "seq": 2, "text": "後一岁，以右将军再从大将军出定襄，亡翕侯，失军，当斩，赎为庶人。", "len": 32}
{"sid": "111_卫将军骠骑列传.116.s3", "chapter": "111_卫将军骠骑列传", "para": "116", "seq": 3, "text": "其後为代郡太守，卒，冢在大犹乡。", "len": 16}
{"sid": "111_卫将军骠骑列传.117.s1", "chapter": "111_卫将军骠骑列传", "para": "117", "seq": 1, "text": "将军赵信，以匈奴相国降，为翕侯。", "len": 16}
{"sid": "111_卫将军骠骑列传.117.s2", "chapter": "111_卫将军骠骑列传", "para": "117", "seq": 2, "text": "武帝立十七岁，为前将军，与单于战，败，降匈奴。", "len": 23}
{"sid": "111_卫将军骠骑列传.118.s1", "chapter": "111_卫将军骠骑列传", "para": "118", "seq": 1, "text": "将军张骞，以使通大夏，还，为校尉。", "len": 17}
{"sid": "111_卫将军骠骑列传.118.s2", "chapter": "111_卫将军骠骑列传", "para": "118", "seq": 2, "text": "从大将军有功，封为博望侯。", "len": 13}
{"sid": "111_卫将军骠骑列传.119.s1", "chapter": "111_卫将军骠骑列传", "para": "119", "seq": 1, "text": "後三岁，为将军，出右北平，失期，当斩，赎为庶人。", "len": 24}
{"sid": "111_卫将军骠骑列传.119.s2", "chapter": "111_卫将军骠骑列传", "para": "119", "seq": 2, "text": "其後使通乌孙，为大行而卒，冢在汉中。", "len": 18}
{"sid": "111_卫将军骠骑列传.120.s1", "chapter": "111_卫将军骠骑列传", "para": "120", "seq": 1, "text": "将军赵食其，祋祤人也。", "len": 11}
{"sid": "111_卫将军骠骑列传.120.s2", "chapter": "111_卫将军骠骑列传", "para": "120", "seq": 2, "text": "武帝立二十二岁，以主爵为右将军，从大将军出定襄，迷失道，当斩，赎为庶人。", "len": 36}
{"sid": "111_卫将军骠骑列传.121.s1", "chapter": "111_卫将军骠骑列传", "para": "121", "seq": 1, "text": "将军曹襄，以平阳侯为後将军，从大将军出定襄。", "len": 22}
{"sid": "111_卫将军骠骑列传.121.s2", "chapter": "111_卫将军骠骑列传", "para": "121", "seq": 2, "text": "襄，曹参孙也。", "len": 7}
{"sid": "111_卫将军骠骑列传.122.s1", "chapter": "111_卫将军骠骑列传", "para": "122", "seq": 1, "text": "将军韩说，弓高侯庶孙也。", "len": 12}
{"sid": "111_卫将军骠骑列传.122.s2", "chapter": "111_卫将军骠骑列传", "para": "122", "seq": 2, "text": "以校尉从大将军有功，为龙嵒侯，坐酎金失侯。", "len": 21}
{"sid": "111_卫将军骠骑列传.123.s1", "chapter": "111_卫将军骠骑列传", "para": "123", "seq": 1, "text": "元鼎六年，以待诏为横海将军，击东越有功，为按道侯。", "len": 25}
{"sid": "111_卫将军骠骑列传.123.s2", "chapter": "111_卫将军骠骑列传", "para": "123", "seq": 2, "text": "以太初三年为游击将军，屯於五原外列城。", "len": 19}
{"sid": "111_卫将军骠骑列传.124.s1", "chapter": "111_卫将军骠骑列传", "para": "124", "seq": 1, "text": "为光禄勋，掘蛊太子宫，卫太子杀之。", "len": 17}
{"sid": "111_卫将军骠骑列传.125.s1", "chapter": "111_卫将军骠骑列传", "para": "125", "seq": 1, "text": "将军郭昌，云中人也。", "len": 10}
{"sid": "111_卫将军骠骑列传.125.s2", "chapter": "111_卫将军骠骑列传", "para": "125", "seq": 2, "text": "以校尉从大将军。", "len": 8}
{"sid": "111_卫将军骠骑列传.125.s3", "chapter": "111_卫将军骠骑列传", "para": "125", "seq": 3, "text": "元封四年，以太中大夫为拔胡将军，屯朔方。", "len": 20}
{"sid": "111_卫将军骠骑列传.125.s4", "chapter": "111_卫将军骠骑列传", "para": "125", "seq": 4, "text": "还击昆明，毋功，夺印。", "len": 11}
{"sid": "111_卫将军骠骑列传.126.s1", "chapter": "111_卫将军骠骑列传", "para": "126", "seq": 1, "text": "将军荀彘，太原广武人。", "len": 11}
{"sid": "111_卫将军骠骑列传.126.s2", "chapter": "111_卫将军骠骑列传", "para": "126", "seq": 2, "text": "以御见，侍中，为校尉，数从大将军。", "len": 17}
{"sid": "111_卫将军骠骑列传.126.s3", "chapter": "111_卫将军骠骑列传", "para": "126", "seq": 3, "text": "以元封三年为左将军击朝鲜，毋功。", "len": 16}
{"sid": "111_卫将军骠骑列传.126.s4", "chapter": "111_卫将军骠骑列传", "para": "126", "seq": 4, "text": "以捕楼船将军坐法死。", "len": 10}
{"sid": "111_卫将军骠骑列传.127.s1", "chapter": "111_卫将军骠骑列传", "para": "127", "seq": 1, "text": "最骠骑将军去病，凡六出击匈奴，其四出以将军，斩捕首虏十一万馀级。", "len": 32}
{"sid": "111_卫将军骠骑列传.127.s2", "chapter": "111_卫将军骠骑列传", "para": "127", "seq": 2, "text": "及浑邪王以众降数万，遂开河西酒泉之地，西方益少胡寇。", "len": 26}
{"sid": "111_卫将军骠骑列传.127.s3", "chapter": "111_卫将军骠骑列传", "para": "127", "seq": 3, "text": "四益封，凡万五千一百户。", "len": 12}
{"sid": "111_卫将军骠骑列传.127.s4", "chapter": "111_卫将军骠骑列传", "para": "127", "seq": 4, "text": "其校吏有功为侯者凡六人，而後为将军二人。", "len": 20}
{"sid": "111_卫将军骠骑列传.128.s1", "chapter": "111_卫将军骠骑列传", "para": "128", "seq": 1, "text": "将军路博德，平州人。", "len": 10}
{"sid": "111_卫将军骠骑列传.128.s2", "chapter": "111_卫将军骠骑列传", "para": "128", "seq": 2, "text": "以右北平太守从骠骑将军有功，为符离侯。", "len": 19}
{"sid": "111_卫将军骠骑列传.129.s1", "chapter": "111_卫将军骠骑列传", "para": "129", "seq": 1, "text": "骠骑死後，博德以卫尉为伏波将军，伐破南越，益封。", "len": 24}
{"sid": "111_卫将军骠骑列传.129.s2", "chapter": "111_卫将军骠骑列传", "para": "129", "seq": 2, "text": "其後坐法失侯。", "len": 7}
{"sid": "111_卫将军骠骑列传.129.s3", "chapter": "111_卫将军骠骑列传", "para": "129", "seq": 3, "text": "为彊弩都尉，屯居延，卒。", "len": 12}
{"sid": "111_卫将军骠骑列传.130.s1", "chapter": "111_卫将军骠骑列传", "para": "130", "seq": 1, "text": "将军赵破奴，故九原人。", "len": 11}
{"sid": "111_卫将军骠骑列传.130.s2", "chapter": "111_卫将军骠骑列传", "para": "130", "seq": 2, "text": "尝亡入匈奴，已而归汉，为骠骑将军司马。", "len": 19}
{"sid": "111_卫将军骠骑列传.130.s3", "chapter": "111_卫将军骠骑列传", "para": "130", "seq": 3, "text": "出北地时有功，封为从骠侯。", "len": 13}
{"sid": "111_卫将军骠骑列传.130.s4", "chapter": "111_卫将军骠骑列传", "para": "130", "seq": 4, "text": "坐酎金失侯。", "len": 6}
{"sid": "111_卫将军骠骑列传.131.s1", "chapter": "111_卫将军骠骑列传", "para": "131", "seq": 1, "text": "後一岁，为匈河将军，攻胡至匈河水，无功。", "len": 20}
{"sid": "111_卫将军骠骑列传.131.s2", "chapter": "111_卫将军骠骑列传", "para": "131", "seq": 2, "text": "後二岁，击虏楼兰王，复封为浞野侯。", "len": 17}
{"sid": "111_卫将军骠骑列传.132.s1", "chapter": "111_卫将军骠骑列传", "para": "132", "seq": 1, "text": "後六岁，为浚稽将军，将二万骑击匈奴左贤王，左贤王与战，兵八万骑围破奴，破奴生为虏所得，遂没其军。", "len": 48}
{"sid": "111_卫将军骠骑列传.133.s1", "chapter": "111_卫将军骠骑列传", "para": "133", "seq": 1, "text": "居匈奴中十岁，复与其太子安国亡入汉。", "len": 18}
{"sid": "111_卫将军骠骑列传.133.s2", "chapter": "111_卫将军骠骑列传", "para": "133", "seq": 2, "text": "後坐巫蛊，族。", "len": 7}
{"sid": "111_卫将军骠骑列传.134.s1", "chapter": "111_卫将军骠骑列传", "para": "134", "seq": 1, "text": "自卫氏兴，大将军青首封，其後枝属为五侯。", "len": 20}
{"sid": "111_卫将军骠骑列传.134.s2", "chapter": "111_卫将军骠骑列传", "para": "134", "seq": 2, "text": "凡二十四岁而五侯尽夺，卫氏无为侯者。", "len": 18}
{"sid": "111_卫将军骠骑列传.134.s3", "chapter": "111_卫将军骠骑列传", "para": "134", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "111_卫将军骠骑列传.135.s1", "chapter": "111_卫将军骠骑列传", "para": "135", "seq": 1, "text": "太史公曰：苏建语余曰：“吾尝责大将军至尊重，而天下之贤大夫毋称焉，原将军观古名将所招选择贤者，勉之哉。", "len": 51}
{"sid": "111_卫将军骠骑列传.135.s2", "chapter": "111_卫将军骠骑列传", "para": "135", "seq": 2, "text": "大将军谢曰：“自魏其、武安之厚宾客，天子常切齿。", "len": 24}
{"sid": "111_卫将军骠骑列传.135.s3", "chapter": "111_卫将军骠骑列传", "para": "135", "seq": 3, "text": "彼亲附士大夫，招贤绌不肖者，人主之柄也。", "len": 20}
{"sid": "111_卫将军骠骑列传.135.s4", "chapter": "111_卫将军骠骑列传", "para": "135", "seq": 4, "text": "人臣奉法遵职而已，何与招士！", "len": 14}
{"sid": "111_卫将军骠骑列传.135.s5", "chapter": "111_卫将军骠骑列传", "para": "135", "seq": 5, "text": "” ” 骠骑亦放此意，其为将如此。", "len": 17}
{"sid": "111_卫将军骠骑列传.135.s6", "chapter": "111_卫将军骠骑列传", "para": "135", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "111_卫将军骠骑列传.136.s1", "chapter": "111_卫将军骠骑列传", "para": "136", "seq": 1, "text": "君子豹变，贵贱何常。", "len": 10}
{"sid": "111_卫将军骠骑列传.136.s2", "chapter": "111_卫将军骠骑列传", "para": "136", "seq": 2, "text": "青本奴虏，忽升戎行。", "len": 10}
{"sid": "111_卫将军骠骑列传.136.s3", "chapter": "111_卫将军骠骑列传", "para": "136", "seq": 3, "text": "姊配皇极，身尚平阳。", "len": 10}
{"sid": "111_卫将军骠骑列传.136.s4", "chapter": "111_卫将军骠骑列传", "para": "136", "seq": 4, "text": "宠荣斯僭，取乱彝章。", "len": 10}
{"sid": "111_卫将军骠骑列传.136.s5", "chapter": "111_卫将军骠骑列传", "para": "136", "seq": 5, "text": "嫖姚继踵，再静边方。", "len": 10}
{"sid": "111_卫将军骠骑列传.136.s6", "chapter": "111_卫将军骠骑列传", "para": "136", "seq": 6, "text": ":::", "len": 3}
