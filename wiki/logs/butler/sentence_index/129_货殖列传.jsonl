{"sid": "129_货殖列传.1.s1", "chapter": "129_货殖列传", "para": "1", "seq": 1, "text": "老子曰：“至治之极，邻国相望，鸡狗之声相闻，民各甘其食，美其服，安其俗，乐其业，至老死不相往来。", "len": 48}
{"sid": "129_货殖列传.1.s2", "chapter": "129_货殖列传", "para": "1", "seq": 2, "text": "” 必用此为务，輓近世涂民耳目，则几无行矣。", "len": 22}
{"sid": "129_货殖列传.2.s1", "chapter": "129_货殖列传", "para": "2", "seq": 1, "text": "太史公曰：夫神农以前，吾不知已。", "len": 16}
{"sid": "129_货殖列传.2.s2", "chapter": "129_货殖列传", "para": "2", "seq": 2, "text": "至若诗书所述虞夏以来，耳目欲极声色之好，口欲穷刍豢之味，身安逸乐，而心夸矜埶能之荣使。", "len": 43}
{"sid": "129_货殖列传.2.s3", "chapter": "129_货殖列传", "para": "2", "seq": 3, "text": "俗之渐民久矣，虽户说以眇论，终不能化。", "len": 19}
{"sid": "129_货殖列传.2.s4", "chapter": "129_货殖列传", "para": "2", "seq": 4, "text": "故善者因之，其次利道之，其次教诲之，其次整齐之，最下者与之争。", "len": 31}
{"sid": "129_货殖列传.3.s1", "chapter": "129_货殖列传", "para": "3", "seq": 1, "text": "夫山西饶材、竹、穀、纑、旄、玉石；山东多鱼、盐、漆、丝、声色；江南出棻、梓、姜、桂、金、锡、连、丹沙、犀、玳瑁、珠玑、齿革；龙门、碣石北多马、牛、羊、旃裘、筋角；铜、铁则千里往往山出釭置：此其大较也。", "len": 100}
{"sid": "129_货殖列传.3.s2", "chapter": "129_货殖列传", "para": "3", "seq": 2, "text": "皆中国人民所喜好，谣俗被服饮食奉生送死之具也。", "len": 23}
{"sid": "129_货殖列传.3.s3", "chapter": "129_货殖列传", "para": "3", "seq": 3, "text": "故待农而食之，虞而出之，工而成之，商而通之。", "len": 22}
{"sid": "129_货殖列传.3.s4", "chapter": "129_货殖列传", "para": "3", "seq": 4, "text": "此宁有政教发徵期会哉？", "len": 11}
{"sid": "129_货殖列传.3.s5", "chapter": "129_货殖列传", "para": "3", "seq": 5, "text": "人各任其能，竭其力，以得所欲。", "len": 15}
{"sid": "129_货殖列传.3.s6", "chapter": "129_货殖列传", "para": "3", "seq": 6, "text": "故物贱之徵贵，贵之徵贱，各劝其业，乐其事，若水之趋下，日夜无休时，不召而自来，不求而民出之。", "len": 46}
{"sid": "129_货殖列传.3.s7", "chapter": "129_货殖列传", "para": "3", "seq": 7, "text": "岂非道之所符，而自然之验邪？", "len": 14}
{"sid": "129_货殖列传.4.s1", "chapter": "129_货殖列传", "para": "4", "seq": 1, "text": "周书曰：“农不出则乏其食，工不出则乏其事，商不出则三宝绝，虞不出则财匮少。", "len": 37}
{"sid": "129_货殖列传.4.s2", "chapter": "129_货殖列传", "para": "4", "seq": 2, "text": "” 财匮少而山泽不辟矣。", "len": 12}
{"sid": "129_货殖列传.4.s3", "chapter": "129_货殖列传", "para": "4", "seq": 3, "text": "此四者，民所衣食之原也。", "len": 12}
{"sid": "129_货殖列传.4.s4", "chapter": "129_货殖列传", "para": "4", "seq": 4, "text": "原大则饶，原小则鲜。", "len": 10}
{"sid": "129_货殖列传.4.s5", "chapter": "129_货殖列传", "para": "4", "seq": 5, "text": "上则富国，下则富家。", "len": 10}
{"sid": "129_货殖列传.4.s6", "chapter": "129_货殖列传", "para": "4", "seq": 6, "text": "贫富之道，莫之夺予，而巧者有馀，拙者不足。", "len": 21}
{"sid": "129_货殖列传.4.s7", "chapter": "129_货殖列传", "para": "4", "seq": 7, "text": "故太公望封於营丘，地潟卤，人民寡，於是太公劝其女功，极技巧，通鱼盐，则人物归之，繦至而辐凑。", "len": 46}
{"sid": "129_货殖列传.4.s8", "chapter": "129_货殖列传", "para": "4", "seq": 8, "text": "故齐冠带衣履天下，海岱之间敛袂而往朝焉。", "len": 20}
{"sid": "129_货殖列传.4.s9", "chapter": "129_货殖列传", "para": "4", "seq": 9, "text": "其後齐中衰，管子修之，设轻重九府，则桓公以霸，九合诸侯，一匡天下；而管氏亦有三归，位在陪臣，富於列国之君。", "len": 53}
{"sid": "129_货殖列传.4.s10", "chapter": "129_货殖列传", "para": "4", "seq": 10, "text": "是以齐富彊至於威、宣也。", "len": 12}
{"sid": "129_货殖列传.5.s1", "chapter": "129_货殖列传", "para": "5", "seq": 1, "text": "故曰：“仓廪实而知礼节，衣食足而知荣辱。", "len": 20}
{"sid": "129_货殖列传.5.s2", "chapter": "129_货殖列传", "para": "5", "seq": 2, "text": "” 礼生於有而废於无。", "len": 11}
{"sid": "129_货殖列传.5.s3", "chapter": "129_货殖列传", "para": "5", "seq": 3, "text": "故君子富，好行其德；小人富，以適其力。", "len": 19}
{"sid": "129_货殖列传.5.s4", "chapter": "129_货殖列传", "para": "5", "seq": 4, "text": "渊深而鱼生之，山深而兽往之，人富而仁义附焉。", "len": 22}
{"sid": "129_货殖列传.5.s5", "chapter": "129_货殖列传", "para": "5", "seq": 5, "text": "富者得埶益彰，失埶则客无所之，以而不乐。", "len": 20}
{"sid": "129_货殖列传.5.s6", "chapter": "129_货殖列传", "para": "5", "seq": 6, "text": "夷狄益甚。", "len": 5}
{"sid": "129_货殖列传.5.s7", "chapter": "129_货殖列传", "para": "5", "seq": 7, "text": "谚曰：“千金之子，不死於市。", "len": 14}
{"sid": "129_货殖列传.5.s8", "chapter": "129_货殖列传", "para": "5", "seq": 8, "text": "” 此非空言也。", "len": 8}
{"sid": "129_货殖列传.5.s9", "chapter": "129_货殖列传", "para": "5", "seq": 9, "text": "故曰：“天下熙熙，皆为利来；天下壤壤，皆为利往。", "len": 24}
{"sid": "129_货殖列传.5.s10", "chapter": "129_货殖列传", "para": "5", "seq": 10, "text": "” 夫千乘之王，万家之侯，百室之君，尚犹患贫，而况匹夫编户之民乎！", "len": 33}
{"sid": "129_货殖列传.6.s1", "chapter": "129_货殖列传", "para": "6", "seq": 1, "text": "昔者越王句践困於会稽之上，乃用范蠡、计然。", "len": 21}
{"sid": "129_货殖列传.6.s2", "chapter": "129_货殖列传", "para": "6", "seq": 2, "text": "计然曰：“知斗则修备，时用则知物，二者形则万货之情可得而观已。", "len": 31}
{"sid": "129_货殖列传.6.s3", "chapter": "129_货殖列传", "para": "6", "seq": 3, "text": "故岁在金，穰；水，毁；木，饥；火，旱。", "len": 19}
{"sid": "129_货殖列传.6.s4", "chapter": "129_货殖列传", "para": "6", "seq": 4, "text": "旱则资舟，水则资车，物之理也。", "len": 15}
{"sid": "129_货殖列传.6.s5", "chapter": "129_货殖列传", "para": "6", "seq": 5, "text": "六岁穰，六岁旱，十二岁一大饥。", "len": 15}
{"sid": "129_货殖列传.6.s6", "chapter": "129_货殖列传", "para": "6", "seq": 6, "text": "夫粜，二十病农，九十病末。", "len": 13}
{"sid": "129_货殖列传.6.s7", "chapter": "129_货殖列传", "para": "6", "seq": 7, "text": "末病则财不出，农病则草不辟矣。", "len": 15}
{"sid": "129_货殖列传.6.s8", "chapter": "129_货殖列传", "para": "6", "seq": 8, "text": "上不过八十，下不减三十，则农末俱利，平粜齐物，关市不乏，治国之道也。", "len": 34}
{"sid": "129_货殖列传.6.s9", "chapter": "129_货殖列传", "para": "6", "seq": 9, "text": "积著之理，务完物，无息币。", "len": 13}
{"sid": "129_货殖列传.6.s10", "chapter": "129_货殖列传", "para": "6", "seq": 10, "text": "以物相贸易，腐败而食之货勿留，无敢居贵。", "len": 20}
{"sid": "129_货殖列传.6.s11", "chapter": "129_货殖列传", "para": "6", "seq": 11, "text": "论其有馀不足，则知贵贱。", "len": 12}
{"sid": "129_货殖列传.6.s12", "chapter": "129_货殖列传", "para": "6", "seq": 12, "text": "贵上极则反贱，贱下极则反贵。", "len": 14}
{"sid": "129_货殖列传.6.s13", "chapter": "129_货殖列传", "para": "6", "seq": 13, "text": "贵出如粪土，贱取如珠玉。", "len": 12}
{"sid": "129_货殖列传.6.s14", "chapter": "129_货殖列传", "para": "6", "seq": 14, "text": "财币欲其行如流水。", "len": 9}
{"sid": "129_货殖列传.6.s15", "chapter": "129_货殖列传", "para": "6", "seq": 15, "text": "” 修之十年，国富，厚赂战士，士赴矢石，如渴得饮，遂报彊吴，观兵中国，称号” 五霸”。", "len": 43}
{"sid": "129_货殖列传.7.s1", "chapter": "129_货殖列传", "para": "7", "seq": 1, "text": "范蠡既雪会稽之耻，乃喟然而叹曰：“计然之策七，越用其五而得意。", "len": 31}
{"sid": "129_货殖列传.7.s2", "chapter": "129_货殖列传", "para": "7", "seq": 2, "text": "既已施於国，吾欲用之家。", "len": 12}
{"sid": "129_货殖列传.7.s3", "chapter": "129_货殖列传", "para": "7", "seq": 3, "text": "” 乃乘扁舟浮於江湖，变名易姓，適齐为鸱夷子皮，之陶为硃公。", "len": 30}
{"sid": "129_货殖列传.7.s4", "chapter": "129_货殖列传", "para": "7", "seq": 4, "text": "硃公以为陶天下之中，诸侯四通，货物所交易也。", "len": 22}
{"sid": "129_货殖列传.7.s5", "chapter": "129_货殖列传", "para": "7", "seq": 5, "text": "乃治产积居。", "len": 6}
{"sid": "129_货殖列传.7.s6", "chapter": "129_货殖列传", "para": "7", "seq": 6, "text": "与时逐而不责於人。", "len": 9}
{"sid": "129_货殖列传.7.s7", "chapter": "129_货殖列传", "para": "7", "seq": 7, "text": "故善治生者，能择人而任时。", "len": 13}
{"sid": "129_货殖列传.7.s8", "chapter": "129_货殖列传", "para": "7", "seq": 8, "text": "十九年之中三致千金，再分散与贫交疏昆弟。", "len": 20}
{"sid": "129_货殖列传.7.s9", "chapter": "129_货殖列传", "para": "7", "seq": 9, "text": "此所谓富好行其德者也。", "len": 11}
{"sid": "129_货殖列传.7.s10", "chapter": "129_货殖列传", "para": "7", "seq": 10, "text": "後年衰老而听子孙，子孙脩业而息之，遂至巨万。", "len": 22}
{"sid": "129_货殖列传.7.s11", "chapter": "129_货殖列传", "para": "7", "seq": 11, "text": "故言富者皆称陶硃公。", "len": 10}
{"sid": "129_货殖列传.8.s1", "chapter": "129_货殖列传", "para": "8", "seq": 1, "text": "子赣既学於仲尼，退而仕於卫，废著鬻财於曹、鲁之间，七十子之徒，赐最为饶益。", "len": 37}
{"sid": "129_货殖列传.8.s2", "chapter": "129_货殖列传", "para": "8", "seq": 2, "text": "原宪不厌糟糠，匿於穷巷。", "len": 12}
{"sid": "129_货殖列传.8.s3", "chapter": "129_货殖列传", "para": "8", "seq": 3, "text": "子贡结驷连骑，束帛之币以聘享诸侯，所至，国君无不分庭与之抗礼。", "len": 31}
{"sid": "129_货殖列传.8.s4", "chapter": "129_货殖列传", "para": "8", "seq": 4, "text": "夫使孔子名布扬於天下者，子贡先後之也。", "len": 19}
{"sid": "129_货殖列传.8.s5", "chapter": "129_货殖列传", "para": "8", "seq": 5, "text": "此所谓得埶而益彰者乎？", "len": 11}
{"sid": "129_货殖列传.9.s1", "chapter": "129_货殖列传", "para": "9", "seq": 1, "text": "白圭，周人也。", "len": 7}
{"sid": "129_货殖列传.9.s2", "chapter": "129_货殖列传", "para": "9", "seq": 2, "text": "当魏文侯时，李克务尽地力，而白圭乐观时变，故人弃我取，人取我与。", "len": 32}
{"sid": "129_货殖列传.9.s3", "chapter": "129_货殖列传", "para": "9", "seq": 3, "text": "夫岁孰取穀，予之丝漆；茧出取帛絮，予之食。", "len": 21}
{"sid": "129_货殖列传.9.s4", "chapter": "129_货殖列传", "para": "9", "seq": 4, "text": "太阴在卯，穰；明岁衰恶。", "len": 12}
{"sid": "129_货殖列传.9.s5", "chapter": "129_货殖列传", "para": "9", "seq": 5, "text": "至午，旱；明岁美。", "len": 9}
{"sid": "129_货殖列传.9.s6", "chapter": "129_货殖列传", "para": "9", "seq": 6, "text": "至酉，穰；明岁衰恶。", "len": 10}
{"sid": "129_货殖列传.9.s7", "chapter": "129_货殖列传", "para": "9", "seq": 7, "text": "至子，大旱；明岁美，有水。", "len": 13}
{"sid": "129_货殖列传.9.s8", "chapter": "129_货殖列传", "para": "9", "seq": 8, "text": "至卯，积著率岁倍。", "len": 9}
{"sid": "129_货殖列传.9.s9", "chapter": "129_货殖列传", "para": "9", "seq": 9, "text": "欲长钱，取下穀；长石斗，取上种。", "len": 16}
{"sid": "129_货殖列传.9.s10", "chapter": "129_货殖列传", "para": "9", "seq": 10, "text": "能薄饮食，忍嗜欲，节衣服，与用事僮仆同苦乐，趋时若猛兽挚鸟之发。", "len": 32}
{"sid": "129_货殖列传.9.s11", "chapter": "129_货殖列传", "para": "9", "seq": 11, "text": "故曰：“吾治生产，犹伊尹、吕尚之谋，孙吴用兵，商鞅行法是也。", "len": 30}
{"sid": "129_货殖列传.9.s12", "chapter": "129_货殖列传", "para": "9", "seq": 12, "text": "是故其智不足与权变，勇不足以决断，仁不能以取予，彊不能有所守，虽欲学吾术，终不告之矣。", "len": 43}
{"sid": "129_货殖列传.9.s13", "chapter": "129_货殖列传", "para": "9", "seq": 13, "text": "” 盖天下言治生祖白圭。", "len": 12}
{"sid": "129_货殖列传.9.s14", "chapter": "129_货殖列传", "para": "9", "seq": 14, "text": "白圭其有所试矣，能试有所长，非苟而已也。", "len": 20}
{"sid": "129_货殖列传.10.s1", "chapter": "129_货殖列传", "para": "10", "seq": 1, "text": "猗顿用盬盐起。", "len": 7}
{"sid": "129_货殖列传.10.s2", "chapter": "129_货殖列传", "para": "10", "seq": 2, "text": "而邯郸郭纵以铁冶成业，与王者埒富。", "len": 17}
{"sid": "129_货殖列传.11.s1", "chapter": "129_货殖列传", "para": "11", "seq": 1, "text": "乌氏倮畜牧，及众，斥卖，求奇缯物，间献遗戎王。", "len": 23}
{"sid": "129_货殖列传.11.s2", "chapter": "129_货殖列传", "para": "11", "seq": 2, "text": "戎王什倍其偿，与之畜，畜至用穀量马牛。", "len": 19}
{"sid": "129_货殖列传.11.s3", "chapter": "129_货殖列传", "para": "11", "seq": 3, "text": "秦始皇帝令倮比封君，以时与列臣朝请。", "len": 18}
{"sid": "129_货殖列传.11.s4", "chapter": "129_货殖列传", "para": "11", "seq": 4, "text": "而巴寡妇清，其先得丹穴，而擅其利数世，家亦不訾。", "len": 24}
{"sid": "129_货殖列传.11.s5", "chapter": "129_货殖列传", "para": "11", "seq": 5, "text": "清，寡妇也，能守其业，用财自卫，不见侵犯。", "len": 21}
{"sid": "129_货殖列传.11.s6", "chapter": "129_货殖列传", "para": "11", "seq": 6, "text": "秦皇帝以为贞妇而客之，为筑女怀清台。", "len": 18}
{"sid": "129_货殖列传.11.s7", "chapter": "129_货殖列传", "para": "11", "seq": 7, "text": "夫倮鄙人牧长，清穷乡寡妇，礼抗万乘，名显天下，岂非以富邪？", "len": 29}
{"sid": "129_货殖列传.12.s1", "chapter": "129_货殖列传", "para": "12", "seq": 1, "text": "汉兴，海内为一，开关梁，弛山泽之禁，是以富商大贾周流天下，交易之物莫不通，得其所欲，而徙豪杰诸侯彊族於京师。", "len": 54}
{"sid": "129_货殖列传.13.s1", "chapter": "129_货殖列传", "para": "13", "seq": 1, "text": "关中自汧、雍以东至河、华，膏壤沃野千里，自虞夏之贡以为上田，而公刘適邠，大王、王季在岐，文王作丰，武王治镐，故其民犹有先王之遗风，好稼穑，殖五穀，地重，重为邪。", "len": 80}
{"sid": "129_货殖列传.13.s2", "chapter": "129_货殖列传", "para": "13", "seq": 2, "text": "及秦文、、缪居雍，隙陇蜀之货物而多贾。", "len": 19}
{"sid": "129_货殖列传.13.s3", "chapter": "129_货殖列传", "para": "13", "seq": 3, "text": "献公徙栎邑，栎邑北卻戎翟，东通三晋，亦多大贾。", "len": 23}
{"sid": "129_货殖列传.13.s4", "chapter": "129_货殖列传", "para": "13", "seq": 4, "text": "昭治咸阳，因以汉都，长安诸陵，四方辐凑并至而会，地小人众，故其民益玩巧而事末也。", "len": 40}
{"sid": "129_货殖列传.13.s5", "chapter": "129_货殖列传", "para": "13", "seq": 5, "text": "南则巴蜀。", "len": 5}
{"sid": "129_货殖列传.13.s6", "chapter": "129_货殖列传", "para": "13", "seq": 6, "text": "巴蜀亦沃野，地饶卮、姜、丹沙、石、铜、铁、竹、木之器。", "len": 27}
{"sid": "129_货殖列传.13.s7", "chapter": "129_货殖列传", "para": "13", "seq": 7, "text": "南御滇僰，僰僮。", "len": 8}
{"sid": "129_货殖列传.13.s8", "chapter": "129_货殖列传", "para": "13", "seq": 8, "text": "西近邛笮，笮马、旄牛。", "len": 11}
{"sid": "129_货殖列传.13.s9", "chapter": "129_货殖列传", "para": "13", "seq": 9, "text": "然四塞，栈道千里，无所不通，唯襃斜绾毂其口，以所多易所鲜。", "len": 29}
{"sid": "129_货殖列传.13.s10", "chapter": "129_货殖列传", "para": "13", "seq": 10, "text": "天水、陇西、北地、上郡与关中同俗，然西有羌中之利，北有戎翟之畜，畜牧为天下饶。", "len": 39}
{"sid": "129_货殖列传.13.s11", "chapter": "129_货殖列传", "para": "13", "seq": 11, "text": "然地亦穷险，唯京师要其道。", "len": 13}
{"sid": "129_货殖列传.13.s12", "chapter": "129_货殖列传", "para": "13", "seq": 12, "text": "故关中之地，於天下三分之一，而人众不过什三；然量其富，什居其六。", "len": 32}
{"sid": "129_货殖列传.14.s1", "chapter": "129_货殖列传", "para": "14", "seq": 1, "text": "昔唐人都河东，殷人都河内，周人都河南。", "len": 19}
{"sid": "129_货殖列传.14.s2", "chapter": "129_货殖列传", "para": "14", "seq": 2, "text": "夫三河在天下之中，若鼎足，王者所更居也，建国各数百千岁，土地小狭，民人众，都国诸侯所聚会，故其俗纤俭习事。", "len": 53}
{"sid": "129_货殖列传.14.s3", "chapter": "129_货殖列传", "para": "14", "seq": 3, "text": "杨、平阳陈西贾秦、翟，北贾种、代。", "len": 17}
{"sid": "129_货殖列传.14.s4", "chapter": "129_货殖列传", "para": "14", "seq": 4, "text": "种、代，石北也，地边胡，数被寇。", "len": 16}
{"sid": "129_货殖列传.14.s5", "chapter": "129_货殖列传", "para": "14", "seq": 5, "text": "人民矜懻忮，好气，任侠为奸，不事农商。", "len": 19}
{"sid": "129_货殖列传.14.s6", "chapter": "129_货殖列传", "para": "14", "seq": 6, "text": "然迫近北夷，师旅亟往，中国委输时有奇羡。", "len": 20}
{"sid": "129_货殖列传.14.s7", "chapter": "129_货殖列传", "para": "14", "seq": 7, "text": "其民羯羠不均，自全晋之时固已患其僄悍，而武灵王益厉之，其谣俗犹有赵之风也。", "len": 37}
{"sid": "129_货殖列传.14.s8", "chapter": "129_货殖列传", "para": "14", "seq": 8, "text": "故杨、平阳陈掾其间，得所欲。", "len": 14}
{"sid": "129_货殖列传.14.s9", "chapter": "129_货殖列传", "para": "14", "seq": 9, "text": "温、轵西贾上党，北贾赵、中山。", "len": 15}
{"sid": "129_货殖列传.14.s10", "chapter": "129_货殖列传", "para": "14", "seq": 10, "text": "中山地薄人众，犹有沙丘纣淫地馀民，民俗懁急，仰机利而食。", "len": 28}
{"sid": "129_货殖列传.14.s11", "chapter": "129_货殖列传", "para": "14", "seq": 11, "text": "丈夫相聚游戏，悲歌慷慨，起则相随椎剽，休则掘冢作巧奸冶，多美物，为倡优。", "len": 36}
{"sid": "129_货殖列传.14.s12", "chapter": "129_货殖列传", "para": "14", "seq": 12, "text": "女子则鼓鸣瑟，跕屣，游媚贵富，入後宫，遍诸侯。", "len": 23}
{"sid": "129_货殖列传.15.s1", "chapter": "129_货殖列传", "para": "15", "seq": 1, "text": "然邯郸亦漳、河之间一都会也。", "len": 14}
{"sid": "129_货殖列传.15.s2", "chapter": "129_货殖列传", "para": "15", "seq": 2, "text": "北通燕、涿，南有郑、卫。", "len": 12}
{"sid": "129_货殖列传.15.s3", "chapter": "129_货殖列传", "para": "15", "seq": 3, "text": "郑、卫俗与赵相类，然近梁、鲁，微重而矜节。", "len": 21}
{"sid": "129_货殖列传.15.s4", "chapter": "129_货殖列传", "para": "15", "seq": 4, "text": "濮上之邑徙野王，野王好气任侠，卫之风也。", "len": 20}
{"sid": "129_货殖列传.16.s1", "chapter": "129_货殖列传", "para": "16", "seq": 1, "text": "夫燕亦勃、碣之间一都会也。", "len": 13}
{"sid": "129_货殖列传.16.s2", "chapter": "129_货殖列传", "para": "16", "seq": 2, "text": "南通齐、赵，东北边胡。", "len": 11}
{"sid": "129_货殖列传.16.s3", "chapter": "129_货殖列传", "para": "16", "seq": 3, "text": "上谷至辽东，地踔远，人民希，数被寇，大与赵、代俗相类，而民雕捍少虑，有鱼盐枣栗之饶。", "len": 42}
{"sid": "129_货殖列传.16.s4", "chapter": "129_货殖列传", "para": "16", "seq": 4, "text": "北邻乌桓、夫馀，东绾秽貉、朝鲜、真番之利。", "len": 21}
{"sid": "129_货殖列传.17.s1", "chapter": "129_货殖列传", "para": "17", "seq": 1, "text": "洛阳东贾齐、鲁，南贾梁、楚。", "len": 14}
{"sid": "129_货殖列传.17.s2", "chapter": "129_货殖列传", "para": "17", "seq": 2, "text": "故泰山之阳则鲁，其阴则齐。", "len": 13}
{"sid": "129_货殖列传.18.s1", "chapter": "129_货殖列传", "para": "18", "seq": 1, "text": "齐带山海，膏壤千里，宜桑麻，人民多文采布帛鱼盐。", "len": 24}
{"sid": "129_货殖列传.18.s2", "chapter": "129_货殖列传", "para": "18", "seq": 2, "text": "临菑亦海岱之间一都会也。", "len": 12}
{"sid": "129_货殖列传.18.s3", "chapter": "129_货殖列传", "para": "18", "seq": 3, "text": "其俗宽缓阔达，而足智，好议论，地重，难动摇，怯於众斗，勇於持刺，故多劫人者，大国之风也。", "len": 44}
{"sid": "129_货殖列传.18.s4", "chapter": "129_货殖列传", "para": "18", "seq": 4, "text": "其中具五民。", "len": 6}
{"sid": "129_货殖列传.19.s1", "chapter": "129_货殖列传", "para": "19", "seq": 1, "text": "而邹、鲁滨洙、泗，犹有周公遗风，俗好儒，备於礼，故其民龊龊。", "len": 30}
{"sid": "129_货殖列传.19.s2", "chapter": "129_货殖列传", "para": "19", "seq": 2, "text": "颇有桑麻之业，无林泽之饶。", "len": 13}
{"sid": "129_货殖列传.19.s3", "chapter": "129_货殖列传", "para": "19", "seq": 3, "text": "地小人众，俭啬，畏罪远邪。", "len": 13}
{"sid": "129_货殖列传.19.s4", "chapter": "129_货殖列传", "para": "19", "seq": 4, "text": "及其衰，好贾趋利，甚於周人。", "len": 14}
{"sid": "129_货殖列传.20.s1", "chapter": "129_货殖列传", "para": "20", "seq": 1, "text": "夫自鸿沟以东，芒、砀以北，属巨野，此梁、宋也。", "len": 23}
{"sid": "129_货殖列传.20.s2", "chapter": "129_货殖列传", "para": "20", "seq": 2, "text": "陶、睢阳亦一都会也。", "len": 10}
{"sid": "129_货殖列传.20.s3", "chapter": "129_货殖列传", "para": "20", "seq": 3, "text": "昔尧作成阳，舜渔於雷泽，汤止于亳。", "len": 17}
{"sid": "129_货殖列传.20.s4", "chapter": "129_货殖列传", "para": "20", "seq": 4, "text": "其俗犹有先王遗风，重厚多君子，好稼穑，虽无山川之饶，能恶衣食，致其蓄藏。", "len": 36}
{"sid": "129_货殖列传.21.s1", "chapter": "129_货殖列传", "para": "21", "seq": 1, "text": "越、楚则有三俗。", "len": 8}
{"sid": "129_货殖列传.21.s2", "chapter": "129_货殖列传", "para": "21", "seq": 2, "text": "夫自淮北沛、陈、汝南、南郡，此西楚也。", "len": 19}
{"sid": "129_货殖列传.21.s3", "chapter": "129_货殖列传", "para": "21", "seq": 3, "text": "其俗剽轻，易发怒，地薄，寡於积聚。", "len": 17}
{"sid": "129_货殖列传.21.s4", "chapter": "129_货殖列传", "para": "21", "seq": 4, "text": "江陵故郢都，西通巫、巴，东有云梦之饶。", "len": 19}
{"sid": "129_货殖列传.21.s5", "chapter": "129_货殖列传", "para": "21", "seq": 5, "text": "陈在楚夏之交，通鱼盐之货，其民多贾。", "len": 18}
{"sid": "129_货殖列传.21.s6", "chapter": "129_货殖列传", "para": "21", "seq": 6, "text": "徐、僮、取虑，则清刻，矜己诺。", "len": 15}
{"sid": "129_货殖列传.22.s1", "chapter": "129_货殖列传", "para": "22", "seq": 1, "text": "彭城以东，东海、吴、广陵，此东楚也。", "len": 18}
{"sid": "129_货殖列传.22.s2", "chapter": "129_货殖列传", "para": "22", "seq": 2, "text": "其俗类徐、僮。", "len": 7}
{"sid": "129_货殖列传.22.s3", "chapter": "129_货殖列传", "para": "22", "seq": 3, "text": "朐、缯以北，俗则齐。", "len": 10}
{"sid": "129_货殖列传.22.s4", "chapter": "129_货殖列传", "para": "22", "seq": 4, "text": "浙江南则越。", "len": 6}
{"sid": "129_货殖列传.22.s5", "chapter": "129_货殖列传", "para": "22", "seq": 5, "text": "夫吴自阖庐、春申、王濞三人招致天下之喜游子弟，东有海盐之饶，章山之铜，三江、五湖之利，亦江东一都会也。", "len": 51}
{"sid": "129_货殖列传.23.s1", "chapter": "129_货殖列传", "para": "23", "seq": 1, "text": "衡山、九江、江南、豫章、长沙，是南楚也，其俗大类西楚。", "len": 27}
{"sid": "129_货殖列传.23.s2", "chapter": "129_货殖列传", "para": "23", "seq": 2, "text": "郢之後徙寿春，亦一都会也。", "len": 13}
{"sid": "129_货殖列传.23.s3", "chapter": "129_货殖列传", "para": "23", "seq": 3, "text": "而合肥受南北潮，皮革、鲍、木输会也。", "len": 18}
{"sid": "129_货殖列传.23.s4", "chapter": "129_货殖列传", "para": "23", "seq": 4, "text": "与闽中、干越杂俗，故南楚好辞，巧说少信。", "len": 20}
{"sid": "129_货殖列传.23.s5", "chapter": "129_货殖列传", "para": "23", "seq": 5, "text": "江南卑湿，丈夫早夭。", "len": 10}
{"sid": "129_货殖列传.23.s6", "chapter": "129_货殖列传", "para": "23", "seq": 6, "text": "多竹木。", "len": 4}
{"sid": "129_货殖列传.23.s7", "chapter": "129_货殖列传", "para": "23", "seq": 7, "text": "豫章出黄金，长沙出连、锡，然堇堇物之所有，取之不足以更费。", "len": 29}
{"sid": "129_货殖列传.23.s8", "chapter": "129_货殖列传", "para": "23", "seq": 8, "text": "九疑、苍梧以南至儋耳者，与江南大同俗，而杨越多焉。", "len": 25}
{"sid": "129_货殖列传.23.s9", "chapter": "129_货殖列传", "para": "23", "seq": 9, "text": "番禺亦其一都会也，珠玑、犀、玳瑁、果、布之凑。", "len": 23}
{"sid": "129_货殖列传.24.s1", "chapter": "129_货殖列传", "para": "24", "seq": 1, "text": "颍川、南阳，夏人之居也。", "len": 12}
{"sid": "129_货殖列传.24.s2", "chapter": "129_货殖列传", "para": "24", "seq": 2, "text": "夏人政尚忠朴，犹有先王之遗风。", "len": 15}
{"sid": "129_货殖列传.24.s3", "chapter": "129_货殖列传", "para": "24", "seq": 3, "text": "颍川敦愿。", "len": 5}
{"sid": "129_货殖列传.24.s4", "chapter": "129_货殖列传", "para": "24", "seq": 4, "text": "秦末世，迁不轨之民於南阳。", "len": 13}
{"sid": "129_货殖列传.24.s5", "chapter": "129_货殖列传", "para": "24", "seq": 5, "text": "南阳西通武关、郧关，东南受汉、江、淮。", "len": 19}
{"sid": "129_货殖列传.24.s6", "chapter": "129_货殖列传", "para": "24", "seq": 6, "text": "宛亦一都会也。", "len": 7}
{"sid": "129_货殖列传.24.s7", "chapter": "129_货殖列传", "para": "24", "seq": 7, "text": "俗杂好事，业多贾。", "len": 9}
{"sid": "129_货殖列传.24.s8", "chapter": "129_货殖列传", "para": "24", "seq": 8, "text": "其任侠，交通颍川，故至今谓之“夏人”。", "len": 19}
{"sid": "129_货殖列传.25.s1", "chapter": "129_货殖列传", "para": "25", "seq": 1, "text": "夫天下物所鲜所多，人民谣俗，山东食海盐，山西食盐卤，领南、沙北固往往出盐，大体如此矣。", "len": 43}
{"sid": "129_货殖列传.26.s1", "chapter": "129_货殖列传", "para": "26", "seq": 1, "text": "总之，楚越之地，地广人希，饭稻羹鱼，或火耕而水耨，果隋蠃蛤，不待贾而足，地埶饶食，无饥馑之患，以故呰窳偷生，无积聚而多贫。", "len": 61}
{"sid": "129_货殖列传.26.s2", "chapter": "129_货殖列传", "para": "26", "seq": 2, "text": "是故江淮以南，无冻饿之人，亦无千金之家。", "len": 20}
{"sid": "129_货殖列传.26.s3", "chapter": "129_货殖列传", "para": "26", "seq": 3, "text": "沂、泗水以北，宜五穀桑麻六畜，地小人众，数被水旱之害，民好畜藏，故秦、夏、梁、鲁好农而重民。", "len": 46}
{"sid": "129_货殖列传.26.s4", "chapter": "129_货殖列传", "para": "26", "seq": 4, "text": "三河、宛、陈亦然，加以商贾。", "len": 14}
{"sid": "129_货殖列传.26.s5", "chapter": "129_货殖列传", "para": "26", "seq": 5, "text": "齐、赵设智巧，仰机利。", "len": 11}
{"sid": "129_货殖列传.26.s6", "chapter": "129_货殖列传", "para": "26", "seq": 6, "text": "燕、代田畜而事蚕。", "len": 9}
{"sid": "129_货殖列传.27.s1", "chapter": "129_货殖列传", "para": "27", "seq": 1, "text": "由此观之，贤人深谋於廊庙，论议朝廷，守信死节隐居岩穴之士设为名高者安归乎？", "len": 37}
{"sid": "129_货殖列传.27.s2", "chapter": "129_货殖列传", "para": "27", "seq": 2, "text": "归於富厚也。", "len": 6}
{"sid": "129_货殖列传.27.s3", "chapter": "129_货殖列传", "para": "27", "seq": 3, "text": "是以廉吏久，久更富，廉贾归富。", "len": 15}
{"sid": "129_货殖列传.27.s4", "chapter": "129_货殖列传", "para": "27", "seq": 4, "text": "富者，人之情性，所不学而俱欲者也。", "len": 17}
{"sid": "129_货殖列传.27.s5", "chapter": "129_货殖列传", "para": "27", "seq": 5, "text": "故壮士在军，攻城先登，陷阵卻敌，斩将搴旗，前蒙矢石，不避汤火之难者，为重赏使也。", "len": 40}
{"sid": "129_货殖列传.27.s6", "chapter": "129_货殖列传", "para": "27", "seq": 6, "text": "其在闾巷少年，攻剽椎埋，劫人作奸，掘冢铸币，任侠并兼，借交报仇，篡逐幽隐，不避法禁，走死地如骛者，其实皆为财用耳。", "len": 57}
{"sid": "129_货殖列传.27.s7", "chapter": "129_货殖列传", "para": "27", "seq": 7, "text": "今夫赵女郑姬，设形容，揳鸣琴，揄长袂，蹑利屣，目挑心招，出不远千里，不择老少者，奔富厚也。", "len": 45}
{"sid": "129_货殖列传.27.s8", "chapter": "129_货殖列传", "para": "27", "seq": 8, "text": "游闲公子，饰冠剑，连车骑，亦为富贵容也。", "len": 20}
{"sid": "129_货殖列传.27.s9", "chapter": "129_货殖列传", "para": "27", "seq": 9, "text": "弋射渔猎，犯晨夜，冒霜雪，驰阬谷，不避猛兽之害，为得味也。", "len": 29}
{"sid": "129_货殖列传.27.s10", "chapter": "129_货殖列传", "para": "27", "seq": 10, "text": "博戏驰逐，斗鸡走狗，作色相矜，必争胜者，重失负也。", "len": 25}
{"sid": "129_货殖列传.27.s11", "chapter": "129_货殖列传", "para": "27", "seq": 11, "text": "医方诸食技术之人，焦神极能，为重糈也。", "len": 19}
{"sid": "129_货殖列传.27.s12", "chapter": "129_货殖列传", "para": "27", "seq": 12, "text": "吏士舞文弄法，刻章伪书，不避刀锯之诛者，没於赂遗也。", "len": 26}
{"sid": "129_货殖列传.27.s13", "chapter": "129_货殖列传", "para": "27", "seq": 13, "text": "农工商贾畜长，固求富益货也。", "len": 14}
{"sid": "129_货殖列传.27.s14", "chapter": "129_货殖列传", "para": "27", "seq": 14, "text": "此有知尽能索耳，终不馀力而让财矣。", "len": 17}
{"sid": "129_货殖列传.28.s1", "chapter": "129_货殖列传", "para": "28", "seq": 1, "text": "谚曰：“百里不贩樵，千里不贩籴。", "len": 16}
{"sid": "129_货殖列传.28.s2", "chapter": "129_货殖列传", "para": "28", "seq": 2, "text": "” 居之一岁，种之以穀；十岁，树之以木；百岁，来之以德。", "len": 28}
{"sid": "129_货殖列传.28.s3", "chapter": "129_货殖列传", "para": "28", "seq": 3, "text": "德者，人物之谓也。", "len": 9}
{"sid": "129_货殖列传.28.s4", "chapter": "129_货殖列传", "para": "28", "seq": 4, "text": "今有无秩禄之奉，爵邑之入，而乐与之比者。", "len": 20}
{"sid": "129_货殖列传.28.s5", "chapter": "129_货殖列传", "para": "28", "seq": 5, "text": "命曰“素封”。", "len": 7}
{"sid": "129_货殖列传.28.s6", "chapter": "129_货殖列传", "para": "28", "seq": 6, "text": "封者食租税，岁率户二百。", "len": 12}
{"sid": "129_货殖列传.28.s7", "chapter": "129_货殖列传", "para": "28", "seq": 7, "text": "千户之君则二十万，朝觐聘享出其中。", "len": 17}
{"sid": "129_货殖列传.28.s8", "chapter": "129_货殖列传", "para": "28", "seq": 8, "text": "庶民农工商贾，率亦岁万息二千，百万之家则二十万，而更徭租赋出其中。", "len": 33}
{"sid": "129_货殖列传.28.s9", "chapter": "129_货殖列传", "para": "28", "seq": 9, "text": "衣食之欲，恣所好美矣。", "len": 11}
{"sid": "129_货殖列传.28.s10", "chapter": "129_货殖列传", "para": "28", "seq": 10, "text": "故曰陆地牧马二百蹄，牛蹄角千，千足羊，泽中千足彘，水居千石鱼陂，山居千章之材。", "len": 39}
{"sid": "129_货殖列传.28.s11", "chapter": "129_货殖列传", "para": "28", "seq": 11, "text": "安邑千树枣；燕、秦千树栗；蜀、汉、江陵千树橘；淮北、常山已南，河济之间千树萩；陈、夏千亩漆；齐、鲁千亩桑麻；渭川千亩竹；及名国万家之城，带郭千亩亩锺之田，若千亩卮茜，千畦姜韭：此其人皆与千户侯等。", "len": 98}
{"sid": "129_货殖列传.28.s12", "chapter": "129_货殖列传", "para": "28", "seq": 12, "text": "然是富给之资也，不窥市井，不行异邑，坐而待收，身有处士之义而取给焉。", "len": 34}
{"sid": "129_货殖列传.28.s13", "chapter": "129_货殖列传", "para": "28", "seq": 13, "text": "若至家贫亲老，妻子软弱，岁时无以祭祀进醵，饮食被服不足以自通，如此不惭耻，则无所比矣。", "len": 43}
{"sid": "129_货殖列传.28.s14", "chapter": "129_货殖列传", "para": "28", "seq": 14, "text": "是以无财作力，少有斗智，既饶争时，此其大经也。", "len": 23}
{"sid": "129_货殖列传.28.s15", "chapter": "129_货殖列传", "para": "28", "seq": 15, "text": "今治生不待危身取给，则贤人勉焉。", "len": 16}
{"sid": "129_货殖列传.28.s16", "chapter": "129_货殖列传", "para": "28", "seq": 16, "text": "是故本富为上，末富次之，奸富最下。", "len": 17}
{"sid": "129_货殖列传.28.s17", "chapter": "129_货殖列传", "para": "28", "seq": 17, "text": "无岩处奇士之行，而长贫贱，好语仁义，亦足羞也。", "len": 23}
{"sid": "129_货殖列传.29.s1", "chapter": "129_货殖列传", "para": "29", "seq": 1, "text": "凡编户之民，富相什则卑下之，伯则畏惮之，千则役，万则仆，物之理也。", "len": 33}
{"sid": "129_货殖列传.29.s2", "chapter": "129_货殖列传", "para": "29", "seq": 2, "text": "夫用贫求富，农不如工，工不如商，刺绣文不如倚市门，此言末业，贫者之资也。", "len": 36}
{"sid": "129_货殖列传.29.s3", "chapter": "129_货殖列传", "para": "29", "seq": 3, "text": "通邑大都，酤一岁千酿，醯酱千瓨，浆千甔，屠牛羊彘千皮，贩穀粜千锺，薪稾千车，船长千丈，木千章，竹竿万个，其轺车百乘，牛车千两，木器魨者千枚，铜器千钧，素木铁器若卮茜千石，马蹄躈千，牛千足，羊彘千双，僮手指千，筋角丹沙千斤，其帛絮细布千钧，文采千匹，榻布皮革千石，漆千斗，糵麹盐豉千荅，鮐{此鱼}千斤，鲰千石，鲍千钧，枣栗千石者三之，狐龂裘千皮，羔羊裘千石，旃席千具，佗果菜千锺，子贷金钱千贯，节駔会，贪贾三之，廉贾五之，此亦比千乘之家，其大率也。", "len": 223}
{"sid": "129_货殖列传.29.s4", "chapter": "129_货殖列传", "para": "29", "seq": 4, "text": "佗杂业不中什二，则非吾财也。", "len": 14}
{"sid": "129_货殖列传.30.s1", "chapter": "129_货殖列传", "para": "30", "seq": 1, "text": "请略道当世千里之中，贤人所以富者，令後世得以观择焉。", "len": 26}
{"sid": "129_货殖列传.31.s1", "chapter": "129_货殖列传", "para": "31", "seq": 1, "text": "蜀卓氏之先，赵人也，用铁冶富。", "len": 15}
{"sid": "129_货殖列传.31.s2", "chapter": "129_货殖列传", "para": "31", "seq": 2, "text": "秦破赵，迁卓氏。", "len": 8}
{"sid": "129_货殖列传.31.s3", "chapter": "129_货殖列传", "para": "31", "seq": 3, "text": "卓氏见虏略，独夫妻推辇，行诣迁处。", "len": 17}
{"sid": "129_货殖列传.31.s4", "chapter": "129_货殖列传", "para": "31", "seq": 4, "text": "诸迁虏少有馀财，争与吏，求近处，处葭萌。", "len": 20}
{"sid": "129_货殖列传.31.s5", "chapter": "129_货殖列传", "para": "31", "seq": 5, "text": "唯卓氏曰：“此地狭薄。", "len": 11}
{"sid": "129_货殖列传.31.s6", "chapter": "129_货殖列传", "para": "31", "seq": 6, "text": "吾闻汶山之下，沃野，下有蹲鸱，至死不饥。", "len": 20}
{"sid": "129_货殖列传.31.s7", "chapter": "129_货殖列传", "para": "31", "seq": 7, "text": "民工於市，易贾。", "len": 8}
{"sid": "129_货殖列传.31.s8", "chapter": "129_货殖列传", "para": "31", "seq": 8, "text": "” 乃求远迁。", "len": 7}
{"sid": "129_货殖列传.31.s9", "chapter": "129_货殖列传", "para": "31", "seq": 9, "text": "致之临邛，大喜，即铁山鼓铸，运筹策，倾滇蜀之民，富至僮千人。", "len": 30}
{"sid": "129_货殖列传.31.s10", "chapter": "129_货殖列传", "para": "31", "seq": 10, "text": "田池射猎之乐，拟於人君。", "len": 12}
{"sid": "129_货殖列传.32.s1", "chapter": "129_货殖列传", "para": "32", "seq": 1, "text": "程郑，山东迁虏也，亦冶铸，贾椎髻之民，富埒卓氏，俱居临邛。", "len": 29}
{"sid": "129_货殖列传.33.s1", "chapter": "129_货殖列传", "para": "33", "seq": 1, "text": "宛孔氏之先，梁人也，用铁冶为业。", "len": 16}
{"sid": "129_货殖列传.33.s2", "chapter": "129_货殖列传", "para": "33", "seq": 2, "text": "秦伐魏，迁孔氏南阳。", "len": 10}
{"sid": "129_货殖列传.33.s3", "chapter": "129_货殖列传", "para": "33", "seq": 3, "text": "大鼓铸，规陂池，连车骑，游诸侯，因通商贾之利，有游闲公子之赐与名。", "len": 33}
{"sid": "129_货殖列传.33.s4", "chapter": "129_货殖列传", "para": "33", "seq": 4, "text": "然其赢得过当，愈於纤啬，家致富数千金，故南阳行贾尽法孔氏之雍容。", "len": 32}
{"sid": "129_货殖列传.34.s1", "chapter": "129_货殖列传", "para": "34", "seq": 1, "text": "鲁人俗俭啬，而曹邴氏尤甚，以铁冶起，富至巨万。", "len": 23}
{"sid": "129_货殖列传.34.s2", "chapter": "129_货殖列传", "para": "34", "seq": 2, "text": "然家自父兄子孙约，俯有拾，仰有取，贳贷行贾遍郡国。", "len": 25}
{"sid": "129_货殖列传.34.s3", "chapter": "129_货殖列传", "para": "34", "seq": 3, "text": "邹、鲁以其故多去文学而趋利者，以曹邴氏也。", "len": 21}
{"sid": "129_货殖列传.35.s1", "chapter": "129_货殖列传", "para": "35", "seq": 1, "text": "齐俗贱奴虏，而刀间独爱贵之。", "len": 14}
{"sid": "129_货殖列传.35.s2", "chapter": "129_货殖列传", "para": "35", "seq": 2, "text": "桀黠奴，人之所患也，唯刀间收取，使之逐渔盐商贾之利，或连车骑，交守相，然愈益任之。", "len": 41}
{"sid": "129_货殖列传.35.s3", "chapter": "129_货殖列传", "para": "35", "seq": 3, "text": "终得其力，起富数千万。", "len": 11}
{"sid": "129_货殖列传.35.s4", "chapter": "129_货殖列传", "para": "35", "seq": 4, "text": "故曰“宁爵毋刀”，言其能使豪奴自饶而尽其力。", "len": 22}
{"sid": "129_货殖列传.36.s1", "chapter": "129_货殖列传", "para": "36", "seq": 1, "text": "周人既纤，而师史尤甚，转毂以百数，贾郡国，无所不至。", "len": 26}
{"sid": "129_货殖列传.36.s2", "chapter": "129_货殖列传", "para": "36", "seq": 2, "text": "洛阳街居在齐秦楚赵之中，贫人学事富家，相矜以久贾，数过邑不入门，设任此等，故师史能致七千万。", "len": 46}
{"sid": "129_货殖列传.37.s1", "chapter": "129_货殖列传", "para": "37", "seq": 1, "text": "宣曲任氏之先，为督道仓吏。", "len": 13}
{"sid": "129_货殖列传.37.s2", "chapter": "129_货殖列传", "para": "37", "seq": 2, "text": "秦之败也，豪杰皆争取金玉，而任氏独窖仓粟。", "len": 21}
{"sid": "129_货殖列传.37.s3", "chapter": "129_货殖列传", "para": "37", "seq": 3, "text": "楚汉相距荥阳也，民不得耕种，米石至万，而豪杰金玉尽归任氏，任氏以此起富。", "len": 36}
{"sid": "129_货殖列传.37.s4", "chapter": "129_货殖列传", "para": "37", "seq": 4, "text": "富人争奢侈，而任氏折节为俭，力田畜。", "len": 18}
{"sid": "129_货殖列传.37.s5", "chapter": "129_货殖列传", "para": "37", "seq": 5, "text": "田畜人争取贱贾，任氏独取贵善。", "len": 15}
{"sid": "129_货殖列传.37.s6", "chapter": "129_货殖列传", "para": "37", "seq": 6, "text": "富者数世。", "len": 5}
{"sid": "129_货殖列传.37.s7", "chapter": "129_货殖列传", "para": "37", "seq": 7, "text": "然任公家约，非田畜所出弗衣食，公事不毕则身不得饮酒食肉。", "len": 28}
{"sid": "129_货殖列传.37.s8", "chapter": "129_货殖列传", "para": "37", "seq": 8, "text": "以此为闾里率，故富而主上重之。", "len": 15}
{"sid": "129_货殖列传.38.s1", "chapter": "129_货殖列传", "para": "38", "seq": 1, "text": "塞之斥也，唯桥姚已致马千匹，牛倍之，羊万头，粟以万锺计。", "len": 28}
{"sid": "129_货殖列传.38.s2", "chapter": "129_货殖列传", "para": "38", "seq": 2, "text": "吴楚七国兵起时，长安中列侯封君行从军旅，赍贷子钱，子钱家以为侯邑国在关东，关东成败未决，莫肯与。", "len": 48}
{"sid": "129_货殖列传.38.s3", "chapter": "129_货殖列传", "para": "38", "seq": 3, "text": "唯无盐氏出捐千金贷，其息什之。", "len": 15}
{"sid": "129_货殖列传.38.s4", "chapter": "129_货殖列传", "para": "38", "seq": 4, "text": "三月，吴楚平，一岁之中，则无盐氏之息什倍，用此富埒关中。", "len": 28}
{"sid": "129_货殖列传.39.s1", "chapter": "129_货殖列传", "para": "39", "seq": 1, "text": "关中富商大贾，大抵尽诸田，田啬、田兰。", "len": 19}
{"sid": "129_货殖列传.39.s2", "chapter": "129_货殖列传", "para": "39", "seq": 2, "text": "韦家栗氏，安陵、杜杜氏，亦巨万。", "len": 16}
{"sid": "129_货殖列传.40.s1", "chapter": "129_货殖列传", "para": "40", "seq": 1, "text": "此其章章尤异者也。", "len": 9}
{"sid": "129_货殖列传.40.s2", "chapter": "129_货殖列传", "para": "40", "seq": 2, "text": "皆非有爵邑奉禄弄法犯奸而富，尽椎埋去就，与时俯仰，获其赢利，以末致财，用本守之，以武一切，用文持之，变化有概，故足术也。", "len": 60}
{"sid": "129_货殖列传.40.s3", "chapter": "129_货殖列传", "para": "40", "seq": 3, "text": "若至力农畜，工虞商贾，为权利以成富，大者倾郡，中者倾县，下者倾乡里者，不可胜数。", "len": 40}
{"sid": "129_货殖列传.41.s1", "chapter": "129_货殖列传", "para": "41", "seq": 1, "text": "夫纤啬筋力，治生之正道也，而富者必用奇胜。", "len": 21}
{"sid": "129_货殖列传.41.s2", "chapter": "129_货殖列传", "para": "41", "seq": 2, "text": "田农，掘业，而秦扬以盖一州。", "len": 14}
{"sid": "129_货殖列传.41.s3", "chapter": "129_货殖列传", "para": "41", "seq": 3, "text": "掘冢，奸事也，而田叔以起。", "len": 13}
{"sid": "129_货殖列传.41.s4", "chapter": "129_货殖列传", "para": "41", "seq": 4, "text": "博戏，恶业也，而桓发用富。", "len": 13}
{"sid": "129_货殖列传.41.s5", "chapter": "129_货殖列传", "para": "41", "seq": 5, "text": "行贾，丈夫贱行也，而雍乐成以饶。", "len": 16}
{"sid": "129_货殖列传.41.s6", "chapter": "129_货殖列传", "para": "41", "seq": 6, "text": "贩脂，辱处也，而雍伯千金。", "len": 13}
{"sid": "129_货殖列传.41.s7", "chapter": "129_货殖列传", "para": "41", "seq": 7, "text": "卖浆，小业也，而张氏千万。", "len": 13}
{"sid": "129_货殖列传.41.s8", "chapter": "129_货殖列传", "para": "41", "seq": 8, "text": "洒削，薄技也，而郅氏鼎食。", "len": 13}
{"sid": "129_货殖列传.41.s9", "chapter": "129_货殖列传", "para": "41", "seq": 9, "text": "胃脯，简微耳，浊氏连骑。", "len": 12}
{"sid": "129_货殖列传.41.s10", "chapter": "129_货殖列传", "para": "41", "seq": 10, "text": "马医，浅方，张里击锺。", "len": 11}
{"sid": "129_货殖列传.41.s11", "chapter": "129_货殖列传", "para": "41", "seq": 11, "text": "此皆诚壹之所致。", "len": 8}
{"sid": "129_货殖列传.42.s1", "chapter": "129_货殖列传", "para": "42", "seq": 1, "text": "由是观之，富无经业，则货无常主，能者辐凑，不肖者瓦解。", "len": 27}
{"sid": "129_货殖列传.42.s2", "chapter": "129_货殖列传", "para": "42", "seq": 2, "text": "千金之家比一都之君，巨万者乃与王者同乐。", "len": 20}
{"sid": "129_货殖列传.42.s3", "chapter": "129_货殖列传", "para": "42", "seq": 3, "text": "岂所谓“素封” 者邪？", "len": 11}
{"sid": "129_货殖列传.42.s4", "chapter": "129_货殖列传", "para": "42", "seq": 4, "text": "非也？", "len": 3}
{"sid": "129_货殖列传.42.s5", "chapter": "129_货殖列传", "para": "42", "seq": 5, "text": "::: 赞", "len": 5}
{"sid": "129_货殖列传.43.s1", "chapter": "129_货殖列传", "para": "43", "seq": 1, "text": "货殖之利，工商是营。", "len": 10}
{"sid": "129_货殖列传.43.s2", "chapter": "129_货殖列传", "para": "43", "seq": 2, "text": "废居善积，倚巿邪赢。", "len": 10}
{"sid": "129_货殖列传.43.s3", "chapter": "129_货殖列传", "para": "43", "seq": 3, "text": "白圭富国，计然强兵。", "len": 10}
{"sid": "129_货殖列传.43.s4", "chapter": "129_货殖列传", "para": "43", "seq": 4, "text": "倮参朝请，女筑怀清。", "len": 10}
{"sid": "129_货殖列传.43.s5", "chapter": "129_货殖列传", "para": "43", "seq": 5, "text": "素封千户，卓郑齐名。", "len": 10}
