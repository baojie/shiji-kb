{"sid": "098_傅靳蒯成列传.1.s1", "chapter": "098_傅靳蒯成列传", "para": "1", "seq": 1, "text": "阳陵侯傅宽，以魏五大夫骑将从，为舍人，起横阳。", "len": 23}
{"sid": "098_傅靳蒯成列传.1.s2", "chapter": "098_傅靳蒯成列传", "para": "1", "seq": 2, "text": "从攻安阳、杠里，击赵贲军於开封，及击杨熊曲遇、阳武，斩首十二级，赐爵卿。", "len": 36}
{"sid": "098_傅靳蒯成列传.1.s3", "chapter": "098_傅靳蒯成列传", "para": "1", "seq": 3, "text": "从至霸上。", "len": 5}
{"sid": "098_傅靳蒯成列传.1.s4", "chapter": "098_傅靳蒯成列传", "para": "1", "seq": 4, "text": "沛公立为汉王，汉王赐宽封号共德君。", "len": 17}
{"sid": "098_傅靳蒯成列传.1.s5", "chapter": "098_傅靳蒯成列传", "para": "1", "seq": 5, "text": "从入汉中，迁为右骑将。", "len": 11}
{"sid": "098_傅靳蒯成列传.1.s6", "chapter": "098_傅靳蒯成列传", "para": "1", "seq": 6, "text": "从定三秦，赐食邑雕阴。", "len": 11}
{"sid": "098_傅靳蒯成列传.1.s7", "chapter": "098_傅靳蒯成列传", "para": "1", "seq": 7, "text": "从击项籍，待怀，赐爵通德侯。", "len": 14}
{"sid": "098_傅靳蒯成列传.1.s8", "chapter": "098_傅靳蒯成列传", "para": "1", "seq": 8, "text": "从击项冠、周兰、龙且，所将卒斩骑将一人敖下，益食邑。", "len": 26}
{"sid": "098_傅靳蒯成列传.2.s1", "chapter": "098_傅靳蒯成列传", "para": "2", "seq": 1, "text": "属淮阴，击破齐历下军，击田解。", "len": 15}
{"sid": "098_傅靳蒯成列传.2.s2", "chapter": "098_傅靳蒯成列传", "para": "2", "seq": 2, "text": "属相国参，残博，益食邑。", "len": 12}
{"sid": "098_傅靳蒯成列传.2.s3", "chapter": "098_傅靳蒯成列传", "para": "2", "seq": 3, "text": "因定齐地，剖符世世勿绝，封为阳陵侯，二千六百户，除前所食。", "len": 29}
{"sid": "098_傅靳蒯成列传.2.s4", "chapter": "098_傅靳蒯成列传", "para": "2", "seq": 4, "text": "为齐右丞相，备齐。", "len": 9}
{"sid": "098_傅靳蒯成列传.2.s5", "chapter": "098_傅靳蒯成列传", "para": "2", "seq": 5, "text": "五岁为齐相国。", "len": 7}
{"sid": "098_傅靳蒯成列传.3.s1", "chapter": "098_傅靳蒯成列传", "para": "3", "seq": 1, "text": "四月，击陈豨，属太尉勃，以相国代丞相哙击豨。", "len": 22}
{"sid": "098_傅靳蒯成列传.3.s2", "chapter": "098_傅靳蒯成列传", "para": "3", "seq": 2, "text": "一月，徙为代相国，将屯。", "len": 12}
{"sid": "098_傅靳蒯成列传.3.s3", "chapter": "098_傅靳蒯成列传", "para": "3", "seq": 3, "text": "二岁，为代丞相，将屯。", "len": 11}
{"sid": "098_傅靳蒯成列传.4.s1", "chapter": "098_傅靳蒯成列传", "para": "4", "seq": 1, "text": "孝惠五年卒，谥为景侯。", "len": 11}
{"sid": "098_傅靳蒯成列传.4.s2", "chapter": "098_傅靳蒯成列传", "para": "4", "seq": 2, "text": "子顷侯精立，二十四年卒。", "len": 12}
{"sid": "098_傅靳蒯成列传.4.s3", "chapter": "098_傅靳蒯成列传", "para": "4", "seq": 3, "text": "子共侯则立，十二年卒。", "len": 11}
{"sid": "098_傅靳蒯成列传.4.s4", "chapter": "098_傅靳蒯成列传", "para": "4", "seq": 4, "text": "子侯偃立，三十一年，坐与淮南王谋反，死，国除。", "len": 23}
{"sid": "098_傅靳蒯成列传.5.s1", "chapter": "098_傅靳蒯成列传", "para": "5", "seq": 1, "text": "信武侯靳歙，以中涓从，起宛朐。", "len": 15}
{"sid": "098_傅靳蒯成列传.5.s2", "chapter": "098_傅靳蒯成列传", "para": "5", "seq": 2, "text": "攻济阳。", "len": 4}
{"sid": "098_傅靳蒯成列传.5.s3", "chapter": "098_傅靳蒯成列传", "para": "5", "seq": 3, "text": "破李由军。", "len": 5}
{"sid": "098_傅靳蒯成列传.5.s4", "chapter": "098_傅靳蒯成列传", "para": "5", "seq": 4, "text": "击秦军亳南、开封东北，斩骑千人将一人，首五十七级，捕虏七十三人，赐爵封号临平君。", "len": 40}
{"sid": "098_傅靳蒯成列传.5.s5", "chapter": "098_傅靳蒯成列传", "para": "5", "seq": 5, "text": "又战蓝田北，斩车司马二人，骑长一人，首二十八级，捕虏五十七人。", "len": 31}
{"sid": "098_傅靳蒯成列传.5.s6", "chapter": "098_傅靳蒯成列传", "para": "5", "seq": 6, "text": "至霸上。", "len": 4}
{"sid": "098_傅靳蒯成列传.5.s7", "chapter": "098_傅靳蒯成列传", "para": "5", "seq": 7, "text": "沛公立为汉王，赐歙爵建武侯，迁为骑都尉。", "len": 20}
{"sid": "098_傅靳蒯成列传.6.s1", "chapter": "098_傅靳蒯成列传", "para": "6", "seq": 1, "text": "从定三秦。", "len": 5}
{"sid": "098_傅靳蒯成列传.6.s2", "chapter": "098_傅靳蒯成列传", "para": "6", "seq": 2, "text": "别西击章平军於陇西，破之，定陇西六县，所将卒斩车司马、候各四人，骑长十二人。", "len": 38}
{"sid": "098_傅靳蒯成列传.6.s3", "chapter": "098_傅靳蒯成列传", "para": "6", "seq": 3, "text": "从东击楚，至彭城。", "len": 9}
{"sid": "098_傅靳蒯成列传.6.s4", "chapter": "098_傅靳蒯成列传", "para": "6", "seq": 4, "text": "汉军败还，保雍丘，去击反者王武等。", "len": 17}
{"sid": "098_傅靳蒯成列传.6.s5", "chapter": "098_傅靳蒯成列传", "para": "6", "seq": 5, "text": "略梁地，别将击邢说军菑南，破之，身得说都尉二人，司马、候十二人，降吏卒四千一百八十人。", "len": 43}
{"sid": "098_傅靳蒯成列传.6.s6", "chapter": "098_傅靳蒯成列传", "para": "6", "seq": 6, "text": "破楚军荥阳东。", "len": 7}
{"sid": "098_傅靳蒯成列传.6.s7", "chapter": "098_傅靳蒯成列传", "para": "6", "seq": 7, "text": "三年，赐食邑四千二百户。", "len": 12}
{"sid": "098_傅靳蒯成列传.7.s1", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 1, "text": "别之河内，击赵将贲郝军朝歌，破之，所将卒得骑将二人，车马二百五十匹。", "len": 34}
{"sid": "098_傅靳蒯成列传.7.s2", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 2, "text": "从攻安阳以东，至棘蒲，下七县。", "len": 15}
{"sid": "098_傅靳蒯成列传.7.s3", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 3, "text": "别攻破赵军，得其将司马二人，候四人，降吏卒二千四百人。", "len": 27}
{"sid": "098_傅靳蒯成列传.7.s4", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 4, "text": "从攻下邯郸。", "len": 6}
{"sid": "098_傅靳蒯成列传.7.s5", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 5, "text": "别下平阳，身斩守相，所将卒斩兵守、郡守各一人，降鄴。", "len": 26}
{"sid": "098_傅靳蒯成列传.7.s6", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 6, "text": "从攻朝歌、邯郸，及别击破赵军，降邯郸郡六县。", "len": 22}
{"sid": "098_傅靳蒯成列传.7.s7", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 7, "text": "还军敖仓，破项籍军成皋南，击绝楚饟道，起荥阳至襄邑。", "len": 26}
{"sid": "098_傅靳蒯成列传.7.s8", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 8, "text": "破项冠军鲁下。", "len": 7}
{"sid": "098_傅靳蒯成列传.7.s9", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 9, "text": "略地东至缯、郯、下邳，南至蕲、竹邑。", "len": 18}
{"sid": "098_傅靳蒯成列传.7.s10", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 10, "text": "击项悍济阳下。", "len": 7}
{"sid": "098_傅靳蒯成列传.7.s11", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 11, "text": "还击项籍陈下，破之。", "len": 10}
{"sid": "098_傅靳蒯成列传.7.s12", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 12, "text": "别定江陵，降江陵柱国、大司马以下八人，身得江陵王，生致之雒阳，因定南郡。", "len": 36}
{"sid": "098_傅靳蒯成列传.7.s13", "chapter": "098_傅靳蒯成列传", "para": "7", "seq": 13, "text": "从至陈，取楚王信，剖符世世勿绝，定食四千六百户，号信武侯。", "len": 29}
{"sid": "098_傅靳蒯成列传.8.s1", "chapter": "098_傅靳蒯成列传", "para": "8", "seq": 1, "text": "以骑都尉从击代，攻韩信平城下，还军东垣。", "len": 20}
{"sid": "098_傅靳蒯成列传.8.s2", "chapter": "098_傅靳蒯成列传", "para": "8", "seq": 2, "text": "有功，迁为车骑将军，并将梁、赵、齐、燕、楚车骑，别击陈豨丞相敞，破之，因降曲逆。", "len": 40}
{"sid": "098_傅靳蒯成列传.8.s3", "chapter": "098_傅靳蒯成列传", "para": "8", "seq": 3, "text": "从击黥布有功，益封定食五千三百户。", "len": 17}
{"sid": "098_傅靳蒯成列传.8.s4", "chapter": "098_傅靳蒯成列传", "para": "8", "seq": 4, "text": "凡斩首九十级，虏百三十二人；别破军十四，降城五十九，定郡、国各一，县二十三；得王、柱国各一人，二千石以下至五百石三十九人。", "len": 61}
{"sid": "098_傅靳蒯成列传.9.s1", "chapter": "098_傅靳蒯成列传", "para": "9", "seq": 1, "text": "高后五年，歙卒，谥为肃侯。", "len": 13}
{"sid": "098_傅靳蒯成列传.9.s2", "chapter": "098_傅靳蒯成列传", "para": "9", "seq": 2, "text": "子亭代侯。", "len": 5}
{"sid": "098_傅靳蒯成列传.9.s3", "chapter": "098_傅靳蒯成列传", "para": "9", "seq": 3, "text": "二十一年，坐事国人过律，孝文後三年，夺侯，国除。", "len": 24}
{"sid": "098_傅靳蒯成列传.10.s1", "chapter": "098_傅靳蒯成列传", "para": "10", "seq": 1, "text": "蒯成侯緤者，沛人也，姓周氏。", "len": 14}
{"sid": "098_傅靳蒯成列传.10.s2", "chapter": "098_傅靳蒯成列传", "para": "10", "seq": 2, "text": "常为高祖参乘，以舍人从起沛。", "len": 14}
{"sid": "098_傅靳蒯成列传.10.s3", "chapter": "098_傅靳蒯成列传", "para": "10", "seq": 3, "text": "至霸上，西入蜀、汉，还定三秦，食邑池阳。", "len": 20}
{"sid": "098_傅靳蒯成列传.10.s4", "chapter": "098_傅靳蒯成列传", "para": "10", "seq": 4, "text": "东绝甬道，从出度平阴，遇淮阴侯兵襄国，军乍利乍不利，终无离上心。", "len": 32}
{"sid": "098_傅靳蒯成列传.10.s5", "chapter": "098_傅靳蒯成列传", "para": "10", "seq": 5, "text": "以緤为信武侯，食邑三千三百户。", "len": 15}
{"sid": "098_傅靳蒯成列传.10.s6", "chapter": "098_傅靳蒯成列传", "para": "10", "seq": 6, "text": "高祖十二年，以緤为蒯成侯，除前所食邑。", "len": 19}
{"sid": "098_傅靳蒯成列传.11.s1", "chapter": "098_傅靳蒯成列传", "para": "11", "seq": 1, "text": "上欲自击陈豨，蒯成侯泣曰：“始秦攻破天下，未尝自行。", "len": 26}
{"sid": "098_傅靳蒯成列传.11.s2", "chapter": "098_傅靳蒯成列传", "para": "11", "seq": 2, "text": "今上常自行，是为无人可使者乎？", "len": 15}
{"sid": "098_傅靳蒯成列传.11.s3", "chapter": "098_傅靳蒯成列传", "para": "11", "seq": 3, "text": "” 上以为” 爱我”，赐入殿门不趋，杀人不死。", "len": 23}
{"sid": "098_傅靳蒯成列传.12.s1", "chapter": "098_傅靳蒯成列传", "para": "12", "seq": 1, "text": "至孝文五年，緤以寿终，谥为贞侯。", "len": 16}
{"sid": "098_傅靳蒯成列传.12.s2", "chapter": "098_傅靳蒯成列传", "para": "12", "seq": 2, "text": "子昌代侯，有罪，国除。", "len": 11}
{"sid": "098_傅靳蒯成列传.12.s3", "chapter": "098_傅靳蒯成列传", "para": "12", "seq": 3, "text": "至孝景中二年，封緤子居代侯。", "len": 14}
{"sid": "098_傅靳蒯成列传.12.s4", "chapter": "098_傅靳蒯成列传", "para": "12", "seq": 4, "text": "至元鼎三年，居为太常，有罪，国除。", "len": 17}
{"sid": "098_傅靳蒯成列传.12.s5", "chapter": "098_傅靳蒯成列传", "para": "12", "seq": 5, "text": "::: 太史公曰", "len": 8}
{"sid": "098_傅靳蒯成列传.13.s1", "chapter": "098_傅靳蒯成列传", "para": "13", "seq": 1, "text": "太史公曰：阳陵侯傅宽、信武侯靳歙皆高爵，从高祖起山东，攻项籍，诛杀名将，破军降城以十数，未尝困辱，此亦天授也。", "len": 55}
{"sid": "098_傅靳蒯成列传.13.s2", "chapter": "098_傅靳蒯成列传", "para": "13", "seq": 2, "text": "蒯成侯周緤操心坚正，身不见疑，上欲有所之，未尝不垂涕，此有伤心者然，可谓笃厚君子矣。", "len": 42}
{"sid": "098_傅靳蒯成列传.13.s3", "chapter": "098_傅靳蒯成列传", "para": "13", "seq": 3, "text": "::: ::: 赞", "len": 9}
{"sid": "098_傅靳蒯成列传.14.s1", "chapter": "098_傅靳蒯成列传", "para": "14", "seq": 1, "text": "阳陵、信武，结发从汉。", "len": 11}
{"sid": "098_傅靳蒯成列传.14.s2", "chapter": "098_傅靳蒯成列传", "para": "14", "seq": 2, "text": "动叶人谋，功实天赞。", "len": 10}
{"sid": "098_傅靳蒯成列传.14.s3", "chapter": "098_傅靳蒯成列传", "para": "14", "seq": 3, "text": "定齐破项，我军常冠， 蒯成委质，夷险不乱。", "len": 21}
{"sid": "098_傅靳蒯成列传.14.s4", "chapter": "098_傅靳蒯成列传", "para": "14", "seq": 4, "text": "主上称忠，人臣鸧腕。", "len": 10}
{"sid": "098_傅靳蒯成列传.14.s5", "chapter": "098_傅靳蒯成列传", "para": "14", "seq": 5, "text": ":::", "len": 3}
