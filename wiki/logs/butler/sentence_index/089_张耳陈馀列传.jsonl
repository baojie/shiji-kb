{"sid": "089_张耳陈馀列传.1.s1", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 1, "text": "张耳者，大梁人也。", "len": 9}
{"sid": "089_张耳陈馀列传.1.s2", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 2, "text": "其少时，及魏公子毋忌为客。", "len": 13}
{"sid": "089_张耳陈馀列传.1.s3", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 3, "text": "张耳尝亡命游外黄。", "len": 9}
{"sid": "089_张耳陈馀列传.1.s4", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 4, "text": "外黄富人女甚美，嫁庸奴，亡其夫，去抵父客。", "len": 21}
{"sid": "089_张耳陈馀列传.1.s5", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 5, "text": "父客素知张耳，乃谓女曰：“必欲求贤夫，从张耳。", "len": 23}
{"sid": "089_张耳陈馀列传.1.s6", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 6, "text": "” 女听，乃卒为请决，嫁之张耳。", "len": 16}
{"sid": "089_张耳陈馀列传.1.s7", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 7, "text": "张耳是时脱身游，女家厚奉给张耳，张耳以故致千里客。", "len": 25}
{"sid": "089_张耳陈馀列传.1.s8", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 8, "text": "乃宦魏为外黄令。", "len": 8}
{"sid": "089_张耳陈馀列传.1.s9", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 9, "text": "名由此益贤。", "len": 6}
{"sid": "089_张耳陈馀列传.1.s10", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 10, "text": "陈馀者，亦大梁人也，好儒术，数游赵苦陉。", "len": 20}
{"sid": "089_张耳陈馀列传.1.s11", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 11, "text": "富人公乘氏以其女妻之，亦知陈馀非庸人也。", "len": 20}
{"sid": "089_张耳陈馀列传.1.s12", "chapter": "089_张耳陈馀列传", "para": "1", "seq": 12, "text": "馀年少，父事张耳，两人相与为刎颈交。", "len": 18}
{"sid": "089_张耳陈馀列传.2.s1", "chapter": "089_张耳陈馀列传", "para": "2", "seq": 1, "text": "秦之灭大梁也，张耳家外黄。", "len": 13}
{"sid": "089_张耳陈馀列传.2.s2", "chapter": "089_张耳陈馀列传", "para": "2", "seq": 2, "text": "高祖为布衣时，尝数从张耳游，客数月。", "len": 18}
{"sid": "089_张耳陈馀列传.2.s3", "chapter": "089_张耳陈馀列传", "para": "2", "seq": 3, "text": "秦灭魏数岁，已闻此两人魏之名士也，购求有得张耳千金，陈馀五百金。", "len": 32}
{"sid": "089_张耳陈馀列传.2.s4", "chapter": "089_张耳陈馀列传", "para": "2", "seq": 4, "text": "张耳、陈馀乃变名姓，俱之陈，为里监门以自食。", "len": 22}
{"sid": "089_张耳陈馀列传.2.s5", "chapter": "089_张耳陈馀列传", "para": "2", "seq": 5, "text": "两人相对。", "len": 5}
{"sid": "089_张耳陈馀列传.2.s6", "chapter": "089_张耳陈馀列传", "para": "2", "seq": 6, "text": "里吏尝有过笞陈馀，陈馀欲起，张耳蹑之，使受笞。", "len": 23}
{"sid": "089_张耳陈馀列传.2.s7", "chapter": "089_张耳陈馀列传", "para": "2", "seq": 7, "text": "吏去，张耳乃引陈馀之桑下而数之曰：“始吾与公言何如？", "len": 26}
{"sid": "089_张耳陈馀列传.2.s8", "chapter": "089_张耳陈馀列传", "para": "2", "seq": 8, "text": "今见小辱而欲死一吏乎？", "len": 11}
{"sid": "089_张耳陈馀列传.2.s9", "chapter": "089_张耳陈馀列传", "para": "2", "seq": 9, "text": "” 陈馀然之。", "len": 7}
{"sid": "089_张耳陈馀列传.2.s10", "chapter": "089_张耳陈馀列传", "para": "2", "seq": 10, "text": "秦诏书购求两人，两人亦反用门者以令里中。", "len": 20}
{"sid": "089_张耳陈馀列传.3.s1", "chapter": "089_张耳陈馀列传", "para": "3", "seq": 1, "text": "陈涉起蕲，至入陈，兵数万。", "len": 13}
{"sid": "089_张耳陈馀列传.3.s2", "chapter": "089_张耳陈馀列传", "para": "3", "seq": 2, "text": "张耳、陈馀上谒陈涉。", "len": 10}
{"sid": "089_张耳陈馀列传.3.s3", "chapter": "089_张耳陈馀列传", "para": "3", "seq": 3, "text": "涉及左右生平数闻张耳、陈馀贤，未尝见，见即大喜。", "len": 24}
{"sid": "089_张耳陈馀列传.4.s1", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 1, "text": "陈中豪杰父老乃说陈涉曰：“将军身被坚执锐，率士卒以诛暴秦，复立楚社稷，存亡继绝，功德宜为王。", "len": 46}
{"sid": "089_张耳陈馀列传.4.s2", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 2, "text": "且夫监临天下诸将，不为王不可，原将军立为楚王也。", "len": 24}
{"sid": "089_张耳陈馀列传.4.s3", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 3, "text": "” 陈涉问此两人，两人对曰：“夫秦为无道，破人国家，灭人社稷，绝人後世，罢百姓之力，尽百姓之财。", "len": 48}
{"sid": "089_张耳陈馀列传.4.s4", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 4, "text": "将军瞋目张胆，出万死不顾一生之计，为天下除残也。", "len": 24}
{"sid": "089_张耳陈馀列传.4.s5", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 5, "text": "今始至陈而王之，示天下私。", "len": 13}
{"sid": "089_张耳陈馀列传.4.s6", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 6, "text": "原将军毋王，急引兵而西，遣人立六国後，自为树党，为秦益敌也。", "len": 30}
{"sid": "089_张耳陈馀列传.4.s7", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 7, "text": "敌多则力分，与众则兵彊。", "len": 12}
{"sid": "089_张耳陈馀列传.4.s8", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 8, "text": "如此野无交兵，县无守城，诛暴秦，据咸阳以令诸侯。", "len": 24}
{"sid": "089_张耳陈馀列传.4.s9", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 9, "text": "诸侯亡而得立，以德服之，如此则帝业成矣。", "len": 20}
{"sid": "089_张耳陈馀列传.4.s10", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 10, "text": "今独王陈，恐天下解也。", "len": 11}
{"sid": "089_张耳陈馀列传.4.s11", "chapter": "089_张耳陈馀列传", "para": "4", "seq": 11, "text": "” 陈涉不听，遂立为王。", "len": 12}
{"sid": "089_张耳陈馀列传.5.s1", "chapter": "089_张耳陈馀列传", "para": "5", "seq": 1, "text": "陈馀乃复说陈王曰：“大王举梁、楚而西，务在入关，未及收河北也。", "len": 31}
{"sid": "089_张耳陈馀列传.5.s2", "chapter": "089_张耳陈馀列传", "para": "5", "seq": 2, "text": "臣尝游赵，知其豪桀及地形，原请奇兵北略赵地。", "len": 22}
{"sid": "089_张耳陈馀列传.5.s3", "chapter": "089_张耳陈馀列传", "para": "5", "seq": 3, "text": "” 於是陈王以故所善陈人武臣为将军，邵骚为护军，以张耳、陈馀为左右校尉，予卒三千人，北略赵地。", "len": 47}
{"sid": "089_张耳陈馀列传.6.s1", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 1, "text": "武臣等从白马渡河，至诸县，说其豪桀曰：“秦为乱政虐刑以残贼天下，数十年矣。", "len": 37}
{"sid": "089_张耳陈馀列传.6.s2", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 2, "text": "北有长城之役，南有五岭之戍，外内骚动，百姓罢敝，头会箕敛，以供军费，财匮力尽，民不聊生。", "len": 44}
{"sid": "089_张耳陈馀列传.6.s3", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 3, "text": "重之以苛法峻刑，使天下父子不相安。", "len": 17}
{"sid": "089_张耳陈馀列传.6.s4", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 4, "text": "陈王奋臂为天下倡始，王楚之地，方二千里，莫不响应，家自为怒，人自为斗，各报其怨而攻其雠，县杀其令丞，郡杀其守尉。", "len": 56}
{"sid": "089_张耳陈馀列传.6.s5", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 5, "text": "今已张大楚，王陈，使吴广、周文将卒百万西击秦。", "len": 23}
{"sid": "089_张耳陈馀列传.6.s6", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 6, "text": "於此时而不成封侯之业者，非人豪也。", "len": 17}
{"sid": "089_张耳陈馀列传.6.s7", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 7, "text": "诸君试相与计之！", "len": 8}
{"sid": "089_张耳陈馀列传.6.s8", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 8, "text": "夫天下同心而苦秦久矣。", "len": 11}
{"sid": "089_张耳陈馀列传.6.s9", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 9, "text": "因天下之力而攻无道之君，报父兄之怨而成割地有土之业，此士之一时也。", "len": 33}
{"sid": "089_张耳陈馀列传.6.s10", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 10, "text": "” 豪桀皆然其言。", "len": 9}
{"sid": "089_张耳陈馀列传.6.s11", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 11, "text": "乃行收兵，得数万人，号武臣为武信君。", "len": 18}
{"sid": "089_张耳陈馀列传.6.s12", "chapter": "089_张耳陈馀列传", "para": "6", "seq": 12, "text": "下赵十城，馀皆城守，莫肯下。", "len": 14}
{"sid": "089_张耳陈馀列传.7.s1", "chapter": "089_张耳陈馀列传", "para": "7", "seq": 1, "text": "乃引兵东北击范阳。", "len": 9}
{"sid": "089_张耳陈馀列传.7.s2", "chapter": "089_张耳陈馀列传", "para": "7", "seq": 2, "text": "范阳人蒯通说范阳令曰：“窃闻公之将死，故吊。", "len": 22}
{"sid": "089_张耳陈馀列传.7.s3", "chapter": "089_张耳陈馀列传", "para": "7", "seq": 3, "text": "虽然，贺公得通而生。", "len": 10}
{"sid": "089_张耳陈馀列传.7.s4", "chapter": "089_张耳陈馀列传", "para": "7", "seq": 4, "text": "” 范阳令曰：“何以吊之？", "len": 13}
{"sid": "089_张耳陈馀列传.7.s5", "chapter": "089_张耳陈馀列传", "para": "7", "seq": 5, "text": "” 对曰：“秦法重，足下为范阳令十年矣，杀人之父，孤人之子，断人之足，黥人之首，不可胜数。", "len": 45}
{"sid": "089_张耳陈馀列传.7.s6", "chapter": "089_张耳陈馀列传", "para": "7", "seq": 6, "text": "然而慈父孝子莫敢倳刃公之腹中者，畏秦法耳。", "len": 21}
{"sid": "089_张耳陈馀列传.7.s7", "chapter": "089_张耳陈馀列传", "para": "7", "seq": 7, "text": "今天下大乱，秦法不施，然则慈父孝子且倳刃公之腹中以成其名，此臣之所以吊公也。", "len": 38}
{"sid": "089_张耳陈馀列传.7.s8", "chapter": "089_张耳陈馀列传", "para": "7", "seq": 8, "text": "今诸侯畔秦矣，武信君兵且至，而君坚守范阳，少年皆争杀君，下武信君。", "len": 33}
{"sid": "089_张耳陈馀列传.7.s9", "chapter": "089_张耳陈馀列传", "para": "7", "seq": 9, "text": "君急遣臣见武信君，可转祸为福，在今矣。”", "len": 20}
{"sid": "089_张耳陈馀列传.8.s1", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 1, "text": "范阳令乃使蒯通见武信君曰：“足下必将战胜然後略地，攻得然後下城，臣窃以为过矣。", "len": 39}
{"sid": "089_张耳陈馀列传.8.s2", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 2, "text": "诚听臣之计，可不攻而降城，不战而略地，传檄而千里定，可乎？", "len": 29}
{"sid": "089_张耳陈馀列传.8.s3", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 3, "text": "” 武信君曰：“何谓也？", "len": 12}
{"sid": "089_张耳陈馀列传.8.s4", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 4, "text": "” 蒯通曰：“今范阳令宜整顿其士卒以守战者也，怯而畏死，贪而重富贵，故欲先天下降，畏君以为秦所置吏，诛杀如前十城也。", "len": 58}
{"sid": "089_张耳陈馀列传.8.s5", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 5, "text": "然今范阳少年亦方杀其令，自以城距君。", "len": 18}
{"sid": "089_张耳陈馀列传.8.s6", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 6, "text": "君何不赍臣侯印，拜范阳令，范阳令则以城下君，少年亦不敢杀其令。", "len": 31}
{"sid": "089_张耳陈馀列传.8.s7", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 7, "text": "令范阳令乘硃轮华毂，使驱驰燕、赵郊。", "len": 18}
{"sid": "089_张耳陈馀列传.8.s8", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 8, "text": "燕、赵郊见之，皆曰此范阳令，先下者也，即喜矣，燕、赵城可毋战而降也。", "len": 34}
{"sid": "089_张耳陈馀列传.8.s9", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 9, "text": "此臣之所谓传檄而千里定者也。", "len": 14}
{"sid": "089_张耳陈馀列传.8.s10", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 10, "text": "” 武信君从其计，因使蒯通赐范阳令侯印。", "len": 20}
{"sid": "089_张耳陈馀列传.8.s11", "chapter": "089_张耳陈馀列传", "para": "8", "seq": 11, "text": "赵地闻之，不战以城下者三十馀城。", "len": 16}
{"sid": "089_张耳陈馀列传.9.s1", "chapter": "089_张耳陈馀列传", "para": "9", "seq": 1, "text": "至邯郸，张耳、陈馀闻周章军入关，至戏卻；又闻诸将为陈王徇地，多以谗毁得罪诛，怨陈王不用其筴不以为将而以为校尉。", "len": 55}
{"sid": "089_张耳陈馀列传.9.s2", "chapter": "089_张耳陈馀列传", "para": "9", "seq": 2, "text": "乃说武臣曰：“陈王起蕲，至陈而王，非必立六国後。", "len": 24}
{"sid": "089_张耳陈馀列传.9.s3", "chapter": "089_张耳陈馀列传", "para": "9", "seq": 3, "text": "将军今以三千人下赵数十城，独介居河北，不王无以填之。", "len": 26}
{"sid": "089_张耳陈馀列传.9.s4", "chapter": "089_张耳陈馀列传", "para": "9", "seq": 4, "text": "且陈王听谗，还报，恐不脱於祸。", "len": 15}
{"sid": "089_张耳陈馀列传.9.s5", "chapter": "089_张耳陈馀列传", "para": "9", "seq": 5, "text": "又不如立其兄弟；不，即立赵後。", "len": 15}
{"sid": "089_张耳陈馀列传.9.s6", "chapter": "089_张耳陈馀列传", "para": "9", "seq": 6, "text": "将军毋失时，时间不容息。", "len": 12}
{"sid": "089_张耳陈馀列传.9.s7", "chapter": "089_张耳陈馀列传", "para": "9", "seq": 7, "text": "” 武臣乃听之，遂立为赵王。", "len": 14}
{"sid": "089_张耳陈馀列传.9.s8", "chapter": "089_张耳陈馀列传", "para": "9", "seq": 8, "text": "以陈馀为大将军，张耳为右丞相，邵骚为左丞相。", "len": 22}
{"sid": "089_张耳陈馀列传.10.s1", "chapter": "089_张耳陈馀列传", "para": "10", "seq": 1, "text": "使人报陈王，陈王大怒，欲尽族武臣等家，而发兵击赵。", "len": 25}
{"sid": "089_张耳陈馀列传.10.s2", "chapter": "089_张耳陈馀列传", "para": "10", "seq": 2, "text": "陈王相国房君谏曰：“秦未亡而诛武臣等家，此又生一秦也。", "len": 27}
{"sid": "089_张耳陈馀列传.10.s3", "chapter": "089_张耳陈馀列传", "para": "10", "seq": 3, "text": "不如因而贺之，使急引兵西击秦。", "len": 15}
{"sid": "089_张耳陈馀列传.10.s4", "chapter": "089_张耳陈馀列传", "para": "10", "seq": 4, "text": "” 陈王然之，从其计，徙系武臣等家宫中，封张耳子敖为成都君。", "len": 30}
{"sid": "089_张耳陈馀列传.11.s1", "chapter": "089_张耳陈馀列传", "para": "11", "seq": 1, "text": "陈王使使者贺赵，令趣发兵西入关。", "len": 16}
{"sid": "089_张耳陈馀列传.11.s2", "chapter": "089_张耳陈馀列传", "para": "11", "seq": 2, "text": "张耳、陈馀说武臣曰：“王王赵，非楚意，特以计贺王。", "len": 25}
{"sid": "089_张耳陈馀列传.11.s3", "chapter": "089_张耳陈馀列传", "para": "11", "seq": 3, "text": "楚已灭秦，必加兵於赵。", "len": 11}
{"sid": "089_张耳陈馀列传.11.s4", "chapter": "089_张耳陈馀列传", "para": "11", "seq": 4, "text": "原王毋西兵，北徇燕、代，南收河内以自广。", "len": 20}
{"sid": "089_张耳陈馀列传.11.s5", "chapter": "089_张耳陈馀列传", "para": "11", "seq": 5, "text": "赵南据大河，北有燕、代，楚虽胜秦，必不敢制赵。", "len": 23}
{"sid": "089_张耳陈馀列传.11.s6", "chapter": "089_张耳陈馀列传", "para": "11", "seq": 6, "text": "” 赵王以为然，因不西兵，而使韩广略燕，李良略常山，张黡略上党。", "len": 32}
{"sid": "089_张耳陈馀列传.12.s1", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 1, "text": "韩广至燕，燕人因立广为燕王。", "len": 14}
{"sid": "089_张耳陈馀列传.12.s2", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 2, "text": "赵王乃与张耳、陈馀北略地燕界。", "len": 15}
{"sid": "089_张耳陈馀列传.12.s3", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 3, "text": "赵王间出，为燕军所得。", "len": 11}
{"sid": "089_张耳陈馀列传.12.s4", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 4, "text": "燕将囚之，欲与分赵地半，乃归王。", "len": 16}
{"sid": "089_张耳陈馀列传.12.s5", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 5, "text": "使者往，燕辄杀之以求地。", "len": 12}
{"sid": "089_张耳陈馀列传.12.s6", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 6, "text": "张耳、陈馀患之。", "len": 8}
{"sid": "089_张耳陈馀列传.12.s7", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 7, "text": "有厮养卒谢其舍中曰：“吾为公说燕，与赵王载归。", "len": 23}
{"sid": "089_张耳陈馀列传.12.s8", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 8, "text": "” 舍中皆笑曰：“使者往十馀辈，辄死，若何以能得王？", "len": 26}
{"sid": "089_张耳陈馀列传.12.s9", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 9, "text": "” 乃走燕壁。", "len": 7}
{"sid": "089_张耳陈馀列传.12.s10", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 10, "text": "燕将见之，问燕将曰：“知臣何欲？", "len": 16}
{"sid": "089_张耳陈馀列传.12.s11", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 11, "text": "” 燕将曰：“若欲得赵王耳。", "len": 14}
{"sid": "089_张耳陈馀列传.12.s12", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 12, "text": "” 曰：“君知张耳、陈馀何如人也？", "len": 17}
{"sid": "089_张耳陈馀列传.12.s13", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 13, "text": "” 燕将曰：“贤人也。", "len": 11}
{"sid": "089_张耳陈馀列传.12.s14", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 14, "text": "” 曰：“知其志何欲？", "len": 11}
{"sid": "089_张耳陈馀列传.12.s15", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 15, "text": "” 曰：“欲得其王耳。", "len": 11}
{"sid": "089_张耳陈馀列传.12.s16", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 16, "text": "” 赵养卒乃笑曰：“君未知此两人所欲也。", "len": 20}
{"sid": "089_张耳陈馀列传.12.s17", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 17, "text": "夫武臣、张耳、陈馀杖马箠下赵数十城，此亦各欲南面而王，岂欲为卿相终己邪？", "len": 36}
{"sid": "089_张耳陈馀列传.12.s18", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 18, "text": "夫臣与主岂可同日而道哉，顾其势初定，未敢参分而王，且以少长先立武臣为王，以持赵心。", "len": 41}
{"sid": "089_张耳陈馀列传.12.s19", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 19, "text": "今赵地已服，此两人亦欲分赵而王，时未可耳。", "len": 21}
{"sid": "089_张耳陈馀列传.12.s20", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 20, "text": "今君乃囚赵王。", "len": 7}
{"sid": "089_张耳陈馀列传.12.s21", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 21, "text": "此两人名为求赵王，实欲燕杀之，此两人分赵自立。", "len": 23}
{"sid": "089_张耳陈馀列传.12.s22", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 22, "text": "夫以一赵尚易燕，况以两贤王左提右挈，而责杀王之罪，灭燕易矣。", "len": 30}
{"sid": "089_张耳陈馀列传.12.s23", "chapter": "089_张耳陈馀列传", "para": "12", "seq": 23, "text": "” 燕将以为然，乃归赵王，养卒为御而归。", "len": 20}
{"sid": "089_张耳陈馀列传.13.s1", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 1, "text": "李良已定常山，还报，赵王复使良略太原。", "len": 19}
{"sid": "089_张耳陈馀列传.13.s2", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 2, "text": "至石邑，秦兵塞井陉，未能前。", "len": 14}
{"sid": "089_张耳陈馀列传.13.s3", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 3, "text": "秦将诈称二世使人遗李良书，不封，曰：“良尝事我得显幸。", "len": 27}
{"sid": "089_张耳陈馀列传.13.s4", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 4, "text": "良诚能反赵为秦，赦良罪，贵良。", "len": 15}
{"sid": "089_张耳陈馀列传.13.s5", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 5, "text": "” 良得书，疑不信。", "len": 10}
{"sid": "089_张耳陈馀列传.13.s6", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 6, "text": "乃还之邯郸，益请兵。", "len": 10}
{"sid": "089_张耳陈馀列传.13.s7", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 7, "text": "未至，道逢赵王姊出饮，从百馀骑。", "len": 16}
{"sid": "089_张耳陈馀列传.13.s8", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 8, "text": "李良望见，以为王，伏谒道旁。", "len": 14}
{"sid": "089_张耳陈馀列传.13.s9", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 9, "text": "王姊醉，不知其将，使骑谢李良。", "len": 15}
{"sid": "089_张耳陈馀列传.13.s10", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 10, "text": "李良素贵，起，惭其从官。", "len": 12}
{"sid": "089_张耳陈馀列传.13.s11", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 11, "text": "从官有一人曰：“天下畔秦，能者先立。", "len": 18}
{"sid": "089_张耳陈馀列传.13.s12", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 12, "text": "且赵王素出将军下，今女兒乃不为将军下车，请追杀之。", "len": 25}
{"sid": "089_张耳陈馀列传.13.s13", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 13, "text": "” 李良已得秦书，固欲反赵，未决，因此怒，遣人追杀王姊道中，乃遂将其兵袭邯郸。", "len": 39}
{"sid": "089_张耳陈馀列传.13.s14", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 14, "text": "邯郸不知，竟杀武臣、邵骚。", "len": 13}
{"sid": "089_张耳陈馀列传.13.s15", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 15, "text": "赵人多为张耳、陈馀耳目者，以故得脱出。", "len": 19}
{"sid": "089_张耳陈馀列传.13.s16", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 16, "text": "收其兵，得数万人。", "len": 9}
{"sid": "089_张耳陈馀列传.13.s17", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 17, "text": "客有说张耳曰：“两君羁旅，而欲附赵，难；独立赵後，扶以义，可就功。", "len": 33}
{"sid": "089_张耳陈馀列传.13.s18", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 18, "text": "” 乃求得赵歇，立为赵王，居信都。", "len": 17}
{"sid": "089_张耳陈馀列传.13.s19", "chapter": "089_张耳陈馀列传", "para": "13", "seq": 19, "text": "李良进兵击陈馀，陈馀败李良，李良走归章邯。", "len": 21}
{"sid": "089_张耳陈馀列传.14.s1", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 1, "text": "章邯引兵至邯郸，皆徙其民河内，夷其城郭。", "len": 20}
{"sid": "089_张耳陈馀列传.14.s2", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 2, "text": "张耳与赵王歇走入钜鹿城，王离围之。", "len": 17}
{"sid": "089_张耳陈馀列传.14.s3", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 3, "text": "陈馀北收常山兵，得数万人，军钜鹿北。", "len": 18}
{"sid": "089_张耳陈馀列传.14.s4", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 4, "text": "章邯军钜鹿南棘原，筑甬道属河，饷王离。", "len": 19}
{"sid": "089_张耳陈馀列传.14.s5", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 5, "text": "王离兵食多，急攻钜鹿。", "len": 11}
{"sid": "089_张耳陈馀列传.14.s6", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 6, "text": "钜鹿城中食尽兵少，张耳数使人召前陈馀，陈馀自度兵少，不敌秦，不敢前。", "len": 34}
{"sid": "089_张耳陈馀列传.14.s7", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 7, "text": "数月，张耳大怒，怨陈馀，使张黡、陈泽往让陈馀曰：“始吾与公为刎颈交，今王与耳旦暮且死，而公拥兵数万，不肯相救，安在其相为死！", "len": 62}
{"sid": "089_张耳陈馀列传.14.s8", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 8, "text": "苟必信，胡不赴秦军俱死？", "len": 12}
{"sid": "089_张耳陈馀列传.14.s9", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 9, "text": "且有十一二相全。", "len": 8}
{"sid": "089_张耳陈馀列传.14.s10", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 10, "text": "” 陈馀曰：“吾度前终不能救赵，徒尽亡军。", "len": 21}
{"sid": "089_张耳陈馀列传.14.s11", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 11, "text": "且馀所以不俱死，欲为赵王、张君报秦。", "len": 18}
{"sid": "089_张耳陈馀列传.14.s12", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 12, "text": "今必俱死，如以肉委饿虎，何益？", "len": 15}
{"sid": "089_张耳陈馀列传.14.s13", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 13, "text": "” 张黡、陈泽曰：“事已急，要以俱死立信，安知後虑！", "len": 26}
{"sid": "089_张耳陈馀列传.14.s14", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 14, "text": "” 陈馀曰：“吾死顾以为无益。", "len": 15}
{"sid": "089_张耳陈馀列传.14.s15", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 15, "text": "必如公言。", "len": 5}
{"sid": "089_张耳陈馀列传.14.s16", "chapter": "089_张耳陈馀列传", "para": "14", "seq": 16, "text": "” 乃使五千人令张黡、陈泽先尝秦军，至皆没。", "len": 22}
{"sid": "089_张耳陈馀列传.15.s1", "chapter": "089_张耳陈馀列传", "para": "15", "seq": 1, "text": "当是时，燕、齐、楚闻赵急，皆来救。", "len": 17}
{"sid": "089_张耳陈馀列传.15.s2", "chapter": "089_张耳陈馀列传", "para": "15", "seq": 2, "text": "张敖亦北收代兵，得万馀人，来，皆壁馀旁，未敢击秦。", "len": 25}
{"sid": "089_张耳陈馀列传.15.s3", "chapter": "089_张耳陈馀列传", "para": "15", "seq": 3, "text": "项羽兵数绝章邯甬道，王离军乏食，项羽悉引兵渡河，遂破章邯。", "len": 29}
{"sid": "089_张耳陈馀列传.15.s4", "chapter": "089_张耳陈馀列传", "para": "15", "seq": 4, "text": "章邯引兵解，诸侯军乃敢击围钜鹿秦军，遂虏王离。", "len": 23}
{"sid": "089_张耳陈馀列传.15.s5", "chapter": "089_张耳陈馀列传", "para": "15", "seq": 5, "text": "涉间自杀。", "len": 5}
{"sid": "089_张耳陈馀列传.15.s6", "chapter": "089_张耳陈馀列传", "para": "15", "seq": 6, "text": "卒存钜鹿者，楚力也。", "len": 10}
{"sid": "089_张耳陈馀列传.16.s1", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 1, "text": "於是赵王歇、张耳乃得出钜鹿，谢诸侯。", "len": 18}
{"sid": "089_张耳陈馀列传.16.s2", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 2, "text": "张耳与陈馀相见，责让陈馀以不肯救赵，及问张黡、陈泽所在。", "len": 28}
{"sid": "089_张耳陈馀列传.16.s3", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 3, "text": "陈馀怒曰：“张黡、陈泽以必死责臣，臣使将五千人先尝秦军，皆没不出。", "len": 33}
{"sid": "089_张耳陈馀列传.16.s4", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 4, "text": "” 张耳不信，以为杀之，数问陈馀。", "len": 17}
{"sid": "089_张耳陈馀列传.16.s5", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 5, "text": "陈馀怒曰：“不意君之望臣深也！", "len": 15}
{"sid": "089_张耳陈馀列传.16.s6", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 6, "text": "岂以臣为重去将哉？", "len": 9}
{"sid": "089_张耳陈馀列传.16.s7", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 7, "text": "” 乃脱解印绶，推予张耳。", "len": 13}
{"sid": "089_张耳陈馀列传.16.s8", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 8, "text": "张耳亦愕不受。", "len": 7}
{"sid": "089_张耳陈馀列传.16.s9", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 9, "text": "陈馀起如厕。", "len": 6}
{"sid": "089_张耳陈馀列传.16.s10", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 10, "text": "客有说张耳曰：“臣闻‘天与不取，反受其咎’。", "len": 22}
{"sid": "089_张耳陈馀列传.16.s11", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 11, "text": "今陈将军与君印，君不受，反天不祥。", "len": 17}
{"sid": "089_张耳陈馀列传.16.s12", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 12, "text": "急取之！", "len": 4}
{"sid": "089_张耳陈馀列传.16.s13", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 13, "text": "” 张耳乃佩其印，收其麾下。", "len": 14}
{"sid": "089_张耳陈馀列传.16.s14", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 14, "text": "而陈馀还，亦望张耳不让，遂趋出。", "len": 16}
{"sid": "089_张耳陈馀列传.16.s15", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 15, "text": "张耳遂收其兵。", "len": 7}
{"sid": "089_张耳陈馀列传.16.s16", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 16, "text": "陈馀独与麾下所善数百人之河上泽中渔猎。", "len": 19}
{"sid": "089_张耳陈馀列传.16.s17", "chapter": "089_张耳陈馀列传", "para": "16", "seq": 17, "text": "由此陈馀、张耳遂有卻。", "len": 11}
{"sid": "089_张耳陈馀列传.17.s1", "chapter": "089_张耳陈馀列传", "para": "17", "seq": 1, "text": "赵王歇复居信都。", "len": 8}
{"sid": "089_张耳陈馀列传.17.s2", "chapter": "089_张耳陈馀列传", "para": "17", "seq": 2, "text": "张耳从项羽诸侯入关。", "len": 10}
{"sid": "089_张耳陈馀列传.17.s3", "chapter": "089_张耳陈馀列传", "para": "17", "seq": 3, "text": "汉元年二月，项羽立诸侯王，张耳雅游，人多为之言，项羽亦素数闻张耳贤，乃分赵立张耳为常山王，治信都。", "len": 49}
{"sid": "089_张耳陈馀列传.17.s4", "chapter": "089_张耳陈馀列传", "para": "17", "seq": 4, "text": "信都更名襄国。", "len": 7}
{"sid": "089_张耳陈馀列传.18.s1", "chapter": "089_张耳陈馀列传", "para": "18", "seq": 1, "text": "陈馀客多说项羽曰：“陈馀、张耳一体有功於赵。", "len": 22}
{"sid": "089_张耳陈馀列传.18.s2", "chapter": "089_张耳陈馀列传", "para": "18", "seq": 2, "text": "” 项羽以陈馀不从入关，闻其在南皮，即以南皮旁三县以封之，而徙赵王歇王代。", "len": 37}
{"sid": "089_张耳陈馀列传.19.s1", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 1, "text": "张耳之国，陈馀愈益怒，曰：“张耳与馀功等也，今张耳王，馀独侯，此项羽不平。", "len": 37}
{"sid": "089_张耳陈馀列传.19.s2", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 2, "text": "” 及齐王田荣畔楚，陈馀乃使夏说说田荣曰：“项羽为天下宰不平，尽王诸将善地，徙故王王恶地，今赵王乃居代！", "len": 52}
{"sid": "089_张耳陈馀列传.19.s3", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 3, "text": "原王假臣兵，请以南皮为扞蔽。", "len": 14}
{"sid": "089_张耳陈馀列传.19.s4", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 4, "text": "” 田荣欲树党於赵以反楚，乃遣兵从陈馀。", "len": 20}
{"sid": "089_张耳陈馀列传.19.s5", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 5, "text": "陈馀因悉三县兵袭常山王张耳。", "len": 14}
{"sid": "089_张耳陈馀列传.19.s6", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 6, "text": "张耳败走，念诸侯无可归者，曰：“汉王与我有旧故，而项羽又彊，立我，我欲之楚。", "len": 38}
{"sid": "089_张耳陈馀列传.19.s7", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 7, "text": "” 甘公曰：“汉王之入关，五星聚东井。", "len": 19}
{"sid": "089_张耳陈馀列传.19.s8", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 8, "text": "东井者，秦分也。", "len": 8}
{"sid": "089_张耳陈馀列传.19.s9", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 9, "text": "先至必霸。", "len": 5}
{"sid": "089_张耳陈馀列传.19.s10", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 10, "text": "楚虽彊，後必属汉。", "len": 9}
{"sid": "089_张耳陈馀列传.19.s11", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 11, "text": "” 故耳走汉。", "len": 7}
{"sid": "089_张耳陈馀列传.19.s12", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 12, "text": "汉王亦还定三秦，方围章邯废丘。", "len": 15}
{"sid": "089_张耳陈馀列传.19.s13", "chapter": "089_张耳陈馀列传", "para": "19", "seq": 13, "text": "张耳谒汉王，汉王厚遇之。", "len": 12}
{"sid": "089_张耳陈馀列传.20.s1", "chapter": "089_张耳陈馀列传", "para": "20", "seq": 1, "text": "陈馀已败张耳，皆复收赵地，迎赵王於代，复为赵王。", "len": 24}
{"sid": "089_张耳陈馀列传.20.s2", "chapter": "089_张耳陈馀列传", "para": "20", "seq": 2, "text": "赵王德陈馀，立以为代王。", "len": 12}
{"sid": "089_张耳陈馀列传.20.s3", "chapter": "089_张耳陈馀列传", "para": "20", "seq": 3, "text": "陈馀为赵王弱，国初定，不之国，留傅赵王，而使夏说以相国守代。", "len": 30}
{"sid": "089_张耳陈馀列传.21.s1", "chapter": "089_张耳陈馀列传", "para": "21", "seq": 1, "text": "汉二年，东击楚，使使告赵，欲与俱。", "len": 17}
{"sid": "089_张耳陈馀列传.21.s2", "chapter": "089_张耳陈馀列传", "para": "21", "seq": 2, "text": "陈馀曰：“汉杀张耳乃从。", "len": 12}
{"sid": "089_张耳陈馀列传.21.s3", "chapter": "089_张耳陈馀列传", "para": "21", "seq": 3, "text": "” 於是汉王求人类张耳者斩之，持其头遗陈馀。", "len": 22}
{"sid": "089_张耳陈馀列传.21.s4", "chapter": "089_张耳陈馀列传", "para": "21", "seq": 4, "text": "陈馀乃遣兵助汉。", "len": 8}
{"sid": "089_张耳陈馀列传.21.s5", "chapter": "089_张耳陈馀列传", "para": "21", "seq": 5, "text": "汉之败於彭城西，陈馀亦复觉张耳不死，即背汉。", "len": 22}
{"sid": "089_张耳陈馀列传.22.s1", "chapter": "089_张耳陈馀列传", "para": "22", "seq": 1, "text": "汉三年，韩信已定魏地，遣张耳与韩信击破赵井陉，斩陈馀泜水上，追杀赵王歇襄国。", "len": 38}
{"sid": "089_张耳陈馀列传.22.s2", "chapter": "089_张耳陈馀列传", "para": "22", "seq": 2, "text": "汉立张耳为赵王。", "len": 8}
{"sid": "089_张耳陈馀列传.22.s3", "chapter": "089_张耳陈馀列传", "para": "22", "seq": 3, "text": "汉五年，张耳薨，谥为景王。", "len": 13}
{"sid": "089_张耳陈馀列传.22.s4", "chapter": "089_张耳陈馀列传", "para": "22", "seq": 4, "text": "子敖嗣立为赵王。", "len": 8}
{"sid": "089_张耳陈馀列传.22.s5", "chapter": "089_张耳陈馀列传", "para": "22", "seq": 5, "text": "高祖长女鲁元公主为赵王敖后。", "len": 14}
{"sid": "089_张耳陈馀列传.23.s1", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 1, "text": "汉七年，高祖从平城过赵，赵王朝夕袒韝蔽，自上食，礼甚卑，有子婿礼。", "len": 33}
{"sid": "089_张耳陈馀列传.23.s2", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 2, "text": "高祖箕踞詈，甚慢易之。", "len": 11}
{"sid": "089_张耳陈馀列传.23.s3", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 3, "text": "赵相贯高、赵午等年六十馀，故张耳客也。", "len": 19}
{"sid": "089_张耳陈馀列传.23.s4", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 4, "text": "生平为气，乃怒曰：“吾王孱王也！", "len": 16}
{"sid": "089_张耳陈馀列传.23.s5", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 5, "text": "” 说王曰：“夫天下豪桀并起，能者先立。", "len": 20}
{"sid": "089_张耳陈馀列传.23.s6", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 6, "text": "今王事高祖甚恭，而高祖无礼，请为王杀之！", "len": 20}
{"sid": "089_张耳陈馀列传.23.s7", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 7, "text": "” 张敖齧其指出血，曰：“君何言之误！", "len": 19}
{"sid": "089_张耳陈馀列传.23.s8", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 8, "text": "且先人亡国，赖高祖得复国，德流子孙，秋豪皆高祖力也。", "len": 26}
{"sid": "089_张耳陈馀列传.23.s9", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 9, "text": "原君无复出口。", "len": 7}
{"sid": "089_张耳陈馀列传.23.s10", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 10, "text": "” 贯高、赵午等十馀人皆相谓曰：“乃吾等非也。", "len": 23}
{"sid": "089_张耳陈馀列传.23.s11", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 11, "text": "吾王长者，不倍德。", "len": 9}
{"sid": "089_张耳陈馀列传.23.s12", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 12, "text": "且吾等义不辱，今怨高祖辱我王，故欲杀之，何乃汙王为乎？", "len": 27}
{"sid": "089_张耳陈馀列传.23.s13", "chapter": "089_张耳陈馀列传", "para": "23", "seq": 13, "text": "令事成归王，事败独身坐耳。”", "len": 14}
{"sid": "089_张耳陈馀列传.24.s1", "chapter": "089_张耳陈馀列传", "para": "24", "seq": 1, "text": "汉八年，上从东垣还，过赵，贯高等乃壁人柏人，要之置厕。", "len": 27}
{"sid": "089_张耳陈馀列传.24.s2", "chapter": "089_张耳陈馀列传", "para": "24", "seq": 2, "text": "上过欲宿，心动问曰：“县名为何？", "len": 16}
{"sid": "089_张耳陈馀列传.24.s3", "chapter": "089_张耳陈馀列传", "para": "24", "seq": 3, "text": "” 曰：“柏人。", "len": 8}
{"sid": "089_张耳陈馀列传.24.s4", "chapter": "089_张耳陈馀列传", "para": "24", "seq": 4, "text": "” “柏人者，迫於人也！", "len": 12}
{"sid": "089_张耳陈馀列传.24.s5", "chapter": "089_张耳陈馀列传", "para": "24", "seq": 5, "text": "” 不宿而去。", "len": 7}
{"sid": "089_张耳陈馀列传.25.s1", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 1, "text": "汉九年，贯高怨家知其谋，乃上变告之。", "len": 18}
{"sid": "089_张耳陈馀列传.25.s2", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 2, "text": "於是上皆并逮捕赵王、贯高等。", "len": 14}
{"sid": "089_张耳陈馀列传.25.s3", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 3, "text": "十馀人皆争自刭，贯高独怒骂曰：“谁令公为之？", "len": 22}
{"sid": "089_张耳陈馀列传.25.s4", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 4, "text": "今王实无谋，而并捕王；公等皆死，谁白王不反者！", "len": 23}
{"sid": "089_张耳陈馀列传.25.s5", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 5, "text": "” 乃轞车胶致，与王诣长安。", "len": 14}
{"sid": "089_张耳陈馀列传.25.s6", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 6, "text": "治张敖之罪。", "len": 6}
{"sid": "089_张耳陈馀列传.25.s7", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 7, "text": "上乃诏赵群臣宾客有敢从王皆族。", "len": 15}
{"sid": "089_张耳陈馀列传.25.s8", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 8, "text": "贯高与客孟舒等十馀人，皆自髡钳，为王家奴，从来。", "len": 24}
{"sid": "089_张耳陈馀列传.25.s9", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 9, "text": "贯高至，对狱，曰：“独吾属为之，王实不知。", "len": 21}
{"sid": "089_张耳陈馀列传.25.s10", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 10, "text": "” 吏治榜笞数千，刺剟，身无可击者，终不复言。", "len": 23}
{"sid": "089_张耳陈馀列传.25.s11", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 11, "text": "吕后数言张王以鲁元公主故，不宜有此。", "len": 18}
{"sid": "089_张耳陈馀列传.25.s12", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 12, "text": "上怒曰：“使张敖据天下，岂少而女乎！", "len": 18}
{"sid": "089_张耳陈馀列传.25.s13", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 13, "text": "” 不听。", "len": 5}
{"sid": "089_张耳陈馀列传.25.s14", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 14, "text": "廷尉以贯高事辞闻，上曰：“壮士！", "len": 16}
{"sid": "089_张耳陈馀列传.25.s15", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 15, "text": "谁知者，以私问之。", "len": 9}
{"sid": "089_张耳陈馀列传.25.s16", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 16, "text": "” 中大夫泄公曰：“臣之邑子，素知之。", "len": 19}
{"sid": "089_张耳陈馀列传.25.s17", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 17, "text": "此固赵国立名义不侵为然诺者也。", "len": 15}
{"sid": "089_张耳陈馀列传.25.s18", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 18, "text": "” 上使泄公持节问之箯舆前。", "len": 14}
{"sid": "089_张耳陈馀列传.25.s19", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 19, "text": "仰视曰：“泄公邪？", "len": 9}
{"sid": "089_张耳陈馀列传.25.s20", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 20, "text": "” 泄公劳苦如生平驩，与语，问张王果有计谋不。", "len": 23}
{"sid": "089_张耳陈馀列传.25.s21", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 21, "text": "高曰：“人情宁不各爱其父母妻子乎？", "len": 17}
{"sid": "089_张耳陈馀列传.25.s22", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 22, "text": "今吾三族皆以论死，岂以王易吾亲哉！", "len": 17}
{"sid": "089_张耳陈馀列传.25.s23", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 23, "text": "顾为王实不反，独吾等为之。", "len": 13}
{"sid": "089_张耳陈馀列传.25.s24", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 24, "text": "” 具道本指所以为者王不知状。", "len": 15}
{"sid": "089_张耳陈馀列传.25.s25", "chapter": "089_张耳陈馀列传", "para": "25", "seq": 25, "text": "於是泄公入，具以报，上乃赦赵王。", "len": 16}
{"sid": "089_张耳陈馀列传.26.s1", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 1, "text": "上贤贯高为人能立然诺，使泄公具告之，曰：“张王已出。", "len": 26}
{"sid": "089_张耳陈馀列传.26.s2", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 2, "text": "” 因赦贯高。", "len": 7}
{"sid": "089_张耳陈馀列传.26.s3", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 3, "text": "贯高喜曰：“吾王审出乎？", "len": 12}
{"sid": "089_张耳陈馀列传.26.s4", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 4, "text": "” 泄公曰：“然。", "len": 9}
{"sid": "089_张耳陈馀列传.26.s5", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 5, "text": "” 泄公曰：“上多足下，故赦足下。", "len": 17}
{"sid": "089_张耳陈馀列传.26.s6", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 6, "text": "” 贯高曰：“所以不死一身无馀者，白张王不反也。", "len": 24}
{"sid": "089_张耳陈馀列传.26.s7", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 7, "text": "今王已出，吾责已塞，死不恨矣。", "len": 15}
{"sid": "089_张耳陈馀列传.26.s8", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 8, "text": "且人臣有篡杀之名，何面目复事上哉！", "len": 17}
{"sid": "089_张耳陈馀列传.26.s9", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 9, "text": "纵上不杀我，我不愧於心乎？", "len": 13}
{"sid": "089_张耳陈馀列传.26.s10", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 10, "text": "” 乃仰绝肮，遂死。", "len": 10}
{"sid": "089_张耳陈馀列传.26.s11", "chapter": "089_张耳陈馀列传", "para": "26", "seq": 11, "text": "当此之时，名闻天下。", "len": 10}
{"sid": "089_张耳陈馀列传.27.s1", "chapter": "089_张耳陈馀列传", "para": "27", "seq": 1, "text": "张敖已出，以尚鲁元公主故，封为宣平侯。", "len": 19}
{"sid": "089_张耳陈馀列传.27.s2", "chapter": "089_张耳陈馀列传", "para": "27", "seq": 2, "text": "於是上贤张王诸客，以钳奴从张王入关，无不为诸侯相、郡守者。", "len": 29}
{"sid": "089_张耳陈馀列传.27.s3", "chapter": "089_张耳陈馀列传", "para": "27", "seq": 3, "text": "及孝惠、高后、文帝、孝景时，张王客子孙皆得为二千石。", "len": 26}
{"sid": "089_张耳陈馀列传.28.s1", "chapter": "089_张耳陈馀列传", "para": "28", "seq": 1, "text": "张敖，高后六年薨。", "len": 9}
{"sid": "089_张耳陈馀列传.28.s2", "chapter": "089_张耳陈馀列传", "para": "28", "seq": 2, "text": "子偃为鲁元王。", "len": 7}
{"sid": "089_张耳陈馀列传.28.s3", "chapter": "089_张耳陈馀列传", "para": "28", "seq": 3, "text": "以母吕后女故，吕后封为鲁元王。", "len": 15}
{"sid": "089_张耳陈馀列传.28.s4", "chapter": "089_张耳陈馀列传", "para": "28", "seq": 4, "text": "元王弱，兄弟少，乃封张敖他姬子二人：寿为乐昌侯，侈为信都侯。", "len": 30}
{"sid": "089_张耳陈馀列传.28.s5", "chapter": "089_张耳陈馀列传", "para": "28", "seq": 5, "text": "高后崩，诸吕无道，大臣诛之，而废鲁元王及乐昌侯、信都侯。", "len": 28}
{"sid": "089_张耳陈馀列传.28.s6", "chapter": "089_张耳陈馀列传", "para": "28", "seq": 6, "text": "孝文帝即位，复封故鲁元王偃为南宫侯，续张氏。", "len": 22}
{"sid": "089_张耳陈馀列传.28.s7", "chapter": "089_张耳陈馀列传", "para": "28", "seq": 7, "text": "::: 太史公曰", "len": 8}
{"sid": "089_张耳陈馀列传.29.s1", "chapter": "089_张耳陈馀列传", "para": "29", "seq": 1, "text": "太史公曰：张耳、陈馀，世传所称贤者；其宾客厮役，莫非天下俊桀，所居国无不取卿相者。", "len": 41}
{"sid": "089_张耳陈馀列传.29.s2", "chapter": "089_张耳陈馀列传", "para": "29", "seq": 2, "text": "然张耳、陈馀始居约时，相然信以死，岂顾问哉。", "len": 22}
{"sid": "089_张耳陈馀列传.29.s3", "chapter": "089_张耳陈馀列传", "para": "29", "seq": 3, "text": "及据国争权，卒相灭亡，何乡者相慕用之诚，後相倍之戾也！", "len": 27}
{"sid": "089_张耳陈馀列传.29.s4", "chapter": "089_张耳陈馀列传", "para": "29", "seq": 4, "text": "岂非以势利交哉？", "len": 8}
{"sid": "089_张耳陈馀列传.29.s5", "chapter": "089_张耳陈馀列传", "para": "29", "seq": 5, "text": "名誉虽高，宾客虽盛，所由殆与大伯、延陵季子异矣。", "len": 24}
{"sid": "089_张耳陈馀列传.29.s6", "chapter": "089_张耳陈馀列传", "para": "29", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "089_张耳陈馀列传.30.s1", "chapter": "089_张耳陈馀列传", "para": "30", "seq": 1, "text": "张耳、陈馀，天下豪俊。", "len": 11}
{"sid": "089_张耳陈馀列传.30.s2", "chapter": "089_张耳陈馀列传", "para": "30", "seq": 2, "text": "忘年羁旅，刎颈相信。", "len": 10}
{"sid": "089_张耳陈馀列传.30.s3", "chapter": "089_张耳陈馀列传", "para": "30", "seq": 3, "text": "耳围钜鹿，馀兵不进。", "len": 10}
{"sid": "089_张耳陈馀列传.30.s4", "chapter": "089_张耳陈馀列传", "para": "30", "seq": 4, "text": "张既望深，陈乃去印。", "len": 10}
{"sid": "089_张耳陈馀列传.30.s5", "chapter": "089_张耳陈馀列传", "para": "30", "seq": 5, "text": "势利倾夺，隙末成衅。", "len": 10}
{"sid": "089_张耳陈馀列传.30.s6", "chapter": "089_张耳陈馀列传", "para": "30", "seq": 6, "text": ":::", "len": 3}
