{"sid": "010_孝文本纪.1.1.s1", "chapter": "010_孝文本纪", "para": "1.1", "seq": 1, "text": "孝文皇帝，高祖中子也。", "len": 11}
{"sid": "010_孝文本纪.1.2.s1", "chapter": "010_孝文本纪", "para": "1.2", "seq": 1, "text": "高祖十一年春，已破陈豨军，定代地，立为代王，都中都。", "len": 26}
{"sid": "010_孝文本纪.1.3.s1", "chapter": "010_孝文本纪", "para": "1.3", "seq": 1, "text": "太后薄氏子。", "len": 6}
{"sid": "010_孝文本纪.1.4.s1", "chapter": "010_孝文本纪", "para": "1.4", "seq": 1, "text": "即位十七年，高后八年七月，高后崩。", "len": 17}
{"sid": "010_孝文本纪.1.5.s1", "chapter": "010_孝文本纪", "para": "1.5", "seq": 1, "text": "九月，诸吕吕产等欲为乱，以危刘氏，大臣共诛之，谋召立代王，事在吕后语中。", "len": 36}
{"sid": "010_孝文本纪.2.1.s1", "chapter": "010_孝文本纪", "para": "2.1", "seq": 1, "text": "丞相陈平、太尉周勃等使人迎代王。", "len": 16}
{"sid": "010_孝文本纪.2.2.s1", "chapter": "010_孝文本纪", "para": "2.2", "seq": 1, "text": "代王问左右郎中令张武等。", "len": 12}
{"sid": "010_孝文本纪.2.3.s1", "chapter": "010_孝文本纪", "para": "2.3", "seq": 1, "text": "张武等议曰： “汉大臣皆故高帝时大将，习兵，多谋诈，此其属意非止此也，特畏高帝、吕太后威耳。", "len": 46}
{"sid": "010_孝文本纪.2.3.s2", "chapter": "010_孝文本纪", "para": "2.3", "seq": 2, "text": "今已诛诸吕，新喋血京师，此以迎大王为名，实不可信。", "len": 25}
{"sid": "010_孝文本纪.2.3.s3", "chapter": "010_孝文本纪", "para": "2.3", "seq": 3, "text": "原大王称疾毋往，以观其变。”", "len": 14}
{"sid": "010_孝文本纪.3.1.s1", "chapter": "010_孝文本纪", "para": "3.1", "seq": 1, "text": "中尉宋昌进曰： ::: 宋昌说辞 “群臣之议皆非也。", "len": 26}
{"sid": "010_孝文本纪.3.1.s2", "chapter": "010_孝文本纪", "para": "3.1", "seq": 2, "text": "夫秦失其政，诸侯豪桀并起，人人自以为得之者以万数，然卒践天子之位者，刘氏也，天下绝望，一矣。", "len": 46}
{"sid": "010_孝文本纪.3.1.s3", "chapter": "010_孝文本纪", "para": "3.1", "seq": 3, "text": "高帝封王子弟，地犬牙相制，此所谓盘石之宗也，天下服其彊，二矣。", "len": 31}
{"sid": "010_孝文本纪.3.1.s4", "chapter": "010_孝文本纪", "para": "3.1", "seq": 4, "text": "汉兴，除秦苛政，约法令，施德惠，人人自安，难动摇，三矣。", "len": 28}
{"sid": "010_孝文本纪.3.1.s5", "chapter": "010_孝文本纪", "para": "3.1", "seq": 5, "text": "夫以吕太后之严，立诸吕为三王，擅权专制，然而太尉以一节入北军，一呼士皆左袒，为刘氏，叛诸吕，卒以灭之。", "len": 51}
{"sid": "010_孝文本纪.3.1.s6", "chapter": "010_孝文本纪", "para": "3.1", "seq": 6, "text": "此乃天授，非人力也。", "len": 10}
{"sid": "010_孝文本纪.3.1.s7", "chapter": "010_孝文本纪", "para": "3.1", "seq": 7, "text": "今大臣虽欲为变，百姓弗为使，其党宁能专一邪？", "len": 22}
{"sid": "010_孝文本纪.3.1.s8", "chapter": "010_孝文本纪", "para": "3.1", "seq": 8, "text": "方今内有硃虚、东牟之亲，外畏吴、楚、淮南、琅邪、齐、代之彊。", "len": 30}
{"sid": "010_孝文本纪.3.1.s9", "chapter": "010_孝文本纪", "para": "3.1", "seq": 9, "text": "方今高帝子独淮南王与大王，大王又长，贤圣仁孝，闻於天下，故大臣因天下之心而欲迎立大王，大王勿疑也。", "len": 49}
{"sid": "010_孝文本纪.3.1.s10", "chapter": "010_孝文本纪", "para": "3.1", "seq": 10, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.4.1.s1", "chapter": "010_孝文本纪", "para": "4.1", "seq": 1, "text": "代王报太后计之，犹与未定。", "len": 13}
{"sid": "010_孝文本纪.4.2.s1", "chapter": "010_孝文本纪", "para": "4.2", "seq": 1, "text": "卜之龟，卦兆得大横。", "len": 10}
{"sid": "010_孝文本纪.4.3.s1", "chapter": "010_孝文本纪", "para": "4.3", "seq": 1, "text": "占曰： “大横庚庚，余为天王，夏启以光。”", "len": 21}
{"sid": "010_孝文本纪.4.4.s1", "chapter": "010_孝文本纪", "para": "4.4", "seq": 1, "text": "代王曰： “寡人固已为王矣，又何王？”", "len": 19}
{"sid": "010_孝文本纪.4.5.s1", "chapter": "010_孝文本纪", "para": "4.5", "seq": 1, "text": "卜人曰： “所谓天王者乃天子。”", "len": 16}
{"sid": "010_孝文本纪.4.6.s1", "chapter": "010_孝文本纪", "para": "4.6", "seq": 1, "text": "於是代王乃遣太后弟薄昭往见绛侯，绛侯等具为昭言所以迎立王意。", "len": 30}
{"sid": "010_孝文本纪.4.7.s1", "chapter": "010_孝文本纪", "para": "4.7", "seq": 1, "text": "薄昭还报曰： “信矣，毋可疑者。”", "len": 17}
{"sid": "010_孝文本纪.4.8.s1", "chapter": "010_孝文本纪", "para": "4.8", "seq": 1, "text": "代王乃笑谓宋昌曰： “果如公言。”", "len": 17}
{"sid": "010_孝文本纪.4.9.s1", "chapter": "010_孝文本纪", "para": "4.9", "seq": 1, "text": "乃命宋昌参乘，张武等六人乘传诣长安。", "len": 18}
{"sid": "010_孝文本纪.4.10.s1", "chapter": "010_孝文本纪", "para": "4.10", "seq": 1, "text": "至高陵休止，而使宋昌先驰之长安观变。", "len": 18}
{"sid": "010_孝文本纪.5.1.s1", "chapter": "010_孝文本纪", "para": "5.1", "seq": 1, "text": "昌至渭桥，丞相以下皆迎。", "len": 12}
{"sid": "010_孝文本纪.5.2.s1", "chapter": "010_孝文本纪", "para": "5.2", "seq": 1, "text": "宋昌还报。", "len": 5}
{"sid": "010_孝文本纪.5.3.s1", "chapter": "010_孝文本纪", "para": "5.3", "seq": 1, "text": "代王驰至渭桥，群臣拜谒称臣。", "len": 14}
{"sid": "010_孝文本纪.5.4.s1", "chapter": "010_孝文本纪", "para": "5.4", "seq": 1, "text": "代王下车拜。", "len": 6}
{"sid": "010_孝文本纪.5.5.s1", "chapter": "010_孝文本纪", "para": "5.5", "seq": 1, "text": "太尉勃进曰： “原请间言。”", "len": 14}
{"sid": "010_孝文本纪.5.6.s1", "chapter": "010_孝文本纪", "para": "5.6", "seq": 1, "text": "宋昌曰： “所言公，公言之。", "len": 14}
{"sid": "010_孝文本纪.5.6.s2", "chapter": "010_孝文本纪", "para": "5.6", "seq": 2, "text": "所言私，王者不受私。”", "len": 11}
{"sid": "010_孝文本纪.5.7.s1", "chapter": "010_孝文本纪", "para": "5.7", "seq": 1, "text": "太尉乃跪上天子玺符。", "len": 10}
{"sid": "010_孝文本纪.5.8.s1", "chapter": "010_孝文本纪", "para": "5.8", "seq": 1, "text": "代王谢曰： “至代邸而议之。”", "len": 15}
{"sid": "010_孝文本纪.5.9.s1", "chapter": "010_孝文本纪", "para": "5.9", "seq": 1, "text": "遂驰入代邸。", "len": 6}
{"sid": "010_孝文本纪.6.1.s1", "chapter": "010_孝文本纪", "para": "6.1", "seq": 1, "text": "群臣从至。", "len": 5}
{"sid": "010_孝文本纪.6.2.s1", "chapter": "010_孝文本纪", "para": "6.2", "seq": 1, "text": "丞相陈平、太尉周勃、大将军陈武、御史大夫张苍、宗正刘郢、硃虚侯刘章、东牟侯刘兴居、典客刘揭皆再拜言曰： “子弘等皆非孝惠帝子，不当奉宗庙。", "len": 69}
{"sid": "010_孝文本纪.6.2.s2", "chapter": "010_孝文本纪", "para": "6.2", "seq": 2, "text": "臣谨请阴安侯列侯顷王后与琅邪王、宗室、大臣、列侯、吏二千石议曰：‘大王高帝长子，宜为高帝嗣。", "len": 46}
{"sid": "010_孝文本纪.6.2.s3", "chapter": "010_孝文本纪", "para": "6.2", "seq": 3, "text": "‘原大王即天子位。”", "len": 10}
{"sid": "010_孝文本纪.6.3.s1", "chapter": "010_孝文本纪", "para": "6.3", "seq": 1, "text": "代王曰： “奉高帝宗庙，重事也。", "len": 16}
{"sid": "010_孝文本纪.6.3.s2", "chapter": "010_孝文本纪", "para": "6.3", "seq": 2, "text": "寡人不佞，不足以称宗庙。", "len": 12}
{"sid": "010_孝文本纪.6.3.s3", "chapter": "010_孝文本纪", "para": "6.3", "seq": 3, "text": "原请楚王计宜者，寡人不敢当。”", "len": 15}
{"sid": "010_孝文本纪.6.4.s1", "chapter": "010_孝文本纪", "para": "6.4", "seq": 1, "text": "群臣皆伏固请。", "len": 7}
{"sid": "010_孝文本纪.6.5.s1", "chapter": "010_孝文本纪", "para": "6.5", "seq": 1, "text": "代王西乡让者三，南乡让者再。", "len": 14}
{"sid": "010_孝文本纪.6.6.s1", "chapter": "010_孝文本纪", "para": "6.6", "seq": 1, "text": "丞相平等皆曰： “臣伏计之，大王奉高帝宗庙最宜称，虽天下诸侯万民以为宜。", "len": 36}
{"sid": "010_孝文本纪.6.6.s2", "chapter": "010_孝文本纪", "para": "6.6", "seq": 2, "text": "臣等为宗庙社稷计，不敢忽。", "len": 13}
{"sid": "010_孝文本纪.6.6.s3", "chapter": "010_孝文本纪", "para": "6.6", "seq": 3, "text": "原大王幸听臣等。", "len": 8}
{"sid": "010_孝文本纪.6.6.s4", "chapter": "010_孝文本纪", "para": "6.6", "seq": 4, "text": "臣谨奉天子玺符再拜上。”", "len": 12}
{"sid": "010_孝文本纪.6.7.s1", "chapter": "010_孝文本纪", "para": "6.7", "seq": 1, "text": "代王曰： “宗室将相王列侯以为莫宜寡人，寡人不敢辞。”", "len": 27}
{"sid": "010_孝文本纪.6.8.s1", "chapter": "010_孝文本纪", "para": "6.8", "seq": 1, "text": "遂即天子位。", "len": 6}
{"sid": "010_孝文本纪.7.1.s1", "chapter": "010_孝文本纪", "para": "7.1", "seq": 1, "text": "群臣以礼次侍。", "len": 7}
{"sid": "010_孝文本纪.7.2.s1", "chapter": "010_孝文本纪", "para": "7.2", "seq": 1, "text": "乃使太仆婴与东牟侯兴居清宫，奉天子法驾，迎于代邸。", "len": 25}
{"sid": "010_孝文本纪.7.3.s1", "chapter": "010_孝文本纪", "para": "7.3", "seq": 1, "text": "皇帝即日夕入未央宫。", "len": 10}
{"sid": "010_孝文本纪.7.4.s1", "chapter": "010_孝文本纪", "para": "7.4", "seq": 1, "text": "乃夜拜宋昌为卫将军，镇抚南北军。", "len": 16}
{"sid": "010_孝文本纪.7.5.s1", "chapter": "010_孝文本纪", "para": "7.5", "seq": 1, "text": "以张武为郎中令，行殿中。", "len": 12}
{"sid": "010_孝文本纪.7.6.s1", "chapter": "010_孝文本纪", "para": "7.6", "seq": 1, "text": "还坐前殿。", "len": 5}
{"sid": "010_孝文本纪.8.s1", "chapter": "010_孝文本纪", "para": "8", "seq": 1, "text": "於是夜下诏书曰： “间者诸吕用事擅权，谋为大逆，欲以危刘氏宗庙，赖将相列侯宗室大臣诛之，皆伏其辜。", "len": 49}
{"sid": "010_孝文本纪.8.s2", "chapter": "010_孝文本纪", "para": "8", "seq": 2, "text": "朕初即位，其赦天下，赐民爵一级，女子百户牛酒，酺五日。”", "len": 28}
{"sid": "010_孝文本纪.9.1.s1", "chapter": "010_孝文本纪", "para": "9.1", "seq": 1, "text": "孝文皇帝元年十月庚戌，徙立故琅邪王泽为燕王。", "len": 22}
{"sid": "010_孝文本纪.9.2.s1", "chapter": "010_孝文本纪", "para": "9.2", "seq": 1, "text": "辛亥，皇帝即阼，谒高庙。", "len": 12}
{"sid": "010_孝文本纪.9.3.s1", "chapter": "010_孝文本纪", "para": "9.3", "seq": 1, "text": "右丞相平徙为左丞相，太尉勃为右丞相，大将军灌婴为太尉。", "len": 27}
{"sid": "010_孝文本纪.9.4.s1", "chapter": "010_孝文本纪", "para": "9.4", "seq": 1, "text": "诸吕所夺齐楚故地，皆复与之。", "len": 14}
{"sid": "010_孝文本纪.10.1.s1", "chapter": "010_孝文本纪", "para": "10.1", "seq": 1, "text": "壬子，遣车骑将军薄昭迎皇太后于代。", "len": 17}
{"sid": "010_孝文本纪.10.2.s1", "chapter": "010_孝文本纪", "para": "10.2", "seq": 1, "text": "皇帝曰： ::: 论功行赏诏 “吕产自置为相国，吕禄为上将军，擅矫遣灌将军婴将兵击齐，欲代刘氏，婴留荥阳弗击，与诸侯合谋以诛吕氏。", "len": 65}
{"sid": "010_孝文本纪.10.2.s2", "chapter": "010_孝文本纪", "para": "10.2", "seq": 2, "text": "吕产欲为不善，丞相陈平与太尉周勃谋夺吕产等军。", "len": 23}
{"sid": "010_孝文本纪.10.2.s3", "chapter": "010_孝文本纪", "para": "10.2", "seq": 3, "text": "硃虚侯刘章首先捕吕产等。", "len": 12}
{"sid": "010_孝文本纪.10.2.s4", "chapter": "010_孝文本纪", "para": "10.2", "seq": 4, "text": "太尉身率襄平侯通持节承诏入北军。", "len": 16}
{"sid": "010_孝文本纪.10.2.s5", "chapter": "010_孝文本纪", "para": "10.2", "seq": 5, "text": "典客刘揭身夺赵王吕禄印。", "len": 12}
{"sid": "010_孝文本纪.10.2.s6", "chapter": "010_孝文本纪", "para": "10.2", "seq": 6, "text": "益封太尉勃万户，赐金五千斤。", "len": 14}
{"sid": "010_孝文本纪.10.2.s7", "chapter": "010_孝文本纪", "para": "10.2", "seq": 7, "text": "丞相陈平、灌将军婴邑各三千户，金二千斤。", "len": 20}
{"sid": "010_孝文本纪.10.2.s8", "chapter": "010_孝文本纪", "para": "10.2", "seq": 8, "text": "硃虚侯刘章、襄平侯通、东牟侯刘兴居邑各二千户，金千斤。", "len": 27}
{"sid": "010_孝文本纪.10.2.s9", "chapter": "010_孝文本纪", "para": "10.2", "seq": 9, "text": "封典客揭为阳信侯，赐金千斤。", "len": 14}
{"sid": "010_孝文本纪.10.2.s10", "chapter": "010_孝文本纪", "para": "10.2", "seq": 10, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.11.1.s1", "chapter": "010_孝文本纪", "para": "11.1", "seq": 1, "text": "十二月，上曰： ::: 废相坐律诏 “法者，治之正也，所以禁暴而率善人也。", "len": 37}
{"sid": "010_孝文本纪.11.1.s2", "chapter": "010_孝文本纪", "para": "11.1", "seq": 2, "text": "今犯法已论，而使毋罪之父母妻子同产坐之，及为收帑，朕甚不取。", "len": 30}
{"sid": "010_孝文本纪.11.1.s3", "chapter": "010_孝文本纪", "para": "11.1", "seq": 3, "text": "其议之。", "len": 4}
{"sid": "010_孝文本纪.11.1.s4", "chapter": "010_孝文本纪", "para": "11.1", "seq": 4, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.11.2.s1", "chapter": "010_孝文本纪", "para": "11.2", "seq": 1, "text": "有司皆曰： “民不能自治，故为法以禁之。", "len": 20}
{"sid": "010_孝文本纪.11.2.s2", "chapter": "010_孝文本纪", "para": "11.2", "seq": 2, "text": "相坐坐收，所以累其心，使重犯法，所从来远矣。", "len": 22}
{"sid": "010_孝文本纪.11.2.s3", "chapter": "010_孝文本纪", "para": "11.2", "seq": 3, "text": "如故便。”", "len": 5}
{"sid": "010_孝文本纪.11.3.s1", "chapter": "010_孝文本纪", "para": "11.3", "seq": 1, "text": "上曰： “朕闻法正则民悫，罪当则民从。", "len": 19}
{"sid": "010_孝文本纪.11.3.s2", "chapter": "010_孝文本纪", "para": "11.3", "seq": 2, "text": "且夫牧民而导之善者，吏也。", "len": 13}
{"sid": "010_孝文本纪.11.3.s3", "chapter": "010_孝文本纪", "para": "11.3", "seq": 3, "text": "其既不能导，又以不正之法罪之，是反害於民为暴者也。", "len": 25}
{"sid": "010_孝文本纪.11.3.s4", "chapter": "010_孝文本纪", "para": "11.3", "seq": 4, "text": "何以禁之？", "len": 5}
{"sid": "010_孝文本纪.11.3.s5", "chapter": "010_孝文本纪", "para": "11.3", "seq": 5, "text": "朕未见其便，其孰计之。”", "len": 12}
{"sid": "010_孝文本纪.11.4.s1", "chapter": "010_孝文本纪", "para": "11.4", "seq": 1, "text": "有司皆曰： “陛下加大惠，德甚盛，非臣等所及也。", "len": 24}
{"sid": "010_孝文本纪.11.4.s2", "chapter": "010_孝文本纪", "para": "11.4", "seq": 2, "text": "请奉诏书，除收帑诸相坐律令。”", "len": 15}
{"sid": "010_孝文本纪.12.1.s1", "chapter": "010_孝文本纪", "para": "12.1", "seq": 1, "text": "正月，有司言曰： “蚤建太子，所以尊宗庙。", "len": 21}
{"sid": "010_孝文本纪.12.1.s2", "chapter": "010_孝文本纪", "para": "12.1", "seq": 2, "text": "请立太子。”", "len": 6}
{"sid": "010_孝文本纪.12.2.s1", "chapter": "010_孝文本纪", "para": "12.2", "seq": 1, "text": "上曰： ::: 不急立太子诏 “朕既不德，上帝神明未歆享，天下人民未有嗛志。", "len": 38}
{"sid": "010_孝文本纪.12.2.s2", "chapter": "010_孝文本纪", "para": "12.2", "seq": 2, "text": "今纵不能博求天下贤圣有德之人而禅天下焉，而曰豫建太子，是重吾不德也。", "len": 34}
{"sid": "010_孝文本纪.12.2.s3", "chapter": "010_孝文本纪", "para": "12.2", "seq": 3, "text": "谓天下何？", "len": 5}
{"sid": "010_孝文本纪.12.2.s4", "chapter": "010_孝文本纪", "para": "12.2", "seq": 4, "text": "其安之。", "len": 4}
{"sid": "010_孝文本纪.12.2.s5", "chapter": "010_孝文本纪", "para": "12.2", "seq": 5, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.12.3.s1", "chapter": "010_孝文本纪", "para": "12.3", "seq": 1, "text": "有司曰： “豫建太子，所以重宗庙社稷，不忘天下也。”", "len": 26}
{"sid": "010_孝文本纪.12.4.s1", "chapter": "010_孝文本纪", "para": "12.4", "seq": 1, "text": "上曰： ::: 推让诸王 “楚王，季父也，春秋高，阅天下之义理多矣，明於国家之大体。", "len": 42}
{"sid": "010_孝文本纪.12.4.s2", "chapter": "010_孝文本纪", "para": "12.4", "seq": 2, "text": "吴王於朕，兄也，惠仁以好德。", "len": 14}
{"sid": "010_孝文本纪.12.4.s3", "chapter": "010_孝文本纪", "para": "12.4", "seq": 3, "text": "淮南王，弟也，秉德以陪朕。", "len": 13}
{"sid": "010_孝文本纪.12.4.s4", "chapter": "010_孝文本纪", "para": "12.4", "seq": 4, "text": "岂为不豫哉！", "len": 6}
{"sid": "010_孝文本纪.12.4.s5", "chapter": "010_孝文本纪", "para": "12.4", "seq": 5, "text": "诸侯王宗室昆弟有功臣，多贤及有德义者，若举有德以陪朕之不能终，是社稷之灵，天下之福也。", "len": 43}
{"sid": "010_孝文本纪.12.4.s6", "chapter": "010_孝文本纪", "para": "12.4", "seq": 6, "text": "今不选举焉，而曰必子，人其以朕为忘贤有德者而专於子，非所以忧天下也。", "len": 34}
{"sid": "010_孝文本纪.12.4.s7", "chapter": "010_孝文本纪", "para": "12.4", "seq": 7, "text": "朕甚不取也。", "len": 6}
{"sid": "010_孝文本纪.12.4.s8", "chapter": "010_孝文本纪", "para": "12.4", "seq": 8, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.12.5.s1", "chapter": "010_孝文本纪", "para": "12.5", "seq": 1, "text": "有司皆固请曰： ::: 群臣固请立太子 “古者殷周有国，治安皆千馀岁，古之有天下者莫长焉，用此道也。", "len": 50}
{"sid": "010_孝文本纪.12.5.s2", "chapter": "010_孝文本纪", "para": "12.5", "seq": 2, "text": "立嗣必子，所从来远矣。", "len": 11}
{"sid": "010_孝文本纪.12.5.s3", "chapter": "010_孝文本纪", "para": "12.5", "seq": 3, "text": "高帝亲率士大夫，始平天下，建诸侯，为帝者太祖。", "len": 23}
{"sid": "010_孝文本纪.12.5.s4", "chapter": "010_孝文本纪", "para": "12.5", "seq": 4, "text": "诸侯王及列侯始受国者皆亦为其国祖。", "len": 17}
{"sid": "010_孝文本纪.12.5.s5", "chapter": "010_孝文本纪", "para": "12.5", "seq": 5, "text": "子孙继嗣，世世弗绝，天下之大义也，故高帝设之以抚海内。", "len": 27}
{"sid": "010_孝文本纪.12.5.s6", "chapter": "010_孝文本纪", "para": "12.5", "seq": 6, "text": "今释宜建而更选於诸侯及宗室，非高帝之志也。", "len": 21}
{"sid": "010_孝文本纪.12.5.s7", "chapter": "010_孝文本纪", "para": "12.5", "seq": 7, "text": "更议不宜。", "len": 5}
{"sid": "010_孝文本纪.12.5.s8", "chapter": "010_孝文本纪", "para": "12.5", "seq": 8, "text": "子某最长，纯厚慈仁，请建以为太子。", "len": 17}
{"sid": "010_孝文本纪.12.5.s9", "chapter": "010_孝文本纪", "para": "12.5", "seq": 9, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.12.6.s1", "chapter": "010_孝文本纪", "para": "12.6", "seq": 1, "text": "上乃许之。", "len": 5}
{"sid": "010_孝文本纪.12.7.s1", "chapter": "010_孝文本纪", "para": "12.7", "seq": 1, "text": "因赐天下民当代父後者爵各一级封将军薄昭为轵侯。", "len": 23}
{"sid": "010_孝文本纪.13.1.s1", "chapter": "010_孝文本纪", "para": "13.1", "seq": 1, "text": "三月，有司请立皇后。", "len": 10}
{"sid": "010_孝文本纪.13.2.s1", "chapter": "010_孝文本纪", "para": "13.2", "seq": 1, "text": "薄太后曰： “诸侯皆同姓，立太子母为皇后。”", "len": 22}
{"sid": "010_孝文本纪.13.3.s1", "chapter": "010_孝文本纪", "para": "13.3", "seq": 1, "text": "皇后姓窦氏。", "len": 6}
{"sid": "010_孝文本纪.13.4.s1", "chapter": "010_孝文本纪", "para": "13.4", "seq": 1, "text": "上为立后故，赐天下鳏寡孤独穷困及年八十已上孤兒九岁已下布帛米肉各有数。", "len": 35}
{"sid": "010_孝文本纪.14.1.s1", "chapter": "010_孝文本纪", "para": "14.1", "seq": 1, "text": "上从代来，初即位，施德惠天下，填抚诸侯四夷皆洽驩，乃循从代来功臣。", "len": 33}
{"sid": "010_孝文本纪.14.2.s1", "chapter": "010_孝文本纪", "para": "14.2", "seq": 1, "text": "上曰： ::: 封从代功臣 “方大臣之诛诸吕迎朕，朕狐疑，皆止朕，唯中尉宋昌劝朕，朕以得保奉宗庙。", "len": 49}
{"sid": "010_孝文本纪.14.2.s2", "chapter": "010_孝文本纪", "para": "14.2", "seq": 2, "text": "已尊昌为卫将军，其封昌为壮武侯。", "len": 16}
{"sid": "010_孝文本纪.14.2.s3", "chapter": "010_孝文本纪", "para": "14.2", "seq": 3, "text": "诸从朕六人，官皆至九卿。", "len": 12}
{"sid": "010_孝文本纪.14.2.s4", "chapter": "010_孝文本纪", "para": "14.2", "seq": 4, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.14.3.s1", "chapter": "010_孝文本纪", "para": "14.3", "seq": 1, "text": "上曰： ::: 益封从汉功臣 “列侯从高帝入蜀、汉中者六十八人皆益封各三百户，故吏二千石以上从高帝颍川守尊等十人食邑六百户，淮阳守申徒嘉等十人五百户，卫尉定等十人四百户。", "len": 85}
{"sid": "010_孝文本纪.14.3.s2", "chapter": "010_孝文本纪", "para": "14.3", "seq": 2, "text": "封淮南王舅父赵兼为周阳侯，齐王舅父驷钧为清郭侯。", "len": 24}
{"sid": "010_孝文本纪.14.3.s3", "chapter": "010_孝文本纪", "para": "14.3", "seq": 3, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.14.4.s1", "chapter": "010_孝文本纪", "para": "14.4", "seq": 1, "text": "秋，封故常山丞相蔡兼为樊侯。", "len": 14}
{"sid": "010_孝文本纪.15.1.s1", "chapter": "010_孝文本纪", "para": "15.1", "seq": 1, "text": "人或说右丞相曰： “君本诛诸吕，迎代王，今又矜其功，受上赏，处尊位，祸且及身。”", "len": 40}
{"sid": "010_孝文本纪.15.2.s1", "chapter": "010_孝文本纪", "para": "15.2", "seq": 1, "text": "右丞相勃乃谢病免罢，左丞相平专为丞相。", "len": 19}
{"sid": "010_孝文本纪.16.1.s1", "chapter": "010_孝文本纪", "para": "16.1", "seq": 1, "text": "二年十月，丞相平卒，复以绛侯勃为丞相。", "len": 19}
{"sid": "010_孝文本纪.16.2.s1", "chapter": "010_孝文本纪", "para": "16.2", "seq": 1, "text": "上曰： ::: 遣列侯就国诏 “朕闻古者诸侯建国千馀，各守其地，以时入贡，民不劳苦，上下驩欣，靡有遗德。", "len": 52}
{"sid": "010_孝文本纪.16.2.s2", "chapter": "010_孝文本纪", "para": "16.2", "seq": 2, "text": "今列侯多居长安，邑远，吏卒给输费苦，而列侯亦无由教驯其民。", "len": 29}
{"sid": "010_孝文本纪.16.2.s3", "chapter": "010_孝文本纪", "para": "16.2", "seq": 3, "text": "其令列侯之国，为吏及诏所止者，遣太子。", "len": 19}
{"sid": "010_孝文本纪.16.2.s4", "chapter": "010_孝文本纪", "para": "16.2", "seq": 4, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.17.1.s1", "chapter": "010_孝文本纪", "para": "17.1", "seq": 1, "text": "十一月晦，日有食之。", "len": 10}
{"sid": "010_孝文本纪.17.2.s1", "chapter": "010_孝文本纪", "para": "17.2", "seq": 1, "text": "十二月望，日又食。", "len": 9}
{"sid": "010_孝文本纪.17.3.s1", "chapter": "010_孝文本纪", "para": "17.3", "seq": 1, "text": "上曰： ::: 日食求言诏 “朕闻之，天生蒸民，为之置君以养治之。", "len": 33}
{"sid": "010_孝文本纪.17.3.s2", "chapter": "010_孝文本纪", "para": "17.3", "seq": 2, "text": "人主不德，布政不均，则天示之以菑，以诫不治。", "len": 22}
{"sid": "010_孝文本纪.17.3.s3", "chapter": "010_孝文本纪", "para": "17.3", "seq": 3, "text": "乃十一月晦，日有食之，適见于天，菑孰大焉！", "len": 21}
{"sid": "010_孝文本纪.17.3.s4", "chapter": "010_孝文本纪", "para": "17.3", "seq": 4, "text": "朕获保宗庙，以微眇之身讬于兆民君王之上，天下治乱，在朕一人，唯二三执政犹吾股肱也。", "len": 41}
{"sid": "010_孝文本纪.17.3.s5", "chapter": "010_孝文本纪", "para": "17.3", "seq": 5, "text": "朕下不能理育群生，上以累三光之明，其不德大矣。", "len": 23}
{"sid": "010_孝文本纪.17.3.s6", "chapter": "010_孝文本纪", "para": "17.3", "seq": 6, "text": "令至，其悉思朕之过失，及知见思之所不及，匄以告朕。", "len": 25}
{"sid": "010_孝文本纪.17.3.s7", "chapter": "010_孝文本纪", "para": "17.3", "seq": 7, "text": "及举贤良方正能直言极谏者，以匡朕之不逮。", "len": 20}
{"sid": "010_孝文本纪.17.3.s8", "chapter": "010_孝文本纪", "para": "17.3", "seq": 8, "text": "因各饬其任职，务省繇费以便民。", "len": 15}
{"sid": "010_孝文本纪.17.3.s9", "chapter": "010_孝文本纪", "para": "17.3", "seq": 9, "text": "朕既不能远德，故忄间然念外人之有非，是以设备未息。", "len": 25}
{"sid": "010_孝文本纪.17.3.s10", "chapter": "010_孝文本纪", "para": "17.3", "seq": 10, "text": "今纵不能罢边屯戍，而又饬兵厚卫，其罢卫将军军。", "len": 23}
{"sid": "010_孝文本纪.17.3.s11", "chapter": "010_孝文本纪", "para": "17.3", "seq": 11, "text": "太仆见马遗财足，馀皆以给传置。", "len": 15}
{"sid": "010_孝文本纪.17.3.s12", "chapter": "010_孝文本纪", "para": "17.3", "seq": 12, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.18.s1", "chapter": "010_孝文本纪", "para": "18", "seq": 1, "text": "正月，上曰： “农，天下之本，其开籍田，朕亲率耕，以给宗庙粢盛。”", "len": 33}
{"sid": "010_孝文本纪.19.1.s1", "chapter": "010_孝文本纪", "para": "19.1", "seq": 1, "text": "三月，有司请立皇子为诸侯王。", "len": 14}
{"sid": "010_孝文本纪.19.2.s1", "chapter": "010_孝文本纪", "para": "19.2", "seq": 1, "text": "上曰： “赵幽王幽死，朕甚怜之，已立其长子遂为赵王。", "len": 26}
{"sid": "010_孝文本纪.19.2.s2", "chapter": "010_孝文本纪", "para": "19.2", "seq": 2, "text": "遂弟辟彊及齐悼惠王子硃虚侯章、东牟侯兴居有功，可王。”", "len": 27}
{"sid": "010_孝文本纪.19.3.s1", "chapter": "010_孝文本纪", "para": "19.3", "seq": 1, "text": "乃立赵幽王少子辟彊为河间王，以齐剧郡立硃虚侯为城阳王，立东牟侯为济北王，皇子武为代王，子参为太原王，子揖为梁王。", "len": 56}
{"sid": "010_孝文本纪.20.1.s1", "chapter": "010_孝文本纪", "para": "20.1", "seq": 1, "text": "上曰： ::: 除诽谤妖言之罪诏 “古之治天下，朝有进善之旌，诽谤之木，所以通治道而来谏者。", "len": 46}
{"sid": "010_孝文本纪.20.1.s2", "chapter": "010_孝文本纪", "para": "20.1", "seq": 2, "text": "今法有诽谤妖言之罪，是使众臣不敢尽情，而上无由闻过失也。", "len": 28}
{"sid": "010_孝文本纪.20.1.s3", "chapter": "010_孝文本纪", "para": "20.1", "seq": 3, "text": "将何以来远方之贤良？", "len": 10}
{"sid": "010_孝文本纪.20.1.s4", "chapter": "010_孝文本纪", "para": "20.1", "seq": 4, "text": "其除之。", "len": 4}
{"sid": "010_孝文本纪.20.1.s5", "chapter": "010_孝文本纪", "para": "20.1", "seq": 5, "text": "民或祝诅上以相约结而後相谩，吏以为大逆，其有他言，而吏又以为诽谤。", "len": 33}
{"sid": "010_孝文本纪.20.1.s6", "chapter": "010_孝文本纪", "para": "20.1", "seq": 6, "text": "此细民之愚无知抵死，朕甚不取。", "len": 15}
{"sid": "010_孝文本纪.20.1.s7", "chapter": "010_孝文本纪", "para": "20.1", "seq": 7, "text": "自今以来，有犯此者勿听治。", "len": 13}
{"sid": "010_孝文本纪.20.1.s8", "chapter": "010_孝文本纪", "para": "20.1", "seq": 8, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.21.s1", "chapter": "010_孝文本纪", "para": "21", "seq": 1, "text": "九月，初与郡国守相为铜虎符、竹使符。", "len": 18}
{"sid": "010_孝文本纪.22.1.s1", "chapter": "010_孝文本纪", "para": "22.1", "seq": 1, "text": "三年十月丁酉晦，日有食之。", "len": 13}
{"sid": "010_孝文本纪.22.2.s1", "chapter": "010_孝文本纪", "para": "22.2", "seq": 1, "text": "十一月，上曰： “前日遣列侯之国，或辞未行。", "len": 22}
{"sid": "010_孝文本纪.22.2.s2", "chapter": "010_孝文本纪", "para": "22.2", "seq": 2, "text": "丞相朕之所重，其为朕率列侯之国。”", "len": 17}
{"sid": "010_孝文本纪.22.3.s1", "chapter": "010_孝文本纪", "para": "22.3", "seq": 1, "text": "绛侯勃免丞相就国，以太尉颍阴侯婴为丞相。", "len": 20}
{"sid": "010_孝文本纪.22.4.s1", "chapter": "010_孝文本纪", "para": "22.4", "seq": 1, "text": "罢太尉官，属丞相。", "len": 9}
{"sid": "010_孝文本纪.22.5.s1", "chapter": "010_孝文本纪", "para": "22.5", "seq": 1, "text": "四月，城阳王章薨。", "len": 9}
{"sid": "010_孝文本纪.22.6.s1", "chapter": "010_孝文本纪", "para": "22.6", "seq": 1, "text": "淮南王长与从者魏敬杀辟阳侯审食其。", "len": 17}
{"sid": "010_孝文本纪.23.1.s1", "chapter": "010_孝文本纪", "para": "23.1", "seq": 1, "text": "五月，匈奴入北地，居河南为寇。", "len": 15}
{"sid": "010_孝文本纪.23.2.s1", "chapter": "010_孝文本纪", "para": "23.2", "seq": 1, "text": "帝初幸甘泉。", "len": 6}
{"sid": "010_孝文本纪.23.3.s1", "chapter": "010_孝文本纪", "para": "23.3", "seq": 1, "text": "六月，帝曰： ::: 击匈奴诏 “汉与匈奴约为昆弟，毋使害边境，所以输遗匈奴甚厚。", "len": 41}
{"sid": "010_孝文本纪.23.3.s2", "chapter": "010_孝文本纪", "para": "23.3", "seq": 2, "text": "今右贤王离其国，将众居河南降地，非常故，往来近塞，捕杀吏卒，驱保塞蛮夷，令不得居其故，陵轹边吏，入盗，甚敖无道，非约也。", "len": 60}
{"sid": "010_孝文本纪.23.3.s3", "chapter": "010_孝文本纪", "para": "23.3", "seq": 3, "text": "其发边吏骑八万五千诣高奴，遣丞相颍阴侯灌婴击匈奴。", "len": 25}
{"sid": "010_孝文本纪.23.3.s4", "chapter": "010_孝文本纪", "para": "23.3", "seq": 4, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.23.4.s1", "chapter": "010_孝文本纪", "para": "23.4", "seq": 1, "text": "匈奴去，发中尉材官属卫将军军长安。", "len": 17}
{"sid": "010_孝文本纪.24.1.s1", "chapter": "010_孝文本纪", "para": "24.1", "seq": 1, "text": "辛卯，帝自甘泉之高奴，因幸太原，见故群臣，皆赐之。", "len": 25}
{"sid": "010_孝文本纪.24.2.s1", "chapter": "010_孝文本纪", "para": "24.2", "seq": 1, "text": "举功行赏，诸民里赐牛酒。", "len": 12}
{"sid": "010_孝文本纪.24.3.s1", "chapter": "010_孝文本纪", "para": "24.3", "seq": 1, "text": "复晋阳中都民三岁。", "len": 9}
{"sid": "010_孝文本纪.24.4.s1", "chapter": "010_孝文本纪", "para": "24.4", "seq": 1, "text": "留游太原十馀日。", "len": 8}
{"sid": "010_孝文本纪.25.1.s1", "chapter": "010_孝文本纪", "para": "25.1", "seq": 1, "text": "济北王兴居闻帝之代，欲往击胡，乃反，发兵欲袭荥阳。", "len": 25}
{"sid": "010_孝文本纪.25.2.s1", "chapter": "010_孝文本纪", "para": "25.2", "seq": 1, "text": "於是诏罢丞相兵，遣棘蒲侯陈武为大将军，将十万往击之。", "len": 26}
{"sid": "010_孝文本纪.25.3.s1", "chapter": "010_孝文本纪", "para": "25.3", "seq": 1, "text": "祁侯贺为将军，军荥阳。", "len": 11}
{"sid": "010_孝文本纪.25.4.s1", "chapter": "010_孝文本纪", "para": "25.4", "seq": 1, "text": "七月辛亥，帝自太原至长安。", "len": 13}
{"sid": "010_孝文本纪.25.5.s1", "chapter": "010_孝文本纪", "para": "25.5", "seq": 1, "text": "乃诏有司曰： ::: 赦济北吏民诏 “济北王背德反上，诖误吏民，为大逆。", "len": 36}
{"sid": "010_孝文本纪.25.5.s2", "chapter": "010_孝文本纪", "para": "25.5", "seq": 2, "text": "济北吏民兵未至先自定，及以军地邑降者，皆赦之，复官爵。", "len": 27}
{"sid": "010_孝文本纪.25.5.s3", "chapter": "010_孝文本纪", "para": "25.5", "seq": 3, "text": "与王兴居去来，亦赦之。", "len": 11}
{"sid": "010_孝文本纪.25.5.s4", "chapter": "010_孝文本纪", "para": "25.5", "seq": 4, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.25.6.s1", "chapter": "010_孝文本纪", "para": "25.6", "seq": 1, "text": "八月，破济北军，虏其王。", "len": 12}
{"sid": "010_孝文本纪.25.7.s1", "chapter": "010_孝文本纪", "para": "25.7", "seq": 1, "text": "赦济北诸吏民与王反者。", "len": 11}
{"sid": "010_孝文本纪.26.1.s1", "chapter": "010_孝文本纪", "para": "26.1", "seq": 1, "text": "六年，有司言淮南王长废先帝法，不听天子诏，居处毋度，出入拟於天子，擅为法令，与棘蒲侯太子奇谋反，遣人使闽越及匈奴，发其兵，欲以危宗庙社稷。", "len": 69}
{"sid": "010_孝文本纪.26.2.s1", "chapter": "010_孝文本纪", "para": "26.2", "seq": 1, "text": "群臣议，皆曰“长当弃市”", "len": 12}
{"sid": "010_孝文本纪.26.3.s1", "chapter": "010_孝文本纪", "para": "26.3", "seq": 1, "text": "帝不忍致法於王，赦其罪，废勿王。", "len": 16}
{"sid": "010_孝文本纪.26.4.s1", "chapter": "010_孝文本纪", "para": "26.4", "seq": 1, "text": "群臣请处王蜀严道、邛都，帝许之。", "len": 16}
{"sid": "010_孝文本纪.26.5.s1", "chapter": "010_孝文本纪", "para": "26.5", "seq": 1, "text": "长未到处所，行病死，上怜之。", "len": 14}
{"sid": "010_孝文本纪.26.6.s1", "chapter": "010_孝文本纪", "para": "26.6", "seq": 1, "text": "後十六年，追尊淮南王长谥为厉王，立其子三人为淮南王、衡山王、庐江王。", "len": 34}
{"sid": "010_孝文本纪.27.s1", "chapter": "010_孝文本纪", "para": "27", "seq": 1, "text": "十三年夏，上曰： ::: 除祕祝诏 “盖闻天道祸自怨起而福繇德兴。", "len": 33}
{"sid": "010_孝文本纪.27.s2", "chapter": "010_孝文本纪", "para": "27", "seq": 2, "text": "百官之非，宜由朕躬。", "len": 10}
{"sid": "010_孝文本纪.27.s3", "chapter": "010_孝文本纪", "para": "27", "seq": 3, "text": "今祕祝之官移过于下，以彰吾之不德，朕甚不取。", "len": 22}
{"sid": "010_孝文本纪.27.s4", "chapter": "010_孝文本纪", "para": "27", "seq": 4, "text": "其除之。", "len": 4}
{"sid": "010_孝文本纪.27.s5", "chapter": "010_孝文本纪", "para": "27", "seq": 5, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.28.1.s1", "chapter": "010_孝文本纪", "para": "28.1", "seq": 1, "text": "五月，齐太仓令淳于公有罪当刑，诏狱逮徙系长安。", "len": 23}
{"sid": "010_孝文本纪.28.2.s1", "chapter": "010_孝文本纪", "para": "28.2", "seq": 1, "text": "太仓公无男，有女五人。", "len": 11}
{"sid": "010_孝文本纪.28.3.s1", "chapter": "010_孝文本纪", "para": "28.3", "seq": 1, "text": "太仓公将行会逮，骂其女曰： “生子不生男，有缓急非有益也！”", "len": 30}
{"sid": "010_孝文本纪.28.4.s1", "chapter": "010_孝文本纪", "para": "28.4", "seq": 1, "text": "其少女缇萦自伤泣，乃随其父至长安，上书曰： ::: 缇萦上书 “妾父为吏，齐中皆称其廉平，今坐法当刑。", "len": 51}
{"sid": "010_孝文本纪.28.4.s2", "chapter": "010_孝文本纪", "para": "28.4", "seq": 2, "text": "妾伤夫死者不可复生，刑者不可复属，虽复欲改过自新，其道无由也。", "len": 31}
{"sid": "010_孝文本纪.28.4.s3", "chapter": "010_孝文本纪", "para": "28.4", "seq": 3, "text": "妾原没入为官婢，赎父刑罪，使得自新。", "len": 18}
{"sid": "010_孝文本纪.28.4.s4", "chapter": "010_孝文本纪", "para": "28.4", "seq": 4, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.28.5.s1", "chapter": "010_孝文本纪", "para": "28.5", "seq": 1, "text": "书奏天子，天子怜悲其意，乃下诏曰： ::: 除肉刑诏 “盖闻有虞氏之时，画衣冠异章服以为僇，而民不犯。", "len": 51}
{"sid": "010_孝文本纪.28.5.s2", "chapter": "010_孝文本纪", "para": "28.5", "seq": 2, "text": "何则？", "len": 3}
{"sid": "010_孝文本纪.28.5.s3", "chapter": "010_孝文本纪", "para": "28.5", "seq": 3, "text": "至治也。", "len": 4}
{"sid": "010_孝文本纪.28.5.s4", "chapter": "010_孝文本纪", "para": "28.5", "seq": 4, "text": "今法有肉刑三，而奸不止，其咎安在？", "len": 17}
{"sid": "010_孝文本纪.28.5.s5", "chapter": "010_孝文本纪", "para": "28.5", "seq": 5, "text": "非乃朕德薄而教不明欤？", "len": 11}
{"sid": "010_孝文本纪.28.5.s6", "chapter": "010_孝文本纪", "para": "28.5", "seq": 6, "text": "吾甚自愧。", "len": 5}
{"sid": "010_孝文本纪.28.5.s7", "chapter": "010_孝文本纪", "para": "28.5", "seq": 7, "text": "故夫驯道不纯而愚民陷焉。", "len": 12}
{"sid": "010_孝文本纪.28.5.s8", "chapter": "010_孝文本纪", "para": "28.5", "seq": 8, "text": "诗曰‘恺悌君子，民之父母’。", "len": 14}
{"sid": "010_孝文本纪.28.5.s9", "chapter": "010_孝文本纪", "para": "28.5", "seq": 9, "text": "今人有过，教未施而刑加焉？", "len": 13}
{"sid": "010_孝文本纪.28.5.s10", "chapter": "010_孝文本纪", "para": "28.5", "seq": 10, "text": "或欲改行为善而道毋由也。", "len": 12}
{"sid": "010_孝文本纪.28.5.s11", "chapter": "010_孝文本纪", "para": "28.5", "seq": 11, "text": "朕甚怜之。", "len": 5}
{"sid": "010_孝文本纪.28.5.s12", "chapter": "010_孝文本纪", "para": "28.5", "seq": 12, "text": "夫刑至断支体，刻肌肤，终身不息，何其楚痛而不德也，岂称为民父母之意哉！", "len": 35}
{"sid": "010_孝文本纪.28.5.s13", "chapter": "010_孝文本纪", "para": "28.5", "seq": 13, "text": "其除肉刑。", "len": 5}
{"sid": "010_孝文本纪.28.5.s14", "chapter": "010_孝文本纪", "para": "28.5", "seq": 14, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.29.s1", "chapter": "010_孝文本纪", "para": "29", "seq": 1, "text": "上曰： ::: 除田租诏 “农，天下之本，务莫大焉。", "len": 26}
{"sid": "010_孝文本纪.29.s2", "chapter": "010_孝文本纪", "para": "29", "seq": 2, "text": "今勤身从事而有租税之赋，是为本末者毋以异，其於劝农之道未备。", "len": 30}
{"sid": "010_孝文本纪.29.s3", "chapter": "010_孝文本纪", "para": "29", "seq": 3, "text": "其除田之租税。", "len": 7}
{"sid": "010_孝文本纪.29.s4", "chapter": "010_孝文本纪", "para": "29", "seq": 4, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.30.1.s1", "chapter": "010_孝文本纪", "para": "30.1", "seq": 1, "text": "十四年冬，匈奴谋入边为寇，攻朝塞，杀北地都尉卬。", "len": 24}
{"sid": "010_孝文本纪.30.2.s1", "chapter": "010_孝文本纪", "para": "30.2", "seq": 1, "text": "上乃遣三将军军陇西、北地、上郡，中尉周舍为卫将军，郎中令张武为车骑将军，军渭北，车千乘，骑卒十万。", "len": 49}
{"sid": "010_孝文本纪.30.3.s1", "chapter": "010_孝文本纪", "para": "30.3", "seq": 1, "text": "帝亲自劳军，勒兵申教令，赐军吏卒。", "len": 17}
{"sid": "010_孝文本纪.30.4.s1", "chapter": "010_孝文本纪", "para": "30.4", "seq": 1, "text": "帝欲自将击匈奴，群臣谏，皆不听。", "len": 16}
{"sid": "010_孝文本纪.30.5.s1", "chapter": "010_孝文本纪", "para": "30.5", "seq": 1, "text": "皇太后固要帝，帝乃止。", "len": 11}
{"sid": "010_孝文本纪.30.6.s1", "chapter": "010_孝文本纪", "para": "30.6", "seq": 1, "text": "於是以东阳侯张相如为大将军，成侯赤为内史，栾布为将军，击匈奴。", "len": 31}
{"sid": "010_孝文本纪.30.7.s1", "chapter": "010_孝文本纪", "para": "30.7", "seq": 1, "text": "匈奴遁走。", "len": 5}
{"sid": "010_孝文本纪.31.1.s1", "chapter": "010_孝文本纪", "para": "31.1", "seq": 1, "text": "春，上曰： ::: 祀官致敬诏 “朕获执牺牲珪币以事上帝宗庙，十四年于今，历日长，以不敏不明而久抚临天下，朕甚自愧。", "len": 58}
{"sid": "010_孝文本纪.31.1.s2", "chapter": "010_孝文本纪", "para": "31.1", "seq": 2, "text": "其广增诸祀墠场珪币。", "len": 10}
{"sid": "010_孝文本纪.31.1.s3", "chapter": "010_孝文本纪", "para": "31.1", "seq": 3, "text": "昔先王远施不求其报，望祀不祈其福，右贤左戚，先民後己，至明之极也。", "len": 33}
{"sid": "010_孝文本纪.31.1.s4", "chapter": "010_孝文本纪", "para": "31.1", "seq": 4, "text": "今吾闻祠官祝釐，皆归福朕躬，不为百姓，朕甚愧之。", "len": 24}
{"sid": "010_孝文本纪.31.1.s5", "chapter": "010_孝文本纪", "para": "31.1", "seq": 5, "text": "夫以朕不德，而躬享独美其福，百姓不与焉，是重吾不德。", "len": 26}
{"sid": "010_孝文本纪.31.1.s6", "chapter": "010_孝文本纪", "para": "31.1", "seq": 6, "text": "其令祠官致敬，毋有所祈。", "len": 12}
{"sid": "010_孝文本纪.31.1.s7", "chapter": "010_孝文本纪", "para": "31.1", "seq": 7, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.32.1.s1", "chapter": "010_孝文本纪", "para": "32.1", "seq": 1, "text": "是时北平侯张苍为丞相，方明律历。", "len": 16}
{"sid": "010_孝文本纪.32.2.s1", "chapter": "010_孝文本纪", "para": "32.2", "seq": 1, "text": "鲁人公孙臣上书陈终始传五德事，言方今土德时，土德应黄龙见，当改正朔服色制度。", "len": 38}
{"sid": "010_孝文本纪.32.3.s1", "chapter": "010_孝文本纪", "para": "32.3", "seq": 1, "text": "天子下其事与丞相议。", "len": 10}
{"sid": "010_孝文本纪.32.4.s1", "chapter": "010_孝文本纪", "para": "32.4", "seq": 1, "text": "丞相推以为今水德，始明正十月上黑事，以为其言非是，请罢之。", "len": 29}
{"sid": "010_孝文本纪.33.1.s1", "chapter": "010_孝文本纪", "para": "33.1", "seq": 1, "text": "十五年，黄龙见成纪，天子乃复召鲁公孙臣，以为博士，申明土德事。", "len": 31}
{"sid": "010_孝文本纪.33.2.s1", "chapter": "010_孝文本纪", "para": "33.2", "seq": 1, "text": "於是上乃下诏曰： ::: 郊祀诏 “有异物之神见于成纪，无害於民，岁以有年。", "len": 38}
{"sid": "010_孝文本纪.33.2.s2", "chapter": "010_孝文本纪", "para": "33.2", "seq": 2, "text": "朕亲郊祀上帝诸神。", "len": 9}
{"sid": "010_孝文本纪.33.2.s3", "chapter": "010_孝文本纪", "para": "33.2", "seq": 3, "text": "礼官议，毋讳以劳朕。", "len": 10}
{"sid": "010_孝文本纪.33.2.s4", "chapter": "010_孝文本纪", "para": "33.2", "seq": 4, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.33.3.s1", "chapter": "010_孝文本纪", "para": "33.3", "seq": 1, "text": "有司礼官皆曰： “古者天子夏躬亲礼祀上帝於郊，故曰郊。”", "len": 28}
{"sid": "010_孝文本纪.33.4.s1", "chapter": "010_孝文本纪", "para": "33.4", "seq": 1, "text": "於是天子始幸雍，郊见五帝，以孟夏四月答礼焉。", "len": 22}
{"sid": "010_孝文本纪.33.5.s1", "chapter": "010_孝文本纪", "para": "33.5", "seq": 1, "text": "赵人新垣平以望气见，因说上设立渭阳五庙。", "len": 20}
{"sid": "010_孝文本纪.33.6.s1", "chapter": "010_孝文本纪", "para": "33.6", "seq": 1, "text": "欲出周鼎，当有玉英见。", "len": 11}
{"sid": "010_孝文本纪.34.1.s1", "chapter": "010_孝文本纪", "para": "34.1", "seq": 1, "text": "十六年，上亲郊见渭阳五帝庙，亦以夏答礼而尚赤。", "len": 23}
{"sid": "010_孝文本纪.35.1.s1", "chapter": "010_孝文本纪", "para": "35.1", "seq": 1, "text": "十七年，得玉杯，刻曰“人主延寿”。", "len": 17}
{"sid": "010_孝文本纪.35.2.s1", "chapter": "010_孝文本纪", "para": "35.2", "seq": 1, "text": "於是天子始更为元年，令天下大酺。", "len": 16}
{"sid": "010_孝文本纪.35.3.s1", "chapter": "010_孝文本纪", "para": "35.3", "seq": 1, "text": "其岁，新垣平事觉，夷三族。", "len": 13}
{"sid": "010_孝文本纪.36.1.s1", "chapter": "010_孝文本纪", "para": "36.1", "seq": 1, "text": "後二年，上曰： ::: 和亲匈奴诏 “朕既不明，不能远德，是以使方外之国或不宁息。", "len": 41}
{"sid": "010_孝文本纪.36.1.s2", "chapter": "010_孝文本纪", "para": "36.1", "seq": 2, "text": "夫四荒之外不安其生，封畿之内勤劳不处，二者之咎，皆自於朕之德薄而不能远达也。", "len": 38}
{"sid": "010_孝文本纪.36.1.s3", "chapter": "010_孝文本纪", "para": "36.1", "seq": 3, "text": "间者累年，匈奴并暴边境，多杀吏民，边臣兵吏又不能谕吾内志，以重吾不德也。", "len": 36}
{"sid": "010_孝文本纪.36.1.s4", "chapter": "010_孝文本纪", "para": "36.1", "seq": 4, "text": "夫久结难连兵，中外之国将何以自宁？", "len": 17}
{"sid": "010_孝文本纪.36.1.s5", "chapter": "010_孝文本纪", "para": "36.1", "seq": 5, "text": "今朕夙兴夜寐，勤劳天下，忧苦万民，为之怛惕不安，未尝一日忘於心，故遣使者冠盖相望，结轶於道，以谕朕意於单于。", "len": 54}
{"sid": "010_孝文本纪.36.1.s6", "chapter": "010_孝文本纪", "para": "36.1", "seq": 6, "text": "今单于反古之道，计社稷之安，便万民之利，亲与朕俱弃细过，偕之大道，结兄弟之义，以全天下元元之民。", "len": 48}
{"sid": "010_孝文本纪.36.1.s7", "chapter": "010_孝文本纪", "para": "36.1", "seq": 7, "text": "和亲已定，始于今年。", "len": 10}
{"sid": "010_孝文本纪.36.1.s8", "chapter": "010_孝文本纪", "para": "36.1", "seq": 8, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.37.1.s1", "chapter": "010_孝文本纪", "para": "37.1", "seq": 1, "text": "後六年冬，匈奴三万人入上郡，三万人入云中。", "len": 21}
{"sid": "010_孝文本纪.37.2.s1", "chapter": "010_孝文本纪", "para": "37.2", "seq": 1, "text": "以中大夫令勉为车骑将军，军飞狐；故楚相苏意为将军，军句注；将军张武屯北地；河内守周亚夫为将军，居细柳；宗正刘礼为将军，居霸上；祝兹侯军棘门：以备胡。", "len": 74}
{"sid": "010_孝文本纪.37.3.s1", "chapter": "010_孝文本纪", "para": "37.3", "seq": 1, "text": "数月，胡人去，亦罢。", "len": 10}
{"sid": "010_孝文本纪.38.1.s1", "chapter": "010_孝文本纪", "para": "38.1", "seq": 1, "text": "天下旱，蝗。", "len": 6}
{"sid": "010_孝文本纪.38.2.s1", "chapter": "010_孝文本纪", "para": "38.2", "seq": 1, "text": "帝加惠：令诸侯毋入贡，弛山泽，减诸服御狗马，损郎吏员，发仓庾以振贫民，民得卖爵。", "len": 40}
{"sid": "010_孝文本纪.39.1.s1", "chapter": "010_孝文本纪", "para": "39.1", "seq": 1, "text": "孝文帝从代来，即位二十三年，宫室苑囿狗马服御无所增益，有不便，辄弛以利民。", "len": 37}
{"sid": "010_孝文本纪.39.2.s1", "chapter": "010_孝文本纪", "para": "39.2", "seq": 1, "text": "尝欲作露台，召匠计之，直百金。", "len": 15}
{"sid": "010_孝文本纪.39.3.s1", "chapter": "010_孝文本纪", "para": "39.3", "seq": 1, "text": "上曰： “百金中民十家之产，吾奉先帝宫室，常恐羞之，何以台为！”", "len": 32}
{"sid": "010_孝文本纪.39.4.s1", "chapter": "010_孝文本纪", "para": "39.4", "seq": 1, "text": "上常衣綈衣，所幸慎夫人，令衣不得曳地，帏帐不得文绣，以示敦朴，为天下先。", "len": 36}
{"sid": "010_孝文本纪.39.5.s1", "chapter": "010_孝文本纪", "para": "39.5", "seq": 1, "text": "治霸陵皆以瓦器，不得以金银铜锡为饰，不治坟，欲为省，毋烦民。", "len": 30}
{"sid": "010_孝文本纪.40.1.s1", "chapter": "010_孝文本纪", "para": "40.1", "seq": 1, "text": "南越王尉佗自立为武帝，然上召贵尉佗兄弟，以德报之，佗遂去帝称臣。", "len": 32}
{"sid": "010_孝文本纪.40.2.s1", "chapter": "010_孝文本纪", "para": "40.2", "seq": 1, "text": "与匈奴和亲，匈奴背约入盗，然令边备守，不发兵深入，恶烦苦百姓。", "len": 31}
{"sid": "010_孝文本纪.40.3.s1", "chapter": "010_孝文本纪", "para": "40.3", "seq": 1, "text": "吴王诈病不朝，就赐几杖。", "len": 12}
{"sid": "010_孝文本纪.40.4.s1", "chapter": "010_孝文本纪", "para": "40.4", "seq": 1, "text": "群臣如袁盎等称说虽切，常假借用之。", "len": 17}
{"sid": "010_孝文本纪.40.5.s1", "chapter": "010_孝文本纪", "para": "40.5", "seq": 1, "text": "群臣如张武等受赂遗金钱，觉，上乃发御府金钱赐之，以愧其心，弗下吏。", "len": 33}
{"sid": "010_孝文本纪.40.6.s1", "chapter": "010_孝文本纪", "para": "40.6", "seq": 1, "text": "专务以德化民，是以海内殷富，兴於礼义。", "len": 19}
{"sid": "010_孝文本纪.41.1.s1", "chapter": "010_孝文本纪", "para": "41.1", "seq": 1, "text": "後七年六月己亥，帝崩於未央宫。", "len": 15}
{"sid": "010_孝文本纪.41.2.s1", "chapter": "010_孝文本纪", "para": "41.2", "seq": 1, "text": "遗诏曰： ::: 遗诏 “朕闻盖天下万物之萌生，靡不有死。", "len": 29}
{"sid": "010_孝文本纪.41.2.s2", "chapter": "010_孝文本纪", "para": "41.2", "seq": 2, "text": "死者天地之理，物之自然者，奚可甚哀。", "len": 18}
{"sid": "010_孝文本纪.41.2.s3", "chapter": "010_孝文本纪", "para": "41.2", "seq": 3, "text": "当今之时，世咸嘉生而恶死，厚葬以破业，重服以伤生，吾甚不取。", "len": 30}
{"sid": "010_孝文本纪.41.2.s4", "chapter": "010_孝文本纪", "para": "41.2", "seq": 4, "text": "且朕既不德，无以佐百姓；今崩，又使重服久临，以离寒暑之数，哀人之父子，伤长幼之志，损其饮食，绝鬼神之祭祀，以重吾不德也，谓天下何！", "len": 65}
{"sid": "010_孝文本纪.41.2.s5", "chapter": "010_孝文本纪", "para": "41.2", "seq": 5, "text": "朕获保宗庙，以眇眇之身讬于天下君王之上，二十有馀年矣。", "len": 27}
{"sid": "010_孝文本纪.41.2.s6", "chapter": "010_孝文本纪", "para": "41.2", "seq": 6, "text": "赖天地之灵，社稷之福，方内安宁，靡有兵革。", "len": 21}
{"sid": "010_孝文本纪.41.2.s7", "chapter": "010_孝文本纪", "para": "41.2", "seq": 7, "text": "朕既不敏，常畏过行，以羞先帝之遗德；维年之久长，惧于不终。", "len": 29}
{"sid": "010_孝文本纪.41.2.s8", "chapter": "010_孝文本纪", "para": "41.2", "seq": 8, "text": "今乃幸以天年，得复供养于高庙。", "len": 15}
{"sid": "010_孝文本纪.41.2.s9", "chapter": "010_孝文本纪", "para": "41.2", "seq": 9, "text": "朕之不明与嘉之，其奚哀悲之有！", "len": 15}
{"sid": "010_孝文本纪.41.2.s10", "chapter": "010_孝文本纪", "para": "41.2", "seq": 10, "text": "其令天下吏民，令到出临三日，皆释服。", "len": 18}
{"sid": "010_孝文本纪.41.2.s11", "chapter": "010_孝文本纪", "para": "41.2", "seq": 11, "text": "毋禁取妇嫁女祠祀饮酒食肉者。", "len": 14}
{"sid": "010_孝文本纪.41.2.s12", "chapter": "010_孝文本纪", "para": "41.2", "seq": 12, "text": "自当给丧事服临者，皆无践。", "len": 13}
{"sid": "010_孝文本纪.41.2.s13", "chapter": "010_孝文本纪", "para": "41.2", "seq": 13, "text": "绖带无过三寸，毋布车及兵器，毋发民男女哭临宫殿。", "len": 24}
{"sid": "010_孝文本纪.41.2.s14", "chapter": "010_孝文本纪", "para": "41.2", "seq": 14, "text": "宫殿中当临者，皆以旦夕各十五举声，礼毕罢。", "len": 21}
{"sid": "010_孝文本纪.41.2.s15", "chapter": "010_孝文本纪", "para": "41.2", "seq": 15, "text": "非旦夕临时，禁毋得擅哭。", "len": 12}
{"sid": "010_孝文本纪.41.2.s16", "chapter": "010_孝文本纪", "para": "41.2", "seq": 16, "text": "已下，服大红十五日，小红十四日，纤七日，释服。", "len": 23}
{"sid": "010_孝文本纪.41.2.s17", "chapter": "010_孝文本纪", "para": "41.2", "seq": 17, "text": "佗不在令中者，皆以此令比率从事。", "len": 16}
{"sid": "010_孝文本纪.41.2.s18", "chapter": "010_孝文本纪", "para": "41.2", "seq": 18, "text": "布告天下，使明知朕意。", "len": 11}
{"sid": "010_孝文本纪.41.2.s19", "chapter": "010_孝文本纪", "para": "41.2", "seq": 19, "text": "霸陵山川因其故，毋有所改。", "len": 13}
{"sid": "010_孝文本纪.41.2.s20", "chapter": "010_孝文本纪", "para": "41.2", "seq": 20, "text": "归夫人以下至少使。", "len": 9}
{"sid": "010_孝文本纪.41.2.s21", "chapter": "010_孝文本纪", "para": "41.2", "seq": 21, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.41.3.s1", "chapter": "010_孝文本纪", "para": "41.3", "seq": 1, "text": "令中尉亚夫为车骑将军，属国悍为将屯将军，郎中令武为复土将军，发近县见卒万六千人，发内史卒万五千人，藏郭穿复土属将军武。", "len": 59}
{"sid": "010_孝文本纪.42.1.s1", "chapter": "010_孝文本纪", "para": "42.1", "seq": 1, "text": "乙巳，群臣皆顿首上尊号曰孝文皇帝。", "len": 17}
{"sid": "010_孝文本纪.42.2.s1", "chapter": "010_孝文本纪", "para": "42.2", "seq": 1, "text": "太子即位于高庙。", "len": 8}
{"sid": "010_孝文本纪.42.3.s1", "chapter": "010_孝文本纪", "para": "42.3", "seq": 1, "text": "丁未，袭号曰皇帝。", "len": 9}
{"sid": "010_孝文本纪.43.1.s1", "chapter": "010_孝文本纪", "para": "43.1", "seq": 1, "text": "孝景皇帝元年十月，制诏御史： ::: 追颂文帝诏 “盖闻古者祖有功而宗有德，制礼乐各有由。", "len": 45}
{"sid": "010_孝文本纪.43.1.s2", "chapter": "010_孝文本纪", "para": "43.1", "seq": 2, "text": "闻歌者，所以发德也；舞者，所以明功也。", "len": 19}
{"sid": "010_孝文本纪.43.1.s3", "chapter": "010_孝文本纪", "para": "43.1", "seq": 3, "text": "高庙酎，奏武德、文始、五行之舞。", "len": 16}
{"sid": "010_孝文本纪.43.1.s4", "chapter": "010_孝文本纪", "para": "43.1", "seq": 4, "text": "孝惠庙酎，奏文始、五行之舞。", "len": 14}
{"sid": "010_孝文本纪.43.1.s5", "chapter": "010_孝文本纪", "para": "43.1", "seq": 5, "text": "孝文皇帝临天下，通关梁，不异远方。", "len": 17}
{"sid": "010_孝文本纪.43.1.s6", "chapter": "010_孝文本纪", "para": "43.1", "seq": 6, "text": "除诽谤，去肉刑，赏赐长老，收恤孤独，以育群生。", "len": 23}
{"sid": "010_孝文本纪.43.1.s7", "chapter": "010_孝文本纪", "para": "43.1", "seq": 7, "text": "减嗜欲，不受献，不私其利也。", "len": 14}
{"sid": "010_孝文本纪.43.1.s8", "chapter": "010_孝文本纪", "para": "43.1", "seq": 8, "text": "罪人不帑，不诛无罪。", "len": 10}
{"sid": "010_孝文本纪.43.1.s9", "chapter": "010_孝文本纪", "para": "43.1", "seq": 9, "text": "除刑，出美人，重绝人之世。", "len": 13}
{"sid": "010_孝文本纪.43.1.s10", "chapter": "010_孝文本纪", "para": "43.1", "seq": 10, "text": "朕既不敏，不能识。", "len": 9}
{"sid": "010_孝文本纪.43.1.s11", "chapter": "010_孝文本纪", "para": "43.1", "seq": 11, "text": "此皆上古之所不及，而孝文皇帝亲行之。", "len": 18}
{"sid": "010_孝文本纪.43.1.s12", "chapter": "010_孝文本纪", "para": "43.1", "seq": 12, "text": "德厚侔天地，利泽施四海，靡不获福焉。", "len": 18}
{"sid": "010_孝文本纪.43.1.s13", "chapter": "010_孝文本纪", "para": "43.1", "seq": 13, "text": "明象乎日月，而庙乐不称。", "len": 12}
{"sid": "010_孝文本纪.43.1.s14", "chapter": "010_孝文本纪", "para": "43.1", "seq": 14, "text": "朕甚惧焉。", "len": 5}
{"sid": "010_孝文本纪.43.1.s15", "chapter": "010_孝文本纪", "para": "43.1", "seq": 15, "text": "其为孝文皇帝庙为昭德之舞，以明休德。", "len": 18}
{"sid": "010_孝文本纪.43.1.s16", "chapter": "010_孝文本纪", "para": "43.1", "seq": 16, "text": "然后祖宗之功德著於竹帛，施于万世，永永无穷，朕甚嘉之。", "len": 27}
{"sid": "010_孝文本纪.43.1.s17", "chapter": "010_孝文本纪", "para": "43.1", "seq": 17, "text": "其与丞相、列侯、中二千石、礼官具为礼仪奏。", "len": 21}
{"sid": "010_孝文本纪.43.1.s18", "chapter": "010_孝文本纪", "para": "43.1", "seq": 18, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.43.2.s1", "chapter": "010_孝文本纪", "para": "43.2", "seq": 1, "text": "丞相臣嘉等言： ::: 丞相等奏议 “陛下永思孝道，立昭德之舞以明孝文皇帝之盛德。", "len": 41}
{"sid": "010_孝文本纪.43.2.s2", "chapter": "010_孝文本纪", "para": "43.2", "seq": 2, "text": "皆臣嘉等愚所不及。", "len": 9}
{"sid": "010_孝文本纪.43.2.s3", "chapter": "010_孝文本纪", "para": "43.2", "seq": 3, "text": "臣谨议：世功莫大於高皇帝，德莫盛於孝文皇帝，高皇庙宜为帝者太祖之庙，孝文皇帝庙宜为帝者太宗之庙。", "len": 48}
{"sid": "010_孝文本纪.43.2.s4", "chapter": "010_孝文本纪", "para": "43.2", "seq": 4, "text": "天子宜世世献祖宗之庙。", "len": 11}
{"sid": "010_孝文本纪.43.2.s5", "chapter": "010_孝文本纪", "para": "43.2", "seq": 5, "text": "郡国诸侯宜各为孝文皇帝立太宗之庙。", "len": 17}
{"sid": "010_孝文本纪.43.2.s6", "chapter": "010_孝文本纪", "para": "43.2", "seq": 6, "text": "诸侯王列侯使者侍祠天子，岁献祖宗之庙。", "len": 19}
{"sid": "010_孝文本纪.43.2.s7", "chapter": "010_孝文本纪", "para": "43.2", "seq": 7, "text": "请著之竹帛，宣布天下。", "len": 11}
{"sid": "010_孝文本纪.43.2.s8", "chapter": "010_孝文本纪", "para": "43.2", "seq": 8, "text": "” :::", "len": 5}
{"sid": "010_孝文本纪.43.3.s1", "chapter": "010_孝文本纪", "para": "43.3", "seq": 1, "text": "制曰： “可。", "len": 7}
{"sid": "010_孝文本纪.43.3.s2", "chapter": "010_孝文本纪", "para": "43.3", "seq": 2, "text": "” ::: 太史公曰", "len": 10}
{"sid": "010_孝文本纪.44.1.s1", "chapter": "010_孝文本纪", "para": "44.1", "seq": 1, "text": "太史公曰：孔子言“必世然後仁。", "len": 15}
{"sid": "010_孝文本纪.44.1.s2", "chapter": "010_孝文本纪", "para": "44.1", "seq": 2, "text": "善人之治国百年，亦可以胜残去杀”。", "len": 17}
{"sid": "010_孝文本纪.44.1.s3", "chapter": "010_孝文本纪", "para": "44.1", "seq": 3, "text": "诚哉是言！", "len": 5}
{"sid": "010_孝文本纪.44.2.s1", "chapter": "010_孝文本纪", "para": "44.2", "seq": 1, "text": "汉兴，至孝文四十有馀载，德至盛也。", "len": 17}
{"sid": "010_孝文本纪.44.2.s2", "chapter": "010_孝文本纪", "para": "44.2", "seq": 2, "text": "廪廪乡改正服封禅矣，谦让未成於今。", "len": 17}
{"sid": "010_孝文本纪.44.2.s3", "chapter": "010_孝文本纪", "para": "44.2", "seq": 3, "text": "呜呼，岂不仁哉！", "len": 8}
{"sid": "010_孝文本纪.44.2.s4", "chapter": "010_孝文本纪", "para": "44.2", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "010_孝文本纪.45.s1", "chapter": "010_孝文本纪", "para": "45", "seq": 1, "text": "孝文在代，兆遇大横。", "len": 10}
{"sid": "010_孝文本纪.45.s2", "chapter": "010_孝文本纪", "para": "45", "seq": 2, "text": "宋昌建册，绛侯奉迎。", "len": 10}
{"sid": "010_孝文本纪.45.s3", "chapter": "010_孝文本纪", "para": "45", "seq": 3, "text": "南面而让，天下归诚。", "len": 10}
{"sid": "010_孝文本纪.45.s4", "chapter": "010_孝文本纪", "para": "45", "seq": 4, "text": "务农先籍，布德偃兵。", "len": 10}
{"sid": "010_孝文本纪.45.s5", "chapter": "010_孝文本纪", "para": "45", "seq": 5, "text": "除帑削谤，政简刑清。", "len": 10}
{"sid": "010_孝文本纪.45.s6", "chapter": "010_孝文本纪", "para": "45", "seq": 6, "text": "綈衣率俗，露台罢营。", "len": 10}
{"sid": "010_孝文本纪.45.s7", "chapter": "010_孝文本纪", "para": "45", "seq": 7, "text": "法宽张武，狱恤缇萦。", "len": 10}
{"sid": "010_孝文本纪.45.s8", "chapter": "010_孝文本纪", "para": "45", "seq": 8, "text": "霸陵如故，千年颂声。", "len": 10}
{"sid": "010_孝文本纪.45.s9", "chapter": "010_孝文本纪", "para": "45", "seq": 9, "text": ":::", "len": 3}
