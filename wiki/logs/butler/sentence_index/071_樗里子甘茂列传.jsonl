{"sid": "071_樗里子甘茂列传.1.s1", "chapter": "071_樗里子甘茂列传", "para": "1", "seq": 1, "text": "樗里子者，名疾，秦惠王之弟也，与惠王异母。", "len": 21}
{"sid": "071_樗里子甘茂列传.1.s2", "chapter": "071_樗里子甘茂列传", "para": "1", "seq": 2, "text": "母，韩女也。", "len": 6}
{"sid": "071_樗里子甘茂列传.1.s3", "chapter": "071_樗里子甘茂列传", "para": "1", "seq": 3, "text": "樗里子滑稽多智，秦人号曰“智囊”。", "len": 17}
{"sid": "071_樗里子甘茂列传.2.s1", "chapter": "071_樗里子甘茂列传", "para": "2", "seq": 1, "text": "秦惠王八年，爵樗里子右更，使将而伐曲沃，尽出其人，取其城，地入秦。", "len": 33}
{"sid": "071_樗里子甘茂列传.2.s2", "chapter": "071_樗里子甘茂列传", "para": "2", "seq": 2, "text": "秦惠王二十五年，使樗里子为将伐赵，虏赵将军庄豹，拔蔺。", "len": 27}
{"sid": "071_樗里子甘茂列传.2.s3", "chapter": "071_樗里子甘茂列传", "para": "2", "seq": 3, "text": "明年，助魏章攻楚，败楚将屈丐，取汉中地。", "len": 20}
{"sid": "071_樗里子甘茂列传.2.s4", "chapter": "071_樗里子甘茂列传", "para": "2", "seq": 4, "text": "秦封樗里子，号为严君。", "len": 11}
{"sid": "071_樗里子甘茂列传.3.s1", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 1, "text": "秦惠王卒，太子武王立，逐张仪、魏章，而以樗里子、甘茂为左右丞相。", "len": 32}
{"sid": "071_樗里子甘茂列传.3.s2", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 2, "text": "秦使甘茂攻韩，拔宜阳。", "len": 11}
{"sid": "071_樗里子甘茂列传.3.s3", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 3, "text": "使樗里子以车百乘入周。", "len": 11}
{"sid": "071_樗里子甘茂列传.3.s4", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 4, "text": "周以卒迎之，意甚敬。", "len": 10}
{"sid": "071_樗里子甘茂列传.3.s5", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 5, "text": "楚王怒，让周，以其重秦客。", "len": 13}
{"sid": "071_樗里子甘茂列传.3.s6", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 6, "text": "游腾为周说楚王曰：“知伯之伐仇犹，遗之广车，因随之以兵，仇犹遂亡。", "len": 33}
{"sid": "071_樗里子甘茂列传.3.s7", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 7, "text": "何则？", "len": 3}
{"sid": "071_樗里子甘茂列传.3.s8", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 8, "text": "无备故也。", "len": 5}
{"sid": "071_樗里子甘茂列传.3.s9", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 9, "text": "齐桓公伐蔡，号曰诛楚，其实袭蔡。", "len": 16}
{"sid": "071_樗里子甘茂列传.3.s10", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 10, "text": "今秦，虎狼之国，使樗里子以车百乘入周，周以仇犹、蔡观焉，故使长戟居前，彊弩在後，名曰卫疾，而实囚之。", "len": 50}
{"sid": "071_樗里子甘茂列传.3.s11", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 11, "text": "且夫周岂能无忧其社稷哉？", "len": 12}
{"sid": "071_樗里子甘茂列传.3.s12", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 12, "text": "恐一旦亡国以忧大王。", "len": 10}
{"sid": "071_樗里子甘茂列传.3.s13", "chapter": "071_樗里子甘茂列传", "para": "3", "seq": 13, "text": "” 楚王乃悦。", "len": 7}
{"sid": "071_樗里子甘茂列传.4.s1", "chapter": "071_樗里子甘茂列传", "para": "4", "seq": 1, "text": "秦武王卒，昭王立，樗里子又益尊重。", "len": 17}
{"sid": "071_樗里子甘茂列传.5.s1", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 1, "text": "昭王元年，樗里子将伐蒲。", "len": 12}
{"sid": "071_樗里子甘茂列传.5.s2", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 2, "text": "蒲守恐，请胡衍。", "len": 8}
{"sid": "071_樗里子甘茂列传.5.s3", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 3, "text": "胡衍为蒲谓樗里子曰：“公之攻蒲，为秦乎？", "len": 20}
{"sid": "071_樗里子甘茂列传.5.s4", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 4, "text": "为魏乎？", "len": 4}
{"sid": "071_樗里子甘茂列传.5.s5", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 5, "text": "为魏则善矣，为秦则不为赖矣。", "len": 14}
{"sid": "071_樗里子甘茂列传.5.s6", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 6, "text": "夫卫之所以为卫者，以蒲也。", "len": 13}
{"sid": "071_樗里子甘茂列传.5.s7", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 7, "text": "今伐蒲入於魏，卫必折而从之。", "len": 14}
{"sid": "071_樗里子甘茂列传.5.s8", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 8, "text": "魏亡西河之外而无以取者，兵弱也。", "len": 16}
{"sid": "071_樗里子甘茂列传.5.s9", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 9, "text": "今并卫於魏，魏必彊。", "len": 10}
{"sid": "071_樗里子甘茂列传.5.s10", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 10, "text": "魏彊之日，西河之外必危矣。", "len": 13}
{"sid": "071_樗里子甘茂列传.5.s11", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 11, "text": "且秦王将观公之事，害秦而利魏，王必罪公。", "len": 20}
{"sid": "071_樗里子甘茂列传.5.s12", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 12, "text": "” 樗里子曰：“柰何？", "len": 11}
{"sid": "071_樗里子甘茂列传.5.s13", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 13, "text": "” 胡衍曰：“公释蒲勿攻，臣试为公入言之，以德卫君。", "len": 26}
{"sid": "071_樗里子甘茂列传.5.s14", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 14, "text": "” 樗里子曰：“善。", "len": 10}
{"sid": "071_樗里子甘茂列传.5.s15", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 15, "text": "” 胡衍入蒲，谓其守曰：“樗里子知蒲之病矣，其言曰必拔蒲。", "len": 29}
{"sid": "071_樗里子甘茂列传.5.s16", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 16, "text": "衍能令释蒲勿攻。", "len": 8}
{"sid": "071_樗里子甘茂列传.5.s17", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 17, "text": "” 蒲守恐，因再拜曰：“原以请。", "len": 16}
{"sid": "071_樗里子甘茂列传.5.s18", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 18, "text": "” 因效金三百斤，曰：“秦兵苟退，请必言子於卫君，使子为南面。", "len": 31}
{"sid": "071_樗里子甘茂列传.5.s19", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 19, "text": "” 故胡衍受金於蒲以自贵於卫。", "len": 15}
{"sid": "071_樗里子甘茂列传.5.s20", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 20, "text": "於是遂解蒲而去。", "len": 8}
{"sid": "071_樗里子甘茂列传.5.s21", "chapter": "071_樗里子甘茂列传", "para": "5", "seq": 21, "text": "还击皮氏，皮氏未降，又去。", "len": 13}
{"sid": "071_樗里子甘茂列传.6.s1", "chapter": "071_樗里子甘茂列传", "para": "6", "seq": 1, "text": "昭王七年，樗里子卒，葬于渭南章台之东。", "len": 19}
{"sid": "071_樗里子甘茂列传.6.s2", "chapter": "071_樗里子甘茂列传", "para": "6", "seq": 2, "text": "曰：“後百岁，是当有天子之宫夹我墓。", "len": 18}
{"sid": "071_樗里子甘茂列传.6.s3", "chapter": "071_樗里子甘茂列传", "para": "6", "seq": 3, "text": "” 樗里子疾室在於昭王庙西渭南阴乡樗里，故俗谓之樗里子。", "len": 28}
{"sid": "071_樗里子甘茂列传.6.s4", "chapter": "071_樗里子甘茂列传", "para": "6", "seq": 4, "text": "至汉兴，长乐宫在其东，未央宫在其西，武库正直其墓。", "len": 25}
{"sid": "071_樗里子甘茂列传.6.s5", "chapter": "071_樗里子甘茂列传", "para": "6", "seq": 5, "text": "秦人谚曰：“力则任鄙，智则樗里。”", "len": 17}
{"sid": "071_樗里子甘茂列传.7.s1", "chapter": "071_樗里子甘茂列传", "para": "7", "seq": 1, "text": "甘茂者，下蔡人也。", "len": 9}
{"sid": "071_樗里子甘茂列传.7.s2", "chapter": "071_樗里子甘茂列传", "para": "7", "seq": 2, "text": "事下蔡史举先生，学百家之术。", "len": 14}
{"sid": "071_樗里子甘茂列传.7.s3", "chapter": "071_樗里子甘茂列传", "para": "7", "seq": 3, "text": "因张仪、樗里子而求见秦惠王。", "len": 14}
{"sid": "071_樗里子甘茂列传.7.s4", "chapter": "071_樗里子甘茂列传", "para": "7", "seq": 4, "text": "王见而说之，使将，而佐魏章略定汉中地。", "len": 19}
{"sid": "071_樗里子甘茂列传.8.s1", "chapter": "071_樗里子甘茂列传", "para": "8", "seq": 1, "text": "惠王卒，武王立。", "len": 8}
{"sid": "071_樗里子甘茂列传.8.s2", "chapter": "071_樗里子甘茂列传", "para": "8", "seq": 2, "text": "张仪、魏章去，东之魏。", "len": 11}
{"sid": "071_樗里子甘茂列传.8.s3", "chapter": "071_樗里子甘茂列传", "para": "8", "seq": 3, "text": "蜀侯煇、相壮反，秦使甘茂定蜀。", "len": 15}
{"sid": "071_樗里子甘茂列传.8.s4", "chapter": "071_樗里子甘茂列传", "para": "8", "seq": 4, "text": "还，而以甘茂为左丞相，以樗里子为右丞相。", "len": 20}
{"sid": "071_樗里子甘茂列传.9.s1", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 1, "text": "秦武王三年，谓甘茂曰：“寡人欲容车通三川，以窥周室，而寡人死不朽矣。", "len": 34}
{"sid": "071_樗里子甘茂列传.9.s2", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 2, "text": "” 甘茂曰：“请之魏，约以伐韩，而令向寿辅行。", "len": 23}
{"sid": "071_樗里子甘茂列传.9.s3", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 3, "text": "” 甘茂至，谓向寿曰：“子归，言之於王曰‘魏听臣矣，然原王勿伐’。", "len": 33}
{"sid": "071_樗里子甘茂列传.9.s4", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 4, "text": "事成，尽以为子功。", "len": 9}
{"sid": "071_樗里子甘茂列传.9.s5", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 5, "text": "” 向寿归，以告王，王迎甘茂於息壤。", "len": 18}
{"sid": "071_樗里子甘茂列传.9.s6", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 6, "text": "甘茂至，王问其故。", "len": 9}
{"sid": "071_樗里子甘茂列传.9.s7", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 7, "text": "对曰：“宜阳，大县也，上党、南阳积之久矣。", "len": 21}
{"sid": "071_樗里子甘茂列传.9.s8", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 8, "text": "名曰县，其实郡也。", "len": 9}
{"sid": "071_樗里子甘茂列传.9.s9", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 9, "text": "今王倍数险，行千里攻之，难。", "len": 14}
{"sid": "071_樗里子甘茂列传.9.s10", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 10, "text": "昔曾参之处费，鲁人有与曾参同姓名者杀人，人告其母曰‘曾参杀人’，其母织自若也。", "len": 39}
{"sid": "071_樗里子甘茂列传.9.s11", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 11, "text": "顷之，一人又告之曰‘曾参杀人’，其母尚织自若也。", "len": 24}
{"sid": "071_樗里子甘茂列传.9.s12", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 12, "text": "顷又一人告之曰‘曾参杀人’，其母投杼下机，逾墙而走。", "len": 26}
{"sid": "071_樗里子甘茂列传.9.s13", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 13, "text": "夫以曾参之贤与其母信之也，三人疑之，其母惧焉。", "len": 23}
{"sid": "071_樗里子甘茂列传.9.s14", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 14, "text": "今臣之贤不若曾参，王之信臣又不如曾参之母信著参也，疑臣者非特三人，臣恐大王之投杼也。", "len": 42}
{"sid": "071_樗里子甘茂列传.9.s15", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 15, "text": "始张仪西并巴蜀之地，北开西河之外，南取上庸，天下不以多张子而以贤先王。", "len": 35}
{"sid": "071_樗里子甘茂列传.9.s16", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 16, "text": "魏文侯令乐羊将而攻中山，三年而拔之。", "len": 18}
{"sid": "071_樗里子甘茂列传.9.s17", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 17, "text": "乐羊返而论功，文侯示之谤书一箧。", "len": 16}
{"sid": "071_樗里子甘茂列传.9.s18", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 18, "text": "乐羊再拜稽首曰：‘此非臣之功也，主君之力也。", "len": 22}
{"sid": "071_樗里子甘茂列传.9.s19", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 19, "text": "’今臣，羁旅之臣也。", "len": 10}
{"sid": "071_樗里子甘茂列传.9.s20", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 20, "text": "樗里子、公孙奭二人者挟韩而议之，王必听之，是王欺魏王而臣受公仲侈之怨也。", "len": 36}
{"sid": "071_樗里子甘茂列传.9.s21", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 21, "text": "” 王曰：“寡人不听也，请与子盟。", "len": 17}
{"sid": "071_樗里子甘茂列传.9.s22", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 22, "text": "” 卒使丞相甘茂将兵伐宜阳。", "len": 14}
{"sid": "071_樗里子甘茂列传.9.s23", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 23, "text": "五月而不拔，樗里子、公孙奭果争之。", "len": 17}
{"sid": "071_樗里子甘茂列传.9.s24", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 24, "text": "武王召甘茂，欲罢兵。", "len": 10}
{"sid": "071_樗里子甘茂列传.9.s25", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 25, "text": "甘茂曰：“息壤在彼。", "len": 10}
{"sid": "071_樗里子甘茂列传.9.s26", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 26, "text": "” 王曰：“有之。", "len": 9}
{"sid": "071_樗里子甘茂列传.9.s27", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 27, "text": "” 因大悉起兵，使甘茂击之。", "len": 14}
{"sid": "071_樗里子甘茂列传.9.s28", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 28, "text": "斩首六万，遂拔宜阳。", "len": 10}
{"sid": "071_樗里子甘茂列传.9.s29", "chapter": "071_樗里子甘茂列传", "para": "9", "seq": 29, "text": "韩襄王使公仲侈入谢，与秦平。", "len": 14}
{"sid": "071_樗里子甘茂列传.10.s1", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 1, "text": "武王竟至周，而卒於周。", "len": 11}
{"sid": "071_樗里子甘茂列传.10.s2", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 2, "text": "其弟立，为昭王。", "len": 8}
{"sid": "071_樗里子甘茂列传.10.s3", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 3, "text": "王母宣太后，楚女也。", "len": 10}
{"sid": "071_樗里子甘茂列传.10.s4", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 4, "text": "楚怀王怨前秦败楚於丹阳而韩不救，乃以兵围韩雍氏。", "len": 24}
{"sid": "071_樗里子甘茂列传.10.s5", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 5, "text": "韩使公仲侈告急於秦。", "len": 10}
{"sid": "071_樗里子甘茂列传.10.s6", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 6, "text": "秦昭王新立，太后楚人，不肯救。", "len": 15}
{"sid": "071_樗里子甘茂列传.10.s7", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 7, "text": "公仲因甘茂，茂为韩言於秦昭王曰：“公仲方有得秦救，故敢扞楚也。", "len": 31}
{"sid": "071_樗里子甘茂列传.10.s8", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 8, "text": "今雍氏围，秦师不下殽，公仲且仰首而不朝，公叔且以国南合於楚。", "len": 30}
{"sid": "071_樗里子甘茂列传.10.s9", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 9, "text": "楚、韩为一，魏氏不敢不听，然则伐秦之形成矣。", "len": 22}
{"sid": "071_樗里子甘茂列传.10.s10", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 10, "text": "不识坐而待伐孰与伐人之利？", "len": 13}
{"sid": "071_樗里子甘茂列传.10.s11", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 11, "text": "” 秦王曰：“善。", "len": 9}
{"sid": "071_樗里子甘茂列传.10.s12", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 12, "text": "” 乃下师於殽以救韩。", "len": 11}
{"sid": "071_樗里子甘茂列传.10.s13", "chapter": "071_樗里子甘茂列传", "para": "10", "seq": 13, "text": "楚兵去。", "len": 4}
{"sid": "071_樗里子甘茂列传.11.s1", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 1, "text": "秦使向寿平宜阳，而使樗里子、甘茂伐魏皮氏。", "len": 21}
{"sid": "071_樗里子甘茂列传.11.s2", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 2, "text": "向寿者，宣太后外族也，而与昭王少相长，故任用。", "len": 23}
{"sid": "071_樗里子甘茂列传.11.s3", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 3, "text": "向寿如楚，楚闻秦之贵向寿，而厚事向寿。", "len": 19}
{"sid": "071_樗里子甘茂列传.11.s4", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 4, "text": "向寿为秦守宜阳，将以伐韩。", "len": 13}
{"sid": "071_樗里子甘茂列传.11.s5", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 5, "text": "韩公仲使苏代谓向寿曰：“禽困覆车。", "len": 17}
{"sid": "071_樗里子甘茂列传.11.s6", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 6, "text": "公破韩，辱公仲，公仲收国复事秦，自以为必可以封。", "len": 24}
{"sid": "071_樗里子甘茂列传.11.s7", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 7, "text": "今公与楚解口地，封小令尹以杜阳。", "len": 16}
{"sid": "071_樗里子甘茂列传.11.s8", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 8, "text": "秦楚合，复攻韩，韩必亡。", "len": 12}
{"sid": "071_樗里子甘茂列传.11.s9", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 9, "text": "韩亡，公仲且躬率其私徒以阏於秦。", "len": 16}
{"sid": "071_樗里子甘茂列传.11.s10", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 10, "text": "原公孰虑之也。", "len": 7}
{"sid": "071_樗里子甘茂列传.11.s11", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 11, "text": "” 向寿曰：“吾合秦楚非以当韩也，子为寿谒之公仲，曰秦韩之交可合也。", "len": 34}
{"sid": "071_樗里子甘茂列传.11.s12", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 12, "text": "” 苏代对曰：“原有谒於公。", "len": 14}
{"sid": "071_樗里子甘茂列传.11.s13", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 13, "text": "人曰贵其所以贵者贵。", "len": 10}
{"sid": "071_樗里子甘茂列传.11.s14", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 14, "text": "王之爱习公也，不如公孙奭；其智能公也，不如甘茂。", "len": 24}
{"sid": "071_樗里子甘茂列传.11.s15", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 15, "text": "今二人者皆不得亲於秦事，而公独与王主断於国者何？", "len": 24}
{"sid": "071_樗里子甘茂列传.11.s16", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 16, "text": "彼有以失之也。", "len": 7}
{"sid": "071_樗里子甘茂列传.11.s17", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 17, "text": "公孙奭党於韩，而甘茂党於魏，故王不信也。", "len": 20}
{"sid": "071_樗里子甘茂列传.11.s18", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 18, "text": "今秦楚争彊而公党於楚，是与公孙奭、甘茂同道也，公何以异之？", "len": 29}
{"sid": "071_樗里子甘茂列传.11.s19", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 19, "text": "人皆言楚之善变也，而公必亡之，是自为责也。", "len": 21}
{"sid": "071_樗里子甘茂列传.11.s20", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 20, "text": "公不如与王谋其变也，善韩以备楚，如此则无患矣。", "len": 23}
{"sid": "071_樗里子甘茂列传.11.s21", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 21, "text": "韩氏必先以国从公孙奭而後委国於甘茂。", "len": 18}
{"sid": "071_樗里子甘茂列传.11.s22", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 22, "text": "韩，公之雠也。", "len": 7}
{"sid": "071_樗里子甘茂列传.11.s23", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 23, "text": "今公言善韩以备楚，是外举不僻雠也。", "len": 17}
{"sid": "071_樗里子甘茂列传.11.s24", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 24, "text": "” 向寿曰：“然，吾甚欲韩合。", "len": 15}
{"sid": "071_樗里子甘茂列传.11.s25", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 25, "text": "” 对曰：“甘茂许公仲以武遂，反宜阳之民，今公徒收之，甚难。", "len": 30}
{"sid": "071_樗里子甘茂列传.11.s26", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 26, "text": "” 向寿曰：“然则奈何？", "len": 12}
{"sid": "071_樗里子甘茂列传.11.s27", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 27, "text": "武遂终不可得也？", "len": 8}
{"sid": "071_樗里子甘茂列传.11.s28", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 28, "text": "” 对曰：“公奚不以秦为韩求颍川於楚？", "len": 19}
{"sid": "071_樗里子甘茂列传.11.s29", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 29, "text": "此韩之寄地也。", "len": 7}
{"sid": "071_樗里子甘茂列传.11.s30", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 30, "text": "公求而得之，是令行於楚而以其地德韩也。", "len": 19}
{"sid": "071_樗里子甘茂列传.11.s31", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 31, "text": "公求而不得，是韩楚之怨不解而交走秦也。", "len": 19}
{"sid": "071_樗里子甘茂列传.11.s32", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 32, "text": "秦楚争彊，而公徐过楚以收韩，此利於秦。", "len": 19}
{"sid": "071_樗里子甘茂列传.11.s33", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 33, "text": "” 向寿曰：“柰何？", "len": 10}
{"sid": "071_樗里子甘茂列传.11.s34", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 34, "text": "” 对曰：“此善事也。", "len": 11}
{"sid": "071_樗里子甘茂列传.11.s35", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 35, "text": "甘茂欲以魏取齐，公孙奭欲以韩取齐。", "len": 17}
{"sid": "071_樗里子甘茂列传.11.s36", "chapter": "071_樗里子甘茂列传", "para": "11", "seq": 36, "text": "今公取宜阳以为功，收楚韩以安之，而诛齐魏之罪，是以公孙奭、甘茂无事也。”", "len": 36}
{"sid": "071_樗里子甘茂列传.12.s1", "chapter": "071_樗里子甘茂列传", "para": "12", "seq": 1, "text": "甘茂竟言秦昭王，以武遂复归之韩。", "len": 16}
{"sid": "071_樗里子甘茂列传.12.s2", "chapter": "071_樗里子甘茂列传", "para": "12", "seq": 2, "text": "向寿、公孙奭争之，不能得。", "len": 13}
{"sid": "071_樗里子甘茂列传.12.s3", "chapter": "071_樗里子甘茂列传", "para": "12", "seq": 3, "text": "向寿、公孙奭由此怨，谗甘茂。", "len": 14}
{"sid": "071_樗里子甘茂列传.12.s4", "chapter": "071_樗里子甘茂列传", "para": "12", "seq": 4, "text": "茂惧，辍伐魏蒲阪，亡去。", "len": 12}
{"sid": "071_樗里子甘茂列传.12.s5", "chapter": "071_樗里子甘茂列传", "para": "12", "seq": 5, "text": "樗里子与魏讲，罢兵。", "len": 10}
{"sid": "071_樗里子甘茂列传.13.s1", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 1, "text": "甘茂之亡秦奔齐，逢苏代。", "len": 12}
{"sid": "071_樗里子甘茂列传.13.s2", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 2, "text": "代为齐使於秦。", "len": 7}
{"sid": "071_樗里子甘茂列传.13.s3", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 3, "text": "甘茂曰：“臣得罪於秦，惧而遯逃，无所容迹。", "len": 21}
{"sid": "071_樗里子甘茂列传.13.s4", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 4, "text": "臣闻贫人女与富人女会绩，贫人女曰：‘我无以买烛，而子之烛光幸有馀，子可分我馀光，无损子明而得一斯便焉。", "len": 51}
{"sid": "071_樗里子甘茂列传.13.s5", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 5, "text": "’今臣困而君方使秦而当路矣。", "len": 14}
{"sid": "071_樗里子甘茂列传.13.s6", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 6, "text": "茂之妻子在焉，原君以馀光振之。", "len": 15}
{"sid": "071_樗里子甘茂列传.13.s7", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 7, "text": "” 苏代许诺。", "len": 7}
{"sid": "071_樗里子甘茂列传.13.s8", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 8, "text": "遂致使於秦。", "len": 6}
{"sid": "071_樗里子甘茂列传.13.s9", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 9, "text": "已，因说秦王曰：“甘茂，非常士也。", "len": 17}
{"sid": "071_樗里子甘茂列传.13.s10", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 10, "text": "其居於秦，累世重矣。", "len": 10}
{"sid": "071_樗里子甘茂列传.13.s11", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 11, "text": "自殽塞及至鬼谷，其地形险易皆明知之。", "len": 18}
{"sid": "071_樗里子甘茂列传.13.s12", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 12, "text": "彼以齐约韩魏反以图秦，非秦之利也。", "len": 17}
{"sid": "071_樗里子甘茂列传.13.s13", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 13, "text": "” 秦王曰：“然则柰何？", "len": 12}
{"sid": "071_樗里子甘茂列传.13.s14", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 14, "text": "” 苏代曰：“王不若重其贽，厚其禄以迎之，使彼来则置之鬼谷，终身勿出。", "len": 35}
{"sid": "071_樗里子甘茂列传.13.s15", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 15, "text": "” 秦王曰：“善。", "len": 9}
{"sid": "071_樗里子甘茂列传.13.s16", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 16, "text": "” 即赐之上卿，以相印迎之於齐。", "len": 16}
{"sid": "071_樗里子甘茂列传.13.s17", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 17, "text": "甘茂不往。", "len": 5}
{"sid": "071_樗里子甘茂列传.13.s18", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 18, "text": "苏代谓齐湣王曰：“夫甘茂，贤人也。", "len": 17}
{"sid": "071_樗里子甘茂列传.13.s19", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 19, "text": "今秦赐之上卿，以相印迎之。", "len": 13}
{"sid": "071_樗里子甘茂列传.13.s20", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 20, "text": "甘茂德王之赐，好为王臣，故辞而不往。", "len": 18}
{"sid": "071_樗里子甘茂列传.13.s21", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 21, "text": "今王何以礼之？", "len": 7}
{"sid": "071_樗里子甘茂列传.13.s22", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 22, "text": "” 齐王曰：“善。", "len": 9}
{"sid": "071_樗里子甘茂列传.13.s23", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 23, "text": "” 即位之上卿而处之。", "len": 11}
{"sid": "071_樗里子甘茂列传.13.s24", "chapter": "071_樗里子甘茂列传", "para": "13", "seq": 24, "text": "秦因复甘茂之家以市於齐。", "len": 12}
{"sid": "071_樗里子甘茂列传.14.s1", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 1, "text": "齐使甘茂於楚，楚怀王新与秦合婚而驩。", "len": 18}
{"sid": "071_樗里子甘茂列传.14.s2", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 2, "text": "而秦闻甘茂在楚，使人谓楚王曰：“原送甘茂於秦。", "len": 23}
{"sid": "071_樗里子甘茂列传.14.s3", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 3, "text": "” 楚王问於范蜎曰：“寡人欲置相於秦，孰可？", "len": 22}
{"sid": "071_樗里子甘茂列传.14.s4", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 4, "text": "” 对曰：“臣不足以识之。", "len": 13}
{"sid": "071_樗里子甘茂列传.14.s5", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 5, "text": "” 楚王曰：“寡人欲相甘茂，可乎？", "len": 17}
{"sid": "071_樗里子甘茂列传.14.s6", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 6, "text": "” 对曰：“不可。", "len": 9}
{"sid": "071_樗里子甘茂列传.14.s7", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 7, "text": "夫史举，下蔡之监门也，大不为事君，小不为家室，以苟贱不廉闻於世，甘茂事之顺焉。", "len": 39}
{"sid": "071_樗里子甘茂列传.14.s8", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 8, "text": "故惠王之明，武王之察，张仪之辩，而甘茂事之，取十官而无罪。", "len": 29}
{"sid": "071_樗里子甘茂列传.14.s9", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 9, "text": "茂诚贤者也，然不可相於秦。", "len": 13}
{"sid": "071_樗里子甘茂列传.14.s10", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 10, "text": "夫秦之有贤相，非楚国之利也。", "len": 14}
{"sid": "071_樗里子甘茂列传.14.s11", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 11, "text": "，且王前尝用召滑於越，而内行章义之难，越国乱，故楚南塞厉门而郡江东。", "len": 34}
{"sid": "071_樗里子甘茂列传.14.s12", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 12, "text": "计王之功所以能如此者，越国乱而楚治也。", "len": 19}
{"sid": "071_樗里子甘茂列传.14.s13", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 13, "text": "今王知用诸越而忘用诸秦，臣以王为钜过矣。", "len": 20}
{"sid": "071_樗里子甘茂列传.14.s14", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 14, "text": "然则王若欲置相於秦，则莫若向寿者可。", "len": 18}
{"sid": "071_樗里子甘茂列传.14.s15", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 15, "text": "夫向寿之於秦王，亲也，少与之同衣，长与之同车，以听事。", "len": 27}
{"sid": "071_樗里子甘茂列传.14.s16", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 16, "text": "王必相向寿於秦，则楚国之利也。", "len": 15}
{"sid": "071_樗里子甘茂列传.14.s17", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 17, "text": "” 於是使使请秦相向寿於秦。", "len": 14}
{"sid": "071_樗里子甘茂列传.14.s18", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 18, "text": "秦卒相向寿。", "len": 6}
{"sid": "071_樗里子甘茂列传.14.s19", "chapter": "071_樗里子甘茂列传", "para": "14", "seq": 19, "text": "而甘茂竟不得复入秦，卒於魏。", "len": 14}
{"sid": "071_樗里子甘茂列传.15.s1", "chapter": "071_樗里子甘茂列传", "para": "15", "seq": 1, "text": "甘茂有孙曰甘罗。", "len": 8}
{"sid": "071_樗里子甘茂列传.16.s1", "chapter": "071_樗里子甘茂列传", "para": "16", "seq": 1, "text": "甘罗者，甘茂孙也。", "len": 9}
{"sid": "071_樗里子甘茂列传.16.s2", "chapter": "071_樗里子甘茂列传", "para": "16", "seq": 2, "text": "茂既死後，甘罗年十二，事秦相文信侯吕不韦。", "len": 21}
{"sid": "071_樗里子甘茂列传.17.s1", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 1, "text": "秦始皇帝使刚成君蔡泽於燕，三年而燕王喜使太子丹入质於秦。", "len": 28}
{"sid": "071_樗里子甘茂列传.17.s2", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 2, "text": "秦使张唐往相燕，欲与燕共伐赵以广河间之地。", "len": 21}
{"sid": "071_樗里子甘茂列传.17.s3", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 3, "text": "张唐谓文信侯曰：“臣尝为秦昭王伐赵，赵怨臣，曰：‘得唐者与百里之地。", "len": 34}
{"sid": "071_樗里子甘茂列传.17.s4", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 4, "text": "’今之燕必经赵，臣不可以行。", "len": 14}
{"sid": "071_樗里子甘茂列传.17.s5", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 5, "text": "” 文信侯不快，未有以彊也。", "len": 14}
{"sid": "071_樗里子甘茂列传.17.s6", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 6, "text": "甘罗曰：“君侯何不快之甚也？", "len": 14}
{"sid": "071_樗里子甘茂列传.17.s7", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 7, "text": "” 文信侯曰：“吾令刚成君蔡泽事燕三年，燕太子丹已入质矣，吾自请张卿相燕而不肯行。", "len": 41}
{"sid": "071_樗里子甘茂列传.17.s8", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 8, "text": "” 甘罗曰：“臣请行之。", "len": 12}
{"sid": "071_樗里子甘茂列传.17.s9", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 9, "text": "” 文信侯叱曰：“去！", "len": 11}
{"sid": "071_樗里子甘茂列传.17.s10", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 10, "text": "我身自请之而不肯，女焉能行之？", "len": 15}
{"sid": "071_樗里子甘茂列传.17.s11", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 11, "text": "” 甘罗曰：“大项橐生七岁为孔子师。", "len": 18}
{"sid": "071_樗里子甘茂列传.17.s12", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 12, "text": "今臣生十二岁於兹矣，君其试臣，何遽叱乎？", "len": 20}
{"sid": "071_樗里子甘茂列传.17.s13", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 13, "text": "” 於是甘罗见张卿曰：“卿之功孰与武安君？", "len": 21}
{"sid": "071_樗里子甘茂列传.17.s14", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 14, "text": "” 卿曰：“武安君南挫彊楚，北威燕、赵，战胜攻取，破城堕邑，不知其数，臣之功不如也。", "len": 42}
{"sid": "071_樗里子甘茂列传.17.s15", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 15, "text": "” 甘罗曰：“应侯之用於秦也，孰与文信侯专？", "len": 22}
{"sid": "071_樗里子甘茂列传.17.s16", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 16, "text": "” 张卿曰：“应侯不如文信侯专。", "len": 16}
{"sid": "071_樗里子甘茂列传.17.s17", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 17, "text": "” 甘罗曰：“卿明知其不如文信侯专与？", "len": 19}
{"sid": "071_樗里子甘茂列传.17.s18", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 18, "text": "” 曰：“知之。", "len": 8}
{"sid": "071_樗里子甘茂列传.17.s19", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 19, "text": "” 甘罗曰：“应侯欲攻赵，武安君难之，去咸阳七里而立死於杜邮。", "len": 31}
{"sid": "071_樗里子甘茂列传.17.s20", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 20, "text": "今文信侯自请卿相燕而不肯行，臣不知卿所死处矣。", "len": 23}
{"sid": "071_樗里子甘茂列传.17.s21", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 21, "text": "” 张唐曰：“请因孺子行。", "len": 13}
{"sid": "071_樗里子甘茂列传.17.s22", "chapter": "071_樗里子甘茂列传", "para": "17", "seq": 22, "text": "” 令装治行。", "len": 7}
{"sid": "071_樗里子甘茂列传.18.s1", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 1, "text": "行有日，甘罗谓文信侯曰：“借臣车五乘，请为张唐先报赵。", "len": 27}
{"sid": "071_樗里子甘茂列传.18.s2", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 2, "text": "” 文信侯乃入言之於始皇曰：“昔甘茂之孙甘罗，年少耳，然名家之子孙，诸侯皆闻之。", "len": 40}
{"sid": "071_樗里子甘茂列传.18.s3", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 3, "text": "今者张唐欲称疾不肯行，甘罗说而行之。", "len": 18}
{"sid": "071_樗里子甘茂列传.18.s4", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 4, "text": "今原先报赵，请许遣之。", "len": 11}
{"sid": "071_樗里子甘茂列传.18.s5", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 5, "text": "” 始皇召见，使甘罗於赵。", "len": 13}
{"sid": "071_樗里子甘茂列传.18.s6", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 6, "text": "赵襄王郊迎甘罗。", "len": 8}
{"sid": "071_樗里子甘茂列传.18.s7", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 7, "text": "甘罗说赵王曰：“王闻燕太子丹入质秦欤？", "len": 19}
{"sid": "071_樗里子甘茂列传.18.s8", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 8, "text": "” 曰：“闻之。", "len": 8}
{"sid": "071_樗里子甘茂列传.18.s9", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 9, "text": "” 曰：“闻张唐相燕欤？", "len": 12}
{"sid": "071_樗里子甘茂列传.18.s10", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 10, "text": "” 曰：“闻之。", "len": 8}
{"sid": "071_樗里子甘茂列传.18.s11", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 11, "text": "” “燕太子丹入秦者，燕不欺秦也。", "len": 17}
{"sid": "071_樗里子甘茂列传.18.s12", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 12, "text": "张唐相燕者，秦不欺燕也。", "len": 12}
{"sid": "071_樗里子甘茂列传.18.s13", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 13, "text": "燕、秦不相欺者，伐赵，危矣。", "len": 14}
{"sid": "071_樗里子甘茂列传.18.s14", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 14, "text": "燕、秦不相欺无异故，欲攻赵而广河间。", "len": 18}
{"sid": "071_樗里子甘茂列传.18.s15", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 15, "text": "王不如赍臣五城以广河间，请归燕太子，与彊赵攻弱燕。", "len": 25}
{"sid": "071_樗里子甘茂列传.18.s16", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 16, "text": "” 赵王立自割五城以广河间。", "len": 14}
{"sid": "071_樗里子甘茂列传.18.s17", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 17, "text": "秦归燕太子。", "len": 6}
{"sid": "071_樗里子甘茂列传.18.s18", "chapter": "071_樗里子甘茂列传", "para": "18", "seq": 18, "text": "赵攻燕，得上谷三十城，令秦有十一。", "len": 17}
{"sid": "071_樗里子甘茂列传.19.s1", "chapter": "071_樗里子甘茂列传", "para": "19", "seq": 1, "text": "甘罗还报秦，乃封甘罗以为上卿，复以始甘茂田宅赐之。", "len": 25}
{"sid": "071_樗里子甘茂列传.19.s2", "chapter": "071_樗里子甘茂列传", "para": "19", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "071_樗里子甘茂列传.20.s1", "chapter": "071_樗里子甘茂列传", "para": "20", "seq": 1, "text": "太史公曰：樗里子以骨肉重，固其理，而秦人称其智，故颇采焉。", "len": 29}
{"sid": "071_樗里子甘茂列传.20.s2", "chapter": "071_樗里子甘茂列传", "para": "20", "seq": 2, "text": "甘茂起下蔡闾阎，显名诸侯，重彊齐楚。", "len": 18}
{"sid": "071_樗里子甘茂列传.20.s3", "chapter": "071_樗里子甘茂列传", "para": "20", "seq": 3, "text": "甘罗年少，然出一奇计，声称後世。", "len": 16}
{"sid": "071_樗里子甘茂列传.20.s4", "chapter": "071_樗里子甘茂列传", "para": "20", "seq": 4, "text": "虽非笃行之君子，然亦战国之策士也。", "len": 17}
{"sid": "071_樗里子甘茂列传.20.s5", "chapter": "071_樗里子甘茂列传", "para": "20", "seq": 5, "text": "方秦之彊时，天下尤趋谋诈哉 ::: ::: 赞", "len": 23}
{"sid": "071_樗里子甘茂列传.21.s1", "chapter": "071_樗里子甘茂列传", "para": "21", "seq": 1, "text": "严君名疾，厥号“智囊”。", "len": 12}
{"sid": "071_樗里子甘茂列传.21.s2", "chapter": "071_樗里子甘茂列传", "para": "21", "seq": 2, "text": "既亲且重，称兵外攘。", "len": 10}
{"sid": "071_樗里子甘茂列传.21.s3", "chapter": "071_樗里子甘茂列传", "para": "21", "seq": 3, "text": "甘茂并相，初佐魏章。", "len": 10}
{"sid": "071_樗里子甘茂列传.21.s4", "chapter": "071_樗里子甘茂列传", "para": "21", "seq": 4, "text": "始推向寿，乃攻宜阳。", "len": 10}
{"sid": "071_樗里子甘茂列传.21.s5", "chapter": "071_樗里子甘茂列传", "para": "21", "seq": 5, "text": "甘罗妙岁，卒起张唐。", "len": 10}
{"sid": "071_樗里子甘茂列传.21.s6", "chapter": "071_樗里子甘茂列传", "para": "21", "seq": 6, "text": ":::", "len": 3}
