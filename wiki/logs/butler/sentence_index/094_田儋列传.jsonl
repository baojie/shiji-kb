{"sid": "094_田儋列传.1.s1", "chapter": "094_田儋列传", "para": "1", "seq": 1, "text": "田儋者，狄人也，故齐王田氏族也。", "len": 16}
{"sid": "094_田儋列传.1.s2", "chapter": "094_田儋列传", "para": "1", "seq": 2, "text": "儋从弟田荣，荣弟田横，皆豪，宗彊，能得人。", "len": 21}
{"sid": "094_田儋列传.2.s1", "chapter": "094_田儋列传", "para": "2", "seq": 1, "text": "陈涉之初起王楚也，使周市略定魏地，北至狄，狄城守。", "len": 25}
{"sid": "094_田儋列传.2.s2", "chapter": "094_田儋列传", "para": "2", "seq": 2, "text": "田儋详为缚其奴，从少年之廷，欲谒杀奴。", "len": 19}
{"sid": "094_田儋列传.2.s3", "chapter": "094_田儋列传", "para": "2", "seq": 3, "text": "见狄令，因击杀令，而召豪吏子弟曰：“诸侯皆反秦自立，齐，古之建国，儋，田氏，当王。", "len": 41}
{"sid": "094_田儋列传.2.s4", "chapter": "094_田儋列传", "para": "2", "seq": 4, "text": "” 遂自立为齐王，发兵以击周市。", "len": 16}
{"sid": "094_田儋列传.2.s5", "chapter": "094_田儋列传", "para": "2", "seq": 5, "text": "周市军还去，田儋因率兵东略定齐地。", "len": 17}
{"sid": "094_田儋列传.3.s1", "chapter": "094_田儋列传", "para": "3", "seq": 1, "text": "秦将章邯围魏王咎於临济，急。", "len": 14}
{"sid": "094_田儋列传.3.s2", "chapter": "094_田儋列传", "para": "3", "seq": 2, "text": "魏王请救於齐，齐王田儋将兵救魏。", "len": 16}
{"sid": "094_田儋列传.3.s3", "chapter": "094_田儋列传", "para": "3", "seq": 3, "text": "章邯夜衔枚击，大破齐、魏军，杀田儋於临济下。", "len": 22}
{"sid": "094_田儋列传.3.s4", "chapter": "094_田儋列传", "para": "3", "seq": 4, "text": "儋弟田荣收儋馀兵东走东阿。", "len": 13}
{"sid": "094_田儋列传.4.s1", "chapter": "094_田儋列传", "para": "4", "seq": 1, "text": "齐人闻王田儋死，乃立故齐王建之弟田假为齐王，田角为相，田间为将，以距诸侯。", "len": 37}
{"sid": "094_田儋列传.5.s1", "chapter": "094_田儋列传", "para": "5", "seq": 1, "text": "田荣之走东阿，章邯追围之。", "len": 13}
{"sid": "094_田儋列传.5.s2", "chapter": "094_田儋列传", "para": "5", "seq": 2, "text": "项梁闻田荣之急，乃引兵击破章邯军东阿下。", "len": 20}
{"sid": "094_田儋列传.5.s3", "chapter": "094_田儋列传", "para": "5", "seq": 3, "text": "章邯走而西，项梁因追之。", "len": 12}
{"sid": "094_田儋列传.5.s4", "chapter": "094_田儋列传", "para": "5", "seq": 4, "text": "而田荣怒齐之立假，乃引兵归，击逐齐王假。", "len": 20}
{"sid": "094_田儋列传.5.s5", "chapter": "094_田儋列传", "para": "5", "seq": 5, "text": "假亡走楚。", "len": 5}
{"sid": "094_田儋列传.5.s6", "chapter": "094_田儋列传", "para": "5", "seq": 6, "text": "齐相角亡走赵；角弟田间前求救赵，因留不敢归。", "len": 22}
{"sid": "094_田儋列传.5.s7", "chapter": "094_田儋列传", "para": "5", "seq": 7, "text": "田荣乃立田儋子市为齐王。", "len": 12}
{"sid": "094_田儋列传.5.s8", "chapter": "094_田儋列传", "para": "5", "seq": 8, "text": "荣相之，田横为将，平齐地。", "len": 13}
{"sid": "094_田儋列传.6.s1", "chapter": "094_田儋列传", "para": "6", "seq": 1, "text": "项梁既追章邯，章邯兵益盛，项梁使使告赵、齐，发兵共击章邯。", "len": 29}
{"sid": "094_田儋列传.6.s2", "chapter": "094_田儋列传", "para": "6", "seq": 2, "text": "田荣曰：“使楚杀田假，赵杀田角、田间，乃肯出兵。", "len": 24}
{"sid": "094_田儋列传.6.s3", "chapter": "094_田儋列传", "para": "6", "seq": 3, "text": "” 楚怀王曰：“田假与国之王，穷而归我，杀之不义。", "len": 25}
{"sid": "094_田儋列传.6.s4", "chapter": "094_田儋列传", "para": "6", "seq": 4, "text": "” 赵亦不杀田角、田间以市於齐。", "len": 16}
{"sid": "094_田儋列传.6.s5", "chapter": "094_田儋列传", "para": "6", "seq": 5, "text": "齐曰：“蝮螫手则斩手，螫足则斩足。", "len": 17}
{"sid": "094_田儋列传.6.s6", "chapter": "094_田儋列传", "para": "6", "seq": 6, "text": "何者？", "len": 3}
{"sid": "094_田儋列传.6.s7", "chapter": "094_田儋列传", "para": "6", "seq": 7, "text": "为害於身也。", "len": 6}
{"sid": "094_田儋列传.6.s8", "chapter": "094_田儋列传", "para": "6", "seq": 8, "text": "今田假、田角、田间於楚、赵，非直手足戚也，何故不杀？", "len": 26}
{"sid": "094_田儋列传.6.s9", "chapter": "094_田儋列传", "para": "6", "seq": 9, "text": "且秦复得志於天下，则齮龁用事者坟墓矣。", "len": 19}
{"sid": "094_田儋列传.6.s10", "chapter": "094_田儋列传", "para": "6", "seq": 10, "text": "” 楚、赵不听，齐亦怒，终不肯出兵。", "len": 18}
{"sid": "094_田儋列传.6.s11", "chapter": "094_田儋列传", "para": "6", "seq": 11, "text": "章邯果败杀项梁，破楚兵，楚兵东走，而章邯渡河围赵於钜鹿。", "len": 28}
{"sid": "094_田儋列传.6.s12", "chapter": "094_田儋列传", "para": "6", "seq": 12, "text": "项羽往救赵，由此怨田荣。", "len": 12}
{"sid": "094_田儋列传.7.s1", "chapter": "094_田儋列传", "para": "7", "seq": 1, "text": "项羽既存赵，降章邯等，西屠咸阳，灭秦而立侯王也，乃徙齐王田市更王胶东，治即墨。", "len": 39}
{"sid": "094_田儋列传.7.s2", "chapter": "094_田儋列传", "para": "7", "seq": 2, "text": "齐将田都从共救赵，因入关，故立都为齐王，治临淄。", "len": 24}
{"sid": "094_田儋列传.7.s3", "chapter": "094_田儋列传", "para": "7", "seq": 3, "text": "故齐王建孙田安，项羽方渡河救赵，田安下济北数城，引兵降项羽，项羽立田安为济北王，治博阳。", "len": 44}
{"sid": "094_田儋列传.7.s4", "chapter": "094_田儋列传", "para": "7", "seq": 4, "text": "田荣以负项梁不肯出兵助楚、赵攻秦，故不得王；赵将陈馀亦失职，不得王：二人俱怨项王。", "len": 41}
{"sid": "094_田儋列传.8.s1", "chapter": "094_田儋列传", "para": "8", "seq": 1, "text": "项王既归，诸侯各就国，田荣使人将兵助陈馀，令反赵地，而荣亦发兵以距击田都，田都亡走楚。", "len": 43}
{"sid": "094_田儋列传.8.s2", "chapter": "094_田儋列传", "para": "8", "seq": 2, "text": "田荣留齐王市，无令之胶东。", "len": 13}
{"sid": "094_田儋列传.8.s3", "chapter": "094_田儋列传", "para": "8", "seq": 3, "text": "市之左右曰：“项王彊暴，而王当之胶东，不就国，必危。", "len": 26}
{"sid": "094_田儋列传.8.s4", "chapter": "094_田儋列传", "para": "8", "seq": 4, "text": "” 市惧，乃亡就国。", "len": 10}
{"sid": "094_田儋列传.8.s5", "chapter": "094_田儋列传", "para": "8", "seq": 5, "text": "田荣怒，追击杀齐王市於即墨，还攻杀济北王安。", "len": 22}
{"sid": "094_田儋列传.8.s6", "chapter": "094_田儋列传", "para": "8", "seq": 6, "text": "於是田荣乃自立为齐王，尽并三齐之地。", "len": 18}
{"sid": "094_田儋列传.9.s1", "chapter": "094_田儋列传", "para": "9", "seq": 1, "text": "项王闻之，大怒，乃北伐齐。", "len": 13}
{"sid": "094_田儋列传.9.s2", "chapter": "094_田儋列传", "para": "9", "seq": 2, "text": "齐王田荣兵败，走平原，平原人杀荣。", "len": 17}
{"sid": "094_田儋列传.9.s3", "chapter": "094_田儋列传", "para": "9", "seq": 3, "text": "项王遂烧夷齐城郭，所过者尽屠之。", "len": 16}
{"sid": "094_田儋列传.9.s4", "chapter": "094_田儋列传", "para": "9", "seq": 4, "text": "齐人相聚畔之。", "len": 7}
{"sid": "094_田儋列传.9.s5", "chapter": "094_田儋列传", "para": "9", "seq": 5, "text": "荣弟横，收齐散兵，得数万人，反击项羽於城阳。", "len": 22}
{"sid": "094_田儋列传.9.s6", "chapter": "094_田儋列传", "para": "9", "seq": 6, "text": "而汉王率诸侯败楚，入彭城。", "len": 13}
{"sid": "094_田儋列传.9.s7", "chapter": "094_田儋列传", "para": "9", "seq": 7, "text": "项羽闻之，乃醳齐而归，击汉於彭城，因连与汉战，相距荥阳。", "len": 28}
{"sid": "094_田儋列传.9.s8", "chapter": "094_田儋列传", "para": "9", "seq": 8, "text": "以故田横复得收齐城邑，立田荣子广为齐王，而横相之，专国政，政无巨细皆断於相。", "len": 38}
{"sid": "094_田儋列传.10.s1", "chapter": "094_田儋列传", "para": "10", "seq": 1, "text": "横定齐三年，汉王使郦生往说下齐王广及其相国横。", "len": 23}
{"sid": "094_田儋列传.10.s2", "chapter": "094_田儋列传", "para": "10", "seq": 2, "text": "横以为然，解其历下军。", "len": 11}
{"sid": "094_田儋列传.10.s3", "chapter": "094_田儋列传", "para": "10", "seq": 3, "text": "汉将韩信引兵且东击齐。", "len": 11}
{"sid": "094_田儋列传.10.s4", "chapter": "094_田儋列传", "para": "10", "seq": 4, "text": "齐初使华无伤、田解军於历下以距汉，汉使至，乃罢守战备，纵酒，且遣使与汉平。", "len": 37}
{"sid": "094_田儋列传.10.s5", "chapter": "094_田儋列传", "para": "10", "seq": 5, "text": "汉将韩信已平赵、燕，用蒯通计，度平原，袭破齐历下军，因入临淄。", "len": 31}
{"sid": "094_田儋列传.10.s6", "chapter": "094_田儋列传", "para": "10", "seq": 6, "text": "齐王广、相横怒，以郦生卖己，而亨郦生。", "len": 19}
{"sid": "094_田儋列传.10.s7", "chapter": "094_田儋列传", "para": "10", "seq": 7, "text": "齐王广东走高密，相横走博，守相田光走城阳，将军田既军於胶东。", "len": 30}
{"sid": "094_田儋列传.10.s8", "chapter": "094_田儋列传", "para": "10", "seq": 8, "text": "楚使龙且救齐，齐王与合军高密。", "len": 15}
{"sid": "094_田儋列传.10.s9", "chapter": "094_田儋列传", "para": "10", "seq": 9, "text": "汉将韩信与曹参破杀龙且，虏齐王广。", "len": 17}
{"sid": "094_田儋列传.10.s10", "chapter": "094_田儋列传", "para": "10", "seq": 10, "text": "汉将灌婴追得齐守相田光。", "len": 12}
{"sid": "094_田儋列传.10.s11", "chapter": "094_田儋列传", "para": "10", "seq": 11, "text": "至博，而横闻齐王死，自立为齐王，还击婴，婴败横之军於嬴下。", "len": 29}
{"sid": "094_田儋列传.10.s12", "chapter": "094_田儋列传", "para": "10", "seq": 12, "text": "田横亡走梁，归彭越。", "len": 10}
{"sid": "094_田儋列传.10.s13", "chapter": "094_田儋列传", "para": "10", "seq": 13, "text": "彭越是时居梁地，中立，且为汉，且为楚。", "len": 19}
{"sid": "094_田儋列传.10.s14", "chapter": "094_田儋列传", "para": "10", "seq": 14, "text": "韩信已杀龙且，因令曹参进兵破杀田既於胶东，使灌婴破杀齐将田吸於千乘。", "len": 34}
{"sid": "094_田儋列传.10.s15", "chapter": "094_田儋列传", "para": "10", "seq": 15, "text": "韩信遂平齐，乞自立为齐假王，汉因而立之。", "len": 20}
{"sid": "094_田儋列传.11.s1", "chapter": "094_田儋列传", "para": "11", "seq": 1, "text": "後岁馀，汉灭项籍，汉王立为皇帝，以彭越为梁王。", "len": 23}
{"sid": "094_田儋列传.11.s2", "chapter": "094_田儋列传", "para": "11", "seq": 2, "text": "田横惧诛，而与其徒属五百馀人入海，居岛中。", "len": 21}
{"sid": "094_田儋列传.11.s3", "chapter": "094_田儋列传", "para": "11", "seq": 3, "text": "高帝闻之，以为田横兄弟本定齐，齐人贤者多附焉，今在海中不收，後恐为乱，乃使使赦田横罪而召之。", "len": 46}
{"sid": "094_田儋列传.11.s4", "chapter": "094_田儋列传", "para": "11", "seq": 4, "text": "田横因谢曰：“臣亨陛下之使郦生，今闻其弟郦商为汉将而贤，臣恐惧，不敢奉诏，请为庶人，守海岛中。", "len": 47}
{"sid": "094_田儋列传.11.s5", "chapter": "094_田儋列传", "para": "11", "seq": 5, "text": "” 使还报，高皇帝乃诏卫尉郦商曰：“齐王田横即至，人马从者敢动摇者致族夷！", "len": 37}
{"sid": "094_田儋列传.11.s6", "chapter": "094_田儋列传", "para": "11", "seq": 6, "text": "” 乃复使使持节具告以诏商状，曰：“田横来，大者王，小者乃侯耳；不来，且举兵加诛焉。", "len": 42}
{"sid": "094_田儋列传.11.s7", "chapter": "094_田儋列传", "para": "11", "seq": 7, "text": "” 田横乃与其客二人乘传诣雒阳。", "len": 16}
{"sid": "094_田儋列传.12.s1", "chapter": "094_田儋列传", "para": "12", "seq": 1, "text": "未至三十里，至尸乡厩置，横谢使者曰：“人臣见天子当洗沐。", "len": 28}
{"sid": "094_田儋列传.12.s2", "chapter": "094_田儋列传", "para": "12", "seq": 2, "text": "” 止留。", "len": 5}
{"sid": "094_田儋列传.12.s3", "chapter": "094_田儋列传", "para": "12", "seq": 3, "text": "谓其客曰：“横始与汉王俱南面称孤，今汉王为天子，而横乃为亡虏而北面事之，其耻固已甚矣。", "len": 43}
{"sid": "094_田儋列传.12.s4", "chapter": "094_田儋列传", "para": "12", "seq": 4, "text": "且吾亨人之兄，与其弟并肩而事其主，纵彼畏天子之诏，不敢动我，我独不愧於心乎？", "len": 38}
{"sid": "094_田儋列传.12.s5", "chapter": "094_田儋列传", "para": "12", "seq": 5, "text": "且陛下所以欲见我者，不过欲一见吾面貌耳。", "len": 20}
{"sid": "094_田儋列传.12.s6", "chapter": "094_田儋列传", "para": "12", "seq": 6, "text": "今陛下在洛阳，今斩吾头，驰三十里间，形容尚未能败，犹可观也。", "len": 30}
{"sid": "094_田儋列传.12.s7", "chapter": "094_田儋列传", "para": "12", "seq": 7, "text": "” 遂自刭，令客奉其头，从使者驰奏之高帝。", "len": 21}
{"sid": "094_田儋列传.12.s8", "chapter": "094_田儋列传", "para": "12", "seq": 8, "text": "高帝曰：“嗟乎，有以也夫！", "len": 13}
{"sid": "094_田儋列传.12.s9", "chapter": "094_田儋列传", "para": "12", "seq": 9, "text": "起自布衣，兄弟三人更王，岂不贤乎哉！", "len": 18}
{"sid": "094_田儋列传.12.s10", "chapter": "094_田儋列传", "para": "12", "seq": 10, "text": "” 为之流涕，而拜其二客为都尉，发卒二千人，以王者礼葬田横。", "len": 30}
{"sid": "094_田儋列传.13.s1", "chapter": "094_田儋列传", "para": "13", "seq": 1, "text": "既葬，二客穿其冢旁孔，皆自刭，下从之。", "len": 19}
{"sid": "094_田儋列传.13.s2", "chapter": "094_田儋列传", "para": "13", "seq": 2, "text": "高帝闻之，乃大惊，大田横之客皆贤。", "len": 17}
{"sid": "094_田儋列传.13.s3", "chapter": "094_田儋列传", "para": "13", "seq": 3, "text": "吾闻其馀尚五百人在海中，使使召之。", "len": 17}
{"sid": "094_田儋列传.13.s4", "chapter": "094_田儋列传", "para": "13", "seq": 4, "text": "至则闻田横死，亦皆自杀。", "len": 12}
{"sid": "094_田儋列传.13.s5", "chapter": "094_田儋列传", "para": "13", "seq": 5, "text": "於是乃知田横兄弟能得士也。", "len": 13}
{"sid": "094_田儋列传.13.s6", "chapter": "094_田儋列传", "para": "13", "seq": 6, "text": "::: 太史公曰", "len": 8}
{"sid": "094_田儋列传.14.s1", "chapter": "094_田儋列传", "para": "14", "seq": 1, "text": "太史公曰：甚矣蒯通之谋，乱齐骄淮阴，其卒亡此两人！", "len": 25}
{"sid": "094_田儋列传.14.s2", "chapter": "094_田儋列传", "para": "14", "seq": 2, "text": "蒯通者，善为长短说，论战国之权变，为八十一首。", "len": 23}
{"sid": "094_田儋列传.14.s3", "chapter": "094_田儋列传", "para": "14", "seq": 3, "text": "通善齐人安期生，安期生尝干项羽，项羽不能用其筴。", "len": 24}
{"sid": "094_田儋列传.14.s4", "chapter": "094_田儋列传", "para": "14", "seq": 4, "text": "已而项羽欲封此两人，两人终不肯受，亡去。", "len": 20}
{"sid": "094_田儋列传.14.s5", "chapter": "094_田儋列传", "para": "14", "seq": 5, "text": "田横之高节，宾客慕义而从横死，岂非至贤！", "len": 20}
{"sid": "094_田儋列传.14.s6", "chapter": "094_田儋列传", "para": "14", "seq": 6, "text": "余因而列焉。", "len": 6}
{"sid": "094_田儋列传.14.s7", "chapter": "094_田儋列传", "para": "14", "seq": 7, "text": "不无善画者，莫能图，何哉？", "len": 13}
{"sid": "094_田儋列传.14.s8", "chapter": "094_田儋列传", "para": "14", "seq": 8, "text": "::: ::: 赞", "len": 9}
{"sid": "094_田儋列传.15.s1", "chapter": "094_田儋列传", "para": "15", "seq": 1, "text": "秦项之际，天下交兵。", "len": 10}
{"sid": "094_田儋列传.15.s2", "chapter": "094_田儋列传", "para": "15", "seq": 2, "text": "六国树党，自置豪英。", "len": 10}
{"sid": "094_田儋列传.15.s3", "chapter": "094_田儋列传", "para": "15", "seq": 3, "text": "田儋殒寇，立市相荣。", "len": 10}
{"sid": "094_田儋列传.15.s4", "chapter": "094_田儋列传", "para": "15", "seq": 4, "text": "楚封王假，齐破郦生。", "len": 10}
{"sid": "094_田儋列传.15.s5", "chapter": "094_田儋列传", "para": "15", "seq": 5, "text": "兄弟更王，海岛传声。", "len": 10}
{"sid": "094_田儋列传.15.s6", "chapter": "094_田儋列传", "para": "15", "seq": 6, "text": ":::", "len": 3}
