{"sid": "101_袁盎晁错列传.1.s1", "chapter": "101_袁盎晁错列传", "para": "1", "seq": 1, "text": "袁盎者，楚人也，字丝。", "len": 11}
{"sid": "101_袁盎晁错列传.2.s1", "chapter": "101_袁盎晁错列传", "para": "2", "seq": 1, "text": "父故为群盗，徙处安陵。", "len": 11}
{"sid": "101_袁盎晁错列传.3.s1", "chapter": "101_袁盎晁错列传", "para": "3", "seq": 1, "text": "高后时，盎尝为吕禄舍人。", "len": 12}
{"sid": "101_袁盎晁错列传.4.s1", "chapter": "101_袁盎晁错列传", "para": "4", "seq": 1, "text": "及孝文帝即位，盎兄哙任盎为中郎。", "len": 16}
{"sid": "101_袁盎晁错列传.5.s1", "chapter": "101_袁盎晁错列传", "para": "5", "seq": 1, "text": "绛侯为丞相，朝罢趋出，意得甚。", "len": 15}
{"sid": "101_袁盎晁错列传.6.s1", "chapter": "101_袁盎晁错列传", "para": "6", "seq": 1, "text": "上礼之恭，常自送之。", "len": 10}
{"sid": "101_袁盎晁错列传.7.s1", "chapter": "101_袁盎晁错列传", "para": "7", "seq": 1, "text": "袁盎进曰： “陛下以丞相何如人？”", "len": 17}
{"sid": "101_袁盎晁错列传.8.s1", "chapter": "101_袁盎晁错列传", "para": "8", "seq": 1, "text": "上曰： “社稷臣。”", "len": 10}
{"sid": "101_袁盎晁错列传.9.s1", "chapter": "101_袁盎晁错列传", "para": "9", "seq": 1, "text": "盎曰： ::: 袁盎论社稷臣与功臣之别", "len": 19}
{"sid": "101_袁盎晁错列传.10.s1", "chapter": "101_袁盎晁错列传", "para": "10", "seq": 1, "text": "“绛侯所谓功臣，非社稷臣，社稷臣主在与在，主亡与亡。", "len": 26}
{"sid": "101_袁盎晁错列传.10.s2", "chapter": "101_袁盎晁错列传", "para": "10", "seq": 2, "text": "方吕后时，诸吕用事，擅相王，刘氏不绝如带。", "len": 21}
{"sid": "101_袁盎晁错列传.10.s3", "chapter": "101_袁盎晁错列传", "para": "10", "seq": 3, "text": "是时绛侯为太尉，主兵柄，弗能正。", "len": 16}
{"sid": "101_袁盎晁错列传.10.s4", "chapter": "101_袁盎晁错列传", "para": "10", "seq": 4, "text": "吕后崩，大臣相与共畔诸吕，太尉主兵，適会其成功，所谓功臣，非社稷臣。", "len": 34}
{"sid": "101_袁盎晁错列传.10.s5", "chapter": "101_袁盎晁错列传", "para": "10", "seq": 5, "text": "丞相如有骄主色。", "len": 8}
{"sid": "101_袁盎晁错列传.10.s6", "chapter": "101_袁盎晁错列传", "para": "10", "seq": 6, "text": "陛下谦让，臣主失礼，窃为陛下不取也。", "len": 18}
{"sid": "101_袁盎晁错列传.10.s7", "chapter": "101_袁盎晁错列传", "para": "10", "seq": 7, "text": "” :::", "len": 5}
{"sid": "101_袁盎晁错列传.11.s1", "chapter": "101_袁盎晁错列传", "para": "11", "seq": 1, "text": "後朝，上益庄，丞相益畏。", "len": 12}
{"sid": "101_袁盎晁错列传.12.s1", "chapter": "101_袁盎晁错列传", "para": "12", "seq": 1, "text": "已而绛侯望袁盎曰： “吾与而兄善，今兒廷毁我！”", "len": 24}
{"sid": "101_袁盎晁错列传.13.s1", "chapter": "101_袁盎晁错列传", "para": "13", "seq": 1, "text": "盎遂不谢。", "len": 5}
{"sid": "101_袁盎晁错列传.14.s1", "chapter": "101_袁盎晁错列传", "para": "14", "seq": 1, "text": "及绛侯免相之国，国人上书告以为反，徵系清室，宗室诸公莫敢为言，唯袁盎明绛侯无罪。", "len": 40}
{"sid": "101_袁盎晁错列传.15.s1", "chapter": "101_袁盎晁错列传", "para": "15", "seq": 1, "text": "绛侯得释，盎颇有力。", "len": 10}
{"sid": "101_袁盎晁错列传.16.s1", "chapter": "101_袁盎晁错列传", "para": "16", "seq": 1, "text": "绛侯乃大与盎结交。", "len": 9}
{"sid": "101_袁盎晁错列传.17.s1", "chapter": "101_袁盎晁错列传", "para": "17", "seq": 1, "text": "淮南厉王朝，杀辟阳侯，居处骄甚。", "len": 16}
{"sid": "101_袁盎晁错列传.18.s1", "chapter": "101_袁盎晁错列传", "para": "18", "seq": 1, "text": "袁盎谏曰： “诸侯大骄必生患，可適削地。”", "len": 21}
{"sid": "101_袁盎晁错列传.19.s1", "chapter": "101_袁盎晁错列传", "para": "19", "seq": 1, "text": "上弗用。", "len": 4}
{"sid": "101_袁盎晁错列传.19.s2", "chapter": "101_袁盎晁错列传", "para": "19", "seq": 2, "text": "淮南王益横。", "len": 6}
{"sid": "101_袁盎晁错列传.20.s1", "chapter": "101_袁盎晁错列传", "para": "20", "seq": 1, "text": "及棘蒲侯柴武太子谋反事觉，治，连淮南王，淮南王徵，上因迁之蜀，轞车传送。", "len": 36}
{"sid": "101_袁盎晁错列传.21.s1", "chapter": "101_袁盎晁错列传", "para": "21", "seq": 1, "text": "袁盎时为中郎将，乃谏曰： ::: 袁盎谏迁淮南王", "len": 24}
{"sid": "101_袁盎晁错列传.22.s1", "chapter": "101_袁盎晁错列传", "para": "22", "seq": 1, "text": "“陛下素骄淮南王，弗稍禁，以至此，今又暴摧折之。", "len": 24}
{"sid": "101_袁盎晁错列传.22.s2", "chapter": "101_袁盎晁错列传", "para": "22", "seq": 2, "text": "淮南王为人刚，如有遇雾露行道死，陛下竟为以天下之大弗能容，有杀弟之名，柰何？", "len": 38}
{"sid": "101_袁盎晁错列传.22.s3", "chapter": "101_袁盎晁错列传", "para": "22", "seq": 3, "text": "” :::", "len": 5}
{"sid": "101_袁盎晁错列传.23.s1", "chapter": "101_袁盎晁错列传", "para": "23", "seq": 1, "text": "上弗听，遂行之。", "len": 8}
{"sid": "101_袁盎晁错列传.24.s1", "chapter": "101_袁盎晁错列传", "para": "24", "seq": 1, "text": "淮南王至雍，病死，闻，上辍食，哭甚哀。", "len": 19}
{"sid": "101_袁盎晁错列传.25.s1", "chapter": "101_袁盎晁错列传", "para": "25", "seq": 1, "text": "盎入，顿首请罪。", "len": 8}
{"sid": "101_袁盎晁错列传.26.s1", "chapter": "101_袁盎晁错列传", "para": "26", "seq": 1, "text": "上曰： “以不用公言至此。”", "len": 14}
{"sid": "101_袁盎晁错列传.27.s1", "chapter": "101_袁盎晁错列传", "para": "27", "seq": 1, "text": "盎曰： “上自宽，此往事，岂可悔哉！", "len": 18}
{"sid": "101_袁盎晁错列传.27.s2", "chapter": "101_袁盎晁错列传", "para": "27", "seq": 2, "text": "且陛下有高世之行者三，此不足以毁名。”", "len": 19}
{"sid": "101_袁盎晁错列传.28.s1", "chapter": "101_袁盎晁错列传", "para": "28", "seq": 1, "text": "上曰： “吾高世行三者何事？”", "len": 15}
{"sid": "101_袁盎晁错列传.29.s1", "chapter": "101_袁盎晁错列传", "para": "29", "seq": 1, "text": "盎曰： ::: 袁盎论文帝三高世行", "len": 17}
{"sid": "101_袁盎晁错列传.30.s1", "chapter": "101_袁盎晁错列传", "para": "30", "seq": 1, "text": "“陛下居代时，太后尝病，三年，陛下不交睫，不解衣，汤药非陛下口所尝弗进。", "len": 36}
{"sid": "101_袁盎晁错列传.30.s2", "chapter": "101_袁盎晁错列传", "para": "30", "seq": 2, "text": "夫曾参以布衣犹难之，今陛下亲以王者脩之，过曾参孝远矣。", "len": 27}
{"sid": "101_袁盎晁错列传.30.s3", "chapter": "101_袁盎晁错列传", "para": "30", "seq": 3, "text": "夫诸吕用事，大臣专制，然陛下从代乘六传驰不测之渊，虽贲育之勇不及陛下。", "len": 35}
{"sid": "101_袁盎晁错列传.30.s4", "chapter": "101_袁盎晁错列传", "para": "30", "seq": 4, "text": "陛下至代邸，西向让天子位者再，南面让天子位者三。", "len": 24}
{"sid": "101_袁盎晁错列传.30.s5", "chapter": "101_袁盎晁错列传", "para": "30", "seq": 5, "text": "夫许由一让，而陛下五以天下让，过许由四矣。", "len": 21}
{"sid": "101_袁盎晁错列传.30.s6", "chapter": "101_袁盎晁错列传", "para": "30", "seq": 6, "text": "且陛下迁淮南王，欲以苦其志，使改过，有司卫不谨，故病死。", "len": 28}
{"sid": "101_袁盎晁错列传.30.s7", "chapter": "101_袁盎晁错列传", "para": "30", "seq": 7, "text": "” :::", "len": 5}
{"sid": "101_袁盎晁错列传.31.s1", "chapter": "101_袁盎晁错列传", "para": "31", "seq": 1, "text": "於是上乃解，曰： “将柰何？”", "len": 15}
{"sid": "101_袁盎晁错列传.32.s1", "chapter": "101_袁盎晁错列传", "para": "32", "seq": 1, "text": "盎曰： “淮南王有三子，唯在陛下耳。”", "len": 19}
{"sid": "101_袁盎晁错列传.33.s1", "chapter": "101_袁盎晁错列传", "para": "33", "seq": 1, "text": "於是文帝立其三子皆为王。", "len": 12}
{"sid": "101_袁盎晁错列传.34.s1", "chapter": "101_袁盎晁错列传", "para": "34", "seq": 1, "text": "盎由此名重朝廷。", "len": 8}
{"sid": "101_袁盎晁错列传.35.s1", "chapter": "101_袁盎晁错列传", "para": "35", "seq": 1, "text": "袁盎常引大体慷慨。", "len": 9}
{"sid": "101_袁盎晁错列传.36.s1", "chapter": "101_袁盎晁错列传", "para": "36", "seq": 1, "text": "宦者赵同以数幸，常害袁盎，袁盎患之。", "len": 18}
{"sid": "101_袁盎晁错列传.37.s1", "chapter": "101_袁盎晁错列传", "para": "37", "seq": 1, "text": "盎兄子种为常侍骑，持节夹乘，说盎曰： “君与斗，廷辱之，使其毁不用。”", "len": 35}
{"sid": "101_袁盎晁错列传.38.s1", "chapter": "101_袁盎晁错列传", "para": "38", "seq": 1, "text": "孝文帝出，赵同参乘，袁盎伏车前曰： “臣闻天子所与共六尺舆者，皆天下豪英。", "len": 37}
{"sid": "101_袁盎晁错列传.38.s2", "chapter": "101_袁盎晁错列传", "para": "38", "seq": 2, "text": "今汉虽乏人，陛下独奈何与刀锯馀人载！”", "len": 19}
{"sid": "101_袁盎晁错列传.39.s1", "chapter": "101_袁盎晁错列传", "para": "39", "seq": 1, "text": "於是上笑，下赵同。", "len": 9}
{"sid": "101_袁盎晁错列传.39.s2", "chapter": "101_袁盎晁错列传", "para": "39", "seq": 2, "text": "赵同泣下车。", "len": 6}
{"sid": "101_袁盎晁错列传.40.s1", "chapter": "101_袁盎晁错列传", "para": "40", "seq": 1, "text": "文帝从霸陵上，欲西驰下峻阪。", "len": 14}
{"sid": "101_袁盎晁错列传.41.s1", "chapter": "101_袁盎晁错列传", "para": "41", "seq": 1, "text": "袁盎骑，并车揽辔。", "len": 9}
{"sid": "101_袁盎晁错列传.42.s1", "chapter": "101_袁盎晁错列传", "para": "42", "seq": 1, "text": "上曰： “将军怯邪？”", "len": 11}
{"sid": "101_袁盎晁错列传.43.s1", "chapter": "101_袁盎晁错列传", "para": "43", "seq": 1, "text": "盎曰： “臣闻千金之子坐不垂堂，百金之子不骑衡，圣主不乘危而徼幸。", "len": 33}
{"sid": "101_袁盎晁错列传.43.s2", "chapter": "101_袁盎晁错列传", "para": "43", "seq": 2, "text": "今陛下骋六騑，驰下峻山，如有马惊车败，陛下纵自轻，柰高庙、太后何？”", "len": 34}
{"sid": "101_袁盎晁错列传.44.s1", "chapter": "101_袁盎晁错列传", "para": "44", "seq": 1, "text": "上乃止。", "len": 4}
{"sid": "101_袁盎晁错列传.45.s1", "chapter": "101_袁盎晁错列传", "para": "45", "seq": 1, "text": "上幸上林，皇后、慎夫人从。", "len": 13}
{"sid": "101_袁盎晁错列传.46.s1", "chapter": "101_袁盎晁错列传", "para": "46", "seq": 1, "text": "其在禁中，常同席坐。", "len": 10}
{"sid": "101_袁盎晁错列传.47.s1", "chapter": "101_袁盎晁错列传", "para": "47", "seq": 1, "text": "及坐，郎署长布席，袁盎引卻慎夫人坐。", "len": 18}
{"sid": "101_袁盎晁错列传.48.s1", "chapter": "101_袁盎晁错列传", "para": "48", "seq": 1, "text": "慎夫人怒，不肯坐。", "len": 9}
{"sid": "101_袁盎晁错列传.48.s2", "chapter": "101_袁盎晁错列传", "para": "48", "seq": 2, "text": "上亦怒，起，入禁中。", "len": 10}
{"sid": "101_袁盎晁错列传.49.s1", "chapter": "101_袁盎晁错列传", "para": "49", "seq": 1, "text": "盎因前说曰： ::: 袁盎论尊卑之序", "len": 18}
{"sid": "101_袁盎晁错列传.50.s1", "chapter": "101_袁盎晁错列传", "para": "50", "seq": 1, "text": "“臣闻尊卑有序则上下和。", "len": 12}
{"sid": "101_袁盎晁错列传.50.s2", "chapter": "101_袁盎晁错列传", "para": "50", "seq": 2, "text": "今陛下既已立后，慎夫人乃妾，妾主岂可与同坐哉！", "len": 23}
{"sid": "101_袁盎晁错列传.50.s3", "chapter": "101_袁盎晁错列传", "para": "50", "seq": 3, "text": "適所以失尊卑矣。", "len": 8}
{"sid": "101_袁盎晁错列传.50.s4", "chapter": "101_袁盎晁错列传", "para": "50", "seq": 4, "text": "且陛下幸之，即厚赐之。", "len": 11}
{"sid": "101_袁盎晁错列传.50.s5", "chapter": "101_袁盎晁错列传", "para": "50", "seq": 5, "text": "陛下所以为慎夫人，適所以祸之。", "len": 15}
{"sid": "101_袁盎晁错列传.50.s6", "chapter": "101_袁盎晁错列传", "para": "50", "seq": 6, "text": "陛下独不见‘人彘’乎？", "len": 11}
{"sid": "101_袁盎晁错列传.50.s7", "chapter": "101_袁盎晁错列传", "para": "50", "seq": 7, "text": "” :::", "len": 5}
{"sid": "101_袁盎晁错列传.51.s1", "chapter": "101_袁盎晁错列传", "para": "51", "seq": 1, "text": "於是上乃说，召语慎夫人。", "len": 12}
{"sid": "101_袁盎晁错列传.52.s1", "chapter": "101_袁盎晁错列传", "para": "52", "seq": 1, "text": "慎夫人赐盎金五十斤。", "len": 10}
{"sid": "101_袁盎晁错列传.53.s1", "chapter": "101_袁盎晁错列传", "para": "53", "seq": 1, "text": "然袁盎亦以数直谏，不得久居中，调为陇西都尉。", "len": 22}
{"sid": "101_袁盎晁错列传.54.s1", "chapter": "101_袁盎晁错列传", "para": "54", "seq": 1, "text": "仁爱士卒，士卒皆争为死。", "len": 12}
{"sid": "101_袁盎晁错列传.55.s1", "chapter": "101_袁盎晁错列传", "para": "55", "seq": 1, "text": "迁为齐相。", "len": 5}
{"sid": "101_袁盎晁错列传.56.s1", "chapter": "101_袁盎晁错列传", "para": "56", "seq": 1, "text": "徙为吴相，辞行，种谓盎曰： ::: 袁种教盎为吴相之策", "len": 27}
{"sid": "101_袁盎晁错列传.57.s1", "chapter": "101_袁盎晁错列传", "para": "57", "seq": 1, "text": "“吴王骄日久，国多奸。", "len": 11}
{"sid": "101_袁盎晁错列传.57.s2", "chapter": "101_袁盎晁错列传", "para": "57", "seq": 2, "text": "今苟欲劾治，彼不上书告君，即利剑刺君矣。", "len": 20}
{"sid": "101_袁盎晁错列传.57.s3", "chapter": "101_袁盎晁错列传", "para": "57", "seq": 3, "text": "南方卑湿，君能日饮，毋何，时说王曰毋反而已。", "len": 22}
{"sid": "101_袁盎晁错列传.57.s4", "chapter": "101_袁盎晁错列传", "para": "57", "seq": 4, "text": "如此幸得脱。", "len": 6}
{"sid": "101_袁盎晁错列传.57.s5", "chapter": "101_袁盎晁错列传", "para": "57", "seq": 5, "text": "” :::", "len": 5}
{"sid": "101_袁盎晁错列传.58.s1", "chapter": "101_袁盎晁错列传", "para": "58", "seq": 1, "text": "盎用种之计，吴王厚遇盎。", "len": 12}
{"sid": "101_袁盎晁错列传.59.s1", "chapter": "101_袁盎晁错列传", "para": "59", "seq": 1, "text": "盎告归，道逢丞相申屠嘉，下车拜谒，丞相从车上谢袁盎。", "len": 26}
{"sid": "101_袁盎晁错列传.60.s1", "chapter": "101_袁盎晁错列传", "para": "60", "seq": 1, "text": "袁盎还，愧其吏，乃之丞相舍上谒，求见丞相。", "len": 21}
{"sid": "101_袁盎晁错列传.61.s1", "chapter": "101_袁盎晁错列传", "para": "61", "seq": 1, "text": "丞相良久而见之。", "len": 8}
{"sid": "101_袁盎晁错列传.62.s1", "chapter": "101_袁盎晁错列传", "para": "62", "seq": 1, "text": "盎因跪曰： “原请间。”", "len": 12}
{"sid": "101_袁盎晁错列传.63.s1", "chapter": "101_袁盎晁错列传", "para": "63", "seq": 1, "text": "丞相曰： “使君所言公事，之曹与长史掾议，吾且奏之；即私邪，吾不受私语。”", "len": 37}
{"sid": "101_袁盎晁错列传.64.s1", "chapter": "101_袁盎晁错列传", "para": "64", "seq": 1, "text": "袁盎即跪说曰： ::: 袁盎说申屠嘉", "len": 18}
{"sid": "101_袁盎晁错列传.65.s1", "chapter": "101_袁盎晁错列传", "para": "65", "seq": 1, "text": "“君为丞相，自度孰与陈平、绛侯？", "len": 16}
{"sid": "101_袁盎晁错列传.65.s2", "chapter": "101_袁盎晁错列传", "para": "65", "seq": 2, "text": "” :::", "len": 5}
{"sid": "101_袁盎晁错列传.66.s1", "chapter": "101_袁盎晁错列传", "para": "66", "seq": 1, "text": "丞相曰： “吾不如。”", "len": 11}
{"sid": "101_袁盎晁错列传.67.s1", "chapter": "101_袁盎晁错列传", "para": "67", "seq": 1, "text": "袁盎曰： “善，君即自谓不如。", "len": 15}
{"sid": "101_袁盎晁错列传.67.s2", "chapter": "101_袁盎晁错列传", "para": "67", "seq": 2, "text": "夫陈平、绛侯辅翼高帝，定天下，为将相，而诛诸吕，存刘氏；君乃为材官蹶张，迁为队率，积功至淮阳守，非有奇计攻城野战之功。", "len": 59}
{"sid": "101_袁盎晁错列传.67.s3", "chapter": "101_袁盎晁错列传", "para": "67", "seq": 3, "text": "且陛下从代来，每朝，郎官上书疏，未尝不止辇受其言，言不可用置之，言可受采之，未尝不称善。", "len": 44}
{"sid": "101_袁盎晁错列传.67.s4", "chapter": "101_袁盎晁错列传", "para": "67", "seq": 4, "text": "何也？", "len": 3}
{"sid": "101_袁盎晁错列传.67.s5", "chapter": "101_袁盎晁错列传", "para": "67", "seq": 5, "text": "则欲以致天下贤士大夫。", "len": 11}
{"sid": "101_袁盎晁错列传.67.s6", "chapter": "101_袁盎晁错列传", "para": "67", "seq": 6, "text": "上日闻所不闻，明所不知，日益圣智；君今自闭钳天下之口而日益愚。", "len": 31}
{"sid": "101_袁盎晁错列传.67.s7", "chapter": "101_袁盎晁错列传", "para": "67", "seq": 7, "text": "夫以圣主责愚相，君受祸不久矣。”", "len": 16}
{"sid": "101_袁盎晁错列传.68.s1", "chapter": "101_袁盎晁错列传", "para": "68", "seq": 1, "text": "丞相乃再拜曰： “嘉鄙野人，乃不知，将军幸教。”", "len": 24}
{"sid": "101_袁盎晁错列传.69.s1", "chapter": "101_袁盎晁错列传", "para": "69", "seq": 1, "text": "引入与坐，为上客。", "len": 9}
{"sid": "101_袁盎晁错列传.70.s1", "chapter": "101_袁盎晁错列传", "para": "70", "seq": 1, "text": "盎素不好晁错，晁错所居坐，盎去；盎坐，错亦去：两人未尝同堂语。", "len": 31}
{"sid": "101_袁盎晁错列传.71.s1", "chapter": "101_袁盎晁错列传", "para": "71", "seq": 1, "text": "及孝文帝崩，孝景帝即位，晁错为御史大夫，使吏案袁盎受吴王财物，抵罪，诏赦以为庶人。", "len": 41}
{"sid": "101_袁盎晁错列传.72.s1", "chapter": "101_袁盎晁错列传", "para": "72", "seq": 1, "text": "吴楚反，闻，晁错谓丞史曰： “夫袁盎多受吴王金钱，专为蔽匿，言不反。", "len": 34}
{"sid": "101_袁盎晁错列传.72.s2", "chapter": "101_袁盎晁错列传", "para": "72", "seq": 2, "text": "今果反，欲请治盎宜知计谋。”", "len": 14}
{"sid": "101_袁盎晁错列传.73.s1", "chapter": "101_袁盎晁错列传", "para": "73", "seq": 1, "text": "丞史曰： “事未发，治之有绝。", "len": 15}
{"sid": "101_袁盎晁错列传.73.s2", "chapter": "101_袁盎晁错列传", "para": "73", "seq": 2, "text": "今兵西乡，治之何益！", "len": 10}
{"sid": "101_袁盎晁错列传.73.s3", "chapter": "101_袁盎晁错列传", "para": "73", "seq": 3, "text": "且袁盎不宜有谋。”", "len": 9}
{"sid": "101_袁盎晁错列传.74.s1", "chapter": "101_袁盎晁错列传", "para": "74", "seq": 1, "text": "晁错犹与未决。", "len": 7}
{"sid": "101_袁盎晁错列传.75.s1", "chapter": "101_袁盎晁错列传", "para": "75", "seq": 1, "text": "人有告袁盎者，袁盎恐，夜见窦婴，为言吴所以反者，原至上前口对状。", "len": 32}
{"sid": "101_袁盎晁错列传.76.s1", "chapter": "101_袁盎晁错列传", "para": "76", "seq": 1, "text": "窦婴入言上，上乃召袁盎入见。", "len": 14}
{"sid": "101_袁盎晁错列传.77.s1", "chapter": "101_袁盎晁错列传", "para": "77", "seq": 1, "text": "晁错在前，及盎请辟人赐间，错去，固恨甚。", "len": 20}
{"sid": "101_袁盎晁错列传.78.s1", "chapter": "101_袁盎晁错列传", "para": "78", "seq": 1, "text": "袁盎具言吴所以反状，以错故，独急斩错以谢吴，吴兵乃可罢。", "len": 28}
{"sid": "101_袁盎晁错列传.79.s1", "chapter": "101_袁盎晁错列传", "para": "79", "seq": 1, "text": "其语具在吴事中。", "len": 8}
{"sid": "101_袁盎晁错列传.80.s1", "chapter": "101_袁盎晁错列传", "para": "80", "seq": 1, "text": "使袁盎为太常，窦婴为大将军。", "len": 14}
{"sid": "101_袁盎晁错列传.81.s1", "chapter": "101_袁盎晁错列传", "para": "81", "seq": 1, "text": "两人素相与善。", "len": 7}
{"sid": "101_袁盎晁错列传.81.s2", "chapter": "101_袁盎晁错列传", "para": "81", "seq": 2, "text": "逮吴反。", "len": 4}
{"sid": "101_袁盎晁错列传.81.s3", "chapter": "101_袁盎晁错列传", "para": "81", "seq": 3, "text": "诸陵长者长安中贤大夫争附两人，车随者日数百乘。", "len": 23}
{"sid": "101_袁盎晁错列传.82.s1", "chapter": "101_袁盎晁错列传", "para": "82", "seq": 1, "text": "及晁错已诛，袁盎以太常使吴。", "len": 14}
{"sid": "101_袁盎晁错列传.83.s1", "chapter": "101_袁盎晁错列传", "para": "83", "seq": 1, "text": "吴王欲使将，不肯。", "len": 9}
{"sid": "101_袁盎晁错列传.83.s2", "chapter": "101_袁盎晁错列传", "para": "83", "seq": 2, "text": "欲杀之，使一都尉以五百人围守盎军中。", "len": 18}
{"sid": "101_袁盎晁错列传.84.s1", "chapter": "101_袁盎晁错列传", "para": "84", "seq": 1, "text": "袁盎自其为吴相时，有从史尝盗爱盎侍兒，盎知之，弗泄，遇之如故。", "len": 31}
{"sid": "101_袁盎晁错列传.85.s1", "chapter": "101_袁盎晁错列传", "para": "85", "seq": 1, "text": "人有告从史，言“君知尔与侍者通”，乃亡归。", "len": 21}
{"sid": "101_袁盎晁错列传.86.s1", "chapter": "101_袁盎晁错列传", "para": "86", "seq": 1, "text": "袁盎驱自追之，遂以侍者赐之，复为从史。", "len": 19}
{"sid": "101_袁盎晁错列传.87.s1", "chapter": "101_袁盎晁错列传", "para": "87", "seq": 1, "text": "及袁盎使吴见守，从史適为守盎校尉司马，乃悉以其装赍置二石醇醪，会天寒，士卒饥渴，饮酒醉，西南陬卒皆卧，司马夜引袁盎起，曰： “君可以去矣，吴王期旦日斩君。”", "len": 78}
{"sid": "101_袁盎晁错列传.88.s1", "chapter": "101_袁盎晁错列传", "para": "88", "seq": 1, "text": "盎弗信，曰： “公何为者？”", "len": 14}
{"sid": "101_袁盎晁错列传.89.s1", "chapter": "101_袁盎晁错列传", "para": "89", "seq": 1, "text": "司马曰： “臣故为从史盗君侍兒者。”", "len": 18}
{"sid": "101_袁盎晁错列传.90.s1", "chapter": "101_袁盎晁错列传", "para": "90", "seq": 1, "text": "盎乃惊谢曰： “公幸有亲，吾不足以累公。”", "len": 21}
{"sid": "101_袁盎晁错列传.91.s1", "chapter": "101_袁盎晁错列传", "para": "91", "seq": 1, "text": "司马曰： “君弟去，臣亦且亡，辟吾亲，君何患！”", "len": 24}
{"sid": "101_袁盎晁错列传.92.s1", "chapter": "101_袁盎晁错列传", "para": "92", "seq": 1, "text": "乃以刀决张，道从醉卒隧出。", "len": 13}
{"sid": "101_袁盎晁错列传.93.s1", "chapter": "101_袁盎晁错列传", "para": "93", "seq": 1, "text": "司马与分背，袁盎解节毛怀之，杖，步行七八里，明，见梁骑，骑驰去，遂归报。", "len": 36}
{"sid": "101_袁盎晁错列传.94.s1", "chapter": "101_袁盎晁错列传", "para": "94", "seq": 1, "text": "吴楚已破，上更以元王子平陆侯礼为楚王，袁盎为楚相。", "len": 25}
{"sid": "101_袁盎晁错列传.95.s1", "chapter": "101_袁盎晁错列传", "para": "95", "seq": 1, "text": "尝上书有所言，不用。", "len": 10}
{"sid": "101_袁盎晁错列传.96.s1", "chapter": "101_袁盎晁错列传", "para": "96", "seq": 1, "text": "袁盎病免居家，与闾里浮沈，相随行，斗鸡走狗。", "len": 22}
{"sid": "101_袁盎晁错列传.97.s1", "chapter": "101_袁盎晁错列传", "para": "97", "seq": 1, "text": "雒阳剧孟尝过袁盎，盎善待之。", "len": 14}
{"sid": "101_袁盎晁错列传.98.s1", "chapter": "101_袁盎晁错列传", "para": "98", "seq": 1, "text": "安陵富人有谓盎曰： “吾闻剧孟博徒，将军何自通之？”", "len": 26}
{"sid": "101_袁盎晁错列传.99.s1", "chapter": "101_袁盎晁错列传", "para": "99", "seq": 1, "text": "盎曰： ::: 袁盎论剧孟", "len": 13}
{"sid": "101_袁盎晁错列传.100.s1", "chapter": "101_袁盎晁错列传", "para": "100", "seq": 1, "text": "“剧孟虽博徒，然母死，客送葬车千馀乘，此亦有过人者。", "len": 26}
{"sid": "101_袁盎晁错列传.100.s2", "chapter": "101_袁盎晁错列传", "para": "100", "seq": 2, "text": "且缓急人所有。", "len": 7}
{"sid": "101_袁盎晁错列传.100.s3", "chapter": "101_袁盎晁错列传", "para": "100", "seq": 3, "text": "夫一旦有急叩门，不以亲为解，不以存亡为辞，天下所望者，独季心、剧孟耳。", "len": 35}
{"sid": "101_袁盎晁错列传.100.s4", "chapter": "101_袁盎晁错列传", "para": "100", "seq": 4, "text": "今公常从数骑，一旦有缓急，宁足恃乎！", "len": 18}
{"sid": "101_袁盎晁错列传.100.s5", "chapter": "101_袁盎晁错列传", "para": "100", "seq": 5, "text": "” :::", "len": 5}
{"sid": "101_袁盎晁错列传.101.s1", "chapter": "101_袁盎晁错列传", "para": "101", "seq": 1, "text": "骂富人，弗与通。", "len": 8}
{"sid": "101_袁盎晁错列传.102.s1", "chapter": "101_袁盎晁错列传", "para": "102", "seq": 1, "text": "诸公闻之，皆多袁盎。", "len": 10}
{"sid": "101_袁盎晁错列传.103.s1", "chapter": "101_袁盎晁错列传", "para": "103", "seq": 1, "text": "袁盎虽家居，景帝时时使人问筹策。", "len": 16}
{"sid": "101_袁盎晁错列传.104.s1", "chapter": "101_袁盎晁错列传", "para": "104", "seq": 1, "text": "梁王欲求为嗣，袁盎进说，其後语塞。", "len": 17}
{"sid": "101_袁盎晁错列传.105.s1", "chapter": "101_袁盎晁错列传", "para": "105", "seq": 1, "text": "梁王以此怨盎，曾使人刺盎。", "len": 13}
{"sid": "101_袁盎晁错列传.106.s1", "chapter": "101_袁盎晁错列传", "para": "106", "seq": 1, "text": "刺者至关中，问袁盎，诸君誉之皆不容口。", "len": 19}
{"sid": "101_袁盎晁错列传.107.s1", "chapter": "101_袁盎晁错列传", "para": "107", "seq": 1, "text": "乃见袁盎曰： “臣受梁王金来刺君，君长者，不忍刺君。", "len": 26}
{"sid": "101_袁盎晁错列传.107.s2", "chapter": "101_袁盎晁错列传", "para": "107", "seq": 2, "text": "然後刺君者十馀曹，备之！”", "len": 13}
{"sid": "101_袁盎晁错列传.108.s1", "chapter": "101_袁盎晁错列传", "para": "108", "seq": 1, "text": "袁盎心不乐，家又多怪，乃之棓生所问占。", "len": 19}
{"sid": "101_袁盎晁错列传.109.s1", "chapter": "101_袁盎晁错列传", "para": "109", "seq": 1, "text": "还，梁刺客後曹辈果遮刺杀盎安陵郭门外。", "len": 19}
{"sid": "101_袁盎晁错列传.110.s1", "chapter": "101_袁盎晁错列传", "para": "110", "seq": 1, "text": "晁错者，颍川人也。", "len": 9}
{"sid": "101_袁盎晁错列传.111.s1", "chapter": "101_袁盎晁错列传", "para": "111", "seq": 1, "text": "学申商刑名於轵张恢先所，与雒阳宋孟及刘礼同师。", "len": 23}
{"sid": "101_袁盎晁错列传.112.s1", "chapter": "101_袁盎晁错列传", "para": "112", "seq": 1, "text": "以文学为太常掌故。", "len": 9}
{"sid": "101_袁盎晁错列传.113.s1", "chapter": "101_袁盎晁错列传", "para": "113", "seq": 1, "text": "错为人穞直刻深。", "len": 8}
{"sid": "101_袁盎晁错列传.114.s1", "chapter": "101_袁盎晁错列传", "para": "114", "seq": 1, "text": "孝文帝时，天下无治尚书者，独闻济南伏生故秦博士，治尚书，年九十馀，老不可徵，乃诏太常使人往受之。", "len": 48}
{"sid": "101_袁盎晁错列传.115.s1", "chapter": "101_袁盎晁错列传", "para": "115", "seq": 1, "text": "太常遣错受尚书伏生所。", "len": 11}
{"sid": "101_袁盎晁错列传.116.s1", "chapter": "101_袁盎晁错列传", "para": "116", "seq": 1, "text": "还，因上便宜事，以书称说。", "len": 13}
{"sid": "101_袁盎晁错列传.117.s1", "chapter": "101_袁盎晁错列传", "para": "117", "seq": 1, "text": "诏以为太子舍人、门大夫、家令。", "len": 15}
{"sid": "101_袁盎晁错列传.118.s1", "chapter": "101_袁盎晁错列传", "para": "118", "seq": 1, "text": "以其辩得幸太子，太子家号曰“智囊”。", "len": 18}
{"sid": "101_袁盎晁错列传.119.s1", "chapter": "101_袁盎晁错列传", "para": "119", "seq": 1, "text": "数上书孝文时，言削诸侯事，及法令可更定者。", "len": 21}
{"sid": "101_袁盎晁错列传.120.s1", "chapter": "101_袁盎晁错列传", "para": "120", "seq": 1, "text": "书数十上，孝文不听，然奇其材，迁为中大夫。", "len": 21}
{"sid": "101_袁盎晁错列传.121.s1", "chapter": "101_袁盎晁错列传", "para": "121", "seq": 1, "text": "当是时，太子善错计策，袁盎诸大功臣多不好错。", "len": 22}
{"sid": "101_袁盎晁错列传.122.s1", "chapter": "101_袁盎晁错列传", "para": "122", "seq": 1, "text": "景帝即位，以错为内史。", "len": 11}
{"sid": "101_袁盎晁错列传.123.s1", "chapter": "101_袁盎晁错列传", "para": "123", "seq": 1, "text": "错常数请间言事，辄听，宠幸倾九卿，法令多所更定。", "len": 24}
{"sid": "101_袁盎晁错列传.124.s1", "chapter": "101_袁盎晁错列传", "para": "124", "seq": 1, "text": "丞相申屠嘉心弗便，力未有以伤。", "len": 15}
{"sid": "101_袁盎晁错列传.125.s1", "chapter": "101_袁盎晁错列传", "para": "125", "seq": 1, "text": "内史府居太上庙壖中，门东出，不便，错乃穿两门南出，凿庙壖垣。", "len": 30}
{"sid": "101_袁盎晁错列传.126.s1", "chapter": "101_袁盎晁错列传", "para": "126", "seq": 1, "text": "丞相嘉闻，大怒，欲因此过为奏请诛错。", "len": 18}
{"sid": "101_袁盎晁错列传.127.s1", "chapter": "101_袁盎晁错列传", "para": "127", "seq": 1, "text": "错闻之，即夜请间，具为上言之。", "len": 15}
{"sid": "101_袁盎晁错列传.128.s1", "chapter": "101_袁盎晁错列传", "para": "128", "seq": 1, "text": "丞相奏事，因言错擅凿庙垣为门，请下廷尉诛。", "len": 21}
{"sid": "101_袁盎晁错列传.129.s1", "chapter": "101_袁盎晁错列传", "para": "129", "seq": 1, "text": "上曰： “此非庙垣，乃壖中垣，不致於法。”", "len": 21}
{"sid": "101_袁盎晁错列传.130.s1", "chapter": "101_袁盎晁错列传", "para": "130", "seq": 1, "text": "丞相谢。", "len": 4}
{"sid": "101_袁盎晁错列传.131.s1", "chapter": "101_袁盎晁错列传", "para": "131", "seq": 1, "text": "罢朝，怒谓长史曰： “吾当先斩以闻，乃先请，为兒所卖，固误。”", "len": 31}
{"sid": "101_袁盎晁错列传.132.s1", "chapter": "101_袁盎晁错列传", "para": "132", "seq": 1, "text": "丞相遂发病死。", "len": 7}
{"sid": "101_袁盎晁错列传.133.s1", "chapter": "101_袁盎晁错列传", "para": "133", "seq": 1, "text": "错以此愈贵。", "len": 6}
{"sid": "101_袁盎晁错列传.134.s1", "chapter": "101_袁盎晁错列传", "para": "134", "seq": 1, "text": "迁为御史大夫，请诸侯之罪过，削其地，收其枝郡。", "len": 23}
{"sid": "101_袁盎晁错列传.135.s1", "chapter": "101_袁盎晁错列传", "para": "135", "seq": 1, "text": "奏上，上令公卿列侯宗室集议，莫敢难，独窦婴争之，由此与错有卻。", "len": 31}
{"sid": "101_袁盎晁错列传.136.s1", "chapter": "101_袁盎晁错列传", "para": "136", "seq": 1, "text": "错所更令三十章，诸侯皆諠譁疾晁错。", "len": 17}
{"sid": "101_袁盎晁错列传.137.s1", "chapter": "101_袁盎晁错列传", "para": "137", "seq": 1, "text": "错父闻之，从颍川来，谓错曰： “上初即位，公为政用事，侵削诸侯，别疏人骨肉，人口议多怨公者，何也？”", "len": 50}
{"sid": "101_袁盎晁错列传.138.s1", "chapter": "101_袁盎晁错列传", "para": "138", "seq": 1, "text": "晁错曰： “固也。", "len": 9}
{"sid": "101_袁盎晁错列传.138.s2", "chapter": "101_袁盎晁错列传", "para": "138", "seq": 2, "text": "不如此，天子不尊，宗庙不安。”", "len": 15}
{"sid": "101_袁盎晁错列传.139.s1", "chapter": "101_袁盎晁错列传", "para": "139", "seq": 1, "text": "错父曰： ::: 晁错父之言", "len": 14}
{"sid": "101_袁盎晁错列传.140.s1", "chapter": "101_袁盎晁错列传", "para": "140", "seq": 1, "text": "“刘氏安矣，而晁氏危矣，吾去公归矣！", "len": 18}
{"sid": "101_袁盎晁错列传.140.s2", "chapter": "101_袁盎晁错列传", "para": "140", "seq": 2, "text": "” :::", "len": 5}
{"sid": "101_袁盎晁错列传.141.s1", "chapter": "101_袁盎晁错列传", "para": "141", "seq": 1, "text": "遂饮药死，曰： “吾不忍见祸及吾身。”", "len": 19}
{"sid": "101_袁盎晁错列传.142.s1", "chapter": "101_袁盎晁错列传", "para": "142", "seq": 1, "text": "死十馀日，吴楚七国果反，以诛错为名。", "len": 18}
{"sid": "101_袁盎晁错列传.143.s1", "chapter": "101_袁盎晁错列传", "para": "143", "seq": 1, "text": "及窦婴、袁盎进说，上令晁错衣朝衣斩东市。", "len": 20}
{"sid": "101_袁盎晁错列传.144.s1", "chapter": "101_袁盎晁错列传", "para": "144", "seq": 1, "text": "晁错已死，谒者仆射邓公为校尉，击吴楚军为将。", "len": 22}
{"sid": "101_袁盎晁错列传.145.s1", "chapter": "101_袁盎晁错列传", "para": "145", "seq": 1, "text": "还，上书言军事，谒见上。", "len": 12}
{"sid": "101_袁盎晁错列传.146.s1", "chapter": "101_袁盎晁错列传", "para": "146", "seq": 1, "text": "上问曰： “道军所来，闻晁错死，吴楚罢不？”", "len": 22}
{"sid": "101_袁盎晁错列传.147.s1", "chapter": "101_袁盎晁错列传", "para": "147", "seq": 1, "text": "邓公曰： “吴王为反数十年矣，发怒削地，以诛错为名，其意非在错也。", "len": 33}
{"sid": "101_袁盎晁错列传.147.s2", "chapter": "101_袁盎晁错列传", "para": "147", "seq": 2, "text": "且臣恐天下之士噤口，不敢复言也！”", "len": 17}
{"sid": "101_袁盎晁错列传.148.s1", "chapter": "101_袁盎晁错列传", "para": "148", "seq": 1, "text": "上曰： “何哉？”", "len": 9}
{"sid": "101_袁盎晁错列传.149.s1", "chapter": "101_袁盎晁错列传", "para": "149", "seq": 1, "text": "邓公曰： ::: 邓公论晁错之死", "len": 16}
{"sid": "101_袁盎晁错列传.150.s1", "chapter": "101_袁盎晁错列传", "para": "150", "seq": 1, "text": "“夫晁错患诸侯彊大不可制，故请削地以尊京师，万世之利也。", "len": 28}
{"sid": "101_袁盎晁错列传.150.s2", "chapter": "101_袁盎晁错列传", "para": "150", "seq": 2, "text": "计画始行，卒受大戮，内杜忠臣之口，外为诸侯报仇，臣窃为陛下不取也。", "len": 33}
{"sid": "101_袁盎晁错列传.150.s3", "chapter": "101_袁盎晁错列传", "para": "150", "seq": 3, "text": "” :::", "len": 5}
{"sid": "101_袁盎晁错列传.151.s1", "chapter": "101_袁盎晁错列传", "para": "151", "seq": 1, "text": "於是景帝默然良久，曰： “公言善，吾亦恨之。”", "len": 23}
{"sid": "101_袁盎晁错列传.152.s1", "chapter": "101_袁盎晁错列传", "para": "152", "seq": 1, "text": "乃拜邓公为城阳中尉。", "len": 10}
{"sid": "101_袁盎晁错列传.153.s1", "chapter": "101_袁盎晁错列传", "para": "153", "seq": 1, "text": "邓公，成固人也，多奇计。", "len": 12}
{"sid": "101_袁盎晁错列传.154.s1", "chapter": "101_袁盎晁错列传", "para": "154", "seq": 1, "text": "建元中，上招贤良，公卿言邓公，时邓公免，起家为九卿。", "len": 26}
{"sid": "101_袁盎晁错列传.155.s1", "chapter": "101_袁盎晁错列传", "para": "155", "seq": 1, "text": "一年，复谢病免归。", "len": 9}
{"sid": "101_袁盎晁错列传.156.s1", "chapter": "101_袁盎晁错列传", "para": "156", "seq": 1, "text": "其子章以脩黄老言显於诸公间。", "len": 14}
{"sid": "101_袁盎晁错列传.156.s2", "chapter": "101_袁盎晁错列传", "para": "156", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "101_袁盎晁错列传.157.s1", "chapter": "101_袁盎晁错列传", "para": "157", "seq": 1, "text": "太史公曰：袁盎虽不好学，亦善傅会，仁心为质，引义慷慨。", "len": 27}
{"sid": "101_袁盎晁错列传.157.s2", "chapter": "101_袁盎晁错列传", "para": "157", "seq": 2, "text": "遭孝文初立，资適逢世。", "len": 11}
{"sid": "101_袁盎晁错列传.157.s3", "chapter": "101_袁盎晁错列传", "para": "157", "seq": 3, "text": "时以变易，及吴楚一说，说虽行哉，然复不遂。", "len": 21}
{"sid": "101_袁盎晁错列传.157.s4", "chapter": "101_袁盎晁错列传", "para": "157", "seq": 4, "text": "好声矜贤，竟以名败。", "len": 10}
{"sid": "101_袁盎晁错列传.157.s5", "chapter": "101_袁盎晁错列传", "para": "157", "seq": 5, "text": "晁错为家令时，数言事不用；後擅权，多所变更。", "len": 22}
{"sid": "101_袁盎晁错列传.157.s6", "chapter": "101_袁盎晁错列传", "para": "157", "seq": 6, "text": "诸侯发难，不急匡救，欲报私雠，反以亡躯。", "len": 20}
{"sid": "101_袁盎晁错列传.157.s7", "chapter": "101_袁盎晁错列传", "para": "157", "seq": 7, "text": "语曰“变古乱常，不死则亡”，岂错等谓邪！", "len": 20}
{"sid": "101_袁盎晁错列传.157.s8", "chapter": "101_袁盎晁错列传", "para": "157", "seq": 8, "text": "::: ::: 赞", "len": 9}
{"sid": "101_袁盎晁错列传.158.s1", "chapter": "101_袁盎晁错列传", "para": "158", "seq": 1, "text": "袁丝公直，亦多附会。", "len": 10}
{"sid": "101_袁盎晁错列传.158.s2", "chapter": "101_袁盎晁错列传", "para": "158", "seq": 2, "text": "揽辔见重，卻席翳赖。", "len": 10}
{"sid": "101_袁盎晁错列传.158.s3", "chapter": "101_袁盎晁错列传", "para": "158", "seq": 3, "text": "晁错建策，屡陈利害。", "len": 10}
{"sid": "101_袁盎晁错列传.158.s4", "chapter": "101_袁盎晁错列传", "para": "158", "seq": 4, "text": "尊主卑臣，家危国泰。", "len": 10}
{"sid": "101_袁盎晁错列传.158.s5", "chapter": "101_袁盎晁错列传", "para": "158", "seq": 5, "text": "悲彼二子，名立身败！", "len": 10}
{"sid": "101_袁盎晁错列传.158.s6", "chapter": "101_袁盎晁错列传", "para": "158", "seq": 6, "text": ":::", "len": 3}
