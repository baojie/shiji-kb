{"sid": "075_孟尝君列传.1.s1", "chapter": "075_孟尝君列传", "para": "1", "seq": 1, "text": "孟尝君名文，姓田氏。", "len": 10}
{"sid": "075_孟尝君列传.1.s2", "chapter": "075_孟尝君列传", "para": "1", "seq": 2, "text": "文之父曰靖郭君田婴。", "len": 10}
{"sid": "075_孟尝君列传.1.s3", "chapter": "075_孟尝君列传", "para": "1", "seq": 3, "text": "田婴者，齐威王少子而齐宣王庶弟也。", "len": 17}
{"sid": "075_孟尝君列传.1.s4", "chapter": "075_孟尝君列传", "para": "1", "seq": 4, "text": "田婴自威王时任职用事，与成侯邹忌及田忌将而救韩伐魏。", "len": 26}
{"sid": "075_孟尝君列传.1.s5", "chapter": "075_孟尝君列传", "para": "1", "seq": 5, "text": "成侯与田忌争宠，成侯卖田忌。", "len": 14}
{"sid": "075_孟尝君列传.1.s6", "chapter": "075_孟尝君列传", "para": "1", "seq": 6, "text": "田忌惧，袭齐之边邑，不胜，亡走。", "len": 16}
{"sid": "075_孟尝君列传.1.s7", "chapter": "075_孟尝君列传", "para": "1", "seq": 7, "text": "会威王卒，宣王立，知成侯卖田忌，乃复召田忌以为将。", "len": 25}
{"sid": "075_孟尝君列传.1.s8", "chapter": "075_孟尝君列传", "para": "1", "seq": 8, "text": "宣王二年，田忌与孙膑、田婴俱伐魏，败之马陵，虏魏太子申而杀魏将庞涓。", "len": 34}
{"sid": "075_孟尝君列传.1.s9", "chapter": "075_孟尝君列传", "para": "1", "seq": 9, "text": "宣王七年，田婴使於韩、魏，韩、魏服於齐。", "len": 20}
{"sid": "075_孟尝君列传.1.s10", "chapter": "075_孟尝君列传", "para": "1", "seq": 10, "text": "婴与韩昭侯、魏惠王会齐宣王东阿南，盟而去。", "len": 21}
{"sid": "075_孟尝君列传.1.s11", "chapter": "075_孟尝君列传", "para": "1", "seq": 11, "text": "明年，复与梁惠王会甄。", "len": 11}
{"sid": "075_孟尝君列传.1.s12", "chapter": "075_孟尝君列传", "para": "1", "seq": 12, "text": "是岁，梁惠王卒。", "len": 8}
{"sid": "075_孟尝君列传.1.s13", "chapter": "075_孟尝君列传", "para": "1", "seq": 13, "text": "宣王九年，田婴相齐。", "len": 10}
{"sid": "075_孟尝君列传.1.s14", "chapter": "075_孟尝君列传", "para": "1", "seq": 14, "text": "齐宣王与魏襄王会徐州而相王也。", "len": 15}
{"sid": "075_孟尝君列传.1.s15", "chapter": "075_孟尝君列传", "para": "1", "seq": 15, "text": "楚威王闻之，怒田婴。", "len": 10}
{"sid": "075_孟尝君列传.1.s16", "chapter": "075_孟尝君列传", "para": "1", "seq": 16, "text": "明年，楚伐败齐师於徐州，而使人逐田婴。", "len": 19}
{"sid": "075_孟尝君列传.1.s17", "chapter": "075_孟尝君列传", "para": "1", "seq": 17, "text": "田婴使张丑说楚威王，威王乃止。", "len": 15}
{"sid": "075_孟尝君列传.1.s18", "chapter": "075_孟尝君列传", "para": "1", "seq": 18, "text": "田婴相齐十一年，宣王卒，湣王即位。", "len": 17}
{"sid": "075_孟尝君列传.1.s19", "chapter": "075_孟尝君列传", "para": "1", "seq": 19, "text": "即位三年，而封田婴於薛。", "len": 12}
{"sid": "075_孟尝君列传.2.s1", "chapter": "075_孟尝君列传", "para": "2", "seq": 1, "text": "初，田婴有子四十馀人。", "len": 11}
{"sid": "075_孟尝君列传.2.s2", "chapter": "075_孟尝君列传", "para": "2", "seq": 2, "text": "其贱妾有子名文，文以五月五日生。", "len": 16}
{"sid": "075_孟尝君列传.2.s3", "chapter": "075_孟尝君列传", "para": "2", "seq": 3, "text": "婴告其母曰：“勿举也。", "len": 11}
{"sid": "075_孟尝君列传.2.s4", "chapter": "075_孟尝君列传", "para": "2", "seq": 4, "text": "” 其母窃举生之。", "len": 9}
{"sid": "075_孟尝君列传.2.s5", "chapter": "075_孟尝君列传", "para": "2", "seq": 5, "text": "及长，其母因兄弟而见其子文於田婴。", "len": 17}
{"sid": "075_孟尝君列传.2.s6", "chapter": "075_孟尝君列传", "para": "2", "seq": 6, "text": "田婴怒其母曰：“吾令若去此子，而敢生之，何也？", "len": 23}
{"sid": "075_孟尝君列传.2.s7", "chapter": "075_孟尝君列传", "para": "2", "seq": 7, "text": "” 文顿首，因曰：“君所以不举五月子者，何故？", "len": 23}
{"sid": "075_孟尝君列传.2.s8", "chapter": "075_孟尝君列传", "para": "2", "seq": 8, "text": "” 婴曰：“五月子者，长与户齐，将不利其父母。", "len": 23}
{"sid": "075_孟尝君列传.2.s9", "chapter": "075_孟尝君列传", "para": "2", "seq": 9, "text": "” 文曰：“人生受命於天乎？", "len": 14}
{"sid": "075_孟尝君列传.2.s10", "chapter": "075_孟尝君列传", "para": "2", "seq": 10, "text": "将受命於户邪？", "len": 7}
{"sid": "075_孟尝君列传.2.s11", "chapter": "075_孟尝君列传", "para": "2", "seq": 11, "text": "” 婴默然。", "len": 6}
{"sid": "075_孟尝君列传.2.s12", "chapter": "075_孟尝君列传", "para": "2", "seq": 12, "text": "文曰：“必受命於天，君何忧焉。", "len": 15}
{"sid": "075_孟尝君列传.2.s13", "chapter": "075_孟尝君列传", "para": "2", "seq": 13, "text": "必受命於户，则可高其户耳，谁能至者！", "len": 18}
{"sid": "075_孟尝君列传.2.s14", "chapter": "075_孟尝君列传", "para": "2", "seq": 14, "text": "” 婴曰：“子休矣。”", "len": 11}
{"sid": "075_孟尝君列传.3.s1", "chapter": "075_孟尝君列传", "para": "3", "seq": 1, "text": "久之，文承间问其父婴曰：“子之子为何？", "len": 19}
{"sid": "075_孟尝君列传.3.s2", "chapter": "075_孟尝君列传", "para": "3", "seq": 2, "text": "” 曰：“为孙。", "len": 8}
{"sid": "075_孟尝君列传.3.s3", "chapter": "075_孟尝君列传", "para": "3", "seq": 3, "text": "” “孙之孙为何？", "len": 9}
{"sid": "075_孟尝君列传.3.s4", "chapter": "075_孟尝君列传", "para": "3", "seq": 4, "text": "” 曰：“为玄孙。", "len": 9}
{"sid": "075_孟尝君列传.3.s5", "chapter": "075_孟尝君列传", "para": "3", "seq": 5, "text": "” “玄孙之孙为何？", "len": 10}
{"sid": "075_孟尝君列传.3.s6", "chapter": "075_孟尝君列传", "para": "3", "seq": 6, "text": "” 曰：“不能知也。", "len": 10}
{"sid": "075_孟尝君列传.3.s7", "chapter": "075_孟尝君列传", "para": "3", "seq": 7, "text": "” 文曰：“君用事相齐，至今三王矣，齐不加广而君私家富累万金，门下不见一贤者。", "len": 39}
{"sid": "075_孟尝君列传.3.s8", "chapter": "075_孟尝君列传", "para": "3", "seq": 8, "text": "文闻将门必有将，相门必有相。", "len": 14}
{"sid": "075_孟尝君列传.3.s9", "chapter": "075_孟尝君列传", "para": "3", "seq": 9, "text": "今君後宫蹈绮縠而士不得褐，仆妾馀粱肉而士不厌糟糠。", "len": 25}
{"sid": "075_孟尝君列传.3.s10", "chapter": "075_孟尝君列传", "para": "3", "seq": 10, "text": "今君又尚厚积馀藏，欲以遗所不知何人，而忘公家之事日损，文窃怪之。", "len": 32}
{"sid": "075_孟尝君列传.3.s11", "chapter": "075_孟尝君列传", "para": "3", "seq": 11, "text": "” 於是婴乃礼文，使主家待宾客。", "len": 16}
{"sid": "075_孟尝君列传.3.s12", "chapter": "075_孟尝君列传", "para": "3", "seq": 12, "text": "宾客日进，名声闻於诸侯。", "len": 12}
{"sid": "075_孟尝君列传.3.s13", "chapter": "075_孟尝君列传", "para": "3", "seq": 13, "text": "诸侯皆使人请薛公田婴以文为太子，婴许之。", "len": 20}
{"sid": "075_孟尝君列传.3.s14", "chapter": "075_孟尝君列传", "para": "3", "seq": 14, "text": "婴卒，谥为靖郭君。", "len": 9}
{"sid": "075_孟尝君列传.3.s15", "chapter": "075_孟尝君列传", "para": "3", "seq": 15, "text": "而文果代立於薛，是为孟尝君。", "len": 14}
{"sid": "075_孟尝君列传.4.s1", "chapter": "075_孟尝君列传", "para": "4", "seq": 1, "text": "孟尝君在薛，招致诸侯宾客及亡人有罪者，皆归孟尝君。", "len": 25}
{"sid": "075_孟尝君列传.4.s2", "chapter": "075_孟尝君列传", "para": "4", "seq": 2, "text": "孟尝君舍业厚遇之，以故倾天下之士。", "len": 17}
{"sid": "075_孟尝君列传.4.s3", "chapter": "075_孟尝君列传", "para": "4", "seq": 3, "text": "食客数千人，无贵贱一与文等。", "len": 14}
{"sid": "075_孟尝君列传.4.s4", "chapter": "075_孟尝君列传", "para": "4", "seq": 4, "text": "孟尝君待客坐语，而屏风後常有侍史，主记君所与客语，问亲戚居处。", "len": 31}
{"sid": "075_孟尝君列传.4.s5", "chapter": "075_孟尝君列传", "para": "4", "seq": 5, "text": "客去，孟尝君已使使存问，献遗其亲戚。", "len": 18}
{"sid": "075_孟尝君列传.4.s6", "chapter": "075_孟尝君列传", "para": "4", "seq": 6, "text": "孟尝君曾待客夜食，有一人蔽火光。", "len": 16}
{"sid": "075_孟尝君列传.4.s7", "chapter": "075_孟尝君列传", "para": "4", "seq": 7, "text": "客怒，以饭不等，辍食辞去。", "len": 13}
{"sid": "075_孟尝君列传.4.s8", "chapter": "075_孟尝君列传", "para": "4", "seq": 8, "text": "孟尝君起，自持其饭比之。", "len": 12}
{"sid": "075_孟尝君列传.4.s9", "chapter": "075_孟尝君列传", "para": "4", "seq": 9, "text": "客惭，自刭。", "len": 6}
{"sid": "075_孟尝君列传.4.s10", "chapter": "075_孟尝君列传", "para": "4", "seq": 10, "text": "士以此多归孟尝君。", "len": 9}
{"sid": "075_孟尝君列传.4.s11", "chapter": "075_孟尝君列传", "para": "4", "seq": 11, "text": "孟尝君客无所择，皆善遇之。", "len": 13}
{"sid": "075_孟尝君列传.4.s12", "chapter": "075_孟尝君列传", "para": "4", "seq": 12, "text": "人人各自以为孟尝君亲己。", "len": 12}
{"sid": "075_孟尝君列传.5.s1", "chapter": "075_孟尝君列传", "para": "5", "seq": 1, "text": "秦昭王闻其贤，乃先使泾阳君为质於齐，以求见孟尝君。", "len": 25}
{"sid": "075_孟尝君列传.5.s2", "chapter": "075_孟尝君列传", "para": "5", "seq": 2, "text": "孟尝君将入秦，宾客莫欲其行，谏，不听。", "len": 19}
{"sid": "075_孟尝君列传.5.s3", "chapter": "075_孟尝君列传", "para": "5", "seq": 3, "text": "苏代谓曰：“今旦代从外来，见木禺人与土禺人相与语。", "len": 25}
{"sid": "075_孟尝君列传.5.s4", "chapter": "075_孟尝君列传", "para": "5", "seq": 4, "text": "木禺人曰：‘天雨，子将败矣。", "len": 14}
{"sid": "075_孟尝君列传.5.s5", "chapter": "075_孟尝君列传", "para": "5", "seq": 5, "text": "’土禺人曰：‘我生於土，败则归土。", "len": 17}
{"sid": "075_孟尝君列传.5.s6", "chapter": "075_孟尝君列传", "para": "5", "seq": 6, "text": "今天雨，流子而行，未知所止息也。", "len": 16}
{"sid": "075_孟尝君列传.5.s7", "chapter": "075_孟尝君列传", "para": "5", "seq": 7, "text": "’今秦，虎狼之国也，而君欲往，如有不得还，君得无为土禺人所笑乎？", "len": 32}
{"sid": "075_孟尝君列传.5.s8", "chapter": "075_孟尝君列传", "para": "5", "seq": 8, "text": "” 孟尝君乃止。", "len": 8}
{"sid": "075_孟尝君列传.6.s1", "chapter": "075_孟尝君列传", "para": "6", "seq": 1, "text": "齐湣王二十五年，复卒使孟尝君入秦，昭王即以孟尝君为秦相。", "len": 28}
{"sid": "075_孟尝君列传.6.s2", "chapter": "075_孟尝君列传", "para": "6", "seq": 2, "text": "人或说秦昭王曰：“孟尝君贤，而又齐族也，今相秦，必先齐而後秦，秦其危矣。", "len": 36}
{"sid": "075_孟尝君列传.6.s3", "chapter": "075_孟尝君列传", "para": "6", "seq": 3, "text": "” 於是秦昭王乃止。", "len": 10}
{"sid": "075_孟尝君列传.6.s4", "chapter": "075_孟尝君列传", "para": "6", "seq": 4, "text": "囚孟尝君，谋欲杀之。", "len": 10}
{"sid": "075_孟尝君列传.6.s5", "chapter": "075_孟尝君列传", "para": "6", "seq": 5, "text": "孟尝君使人抵昭王幸姬求解。", "len": 13}
{"sid": "075_孟尝君列传.6.s6", "chapter": "075_孟尝君列传", "para": "6", "seq": 6, "text": "幸姬曰：“妾原得君狐白裘。", "len": 13}
{"sid": "075_孟尝君列传.6.s7", "chapter": "075_孟尝君列传", "para": "6", "seq": 7, "text": "” 此时孟尝君有一狐白裘，直千金，天下无双，入秦献之昭王，更无他裘。", "len": 34}
{"sid": "075_孟尝君列传.6.s8", "chapter": "075_孟尝君列传", "para": "6", "seq": 8, "text": "孟尝君患之，遍问客，莫能对。", "len": 14}
{"sid": "075_孟尝君列传.6.s9", "chapter": "075_孟尝君列传", "para": "6", "seq": 9, "text": "最下坐有能为狗盗者，曰：“臣能得狐白裘。", "len": 20}
{"sid": "075_孟尝君列传.6.s10", "chapter": "075_孟尝君列传", "para": "6", "seq": 10, "text": "” 乃夜为狗，以入秦宫臧中，取所献狐白裘至，以献秦王幸姬。", "len": 29}
{"sid": "075_孟尝君列传.6.s11", "chapter": "075_孟尝君列传", "para": "6", "seq": 11, "text": "幸姬为言昭王，昭王释孟尝君。", "len": 14}
{"sid": "075_孟尝君列传.6.s12", "chapter": "075_孟尝君列传", "para": "6", "seq": 12, "text": "孟尝君得出，即驰去，更封传，变名姓以出关。", "len": 21}
{"sid": "075_孟尝君列传.6.s13", "chapter": "075_孟尝君列传", "para": "6", "seq": 13, "text": "夜半至函谷关。", "len": 7}
{"sid": "075_孟尝君列传.6.s14", "chapter": "075_孟尝君列传", "para": "6", "seq": 14, "text": "秦昭王後悔出孟尝君，求之已去，即使人驰传逐之。", "len": 23}
{"sid": "075_孟尝君列传.6.s15", "chapter": "075_孟尝君列传", "para": "6", "seq": 15, "text": "孟尝君至关，关法鸡鸣而出客，孟尝君恐追至，客之居下坐者有能为鸡鸣，而鸡齐鸣，遂发传出。", "len": 43}
{"sid": "075_孟尝君列传.6.s16", "chapter": "075_孟尝君列传", "para": "6", "seq": 16, "text": "出如食顷，秦追果至关，已後孟尝君出，乃还。", "len": 21}
{"sid": "075_孟尝君列传.6.s17", "chapter": "075_孟尝君列传", "para": "6", "seq": 17, "text": "始孟尝君列此二人於宾客，宾客尽羞之，及孟尝君有秦难，卒此二人拔之。", "len": 33}
{"sid": "075_孟尝君列传.6.s18", "chapter": "075_孟尝君列传", "para": "6", "seq": 18, "text": "自是之後，客皆服。", "len": 9}
{"sid": "075_孟尝君列传.7.s1", "chapter": "075_孟尝君列传", "para": "7", "seq": 1, "text": "孟尝君过赵，赵平原君客之。", "len": 13}
{"sid": "075_孟尝君列传.7.s2", "chapter": "075_孟尝君列传", "para": "7", "seq": 2, "text": "赵人闻孟尝君贤，出观之，皆笑曰：“始以薛公为魁然也，今视之，乃眇小丈夫耳。", "len": 37}
{"sid": "075_孟尝君列传.7.s3", "chapter": "075_孟尝君列传", "para": "7", "seq": 3, "text": "” 孟尝君闻之，怒。", "len": 10}
{"sid": "075_孟尝君列传.7.s4", "chapter": "075_孟尝君列传", "para": "7", "seq": 4, "text": "客与俱者下，斫击杀数百人，遂灭一县以去。", "len": 20}
{"sid": "075_孟尝君列传.8.s1", "chapter": "075_孟尝君列传", "para": "8", "seq": 1, "text": "齐湣王不自得，以其遣孟尝君。", "len": 14}
{"sid": "075_孟尝君列传.8.s2", "chapter": "075_孟尝君列传", "para": "8", "seq": 2, "text": "孟尝君至，则以为齐相，任政。", "len": 14}
{"sid": "075_孟尝君列传.9.s1", "chapter": "075_孟尝君列传", "para": "9", "seq": 1, "text": "孟尝君怨秦，将以齐为韩、魏攻楚，因与韩、魏攻秦，而借兵食於西周。", "len": 32}
{"sid": "075_孟尝君列传.9.s2", "chapter": "075_孟尝君列传", "para": "9", "seq": 2, "text": "苏代为西周谓曰：“君以齐为韩、魏攻楚九年，取宛、叶以北以彊韩、魏，今复攻秦以益之。", "len": 41}
{"sid": "075_孟尝君列传.9.s3", "chapter": "075_孟尝君列传", "para": "9", "seq": 3, "text": "韩、魏南无楚忧，西无秦患，则齐危矣。", "len": 18}
{"sid": "075_孟尝君列传.9.s4", "chapter": "075_孟尝君列传", "para": "9", "seq": 4, "text": "韩、魏必轻齐畏秦，臣为君危之。", "len": 15}
{"sid": "075_孟尝君列传.9.s5", "chapter": "075_孟尝君列传", "para": "9", "seq": 5, "text": "君不如令敝邑深合於秦，而君无攻，又无借兵食。", "len": 22}
{"sid": "075_孟尝君列传.9.s6", "chapter": "075_孟尝君列传", "para": "9", "seq": 6, "text": "君临函谷而无攻，令敝邑以君之情谓秦昭王曰‘薛公必不破秦以彊韩、魏。", "len": 33}
{"sid": "075_孟尝君列传.9.s7", "chapter": "075_孟尝君列传", "para": "9", "seq": 7, "text": "其攻秦也，欲王之令楚王割东国以与齐，而秦出楚怀王以为和’。", "len": 29}
{"sid": "075_孟尝君列传.9.s8", "chapter": "075_孟尝君列传", "para": "9", "seq": 8, "text": "君令敝邑以此惠秦，秦得无破而以东国自免也，秦必欲之。", "len": 26}
{"sid": "075_孟尝君列传.9.s9", "chapter": "075_孟尝君列传", "para": "9", "seq": 9, "text": "楚王得出，必德齐。", "len": 9}
{"sid": "075_孟尝君列传.9.s10", "chapter": "075_孟尝君列传", "para": "9", "seq": 10, "text": "齐得东国益彊，而薛世世无患矣。", "len": 15}
{"sid": "075_孟尝君列传.9.s11", "chapter": "075_孟尝君列传", "para": "9", "seq": 11, "text": "秦不大弱，而处三晋之西，三晋必重齐。", "len": 18}
{"sid": "075_孟尝君列传.9.s12", "chapter": "075_孟尝君列传", "para": "9", "seq": 12, "text": "” 薛公曰：“善。", "len": 9}
{"sid": "075_孟尝君列传.9.s13", "chapter": "075_孟尝君列传", "para": "9", "seq": 13, "text": "” 因令韩、魏贺秦，使三国无攻，而不借兵食於西周矣。", "len": 26}
{"sid": "075_孟尝君列传.9.s14", "chapter": "075_孟尝君列传", "para": "9", "seq": 14, "text": "是时，楚怀王入秦，秦留之，故欲必出之。", "len": 19}
{"sid": "075_孟尝君列传.9.s15", "chapter": "075_孟尝君列传", "para": "9", "seq": 15, "text": "秦不果出楚怀王。", "len": 8}
{"sid": "075_孟尝君列传.10.s1", "chapter": "075_孟尝君列传", "para": "10", "seq": 1, "text": "孟尝君相齐，其舍人魏子为孟尝君收邑入，三反而不致一入。", "len": 27}
{"sid": "075_孟尝君列传.10.s2", "chapter": "075_孟尝君列传", "para": "10", "seq": 2, "text": "孟尝君问之，对曰：“有贤者，窃假与之，以故不致入。", "len": 25}
{"sid": "075_孟尝君列传.10.s3", "chapter": "075_孟尝君列传", "para": "10", "seq": 3, "text": "” 孟尝君怒而退魏子。", "len": 11}
{"sid": "075_孟尝君列传.10.s4", "chapter": "075_孟尝君列传", "para": "10", "seq": 4, "text": "居数年，人或毁孟尝君於齐湣王曰：“孟尝君将为乱。", "len": 24}
{"sid": "075_孟尝君列传.10.s5", "chapter": "075_孟尝君列传", "para": "10", "seq": 5, "text": "” 及田甲劫湣王，湣王意疑孟尝君，孟尝君乃奔。", "len": 23}
{"sid": "075_孟尝君列传.10.s6", "chapter": "075_孟尝君列传", "para": "10", "seq": 6, "text": "魏子所与粟贤者闻之，乃上书言孟尝君不作乱，请以身为盟，遂自刭宫门以明孟尝君。", "len": 38}
{"sid": "075_孟尝君列传.10.s7", "chapter": "075_孟尝君列传", "para": "10", "seq": 7, "text": "湣王乃惊，而踪迹验问，孟尝君果无反谋，乃复召孟尝君。", "len": 26}
{"sid": "075_孟尝君列传.10.s8", "chapter": "075_孟尝君列传", "para": "10", "seq": 8, "text": "孟尝君因谢病，归老於薛。", "len": 12}
{"sid": "075_孟尝君列传.10.s9", "chapter": "075_孟尝君列传", "para": "10", "seq": 9, "text": "湣王许之。", "len": 5}
{"sid": "075_孟尝君列传.11.s1", "chapter": "075_孟尝君列传", "para": "11", "seq": 1, "text": "其後，秦亡将吕礼相齐，欲困苏代。", "len": 16}
{"sid": "075_孟尝君列传.11.s2", "chapter": "075_孟尝君列传", "para": "11", "seq": 2, "text": "代乃谓孟尝君曰：“周最於齐，至厚也，而齐王逐之，而听亲弗相吕礼者，欲取秦也。", "len": 38}
{"sid": "075_孟尝君列传.11.s3", "chapter": "075_孟尝君列传", "para": "11", "seq": 3, "text": "齐、秦合，则亲弗与吕礼重矣。", "len": 14}
{"sid": "075_孟尝君列传.11.s4", "chapter": "075_孟尝君列传", "para": "11", "seq": 4, "text": "有用，齐、秦必轻君。", "len": 10}
{"sid": "075_孟尝君列传.11.s5", "chapter": "075_孟尝君列传", "para": "11", "seq": 5, "text": "君不如急北兵，趋赵以和秦、魏，收周最以厚行，且反齐王之信，又禁天下之变。", "len": 36}
{"sid": "075_孟尝君列传.11.s6", "chapter": "075_孟尝君列传", "para": "11", "seq": 6, "text": "齐无秦，则天下集齐，亲弗必走，则齐王孰与为其国也！", "len": 25}
{"sid": "075_孟尝君列传.11.s7", "chapter": "075_孟尝君列传", "para": "11", "seq": 7, "text": "” 於是孟尝君从其计，而吕礼嫉害於孟尝君。", "len": 21}
{"sid": "075_孟尝君列传.12.s1", "chapter": "075_孟尝君列传", "para": "12", "seq": 1, "text": "孟尝君惧，乃遗秦相穰侯魏厓书曰：“吾闻秦欲以吕礼收齐，齐，天下之彊国也，子必轻矣。", "len": 41}
{"sid": "075_孟尝君列传.12.s2", "chapter": "075_孟尝君列传", "para": "12", "seq": 2, "text": "齐秦相取以临三晋，吕礼必并相矣，是子通齐以重吕礼也。", "len": 26}
{"sid": "075_孟尝君列传.12.s3", "chapter": "075_孟尝君列传", "para": "12", "seq": 3, "text": "若齐免於天下之兵，其雠子必深矣。", "len": 16}
{"sid": "075_孟尝君列传.12.s4", "chapter": "075_孟尝君列传", "para": "12", "seq": 4, "text": "子不如劝秦王伐齐。", "len": 9}
{"sid": "075_孟尝君列传.12.s5", "chapter": "075_孟尝君列传", "para": "12", "seq": 5, "text": "齐破，吾请以所得封子。", "len": 11}
{"sid": "075_孟尝君列传.12.s6", "chapter": "075_孟尝君列传", "para": "12", "seq": 6, "text": "齐破，秦畏晋之彊，秦必重子以取晋。", "len": 17}
{"sid": "075_孟尝君列传.12.s7", "chapter": "075_孟尝君列传", "para": "12", "seq": 7, "text": "晋国敝於齐而畏秦，晋必重子以取秦。", "len": 17}
{"sid": "075_孟尝君列传.12.s8", "chapter": "075_孟尝君列传", "para": "12", "seq": 8, "text": "是子破齐以为功，挟晋以为重；是子破齐定封，秦、晋交重子。", "len": 28}
{"sid": "075_孟尝君列传.12.s9", "chapter": "075_孟尝君列传", "para": "12", "seq": 9, "text": "若齐不破，吕礼复用，子必大穷。", "len": 15}
{"sid": "075_孟尝君列传.12.s10", "chapter": "075_孟尝君列传", "para": "12", "seq": 10, "text": "” 於是穰侯言於秦昭王伐齐，而吕礼亡。", "len": 19}
{"sid": "075_孟尝君列传.13.s1", "chapter": "075_孟尝君列传", "para": "13", "seq": 1, "text": "後齐湣王灭宋，益骄，欲去孟尝君。", "len": 16}
{"sid": "075_孟尝君列传.13.s2", "chapter": "075_孟尝君列传", "para": "13", "seq": 2, "text": "孟尝君恐，乃如魏。", "len": 9}
{"sid": "075_孟尝君列传.13.s3", "chapter": "075_孟尝君列传", "para": "13", "seq": 3, "text": "魏昭王以为相，西合於秦、赵，与燕共伐破齐。", "len": 21}
{"sid": "075_孟尝君列传.13.s4", "chapter": "075_孟尝君列传", "para": "13", "seq": 4, "text": "齐湣王亡在莒，遂死焉。", "len": 11}
{"sid": "075_孟尝君列传.13.s5", "chapter": "075_孟尝君列传", "para": "13", "seq": 5, "text": "齐襄王立，而孟尝君中立於诸侯，无所属。", "len": 19}
{"sid": "075_孟尝君列传.13.s6", "chapter": "075_孟尝君列传", "para": "13", "seq": 6, "text": "齐襄王新立，畏孟尝君，与连和，复亲薛公。", "len": 20}
{"sid": "075_孟尝君列传.13.s7", "chapter": "075_孟尝君列传", "para": "13", "seq": 7, "text": "文卒，谥为孟尝君。", "len": 9}
{"sid": "075_孟尝君列传.13.s8", "chapter": "075_孟尝君列传", "para": "13", "seq": 8, "text": "诸子争立，而齐魏共灭薛。", "len": 12}
{"sid": "075_孟尝君列传.13.s9", "chapter": "075_孟尝君列传", "para": "13", "seq": 9, "text": "孟尝绝嗣无後也。", "len": 8}
{"sid": "075_孟尝君列传.14.s1", "chapter": "075_孟尝君列传", "para": "14", "seq": 1, "text": "初，冯驩闻孟尝君好客，蹑蹻而见之。", "len": 17}
{"sid": "075_孟尝君列传.14.s2", "chapter": "075_孟尝君列传", "para": "14", "seq": 2, "text": "孟尝君曰；“先生远辱，何以教文也？", "len": 17}
{"sid": "075_孟尝君列传.14.s3", "chapter": "075_孟尝君列传", "para": "14", "seq": 3, "text": "” 冯驩曰：“闻君好士，以贫身归於君。", "len": 19}
{"sid": "075_孟尝君列传.14.s4", "chapter": "075_孟尝君列传", "para": "14", "seq": 4, "text": "” 孟尝君置传舍十日，孟尝君问传舍长曰：“客何所为？", "len": 26}
{"sid": "075_孟尝君列传.14.s5", "chapter": "075_孟尝君列传", "para": "14", "seq": 5, "text": "” 答曰：“冯先生甚贫，犹有一剑耳，又蒯缑。", "len": 22}
{"sid": "075_孟尝君列传.14.s6", "chapter": "075_孟尝君列传", "para": "14", "seq": 6, "text": "弹其剑而歌曰‘长铗归来乎，食无鱼’。", "len": 18}
{"sid": "075_孟尝君列传.14.s7", "chapter": "075_孟尝君列传", "para": "14", "seq": 7, "text": "” 孟尝君迁之幸舍，食有鱼矣。", "len": 15}
{"sid": "075_孟尝君列传.14.s8", "chapter": "075_孟尝君列传", "para": "14", "seq": 8, "text": "五日，又问传舍长。", "len": 9}
{"sid": "075_孟尝君列传.14.s9", "chapter": "075_孟尝君列传", "para": "14", "seq": 9, "text": "答曰：“客复弹剑而歌曰‘长铗归来乎，出无舆’。", "len": 23}
{"sid": "075_孟尝君列传.14.s10", "chapter": "075_孟尝君列传", "para": "14", "seq": 10, "text": "” 孟尝君迁之代舍，出入乘舆车矣。", "len": 17}
{"sid": "075_孟尝君列传.14.s11", "chapter": "075_孟尝君列传", "para": "14", "seq": 11, "text": "五日，孟尝君复问传舍长。", "len": 12}
{"sid": "075_孟尝君列传.14.s12", "chapter": "075_孟尝君列传", "para": "14", "seq": 12, "text": "舍长答曰：“先生又尝弹剑而歌曰‘长铗归来乎，无以为家’。", "len": 28}
{"sid": "075_孟尝君列传.14.s13", "chapter": "075_孟尝君列传", "para": "14", "seq": 13, "text": "” 孟尝君不悦。", "len": 8}
{"sid": "075_孟尝君列传.15.s1", "chapter": "075_孟尝君列传", "para": "15", "seq": 1, "text": "居期年，冯驩无所言。", "len": 10}
{"sid": "075_孟尝君列传.15.s2", "chapter": "075_孟尝君列传", "para": "15", "seq": 2, "text": "孟尝君时相齐，封万户於薛。", "len": 13}
{"sid": "075_孟尝君列传.15.s3", "chapter": "075_孟尝君列传", "para": "15", "seq": 3, "text": "其食客三千人。", "len": 7}
{"sid": "075_孟尝君列传.15.s4", "chapter": "075_孟尝君列传", "para": "15", "seq": 4, "text": "邑入不足以奉客，使人出钱於薛。", "len": 15}
{"sid": "075_孟尝君列传.15.s5", "chapter": "075_孟尝君列传", "para": "15", "seq": 5, "text": "岁馀不入，贷钱者多不能与其息，客奉将不给。", "len": 21}
{"sid": "075_孟尝君列传.15.s6", "chapter": "075_孟尝君列传", "para": "15", "seq": 6, "text": "孟尝君忧之，问左右：“何人可使收债於薛者？", "len": 21}
{"sid": "075_孟尝君列传.15.s7", "chapter": "075_孟尝君列传", "para": "15", "seq": 7, "text": "” 传舍长曰：“代舍客冯公形容状貌甚辩，长者，无他伎能，宜可令收债。", "len": 34}
{"sid": "075_孟尝君列传.15.s8", "chapter": "075_孟尝君列传", "para": "15", "seq": 8, "text": "” 孟尝君乃进冯驩而请之曰：“宾客不知文不肖，幸临文者三千馀人，邑入不足以奉宾客，故出息钱於薛。", "len": 48}
{"sid": "075_孟尝君列传.15.s9", "chapter": "075_孟尝君列传", "para": "15", "seq": 9, "text": "薛岁不入，民颇不与其息。", "len": 12}
{"sid": "075_孟尝君列传.15.s10", "chapter": "075_孟尝君列传", "para": "15", "seq": 10, "text": "今客食恐不给，原先生责之。", "len": 13}
{"sid": "075_孟尝君列传.15.s11", "chapter": "075_孟尝君列传", "para": "15", "seq": 11, "text": "” 冯驩曰；“诺。", "len": 9}
{"sid": "075_孟尝君列传.15.s12", "chapter": "075_孟尝君列传", "para": "15", "seq": 12, "text": "” 辞行，至薛，召取孟尝君钱者皆会，得息钱十万。", "len": 24}
{"sid": "075_孟尝君列传.15.s13", "chapter": "075_孟尝君列传", "para": "15", "seq": 13, "text": "乃多酿酒，买肥牛，召诸取钱者，能与息者皆来，不能与息者亦来，皆持取钱之券书合之。", "len": 40}
{"sid": "075_孟尝君列传.15.s14", "chapter": "075_孟尝君列传", "para": "15", "seq": 14, "text": "齐为会，日杀牛置酒。", "len": 10}
{"sid": "075_孟尝君列传.15.s15", "chapter": "075_孟尝君列传", "para": "15", "seq": 15, "text": "酒酣，乃持券如前合之，能与息者，与为期；贫不能与息者，取其券而烧之。", "len": 34}
{"sid": "075_孟尝君列传.15.s16", "chapter": "075_孟尝君列传", "para": "15", "seq": 16, "text": "曰：“孟尝君所以贷钱者，为民之无者以为本业也；所以求息者，为无以奉客也。", "len": 36}
{"sid": "075_孟尝君列传.15.s17", "chapter": "075_孟尝君列传", "para": "15", "seq": 17, "text": "今富给者以要期，贫穷者燔券书以捐之。", "len": 18}
{"sid": "075_孟尝君列传.15.s18", "chapter": "075_孟尝君列传", "para": "15", "seq": 18, "text": "诸君彊饮食。", "len": 6}
{"sid": "075_孟尝君列传.15.s19", "chapter": "075_孟尝君列传", "para": "15", "seq": 19, "text": "有君如此，岂可负哉！", "len": 10}
{"sid": "075_孟尝君列传.15.s20", "chapter": "075_孟尝君列传", "para": "15", "seq": 20, "text": "” 坐者皆起，再拜。", "len": 10}
{"sid": "075_孟尝君列传.16.s1", "chapter": "075_孟尝君列传", "para": "16", "seq": 1, "text": "孟尝君闻冯驩烧券书，怒而使使召驩。", "len": 17}
{"sid": "075_孟尝君列传.16.s2", "chapter": "075_孟尝君列传", "para": "16", "seq": 2, "text": "驩至，孟尝君曰：“文食客三千人，故贷钱於薛。", "len": 22}
{"sid": "075_孟尝君列传.16.s3", "chapter": "075_孟尝君列传", "para": "16", "seq": 3, "text": "文奉邑少，而民尚多不以时与其息，客食恐不足，故请先生收责之。", "len": 30}
{"sid": "075_孟尝君列传.16.s4", "chapter": "075_孟尝君列传", "para": "16", "seq": 4, "text": "闻先生得钱，即以多具牛酒而烧券书，何？", "len": 19}
{"sid": "075_孟尝君列传.16.s5", "chapter": "075_孟尝君列传", "para": "16", "seq": 5, "text": "” 冯驩曰：“然。", "len": 9}
{"sid": "075_孟尝君列传.16.s6", "chapter": "075_孟尝君列传", "para": "16", "seq": 6, "text": "不多具牛酒即不能毕会，无以知其有馀不足。", "len": 20}
{"sid": "075_孟尝君列传.16.s7", "chapter": "075_孟尝君列传", "para": "16", "seq": 7, "text": "有馀者，为要期。", "len": 8}
{"sid": "075_孟尝君列传.16.s8", "chapter": "075_孟尝君列传", "para": "16", "seq": 8, "text": "不足者，虽守而责之十年，息愈多，急，即以逃亡自捐之。", "len": 26}
{"sid": "075_孟尝君列传.16.s9", "chapter": "075_孟尝君列传", "para": "16", "seq": 9, "text": "若急，终无以偿，上则为君好利不爱士民，下则有离上抵负之名，非所以厉士民彰君声也。", "len": 40}
{"sid": "075_孟尝君列传.16.s10", "chapter": "075_孟尝君列传", "para": "16", "seq": 10, "text": "焚无用虚债之券，捐不可得之虚计，令薛民亲君而彰君之善声也，君有何疑焉！", "len": 35}
{"sid": "075_孟尝君列传.16.s11", "chapter": "075_孟尝君列传", "para": "16", "seq": 11, "text": "” 孟尝君乃拊手而谢之。", "len": 12}
{"sid": "075_孟尝君列传.17.s1", "chapter": "075_孟尝君列传", "para": "17", "seq": 1, "text": "齐王惑於秦、楚之毁，以为孟尝君名高其主而擅齐国之权，遂废孟尝君。", "len": 32}
{"sid": "075_孟尝君列传.17.s2", "chapter": "075_孟尝君列传", "para": "17", "seq": 2, "text": "诸客见孟尝君废，皆去。", "len": 11}
{"sid": "075_孟尝君列传.17.s3", "chapter": "075_孟尝君列传", "para": "17", "seq": 3, "text": "冯驩曰：“借臣车一乘，可以入秦者，必令君重於国而奉邑益广，可乎？", "len": 32}
{"sid": "075_孟尝君列传.17.s4", "chapter": "075_孟尝君列传", "para": "17", "seq": 4, "text": "” 孟尝君乃约车币而遣之。", "len": 13}
{"sid": "075_孟尝君列传.17.s5", "chapter": "075_孟尝君列传", "para": "17", "seq": 5, "text": "冯驩乃西说秦王曰：“天下之游士冯轼结靷西入秦者，无不欲彊秦而弱齐；冯轼结靷东入齐者，无不欲彊齐而弱秦。", "len": 51}
{"sid": "075_孟尝君列传.17.s6", "chapter": "075_孟尝君列传", "para": "17", "seq": 6, "text": "此雄雌之国也，势不两立为雄，雄者得天下矣。", "len": 21}
{"sid": "075_孟尝君列传.17.s7", "chapter": "075_孟尝君列传", "para": "17", "seq": 7, "text": "” 秦王跽而问之曰：“何以使秦无为雌而可？", "len": 21}
{"sid": "075_孟尝君列传.17.s8", "chapter": "075_孟尝君列传", "para": "17", "seq": 8, "text": "” 冯驩曰：“王亦知齐之废孟尝君乎？", "len": 18}
{"sid": "075_孟尝君列传.17.s9", "chapter": "075_孟尝君列传", "para": "17", "seq": 9, "text": "” 秦王曰：“闻之。", "len": 10}
{"sid": "075_孟尝君列传.17.s10", "chapter": "075_孟尝君列传", "para": "17", "seq": 10, "text": "” 冯驩曰：“使齐重於天下者，孟尝君也。", "len": 20}
{"sid": "075_孟尝君列传.17.s11", "chapter": "075_孟尝君列传", "para": "17", "seq": 11, "text": "今齐王以毁废之，其心怨，必背齐；背齐入秦，则齐国之情，人事之诚，尽委之秦，齐地可得也，岂直为雄也！", "len": 49}
{"sid": "075_孟尝君列传.17.s12", "chapter": "075_孟尝君列传", "para": "17", "seq": 12, "text": "君急使使载币阴迎孟尝君，不可失时也。", "len": 18}
{"sid": "075_孟尝君列传.17.s13", "chapter": "075_孟尝君列传", "para": "17", "seq": 13, "text": "如有齐觉悟，复用孟尝君，则雌雄之所在未可知也。", "len": 23}
{"sid": "075_孟尝君列传.17.s14", "chapter": "075_孟尝君列传", "para": "17", "seq": 14, "text": "” 秦王大悦，乃遣车十乘黄金百镒以迎孟尝君。", "len": 22}
{"sid": "075_孟尝君列传.17.s15", "chapter": "075_孟尝君列传", "para": "17", "seq": 15, "text": "冯驩辞以先行，至齐，说齐王曰：“天下之游士冯轼结靷东入齐者，无不欲彊齐而弱秦者；冯轼结靷西入秦者，无不欲彊秦而弱齐者。", "len": 59}
{"sid": "075_孟尝君列传.17.s16", "chapter": "075_孟尝君列传", "para": "17", "seq": 16, "text": "夫秦齐雄雌之国，秦彊则齐弱矣，此势不两雄。", "len": 21}
{"sid": "075_孟尝君列传.17.s17", "chapter": "075_孟尝君列传", "para": "17", "seq": 17, "text": "今臣窃闻秦遣使车十乘载黄金百镒以迎孟尝君。", "len": 21}
{"sid": "075_孟尝君列传.17.s18", "chapter": "075_孟尝君列传", "para": "17", "seq": 18, "text": "孟尝君不西则已，西入相秦则天下归之，秦为雄而齐为雌，雌则临淄、即墨危矣。", "len": 36}
{"sid": "075_孟尝君列传.17.s19", "chapter": "075_孟尝君列传", "para": "17", "seq": 19, "text": "王何不先秦使之未到，复孟尝君，而益与之邑以谢之？", "len": 24}
{"sid": "075_孟尝君列传.17.s20", "chapter": "075_孟尝君列传", "para": "17", "seq": 20, "text": "孟尝君必喜而受之。", "len": 9}
{"sid": "075_孟尝君列传.17.s21", "chapter": "075_孟尝君列传", "para": "17", "seq": 21, "text": "秦虽彊国，岂可以请人相而迎之哉！", "len": 16}
{"sid": "075_孟尝君列传.17.s22", "chapter": "075_孟尝君列传", "para": "17", "seq": 22, "text": "折秦之谋，而绝其霸彊之略。", "len": 13}
{"sid": "075_孟尝君列传.17.s23", "chapter": "075_孟尝君列传", "para": "17", "seq": 23, "text": "” 齐王曰：“善。", "len": 9}
{"sid": "075_孟尝君列传.17.s24", "chapter": "075_孟尝君列传", "para": "17", "seq": 24, "text": "” 乃使人至境候秦使。", "len": 11}
{"sid": "075_孟尝君列传.17.s25", "chapter": "075_孟尝君列传", "para": "17", "seq": 25, "text": "秦使车適入齐境，使还驰告之，王召孟尝君而复其相位，而与其故邑之地，又益以千户。", "len": 39}
{"sid": "075_孟尝君列传.17.s26", "chapter": "075_孟尝君列传", "para": "17", "seq": 26, "text": "秦之使者闻孟尝君复相齐，还车而去矣。", "len": 18}
{"sid": "075_孟尝君列传.18.s1", "chapter": "075_孟尝君列传", "para": "18", "seq": 1, "text": "自齐王毁废孟尝君，诸客皆去。", "len": 14}
{"sid": "075_孟尝君列传.18.s2", "chapter": "075_孟尝君列传", "para": "18", "seq": 2, "text": "後召而复之，冯驩迎之。", "len": 11}
{"sid": "075_孟尝君列传.18.s3", "chapter": "075_孟尝君列传", "para": "18", "seq": 3, "text": "未到，孟尝君太息叹曰：“文常好客，遇客无所敢失，食客三千有馀人，先生所知也。", "len": 38}
{"sid": "075_孟尝君列传.18.s4", "chapter": "075_孟尝君列传", "para": "18", "seq": 4, "text": "客见文一日废，皆背文而去，莫顾文者。", "len": 18}
{"sid": "075_孟尝君列传.18.s5", "chapter": "075_孟尝君列传", "para": "18", "seq": 5, "text": "今赖先生得复其位，客亦有何面目复见文乎？", "len": 20}
{"sid": "075_孟尝君列传.18.s6", "chapter": "075_孟尝君列传", "para": "18", "seq": 6, "text": "如复见文者，必唾其面而大辱之。", "len": 15}
{"sid": "075_孟尝君列传.18.s7", "chapter": "075_孟尝君列传", "para": "18", "seq": 7, "text": "” 冯驩结辔下拜。", "len": 9}
{"sid": "075_孟尝君列传.18.s8", "chapter": "075_孟尝君列传", "para": "18", "seq": 8, "text": "孟尝君下车接之，曰：“先生为客谢乎？", "len": 18}
{"sid": "075_孟尝君列传.18.s9", "chapter": "075_孟尝君列传", "para": "18", "seq": 9, "text": "” 冯驩曰：“非为客谢也，为君之言失。", "len": 19}
{"sid": "075_孟尝君列传.18.s10", "chapter": "075_孟尝君列传", "para": "18", "seq": 10, "text": "夫物有必至，事有固然，君知之乎？", "len": 16}
{"sid": "075_孟尝君列传.18.s11", "chapter": "075_孟尝君列传", "para": "18", "seq": 11, "text": "” 孟尝君曰：“愚不知所谓也。", "len": 15}
{"sid": "075_孟尝君列传.18.s12", "chapter": "075_孟尝君列传", "para": "18", "seq": 12, "text": "” 曰：“生者必有死，物之必至也；富贵多士，贫贱寡友，事之固然也。", "len": 33}
{"sid": "075_孟尝君列传.18.s13", "chapter": "075_孟尝君列传", "para": "18", "seq": 13, "text": "君独不见夫趣市者乎？", "len": 10}
{"sid": "075_孟尝君列传.18.s14", "chapter": "075_孟尝君列传", "para": "18", "seq": 14, "text": "明旦，侧肩争门而入；日暮之後，过市朝者掉臂而不顾。", "len": 25}
{"sid": "075_孟尝君列传.18.s15", "chapter": "075_孟尝君列传", "para": "18", "seq": 15, "text": "非好朝而恶暮，所期物忘其中。", "len": 14}
{"sid": "075_孟尝君列传.18.s16", "chapter": "075_孟尝君列传", "para": "18", "seq": 16, "text": "今君失位，宾客皆去，不足以怨士而徒绝宾客之路。", "len": 23}
{"sid": "075_孟尝君列传.18.s17", "chapter": "075_孟尝君列传", "para": "18", "seq": 17, "text": "原君遇客如故。", "len": 7}
{"sid": "075_孟尝君列传.18.s18", "chapter": "075_孟尝君列传", "para": "18", "seq": 18, "text": "” 孟尝君再拜曰：“敬从命矣。", "len": 15}
{"sid": "075_孟尝君列传.18.s19", "chapter": "075_孟尝君列传", "para": "18", "seq": 19, "text": "闻先生之言，敢不奉教焉。", "len": 12}
{"sid": "075_孟尝君列传.18.s20", "chapter": "075_孟尝君列传", "para": "18", "seq": 20, "text": "” ::: 太史公曰", "len": 10}
{"sid": "075_孟尝君列传.19.s1", "chapter": "075_孟尝君列传", "para": "19", "seq": 1, "text": "太史公曰：吾尝过薛，其俗闾里率多暴桀子弟，与邹、鲁殊。", "len": 27}
{"sid": "075_孟尝君列传.19.s2", "chapter": "075_孟尝君列传", "para": "19", "seq": 2, "text": "问其故，曰：“孟尝君招致天下任侠，奸人入薛中盖六万馀家矣。", "len": 29}
{"sid": "075_孟尝君列传.19.s3", "chapter": "075_孟尝君列传", "para": "19", "seq": 3, "text": "” 世之传孟尝君好客自喜，名不虚矣。", "len": 18}
{"sid": "075_孟尝君列传.19.s4", "chapter": "075_孟尝君列传", "para": "19", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "075_孟尝君列传.20.s1", "chapter": "075_孟尝君列传", "para": "20", "seq": 1, "text": "靖郭之子，威王之孙。", "len": 10}
{"sid": "075_孟尝君列传.20.s2", "chapter": "075_孟尝君列传", "para": "20", "seq": 2, "text": "既彊其国，实高其门。", "len": 10}
{"sid": "075_孟尝君列传.20.s3", "chapter": "075_孟尝君列传", "para": "20", "seq": 3, "text": "好客喜士，见重平原。", "len": 10}
{"sid": "075_孟尝君列传.20.s4", "chapter": "075_孟尝君列传", "para": "20", "seq": 4, "text": "鸡鸣狗盗，魏子、冯暖。", "len": 11}
{"sid": "075_孟尝君列传.20.s5", "chapter": "075_孟尝君列传", "para": "20", "seq": 5, "text": "如何承睫，薛县徒存！", "len": 10}
{"sid": "075_孟尝君列传.20.s6", "chapter": "075_孟尝君列传", "para": "20", "seq": 6, "text": ":::", "len": 3}
