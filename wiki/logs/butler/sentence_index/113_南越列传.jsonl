{"sid": "113_南越列传.1.s1", "chapter": "113_南越列传", "para": "1", "seq": 1, "text": "南越王尉佗者，真定人也，姓赵氏。", "len": 16}
{"sid": "113_南越列传.1.s2", "chapter": "113_南越列传", "para": "1", "seq": 2, "text": "秦时已并天下，略定杨越，置桂林、南海、象郡，以谪徙民，与越杂处十三岁。", "len": 35}
{"sid": "113_南越列传.1.s3", "chapter": "113_南越列传", "para": "1", "seq": 3, "text": "佗，秦时用为南海龙川令。", "len": 12}
{"sid": "113_南越列传.1.s4", "chapter": "113_南越列传", "para": "1", "seq": 4, "text": "至二世时，南海尉任嚣病且死，召龙川令赵佗语曰：“闻陈胜等作乱，秦为无道，天下苦之，项羽、刘季、陈胜、吴广等州郡各共兴军聚众，虎争天下，中国扰乱，未知所安，豪杰畔秦相立。", "len": 84}
{"sid": "113_南越列传.1.s5", "chapter": "113_南越列传", "para": "1", "seq": 5, "text": "南海僻远，吾恐盗兵侵地至此，吾欲兴兵绝新道，自备，待诸侯变，会病甚。", "len": 34}
{"sid": "113_南越列传.1.s6", "chapter": "113_南越列传", "para": "1", "seq": 6, "text": "且番禺负山险，阻南海，东西数千里，颇有中国人相辅，此亦一州之主也，可以立国。", "len": 38}
{"sid": "113_南越列传.1.s7", "chapter": "113_南越列传", "para": "1", "seq": 7, "text": "郡中长吏无足与言者，故召公告之。", "len": 16}
{"sid": "113_南越列传.1.s8", "chapter": "113_南越列传", "para": "1", "seq": 8, "text": "” 即被佗书，行南海尉事。", "len": 13}
{"sid": "113_南越列传.1.s9", "chapter": "113_南越列传", "para": "1", "seq": 9, "text": "嚣死，佗即移檄告横浦、阳山、湟谿关曰：“盗兵且至，急绝道聚兵自守！", "len": 33}
{"sid": "113_南越列传.1.s10", "chapter": "113_南越列传", "para": "1", "seq": 10, "text": "” 因稍以法诛秦所置长吏，以其党为假守。", "len": 20}
{"sid": "113_南越列传.1.s11", "chapter": "113_南越列传", "para": "1", "seq": 11, "text": "秦已破灭，佗即击并桂林、象郡，自立为南越武王。", "len": 23}
{"sid": "113_南越列传.1.s12", "chapter": "113_南越列传", "para": "1", "seq": 12, "text": "高帝已定天下，为中国劳苦，故释佗弗诛。", "len": 19}
{"sid": "113_南越列传.2.s1", "chapter": "113_南越列传", "para": "2", "seq": 1, "text": "汉十一年，遣陆贾因立佗为南越王，与剖符通使，和集百越，毋为南边患害，与长沙接境。", "len": 40}
{"sid": "113_南越列传.3.s1", "chapter": "113_南越列传", "para": "3", "seq": 1, "text": "高后时，有司请禁南越关市铁器。", "len": 15}
{"sid": "113_南越列传.3.s2", "chapter": "113_南越列传", "para": "3", "seq": 2, "text": "佗曰：“高帝立我，通使物，今高后听谗臣，别异蛮夷，隔绝器物，此必长沙王计也，欲倚中国，击灭南越而并王之，自为功也。", "len": 57}
{"sid": "113_南越列传.3.s3", "chapter": "113_南越列传", "para": "3", "seq": 3, "text": "” 於是佗乃自尊号为南越武帝，发兵攻长沙边邑，败数县而去焉。", "len": 30}
{"sid": "113_南越列传.3.s4", "chapter": "113_南越列传", "para": "3", "seq": 4, "text": "高后遣将军隆虑侯灶往击之。", "len": 13}
{"sid": "113_南越列传.3.s5", "chapter": "113_南越列传", "para": "3", "seq": 5, "text": "会暑湿，士卒大疫，兵不能逾岭。", "len": 15}
{"sid": "113_南越列传.3.s6", "chapter": "113_南越列传", "para": "3", "seq": 6, "text": "岁馀，高后崩，即罢兵。", "len": 11}
{"sid": "113_南越列传.3.s7", "chapter": "113_南越列传", "para": "3", "seq": 7, "text": "佗因此以兵威边，财物赂遗闽越、西瓯、骆，役属焉，东西万馀里。", "len": 30}
{"sid": "113_南越列传.3.s8", "chapter": "113_南越列传", "para": "3", "seq": 8, "text": "乃乘黄屋左纛，称制，与中国侔。", "len": 15}
{"sid": "113_南越列传.4.s1", "chapter": "113_南越列传", "para": "4", "seq": 1, "text": "及孝文帝元年，初镇抚天下，使告诸侯四夷从代来即位意，喻盛德焉。", "len": 31}
{"sid": "113_南越列传.4.s2", "chapter": "113_南越列传", "para": "4", "seq": 2, "text": "乃为佗亲冢在真定，置守邑，岁时奉祀。", "len": 18}
{"sid": "113_南越列传.4.s3", "chapter": "113_南越列传", "para": "4", "seq": 3, "text": "召其从昆弟，尊官厚赐宠之。", "len": 13}
{"sid": "113_南越列传.4.s4", "chapter": "113_南越列传", "para": "4", "seq": 4, "text": "诏丞相陈平等举可使南越者，平言好畤陆贾，先帝时习使南越。", "len": 28}
{"sid": "113_南越列传.4.s5", "chapter": "113_南越列传", "para": "4", "seq": 5, "text": "乃召贾以为太中大夫，往使。", "len": 13}
{"sid": "113_南越列传.4.s6", "chapter": "113_南越列传", "para": "4", "seq": 6, "text": "因让佗自立为帝，曾无一介之使报者。", "len": 17}
{"sid": "113_南越列传.4.s7", "chapter": "113_南越列传", "para": "4", "seq": 7, "text": "陆贾至南越，王甚恐，为书谢，称曰：“蛮夷大长老夫臣佗，前日高后隔异南越，窃疑长沙王谗臣，又遥闻高后尽诛佗宗族，掘烧先人冢，以故自弃，犯长沙边境。", "len": 72}
{"sid": "113_南越列传.4.s8", "chapter": "113_南越列传", "para": "4", "seq": 8, "text": "且南方卑湿，蛮夷中间，其东闽越千人众号称王，其西瓯骆裸国亦称王。", "len": 32}
{"sid": "113_南越列传.4.s9", "chapter": "113_南越列传", "para": "4", "seq": 9, "text": "老臣妄窃帝号，聊以自娱，岂敢以闻天王哉！", "len": 20}
{"sid": "113_南越列传.4.s10", "chapter": "113_南越列传", "para": "4", "seq": 10, "text": "” 乃顿首谢，原长为籓臣，奉贡职。", "len": 17}
{"sid": "113_南越列传.4.s11", "chapter": "113_南越列传", "para": "4", "seq": 11, "text": "於是乃下令国中曰：“吾闻两雄不俱立，两贤不并世。", "len": 24}
{"sid": "113_南越列传.4.s12", "chapter": "113_南越列传", "para": "4", "seq": 12, "text": "皇帝，贤天子也。", "len": 8}
{"sid": "113_南越列传.4.s13", "chapter": "113_南越列传", "para": "4", "seq": 13, "text": "自今以後，去帝制黄屋左纛。", "len": 13}
{"sid": "113_南越列传.4.s14", "chapter": "113_南越列传", "para": "4", "seq": 14, "text": "” 陆贾还报，孝文帝大说。", "len": 13}
{"sid": "113_南越列传.4.s15", "chapter": "113_南越列传", "para": "4", "seq": 15, "text": "遂至孝景时，称臣，使人朝请。", "len": 14}
{"sid": "113_南越列传.4.s16", "chapter": "113_南越列传", "para": "4", "seq": 16, "text": "然南越其居国窃如故号名，其使天子，称王朝命如诸侯。", "len": 25}
{"sid": "113_南越列传.4.s17", "chapter": "113_南越列传", "para": "4", "seq": 17, "text": "至建元四年卒。", "len": 7}
{"sid": "113_南越列传.5.s1", "chapter": "113_南越列传", "para": "5", "seq": 1, "text": "佗孙胡为南越王。", "len": 8}
{"sid": "113_南越列传.5.s2", "chapter": "113_南越列传", "para": "5", "seq": 2, "text": "此时闽越王郢兴兵击南越边邑，胡使人上书曰：“两越俱为籓臣，毋得擅兴兵相攻击。", "len": 38}
{"sid": "113_南越列传.5.s3", "chapter": "113_南越列传", "para": "5", "seq": 3, "text": "今闽越兴兵侵臣，臣不敢兴兵，唯天子诏之。", "len": 20}
{"sid": "113_南越列传.5.s4", "chapter": "113_南越列传", "para": "5", "seq": 4, "text": "” 於是天子多南越义，守职约，为兴师，遣两将军往讨闽越。", "len": 28}
{"sid": "113_南越列传.5.s5", "chapter": "113_南越列传", "para": "5", "seq": 5, "text": "兵未逾岭，闽越王弟馀善杀郢以降，於是罢兵。", "len": 21}
{"sid": "113_南越列传.6.s1", "chapter": "113_南越列传", "para": "6", "seq": 1, "text": "天子使庄助往谕意南越王，胡顿首曰：“天子乃为臣兴兵讨闽越，死无以报德！", "len": 35}
{"sid": "113_南越列传.6.s2", "chapter": "113_南越列传", "para": "6", "seq": 2, "text": "” 遣太子婴齐入宿卫。", "len": 11}
{"sid": "113_南越列传.6.s3", "chapter": "113_南越列传", "para": "6", "seq": 3, "text": "谓助曰：“国新被寇，使者行矣。", "len": 15}
{"sid": "113_南越列传.6.s4", "chapter": "113_南越列传", "para": "6", "seq": 4, "text": "胡方日夜装入见天子。", "len": 10}
{"sid": "113_南越列传.6.s5", "chapter": "113_南越列传", "para": "6", "seq": 5, "text": "” 助去後，其大臣谏胡曰：“汉兴兵诛郢，亦行以惊动南越。", "len": 28}
{"sid": "113_南越列传.6.s6", "chapter": "113_南越列传", "para": "6", "seq": 6, "text": "且先王昔言，事天子期无失礼，要之不可以说好语入见。", "len": 25}
{"sid": "113_南越列传.6.s7", "chapter": "113_南越列传", "para": "6", "seq": 7, "text": "入见则不得复归，亡国之势也。", "len": 14}
{"sid": "113_南越列传.6.s8", "chapter": "113_南越列传", "para": "6", "seq": 8, "text": "” 於是胡称病，竟不入见。", "len": 13}
{"sid": "113_南越列传.6.s9", "chapter": "113_南越列传", "para": "6", "seq": 9, "text": "後十馀岁，胡实病甚，太子婴齐请归。", "len": 17}
{"sid": "113_南越列传.6.s10", "chapter": "113_南越列传", "para": "6", "seq": 10, "text": "胡薨，谥为文王。", "len": 8}
{"sid": "113_南越列传.7.s1", "chapter": "113_南越列传", "para": "7", "seq": 1, "text": "婴齐代立，即藏其先武帝玺。", "len": 13}
{"sid": "113_南越列传.7.s2", "chapter": "113_南越列传", "para": "7", "seq": 2, "text": "婴齐其入宿卫在长安时，取邯郸樛氏女，生子兴。", "len": 22}
{"sid": "113_南越列传.7.s3", "chapter": "113_南越列传", "para": "7", "seq": 3, "text": "及即位，上书请立樛氏女为后，兴为嗣。", "len": 18}
{"sid": "113_南越列传.7.s4", "chapter": "113_南越列传", "para": "7", "seq": 4, "text": "汉数使使者风谕婴齐，婴齐尚乐擅杀生自恣，惧入见要用汉法，比内诸侯，固称病，遂不入见。", "len": 42}
{"sid": "113_南越列传.7.s5", "chapter": "113_南越列传", "para": "7", "seq": 5, "text": "遣子次公入宿卫。", "len": 8}
{"sid": "113_南越列传.7.s6", "chapter": "113_南越列传", "para": "7", "seq": 6, "text": "婴齐薨，谥为明王。", "len": 9}
{"sid": "113_南越列传.8.s1", "chapter": "113_南越列传", "para": "8", "seq": 1, "text": "太子兴代立，其母为太后。", "len": 12}
{"sid": "113_南越列传.8.s2", "chapter": "113_南越列传", "para": "8", "seq": 2, "text": "太后自未为婴齐姬时，尝与霸陵人安国少季通。", "len": 21}
{"sid": "113_南越列传.8.s3", "chapter": "113_南越列传", "para": "8", "seq": 3, "text": "及婴齐薨後，元鼎四年，汉使安国少季往谕王、王太后以入朝，比内诸侯；令辩士谏大夫终军等宣其辞，勇士魏臣等辅其缺，卫尉路博德将兵屯桂阳，待使者。", "len": 70}
{"sid": "113_南越列传.8.s4", "chapter": "113_南越列传", "para": "8", "seq": 4, "text": "王年少，太后中国人也，尝与安国少季通，其使复私焉。", "len": 25}
{"sid": "113_南越列传.8.s5", "chapter": "113_南越列传", "para": "8", "seq": 5, "text": "国人颇知之，多不附太后。", "len": 12}
{"sid": "113_南越列传.8.s6", "chapter": "113_南越列传", "para": "8", "seq": 6, "text": "太后恐乱起，亦欲倚汉威，数劝王及群臣求内属。", "len": 22}
{"sid": "113_南越列传.8.s7", "chapter": "113_南越列传", "para": "8", "seq": 7, "text": "即因使者上书，请比内诸侯，三岁一朝，除边关。", "len": 22}
{"sid": "113_南越列传.8.s8", "chapter": "113_南越列传", "para": "8", "seq": 8, "text": "於是天子许之，赐其丞相吕嘉银印，及内史、中尉、太傅印，馀得自置。", "len": 32}
{"sid": "113_南越列传.8.s9", "chapter": "113_南越列传", "para": "8", "seq": 9, "text": "除其故黥劓刑，用汉法，比内诸侯。", "len": 16}
{"sid": "113_南越列传.8.s10", "chapter": "113_南越列传", "para": "8", "seq": 10, "text": "使者皆留填抚之。", "len": 8}
{"sid": "113_南越列传.8.s11", "chapter": "113_南越列传", "para": "8", "seq": 11, "text": "王、王太后饬治行装重赍，为入朝具。", "len": 17}
{"sid": "113_南越列传.9.s1", "chapter": "113_南越列传", "para": "9", "seq": 1, "text": "其相吕嘉年长矣，相三王，宗族官仕为长吏者七十馀人，男尽尚王女，女尽嫁王子兄弟宗室，及苍梧秦王有连。", "len": 49}
{"sid": "113_南越列传.9.s2", "chapter": "113_南越列传", "para": "9", "seq": 2, "text": "其居国中甚重，越人信之，多为耳目者，得众心愈於王。", "len": 25}
{"sid": "113_南越列传.9.s3", "chapter": "113_南越列传", "para": "9", "seq": 3, "text": "王之上书，数谏止王，王弗听。", "len": 14}
{"sid": "113_南越列传.9.s4", "chapter": "113_南越列传", "para": "9", "seq": 4, "text": "有畔心，数称病不见汉使者。", "len": 13}
{"sid": "113_南越列传.9.s5", "chapter": "113_南越列传", "para": "9", "seq": 5, "text": "使者皆注意嘉，势未能诛。", "len": 12}
{"sid": "113_南越列传.9.s6", "chapter": "113_南越列传", "para": "9", "seq": 6, "text": "王、王太后亦恐嘉等先事发，乃置酒，介汉使者权，谋诛嘉等。", "len": 28}
{"sid": "113_南越列传.9.s7", "chapter": "113_南越列传", "para": "9", "seq": 7, "text": "使者皆东乡，太后南乡，王北乡，相嘉、大臣皆西乡，侍坐饮。", "len": 28}
{"sid": "113_南越列传.9.s8", "chapter": "113_南越列传", "para": "9", "seq": 8, "text": "嘉弟为将，将卒居宫外。", "len": 11}
{"sid": "113_南越列传.9.s9", "chapter": "113_南越列传", "para": "9", "seq": 9, "text": "酒行，太后谓嘉曰：“南越内属，国之利也，而相君苦不便者，何也？", "len": 31}
{"sid": "113_南越列传.9.s10", "chapter": "113_南越列传", "para": "9", "seq": 10, "text": "” 以激怒使者。", "len": 8}
{"sid": "113_南越列传.9.s11", "chapter": "113_南越列传", "para": "9", "seq": 11, "text": "使者狐疑相杖，遂莫敢发。", "len": 12}
{"sid": "113_南越列传.9.s12", "chapter": "113_南越列传", "para": "9", "seq": 12, "text": "嘉见耳目非是，即起而出。", "len": 12}
{"sid": "113_南越列传.9.s13", "chapter": "113_南越列传", "para": "9", "seq": 13, "text": "太后怒，欲鏦嘉以矛，王止太后。", "len": 15}
{"sid": "113_南越列传.9.s14", "chapter": "113_南越列传", "para": "9", "seq": 14, "text": "嘉遂出，分其弟兵就舍，称病，不肯见王及使者。", "len": 22}
{"sid": "113_南越列传.9.s15", "chapter": "113_南越列传", "para": "9", "seq": 15, "text": "乃阴与大臣作乱。", "len": 8}
{"sid": "113_南越列传.9.s16", "chapter": "113_南越列传", "para": "9", "seq": 16, "text": "王素无意诛嘉，嘉知之，以故数月不发。", "len": 18}
{"sid": "113_南越列传.9.s17", "chapter": "113_南越列传", "para": "9", "seq": 17, "text": "太后有淫行，国人不附，欲独诛嘉等，力又不能。", "len": 22}
{"sid": "113_南越列传.10.s1", "chapter": "113_南越列传", "para": "10", "seq": 1, "text": "天子闻嘉不听王，王、王太后弱孤不能制，使者怯无决。", "len": 25}
{"sid": "113_南越列传.10.s2", "chapter": "113_南越列传", "para": "10", "seq": 2, "text": "又以为王、王太后已附汉，独吕嘉为乱，不足以兴兵，欲使庄参以二千人往使。", "len": 35}
{"sid": "113_南越列传.10.s3", "chapter": "113_南越列传", "para": "10", "seq": 3, "text": "参曰：“以好往，数人足矣；以武往，二千人无足以为也。", "len": 26}
{"sid": "113_南越列传.10.s4", "chapter": "113_南越列传", "para": "10", "seq": 4, "text": "” 辞不可，天子罢参也。", "len": 12}
{"sid": "113_南越列传.10.s5", "chapter": "113_南越列传", "para": "10", "seq": 5, "text": "郏壮士故济北相韩千秋奋曰：“以区区之越，又有王、太后应，独相吕嘉为害，原得勇士二百人，必斩嘉以报。", "len": 49}
{"sid": "113_南越列传.10.s6", "chapter": "113_南越列传", "para": "10", "seq": 6, "text": "” 於是天子遣千秋与王太后弟樛乐将二千人往，入越境。", "len": 26}
{"sid": "113_南越列传.10.s7", "chapter": "113_南越列传", "para": "10", "seq": 7, "text": "吕嘉等乃遂反，下令国中曰：“王年少。", "len": 18}
{"sid": "113_南越列传.10.s8", "chapter": "113_南越列传", "para": "10", "seq": 8, "text": "太后，中国人也，又与使者乱，专欲内属，尽持先王宝器入献天子以自媚，多从人，行至长安，虏卖以为僮仆。", "len": 49}
{"sid": "113_南越列传.10.s9", "chapter": "113_南越列传", "para": "10", "seq": 9, "text": "取自脱一时之利，无顾赵氏社稷，为万世虑计之意。", "len": 23}
{"sid": "113_南越列传.10.s10", "chapter": "113_南越列传", "para": "10", "seq": 10, "text": "” 乃与其弟将卒攻杀王、太后及汉使者。", "len": 19}
{"sid": "113_南越列传.10.s11", "chapter": "113_南越列传", "para": "10", "seq": 11, "text": "遣人告苍梧秦王及其诸郡县，立明王长男越妻子术阳侯建德为王。", "len": 29}
{"sid": "113_南越列传.10.s12", "chapter": "113_南越列传", "para": "10", "seq": 12, "text": "而韩千秋兵入，破数小邑。", "len": 12}
{"sid": "113_南越列传.10.s13", "chapter": "113_南越列传", "para": "10", "seq": 13, "text": "其後越直开道给食，未至番禺四十里，越以兵击千秋等，遂灭之。", "len": 29}
{"sid": "113_南越列传.10.s14", "chapter": "113_南越列传", "para": "10", "seq": 14, "text": "使人函封汉使者节置塞上，好为谩辞谢罪，发兵守要害处。", "len": 26}
{"sid": "113_南越列传.10.s15", "chapter": "113_南越列传", "para": "10", "seq": 15, "text": "於是天子曰：“韩千秋虽无成功，亦军锋之冠。", "len": 21}
{"sid": "113_南越列传.10.s16", "chapter": "113_南越列传", "para": "10", "seq": 16, "text": "” 封其子延年为成安侯。", "len": 12}
{"sid": "113_南越列传.10.s17", "chapter": "113_南越列传", "para": "10", "seq": 17, "text": "樛乐，其姊为王太后，首原属汉，封其子广德为龙亢侯。", "len": 25}
{"sid": "113_南越列传.10.s18", "chapter": "113_南越列传", "para": "10", "seq": 18, "text": "乃下赦曰：“天子微，诸侯力政，讥臣不讨贼。", "len": 21}
{"sid": "113_南越列传.10.s19", "chapter": "113_南越列传", "para": "10", "seq": 19, "text": "今吕嘉、建德等反，自立晏如，令罪人及江淮以南楼船十万师往讨之。”", "len": 32}
{"sid": "113_南越列传.11.s1", "chapter": "113_南越列传", "para": "11", "seq": 1, "text": "元鼎五年秋，卫尉路博德为伏波将军，出桂阳，下汇水；主爵都尉杨仆为楼船将军，出豫章，下横浦；故归义越侯二人为戈船、下厉将军，出零陵，或下离水，或柢苍梧；使驰义侯因巴蜀罪人，发夜郎兵，下牂柯江：咸会番禺。", "len": 100}
{"sid": "113_南越列传.12.s1", "chapter": "113_南越列传", "para": "12", "seq": 1, "text": "元鼎六年冬，楼船将军将精卒先陷寻陕，破石门，得越船粟，因推而前，挫越锋，以数万人待伏波。", "len": 44}
{"sid": "113_南越列传.12.s2", "chapter": "113_南越列传", "para": "12", "seq": 2, "text": "伏波将军将罪人，道远，会期後，与楼船会乃有千馀人，遂俱进。", "len": 29}
{"sid": "113_南越列传.12.s3", "chapter": "113_南越列传", "para": "12", "seq": 3, "text": "楼船居前，至番禺。", "len": 9}
{"sid": "113_南越列传.12.s4", "chapter": "113_南越列传", "para": "12", "seq": 4, "text": "建德、嘉皆城守。", "len": 8}
{"sid": "113_南越列传.12.s5", "chapter": "113_南越列传", "para": "12", "seq": 5, "text": "楼船自择便处，居东南面；伏波居西北面。", "len": 19}
{"sid": "113_南越列传.12.s6", "chapter": "113_南越列传", "para": "12", "seq": 6, "text": "会暮，楼船攻败越人，纵火烧城。", "len": 15}
{"sid": "113_南越列传.12.s7", "chapter": "113_南越列传", "para": "12", "seq": 7, "text": "越素闻伏波名，日暮，不知其兵多少。", "len": 17}
{"sid": "113_南越列传.12.s8", "chapter": "113_南越列传", "para": "12", "seq": 8, "text": "伏波乃为营，遣使者招降者，赐印，复纵令相招。", "len": 22}
{"sid": "113_南越列传.12.s9", "chapter": "113_南越列传", "para": "12", "seq": 9, "text": "楼船力攻烧敌，反驱而入伏波营中。", "len": 16}
{"sid": "113_南越列传.12.s10", "chapter": "113_南越列传", "para": "12", "seq": 10, "text": "犁旦，城中皆降伏波。", "len": 10}
{"sid": "113_南越列传.12.s11", "chapter": "113_南越列传", "para": "12", "seq": 11, "text": "吕嘉、建德已夜与其属数百人亡入海，以船西去。", "len": 22}
{"sid": "113_南越列传.12.s12", "chapter": "113_南越列传", "para": "12", "seq": 12, "text": "伏波又因问所得降者贵人，以知吕嘉所之，遣人追之。", "len": 24}
{"sid": "113_南越列传.12.s13", "chapter": "113_南越列传", "para": "12", "seq": 13, "text": "以其故校尉司马苏弘得建德，封为海常侯；越郎都稽得嘉，封为临蔡侯。", "len": 32}
{"sid": "113_南越列传.13.s1", "chapter": "113_南越列传", "para": "13", "seq": 1, "text": "苍梧王赵光者，越王同姓，闻汉兵至，及越揭阳令定自定属汉；越桂林监居翁谕瓯骆属汉：皆得为侯。", "len": 45}
{"sid": "113_南越列传.13.s2", "chapter": "113_南越列传", "para": "13", "seq": 2, "text": "戈船、下厉将军兵及驰义侯所发夜郎兵未下，南越已平矣。", "len": 26}
{"sid": "113_南越列传.13.s3", "chapter": "113_南越列传", "para": "13", "seq": 3, "text": "遂为九郡。", "len": 5}
{"sid": "113_南越列传.13.s4", "chapter": "113_南越列传", "para": "13", "seq": 4, "text": "伏波将军益封。", "len": 7}
{"sid": "113_南越列传.13.s5", "chapter": "113_南越列传", "para": "13", "seq": 5, "text": "楼船将军兵以陷坚为将梁侯。", "len": 13}
{"sid": "113_南越列传.14.s1", "chapter": "113_南越列传", "para": "14", "seq": 1, "text": "自尉佗初王後，五世九十三岁而国亡焉。", "len": 18}
{"sid": "113_南越列传.14.s2", "chapter": "113_南越列传", "para": "14", "seq": 2, "text": "::: 赞", "len": 5}
{"sid": "113_南越列传.15.s1", "chapter": "113_南越列传", "para": "15", "seq": 1, "text": "太史公曰： 尉佗之王，本由任嚣。", "len": 16}
{"sid": "113_南越列传.15.s2", "chapter": "113_南越列传", "para": "15", "seq": 2, "text": "遭汉初定，列为诸侯。", "len": 10}
{"sid": "113_南越列传.15.s3", "chapter": "113_南越列传", "para": "15", "seq": 3, "text": "隆虑离湿疫，佗得以益骄。", "len": 12}
{"sid": "113_南越列传.15.s4", "chapter": "113_南越列传", "para": "15", "seq": 4, "text": "瓯骆相攻，南越动摇。", "len": 10}
{"sid": "113_南越列传.15.s5", "chapter": "113_南越列传", "para": "15", "seq": 5, "text": "汉兵临境，婴齐入朝。", "len": 10}
{"sid": "113_南越列传.15.s6", "chapter": "113_南越列传", "para": "15", "seq": 6, "text": "其後亡国，徵自樛女； 吕嘉小忠，令佗无後。", "len": 21}
{"sid": "113_南越列传.15.s7", "chapter": "113_南越列传", "para": "15", "seq": 7, "text": "楼船从欲，怠傲失惑； 伏波困穷，智虑愈殖，因祸为福。", "len": 26}
{"sid": "113_南越列传.15.s8", "chapter": "113_南越列传", "para": "15", "seq": 8, "text": "成败之转，譬若纠墨。", "len": 10}
{"sid": "113_南越列传.15.s9", "chapter": "113_南越列传", "para": "15", "seq": 9, "text": "中原鹿走，群雄莫制。", "len": 10}
{"sid": "113_南越列传.15.s10", "chapter": "113_南越列传", "para": "15", "seq": 10, "text": "汉事西驱，越权南裔。", "len": 10}
{"sid": "113_南越列传.15.s11", "chapter": "113_南越列传", "para": "15", "seq": 11, "text": "陆贾骋说，尉他去帝。", "len": 10}
{"sid": "113_南越列传.15.s12", "chapter": "113_南越列传", "para": "15", "seq": 12, "text": "嫪后内朝，吕嘉狼戾。", "len": 10}
{"sid": "113_南越列传.15.s13", "chapter": "113_南越列传", "para": "15", "seq": 13, "text": "君臣不协，卒从剿弃。", "len": 10}
{"sid": "113_南越列传.15.s14", "chapter": "113_南越列传", "para": "15", "seq": 14, "text": ":::", "len": 3}
