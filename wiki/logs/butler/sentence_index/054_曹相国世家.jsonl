{"sid": "054_曹相国世家.1.s1", "chapter": "054_曹相国世家", "para": "1", "seq": 1, "text": "平阳侯曹参者，沛人也。", "len": 11}
{"sid": "054_曹相国世家.1.s2", "chapter": "054_曹相国世家", "para": "1", "seq": 2, "text": "秦时为沛狱掾，而萧何为主吏，居县为豪吏矣。", "len": 21}
{"sid": "054_曹相国世家.2.s1", "chapter": "054_曹相国世家", "para": "2", "seq": 1, "text": "高祖为沛公而初起也，参以中涓从。", "len": 16}
{"sid": "054_曹相国世家.2.s2", "chapter": "054_曹相国世家", "para": "2", "seq": 2, "text": "将击胡陵、方与，攻秦监公军，大破之。", "len": 18}
{"sid": "054_曹相国世家.2.s3", "chapter": "054_曹相国世家", "para": "2", "seq": 3, "text": "东下薛，击泗水守军薛郭西。", "len": 13}
{"sid": "054_曹相国世家.2.s4", "chapter": "054_曹相国世家", "para": "2", "seq": 4, "text": "复攻胡陵，取之。", "len": 8}
{"sid": "054_曹相国世家.2.s5", "chapter": "054_曹相国世家", "para": "2", "seq": 5, "text": "徙守方与。", "len": 5}
{"sid": "054_曹相国世家.2.s6", "chapter": "054_曹相国世家", "para": "2", "seq": 6, "text": "方与反为魏，击之。", "len": 9}
{"sid": "054_曹相国世家.2.s7", "chapter": "054_曹相国世家", "para": "2", "seq": 7, "text": "丰反为魏，攻之。", "len": 8}
{"sid": "054_曹相国世家.2.s8", "chapter": "054_曹相国世家", "para": "2", "seq": 8, "text": "赐爵七大夫。", "len": 6}
{"sid": "054_曹相国世家.2.s9", "chapter": "054_曹相国世家", "para": "2", "seq": 9, "text": "击秦司马枿军砀东，破之，取砀、狐父、祁善置。", "len": 22}
{"sid": "054_曹相国世家.2.s10", "chapter": "054_曹相国世家", "para": "2", "seq": 10, "text": "又攻下邑以西，至虞，击章邯车骑。", "len": 16}
{"sid": "054_曹相国世家.2.s11", "chapter": "054_曹相国世家", "para": "2", "seq": 11, "text": "攻爰戚及亢父，先登。", "len": 10}
{"sid": "054_曹相国世家.2.s12", "chapter": "054_曹相国世家", "para": "2", "seq": 12, "text": "迁为五大夫。", "len": 6}
{"sid": "054_曹相国世家.2.s13", "chapter": "054_曹相国世家", "para": "2", "seq": 13, "text": "北救阿，击章邯军，陷陈，追至濮阳。", "len": 17}
{"sid": "054_曹相国世家.2.s14", "chapter": "054_曹相国世家", "para": "2", "seq": 14, "text": "攻定陶，取临济。", "len": 8}
{"sid": "054_曹相国世家.2.s15", "chapter": "054_曹相国世家", "para": "2", "seq": 15, "text": "南救雍丘。", "len": 5}
{"sid": "054_曹相国世家.2.s16", "chapter": "054_曹相国世家", "para": "2", "seq": 16, "text": "击李由军，破之，杀李由，虏秦候一人。", "len": 18}
{"sid": "054_曹相国世家.2.s17", "chapter": "054_曹相国世家", "para": "2", "seq": 17, "text": "秦将章邯破杀项梁也，沛公与项羽引而东。", "len": 19}
{"sid": "054_曹相国世家.2.s18", "chapter": "054_曹相国世家", "para": "2", "seq": 18, "text": "楚怀王以沛公为砀郡长，将砀郡兵。", "len": 16}
{"sid": "054_曹相国世家.2.s19", "chapter": "054_曹相国世家", "para": "2", "seq": 19, "text": "於是乃封参为执帛，号曰建成君。", "len": 15}
{"sid": "054_曹相国世家.2.s20", "chapter": "054_曹相国世家", "para": "2", "seq": 20, "text": "迁为戚公，属砀郡。", "len": 9}
{"sid": "054_曹相国世家.3.s1", "chapter": "054_曹相国世家", "para": "3", "seq": 1, "text": "其後从攻东郡尉军，破之成武南。", "len": 15}
{"sid": "054_曹相国世家.3.s2", "chapter": "054_曹相国世家", "para": "3", "seq": 2, "text": "击王离军成阳南，复攻之杠里，大破之。", "len": 18}
{"sid": "054_曹相国世家.3.s3", "chapter": "054_曹相国世家", "para": "3", "seq": 3, "text": "追北，西至开封，击赵贲军，破之，围赵贲开封城中。", "len": 24}
{"sid": "054_曹相国世家.3.s4", "chapter": "054_曹相国世家", "para": "3", "seq": 4, "text": "西击将杨熊军於曲遇，破之，虏秦司马及御史各一人。", "len": 24}
{"sid": "054_曹相国世家.3.s5", "chapter": "054_曹相国世家", "para": "3", "seq": 5, "text": "迁为执珪。", "len": 5}
{"sid": "054_曹相国世家.3.s6", "chapter": "054_曹相国世家", "para": "3", "seq": 6, "text": "从攻阳武，下轘辕、缑氏，绝河津，还击赵贲军尸北，破之。", "len": 27}
{"sid": "054_曹相国世家.3.s7", "chapter": "054_曹相国世家", "para": "3", "seq": 7, "text": "从南攻犨，与南阳守齮战阳城郭东，陷陈，取宛，虏齮，尽定南阳郡。", "len": 31}
{"sid": "054_曹相国世家.3.s8", "chapter": "054_曹相国世家", "para": "3", "seq": 8, "text": "从西攻武关、峣关，取之。", "len": 12}
{"sid": "054_曹相国世家.3.s9", "chapter": "054_曹相国世家", "para": "3", "seq": 9, "text": "前攻秦军蓝田南，又夜击其北，秦军大破，遂至咸阳，灭秦。", "len": 27}
{"sid": "054_曹相国世家.4.s1", "chapter": "054_曹相国世家", "para": "4", "seq": 1, "text": "项羽至，以沛公为汉王。", "len": 11}
{"sid": "054_曹相国世家.4.s2", "chapter": "054_曹相国世家", "para": "4", "seq": 2, "text": "汉王封参为建成侯。", "len": 9}
{"sid": "054_曹相国世家.4.s3", "chapter": "054_曹相国世家", "para": "4", "seq": 3, "text": "从至汉中，迁为将军。", "len": 10}
{"sid": "054_曹相国世家.4.s4", "chapter": "054_曹相国世家", "para": "4", "seq": 4, "text": "从还定三秦，初攻下辩、故道、雍、斄。", "len": 18}
{"sid": "054_曹相国世家.4.s5", "chapter": "054_曹相国世家", "para": "4", "seq": 5, "text": "击章平军於好畤南，破之，围好畤，取壤乡。", "len": 20}
{"sid": "054_曹相国世家.4.s6", "chapter": "054_曹相国世家", "para": "4", "seq": 6, "text": "击三秦军壤东及高栎，破之。", "len": 13}
{"sid": "054_曹相国世家.4.s7", "chapter": "054_曹相国世家", "para": "4", "seq": 7, "text": "复围章平，章平出好畤走。", "len": 12}
{"sid": "054_曹相国世家.4.s8", "chapter": "054_曹相国世家", "para": "4", "seq": 8, "text": "因击赵贲、内史保军，破之。", "len": 13}
{"sid": "054_曹相国世家.4.s9", "chapter": "054_曹相国世家", "para": "4", "seq": 9, "text": "东取咸阳，更名曰新城。", "len": 11}
{"sid": "054_曹相国世家.4.s10", "chapter": "054_曹相国世家", "para": "4", "seq": 10, "text": "参将兵守景陵二十日，三秦使章平等攻参，参出击，大破之。", "len": 27}
{"sid": "054_曹相国世家.4.s11", "chapter": "054_曹相国世家", "para": "4", "seq": 11, "text": "赐食邑於宁秦。", "len": 7}
{"sid": "054_曹相国世家.4.s12", "chapter": "054_曹相国世家", "para": "4", "seq": 12, "text": "参以将军引兵围章邯於废丘。", "len": 13}
{"sid": "054_曹相国世家.4.s13", "chapter": "054_曹相国世家", "para": "4", "seq": 13, "text": "以中尉从汉王出临晋关。", "len": 11}
{"sid": "054_曹相国世家.4.s14", "chapter": "054_曹相国世家", "para": "4", "seq": 14, "text": "至河内，下脩武，渡围津，东击龙且、项他定陶，破之。", "len": 25}
{"sid": "054_曹相国世家.4.s15", "chapter": "054_曹相国世家", "para": "4", "seq": 15, "text": "东取砀、萧、彭城。", "len": 9}
{"sid": "054_曹相国世家.4.s16", "chapter": "054_曹相国世家", "para": "4", "seq": 16, "text": "击项籍军，汉军大败走。", "len": 11}
{"sid": "054_曹相国世家.4.s17", "chapter": "054_曹相国世家", "para": "4", "seq": 17, "text": "参以中尉围取雍丘。", "len": 9}
{"sid": "054_曹相国世家.4.s18", "chapter": "054_曹相国世家", "para": "4", "seq": 18, "text": "王武反於黄，程处反於燕，往击，尽破之。", "len": 19}
{"sid": "054_曹相国世家.4.s19", "chapter": "054_曹相国世家", "para": "4", "seq": 19, "text": "柱天侯反於衍氏，又进破取衍氏。", "len": 15}
{"sid": "054_曹相国世家.4.s20", "chapter": "054_曹相国世家", "para": "4", "seq": 20, "text": "击羽婴於昆阳，追至叶。", "len": 11}
{"sid": "054_曹相国世家.4.s21", "chapter": "054_曹相国世家", "para": "4", "seq": 21, "text": "还攻武彊，因至荥阳。", "len": 10}
{"sid": "054_曹相国世家.4.s22", "chapter": "054_曹相国世家", "para": "4", "seq": 22, "text": "参自汉中为将军中尉，从击诸侯，及项羽败，还至荥阳，凡二岁。", "len": 29}
{"sid": "054_曹相国世家.5.s1", "chapter": "054_曹相国世家", "para": "5", "seq": 1, "text": "高祖年，拜为假左丞相，入屯兵关中。", "len": 17}
{"sid": "054_曹相国世家.5.s2", "chapter": "054_曹相国世家", "para": "5", "seq": 2, "text": "月馀，魏王豹反，以假左丞相别与韩信东攻魏将军孙遫军东张，大破之。", "len": 32}
{"sid": "054_曹相国世家.5.s3", "chapter": "054_曹相国世家", "para": "5", "seq": 3, "text": "因攻安邑，得魏将王襄。", "len": 11}
{"sid": "054_曹相国世家.5.s4", "chapter": "054_曹相国世家", "para": "5", "seq": 4, "text": "击魏王於曲阳，追至武垣，生得魏王豹。", "len": 18}
{"sid": "054_曹相国世家.5.s5", "chapter": "054_曹相国世家", "para": "5", "seq": 5, "text": "取平阳，得魏王母妻子，尽定魏地，凡五十二城。", "len": 22}
{"sid": "054_曹相国世家.5.s6", "chapter": "054_曹相国世家", "para": "5", "seq": 6, "text": "赐食邑平阳。", "len": 6}
{"sid": "054_曹相国世家.5.s7", "chapter": "054_曹相国世家", "para": "5", "seq": 7, "text": "因从韩信击赵相国夏说军於邬东，大破之，斩夏说。", "len": 23}
{"sid": "054_曹相国世家.5.s8", "chapter": "054_曹相国世家", "para": "5", "seq": 8, "text": "韩信与故常山王张耳引兵下井陉，击成安君，而令参还围赵别将戚将军於邬城中。", "len": 36}
{"sid": "054_曹相国世家.5.s9", "chapter": "054_曹相国世家", "para": "5", "seq": 9, "text": "戚将军出走，追斩之。", "len": 10}
{"sid": "054_曹相国世家.5.s10", "chapter": "054_曹相国世家", "para": "5", "seq": 10, "text": "乃引兵诣敖仓汉王之所。", "len": 11}
{"sid": "054_曹相国世家.5.s11", "chapter": "054_曹相国世家", "para": "5", "seq": 11, "text": "韩信已破赵，为相国，东击齐。", "len": 14}
{"sid": "054_曹相国世家.5.s12", "chapter": "054_曹相国世家", "para": "5", "seq": 12, "text": "参以右丞相属韩信，攻破齐历下军，遂取临菑。", "len": 21}
{"sid": "054_曹相国世家.5.s13", "chapter": "054_曹相国世家", "para": "5", "seq": 13, "text": "还定济北郡，攻著、漯阴、平原、鬲、卢。", "len": 19}
{"sid": "054_曹相国世家.5.s14", "chapter": "054_曹相国世家", "para": "5", "seq": 14, "text": "已而从韩信击龙且军於上假密，大破之，斩龙且，虏其将军周兰。", "len": 29}
{"sid": "054_曹相国世家.5.s15", "chapter": "054_曹相国世家", "para": "5", "seq": 15, "text": "定齐，凡得七十馀县。", "len": 10}
{"sid": "054_曹相国世家.5.s16", "chapter": "054_曹相国世家", "para": "5", "seq": 16, "text": "得故齐王田广相田光，其守相许章，及故齐胶东将军田既。", "len": 26}
{"sid": "054_曹相国世家.5.s17", "chapter": "054_曹相国世家", "para": "5", "seq": 17, "text": "韩信为齐王，引兵诣陈，与汉王共破项羽，而参留平齐未服者。", "len": 28}
{"sid": "054_曹相国世家.6.s1", "chapter": "054_曹相国世家", "para": "6", "seq": 1, "text": "项籍已死，天下定，汉王为皇帝，韩信徙为楚王，齐为郡。", "len": 26}
{"sid": "054_曹相国世家.6.s2", "chapter": "054_曹相国世家", "para": "6", "seq": 2, "text": "参归汉相印。", "len": 6}
{"sid": "054_曹相国世家.6.s3", "chapter": "054_曹相国世家", "para": "6", "seq": 3, "text": "高帝以长子肥为齐王，而以参为齐相国。", "len": 18}
{"sid": "054_曹相国世家.6.s4", "chapter": "054_曹相国世家", "para": "6", "seq": 4, "text": "以高祖六年赐爵列侯，与诸侯剖符，世世勿绝。", "len": 21}
{"sid": "054_曹相国世家.6.s5", "chapter": "054_曹相国世家", "para": "6", "seq": 5, "text": "食邑平阳万六百三十户，号曰平阳侯，除前所食邑。", "len": 23}
{"sid": "054_曹相国世家.7.s1", "chapter": "054_曹相国世家", "para": "7", "seq": 1, "text": "以齐相国击陈豨将张春军，破之。", "len": 15}
{"sid": "054_曹相国世家.7.s2", "chapter": "054_曹相国世家", "para": "7", "seq": 2, "text": "黥布反，参以齐相国从悼惠王将兵车骑十二万人，与高祖会击黥布军，大破之。", "len": 35}
{"sid": "054_曹相国世家.7.s3", "chapter": "054_曹相国世家", "para": "7", "seq": 3, "text": "南至蕲，还定竹邑、相、萧、留。", "len": 15}
{"sid": "054_曹相国世家.8.s1", "chapter": "054_曹相国世家", "para": "8", "seq": 1, "text": "参功：凡下二国，县一百二十二；得王二人，相三人，将军六人，大莫敖、郡守、司马、候、御史各一人。", "len": 47}
{"sid": "054_曹相国世家.9.s1", "chapter": "054_曹相国世家", "para": "9", "seq": 1, "text": "孝惠帝元年，除诸侯相国法，更以参为齐丞相。", "len": 21}
{"sid": "054_曹相国世家.9.s2", "chapter": "054_曹相国世家", "para": "9", "seq": 2, "text": "参之相齐，齐七十城。", "len": 10}
{"sid": "054_曹相国世家.9.s3", "chapter": "054_曹相国世家", "para": "9", "seq": 3, "text": "天下初定，悼惠王富於春秋，参尽召长老诸生，问所以安集百姓，如齐故诸儒以百数，言人人殊，参未知所定。", "len": 49}
{"sid": "054_曹相国世家.9.s4", "chapter": "054_曹相国世家", "para": "9", "seq": 4, "text": "闻胶西有盖公，善治黄老言，使人厚币请之。", "len": 20}
{"sid": "054_曹相国世家.9.s5", "chapter": "054_曹相国世家", "para": "9", "seq": 5, "text": "既见盖公，盖公为言治道贵清静而民自定，推此类具言之。", "len": 26}
{"sid": "054_曹相国世家.9.s6", "chapter": "054_曹相国世家", "para": "9", "seq": 6, "text": "参於是避正堂，舍盖公焉。", "len": 12}
{"sid": "054_曹相国世家.9.s7", "chapter": "054_曹相国世家", "para": "9", "seq": 7, "text": "其治要用黄老术，故相齐九年，齐国安集，大称贤相。", "len": 24}
{"sid": "054_曹相国世家.10.s1", "chapter": "054_曹相国世家", "para": "10", "seq": 1, "text": "惠帝二年，萧何卒。", "len": 9}
{"sid": "054_曹相国世家.10.s2", "chapter": "054_曹相国世家", "para": "10", "seq": 2, "text": "参闻之，告舍人趣治行，“吾将入相”。", "len": 18}
{"sid": "054_曹相国世家.10.s3", "chapter": "054_曹相国世家", "para": "10", "seq": 3, "text": "居无何，使者果召参。", "len": 10}
{"sid": "054_曹相国世家.10.s4", "chapter": "054_曹相国世家", "para": "10", "seq": 4, "text": "参去，属其後相曰：“以齐狱市为寄，慎勿扰也。", "len": 22}
{"sid": "054_曹相国世家.10.s5", "chapter": "054_曹相国世家", "para": "10", "seq": 5, "text": "” 後相曰：“治无大於此者乎？", "len": 15}
{"sid": "054_曹相国世家.10.s6", "chapter": "054_曹相国世家", "para": "10", "seq": 6, "text": "” 参曰：“不然。", "len": 9}
{"sid": "054_曹相国世家.10.s7", "chapter": "054_曹相国世家", "para": "10", "seq": 7, "text": "夫狱市者，所以并容也，今君扰之，奸人安所容也？", "len": 23}
{"sid": "054_曹相国世家.10.s8", "chapter": "054_曹相国世家", "para": "10", "seq": 8, "text": "吾是以先之。”", "len": 7}
{"sid": "054_曹相国世家.11.s1", "chapter": "054_曹相国世家", "para": "11", "seq": 1, "text": "参始微时，与萧何善；及为将相，有卻。", "len": 18}
{"sid": "054_曹相国世家.11.s2", "chapter": "054_曹相国世家", "para": "11", "seq": 2, "text": "至何且死，所推贤唯参。", "len": 11}
{"sid": "054_曹相国世家.11.s3", "chapter": "054_曹相国世家", "para": "11", "seq": 3, "text": "参代何为汉相国，举事无所变更，一遵萧何约束。", "len": 22}
{"sid": "054_曹相国世家.12.s1", "chapter": "054_曹相国世家", "para": "12", "seq": 1, "text": "择郡国吏木诎於文辞，重厚长者，即召除为丞相史。", "len": 23}
{"sid": "054_曹相国世家.12.s2", "chapter": "054_曹相国世家", "para": "12", "seq": 2, "text": "吏之言文刻深，欲务声名者，辄斥去之。", "len": 18}
{"sid": "054_曹相国世家.12.s3", "chapter": "054_曹相国世家", "para": "12", "seq": 3, "text": "日夜饮醇酒。", "len": 6}
{"sid": "054_曹相国世家.12.s4", "chapter": "054_曹相国世家", "para": "12", "seq": 4, "text": "卿大夫已下吏及宾客见参不事事，来者皆欲有言。", "len": 22}
{"sid": "054_曹相国世家.12.s5", "chapter": "054_曹相国世家", "para": "12", "seq": 5, "text": "至者，参辄饮以醇酒，间之，欲有所言，复饮之，醉而後去，终莫得开说，以为常。", "len": 37}
{"sid": "054_曹相国世家.13.s1", "chapter": "054_曹相国世家", "para": "13", "seq": 1, "text": "相舍後园近吏舍，吏舍日饮歌呼。", "len": 15}
{"sid": "054_曹相国世家.13.s2", "chapter": "054_曹相国世家", "para": "13", "seq": 2, "text": "从吏恶之，无如之何，乃请参游园中，闻吏醉歌呼，从吏幸相国召按之。", "len": 32}
{"sid": "054_曹相国世家.13.s3", "chapter": "054_曹相国世家", "para": "13", "seq": 3, "text": "乃反取酒张坐饮，亦歌呼与相应和。", "len": 16}
{"sid": "054_曹相国世家.14.s1", "chapter": "054_曹相国世家", "para": "14", "seq": 1, "text": "参见人之有细过，专掩匿覆盖之，府中无事。", "len": 20}
{"sid": "054_曹相国世家.15.s1", "chapter": "054_曹相国世家", "para": "15", "seq": 1, "text": "参子窋为中大夫。", "len": 8}
{"sid": "054_曹相国世家.15.s2", "chapter": "054_曹相国世家", "para": "15", "seq": 2, "text": "惠帝怪相国不治事，以为“岂少朕与” ？", "len": 19}
{"sid": "054_曹相国世家.15.s3", "chapter": "054_曹相国世家", "para": "15", "seq": 3, "text": "乃谓窋曰：“若归，试私从容问而父曰：‘高帝新弃群臣，帝富於春秋，君为相，日饮，无所请事，何以忧天下乎？", "len": 51}
{"sid": "054_曹相国世家.15.s4", "chapter": "054_曹相国世家", "para": "15", "seq": 4, "text": "’然无言吾告若也。", "len": 9}
{"sid": "054_曹相国世家.15.s5", "chapter": "054_曹相国世家", "para": "15", "seq": 5, "text": "” 窋既洗沐归，间侍，自从其所谏参。", "len": 18}
{"sid": "054_曹相国世家.15.s6", "chapter": "054_曹相国世家", "para": "15", "seq": 6, "text": "参怒，而笞窋二百，曰：“趣入侍，天下事非若所当言也。", "len": 26}
{"sid": "054_曹相国世家.15.s7", "chapter": "054_曹相国世家", "para": "15", "seq": 7, "text": "” 至朝时，惠帝让参曰：“与窋胡治乎？", "len": 19}
{"sid": "054_曹相国世家.15.s8", "chapter": "054_曹相国世家", "para": "15", "seq": 8, "text": "乃者我使谏君也。", "len": 8}
{"sid": "054_曹相国世家.15.s9", "chapter": "054_曹相国世家", "para": "15", "seq": 9, "text": "” 参免冠谢曰：“陛下自察圣武孰与高帝？", "len": 20}
{"sid": "054_曹相国世家.15.s10", "chapter": "054_曹相国世家", "para": "15", "seq": 10, "text": "” 上曰：“朕乃安敢望先帝乎！", "len": 15}
{"sid": "054_曹相国世家.15.s11", "chapter": "054_曹相国世家", "para": "15", "seq": 11, "text": "” 曰：“陛下观臣能孰与萧何贤？", "len": 16}
{"sid": "054_曹相国世家.15.s12", "chapter": "054_曹相国世家", "para": "15", "seq": 12, "text": "” 上曰：“君似不及也。", "len": 12}
{"sid": "054_曹相国世家.15.s13", "chapter": "054_曹相国世家", "para": "15", "seq": 13, "text": "” 参曰：“陛下言之是也。", "len": 13}
{"sid": "054_曹相国世家.15.s14", "chapter": "054_曹相国世家", "para": "15", "seq": 14, "text": "且高帝与萧何定天下，法令既明，今陛下垂拱，参等守职，遵而勿失，不亦可乎？", "len": 36}
{"sid": "054_曹相国世家.15.s15", "chapter": "054_曹相国世家", "para": "15", "seq": 15, "text": "” 惠帝曰：“善。", "len": 9}
{"sid": "054_曹相国世家.15.s16", "chapter": "054_曹相国世家", "para": "15", "seq": 16, "text": "君休矣！”", "len": 5}
{"sid": "054_曹相国世家.16.s1", "chapter": "054_曹相国世家", "para": "16", "seq": 1, "text": "参为汉相国，出入三年。", "len": 11}
{"sid": "054_曹相国世家.16.s2", "chapter": "054_曹相国世家", "para": "16", "seq": 2, "text": "卒，谥懿侯。", "len": 6}
{"sid": "054_曹相国世家.16.s3", "chapter": "054_曹相国世家", "para": "16", "seq": 3, "text": "子窋代侯。", "len": 5}
{"sid": "054_曹相国世家.16.s4", "chapter": "054_曹相国世家", "para": "16", "seq": 4, "text": "百姓歌之曰：“萧何为法，若画一；曹参代之，守而勿失。", "len": 26}
{"sid": "054_曹相国世家.16.s5", "chapter": "054_曹相国世家", "para": "16", "seq": 5, "text": "载其清净，民以宁一。”", "len": 11}
{"sid": "054_曹相国世家.17.s1", "chapter": "054_曹相国世家", "para": "17", "seq": 1, "text": "平阳侯窋，高后时为御史大夫。", "len": 14}
{"sid": "054_曹相国世家.17.s2", "chapter": "054_曹相国世家", "para": "17", "seq": 2, "text": "孝文帝立，免为侯。", "len": 9}
{"sid": "054_曹相国世家.17.s3", "chapter": "054_曹相国世家", "para": "17", "seq": 3, "text": "立二十九年卒，谥为静侯。", "len": 12}
{"sid": "054_曹相国世家.17.s4", "chapter": "054_曹相国世家", "para": "17", "seq": 4, "text": "子奇代侯，立七年卒，谥为简侯。", "len": 15}
{"sid": "054_曹相国世家.17.s5", "chapter": "054_曹相国世家", "para": "17", "seq": 5, "text": "子时代侯。", "len": 5}
{"sid": "054_曹相国世家.17.s6", "chapter": "054_曹相国世家", "para": "17", "seq": 6, "text": "时尚平阳公主，生子襄。", "len": 11}
{"sid": "054_曹相国世家.17.s7", "chapter": "054_曹相国世家", "para": "17", "seq": 7, "text": "时病疠，归国。", "len": 7}
{"sid": "054_曹相国世家.17.s8", "chapter": "054_曹相国世家", "para": "17", "seq": 8, "text": "立二十三年卒，谥夷侯。", "len": 11}
{"sid": "054_曹相国世家.17.s9", "chapter": "054_曹相国世家", "para": "17", "seq": 9, "text": "子襄代侯。", "len": 5}
{"sid": "054_曹相国世家.17.s10", "chapter": "054_曹相国世家", "para": "17", "seq": 10, "text": "襄尚卫长公主，生子宗。", "len": 11}
{"sid": "054_曹相国世家.17.s11", "chapter": "054_曹相国世家", "para": "17", "seq": 11, "text": "立十六年卒，谥为共侯。", "len": 11}
{"sid": "054_曹相国世家.17.s12", "chapter": "054_曹相国世家", "para": "17", "seq": 12, "text": "子宗代侯。", "len": 5}
{"sid": "054_曹相国世家.17.s13", "chapter": "054_曹相国世家", "para": "17", "seq": 13, "text": "征和二年中，宗坐太子死，国除。", "len": 15}
{"sid": "054_曹相国世家.17.s14", "chapter": "054_曹相国世家", "para": "17", "seq": 14, "text": "::: 太史公曰", "len": 8}
{"sid": "054_曹相国世家.18.s1", "chapter": "054_曹相国世家", "para": "18", "seq": 1, "text": "太史公曰：曹相国参攻城野战之功所以能多若此者，以与淮阴侯俱。", "len": 30}
{"sid": "054_曹相国世家.18.s2", "chapter": "054_曹相国世家", "para": "18", "seq": 2, "text": "及信已灭，而列侯成功，唯独参擅其名。", "len": 18}
{"sid": "054_曹相国世家.18.s3", "chapter": "054_曹相国世家", "para": "18", "seq": 3, "text": "参为汉相国，清静极言合道。", "len": 13}
{"sid": "054_曹相国世家.18.s4", "chapter": "054_曹相国世家", "para": "18", "seq": 4, "text": "然百姓离秦之酷後，参与休息无为，故天下俱称其美矣。", "len": 25}
{"sid": "054_曹相国世家.18.s5", "chapter": "054_曹相国世家", "para": "18", "seq": 5, "text": "::: ::: 赞", "len": 9}
{"sid": "054_曹相国世家.19.s1", "chapter": "054_曹相国世家", "para": "19", "seq": 1, "text": "曹参初起，为沛豪吏。", "len": 10}
{"sid": "054_曹相国世家.19.s2", "chapter": "054_曹相国世家", "para": "19", "seq": 2, "text": "始从中涓，先围善置。", "len": 10}
{"sid": "054_曹相国世家.19.s3", "chapter": "054_曹相国世家", "para": "19", "seq": 3, "text": "执珪执帛，攻城略地。", "len": 10}
{"sid": "054_曹相国世家.19.s4", "chapter": "054_曹相国世家", "para": "19", "seq": 4, "text": "衍氏既诛，昆阳失位。", "len": 10}
{"sid": "054_曹相国世家.19.s5", "chapter": "054_曹相国世家", "para": "19", "seq": 5, "text": "北禽夏说，东讨田溉。", "len": 10}
{"sid": "054_曹相国世家.19.s6", "chapter": "054_曹相国世家", "para": "19", "seq": 6, "text": "剖符定封，功无与二。", "len": 10}
{"sid": "054_曹相国世家.19.s7", "chapter": "054_曹相国世家", "para": "19", "seq": 7, "text": "市狱勿扰，清净不事。", "len": 10}
{"sid": "054_曹相国世家.19.s8", "chapter": "054_曹相国世家", "para": "19", "seq": 8, "text": "尚主平阳，代享其利。", "len": 10}
{"sid": "054_曹相国世家.19.s9", "chapter": "054_曹相国世家", "para": "19", "seq": 9, "text": ":::", "len": 3}
