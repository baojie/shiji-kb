{"sid": "084_屈原贾生列传.1.s1", "chapter": "084_屈原贾生列传", "para": "1", "seq": 1, "text": "屈原者，名平，楚之同姓也。", "len": 13}
{"sid": "084_屈原贾生列传.1.s2", "chapter": "084_屈原贾生列传", "para": "1", "seq": 2, "text": "为楚怀王左徒。", "len": 7}
{"sid": "084_屈原贾生列传.1.s3", "chapter": "084_屈原贾生列传", "para": "1", "seq": 3, "text": "博闻彊志，明於治乱，嫺於辞令。", "len": 15}
{"sid": "084_屈原贾生列传.1.s4", "chapter": "084_屈原贾生列传", "para": "1", "seq": 4, "text": "入则与王图议国事，以出号令；出则接遇宾客，应对诸侯。", "len": 26}
{"sid": "084_屈原贾生列传.1.s5", "chapter": "084_屈原贾生列传", "para": "1", "seq": 5, "text": "王甚任之。", "len": 5}
{"sid": "084_屈原贾生列传.2.s1", "chapter": "084_屈原贾生列传", "para": "2", "seq": 1, "text": "上官大夫与之同列，争宠而心害其能。", "len": 17}
{"sid": "084_屈原贾生列传.2.s2", "chapter": "084_屈原贾生列传", "para": "2", "seq": 2, "text": "怀王使屈原造为宪令，屈平属草未定。", "len": 17}
{"sid": "084_屈原贾生列传.2.s3", "chapter": "084_屈原贾生列传", "para": "2", "seq": 3, "text": "上官大夫见而欲夺之，屈平不与，因谗之曰：”王使屈平为令，众莫不知，每一令出，平伐其功，以为’非我莫能为’也。", "len": 54}
{"sid": "084_屈原贾生列传.2.s4", "chapter": "084_屈原贾生列传", "para": "2", "seq": 4, "text": "” 王怒而疏屈平。", "len": 9}
{"sid": "084_屈原贾生列传.2.1.s1", "chapter": "084_屈原贾生列传", "para": "2.1", "seq": 1, "text": "屈平疾王听之不聪也，谗谄之蔽明也，邪曲之害公也，方正之不容也，故忧愁幽思而作离骚。", "len": 41}
{"sid": "084_屈原贾生列传.2.1.s2", "chapter": "084_屈原贾生列传", "para": "2.1", "seq": 2, "text": "离骚者，犹离忧也。", "len": 9}
{"sid": "084_屈原贾生列传.2.1.s3", "chapter": "084_屈原贾生列传", "para": "2.1", "seq": 3, "text": "夫天者，人之始也；父母者，人之本也。", "len": 18}
{"sid": "084_屈原贾生列传.2.1.s4", "chapter": "084_屈原贾生列传", "para": "2.1", "seq": 4, "text": "人穷则反本，故劳苦倦极，未尝不呼天也；疾痛惨怛，未尝不呼父母也。", "len": 32}
{"sid": "084_屈原贾生列传.2.1.s5", "chapter": "084_屈原贾生列传", "para": "2.1", "seq": 5, "text": "屈平正道直行，竭忠尽智以事其君，谗人间之，可谓穷矣。", "len": 26}
{"sid": "084_屈原贾生列传.2.1.s6", "chapter": "084_屈原贾生列传", "para": "2.1", "seq": 6, "text": "信而见疑，忠而被谤，能无怨乎？", "len": 15}
{"sid": "084_屈原贾生列传.2.1.s7", "chapter": "084_屈原贾生列传", "para": "2.1", "seq": 7, "text": "屈平之作离骚，盖自怨生也。", "len": 13}
{"sid": "084_屈原贾生列传.2.2.s1", "chapter": "084_屈原贾生列传", "para": "2.2", "seq": 1, "text": "国风好色而不淫，小雅怨诽而不乱。", "len": 16}
{"sid": "084_屈原贾生列传.2.2.s2", "chapter": "084_屈原贾生列传", "para": "2.2", "seq": 2, "text": "若离骚者，可谓兼之矣。", "len": 11}
{"sid": "084_屈原贾生列传.2.2.s3", "chapter": "084_屈原贾生列传", "para": "2.2", "seq": 3, "text": "上称帝喾，下道齐桓，中述汤武，以刺世事。", "len": 20}
{"sid": "084_屈原贾生列传.2.2.s4", "chapter": "084_屈原贾生列传", "para": "2.2", "seq": 4, "text": "明道德之广崇，治乱之条贯，靡不毕见。", "len": 18}
{"sid": "084_屈原贾生列传.2.2.s5", "chapter": "084_屈原贾生列传", "para": "2.2", "seq": 5, "text": "其文约，其辞微，其志絜，其行廉，其称文小而其指极大，举类迩而见义远。", "len": 34}
{"sid": "084_屈原贾生列传.2.2.s6", "chapter": "084_屈原贾生列传", "para": "2.2", "seq": 6, "text": "其志絜，故其称物芳。", "len": 10}
{"sid": "084_屈原贾生列传.2.2.s7", "chapter": "084_屈原贾生列传", "para": "2.2", "seq": 7, "text": "其行廉，故死而不容自疏。", "len": 12}
{"sid": "084_屈原贾生列传.2.2.s8", "chapter": "084_屈原贾生列传", "para": "2.2", "seq": 8, "text": "濯淖汙泥之中，蝉蜕於浊秽，以浮游尘埃之外，不获世之滋垢，皭然泥而不滓者也。", "len": 37}
{"sid": "084_屈原贾生列传.2.2.s9", "chapter": "084_屈原贾生列传", "para": "2.2", "seq": 9, "text": "推此志也，虽与日月争光可也。", "len": 14}
{"sid": "084_屈原贾生列传.3.1.s1", "chapter": "084_屈原贾生列传", "para": "3.1", "seq": 1, "text": "屈平既绌，其後秦欲伐齐，齐与楚从亲，惠王患之，乃令张仪详去秦，厚币委质事楚，曰：“秦甚憎齐，齐与楚从亲，楚诚能绝齐，秦原献商、於之地六百里。", "len": 70}
{"sid": "084_屈原贾生列传.3.1.s2", "chapter": "084_屈原贾生列传", "para": "3.1", "seq": 2, "text": "” 楚怀王贪而信张仪，遂绝齐，使使如秦受地。", "len": 22}
{"sid": "084_屈原贾生列传.3.1.s3", "chapter": "084_屈原贾生列传", "para": "3.1", "seq": 3, "text": "张仪诈之曰：”仪与王约六里，不闻六百里。", "len": 20}
{"sid": "084_屈原贾生列传.3.1.s4", "chapter": "084_屈原贾生列传", "para": "3.1", "seq": 4, "text": "” 楚使怒去，归告怀王。", "len": 12}
{"sid": "084_屈原贾生列传.3.1.s5", "chapter": "084_屈原贾生列传", "para": "3.1", "seq": 5, "text": "怀王怒，大兴师伐秦。", "len": 10}
{"sid": "084_屈原贾生列传.3.1.s6", "chapter": "084_屈原贾生列传", "para": "3.1", "seq": 6, "text": "秦发兵击之，大破楚师於丹、淅，斩首八万，虏楚将屈匄，遂取楚之汉中地。", "len": 34}
{"sid": "084_屈原贾生列传.3.1.s7", "chapter": "084_屈原贾生列传", "para": "3.1", "seq": 7, "text": "怀王乃悉发国中兵以深入击秦，战於蓝田。", "len": 19}
{"sid": "084_屈原贾生列传.3.1.s8", "chapter": "084_屈原贾生列传", "para": "3.1", "seq": 8, "text": "魏闻之，袭楚至邓。", "len": 9}
{"sid": "084_屈原贾生列传.3.1.s9", "chapter": "084_屈原贾生列传", "para": "3.1", "seq": 9, "text": "楚兵惧，自秦归。", "len": 8}
{"sid": "084_屈原贾生列传.3.1.s10", "chapter": "084_屈原贾生列传", "para": "3.1", "seq": 10, "text": "而齐竟怒不救楚，楚大困。", "len": 12}
{"sid": "084_屈原贾生列传.3.2.s1", "chapter": "084_屈原贾生列传", "para": "3.2", "seq": 1, "text": "明年，秦割汉中地与楚以和。", "len": 13}
{"sid": "084_屈原贾生列传.3.2.s2", "chapter": "084_屈原贾生列传", "para": "3.2", "seq": 2, "text": "楚王曰：”不原得地，原得张仪而甘心焉。", "len": 19}
{"sid": "084_屈原贾生列传.3.2.s3", "chapter": "084_屈原贾生列传", "para": "3.2", "seq": 3, "text": "” 张仪闻，乃曰：“以一仪而当汉中地，臣请往如楚。", "len": 25}
{"sid": "084_屈原贾生列传.3.2.s4", "chapter": "084_屈原贾生列传", "para": "3.2", "seq": 4, "text": "” 如楚，又因厚币用事者臣靳尚，而设诡辩於怀王之宠姬郑袖。", "len": 29}
{"sid": "084_屈原贾生列传.3.2.s5", "chapter": "084_屈原贾生列传", "para": "3.2", "seq": 5, "text": "怀王竟听郑袖，复释去张仪。", "len": 13}
{"sid": "084_屈原贾生列传.3.2.s6", "chapter": "084_屈原贾生列传", "para": "3.2", "seq": 6, "text": "是时屈平既疏，不复在位，使於齐，顾反，谏怀王曰：“何不杀张仪？", "len": 31}
{"sid": "084_屈原贾生列传.3.2.s7", "chapter": "084_屈原贾生列传", "para": "3.2", "seq": 7, "text": "” 怀王悔，追张仪不及。", "len": 12}
{"sid": "084_屈原贾生列传.3.3.s1", "chapter": "084_屈原贾生列传", "para": "3.3", "seq": 1, "text": "其後诸侯共击楚，大破之，杀其将唐眛。", "len": 18}
{"sid": "084_屈原贾生列传.4.1.s1", "chapter": "084_屈原贾生列传", "para": "4.1", "seq": 1, "text": "时秦昭王与楚婚，欲与怀王会。", "len": 14}
{"sid": "084_屈原贾生列传.4.1.s2", "chapter": "084_屈原贾生列传", "para": "4.1", "seq": 2, "text": "怀王欲行，屈平曰：“秦虎狼之国，不可信，不如毋行。", "len": 25}
{"sid": "084_屈原贾生列传.4.1.s3", "chapter": "084_屈原贾生列传", "para": "4.1", "seq": 3, "text": "” 怀王稚子子兰劝王行：”柰何绝秦欢！", "len": 19}
{"sid": "084_屈原贾生列传.4.1.s4", "chapter": "084_屈原贾生列传", "para": "4.1", "seq": 4, "text": "” 怀王卒行。", "len": 7}
{"sid": "084_屈原贾生列传.4.1.s5", "chapter": "084_屈原贾生列传", "para": "4.1", "seq": 5, "text": "入武关，秦伏兵绝其後，因留怀王，以求割地。", "len": 21}
{"sid": "084_屈原贾生列传.4.1.s6", "chapter": "084_屈原贾生列传", "para": "4.1", "seq": 6, "text": "怀王怒，不听。", "len": 7}
{"sid": "084_屈原贾生列传.4.1.s7", "chapter": "084_屈原贾生列传", "para": "4.1", "seq": 7, "text": "亡走赵，赵不内。", "len": 8}
{"sid": "084_屈原贾生列传.4.1.s8", "chapter": "084_屈原贾生列传", "para": "4.1", "seq": 8, "text": "复之秦，竟死於秦而归葬。", "len": 12}
{"sid": "084_屈原贾生列传.4.2.s1", "chapter": "084_屈原贾生列传", "para": "4.2", "seq": 1, "text": "长子顷襄王立，以其弟子兰为令尹。", "len": 16}
{"sid": "084_屈原贾生列传.4.2.s2", "chapter": "084_屈原贾生列传", "para": "4.2", "seq": 2, "text": "楚人既咎子兰以劝怀王入秦而不反也。", "len": 17}
{"sid": "084_屈原贾生列传.5.1.s1", "chapter": "084_屈原贾生列传", "para": "5.1", "seq": 1, "text": "屈平既嫉之，虽放流，睠顾楚国，系心怀王，不忘欲反，冀幸君之一悟，俗之一改也。", "len": 38}
{"sid": "084_屈原贾生列传.5.1.s2", "chapter": "084_屈原贾生列传", "para": "5.1", "seq": 2, "text": "其存君兴国而欲反覆之，一篇之中三致志焉。", "len": 20}
{"sid": "084_屈原贾生列传.5.1.s3", "chapter": "084_屈原贾生列传", "para": "5.1", "seq": 3, "text": "然终无可柰何，故不可以反，卒以此见怀王之终不悟也。", "len": 25}
{"sid": "084_屈原贾生列传.5.2.s1", "chapter": "084_屈原贾生列传", "para": "5.2", "seq": 1, "text": "人君无愚智贤不肖，莫不欲求忠以自为，举贤以自佐，然亡国破家相随属，而圣君治国累世而不见者，其所谓忠者不忠，而所谓贤者不贤也。", "len": 62}
{"sid": "084_屈原贾生列传.5.2.s2", "chapter": "084_屈原贾生列传", "para": "5.2", "seq": 2, "text": "怀王以不知忠臣之分，故内惑於郑袖，外欺於张仪，疏屈平而信上官大夫、令尹子兰。", "len": 38}
{"sid": "084_屈原贾生列传.5.2.s3", "chapter": "084_屈原贾生列传", "para": "5.2", "seq": 3, "text": "兵挫地削，亡其六郡，身客死於秦，为天下笑。", "len": 21}
{"sid": "084_屈原贾生列传.5.2.s4", "chapter": "084_屈原贾生列传", "para": "5.2", "seq": 4, "text": "此不知人之祸也。", "len": 8}
{"sid": "084_屈原贾生列传.5.2.s5", "chapter": "084_屈原贾生列传", "para": "5.2", "seq": 5, "text": "易曰：“井泄不食，为我心恻，可以汲。", "len": 18}
{"sid": "084_屈原贾生列传.5.2.s6", "chapter": "084_屈原贾生列传", "para": "5.2", "seq": 6, "text": "王明，并受其福。", "len": 8}
{"sid": "084_屈原贾生列传.5.2.s7", "chapter": "084_屈原贾生列传", "para": "5.2", "seq": 7, "text": "” 王之不明，岂足福哉！", "len": 12}
{"sid": "084_屈原贾生列传.6.s1", "chapter": "084_屈原贾生列传", "para": "6", "seq": 1, "text": "令尹子兰闻之大怒，卒使上官大夫短屈原於顷襄王，顷襄王怒而迁之。", "len": 31}
{"sid": "084_屈原贾生列传.7.s1", "chapter": "084_屈原贾生列传", "para": "7", "seq": 1, "text": "屈原至於江滨，被发行吟泽畔。", "len": 14}
{"sid": "084_屈原贾生列传.7.s2", "chapter": "084_屈原贾生列传", "para": "7", "seq": 2, "text": "颜色憔悴，形容枯槁。", "len": 10}
{"sid": "084_屈原贾生列传.7.s3", "chapter": "084_屈原贾生列传", "para": "7", "seq": 3, "text": "渔父见而问之曰：“子非三闾大夫欤？", "len": 17}
{"sid": "084_屈原贾生列传.7.s4", "chapter": "084_屈原贾生列传", "para": "7", "seq": 4, "text": "何故而至此？", "len": 6}
{"sid": "084_屈原贾生列传.7.s5", "chapter": "084_屈原贾生列传", "para": "7", "seq": 5, "text": "” 屈原曰：“举世混浊而我独清，众人皆醉而我独醒，是以见放。", "len": 30}
{"sid": "084_屈原贾生列传.7.s6", "chapter": "084_屈原贾生列传", "para": "7", "seq": 6, "text": "” 渔父曰：“夫圣人者，不凝滞於物而能与世推移。", "len": 24}
{"sid": "084_屈原贾生列传.7.s7", "chapter": "084_屈原贾生列传", "para": "7", "seq": 7, "text": "举世混浊，何不随其流而扬其波？", "len": 15}
{"sid": "084_屈原贾生列传.7.s8", "chapter": "084_屈原贾生列传", "para": "7", "seq": 8, "text": "众人皆醉，何不餔其糟而啜其醨？", "len": 15}
{"sid": "084_屈原贾生列传.7.s9", "chapter": "084_屈原贾生列传", "para": "7", "seq": 9, "text": "何故怀瑾握瑜而自令见放为？", "len": 13}
{"sid": "084_屈原贾生列传.7.s10", "chapter": "084_屈原贾生列传", "para": "7", "seq": 10, "text": "” 屈原曰：“吾闻之，新沐者必弹冠，新浴者必振衣，人又谁能以身之察察，受物之汶汶者乎！", "len": 43}
{"sid": "084_屈原贾生列传.7.s11", "chapter": "084_屈原贾生列传", "para": "7", "seq": 11, "text": "宁赴常流而葬乎江鱼腹中耳，又安能以皓皓之白而蒙世俗之温蠖乎！", "len": 30}
{"sid": "084_屈原贾生列传.7.s12", "chapter": "084_屈原贾生列传", "para": "7", "seq": 12, "text": "” ::: 赋", "len": 7}
{"sid": "084_屈原贾生列传.8.1.s1", "chapter": "084_屈原贾生列传", "para": "8.1", "seq": 1, "text": "乃作怀沙之赋。", "len": 7}
{"sid": "084_屈原贾生列传.8.1.s2", "chapter": "084_屈原贾生列传", "para": "8.1", "seq": 2, "text": "其辞曰：", "len": 4}
{"sid": "084_屈原贾生列传.8.2.s1", "chapter": "084_屈原贾生列传", "para": "8.2", "seq": 1, "text": "陶陶孟夏兮，草木莽莽。", "len": 11}
{"sid": "084_屈原贾生列传.8.2.s2", "chapter": "084_屈原贾生列传", "para": "8.2", "seq": 2, "text": "伤怀永哀兮，汩徂南土。", "len": 11}
{"sid": "084_屈原贾生列传.8.2.s3", "chapter": "084_屈原贾生列传", "para": "8.2", "seq": 3, "text": "眴兮窈窈，孔静幽墨。", "len": 10}
{"sid": "084_屈原贾生列传.8.2.s4", "chapter": "084_屈原贾生列传", "para": "8.2", "seq": 4, "text": "冤结纡轸兮，离愍之长鞠； 抚情效志兮，俯诎以自抑。", "len": 25}
{"sid": "084_屈原贾生列传.8.3.s1", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 1, "text": "刓方以为圜兮，常度未替； 易初本由兮，君子所鄙。", "len": 24}
{"sid": "084_屈原贾生列传.8.3.s2", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 2, "text": "章画职墨兮，前度未改； 内直质重兮，大人所盛。", "len": 23}
{"sid": "084_屈原贾生列传.8.3.s3", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 3, "text": "巧匠不斫兮，孰察其揆正？", "len": 12}
{"sid": "084_屈原贾生列传.8.3.s4", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 4, "text": "玄文幽处兮，矇谓之不章； 离娄微睇兮，瞽以为无明。", "len": 25}
{"sid": "084_屈原贾生列传.8.3.s5", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 5, "text": "变白而为黑兮，倒上以为下。", "len": 13}
{"sid": "084_屈原贾生列传.8.3.s6", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 6, "text": "凤皇在笯兮，鸡雉翔舞。", "len": 11}
{"sid": "084_屈原贾生列传.8.3.s7", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 7, "text": "同糅玉石兮，一而相量。", "len": 11}
{"sid": "084_屈原贾生列传.8.3.s8", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 8, "text": "夫党人之鄙妒兮，羌不知吾所臧。", "len": 15}
{"sid": "084_屈原贾生列传.8.3.s9", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 9, "text": "任重载盛兮，陷滞而不济； 怀瑾握瑜兮，穷不得余所示。", "len": 26}
{"sid": "084_屈原贾生列传.8.3.s10", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 10, "text": "邑犬群吠兮，吠所怪也； 诽骏疑桀兮，固庸态也。", "len": 23}
{"sid": "084_屈原贾生列传.8.3.s11", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 11, "text": "文质疏内兮，众不知吾之异采； 材朴委积兮，莫知余之所有。", "len": 28}
{"sid": "084_屈原贾生列传.8.3.s12", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 12, "text": "重仁袭义兮，谨厚以为丰； 重华不可牾兮，孰知余之从容！", "len": 27}
{"sid": "084_屈原贾生列传.8.3.s13", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 13, "text": "古固有不并兮，岂知其故也？", "len": 13}
{"sid": "084_屈原贾生列传.8.3.s14", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 14, "text": "汤禹久远兮，邈不可慕也。", "len": 12}
{"sid": "084_屈原贾生列传.8.3.s15", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 15, "text": "惩违改忿兮，抑心而自彊； 离湣而不迁兮，原志之有象。", "len": 26}
{"sid": "084_屈原贾生列传.8.3.s16", "chapter": "084_屈原贾生列传", "para": "8.3", "seq": 16, "text": "进路北次兮，日昧昧其将暮； 含忧虞哀兮，限之以大故。", "len": 26}
{"sid": "084_屈原贾生列传.8.4.s1", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 1, "text": "乱曰：浩浩沅、湘兮，分流汨兮。", "len": 15}
{"sid": "084_屈原贾生列传.8.4.s2", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 2, "text": "脩路幽拂兮，道远忽兮。", "len": 11}
{"sid": "084_屈原贾生列传.8.4.s3", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 3, "text": "曾唫恆悲兮，永叹慨兮。", "len": 11}
{"sid": "084_屈原贾生列传.8.4.s4", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 4, "text": "世既莫吾知兮，人心不可谓兮。", "len": 14}
{"sid": "084_屈原贾生列传.8.4.s5", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 5, "text": "怀情抱质兮，独无匹兮。", "len": 11}
{"sid": "084_屈原贾生列传.8.4.s6", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 6, "text": "伯乐既殁兮，骥将焉程兮？", "len": 12}
{"sid": "084_屈原贾生列传.8.4.s7", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 7, "text": "人生禀命兮，各有所错兮。", "len": 12}
{"sid": "084_屈原贾生列传.8.4.s8", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 8, "text": "定心广志，馀何畏惧兮？", "len": 11}
{"sid": "084_屈原贾生列传.8.4.s9", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 9, "text": "曾伤爰哀，永叹喟兮。", "len": 10}
{"sid": "084_屈原贾生列传.8.4.s10", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 10, "text": "世溷不吾知，心不可谓兮。", "len": 12}
{"sid": "084_屈原贾生列传.8.4.s11", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 11, "text": "知死不可让兮，原勿爱兮。", "len": 12}
{"sid": "084_屈原贾生列传.8.4.s12", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 12, "text": "明以告君子兮，吾将以为类兮。", "len": 14}
{"sid": "084_屈原贾生列传.8.4.s13", "chapter": "084_屈原贾生列传", "para": "8.4", "seq": 13, "text": ":::", "len": 3}
{"sid": "084_屈原贾生列传.9.1.s1", "chapter": "084_屈原贾生列传", "para": "9.1", "seq": 1, "text": "於是怀石遂自汨罗以死。", "len": 11}
{"sid": "084_屈原贾生列传.9.2.s1", "chapter": "084_屈原贾生列传", "para": "9.2", "seq": 1, "text": "屈原既死之後，楚有宋玉、唐勒、景差之徒者，皆好辞而以赋见称；然皆祖屈原之从容辞令，终莫敢直谏。", "len": 47}
{"sid": "084_屈原贾生列传.9.2.s2", "chapter": "084_屈原贾生列传", "para": "9.2", "seq": 2, "text": "其後楚日以削，数十年竟为秦所灭。", "len": 16}
{"sid": "084_屈原贾生列传.10.1.s1", "chapter": "084_屈原贾生列传", "para": "10.1", "seq": 1, "text": "自屈原沈汨罗後百有馀年，汉有贾生，为长沙王太傅，过湘水，投书以吊屈原。", "len": 35}
{"sid": "084_屈原贾生列传.10.2.s1", "chapter": "084_屈原贾生列传", "para": "10.2", "seq": 1, "text": "贾生名谊，雒阳人也。", "len": 10}
{"sid": "084_屈原贾生列传.10.2.s2", "chapter": "084_屈原贾生列传", "para": "10.2", "seq": 2, "text": "年十八，以能诵诗属书闻於郡中。", "len": 15}
{"sid": "084_屈原贾生列传.10.2.s3", "chapter": "084_屈原贾生列传", "para": "10.2", "seq": 3, "text": "吴公为河南守，闻其秀才，召置门下，甚幸爱。", "len": 21}
{"sid": "084_屈原贾生列传.10.2.s4", "chapter": "084_屈原贾生列传", "para": "10.2", "seq": 4, "text": "孝文皇帝初立，闻河南守吴公治平为天下第一，故与李斯同邑而常学事焉，乃徵为廷尉。", "len": 39}
{"sid": "084_屈原贾生列传.10.2.s5", "chapter": "084_屈原贾生列传", "para": "10.2", "seq": 5, "text": "廷尉乃言贾生年少，颇通诸子百家之书。", "len": 18}
{"sid": "084_屈原贾生列传.10.2.s6", "chapter": "084_屈原贾生列传", "para": "10.2", "seq": 6, "text": "文帝召以为博士。", "len": 8}
{"sid": "084_屈原贾生列传.10.3.s1", "chapter": "084_屈原贾生列传", "para": "10.3", "seq": 1, "text": "是时贾生年二十馀，最为少。", "len": 13}
{"sid": "084_屈原贾生列传.10.3.s2", "chapter": "084_屈原贾生列传", "para": "10.3", "seq": 2, "text": "每诏令议下，诸老先生不能言，贾生尽为之对，人人各如其意所欲出。", "len": 31}
{"sid": "084_屈原贾生列传.10.3.s3", "chapter": "084_屈原贾生列传", "para": "10.3", "seq": 3, "text": "诸生於是乃以为能，不及也。", "len": 13}
{"sid": "084_屈原贾生列传.10.3.s4", "chapter": "084_屈原贾生列传", "para": "10.3", "seq": 4, "text": "孝文帝说之，超迁，一岁中至太中大夫。", "len": 18}
{"sid": "084_屈原贾生列传.11.1.s1", "chapter": "084_屈原贾生列传", "para": "11.1", "seq": 1, "text": "贾生以为汉兴至孝文二十馀年，天下和洽，而固当改正朔，易服色，法制度，定官名，兴礼乐，乃悉草具其事仪法，色尚黄，数用五，为官名，悉更秦之法。", "len": 69}
{"sid": "084_屈原贾生列传.11.1.s2", "chapter": "084_屈原贾生列传", "para": "11.1", "seq": 2, "text": "孝文帝初即位，谦让未遑也。", "len": 13}
{"sid": "084_屈原贾生列传.11.1.s3", "chapter": "084_屈原贾生列传", "para": "11.1", "seq": 3, "text": "诸律令所更定，及列侯悉就国，其说皆自贾生发之。", "len": 23}
{"sid": "084_屈原贾生列传.11.2.s1", "chapter": "084_屈原贾生列传", "para": "11.2", "seq": 1, "text": "於是天子议以为贾生任公卿之位。", "len": 15}
{"sid": "084_屈原贾生列传.11.2.s2", "chapter": "084_屈原贾生列传", "para": "11.2", "seq": 2, "text": "绛、灌、东阳侯、冯敬之属尽害之，乃短贾生曰：“雒阳之人，年少初学，专欲擅权，纷乱诸事。", "len": 43}
{"sid": "084_屈原贾生列传.11.2.s3", "chapter": "084_屈原贾生列传", "para": "11.2", "seq": 3, "text": "” 於是天子後亦疏之，不用其议，乃以贾生为长沙王太傅。", "len": 27}
{"sid": "084_屈原贾生列传.11.2.s4", "chapter": "084_屈原贾生列传", "para": "11.2", "seq": 4, "text": "::: 赋", "len": 5}
{"sid": "084_屈原贾生列传.12.1.s1", "chapter": "084_屈原贾生列传", "para": "12.1", "seq": 1, "text": "贾生既辞往行，闻长沙卑湿，自以寿不得长，又以適去，意不自得。", "len": 30}
{"sid": "084_屈原贾生列传.12.1.s2", "chapter": "084_屈原贾生列传", "para": "12.1", "seq": 2, "text": "及渡湘水，为赋以吊屈原。", "len": 12}
{"sid": "084_屈原贾生列传.12.1.s3", "chapter": "084_屈原贾生列传", "para": "12.1", "seq": 3, "text": "其辞曰：", "len": 4}
{"sid": "084_屈原贾生列传.12.2.s1", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 1, "text": "共承嘉惠兮，俟罪长沙。", "len": 11}
{"sid": "084_屈原贾生列传.12.2.s2", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 2, "text": "侧闻屈原兮，自沈汨罗。", "len": 11}
{"sid": "084_屈原贾生列传.12.2.s3", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 3, "text": "造讬湘流兮，敬吊先生。", "len": 11}
{"sid": "084_屈原贾生列传.12.2.s4", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 4, "text": "遭世罔极兮，乃陨厥身。", "len": 11}
{"sid": "084_屈原贾生列传.12.2.s5", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 5, "text": "呜呼哀哉，逢时不祥！", "len": 10}
{"sid": "084_屈原贾生列传.12.2.s6", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 6, "text": "鸾凤伏窜兮，鸱枭翱翔。", "len": 11}
{"sid": "084_屈原贾生列传.12.2.s7", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 7, "text": "阘茸尊显兮，谗谀得志； 贤圣逆曳兮，方正倒植。", "len": 23}
{"sid": "084_屈原贾生列传.12.2.s8", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 8, "text": "世谓伯夷贪兮，谓盗跖廉； 莫邪为顿兮，铅刀为銛。", "len": 24}
{"sid": "084_屈原贾生列传.12.2.s9", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 9, "text": "于嗟嚜嚜兮，生之无故！", "len": 11}
{"sid": "084_屈原贾生列传.12.2.s10", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 10, "text": "斡弃周鼎兮宝康瓠， 腾驾罢牛兮骖蹇驴， 骥垂两耳兮服盐车。", "len": 29}
{"sid": "084_屈原贾生列传.12.2.s11", "chapter": "084_屈原贾生列传", "para": "12.2", "seq": 11, "text": "章甫荐屦兮，渐不可久； 嗟苦先生兮，独离此咎！", "len": 23}
{"sid": "084_屈原贾生列传.12.3.s1", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 1, "text": "讯曰：已矣，国其莫我知，独堙郁兮其谁语？", "len": 20}
{"sid": "084_屈原贾生列传.12.3.s2", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 2, "text": "凤漂漂其高遰兮，夫固自缩而远去。", "len": 16}
{"sid": "084_屈原贾生列传.12.3.s3", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 3, "text": "袭九渊之神龙兮，沕深潜以自珍。", "len": 15}
{"sid": "084_屈原贾生列传.12.3.s4", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 4, "text": "弥融爚以隐处兮，夫岂从螘与蛭螾？", "len": 16}
{"sid": "084_屈原贾生列传.12.3.s5", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 5, "text": "所贵圣人之神德兮，远浊世而自藏。", "len": 16}
{"sid": "084_屈原贾生列传.12.3.s6", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 6, "text": "使骐骥可得系羁兮，岂云异夫犬羊！", "len": 16}
{"sid": "084_屈原贾生列传.12.3.s7", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 7, "text": "般纷纷其离此尤兮，亦夫子之辜也！", "len": 16}
{"sid": "084_屈原贾生列传.12.3.s8", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 8, "text": "瞝九州而相君兮，何必怀此都也？", "len": 15}
{"sid": "084_屈原贾生列传.12.3.s9", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 9, "text": "凤皇翔于千仞之上兮，览德军而下之； 见细德之险兮，摇增翮逝而去之。", "len": 33}
{"sid": "084_屈原贾生列传.12.3.s10", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 10, "text": "彼寻常之汙渎兮，岂能容吞舟之鱼！", "len": 16}
{"sid": "084_屈原贾生列传.12.3.s11", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 11, "text": "横江湖之鳣鲟兮，固将制於蚁蝼。", "len": 15}
{"sid": "084_屈原贾生列传.12.3.s12", "chapter": "084_屈原贾生列传", "para": "12.3", "seq": 12, "text": "::: ::: 赋", "len": 9}
{"sid": "084_屈原贾生列传.13.1.s1", "chapter": "084_屈原贾生列传", "para": "13.1", "seq": 1, "text": "贾生为长沙王太傅三年，有鸮飞入贾生舍，止于坐隅。", "len": 24}
{"sid": "084_屈原贾生列传.13.1.s2", "chapter": "084_屈原贾生列传", "para": "13.1", "seq": 2, "text": "楚人命鸮曰“服”。", "len": 9}
{"sid": "084_屈原贾生列传.13.1.s3", "chapter": "084_屈原贾生列传", "para": "13.1", "seq": 3, "text": "贾生既以適居长沙，长沙卑湿，自以为寿不得长，伤悼之，乃为赋以自广。", "len": 33}
{"sid": "084_屈原贾生列传.13.1.s4", "chapter": "084_屈原贾生列传", "para": "13.1", "seq": 4, "text": "其辞曰：", "len": 4}
{"sid": "084_屈原贾生列传.13.2.s1", "chapter": "084_屈原贾生列传", "para": "13.2", "seq": 1, "text": "单阏之岁兮，四月孟夏， 庚子日施兮，服集予舍， 止于坐隅，貌甚间暇。", "len": 34}
{"sid": "084_屈原贾生列传.13.2.s2", "chapter": "084_屈原贾生列传", "para": "13.2", "seq": 2, "text": "异物来集兮，私怪其故， 发书占之兮，筴言其度。", "len": 23}
{"sid": "084_屈原贾生列传.13.2.s3", "chapter": "084_屈原贾生列传", "para": "13.2", "seq": 3, "text": "曰“野鸟入处兮，主人将去”。", "len": 14}
{"sid": "084_屈原贾生列传.13.2.s4", "chapter": "084_屈原贾生列传", "para": "13.2", "seq": 4, "text": "请问于服兮：“予去何之？", "len": 12}
{"sid": "084_屈原贾生列传.13.2.s5", "chapter": "084_屈原贾生列传", "para": "13.2", "seq": 5, "text": "吉乎告我，凶言其菑。", "len": 10}
{"sid": "084_屈原贾生列传.13.2.s6", "chapter": "084_屈原贾生列传", "para": "13.2", "seq": 6, "text": "淹数之度兮，语予其期。", "len": 11}
{"sid": "084_屈原贾生列传.13.2.s7", "chapter": "084_屈原贾生列传", "para": "13.2", "seq": 7, "text": "” 服乃叹息，举首奋翼，口不能言，请对以意。", "len": 22}
{"sid": "084_屈原贾生列传.13.3.s1", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 1, "text": "万物变化兮，固无休息。", "len": 11}
{"sid": "084_屈原贾生列传.13.3.s2", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 2, "text": "斡流而迁兮，或推而还。", "len": 11}
{"sid": "084_屈原贾生列传.13.3.s3", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 3, "text": "形气转续兮，变化而嬗。", "len": 11}
{"sid": "084_屈原贾生列传.13.3.s4", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 4, "text": "沕穆无穷兮，胡可胜言！", "len": 11}
{"sid": "084_屈原贾生列传.13.3.s5", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 5, "text": "祸兮福所倚，福兮祸所伏； 忧喜聚门兮，吉凶同域。", "len": 24}
{"sid": "084_屈原贾生列传.13.3.s6", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 6, "text": "彼吴彊大兮，夫差以败； 越栖会稽兮，句践霸世。", "len": 23}
{"sid": "084_屈原贾生列传.13.3.s7", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 7, "text": "斯游遂成兮，卒被五刑； 傅说胥靡兮，乃相武丁。", "len": 23}
{"sid": "084_屈原贾生列传.13.3.s8", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 8, "text": "夫祸之与福兮，何异纠纆。", "len": 12}
{"sid": "084_屈原贾生列传.13.3.s9", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 9, "text": "命不可说兮，孰知其极？", "len": 11}
{"sid": "084_屈原贾生列传.13.3.s10", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 10, "text": "水激则旱兮，矢激则远。", "len": 11}
{"sid": "084_屈原贾生列传.13.3.s11", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 11, "text": "万物回薄兮，振荡相转。", "len": 11}
{"sid": "084_屈原贾生列传.13.3.s12", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 12, "text": "云蒸雨降兮，错缪相纷。", "len": 11}
{"sid": "084_屈原贾生列传.13.3.s13", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 13, "text": "大专槃物兮，坱轧无垠。", "len": 11}
{"sid": "084_屈原贾生列传.13.3.s14", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 14, "text": "天不可与虑兮，道不可与谋。", "len": 13}
{"sid": "084_屈原贾生列传.13.3.s15", "chapter": "084_屈原贾生列传", "para": "13.3", "seq": 15, "text": "迟数有命兮，恶识其时？", "len": 11}
{"sid": "084_屈原贾生列传.13.4.s1", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 1, "text": "且夫天地为炉兮，造化为工； 阴阳为炭兮，万物为铜。", "len": 25}
{"sid": "084_屈原贾生列传.13.4.s2", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 2, "text": "合散消息兮，安有常则； 千变万化兮，未始有极。", "len": 23}
{"sid": "084_屈原贾生列传.13.4.s3", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 3, "text": "忽然为人兮，何足控抟； 化为异物兮，又何足患！", "len": 23}
{"sid": "084_屈原贾生列传.13.4.s4", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 4, "text": "小知自私兮，贱彼贵我； 通人大观兮，物无不可。", "len": 23}
{"sid": "084_屈原贾生列传.13.4.s5", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 5, "text": "贪夫徇财兮，烈士徇名； 夸者死权兮，品庶冯生。", "len": 23}
{"sid": "084_屈原贾生列传.13.4.s6", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 6, "text": "述迫之徒兮，或趋西东； 大人不曲兮，亿变齐同。", "len": 23}
{"sid": "084_屈原贾生列传.13.4.s7", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 7, "text": "拘士系俗兮，羖如囚拘； 至人遗物兮，独与道俱。", "len": 23}
{"sid": "084_屈原贾生列传.13.4.s8", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 8, "text": "众人或或兮，好恶积意； 真人淡漠兮，独与道息。", "len": 23}
{"sid": "084_屈原贾生列传.13.4.s9", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 9, "text": "释知遗形兮，超然自丧； 寥廓忽荒兮，与道翱翔。", "len": 23}
{"sid": "084_屈原贾生列传.13.4.s10", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 10, "text": "乘流则逝兮，得坻则止； 纵躯委命兮，不私与己。", "len": 23}
{"sid": "084_屈原贾生列传.13.4.s11", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 11, "text": "其生若浮兮，其死若休； 澹乎若深渊之静，氾乎若不系之舟。", "len": 28}
{"sid": "084_屈原贾生列传.13.4.s12", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 12, "text": "不以生故自宝兮，养空而浮； 德人无累兮，知命不忧。", "len": 25}
{"sid": "084_屈原贾生列传.13.4.s13", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 13, "text": "细故粦兮，何足以疑！", "len": 10}
{"sid": "084_屈原贾生列传.13.4.s14", "chapter": "084_屈原贾生列传", "para": "13.4", "seq": 14, "text": ":::", "len": 3}
{"sid": "084_屈原贾生列传.14.1.s1", "chapter": "084_屈原贾生列传", "para": "14.1", "seq": 1, "text": "後岁馀，贾生徵见。", "len": 9}
{"sid": "084_屈原贾生列传.14.1.s2", "chapter": "084_屈原贾生列传", "para": "14.1", "seq": 2, "text": "孝文帝方受釐，坐宣室。", "len": 11}
{"sid": "084_屈原贾生列传.14.1.s3", "chapter": "084_屈原贾生列传", "para": "14.1", "seq": 3, "text": "上因感鬼神事，而问鬼神之本。", "len": 14}
{"sid": "084_屈原贾生列传.14.1.s4", "chapter": "084_屈原贾生列传", "para": "14.1", "seq": 4, "text": "贾生因具道所以然之状。", "len": 11}
{"sid": "084_屈原贾生列传.14.1.s5", "chapter": "084_屈原贾生列传", "para": "14.1", "seq": 5, "text": "至夜半，文帝前席。", "len": 9}
{"sid": "084_屈原贾生列传.14.1.s6", "chapter": "084_屈原贾生列传", "para": "14.1", "seq": 6, "text": "既罢，曰：“吾久不见贾生，自以为过之，今不及也。", "len": 24}
{"sid": "084_屈原贾生列传.14.1.s7", "chapter": "084_屈原贾生列传", "para": "14.1", "seq": 7, "text": "” 居顷之，拜贾生为梁怀王太傅。", "len": 16}
{"sid": "084_屈原贾生列传.14.1.s8", "chapter": "084_屈原贾生列传", "para": "14.1", "seq": 8, "text": "梁怀王，文帝之少子，爱，而好书，故令贾生傅之。", "len": 23}
{"sid": "084_屈原贾生列传.14.2.s1", "chapter": "084_屈原贾生列传", "para": "14.2", "seq": 1, "text": "文帝复封淮南厉王子四人皆为列侯。", "len": 16}
{"sid": "084_屈原贾生列传.14.2.s2", "chapter": "084_屈原贾生列传", "para": "14.2", "seq": 2, "text": "贾生谏，以为患之兴自此起矣。", "len": 14}
{"sid": "084_屈原贾生列传.14.2.s3", "chapter": "084_屈原贾生列传", "para": "14.2", "seq": 3, "text": "贾生数上疏，言诸侯或连数郡，非古之制，可稍削之。", "len": 24}
{"sid": "084_屈原贾生列传.14.2.s4", "chapter": "084_屈原贾生列传", "para": "14.2", "seq": 4, "text": "文帝不听。", "len": 5}
{"sid": "084_屈原贾生列传.15.1.s1", "chapter": "084_屈原贾生列传", "para": "15.1", "seq": 1, "text": "居数年，怀王骑，堕马而死，无後。", "len": 16}
{"sid": "084_屈原贾生列传.15.1.s2", "chapter": "084_屈原贾生列传", "para": "15.1", "seq": 2, "text": "贾生自伤为傅无状，哭泣岁馀，亦死。", "len": 17}
{"sid": "084_屈原贾生列传.15.1.s3", "chapter": "084_屈原贾生列传", "para": "15.1", "seq": 3, "text": "贾生之死时年三十三矣。", "len": 11}
{"sid": "084_屈原贾生列传.15.1.s4", "chapter": "084_屈原贾生列传", "para": "15.1", "seq": 4, "text": "及孝文崩，孝武皇帝立，举贾生之孙二人至郡守，而贾嘉最好学，世其家，与余通书。", "len": 38}
{"sid": "084_屈原贾生列传.15.1.s5", "chapter": "084_屈原贾生列传", "para": "15.1", "seq": 5, "text": "至孝昭时，列为九卿。", "len": 10}
{"sid": "084_屈原贾生列传.16.s1", "chapter": "084_屈原贾生列传", "para": "16", "seq": 1, "text": "太史公曰：余读离骚、天问、招魂、哀郢，悲其志。", "len": 23}
{"sid": "084_屈原贾生列传.16.s2", "chapter": "084_屈原贾生列传", "para": "16", "seq": 2, "text": "適长沙，观屈原所自沈渊，未尝不垂涕，想见其为人。", "len": 24}
{"sid": "084_屈原贾生列传.16.s3", "chapter": "084_屈原贾生列传", "para": "16", "seq": 3, "text": "及见贾生吊之，又怪屈原以彼其材，游诸侯，何国不容，而自令若是。", "len": 31}
{"sid": "084_屈原贾生列传.16.s4", "chapter": "084_屈原贾生列传", "para": "16", "seq": 4, "text": "读服乌赋，同死生，轻去就，又爽然自失矣。", "len": 20}
{"sid": "084_屈原贾生列传.16.s5", "chapter": "084_屈原贾生列传", "para": "16", "seq": 5, "text": "::: 赞", "len": 5}
{"sid": "084_屈原贾生列传.17.s1", "chapter": "084_屈原贾生列传", "para": "17", "seq": 1, "text": "屈平行正，以事怀王。", "len": 10}
{"sid": "084_屈原贾生列传.17.s2", "chapter": "084_屈原贾生列传", "para": "17", "seq": 2, "text": "瑾瑜比洁，日月争光。", "len": 10}
{"sid": "084_屈原贾生列传.17.s3", "chapter": "084_屈原贾生列传", "para": "17", "seq": 3, "text": "忠而见放，谗者益章。", "len": 10}
{"sid": "084_屈原贾生列传.17.s4", "chapter": "084_屈原贾生列传", "para": "17", "seq": 4, "text": "赋骚见志，怀沙自伤。", "len": 10}
{"sid": "084_屈原贾生列传.17.s5", "chapter": "084_屈原贾生列传", "para": "17", "seq": 5, "text": "百年之後，空悲吊湘。", "len": 10}
{"sid": "084_屈原贾生列传.17.s6", "chapter": "084_屈原贾生列传", "para": "17", "seq": 6, "text": ":::", "len": 3}
