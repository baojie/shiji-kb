{"sid": "109_李将军列传.1.s1", "chapter": "109_李将军列传", "para": "1", "seq": 1, "text": "李将军广者，陇西成纪人也。", "len": 13}
{"sid": "109_李将军列传.1.s2", "chapter": "109_李将军列传", "para": "1", "seq": 2, "text": "其先曰李信，秦时为将，逐得燕太子丹者也。", "len": 20}
{"sid": "109_李将军列传.1.s3", "chapter": "109_李将军列传", "para": "1", "seq": 3, "text": "故槐里，徙成纪。", "len": 8}
{"sid": "109_李将军列传.1.s4", "chapter": "109_李将军列传", "para": "1", "seq": 4, "text": "广家世世受射。", "len": 7}
{"sid": "109_李将军列传.1.s5", "chapter": "109_李将军列传", "para": "1", "seq": 5, "text": "孝文帝十四年，匈奴大入萧关，而广以良家子从军击胡，用善骑射，杀首虏多，为汉中郎。", "len": 40}
{"sid": "109_李将军列传.1.s6", "chapter": "109_李将军列传", "para": "1", "seq": 6, "text": "广从弟李蔡亦为郎，皆为武骑常侍，秩八百石。", "len": 21}
{"sid": "109_李将军列传.1.s7", "chapter": "109_李将军列传", "para": "1", "seq": 7, "text": "尝从行，有所旻陷折关及格猛兽，而文帝曰：“惜乎，子不遇时！", "len": 29}
{"sid": "109_李将军列传.1.s8", "chapter": "109_李将军列传", "para": "1", "seq": 8, "text": "如令子当高帝时，万户侯岂足道哉！”", "len": 17}
{"sid": "109_李将军列传.2.s1", "chapter": "109_李将军列传", "para": "2", "seq": 1, "text": "及孝景初立，广为陇西都尉，徙为骑郎将。", "len": 19}
{"sid": "109_李将军列传.2.s2", "chapter": "109_李将军列传", "para": "2", "seq": 2, "text": "吴楚军时，广为骁骑都尉，从太尉亚夫击吴楚军，取旗，显功名昌邑下。", "len": 32}
{"sid": "109_李将军列传.2.s3", "chapter": "109_李将军列传", "para": "2", "seq": 3, "text": "以梁王授广将军印，还，赏不行。", "len": 15}
{"sid": "109_李将军列传.2.s4", "chapter": "109_李将军列传", "para": "2", "seq": 4, "text": "徙为上谷太守，匈奴日以合战。", "len": 14}
{"sid": "109_李将军列传.2.s5", "chapter": "109_李将军列传", "para": "2", "seq": 5, "text": "典属国公孙昆邪为上泣曰：“李广才气，天下无双，自负其能，数与虏敌战，恐亡之。", "len": 38}
{"sid": "109_李将军列传.2.s6", "chapter": "109_李将军列传", "para": "2", "seq": 6, "text": "” 於是乃徙为上郡太守。", "len": 12}
{"sid": "109_李将军列传.2.s7", "chapter": "109_李将军列传", "para": "2", "seq": 7, "text": "後广转为边郡太守，徙上郡。", "len": 13}
{"sid": "109_李将军列传.2.s8", "chapter": "109_李将军列传", "para": "2", "seq": 8, "text": "尝为陇西、北地、雁门、代郡、云中太守，皆以力战为名。", "len": 26}
{"sid": "109_李将军列传.3.s1", "chapter": "109_李将军列传", "para": "3", "seq": 1, "text": "匈奴大入上郡，天子使中贵人从广勒习兵击匈奴。", "len": 22}
{"sid": "109_李将军列传.3.s2", "chapter": "109_李将军列传", "para": "3", "seq": 2, "text": "中贵人将骑数十纵，见匈奴三人，与战。", "len": 18}
{"sid": "109_李将军列传.3.s3", "chapter": "109_李将军列传", "para": "3", "seq": 3, "text": "三人还射，伤中贵人，杀其骑且尽。", "len": 16}
{"sid": "109_李将军列传.3.s4", "chapter": "109_李将军列传", "para": "3", "seq": 4, "text": "中贵人走广。", "len": 6}
{"sid": "109_李将军列传.3.s5", "chapter": "109_李将军列传", "para": "3", "seq": 5, "text": "广曰：“是必射雕者也。", "len": 11}
{"sid": "109_李将军列传.3.s6", "chapter": "109_李将军列传", "para": "3", "seq": 6, "text": "” 广乃遂从百骑往驰三人。", "len": 13}
{"sid": "109_李将军列传.3.s7", "chapter": "109_李将军列传", "para": "3", "seq": 7, "text": "三人亡马步行，行数十里。", "len": 12}
{"sid": "109_李将军列传.3.s8", "chapter": "109_李将军列传", "para": "3", "seq": 8, "text": "广令其骑张左右翼，而广身自射彼三人者，杀其二人，生得一人，果匈奴射雕者也。", "len": 37}
{"sid": "109_李将军列传.3.s9", "chapter": "109_李将军列传", "para": "3", "seq": 9, "text": "已缚之上马，望匈奴有数千骑，见广，以为诱骑，皆惊，上山陈。", "len": 29}
{"sid": "109_李将军列传.3.s10", "chapter": "109_李将军列传", "para": "3", "seq": 10, "text": "广之百骑皆大恐，欲驰还走。", "len": 13}
{"sid": "109_李将军列传.3.s11", "chapter": "109_李将军列传", "para": "3", "seq": 11, "text": "广曰：“吾去大军数十里，今如此以百骑走，匈奴追射我立尽。", "len": 28}
{"sid": "109_李将军列传.3.s12", "chapter": "109_李将军列传", "para": "3", "seq": 12, "text": "今我留，匈奴必以我为大军诱，必不敢击我。", "len": 20}
{"sid": "109_李将军列传.3.s13", "chapter": "109_李将军列传", "para": "3", "seq": 13, "text": "” 广令诸骑曰：“前！", "len": 11}
{"sid": "109_李将军列传.3.s14", "chapter": "109_李将军列传", "para": "3", "seq": 14, "text": "” 前未到匈奴陈二里所，止，令曰：“皆下马解鞍！", "len": 24}
{"sid": "109_李将军列传.3.s15", "chapter": "109_李将军列传", "para": "3", "seq": 15, "text": "” 其骑曰：“虏多且近，即有急，柰何？", "len": 19}
{"sid": "109_李将军列传.3.s16", "chapter": "109_李将军列传", "para": "3", "seq": 16, "text": "” 广曰：“彼虏以我为走，今皆解鞍以示不走，用坚其意。", "len": 27}
{"sid": "109_李将军列传.3.s17", "chapter": "109_李将军列传", "para": "3", "seq": 17, "text": "” 於是胡骑遂不敢击。", "len": 11}
{"sid": "109_李将军列传.3.s18", "chapter": "109_李将军列传", "para": "3", "seq": 18, "text": "有白马将出护其兵，李广上马与十馀骑奔射杀胡白马将，而复还至其骑中，解鞍，令士皆纵马卧。", "len": 43}
{"sid": "109_李将军列传.3.s19", "chapter": "109_李将军列传", "para": "3", "seq": 19, "text": "是时会暮，胡兵终怪之，不敢击。", "len": 15}
{"sid": "109_李将军列传.3.s20", "chapter": "109_李将军列传", "para": "3", "seq": 20, "text": "夜半时，胡兵亦以为汉有伏军於旁欲夜取之，胡皆引兵而去。", "len": 27}
{"sid": "109_李将军列传.3.s21", "chapter": "109_李将军列传", "para": "3", "seq": 21, "text": "平旦，李广乃归其大军。", "len": 11}
{"sid": "109_李将军列传.3.s22", "chapter": "109_李将军列传", "para": "3", "seq": 22, "text": "大军不知广所之，故弗从。", "len": 12}
{"sid": "109_李将军列传.4.s1", "chapter": "109_李将军列传", "para": "4", "seq": 1, "text": "居久之，孝景崩，武帝立，左右以为广名将也，於是广以上郡太守为未央卫尉，而程不识亦为长乐卫尉。", "len": 46}
{"sid": "109_李将军列传.4.s2", "chapter": "109_李将军列传", "para": "4", "seq": 2, "text": "程不识故与李广俱以边太守将军屯。", "len": 16}
{"sid": "109_李将军列传.4.s3", "chapter": "109_李将军列传", "para": "4", "seq": 3, "text": "及出击胡，而广行无部伍行陈，就善水草屯，舍止，人人自便，不击刀斗以自卫，莫府省约文书籍事，然亦远斥候，未尝遇害。", "len": 56}
{"sid": "109_李将军列传.4.s4", "chapter": "109_李将军列传", "para": "4", "seq": 4, "text": "程不识正部曲行伍营陈，击刀斗，士吏治军簿至明，军不得休息，然亦未尝遇害。", "len": 36}
{"sid": "109_李将军列传.4.s5", "chapter": "109_李将军列传", "para": "4", "seq": 5, "text": "不识曰：“李广军极简易，然虏卒犯之，无以禁也；而其士卒亦佚乐，咸乐为之死。", "len": 37}
{"sid": "109_李将军列传.4.s6", "chapter": "109_李将军列传", "para": "4", "seq": 6, "text": "我军虽烦扰，然虏亦不得犯我。", "len": 14}
{"sid": "109_李将军列传.4.s7", "chapter": "109_李将军列传", "para": "4", "seq": 7, "text": "” 是时汉边郡李广、程不识皆为名将，然匈奴畏李广之略，士卒亦多乐从李广而苦程不识。", "len": 41}
{"sid": "109_李将军列传.4.s8", "chapter": "109_李将军列传", "para": "4", "seq": 8, "text": "程不识孝景时以数直谏为太中大夫。", "len": 16}
{"sid": "109_李将军列传.4.s9", "chapter": "109_李将军列传", "para": "4", "seq": 9, "text": "为人廉，谨於文法。", "len": 9}
{"sid": "109_李将军列传.5.s1", "chapter": "109_李将军列传", "para": "5", "seq": 1, "text": "後汉以马邑城诱单于，使大军伏马邑旁谷，而广为骁骑将军，领属护军将军。", "len": 34}
{"sid": "109_李将军列传.5.s2", "chapter": "109_李将军列传", "para": "5", "seq": 2, "text": "是时单于觉之，去，汉军皆无功。", "len": 15}
{"sid": "109_李将军列传.5.s3", "chapter": "109_李将军列传", "para": "5", "seq": 3, "text": "其後四岁，广以卫尉为将军，出雁门击匈奴。", "len": 20}
{"sid": "109_李将军列传.5.s4", "chapter": "109_李将军列传", "para": "5", "seq": 4, "text": "匈奴兵多，破败广军，生得广。", "len": 14}
{"sid": "109_李将军列传.5.s5", "chapter": "109_李将军列传", "para": "5", "seq": 5, "text": "单于素闻广贤，令曰：“得李广必生致之。", "len": 19}
{"sid": "109_李将军列传.5.s6", "chapter": "109_李将军列传", "para": "5", "seq": 6, "text": "” 胡骑得广，广时伤病，置广两马间，络而盛卧广。", "len": 24}
{"sid": "109_李将军列传.5.s7", "chapter": "109_李将军列传", "para": "5", "seq": 7, "text": "行十馀里，广详死，睨其旁有一胡兒骑善马，广暂腾而上胡兒马，因推堕兒，取其弓，鞭马南驰数十里，复得其馀军，因引而入塞。", "len": 58}
{"sid": "109_李将军列传.5.s8", "chapter": "109_李将军列传", "para": "5", "seq": 8, "text": "匈奴捕者骑数百追之，广行取胡兒弓，射杀追骑，以故得脱。", "len": 27}
{"sid": "109_李将军列传.5.s9", "chapter": "109_李将军列传", "para": "5", "seq": 9, "text": "於是至汉，汉下广吏。", "len": 10}
{"sid": "109_李将军列传.5.s10", "chapter": "109_李将军列传", "para": "5", "seq": 10, "text": "吏当广所失亡多，为虏所生得，当斩，赎为庶人。", "len": 22}
{"sid": "109_李将军列传.6.s1", "chapter": "109_李将军列传", "para": "6", "seq": 1, "text": "顷之，家居数岁。", "len": 8}
{"sid": "109_李将军列传.6.s2", "chapter": "109_李将军列传", "para": "6", "seq": 2, "text": "广家与故颍阴侯孙屏野居蓝田南山中射猎。", "len": 19}
{"sid": "109_李将军列传.6.s3", "chapter": "109_李将军列传", "para": "6", "seq": 3, "text": "尝夜从一骑出，从人田间饮。", "len": 13}
{"sid": "109_李将军列传.6.s4", "chapter": "109_李将军列传", "para": "6", "seq": 4, "text": "还至霸陵亭，霸陵尉醉，呵止广。", "len": 15}
{"sid": "109_李将军列传.6.s5", "chapter": "109_李将军列传", "para": "6", "seq": 5, "text": "广骑曰：“故李将军。", "len": 10}
{"sid": "109_李将军列传.6.s6", "chapter": "109_李将军列传", "para": "6", "seq": 6, "text": "” 尉曰：“今将军尚不得夜行，何乃故也！", "len": 20}
{"sid": "109_李将军列传.6.s7", "chapter": "109_李将军列传", "para": "6", "seq": 7, "text": "” 止广宿亭下。", "len": 8}
{"sid": "109_李将军列传.6.s8", "chapter": "109_李将军列传", "para": "6", "seq": 8, "text": "居无何，匈奴入杀辽西太守，败韩将军，後韩将军徙右北平。", "len": 27}
{"sid": "109_李将军列传.6.s9", "chapter": "109_李将军列传", "para": "6", "seq": 9, "text": "於是天子乃召拜广为右北平太守。", "len": 15}
{"sid": "109_李将军列传.6.s10", "chapter": "109_李将军列传", "para": "6", "seq": 10, "text": "广即请霸陵尉与俱，至军而斩之。", "len": 15}
{"sid": "109_李将军列传.7.s1", "chapter": "109_李将军列传", "para": "7", "seq": 1, "text": "广居右北平，匈奴闻之，号曰“汉之飞将军”，避之数岁，不敢入右北平。", "len": 33}
{"sid": "109_李将军列传.8.s1", "chapter": "109_李将军列传", "para": "8", "seq": 1, "text": "广出猎，见草中石，以为虎而射之，中石没镞，视之石也。", "len": 26}
{"sid": "109_李将军列传.8.s2", "chapter": "109_李将军列传", "para": "8", "seq": 2, "text": "因复更射之，终不能复入石矣。", "len": 14}
{"sid": "109_李将军列传.8.s3", "chapter": "109_李将军列传", "para": "8", "seq": 3, "text": "广所居郡闻有虎，尝自射之。", "len": 13}
{"sid": "109_李将军列传.8.s4", "chapter": "109_李将军列传", "para": "8", "seq": 4, "text": "及居右北平射虎，虎腾伤广，广亦竟射杀之。", "len": 20}
{"sid": "109_李将军列传.9.s1", "chapter": "109_李将军列传", "para": "9", "seq": 1, "text": "广廉，得赏赐辄分其麾下，饮食与士共之。", "len": 19}
{"sid": "109_李将军列传.9.s2", "chapter": "109_李将军列传", "para": "9", "seq": 2, "text": "终广之身，为二千石四十馀年，家无馀财，终不言家产事。", "len": 26}
{"sid": "109_李将军列传.9.s3", "chapter": "109_李将军列传", "para": "9", "seq": 3, "text": "广为人长，猿臂，其善射亦天性也，虽其子孙他人学者，莫能及广。", "len": 30}
{"sid": "109_李将军列传.9.s4", "chapter": "109_李将军列传", "para": "9", "seq": 4, "text": "广讷口少言，与人居则画地为军陈，射阔狭以饮。", "len": 22}
{"sid": "109_李将军列传.9.s5", "chapter": "109_李将军列传", "para": "9", "seq": 5, "text": "专以射为戏，竟死。", "len": 9}
{"sid": "109_李将军列传.9.s6", "chapter": "109_李将军列传", "para": "9", "seq": 6, "text": "广之将兵，乏绝之处，见水，士卒不尽饮，广不近水，士卒不尽食，广不尝食。", "len": 35}
{"sid": "109_李将军列传.9.s7", "chapter": "109_李将军列传", "para": "9", "seq": 7, "text": "宽缓不苛，士以此爱乐为用。", "len": 13}
{"sid": "109_李将军列传.9.s8", "chapter": "109_李将军列传", "para": "9", "seq": 8, "text": "其射，见敌急，非在数十步之内，度不中不发，发即应弦而倒。", "len": 28}
{"sid": "109_李将军列传.9.s9", "chapter": "109_李将军列传", "para": "9", "seq": 9, "text": "用此，其将兵数困辱，其射猛兽亦为所伤云。", "len": 20}
{"sid": "109_李将军列传.10.s1", "chapter": "109_李将军列传", "para": "10", "seq": 1, "text": "居顷之，石建卒，於是上召广代建为郎中令。", "len": 20}
{"sid": "109_李将军列传.10.s2", "chapter": "109_李将军列传", "para": "10", "seq": 2, "text": "元朔六年，广复为後将军，从大将军军出定襄，击匈奴。", "len": 25}
{"sid": "109_李将军列传.10.s3", "chapter": "109_李将军列传", "para": "10", "seq": 3, "text": "诸将多中首虏率，以功为侯者，而广军无功。", "len": 20}
{"sid": "109_李将军列传.10.s4", "chapter": "109_李将军列传", "para": "10", "seq": 4, "text": "後二岁，广以郎中令将四千骑出右北平，博望侯张骞将万骑与广俱，异道。", "len": 33}
{"sid": "109_李将军列传.10.s5", "chapter": "109_李将军列传", "para": "10", "seq": 5, "text": "行可数百里，匈奴左贤王将四万骑围广，广军士皆恐，广乃使其子敢往驰之。", "len": 34}
{"sid": "109_李将军列传.10.s6", "chapter": "109_李将军列传", "para": "10", "seq": 6, "text": "敢独与数十骑驰，直贯胡骑，出其左右而还，告广曰：“胡虏易与耳。", "len": 31}
{"sid": "109_李将军列传.10.s7", "chapter": "109_李将军列传", "para": "10", "seq": 7, "text": "” 军士乃安。", "len": 7}
{"sid": "109_李将军列传.10.s8", "chapter": "109_李将军列传", "para": "10", "seq": 8, "text": "广为圜陈外乡，胡急击之，矢下如雨。", "len": 17}
{"sid": "109_李将军列传.10.s9", "chapter": "109_李将军列传", "para": "10", "seq": 9, "text": "汉兵死者过半，汉矢且尽。", "len": 12}
{"sid": "109_李将军列传.10.s10", "chapter": "109_李将军列传", "para": "10", "seq": 10, "text": "广乃令士持满毋发，而广身自以大黄射其裨将，杀数人，胡虏益解。", "len": 30}
{"sid": "109_李将军列传.10.s11", "chapter": "109_李将军列传", "para": "10", "seq": 11, "text": "会日暮，吏士皆无人色，而广意气自如，益治军。", "len": 22}
{"sid": "109_李将军列传.10.s12", "chapter": "109_李将军列传", "para": "10", "seq": 12, "text": "军中自是服其勇也。", "len": 9}
{"sid": "109_李将军列传.10.s13", "chapter": "109_李将军列传", "para": "10", "seq": 13, "text": "明日，复力战，而博望侯军亦至，匈奴军乃解去。", "len": 22}
{"sid": "109_李将军列传.10.s14", "chapter": "109_李将军列传", "para": "10", "seq": 14, "text": "汉军罢，弗能追。", "len": 8}
{"sid": "109_李将军列传.10.s15", "chapter": "109_李将军列传", "para": "10", "seq": 15, "text": "是时广军几没，罢归。", "len": 10}
{"sid": "109_李将军列传.10.s16", "chapter": "109_李将军列传", "para": "10", "seq": 16, "text": "汉法，博望侯留迟後期，当死，赎为庶人。", "len": 19}
{"sid": "109_李将军列传.10.s17", "chapter": "109_李将军列传", "para": "10", "seq": 17, "text": "广军功自如，无赏。", "len": 9}
{"sid": "109_李将军列传.11.s1", "chapter": "109_李将军列传", "para": "11", "seq": 1, "text": "初，广之从弟李蔡与广俱事孝文帝。", "len": 16}
{"sid": "109_李将军列传.11.s2", "chapter": "109_李将军列传", "para": "11", "seq": 2, "text": "景帝时，蔡积功劳至二千石。", "len": 13}
{"sid": "109_李将军列传.11.s3", "chapter": "109_李将军列传", "para": "11", "seq": 3, "text": "孝武帝时，至代相。", "len": 9}
{"sid": "109_李将军列传.11.s4", "chapter": "109_李将军列传", "para": "11", "seq": 4, "text": "以元朔五年为轻车将车，从大将军击右贤王，有功中率，封为乐安侯。", "len": 31}
{"sid": "109_李将军列传.11.s5", "chapter": "109_李将军列传", "para": "11", "seq": 5, "text": "元狩二年中，代公孙弘为丞相。", "len": 14}
{"sid": "109_李将军列传.11.s6", "chapter": "109_李将军列传", "para": "11", "seq": 6, "text": "蔡为人在下中，名声出广下甚远，然广不得爵邑，官不过九卿，而蔡为列侯，位至三公。", "len": 39}
{"sid": "109_李将军列传.11.s7", "chapter": "109_李将军列传", "para": "11", "seq": 7, "text": "诸广之军吏及士卒或取封侯。", "len": 13}
{"sid": "109_李将军列传.11.s8", "chapter": "109_李将军列传", "para": "11", "seq": 8, "text": "广尝与望气王朔燕语，曰：“自汉击匈奴而广未尝不在其中，而诸部校尉以下，才能不及中人，然以击胡军功取侯者数十人，而广不为後人，然无尺寸之功以得封邑者，何也？", "len": 77}
{"sid": "109_李将军列传.11.s9", "chapter": "109_李将军列传", "para": "11", "seq": 9, "text": "岂吾相不当侯邪？", "len": 8}
{"sid": "109_李将军列传.11.s10", "chapter": "109_李将军列传", "para": "11", "seq": 10, "text": "且固命也？", "len": 5}
{"sid": "109_李将军列传.11.s11", "chapter": "109_李将军列传", "para": "11", "seq": 11, "text": "” 朔曰：“将军自念，岂尝有所恨乎？", "len": 18}
{"sid": "109_李将军列传.11.s12", "chapter": "109_李将军列传", "para": "11", "seq": 12, "text": "” 广曰：“吾尝为陇西守，羌尝反，吾诱而降，降者八百馀人，吾诈而同日杀之。", "len": 37}
{"sid": "109_李将军列传.11.s13", "chapter": "109_李将军列传", "para": "11", "seq": 13, "text": "至今大恨独此耳。", "len": 8}
{"sid": "109_李将军列传.11.s14", "chapter": "109_李将军列传", "para": "11", "seq": 14, "text": "” 朔曰：“祸莫大於杀已降，此乃将军所以不得侯者也。”", "len": 27}
{"sid": "109_李将军列传.12.s1", "chapter": "109_李将军列传", "para": "12", "seq": 1, "text": "後二岁，大将军、骠骑将军大出击匈奴，广数自请行。", "len": 24}
{"sid": "109_李将军列传.12.s2", "chapter": "109_李将军列传", "para": "12", "seq": 2, "text": "天子以为老，弗许；良久乃许之，以为前将军。", "len": 21}
{"sid": "109_李将军列传.12.s3", "chapter": "109_李将军列传", "para": "12", "seq": 3, "text": "是岁，元狩四年也。", "len": 9}
{"sid": "109_李将军列传.13.s1", "chapter": "109_李将军列传", "para": "13", "seq": 1, "text": "广既从大将军青击匈奴，既出塞，青捕虏知单于所居，乃自以精兵走之，而令广并於右将军军，出东道。", "len": 46}
{"sid": "109_李将军列传.13.s2", "chapter": "109_李将军列传", "para": "13", "seq": 2, "text": "东道少回远，而大军行水草少，其势不屯行。", "len": 20}
{"sid": "109_李将军列传.13.s3", "chapter": "109_李将军列传", "para": "13", "seq": 3, "text": "广自请曰：“臣部为前将军，今大将军乃徙令臣出东道，且臣结发而与匈奴战，今乃一得当单于，臣原居前，先死单于。", "len": 53}
{"sid": "109_李将军列传.13.s4", "chapter": "109_李将军列传", "para": "13", "seq": 4, "text": "” 大将军青亦阴受上诫，以为李广老，数奇，毋令当单于，恐不得所欲。", "len": 33}
{"sid": "109_李将军列传.13.s5", "chapter": "109_李将军列传", "para": "13", "seq": 5, "text": "而是时公孙敖新失侯，为中将军从大将军，大将军亦欲使敖与俱当单于，故徙前将军广。", "len": 39}
{"sid": "109_李将军列传.13.s6", "chapter": "109_李将军列传", "para": "13", "seq": 6, "text": "广时知之，固自辞於大将军。", "len": 13}
{"sid": "109_李将军列传.13.s7", "chapter": "109_李将军列传", "para": "13", "seq": 7, "text": "大将军不听，令长史封书与广之莫府，曰：“急诣部，如书。", "len": 27}
{"sid": "109_李将军列传.13.s8", "chapter": "109_李将军列传", "para": "13", "seq": 8, "text": "” 广不谢大将军而起行，意甚愠怒而就部，引兵与右将军食其合军出东道。", "len": 34}
{"sid": "109_李将军列传.13.s9", "chapter": "109_李将军列传", "para": "13", "seq": 9, "text": "军亡导，或失道，後大将军。", "len": 13}
{"sid": "109_李将军列传.13.s10", "chapter": "109_李将军列传", "para": "13", "seq": 10, "text": "大将军与单于接战，单于遁走，弗能得而还。", "len": 20}
{"sid": "109_李将军列传.13.s11", "chapter": "109_李将军列传", "para": "13", "seq": 11, "text": "南绝幕，遇前将军、右将军。", "len": 13}
{"sid": "109_李将军列传.13.s12", "chapter": "109_李将军列传", "para": "13", "seq": 12, "text": "广已见大将军，还入军。", "len": 11}
{"sid": "109_李将军列传.13.s13", "chapter": "109_李将军列传", "para": "13", "seq": 13, "text": "大将军使长史持Я醪遗广，因问广、食其失道状，青欲上书报天子军曲折。", "len": 33}
{"sid": "109_李将军列传.13.s14", "chapter": "109_李将军列传", "para": "13", "seq": 14, "text": "广未对，大将军使长史急责广之幕府对簿。", "len": 19}
{"sid": "109_李将军列传.13.s15", "chapter": "109_李将军列传", "para": "13", "seq": 15, "text": "广曰：“诸校尉无罪，乃我自失道。", "len": 16}
{"sid": "109_李将军列传.13.s16", "chapter": "109_李将军列传", "para": "13", "seq": 16, "text": "吾今自上簿。”", "len": 7}
{"sid": "109_李将军列传.14.s1", "chapter": "109_李将军列传", "para": "14", "seq": 1, "text": "至莫府，广谓其麾下曰；“广结发与匈奴大小七十馀战，今幸从大将军出接单于兵，而大将军又徙广部行回远，而又迷失道，岂非天哉！", "len": 60}
{"sid": "109_李将军列传.14.s2", "chapter": "109_李将军列传", "para": "14", "seq": 2, "text": "且广年六十馀矣，终不能复对刀笔之吏。", "len": 18}
{"sid": "109_李将军列传.14.s3", "chapter": "109_李将军列传", "para": "14", "seq": 3, "text": "” 遂引刀自刭。", "len": 8}
{"sid": "109_李将军列传.14.s4", "chapter": "109_李将军列传", "para": "14", "seq": 4, "text": "广军士大夫一军皆哭。", "len": 10}
{"sid": "109_李将军列传.14.s5", "chapter": "109_李将军列传", "para": "14", "seq": 5, "text": "百姓闻之，知与不知，无老壮皆为垂涕。", "len": 18}
{"sid": "109_李将军列传.14.s6", "chapter": "109_李将军列传", "para": "14", "seq": 6, "text": "而右将军独下吏，当死，赎为庶人。", "len": 16}
{"sid": "109_李将军列传.15.s1", "chapter": "109_李将军列传", "para": "15", "seq": 1, "text": "广子三人，曰当户、椒、敢，为郎。", "len": 16}
{"sid": "109_李将军列传.15.s2", "chapter": "109_李将军列传", "para": "15", "seq": 2, "text": "天子与韩嫣戏，嫣少不逊，当户击嫣，嫣走。", "len": 20}
{"sid": "109_李将军列传.15.s3", "chapter": "109_李将军列传", "para": "15", "seq": 3, "text": "於是天子以为勇。", "len": 8}
{"sid": "109_李将军列传.15.s4", "chapter": "109_李将军列传", "para": "15", "seq": 4, "text": "当户早死，拜椒为代郡太守，皆先广死。", "len": 18}
{"sid": "109_李将军列传.15.s5", "chapter": "109_李将军列传", "para": "15", "seq": 5, "text": "当户有遗腹子名陵。", "len": 9}
{"sid": "109_李将军列传.15.s6", "chapter": "109_李将军列传", "para": "15", "seq": 6, "text": "广死军时，敢从骠骑将军。", "len": 12}
{"sid": "109_李将军列传.15.s7", "chapter": "109_李将军列传", "para": "15", "seq": 7, "text": "广死明年，李蔡以丞相坐侵孝景园壖地，当下吏治，蔡亦自杀，不对狱，国除。", "len": 35}
{"sid": "109_李将军列传.15.s8", "chapter": "109_李将军列传", "para": "15", "seq": 8, "text": "李敢以校尉从骠骑将军击胡左贤王，力战，夺左贤王鼓旗，斩首多，赐爵关内侯，食邑二百户，代广为郎中令。", "len": 49}
{"sid": "109_李将军列传.15.s9", "chapter": "109_李将军列传", "para": "15", "seq": 9, "text": "顷之，怨大将军青之恨其父，乃击伤大将军，大将军匿讳之。", "len": 27}
{"sid": "109_李将军列传.15.s10", "chapter": "109_李将军列传", "para": "15", "seq": 10, "text": "居无何，敢从上雍，至甘泉宫猎。", "len": 15}
{"sid": "109_李将军列传.15.s11", "chapter": "109_李将军列传", "para": "15", "seq": 11, "text": "骠骑将军去病与青有亲，射杀敢。", "len": 15}
{"sid": "109_李将军列传.15.s12", "chapter": "109_李将军列传", "para": "15", "seq": 12, "text": "去病时方贵幸，上讳云鹿触杀之。", "len": 15}
{"sid": "109_李将军列传.15.s13", "chapter": "109_李将军列传", "para": "15", "seq": 13, "text": "居岁馀，去病死。", "len": 8}
{"sid": "109_李将军列传.15.s14", "chapter": "109_李将军列传", "para": "15", "seq": 14, "text": "而敢有女为太子中人，爱幸，敢男禹有宠於太子，然好利，李氏陵迟衰微矣。", "len": 34}
{"sid": "109_李将军列传.16.s1", "chapter": "109_李将军列传", "para": "16", "seq": 1, "text": "李陵既壮，选为建章监，监诸骑。", "len": 15}
{"sid": "109_李将军列传.16.s2", "chapter": "109_李将军列传", "para": "16", "seq": 2, "text": "善射，爱士卒。", "len": 7}
{"sid": "109_李将军列传.16.s3", "chapter": "109_李将军列传", "para": "16", "seq": 3, "text": "天子以为李氏世将，而使将八百骑。", "len": 16}
{"sid": "109_李将军列传.16.s4", "chapter": "109_李将军列传", "para": "16", "seq": 4, "text": "尝深入匈奴二千馀里，过居延视地形，无所见虏而还。", "len": 24}
{"sid": "109_李将军列传.16.s5", "chapter": "109_李将军列传", "para": "16", "seq": 5, "text": "拜为骑都尉，将丹阳楚人五千人，教射酒泉、张掖以屯卫胡。", "len": 27}
{"sid": "109_李将军列传.17.s1", "chapter": "109_李将军列传", "para": "17", "seq": 1, "text": "数岁，天汉二年秋，贰师将军李广利将三万骑击匈奴右贤王於祁连天山，而使陵将其射士步兵五千人出居延北可千馀里，欲以分匈奴兵，毋令专走贰师也。", "len": 68}
{"sid": "109_李将军列传.17.s2", "chapter": "109_李将军列传", "para": "17", "seq": 2, "text": "陵既至期还，而单于以兵八万围击陵军。", "len": 18}
{"sid": "109_李将军列传.17.s3", "chapter": "109_李将军列传", "para": "17", "seq": 3, "text": "陵军五千人，兵矢既尽，士死者过半，而所杀伤匈奴亦万馀人。", "len": 28}
{"sid": "109_李将军列传.17.s4", "chapter": "109_李将军列传", "para": "17", "seq": 4, "text": "且引且战，连斗八日，还未到居延百馀里，匈奴遮狭绝道，陵食乏而救兵不到，虏急击招降陵。", "len": 42}
{"sid": "109_李将军列传.17.s5", "chapter": "109_李将军列传", "para": "17", "seq": 5, "text": "陵曰：“无面目报陛下。", "len": 11}
{"sid": "109_李将军列传.17.s6", "chapter": "109_李将军列传", "para": "17", "seq": 6, "text": "” 遂降匈奴。", "len": 7}
{"sid": "109_李将军列传.17.s7", "chapter": "109_李将军列传", "para": "17", "seq": 7, "text": "其兵尽没，馀亡散得归汉者四百馀人。", "len": 17}
{"sid": "109_李将军列传.18.s1", "chapter": "109_李将军列传", "para": "18", "seq": 1, "text": "单于既得陵，素闻其家声，及战又壮，乃以其女妻陵而贵之。", "len": 27}
{"sid": "109_李将军列传.18.s2", "chapter": "109_李将军列传", "para": "18", "seq": 2, "text": "汉闻，族陵母妻子。", "len": 9}
{"sid": "109_李将军列传.18.s3", "chapter": "109_李将军列传", "para": "18", "seq": 3, "text": "自是之後，李氏名败，而陇西之士居门下者皆用为耻焉。", "len": 25}
{"sid": "109_李将军列传.18.s4", "chapter": "109_李将军列传", "para": "18", "seq": 4, "text": "::: 太史公曰", "len": 8}
{"sid": "109_李将军列传.19.s1", "chapter": "109_李将军列传", "para": "19", "seq": 1, "text": "太史公曰：传曰“其身正，不令而行；其身不正，虽令不从”。", "len": 28}
{"sid": "109_李将军列传.19.s2", "chapter": "109_李将军列传", "para": "19", "seq": 2, "text": "其李将军之谓也？", "len": 8}
{"sid": "109_李将军列传.19.s3", "chapter": "109_李将军列传", "para": "19", "seq": 3, "text": "余睹李将军悛悛如鄙人，口不能道辞。", "len": 17}
{"sid": "109_李将军列传.19.s4", "chapter": "109_李将军列传", "para": "19", "seq": 4, "text": "及死之日，天下知与不知，皆为尽哀。", "len": 17}
{"sid": "109_李将军列传.19.s5", "chapter": "109_李将军列传", "para": "19", "seq": 5, "text": "彼其忠实心诚信於士大夫也？", "len": 13}
{"sid": "109_李将军列传.19.s6", "chapter": "109_李将军列传", "para": "19", "seq": 6, "text": "谚曰“桃李不言，下自成蹊”。", "len": 14}
{"sid": "109_李将军列传.19.s7", "chapter": "109_李将军列传", "para": "19", "seq": 7, "text": "此言虽小，可以谕大也。", "len": 11}
{"sid": "109_李将军列传.19.s8", "chapter": "109_李将军列传", "para": "19", "seq": 8, "text": "::: ::: 赞", "len": 9}
{"sid": "109_李将军列传.20.s1", "chapter": "109_李将军列传", "para": "20", "seq": 1, "text": "猿臂善射，实负其能。", "len": 10}
{"sid": "109_李将军列传.20.s2", "chapter": "109_李将军列传", "para": "20", "seq": 2, "text": "解鞍卻敌，圆阵摧锋。", "len": 10}
{"sid": "109_李将军列传.20.s3", "chapter": "109_李将军列传", "para": "20", "seq": 3, "text": "边郡屡守，大军再从。", "len": 10}
{"sid": "109_李将军列传.20.s4", "chapter": "109_李将军列传", "para": "20", "seq": 4, "text": "失道见斥，数奇不封。", "len": 10}
{"sid": "109_李将军列传.20.s5", "chapter": "109_李将军列传", "para": "20", "seq": 5, "text": "惜哉名将，天下无双！", "len": 10}
{"sid": "109_李将军列传.20.s6", "chapter": "109_李将军列传", "para": "20", "seq": 6, "text": ":::", "len": 3}
