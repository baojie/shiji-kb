{"sid": "064_司马穰苴列传.1.s1", "chapter": "064_司马穰苴列传", "para": "1", "seq": 1, "text": "司马穰苴者，田完之苗裔也。", "len": 13}
{"sid": "064_司马穰苴列传.1.s2", "chapter": "064_司马穰苴列传", "para": "1", "seq": 2, "text": "齐景公时，晋伐阿、甄，而燕侵河上，齐师败绩。", "len": 22}
{"sid": "064_司马穰苴列传.1.s3", "chapter": "064_司马穰苴列传", "para": "1", "seq": 3, "text": "景公患之。", "len": 5}
{"sid": "064_司马穰苴列传.1.s4", "chapter": "064_司马穰苴列传", "para": "1", "seq": 4, "text": "晏婴乃荐田穰苴曰：”穰苴虽田氏庶孽，然其人文能附众，武能威敌，原君试之。", "len": 36}
{"sid": "064_司马穰苴列传.1.s5", "chapter": "064_司马穰苴列传", "para": "1", "seq": 5, "text": "”景公召穰苴，与语兵事，大说之，以为将军，将兵扞燕晋之师。", "len": 29}
{"sid": "064_司马穰苴列传.1.s6", "chapter": "064_司马穰苴列传", "para": "1", "seq": 6, "text": "穰苴曰：”臣素卑贱，君擢之闾伍之中，加之大夫之上，士卒未附，百姓不信，人微权轻，原得君之宠臣，国之所尊，以监军，乃可。", "len": 59}
{"sid": "064_司马穰苴列传.1.s7", "chapter": "064_司马穰苴列传", "para": "1", "seq": 7, "text": "”於是景公许之，使庄贾往。", "len": 13}
{"sid": "064_司马穰苴列传.1.1.s1", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 1, "text": "穰苴既辞，与庄贾约曰：”旦日日中会於军门。", "len": 21}
{"sid": "064_司马穰苴列传.1.1.s2", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 2, "text": "”穰苴先驰至军，立表下漏待贾。", "len": 15}
{"sid": "064_司马穰苴列传.1.1.s3", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 3, "text": "贾素骄贵，以为将己之军而己为监，不甚急；亲戚左右送之，留饮。", "len": 30}
{"sid": "064_司马穰苴列传.1.1.s4", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 4, "text": "日中而贾不至。", "len": 7}
{"sid": "064_司马穰苴列传.1.1.s5", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 5, "text": "穰苴则仆表决漏，入，行军勒兵，申明约束。", "len": 20}
{"sid": "064_司马穰苴列传.1.1.s6", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 6, "text": "约束既定，夕时，庄贾乃至。", "len": 13}
{"sid": "064_司马穰苴列传.1.1.s7", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 7, "text": "穰苴曰：”何後期为？", "len": 10}
{"sid": "064_司马穰苴列传.1.1.s8", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 8, "text": "” 贾谢曰：”不佞大夫亲戚送之，故留。", "len": 19}
{"sid": "064_司马穰苴列传.1.1.s9", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 9, "text": "” 穰苴曰：”将受命之日则忘其家，临军约束则忘其亲，援枹鼓之急则忘其身。", "len": 36}
{"sid": "064_司马穰苴列传.1.1.s10", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 10, "text": "今敌国深侵，邦内骚动，士卒暴露於境，君寝不安席，食不甘味，百姓之命皆悬於君，何谓相送乎！", "len": 44}
{"sid": "064_司马穰苴列传.1.1.s11", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 11, "text": "” 召军正问曰：”军法期而後至者云何？", "len": 19}
{"sid": "064_司马穰苴列传.1.1.s12", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 12, "text": "” 对曰：”当斩。", "len": 9}
{"sid": "064_司马穰苴列传.1.1.s13", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 13, "text": "” 庄贾惧，使人驰报景公，请救。", "len": 16}
{"sid": "064_司马穰苴列传.1.1.s14", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 14, "text": "既往，未及反，於是遂斩庄贾以徇三军。", "len": 18}
{"sid": "064_司马穰苴列传.1.1.s15", "chapter": "064_司马穰苴列传", "para": "1.1", "seq": 15, "text": "三军之士皆振栗。", "len": 8}
{"sid": "064_司马穰苴列传.1.2.s1", "chapter": "064_司马穰苴列传", "para": "1.2", "seq": 1, "text": "久之，景公遣使者持节赦贾，驰入军中。", "len": 18}
{"sid": "064_司马穰苴列传.1.2.s2", "chapter": "064_司马穰苴列传", "para": "1.2", "seq": 2, "text": "穰苴曰：”将在军，君令有所不受。", "len": 16}
{"sid": "064_司马穰苴列传.1.2.s3", "chapter": "064_司马穰苴列传", "para": "1.2", "seq": 3, "text": "” 问军正曰：”驰三军法何？", "len": 14}
{"sid": "064_司马穰苴列传.1.2.s4", "chapter": "064_司马穰苴列传", "para": "1.2", "seq": 4, "text": "” 正曰：”当斩。", "len": 9}
{"sid": "064_司马穰苴列传.1.2.s5", "chapter": "064_司马穰苴列传", "para": "1.2", "seq": 5, "text": "” 使者大惧。", "len": 7}
{"sid": "064_司马穰苴列传.1.2.s6", "chapter": "064_司马穰苴列传", "para": "1.2", "seq": 6, "text": "穰苴曰：”君之使不可杀之。", "len": 13}
{"sid": "064_司马穰苴列传.1.2.s7", "chapter": "064_司马穰苴列传", "para": "1.2", "seq": 7, "text": "”乃斩其仆，车之左驸，马之左骖，以徇三军。", "len": 21}
{"sid": "064_司马穰苴列传.1.2.s8", "chapter": "064_司马穰苴列传", "para": "1.2", "seq": 8, "text": "遣使者还报，然後行。", "len": 10}
{"sid": "064_司马穰苴列传.1.3.s1", "chapter": "064_司马穰苴列传", "para": "1.3", "seq": 1, "text": "士卒次舍井灶饮食问疾医药，身自拊循之。", "len": 19}
{"sid": "064_司马穰苴列传.1.3.s2", "chapter": "064_司马穰苴列传", "para": "1.3", "seq": 2, "text": "悉取将军之资粮享士卒，身与士卒平分粮食。", "len": 20}
{"sid": "064_司马穰苴列传.1.3.s3", "chapter": "064_司马穰苴列传", "para": "1.3", "seq": 3, "text": "最比其羸弱者，三日而後勒兵。", "len": 14}
{"sid": "064_司马穰苴列传.1.3.s4", "chapter": "064_司马穰苴列传", "para": "1.3", "seq": 4, "text": "病者皆求行，争奋出为之赴战。", "len": 14}
{"sid": "064_司马穰苴列传.1.3.s5", "chapter": "064_司马穰苴列传", "para": "1.3", "seq": 5, "text": "晋师闻之，为罢去。", "len": 9}
{"sid": "064_司马穰苴列传.1.3.s6", "chapter": "064_司马穰苴列传", "para": "1.3", "seq": 6, "text": "燕师闻之，度水而解。", "len": 10}
{"sid": "064_司马穰苴列传.1.3.s7", "chapter": "064_司马穰苴列传", "para": "1.3", "seq": 7, "text": "於是追击之，遂取所亡封内故境而引兵归。", "len": 19}
{"sid": "064_司马穰苴列传.1.4.s1", "chapter": "064_司马穰苴列传", "para": "1.4", "seq": 1, "text": "未至国，释兵旅，解约束，誓盟而後入邑。", "len": 19}
{"sid": "064_司马穰苴列传.1.4.s2", "chapter": "064_司马穰苴列传", "para": "1.4", "seq": 2, "text": "景公与诸大夫郊迎，劳师成礼，然後反归寝。", "len": 20}
{"sid": "064_司马穰苴列传.1.4.s3", "chapter": "064_司马穰苴列传", "para": "1.4", "seq": 3, "text": "既见穰苴，尊为大司马。", "len": 11}
{"sid": "064_司马穰苴列传.1.4.s4", "chapter": "064_司马穰苴列传", "para": "1.4", "seq": 4, "text": "田氏日以益尊於齐。", "len": 9}
{"sid": "064_司马穰苴列传.2.s1", "chapter": "064_司马穰苴列传", "para": "2", "seq": 1, "text": "已而大夫鲍氏、高、国之属害之，谮於景公。", "len": 20}
{"sid": "064_司马穰苴列传.2.s2", "chapter": "064_司马穰苴列传", "para": "2", "seq": 2, "text": "景公退穰苴，苴发疾而死。", "len": 12}
{"sid": "064_司马穰苴列传.2.s3", "chapter": "064_司马穰苴列传", "para": "2", "seq": 3, "text": "田乞、田豹之徒由此怨高、国等。", "len": 15}
{"sid": "064_司马穰苴列传.2.s4", "chapter": "064_司马穰苴列传", "para": "2", "seq": 4, "text": "其後及田常杀简公，尽灭高子、国子之族。", "len": 19}
{"sid": "064_司马穰苴列传.2.s5", "chapter": "064_司马穰苴列传", "para": "2", "seq": 5, "text": "至常曾孙和，因自立为齐威王，用兵行威，大放穰苴之法，而诸侯朝齐。", "len": 32}
{"sid": "064_司马穰苴列传.3.s1", "chapter": "064_司马穰苴列传", "para": "3", "seq": 1, "text": "齐威王使大夫追论古者司马兵法而附穰苴於其中，因号曰司马穰苴兵法。", "len": 32}
{"sid": "064_司马穰苴列传.3.s2", "chapter": "064_司马穰苴列传", "para": "3", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "064_司马穰苴列传.4.s1", "chapter": "064_司马穰苴列传", "para": "4", "seq": 1, "text": "太史公曰：余读司马兵法，闳廓深远，虽三代征伐，未能竟其义，如其文也，亦少襃矣。", "len": 39}
{"sid": "064_司马穰苴列传.4.s2", "chapter": "064_司马穰苴列传", "para": "4", "seq": 2, "text": "若夫穰苴，区区为小国行师，何暇及司马兵法之揖让乎？", "len": 25}
{"sid": "064_司马穰苴列传.4.s3", "chapter": "064_司马穰苴列传", "para": "4", "seq": 3, "text": "世既多司马兵法，以故不论，著穰苴之列传焉。", "len": 21}
{"sid": "064_司马穰苴列传.4.s4", "chapter": "064_司马穰苴列传", "para": "4", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "064_司马穰苴列传.5.s1", "chapter": "064_司马穰苴列传", "para": "5", "seq": 1, "text": "燕侵河上，齐师败绩。", "len": 10}
{"sid": "064_司马穰苴列传.5.s2", "chapter": "064_司马穰苴列传", "para": "5", "seq": 2, "text": "婴荐穰苴，武能威敌。", "len": 10}
{"sid": "064_司马穰苴列传.5.s3", "chapter": "064_司马穰苴列传", "para": "5", "seq": 3, "text": "斩贾以徇，三军惊惕。", "len": 10}
{"sid": "064_司马穰苴列传.5.s4", "chapter": "064_司马穰苴列传", "para": "5", "seq": 4, "text": "我卒既彊，彼寇退壁。", "len": 10}
{"sid": "064_司马穰苴列传.5.s5", "chapter": "064_司马穰苴列传", "para": "5", "seq": 5, "text": "法行司马，实赖宗戚。", "len": 10}
{"sid": "064_司马穰苴列传.5.s6", "chapter": "064_司马穰苴列传", "para": "5", "seq": 6, "text": ":::", "len": 3}
