{"sid": "123_大宛列传.1.s1", "chapter": "123_大宛列传", "para": "1", "seq": 1, "text": "大宛之迹，见自张骞。", "len": 10}
{"sid": "123_大宛列传.1.s2", "chapter": "123_大宛列传", "para": "1", "seq": 2, "text": "张骞，汉中人。", "len": 7}
{"sid": "123_大宛列传.1.s3", "chapter": "123_大宛列传", "para": "1", "seq": 3, "text": "建元中为郎。", "len": 6}
{"sid": "123_大宛列传.1.s4", "chapter": "123_大宛列传", "para": "1", "seq": 4, "text": "是时天子问匈奴降者，皆言匈奴破月氏王，以其头为饮器，月氏遁逃而常怨仇匈奴，无与共击之。", "len": 43}
{"sid": "123_大宛列传.1.s5", "chapter": "123_大宛列传", "para": "1", "seq": 5, "text": "汉方欲事灭胡，闻此言，因欲通使。", "len": 16}
{"sid": "123_大宛列传.1.s6", "chapter": "123_大宛列传", "para": "1", "seq": 6, "text": "道必更匈奴中，乃募能使者。", "len": 13}
{"sid": "123_大宛列传.1.s7", "chapter": "123_大宛列传", "para": "1", "seq": 7, "text": "骞以郎应募，使月氏，与堂邑氏胡奴甘父俱出陇西。", "len": 23}
{"sid": "123_大宛列传.1.s8", "chapter": "123_大宛列传", "para": "1", "seq": 8, "text": "经匈奴，匈奴得之，传诣单于。", "len": 14}
{"sid": "123_大宛列传.1.s9", "chapter": "123_大宛列传", "para": "1", "seq": 9, "text": "单于留之，曰：“月氏在吾北，汉何以得往使？", "len": 21}
{"sid": "123_大宛列传.1.s10", "chapter": "123_大宛列传", "para": "1", "seq": 10, "text": "吾欲使越，汉肯听我乎？", "len": 11}
{"sid": "123_大宛列传.1.s11", "chapter": "123_大宛列传", "para": "1", "seq": 11, "text": "” 留骞十馀岁，与妻，有子，然骞持汉节不失。", "len": 22}
{"sid": "123_大宛列传.2.s1", "chapter": "123_大宛列传", "para": "2", "seq": 1, "text": "居匈奴中，益宽，骞因与其属亡乡月氏，西走数十日至大宛。", "len": 27}
{"sid": "123_大宛列传.2.s2", "chapter": "123_大宛列传", "para": "2", "seq": 2, "text": "大宛闻汉之饶财，欲通不得，见骞，喜，问曰：“若欲何之？", "len": 27}
{"sid": "123_大宛列传.2.s3", "chapter": "123_大宛列传", "para": "2", "seq": 3, "text": "” 骞曰：“为汉使月氏，而为匈奴所闭道。", "len": 20}
{"sid": "123_大宛列传.2.s4", "chapter": "123_大宛列传", "para": "2", "seq": 4, "text": "今亡，唯王使人导送我。", "len": 11}
{"sid": "123_大宛列传.2.s5", "chapter": "123_大宛列传", "para": "2", "seq": 5, "text": "诚得至，反汉，汉之赂遗王财物不可胜言。", "len": 19}
{"sid": "123_大宛列传.2.s6", "chapter": "123_大宛列传", "para": "2", "seq": 6, "text": "” 大宛以为然，遣骞，为发导绎，抵康居，康居传致大月氏。", "len": 28}
{"sid": "123_大宛列传.2.s7", "chapter": "123_大宛列传", "para": "2", "seq": 7, "text": "大月氏王已为胡所杀，立其太子为王。", "len": 17}
{"sid": "123_大宛列传.2.s8", "chapter": "123_大宛列传", "para": "2", "seq": 8, "text": "既臣大夏而居，地肥饶，少寇，志安乐，又自以远汉，殊无报胡之心。", "len": 31}
{"sid": "123_大宛列传.2.s9", "chapter": "123_大宛列传", "para": "2", "seq": 9, "text": "骞从月氏至大夏，竟不能得月氏要领。", "len": 17}
{"sid": "123_大宛列传.3.s1", "chapter": "123_大宛列传", "para": "3", "seq": 1, "text": "留岁馀，还，并南山，欲从羌中归，复为匈奴所得。", "len": 23}
{"sid": "123_大宛列传.3.s2", "chapter": "123_大宛列传", "para": "3", "seq": 2, "text": "留岁馀，单于死，左谷蠡王攻其太子自立，国内乱，骞与胡妻及堂邑父俱亡归汉。", "len": 36}
{"sid": "123_大宛列传.3.s3", "chapter": "123_大宛列传", "para": "3", "seq": 3, "text": "汉拜骞为太中大夫，堂邑父为奉使君。", "len": 17}
{"sid": "123_大宛列传.4.s1", "chapter": "123_大宛列传", "para": "4", "seq": 1, "text": "骞为人彊力，宽大信人，蛮夷爱之。", "len": 16}
{"sid": "123_大宛列传.4.s2", "chapter": "123_大宛列传", "para": "4", "seq": 2, "text": "堂邑父故胡人，善射，穷急射禽兽给食。", "len": 18}
{"sid": "123_大宛列传.4.s3", "chapter": "123_大宛列传", "para": "4", "seq": 3, "text": "初，骞行时百馀人，去十三岁，唯二人得还。", "len": 20}
{"sid": "123_大宛列传.5.s1", "chapter": "123_大宛列传", "para": "5", "seq": 1, "text": "骞身所至者大宛、大月氏、大夏、康居，而传闻其旁大国五六，具为天子言之。", "len": 35}
{"sid": "123_大宛列传.5.s2", "chapter": "123_大宛列传", "para": "5", "seq": 2, "text": "曰：大宛在匈奴西南，在汉正西，去汉可万里。", "len": 21}
{"sid": "123_大宛列传.5.s3", "chapter": "123_大宛列传", "para": "5", "seq": 3, "text": "其俗土著，耕田，田稻麦。", "len": 12}
{"sid": "123_大宛列传.5.s4", "chapter": "123_大宛列传", "para": "5", "seq": 4, "text": "有蒲陶酒。", "len": 5}
{"sid": "123_大宛列传.5.s5", "chapter": "123_大宛列传", "para": "5", "seq": 5, "text": "多善马，马汗血，其先天马子也。", "len": 15}
{"sid": "123_大宛列传.5.s6", "chapter": "123_大宛列传", "para": "5", "seq": 6, "text": "有城郭屋室。", "len": 6}
{"sid": "123_大宛列传.5.s7", "chapter": "123_大宛列传", "para": "5", "seq": 7, "text": "其属邑大小七十馀城，众可数十万。", "len": 16}
{"sid": "123_大宛列传.5.s8", "chapter": "123_大宛列传", "para": "5", "seq": 8, "text": "其兵弓矛骑射。", "len": 7}
{"sid": "123_大宛列传.5.s9", "chapter": "123_大宛列传", "para": "5", "seq": 9, "text": "其北则康居，西则大月氏，西南则大夏，东北则乌孙，东则扜鰛、于窴。", "len": 32}
{"sid": "123_大宛列传.5.s10", "chapter": "123_大宛列传", "para": "5", "seq": 10, "text": "于窴之西，则水皆西流，注西海；其东水东流，注盐泽。", "len": 25}
{"sid": "123_大宛列传.5.s11", "chapter": "123_大宛列传", "para": "5", "seq": 11, "text": "盐泽潜行地下，其南则河源出焉。", "len": 15}
{"sid": "123_大宛列传.5.s12", "chapter": "123_大宛列传", "para": "5", "seq": 12, "text": "多玉石，河注中国。", "len": 9}
{"sid": "123_大宛列传.5.s13", "chapter": "123_大宛列传", "para": "5", "seq": 13, "text": "而楼兰、姑师邑有城郭，临盐泽。", "len": 15}
{"sid": "123_大宛列传.5.s14", "chapter": "123_大宛列传", "para": "5", "seq": 14, "text": "盐泽去长安可五千里。", "len": 10}
{"sid": "123_大宛列传.5.s15", "chapter": "123_大宛列传", "para": "5", "seq": 15, "text": "匈奴右方居盐泽以东，至陇西长城，南接羌，鬲汉道焉。", "len": 25}
{"sid": "123_大宛列传.6.s1", "chapter": "123_大宛列传", "para": "6", "seq": 1, "text": "乌孙在大宛东北可二千里，行国，随畜，与匈奴同俗。", "len": 24}
{"sid": "123_大宛列传.6.s2", "chapter": "123_大宛列传", "para": "6", "seq": 2, "text": "控弦者数万，敢战。", "len": 9}
{"sid": "123_大宛列传.6.s3", "chapter": "123_大宛列传", "para": "6", "seq": 3, "text": "故服匈奴，及盛，取其羁属，不肯往朝会焉。", "len": 20}
{"sid": "123_大宛列传.7.s1", "chapter": "123_大宛列传", "para": "7", "seq": 1, "text": "康居在大宛西北可二千里，行国，与月氏大同俗。", "len": 22}
{"sid": "123_大宛列传.7.s2", "chapter": "123_大宛列传", "para": "7", "seq": 2, "text": "控弦者八九万人。", "len": 8}
{"sid": "123_大宛列传.7.s3", "chapter": "123_大宛列传", "para": "7", "seq": 3, "text": "与大宛邻国。", "len": 6}
{"sid": "123_大宛列传.7.s4", "chapter": "123_大宛列传", "para": "7", "seq": 4, "text": "国小，南羁事月氏，东羁事匈奴。", "len": 15}
{"sid": "123_大宛列传.8.s1", "chapter": "123_大宛列传", "para": "8", "seq": 1, "text": "奄蔡在康居西北可二千里，行国，与康居大同俗。", "len": 22}
{"sid": "123_大宛列传.8.s2", "chapter": "123_大宛列传", "para": "8", "seq": 2, "text": "控弦者十馀万。", "len": 7}
{"sid": "123_大宛列传.8.s3", "chapter": "123_大宛列传", "para": "8", "seq": 3, "text": "临大泽，无崖，盖乃北海云。", "len": 13}
{"sid": "123_大宛列传.9.s1", "chapter": "123_大宛列传", "para": "9", "seq": 1, "text": "大月氏在大宛西可二三千里，居妫水北。", "len": 18}
{"sid": "123_大宛列传.9.s2", "chapter": "123_大宛列传", "para": "9", "seq": 2, "text": "其南则大夏，西则安息，北则康居。", "len": 16}
{"sid": "123_大宛列传.9.s3", "chapter": "123_大宛列传", "para": "9", "seq": 3, "text": "行国也，随畜移徙，与匈奴同俗。", "len": 15}
{"sid": "123_大宛列传.9.s4", "chapter": "123_大宛列传", "para": "9", "seq": 4, "text": "控弦者可一二十万。", "len": 9}
{"sid": "123_大宛列传.9.s5", "chapter": "123_大宛列传", "para": "9", "seq": 5, "text": "故时彊，轻匈奴，及冒顿立，攻破月氏，至匈奴老上单于，杀月氏王，以其头为饮器。", "len": 38}
{"sid": "123_大宛列传.9.s6", "chapter": "123_大宛列传", "para": "9", "seq": 6, "text": "始月氏居敦煌、祁连间，及为匈奴所败，乃远去，过宛，西击大夏而臣之，遂都妫水北，为王庭。", "len": 43}
{"sid": "123_大宛列传.9.s7", "chapter": "123_大宛列传", "para": "9", "seq": 7, "text": "其馀小众不能去者，保南山羌，号小月氏。", "len": 19}
{"sid": "123_大宛列传.10.s1", "chapter": "123_大宛列传", "para": "10", "seq": 1, "text": "安息在大月氏西可数千里。", "len": 12}
{"sid": "123_大宛列传.10.s2", "chapter": "123_大宛列传", "para": "10", "seq": 2, "text": "其俗土著，耕田，田稻麦，蒲陶酒。", "len": 16}
{"sid": "123_大宛列传.10.s3", "chapter": "123_大宛列传", "para": "10", "seq": 3, "text": "城邑如大宛。", "len": 6}
{"sid": "123_大宛列传.10.s4", "chapter": "123_大宛列传", "para": "10", "seq": 4, "text": "其属小大数百城，地方数千里，最为大国。", "len": 19}
{"sid": "123_大宛列传.10.s5", "chapter": "123_大宛列传", "para": "10", "seq": 5, "text": "临妫水，有市，民商贾用车及船，行旁国或数千里。", "len": 23}
{"sid": "123_大宛列传.10.s6", "chapter": "123_大宛列传", "para": "10", "seq": 6, "text": "以银为钱，钱如其王面，王死辄更钱，效王面焉。", "len": 22}
{"sid": "123_大宛列传.10.s7", "chapter": "123_大宛列传", "para": "10", "seq": 7, "text": "画革旁行以为书记。", "len": 9}
{"sid": "123_大宛列传.10.s8", "chapter": "123_大宛列传", "para": "10", "seq": 8, "text": "其西则条枝，北有奄蔡、黎轩。", "len": 14}
{"sid": "123_大宛列传.11.s1", "chapter": "123_大宛列传", "para": "11", "seq": 1, "text": "条枝在安息西数千里，临西海。", "len": 14}
{"sid": "123_大宛列传.11.s2", "chapter": "123_大宛列传", "para": "11", "seq": 2, "text": "暑湿。", "len": 3}
{"sid": "123_大宛列传.11.s3", "chapter": "123_大宛列传", "para": "11", "seq": 3, "text": "耕田，田稻。", "len": 6}
{"sid": "123_大宛列传.11.s4", "chapter": "123_大宛列传", "para": "11", "seq": 4, "text": "有大鸟，卵如甕。", "len": 8}
{"sid": "123_大宛列传.11.s5", "chapter": "123_大宛列传", "para": "11", "seq": 5, "text": "人众甚多，往往有小君长，而安息役属之，以为外国。", "len": 24}
{"sid": "123_大宛列传.11.s6", "chapter": "123_大宛列传", "para": "11", "seq": 6, "text": "国善眩。", "len": 4}
{"sid": "123_大宛列传.11.s7", "chapter": "123_大宛列传", "para": "11", "seq": 7, "text": "安息长老传闻条枝有弱水、西王母，而未尝见。", "len": 21}
{"sid": "123_大宛列传.12.s1", "chapter": "123_大宛列传", "para": "12", "seq": 1, "text": "大夏在大宛西南二千馀里妫水南。", "len": 15}
{"sid": "123_大宛列传.12.s2", "chapter": "123_大宛列传", "para": "12", "seq": 2, "text": "其俗土著，有城屋，与大宛同俗。", "len": 15}
{"sid": "123_大宛列传.12.s3", "chapter": "123_大宛列传", "para": "12", "seq": 3, "text": "无大长，往往城邑置小长。", "len": 12}
{"sid": "123_大宛列传.12.s4", "chapter": "123_大宛列传", "para": "12", "seq": 4, "text": "其兵弱，畏战。", "len": 7}
{"sid": "123_大宛列传.12.s5", "chapter": "123_大宛列传", "para": "12", "seq": 5, "text": "善贾市。", "len": 4}
{"sid": "123_大宛列传.12.s6", "chapter": "123_大宛列传", "para": "12", "seq": 6, "text": "及大月氏西徙，攻败之，皆臣畜大夏。", "len": 17}
{"sid": "123_大宛列传.12.s7", "chapter": "123_大宛列传", "para": "12", "seq": 7, "text": "大夏民多，可百馀万。", "len": 10}
{"sid": "123_大宛列传.12.s8", "chapter": "123_大宛列传", "para": "12", "seq": 8, "text": "其都曰蓝市城，有市贩贾诸物。", "len": 14}
{"sid": "123_大宛列传.12.s9", "chapter": "123_大宛列传", "para": "12", "seq": 9, "text": "其东南有身毒国。", "len": 8}
{"sid": "123_大宛列传.13.s1", "chapter": "123_大宛列传", "para": "13", "seq": 1, "text": "骞曰：“臣在大夏时，见邛竹杖、蜀布。", "len": 18}
{"sid": "123_大宛列传.13.s2", "chapter": "123_大宛列传", "para": "13", "seq": 2, "text": "问曰：‘安得此？’", "len": 9}
{"sid": "123_大宛列传.14.s1", "chapter": "123_大宛列传", "para": "14", "seq": 1, "text": "大夏国人曰：‘吾贾人往市之身毒。", "len": 16}
{"sid": "123_大宛列传.14.s2", "chapter": "123_大宛列传", "para": "14", "seq": 2, "text": "身毒在大夏东南可数千里。", "len": 12}
{"sid": "123_大宛列传.14.s3", "chapter": "123_大宛列传", "para": "14", "seq": 3, "text": "其俗土著，大与大夏同，而卑湿暑热云。", "len": 18}
{"sid": "123_大宛列传.14.s4", "chapter": "123_大宛列传", "para": "14", "seq": 4, "text": "其人民乘象以战。", "len": 8}
{"sid": "123_大宛列传.14.s5", "chapter": "123_大宛列传", "para": "14", "seq": 5, "text": "其国临大水焉。’", "len": 8}
{"sid": "123_大宛列传.15.s1", "chapter": "123_大宛列传", "para": "15", "seq": 1, "text": "以骞度之，大夏去汉万二千里，居汉西南。", "len": 19}
{"sid": "123_大宛列传.15.s2", "chapter": "123_大宛列传", "para": "15", "seq": 2, "text": "今身毒国又居大夏东南数千里，有蜀物，此其去蜀不远矣。", "len": 26}
{"sid": "123_大宛列传.15.s3", "chapter": "123_大宛列传", "para": "15", "seq": 3, "text": "今使大夏，从羌中，险，羌人恶之；少北，则为匈奴所得；从蜀宜径，又无寇。", "len": 35}
{"sid": "123_大宛列传.15.s4", "chapter": "123_大宛列传", "para": "15", "seq": 4, "text": "” 天子既闻大宛及大夏、安息之属皆大国，多奇物，土著，颇与中国同业，而兵弱，贵汉财物；其北有大月氏、康居之属，兵彊，可以赂遗设利朝也。", "len": 67}
{"sid": "123_大宛列传.15.s5", "chapter": "123_大宛列传", "para": "15", "seq": 5, "text": "且诚得而以义属之，则广地万里，重九译，致殊俗，威德遍於四海。", "len": 30}
{"sid": "123_大宛列传.15.s6", "chapter": "123_大宛列传", "para": "15", "seq": 6, "text": "天子欣然，以骞言为然，乃令骞因蜀犍为发间使，四道并出：出駹，出厓，出徙，出邛、僰，皆各行一二千里。", "len": 49}
{"sid": "123_大宛列传.15.s7", "chapter": "123_大宛列传", "para": "15", "seq": 7, "text": "其北方闭氐、筰，南方闭巂、昆明。", "len": 16}
{"sid": "123_大宛列传.15.s8", "chapter": "123_大宛列传", "para": "15", "seq": 8, "text": "昆明之属无君长，善寇盗，辄杀略汉使，终莫得通。", "len": 23}
{"sid": "123_大宛列传.15.s9", "chapter": "123_大宛列传", "para": "15", "seq": 9, "text": "然闻其西可千馀里有乘象国，名曰滇越，而蜀贾奸出物者或至焉，於是汉以求大夏道始通滇国。", "len": 42}
{"sid": "123_大宛列传.15.s10", "chapter": "123_大宛列传", "para": "15", "seq": 10, "text": "初，汉欲通西南夷，费多，道不通，罢之。", "len": 19}
{"sid": "123_大宛列传.15.s11", "chapter": "123_大宛列传", "para": "15", "seq": 11, "text": "及张骞言可以通大夏，乃复事西南夷。", "len": 17}
{"sid": "123_大宛列传.16.s1", "chapter": "123_大宛列传", "para": "16", "seq": 1, "text": "骞以校尉从大将军击匈奴，知水草处，军得以不乏，乃封骞为博望侯。", "len": 31}
{"sid": "123_大宛列传.16.s2", "chapter": "123_大宛列传", "para": "16", "seq": 2, "text": "是岁元朔六年也。", "len": 8}
{"sid": "123_大宛列传.16.s3", "chapter": "123_大宛列传", "para": "16", "seq": 3, "text": "其明年，骞为卫尉，与李将军俱出右北平击匈奴。", "len": 22}
{"sid": "123_大宛列传.16.s4", "chapter": "123_大宛列传", "para": "16", "seq": 4, "text": "匈奴围李将军，军失亡多；而骞後期当斩，赎为庶人。", "len": 24}
{"sid": "123_大宛列传.16.s5", "chapter": "123_大宛列传", "para": "16", "seq": 5, "text": "是岁汉遣骠骑破匈奴西数万人，至祁连山。", "len": 19}
{"sid": "123_大宛列传.16.s6", "chapter": "123_大宛列传", "para": "16", "seq": 6, "text": "其明年，浑邪王率其民降汉，而金城、河西西并南山至盐泽空无匈奴。", "len": 31}
{"sid": "123_大宛列传.16.s7", "chapter": "123_大宛列传", "para": "16", "seq": 7, "text": "匈奴时有候者到，而希矣。", "len": 12}
{"sid": "123_大宛列传.16.s8", "chapter": "123_大宛列传", "para": "16", "seq": 8, "text": "其後二年，汉击走单于於幕北。", "len": 14}
{"sid": "123_大宛列传.17.s1", "chapter": "123_大宛列传", "para": "17", "seq": 1, "text": "是後天子数问骞大夏之属。", "len": 12}
{"sid": "123_大宛列传.17.s2", "chapter": "123_大宛列传", "para": "17", "seq": 2, "text": "骞既失侯，因言曰：“臣居匈奴中，闻乌孙王号昆莫，昆莫之父，匈奴西边小国也。", "len": 37}
{"sid": "123_大宛列传.17.s3", "chapter": "123_大宛列传", "para": "17", "seq": 3, "text": "匈奴攻杀其父，而昆莫生弃於野。", "len": 15}
{"sid": "123_大宛列传.17.s4", "chapter": "123_大宛列传", "para": "17", "seq": 4, "text": "乌嗛肉蜚其上，狼往乳之。", "len": 12}
{"sid": "123_大宛列传.17.s5", "chapter": "123_大宛列传", "para": "17", "seq": 5, "text": "单于怪以为神，而收长之。", "len": 12}
{"sid": "123_大宛列传.17.s6", "chapter": "123_大宛列传", "para": "17", "seq": 6, "text": "及壮，使将兵，数有功，单于复以其父之民予昆莫，令长守於西。", "len": 29}
{"sid": "123_大宛列传.17.s7", "chapter": "123_大宛列传", "para": "17", "seq": 7, "text": "昆莫收养其民，攻旁小邑，控弦数万，习攻战。", "len": 21}
{"sid": "123_大宛列传.17.s8", "chapter": "123_大宛列传", "para": "17", "seq": 8, "text": "单于死，昆莫乃率其众远徙，中立，不肯朝会匈奴。", "len": 23}
{"sid": "123_大宛列传.17.s9", "chapter": "123_大宛列传", "para": "17", "seq": 9, "text": "匈奴遣奇兵击，不胜，以为神而远之，因羁属之，不大攻。", "len": 26}
{"sid": "123_大宛列传.17.s10", "chapter": "123_大宛列传", "para": "17", "seq": 10, "text": "今单于新困於汉，而故浑邪地空无人。", "len": 17}
{"sid": "123_大宛列传.17.s11", "chapter": "123_大宛列传", "para": "17", "seq": 11, "text": "蛮夷俗贪汉财物，今诚以此时而厚币赂乌孙，招以益东，居故浑邪之地，与汉结昆弟，其势宜听，听则是断匈奴右臂也。", "len": 53}
{"sid": "123_大宛列传.17.s12", "chapter": "123_大宛列传", "para": "17", "seq": 12, "text": "既连乌孙，自其西大夏之属皆可招来而为外臣。", "len": 21}
{"sid": "123_大宛列传.17.s13", "chapter": "123_大宛列传", "para": "17", "seq": 13, "text": "” 天子以为然，拜骞为中郎将，将三百人，马各二匹，牛羊以万数，赍金币帛直数千巨万，多持节副使，道可使，使遗之他旁国。", "len": 58}
{"sid": "123_大宛列传.18.s1", "chapter": "123_大宛列传", "para": "18", "seq": 1, "text": "骞既至乌孙，乌孙王昆莫见汉使如单于礼，骞大惭，知蛮夷贪，乃曰：“天子致赐，王不拜则还赐。", "len": 44}
{"sid": "123_大宛列传.18.s2", "chapter": "123_大宛列传", "para": "18", "seq": 2, "text": "” 昆莫起拜赐，其他如故。", "len": 13}
{"sid": "123_大宛列传.18.s3", "chapter": "123_大宛列传", "para": "18", "seq": 3, "text": "骞谕使指曰：“乌孙能东居浑邪地，则汉遣翁主为昆莫夫人。", "len": 27}
{"sid": "123_大宛列传.18.s4", "chapter": "123_大宛列传", "para": "18", "seq": 4, "text": "” 乌孙国分，王老，而远汉，未知其大小，素服属匈奴日久矣，且又近之，其大臣皆畏胡，不欲移徙，王不能专制。", "len": 52}
{"sid": "123_大宛列传.18.s5", "chapter": "123_大宛列传", "para": "18", "seq": 5, "text": "骞不得其要领。", "len": 7}
{"sid": "123_大宛列传.18.s6", "chapter": "123_大宛列传", "para": "18", "seq": 6, "text": "昆莫有十馀子，其中子曰大禄，彊，善将众，将众别居万馀骑。", "len": 28}
{"sid": "123_大宛列传.18.s7", "chapter": "123_大宛列传", "para": "18", "seq": 7, "text": "大禄兄为太子，太子有子曰岑娶，而太子蚤死。", "len": 21}
{"sid": "123_大宛列传.18.s8", "chapter": "123_大宛列传", "para": "18", "seq": 8, "text": "临死谓其父昆莫曰：“必以岑娶为太子，无令他人代之。", "len": 25}
{"sid": "123_大宛列传.18.s9", "chapter": "123_大宛列传", "para": "18", "seq": 9, "text": "” 昆莫哀而许之，卒以岑娶为太子。", "len": 17}
{"sid": "123_大宛列传.18.s10", "chapter": "123_大宛列传", "para": "18", "seq": 10, "text": "大禄怒其不得代太子也，乃收其诸昆弟，将其众畔，谋攻岑娶及昆莫。", "len": 31}
{"sid": "123_大宛列传.18.s11", "chapter": "123_大宛列传", "para": "18", "seq": 11, "text": "昆莫老，常恐大禄杀岑娶，予岑娶万馀骑别居，而昆莫有万馀骑自备，国众分为三，而其大总取羁属昆莫，昆莫亦以此不敢专约於骞。", "len": 59}
{"sid": "123_大宛列传.19.s1", "chapter": "123_大宛列传", "para": "19", "seq": 1, "text": "骞因分遣副使使大宛、康居、大月氏、大夏、安息、身毒、于窴、扜鰛及诸旁国。", "len": 36}
{"sid": "123_大宛列传.19.s2", "chapter": "123_大宛列传", "para": "19", "seq": 2, "text": "乌孙发导译送骞还，骞与乌孙遣使数十人，马数十匹报谢，因令窥汉，知其广大。", "len": 36}
{"sid": "123_大宛列传.20.s1", "chapter": "123_大宛列传", "para": "20", "seq": 1, "text": "骞还到，拜为大行，列於九卿。", "len": 14}
{"sid": "123_大宛列传.20.s2", "chapter": "123_大宛列传", "para": "20", "seq": 2, "text": "岁馀，卒。", "len": 5}
{"sid": "123_大宛列传.21.s1", "chapter": "123_大宛列传", "para": "21", "seq": 1, "text": "乌孙使既见汉人众富厚，归报其国，其国乃益重汉。", "len": 23}
{"sid": "123_大宛列传.21.s2", "chapter": "123_大宛列传", "para": "21", "seq": 2, "text": "其後岁馀，骞所遣使通大夏之属者皆颇与其人俱来，於是西北国始通於汉矣。", "len": 34}
{"sid": "123_大宛列传.21.s3", "chapter": "123_大宛列传", "para": "21", "seq": 3, "text": "然张骞凿空，其後使往者皆称博望侯，以为质於外国，外国由此信之。", "len": 31}
{"sid": "123_大宛列传.22.s1", "chapter": "123_大宛列传", "para": "22", "seq": 1, "text": "自博望侯骞死後，匈奴闻汉通乌孙，怒，欲击之。", "len": 22}
{"sid": "123_大宛列传.22.s2", "chapter": "123_大宛列传", "para": "22", "seq": 2, "text": "及汉使乌孙，若出其南，抵大宛、大月氏相属，乌孙乃恐，使使献马，原得尚汉女翁主为昆弟。", "len": 42}
{"sid": "123_大宛列传.22.s3", "chapter": "123_大宛列传", "para": "22", "seq": 3, "text": "天子问群臣议计，皆曰“必先纳聘，然後乃遣女”。", "len": 23}
{"sid": "123_大宛列传.22.s4", "chapter": "123_大宛列传", "para": "22", "seq": 4, "text": "初，天子发书易，云”神马当从西北来”。", "len": 19}
{"sid": "123_大宛列传.22.s5", "chapter": "123_大宛列传", "para": "22", "seq": 5, "text": "得乌孙马好，名曰“天马”。", "len": 13}
{"sid": "123_大宛列传.22.s6", "chapter": "123_大宛列传", "para": "22", "seq": 6, "text": "及得大宛汗血马，益壮，更名乌孙马曰“西极”，名大宛马曰“天马” 云。", "len": 34}
{"sid": "123_大宛列传.22.s7", "chapter": "123_大宛列传", "para": "22", "seq": 7, "text": "而汉始筑令居以西，初置酒泉郡以通西北国。", "len": 20}
{"sid": "123_大宛列传.22.s8", "chapter": "123_大宛列传", "para": "22", "seq": 8, "text": "因益发使抵安息、奄蔡、黎轩、条枝、身毒国。", "len": 21}
{"sid": "123_大宛列传.22.s9", "chapter": "123_大宛列传", "para": "22", "seq": 9, "text": "而天子好宛马，使者相望於道。", "len": 14}
{"sid": "123_大宛列传.22.s10", "chapter": "123_大宛列传", "para": "22", "seq": 10, "text": "诸使外国一辈大者数百，少者百馀人，人所赍操大放博望侯时。", "len": 28}
{"sid": "123_大宛列传.22.s11", "chapter": "123_大宛列传", "para": "22", "seq": 11, "text": "其後益习而衰少焉。", "len": 9}
{"sid": "123_大宛列传.22.s12", "chapter": "123_大宛列传", "para": "22", "seq": 12, "text": "汉率一岁中使多者十馀，少者五六辈，远者八九岁，近者数岁而反。", "len": 30}
{"sid": "123_大宛列传.23.s1", "chapter": "123_大宛列传", "para": "23", "seq": 1, "text": "是时汉既灭越，而蜀、西南夷皆震，请吏入朝。", "len": 21}
{"sid": "123_大宛列传.23.s2", "chapter": "123_大宛列传", "para": "23", "seq": 2, "text": "於是置益州、越巂、牂柯、沈黎、汶山郡，欲地接以前通大夏。", "len": 28}
{"sid": "123_大宛列传.23.s3", "chapter": "123_大宛列传", "para": "23", "seq": 3, "text": "乃遣使柏始昌、吕越人等岁十馀辈，出此初郡抵大夏，皆复闭昆明，为所杀，夺币财，终莫能通至大夏焉。", "len": 47}
{"sid": "123_大宛列传.23.s4", "chapter": "123_大宛列传", "para": "23", "seq": 4, "text": "於是汉发三辅罪人，因巴蜀士数万人，遣两将军郭昌、卫广等往击昆明之遮汉使者，斩首虏数万人而去。", "len": 46}
{"sid": "123_大宛列传.23.s5", "chapter": "123_大宛列传", "para": "23", "seq": 5, "text": "其後遣使，昆明复为寇，竟莫能得通。", "len": 17}
{"sid": "123_大宛列传.23.s6", "chapter": "123_大宛列传", "para": "23", "seq": 6, "text": "而北道酒泉抵大夏，使者既多，而外国益厌汉币，不贵其物。", "len": 27}
{"sid": "123_大宛列传.24.s1", "chapter": "123_大宛列传", "para": "24", "seq": 1, "text": "自博望侯开外国道以尊贵，其後从吏卒皆争上书言外国奇怪利害，求使。", "len": 32}
{"sid": "123_大宛列传.24.s2", "chapter": "123_大宛列传", "para": "24", "seq": 2, "text": "天子为其绝远，非人所乐往，听其言，予节，募吏民毋问所从来，为具备人众遣之，以广其道。", "len": 42}
{"sid": "123_大宛列传.24.s3", "chapter": "123_大宛列传", "para": "24", "seq": 3, "text": "来还不能毋侵盗币物，及使失指，天子为其习之，辄覆案致重罪，以激怒令赎，复求使。", "len": 39}
{"sid": "123_大宛列传.24.s4", "chapter": "123_大宛列传", "para": "24", "seq": 4, "text": "使端无穷，而轻犯法。", "len": 10}
{"sid": "123_大宛列传.24.s5", "chapter": "123_大宛列传", "para": "24", "seq": 5, "text": "其吏卒亦辄复盛推外国所有，言大者予节，言小者为副，故妄言无行之徒皆争效之。", "len": 37}
{"sid": "123_大宛列传.24.s6", "chapter": "123_大宛列传", "para": "24", "seq": 6, "text": "其使皆贫人子，私县官赍物，欲贱市以私其利外国。", "len": 23}
{"sid": "123_大宛列传.24.s7", "chapter": "123_大宛列传", "para": "24", "seq": 7, "text": "外国亦厌汉使人人有言轻重，度汉兵远不能至，而禁其食物以苦汉使。", "len": 31}
{"sid": "123_大宛列传.24.s8", "chapter": "123_大宛列传", "para": "24", "seq": 8, "text": "汉使乏绝积怨，至相攻击。", "len": 12}
{"sid": "123_大宛列传.24.s9", "chapter": "123_大宛列传", "para": "24", "seq": 9, "text": "而楼兰、姑师小国耳，当空道，攻劫汉使王恢等尤甚。", "len": 24}
{"sid": "123_大宛列传.24.s10", "chapter": "123_大宛列传", "para": "24", "seq": 10, "text": "而匈奴奇兵时时遮击使西国者。", "len": 14}
{"sid": "123_大宛列传.24.s11", "chapter": "123_大宛列传", "para": "24", "seq": 11, "text": "使者争遍言外国灾害，皆有城邑，兵弱易击。", "len": 20}
{"sid": "123_大宛列传.24.s12", "chapter": "123_大宛列传", "para": "24", "seq": 12, "text": "於是天子以故遣从骠侯破奴将属国骑及郡兵数万，至匈河水，欲以击胡，胡皆去。", "len": 36}
{"sid": "123_大宛列传.24.s13", "chapter": "123_大宛列传", "para": "24", "seq": 13, "text": "其明年，击姑师，破奴与轻骑七百馀先至，虏楼兰王，遂破姑师。", "len": 29}
{"sid": "123_大宛列传.24.s14", "chapter": "123_大宛列传", "para": "24", "seq": 14, "text": "因举兵威以困乌孙、大宛之属。", "len": 14}
{"sid": "123_大宛列传.24.s15", "chapter": "123_大宛列传", "para": "24", "seq": 15, "text": "还，封破奴为浞野侯。", "len": 10}
{"sid": "123_大宛列传.24.s16", "chapter": "123_大宛列传", "para": "24", "seq": 16, "text": "王恢数使，为楼兰所苦，言天子，天子发兵令恢佐破奴击破之，封恢为浩侯。", "len": 34}
{"sid": "123_大宛列传.24.s17", "chapter": "123_大宛列传", "para": "24", "seq": 17, "text": "於是酒泉列亭鄣至玉门矣。", "len": 12}
{"sid": "123_大宛列传.25.s1", "chapter": "123_大宛列传", "para": "25", "seq": 1, "text": "乌孙以千匹马聘汉女，汉遣宗室女江都翁主往妻乌孙，乌孙王昆莫以为右夫人。", "len": 35}
{"sid": "123_大宛列传.25.s2", "chapter": "123_大宛列传", "para": "25", "seq": 2, "text": "匈奴亦遣女妻昆莫，昆莫以为左夫人。", "len": 17}
{"sid": "123_大宛列传.25.s3", "chapter": "123_大宛列传", "para": "25", "seq": 3, "text": "昆莫曰“我老”，乃令其孙岑娶妻翁主。", "len": 18}
{"sid": "123_大宛列传.25.s4", "chapter": "123_大宛列传", "para": "25", "seq": 4, "text": "乌孙多马，其富人至有四五千匹马。", "len": 16}
{"sid": "123_大宛列传.26.s1", "chapter": "123_大宛列传", "para": "26", "seq": 1, "text": "初，汉使至安息，安息王令将二万骑迎於东界。", "len": 21}
{"sid": "123_大宛列传.26.s2", "chapter": "123_大宛列传", "para": "26", "seq": 2, "text": "东界去王都数千里。", "len": 9}
{"sid": "123_大宛列传.26.s3", "chapter": "123_大宛列传", "para": "26", "seq": 3, "text": "行比至，过数十城，人民相属甚多。", "len": 16}
{"sid": "123_大宛列传.26.s4", "chapter": "123_大宛列传", "para": "26", "seq": 4, "text": "汉使还，而後发使随汉使来观汉广大，以大鸟卵及黎轩善眩人献于汉。", "len": 31}
{"sid": "123_大宛列传.26.s5", "chapter": "123_大宛列传", "para": "26", "seq": 5, "text": "及宛西小国驩潜、大益，宛东姑师、扞鰛、苏薤之属，皆随汉使献见天子。", "len": 33}
{"sid": "123_大宛列传.26.s6", "chapter": "123_大宛列传", "para": "26", "seq": 6, "text": "天子大悦。", "len": 5}
{"sid": "123_大宛列传.27.s1", "chapter": "123_大宛列传", "para": "27", "seq": 1, "text": "而汉使穷河源，河源出于窴，其山多玉石，采来，天子案古图书，名河所出山曰昆仑云。", "len": 39}
{"sid": "123_大宛列传.28.s1", "chapter": "123_大宛列传", "para": "28", "seq": 1, "text": "是时上方数巡狩海上，乃悉从外国客，大都多人则过之，散财帛以赏赐，厚具以饶给之，以览示汉富厚焉。", "len": 47}
{"sid": "123_大宛列传.28.s2", "chapter": "123_大宛列传", "para": "28", "seq": 2, "text": "於是大觳抵，出奇戏诸怪物，多聚观者，行赏赐，酒池肉林，令外国客遍观仓库府藏之积，见汉之广大，倾骇之。", "len": 50}
{"sid": "123_大宛列传.28.s3", "chapter": "123_大宛列传", "para": "28", "seq": 3, "text": "及加其眩者之工，而觳抵奇戏岁增变，甚盛益兴，自此始。", "len": 26}
{"sid": "123_大宛列传.29.s1", "chapter": "123_大宛列传", "para": "29", "seq": 1, "text": "西北外国使，更来更去。", "len": 11}
{"sid": "123_大宛列传.29.s2", "chapter": "123_大宛列传", "para": "29", "seq": 2, "text": "宛以西，皆自以远，尚骄恣晏然，未可诎以礼羁縻而使也。", "len": 26}
{"sid": "123_大宛列传.29.s3", "chapter": "123_大宛列传", "para": "29", "seq": 3, "text": "自乌孙以西至安息，以近匈奴，匈奴困月氏也，匈奴使持单于一信，则国国传送食，不敢留苦；及至汉使，非出币帛不得食，不市畜不得骑用。", "len": 63}
{"sid": "123_大宛列传.29.s4", "chapter": "123_大宛列传", "para": "29", "seq": 4, "text": "所以然者，远汉，而汉多财物，故必市乃得所欲，然以畏匈奴於汉使焉。", "len": 32}
{"sid": "123_大宛列传.29.s5", "chapter": "123_大宛列传", "para": "29", "seq": 5, "text": "宛左右以蒲陶为酒，富人藏酒至万馀石，久者数十岁不败。", "len": 26}
{"sid": "123_大宛列传.29.s6", "chapter": "123_大宛列传", "para": "29", "seq": 6, "text": "俗嗜酒，马嗜苜蓿。", "len": 9}
{"sid": "123_大宛列传.29.s7", "chapter": "123_大宛列传", "para": "29", "seq": 7, "text": "汉使取其实来，於是天子始种苜蓿、蒲陶肥饶地。", "len": 22}
{"sid": "123_大宛列传.29.s8", "chapter": "123_大宛列传", "para": "29", "seq": 8, "text": "及天马多，外国使来众，则离宫别观旁尽种蒲萄、苜蓿极望。", "len": 27}
{"sid": "123_大宛列传.29.s9", "chapter": "123_大宛列传", "para": "29", "seq": 9, "text": "自大宛以西至安息，国虽颇异言，然大同俗，相知言。", "len": 24}
{"sid": "123_大宛列传.29.s10", "chapter": "123_大宛列传", "para": "29", "seq": 10, "text": "其人皆深眼，多须珣，善市贾，争分铢。", "len": 18}
{"sid": "123_大宛列传.29.s11", "chapter": "123_大宛列传", "para": "29", "seq": 11, "text": "俗贵女子，女子所言而丈夫乃决正。", "len": 16}
{"sid": "123_大宛列传.29.s12", "chapter": "123_大宛列传", "para": "29", "seq": 12, "text": "其地皆无丝漆，不知铸钱器。", "len": 13}
{"sid": "123_大宛列传.29.s13", "chapter": "123_大宛列传", "para": "29", "seq": 13, "text": "及汉使亡卒降，教铸作他兵器。", "len": 14}
{"sid": "123_大宛列传.29.s14", "chapter": "123_大宛列传", "para": "29", "seq": 14, "text": "得汉黄白金，辄以为器，不用为币。", "len": 16}
{"sid": "123_大宛列传.30.s1", "chapter": "123_大宛列传", "para": "30", "seq": 1, "text": "而汉使者往既多，其少从率多进熟於天子，言曰：“宛有善马在贰师城，匿不肯与汉使。", "len": 39}
{"sid": "123_大宛列传.30.s2", "chapter": "123_大宛列传", "para": "30", "seq": 2, "text": "” 天子既好宛马，闻之甘心，使壮士车令等持千金及金马以请宛王贰师城善马。", "len": 36}
{"sid": "123_大宛列传.30.s3", "chapter": "123_大宛列传", "para": "30", "seq": 3, "text": "宛国饶汉物，相与谋曰：“汉去我远，而盐水中数败，出其北有胡寇，出其南乏水草。", "len": 38}
{"sid": "123_大宛列传.30.s4", "chapter": "123_大宛列传", "para": "30", "seq": 4, "text": "又且往往而绝邑，乏食者多。", "len": 13}
{"sid": "123_大宛列传.30.s5", "chapter": "123_大宛列传", "para": "30", "seq": 5, "text": "汉使数百人为辈来，而常乏食，死者过半，是安能致大军乎？", "len": 27}
{"sid": "123_大宛列传.30.s6", "chapter": "123_大宛列传", "para": "30", "seq": 6, "text": "无柰我何。", "len": 5}
{"sid": "123_大宛列传.30.s7", "chapter": "123_大宛列传", "para": "30", "seq": 7, "text": "且贰师马，宛宝马也。", "len": 10}
{"sid": "123_大宛列传.30.s8", "chapter": "123_大宛列传", "para": "30", "seq": 8, "text": "” 遂不肯予汉使。", "len": 9}
{"sid": "123_大宛列传.30.s9", "chapter": "123_大宛列传", "para": "30", "seq": 9, "text": "汉使怒，妄言，椎金马而去。", "len": 13}
{"sid": "123_大宛列传.30.s10", "chapter": "123_大宛列传", "para": "30", "seq": 10, "text": "宛贵人怒曰：“汉使至轻我！", "len": 13}
{"sid": "123_大宛列传.30.s11", "chapter": "123_大宛列传", "para": "30", "seq": 11, "text": "” 遣汉使去，令其东边郁成遮攻杀汉使，取其财物。", "len": 24}
{"sid": "123_大宛列传.30.s12", "chapter": "123_大宛列传", "para": "30", "seq": 12, "text": "於是天子大怒。", "len": 7}
{"sid": "123_大宛列传.30.s13", "chapter": "123_大宛列传", "para": "30", "seq": 13, "text": "诸尝使宛姚定汉等言宛兵弱，诚以汉兵不过三千人，彊弩射之，即尽虏破宛矣。", "len": 35}
{"sid": "123_大宛列传.30.s14", "chapter": "123_大宛列传", "para": "30", "seq": 14, "text": "天子已尝使浞野侯攻楼兰，以七百骑先至，虏其王，以定汉等言为然，而欲侯宠姬李氏，拜李广利为贰师将军，发属国六千骑，及郡国恶少年数万人，以往伐宛。", "len": 71}
{"sid": "123_大宛列传.30.s15", "chapter": "123_大宛列传", "para": "30", "seq": 15, "text": "期至贰师城取善马，故号“贰师将军”。", "len": 18}
{"sid": "123_大宛列传.30.s16", "chapter": "123_大宛列传", "para": "30", "seq": 16, "text": "赵始成为军正，故浩侯王恢使导军，而李哆为校尉，制军事。", "len": 27}
{"sid": "123_大宛列传.30.s17", "chapter": "123_大宛列传", "para": "30", "seq": 17, "text": "是岁太初元年也。", "len": 8}
{"sid": "123_大宛列传.30.s18", "chapter": "123_大宛列传", "para": "30", "seq": 18, "text": "而关东蝗大起，蜚西至敦煌。", "len": 13}
{"sid": "123_大宛列传.31.s1", "chapter": "123_大宛列传", "para": "31", "seq": 1, "text": "贰师将军军既西过盐水，当道小国恐，各坚城守，不肯给食。", "len": 27}
{"sid": "123_大宛列传.31.s2", "chapter": "123_大宛列传", "para": "31", "seq": 2, "text": "攻之不能下。", "len": 6}
{"sid": "123_大宛列传.31.s3", "chapter": "123_大宛列传", "para": "31", "seq": 3, "text": "下者得食，不下者数日则去。", "len": 13}
{"sid": "123_大宛列传.31.s4", "chapter": "123_大宛列传", "para": "31", "seq": 4, "text": "比至郁成，士至者不过数千，皆饥罢。", "len": 17}
{"sid": "123_大宛列传.31.s5", "chapter": "123_大宛列传", "para": "31", "seq": 5, "text": "攻郁成，郁成大破之，所杀伤甚众。", "len": 16}
{"sid": "123_大宛列传.31.s6", "chapter": "123_大宛列传", "para": "31", "seq": 6, "text": "贰师将军与哆、始成等计：“至郁成尚不能举，况至其王都乎？", "len": 28}
{"sid": "123_大宛列传.31.s7", "chapter": "123_大宛列传", "para": "31", "seq": 7, "text": "” 引兵而还。", "len": 7}
{"sid": "123_大宛列传.31.s8", "chapter": "123_大宛列传", "para": "31", "seq": 8, "text": "往来二岁。", "len": 5}
{"sid": "123_大宛列传.31.s9", "chapter": "123_大宛列传", "para": "31", "seq": 9, "text": "还至敦煌，士不过什一二。", "len": 12}
{"sid": "123_大宛列传.31.s10", "chapter": "123_大宛列传", "para": "31", "seq": 10, "text": "使使上书言：“道远多乏食；且士卒不患战，患饥。", "len": 23}
{"sid": "123_大宛列传.31.s11", "chapter": "123_大宛列传", "para": "31", "seq": 11, "text": "人少，不足以拔宛。", "len": 9}
{"sid": "123_大宛列传.31.s12", "chapter": "123_大宛列传", "para": "31", "seq": 12, "text": "原且罢兵，益发而复往。", "len": 11}
{"sid": "123_大宛列传.31.s13", "chapter": "123_大宛列传", "para": "31", "seq": 13, "text": "” 天子闻之，大怒，而使使遮玉门，曰军有敢入者辄斩之！", "len": 27}
{"sid": "123_大宛列传.31.s14", "chapter": "123_大宛列传", "para": "31", "seq": 14, "text": "贰师恐，因留敦煌。", "len": 9}
{"sid": "123_大宛列传.32.s1", "chapter": "123_大宛列传", "para": "32", "seq": 1, "text": "其夏，汉亡浞野之兵二万馀於匈奴。", "len": 16}
{"sid": "123_大宛列传.32.s2", "chapter": "123_大宛列传", "para": "32", "seq": 2, "text": "公卿及议者皆原罢击宛军，专力攻胡。", "len": 17}
{"sid": "123_大宛列传.32.s3", "chapter": "123_大宛列传", "para": "32", "seq": 3, "text": "天子已业诛宛，宛小国而不能下，则大夏之属轻汉，而宛善马绝不来，乌孙、仑头易苦汉使矣，为外国笑。", "len": 47}
{"sid": "123_大宛列传.32.s4", "chapter": "123_大宛列传", "para": "32", "seq": 4, "text": "乃案言伐宛尤不便者邓光等，赦囚徒材官，益发恶少年及边骑，岁馀而出敦煌者六万人，负私从者不与。", "len": 46}
{"sid": "123_大宛列传.32.s5", "chapter": "123_大宛列传", "para": "32", "seq": 5, "text": "牛十万，马三万馀匹，驴骡橐它以万数。", "len": 18}
{"sid": "123_大宛列传.32.s6", "chapter": "123_大宛列传", "para": "32", "seq": 6, "text": "多赍粮，兵弩甚设，天下骚动，传相奉伐宛，凡五十馀校尉。", "len": 27}
{"sid": "123_大宛列传.32.s7", "chapter": "123_大宛列传", "para": "32", "seq": 7, "text": "宛王城中无井，皆汲城外流水，於是乃遣水工徙其城下水空以空其城。", "len": 31}
{"sid": "123_大宛列传.32.s8", "chapter": "123_大宛列传", "para": "32", "seq": 8, "text": "益发戍甲卒十八万，酒泉、张掖北，置居延、休屠以卫酒泉，而发天下七科適，及载Я给贰师。", "len": 42}
{"sid": "123_大宛列传.32.s9", "chapter": "123_大宛列传", "para": "32", "seq": 9, "text": "转车人徒相连属至敦煌。", "len": 11}
{"sid": "123_大宛列传.32.s10", "chapter": "123_大宛列传", "para": "32", "seq": 10, "text": "而拜习马者二人为执驱校尉，备破宛择取其善马云。", "len": 23}
{"sid": "123_大宛列传.33.s1", "chapter": "123_大宛列传", "para": "33", "seq": 1, "text": "於是贰师後复行，兵多，而所至小国莫不迎，出食给军。", "len": 25}
{"sid": "123_大宛列传.33.s2", "chapter": "123_大宛列传", "para": "33", "seq": 2, "text": "至仑头，仑头不下，攻数日，屠之。", "len": 16}
{"sid": "123_大宛列传.33.s3", "chapter": "123_大宛列传", "para": "33", "seq": 3, "text": "自此而西，平行至宛城，汉兵到者三万人。", "len": 19}
{"sid": "123_大宛列传.33.s4", "chapter": "123_大宛列传", "para": "33", "seq": 4, "text": "宛兵迎击汉兵，汉兵射败之，宛走入葆乘其城。", "len": 21}
{"sid": "123_大宛列传.33.s5", "chapter": "123_大宛列传", "para": "33", "seq": 5, "text": "贰师兵欲行攻郁成，恐留行而令宛益生诈，乃先至宛，决其水源，移之，则宛固已忧困。", "len": 39}
{"sid": "123_大宛列传.33.s6", "chapter": "123_大宛列传", "para": "33", "seq": 6, "text": "围其城，攻之四十馀日，其外城坏，虏宛贵人勇将煎靡。", "len": 25}
{"sid": "123_大宛列传.33.s7", "chapter": "123_大宛列传", "para": "33", "seq": 7, "text": "宛大恐，走入中城。", "len": 9}
{"sid": "123_大宛列传.33.s8", "chapter": "123_大宛列传", "para": "33", "seq": 8, "text": "宛贵人相与谋曰：“汉所为攻宛，以王毋寡匿善马而杀汉使。", "len": 27}
{"sid": "123_大宛列传.33.s9", "chapter": "123_大宛列传", "para": "33", "seq": 9, "text": "今杀王毋寡而出善马，汉兵宜解；即不解，乃力战而死，未晚也。", "len": 29}
{"sid": "123_大宛列传.33.s10", "chapter": "123_大宛列传", "para": "33", "seq": 10, "text": "” 宛贵人皆以为然，共杀其王毋寡，持其头遣贵人使贰师，约曰：“汉毋攻我。", "len": 36}
{"sid": "123_大宛列传.33.s11", "chapter": "123_大宛列传", "para": "33", "seq": 11, "text": "我尽出善马，恣所取，而给汉军食。", "len": 16}
{"sid": "123_大宛列传.33.s12", "chapter": "123_大宛列传", "para": "33", "seq": 12, "text": "即不听，我尽杀善马，而康居之救且至。", "len": 18}
{"sid": "123_大宛列传.33.s13", "chapter": "123_大宛列传", "para": "33", "seq": 13, "text": "至，我居内，康居居外，与汉军战。", "len": 16}
{"sid": "123_大宛列传.33.s14", "chapter": "123_大宛列传", "para": "33", "seq": 14, "text": "汉军熟计之，何从？", "len": 9}
{"sid": "123_大宛列传.33.s15", "chapter": "123_大宛列传", "para": "33", "seq": 15, "text": "” 是时康居候视汉兵，汉兵尚盛，不敢进。", "len": 20}
{"sid": "123_大宛列传.33.s16", "chapter": "123_大宛列传", "para": "33", "seq": 16, "text": "贰师与赵始成、李哆等计：“闻宛城中新得秦人，知穿井，而其内食尚多。", "len": 33}
{"sid": "123_大宛列传.33.s17", "chapter": "123_大宛列传", "para": "33", "seq": 17, "text": "所为来，诛首恶者毋寡。", "len": 11}
{"sid": "123_大宛列传.33.s18", "chapter": "123_大宛列传", "para": "33", "seq": 18, "text": "毋寡头已至，如此而不许解兵，则坚守，而康居候汉罢而来救宛，破汉军必矣。", "len": 35}
{"sid": "123_大宛列传.33.s19", "chapter": "123_大宛列传", "para": "33", "seq": 19, "text": "” 军吏皆以为然，许宛之约。", "len": 14}
{"sid": "123_大宛列传.33.s20", "chapter": "123_大宛列传", "para": "33", "seq": 20, "text": "宛乃出其善马，令汉自择之，而多出食食给汉军。", "len": 22}
{"sid": "123_大宛列传.33.s21", "chapter": "123_大宛列传", "para": "33", "seq": 21, "text": "汉军取其善马数十匹。", "len": 10}
{"sid": "123_大宛列传.33.s22", "chapter": "123_大宛列传", "para": "33", "seq": 22, "text": "中马以下牡牝三千馀匹，而立宛贵人之故待遇汉使善者名昧蔡以为宛王，与盟而罢兵。", "len": 38}
{"sid": "123_大宛列传.33.s23", "chapter": "123_大宛列传", "para": "33", "seq": 23, "text": "终不得入中城。", "len": 7}
{"sid": "123_大宛列传.33.s24", "chapter": "123_大宛列传", "para": "33", "seq": 24, "text": "乃罢而引归。", "len": 6}
{"sid": "123_大宛列传.34.s1", "chapter": "123_大宛列传", "para": "34", "seq": 1, "text": "初，贰师起敦煌西，以为人多，道上国不能食，乃分为数军，从南北道。", "len": 32}
{"sid": "123_大宛列传.34.s2", "chapter": "123_大宛列传", "para": "34", "seq": 2, "text": "校尉王申生、故鸿胪壶充国等千馀人，别到郁成。", "len": 22}
{"sid": "123_大宛列传.34.s3", "chapter": "123_大宛列传", "para": "34", "seq": 3, "text": "郁成城守，不肯给食其军。", "len": 12}
{"sid": "123_大宛列传.34.s4", "chapter": "123_大宛列传", "para": "34", "seq": 4, "text": "王申生去大军二百里，而轻之，责郁成。", "len": 18}
{"sid": "123_大宛列传.34.s5", "chapter": "123_大宛列传", "para": "34", "seq": 5, "text": "郁成食不肯出，窥知申生军日少，晨用三千人攻，戮杀申生等，军破，数人脱亡，走贰师。", "len": 40}
{"sid": "123_大宛列传.34.s6", "chapter": "123_大宛列传", "para": "34", "seq": 6, "text": "贰师令搜粟都尉上官桀往攻破郁成。", "len": 16}
{"sid": "123_大宛列传.34.s7", "chapter": "123_大宛列传", "para": "34", "seq": 7, "text": "郁成王亡走康居，桀追至康居。", "len": 14}
{"sid": "123_大宛列传.34.s8", "chapter": "123_大宛列传", "para": "34", "seq": 8, "text": "康居闻汉已破宛，乃出郁成王予桀，桀令四骑士缚守诣大将军。", "len": 28}
{"sid": "123_大宛列传.34.s9", "chapter": "123_大宛列传", "para": "34", "seq": 9, "text": "四人相谓曰：“郁成王汉国所毒，今生将去，卒失大事。", "len": 25}
{"sid": "123_大宛列传.34.s10", "chapter": "123_大宛列传", "para": "34", "seq": 10, "text": "” 欲杀，莫敢先击。", "len": 10}
{"sid": "123_大宛列传.34.s11", "chapter": "123_大宛列传", "para": "34", "seq": 11, "text": "上邽骑士赵弟最少，拔剑击之，斩郁成王，赍头。", "len": 22}
{"sid": "123_大宛列传.34.s12", "chapter": "123_大宛列传", "para": "34", "seq": 12, "text": "弟、桀等逐及大将军。", "len": 10}
{"sid": "123_大宛列传.35.s1", "chapter": "123_大宛列传", "para": "35", "seq": 1, "text": "初，贰师後行，天子使使告乌孙，大发兵并力击宛。", "len": 23}
{"sid": "123_大宛列传.35.s2", "chapter": "123_大宛列传", "para": "35", "seq": 2, "text": "乌孙发二千骑往，持两端，不肯前。", "len": 16}
{"sid": "123_大宛列传.35.s3", "chapter": "123_大宛列传", "para": "35", "seq": 3, "text": "贰师将军之东，诸所过小国闻宛破，皆使其子弟从军入献，见天子，因以为质焉。", "len": 36}
{"sid": "123_大宛列传.35.s4", "chapter": "123_大宛列传", "para": "35", "seq": 4, "text": "贰师之伐宛也，而军正赵始成力战，功最多；及上官桀敢深入，李哆为谋计，军入玉门者万馀人，军马千馀匹。", "len": 49}
{"sid": "123_大宛列传.35.s5", "chapter": "123_大宛列传", "para": "35", "seq": 5, "text": "贰师後行，军非乏食，战死不能多，而将吏贪，多不爱士卒，侵牟之，以此物故众。", "len": 37}
{"sid": "123_大宛列传.35.s6", "chapter": "123_大宛列传", "para": "35", "seq": 6, "text": "天子为万里而伐宛，不录过，封广利为海西侯。", "len": 21}
{"sid": "123_大宛列传.35.s7", "chapter": "123_大宛列传", "para": "35", "seq": 7, "text": "又封身斩郁成王者骑士赵弟为新畤侯。", "len": 17}
{"sid": "123_大宛列传.35.s8", "chapter": "123_大宛列传", "para": "35", "seq": 8, "text": "军正赵始成为光禄大夫，上官桀为少府，李哆为上党太守。", "len": 26}
{"sid": "123_大宛列传.35.s9", "chapter": "123_大宛列传", "para": "35", "seq": 9, "text": "军官吏为九卿者三人，诸侯相、郡守、二千石者百馀人，千石以下千馀人。", "len": 33}
{"sid": "123_大宛列传.35.s10", "chapter": "123_大宛列传", "para": "35", "seq": 10, "text": "奋行者官过其望，以適过行者皆绌其劳。", "len": 18}
{"sid": "123_大宛列传.35.s11", "chapter": "123_大宛列传", "para": "35", "seq": 11, "text": "士卒赐直四万金。", "len": 8}
{"sid": "123_大宛列传.35.s12", "chapter": "123_大宛列传", "para": "35", "seq": 12, "text": "伐宛再反，凡四岁而得罢焉。", "len": 13}
{"sid": "123_大宛列传.36.s1", "chapter": "123_大宛列传", "para": "36", "seq": 1, "text": "汉已伐宛，立昧蔡为橡王而去＃岁馀，宛贵人以为昧蔡善谀，使我国遇侠，乃相与杀昧蔡，立毋寡昆弟曰蝉封为宛王，而遣其子入质於汉。", "len": 61}
{"sid": "123_大宛列传.36.s2", "chapter": "123_大宛列传", "para": "36", "seq": 2, "text": "汉因使使赂赐以镇抚之。", "len": 11}
{"sid": "123_大宛列传.37.s1", "chapter": "123_大宛列传", "para": "37", "seq": 1, "text": "而汉发使十馀辈至宛西诸外国，求奇物，因风览以伐宛之威德。", "len": 28}
{"sid": "123_大宛列传.37.s2", "chapter": "123_大宛列传", "para": "37", "seq": 2, "text": "而敦煌置酒泉都尉；西至盐水，往往有亭。", "len": 19}
{"sid": "123_大宛列传.37.s3", "chapter": "123_大宛列传", "para": "37", "seq": 3, "text": "而仑头有田卒数百人，因置使者护田积粟，以给使外国者。", "len": 26}
{"sid": "123_大宛列传.37.s4", "chapter": "123_大宛列传", "para": "37", "seq": 4, "text": "::: 太史公曰", "len": 8}
{"sid": "123_大宛列传.38.s1", "chapter": "123_大宛列传", "para": "38", "seq": 1, "text": "太史公曰：禹本纪言“河出昆仑。", "len": 15}
{"sid": "123_大宛列传.38.s2", "chapter": "123_大宛列传", "para": "38", "seq": 2, "text": "昆仑其高二千五百馀里，日月所相避隐为光明也。", "len": 22}
{"sid": "123_大宛列传.38.s3", "chapter": "123_大宛列传", "para": "38", "seq": 3, "text": "其上有醴泉、瑶池”。", "len": 10}
{"sid": "123_大宛列传.38.s4", "chapter": "123_大宛列传", "para": "38", "seq": 4, "text": "今自张骞使大夏之後也，穷河源，恶睹本纪所谓昆仑者乎？", "len": 26}
{"sid": "123_大宛列传.38.s5", "chapter": "123_大宛列传", "para": "38", "seq": 5, "text": "故言九州山川，尚书近之矣。", "len": 13}
{"sid": "123_大宛列传.38.s6", "chapter": "123_大宛列传", "para": "38", "seq": 6, "text": "至禹本纪、山海经所有怪物，余不敢言之也。", "len": 20}
{"sid": "123_大宛列传.38.s7", "chapter": "123_大宛列传", "para": "38", "seq": 7, "text": "::: ::: 赞", "len": 9}
{"sid": "123_大宛列传.39.s1", "chapter": "123_大宛列传", "para": "39", "seq": 1, "text": "大宛之迹，元因博望。", "len": 10}
{"sid": "123_大宛列传.39.s2", "chapter": "123_大宛列传", "para": "39", "seq": 2, "text": "始究河源，旋窥海上。", "len": 10}
{"sid": "123_大宛列传.39.s3", "chapter": "123_大宛列传", "para": "39", "seq": 3, "text": "条枝西入，天马内向。", "len": 10}
{"sid": "123_大宛列传.39.s4", "chapter": "123_大宛列传", "para": "39", "seq": 4, "text": "葱岭无尘，盐池息浪。", "len": 10}
{"sid": "123_大宛列传.39.s5", "chapter": "123_大宛列传", "para": "39", "seq": 5, "text": "旷哉绝域，往往亭障。", "len": 10}
{"sid": "123_大宛列传.39.s6", "chapter": "123_大宛列传", "para": "39", "seq": 6, "text": ":::", "len": 3}
