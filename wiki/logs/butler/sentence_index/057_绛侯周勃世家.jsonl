{"sid": "057_绛侯周勃世家.1.s1", "chapter": "057_绛侯周勃世家", "para": "1", "seq": 1, "text": "绛侯周勃者，沛人也。", "len": 10}
{"sid": "057_绛侯周勃世家.1.s2", "chapter": "057_绛侯周勃世家", "para": "1", "seq": 2, "text": "其先卷人，徙沛。", "len": 8}
{"sid": "057_绛侯周勃世家.1.s3", "chapter": "057_绛侯周勃世家", "para": "1", "seq": 3, "text": "勃以织薄曲为生，常为人吹箫给丧事，材官引彊。", "len": 22}
{"sid": "057_绛侯周勃世家.2.s1", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 1, "text": "高祖之为沛公初起，勃以中涓从攻胡陵，下方与。", "len": 22}
{"sid": "057_绛侯周勃世家.2.s2", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 2, "text": "方与反，与战，卻適。", "len": 10}
{"sid": "057_绛侯周勃世家.2.s3", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 3, "text": "攻丰。", "len": 3}
{"sid": "057_绛侯周勃世家.2.s4", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 4, "text": "击秦军砀东。", "len": 6}
{"sid": "057_绛侯周勃世家.2.s5", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 5, "text": "还军留及萧。", "len": 6}
{"sid": "057_绛侯周勃世家.2.s6", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 6, "text": "复攻砀，破之。", "len": 7}
{"sid": "057_绛侯周勃世家.2.s7", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 7, "text": "下下邑，先登。", "len": 7}
{"sid": "057_绛侯周勃世家.2.s8", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 8, "text": "赐爵五大夫。", "len": 6}
{"sid": "057_绛侯周勃世家.2.s9", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 9, "text": "攻蒙、虞，取之。", "len": 8}
{"sid": "057_绛侯周勃世家.2.s10", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 10, "text": "击章邯车骑，殿。", "len": 8}
{"sid": "057_绛侯周勃世家.2.s11", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 11, "text": "定魏地。", "len": 4}
{"sid": "057_绛侯周勃世家.2.s12", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 12, "text": "攻爰戚、东缗，以往至栗，取之。", "len": 15}
{"sid": "057_绛侯周勃世家.2.s13", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 13, "text": "攻齧桑，先登。", "len": 7}
{"sid": "057_绛侯周勃世家.2.s14", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 14, "text": "击秦军阿下，破之。", "len": 9}
{"sid": "057_绛侯周勃世家.2.s15", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 15, "text": "追至濮阳，下甄城。", "len": 9}
{"sid": "057_绛侯周勃世家.2.s16", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 16, "text": "攻都关、定陶，袭取宛朐，得单父令。", "len": 17}
{"sid": "057_绛侯周勃世家.2.s17", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 17, "text": "夜袭取临济，攻张，以前至卷，破之。", "len": 17}
{"sid": "057_绛侯周勃世家.2.s18", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 18, "text": "击李由军雍丘下。", "len": 8}
{"sid": "057_绛侯周勃世家.2.s19", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 19, "text": "攻开封，先至城下为多。", "len": 11}
{"sid": "057_绛侯周勃世家.2.s20", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 20, "text": "後章邯破杀项梁，沛公与项羽引兵东如砀。", "len": 19}
{"sid": "057_绛侯周勃世家.2.s21", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 21, "text": "自初起沛还至砀，一岁二月。", "len": 13}
{"sid": "057_绛侯周勃世家.2.s22", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 22, "text": "楚怀王封沛公号安武侯，为砀郡长。", "len": 16}
{"sid": "057_绛侯周勃世家.2.s23", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 23, "text": "沛公拜勃为虎贲令，以令从沛公定魏地。", "len": 18}
{"sid": "057_绛侯周勃世家.2.s24", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 24, "text": "攻东郡尉於城武，破之。", "len": 11}
{"sid": "057_绛侯周勃世家.2.s25", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 25, "text": "击王离军，破之。", "len": 8}
{"sid": "057_绛侯周勃世家.2.s26", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 26, "text": "攻长社，先登。", "len": 7}
{"sid": "057_绛侯周勃世家.2.s27", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 27, "text": "攻颍阳、缑氏，绝河津。", "len": 11}
{"sid": "057_绛侯周勃世家.2.s28", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 28, "text": "击赵贲军尸北。", "len": 7}
{"sid": "057_绛侯周勃世家.2.s29", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 29, "text": "南攻南阳守齮，破武关、峣关。", "len": 14}
{"sid": "057_绛侯周勃世家.2.s30", "chapter": "057_绛侯周勃世家", "para": "2", "seq": 30, "text": "破秦军於蓝田，至咸阳，灭秦。", "len": 14}
{"sid": "057_绛侯周勃世家.3.s1", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 1, "text": "项羽至，以沛公为汉王。", "len": 11}
{"sid": "057_绛侯周勃世家.3.s2", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 2, "text": "汉王赐勃爵为威武侯。", "len": 10}
{"sid": "057_绛侯周勃世家.3.s3", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 3, "text": "从入汉中，拜为将军。", "len": 10}
{"sid": "057_绛侯周勃世家.3.s4", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 4, "text": "还定三秦，至秦，赐食邑怀德。", "len": 14}
{"sid": "057_绛侯周勃世家.3.s5", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 5, "text": "攻槐里、好畤，最。", "len": 9}
{"sid": "057_绛侯周勃世家.3.s6", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 6, "text": "击赵贲、内史保於咸阳，最。", "len": 13}
{"sid": "057_绛侯周勃世家.3.s7", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 7, "text": "北攻漆。", "len": 4}
{"sid": "057_绛侯周勃世家.3.s8", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 8, "text": "击章平、姚卬军。", "len": 8}
{"sid": "057_绛侯周勃世家.3.s9", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 9, "text": "西定汧。", "len": 4}
{"sid": "057_绛侯周勃世家.3.s10", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 10, "text": "还下郿、频阳。", "len": 7}
{"sid": "057_绛侯周勃世家.3.s11", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 11, "text": "围章邯废丘。", "len": 6}
{"sid": "057_绛侯周勃世家.3.s12", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 12, "text": "破西丞。", "len": 4}
{"sid": "057_绛侯周勃世家.3.s13", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 13, "text": "击盗巴军，破之。", "len": 8}
{"sid": "057_绛侯周勃世家.3.s14", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 14, "text": "攻上邽。", "len": 4}
{"sid": "057_绛侯周勃世家.3.s15", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 15, "text": "东守峣关。", "len": 5}
{"sid": "057_绛侯周勃世家.3.s16", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 16, "text": "转击项籍。", "len": 5}
{"sid": "057_绛侯周勃世家.3.s17", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 17, "text": "攻曲逆，最。", "len": 6}
{"sid": "057_绛侯周勃世家.3.s18", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 18, "text": "还守敖仓，追项籍。", "len": 9}
{"sid": "057_绛侯周勃世家.3.s19", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 19, "text": "籍已死，因东定楚地泗、东海郡，凡得二十二县。", "len": 22}
{"sid": "057_绛侯周勃世家.3.s20", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 20, "text": "还守雒阳、栎阳，赐与颍侯共食锺离。", "len": 17}
{"sid": "057_绛侯周勃世家.3.s21", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 21, "text": "以将军从高帝反者燕王臧荼，破之易下。", "len": 18}
{"sid": "057_绛侯周勃世家.3.s22", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 22, "text": "所将卒当驰道为多。", "len": 9}
{"sid": "057_绛侯周勃世家.3.s23", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 23, "text": "赐爵列侯，剖符世世勿绝。", "len": 12}
{"sid": "057_绛侯周勃世家.3.s24", "chapter": "057_绛侯周勃世家", "para": "3", "seq": 24, "text": "食绛八千一百八十户，号绛侯。", "len": 14}
{"sid": "057_绛侯周勃世家.4.s1", "chapter": "057_绛侯周勃世家", "para": "4", "seq": 1, "text": "以将军从高帝击反韩王信於代，降下霍人。", "len": 19}
{"sid": "057_绛侯周勃世家.4.s2", "chapter": "057_绛侯周勃世家", "para": "4", "seq": 2, "text": "以前至武泉，击胡骑，破之武泉北。", "len": 16}
{"sid": "057_绛侯周勃世家.4.s3", "chapter": "057_绛侯周勃世家", "para": "4", "seq": 3, "text": "转攻韩信军铜鞮，破之。", "len": 11}
{"sid": "057_绛侯周勃世家.4.s4", "chapter": "057_绛侯周勃世家", "para": "4", "seq": 4, "text": "还，降太原六城。", "len": 8}
{"sid": "057_绛侯周勃世家.4.s5", "chapter": "057_绛侯周勃世家", "para": "4", "seq": 5, "text": "击韩信胡骑晋阳下，破之，下晋阳。", "len": 16}
{"sid": "057_绛侯周勃世家.4.s6", "chapter": "057_绛侯周勃世家", "para": "4", "seq": 6, "text": "後击韩信军於硰石，破之，追北八十里。", "len": 18}
{"sid": "057_绛侯周勃世家.4.s7", "chapter": "057_绛侯周勃世家", "para": "4", "seq": 7, "text": "还攻楼烦三城，因击胡骑平城下，所将卒当驰道为多。", "len": 24}
{"sid": "057_绛侯周勃世家.4.s8", "chapter": "057_绛侯周勃世家", "para": "4", "seq": 8, "text": "勃迁为太尉。", "len": 6}
{"sid": "057_绛侯周勃世家.5.s1", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 1, "text": "击陈豨，屠马邑。", "len": 8}
{"sid": "057_绛侯周勃世家.5.s2", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 2, "text": "所将卒斩豨将军乘马絺。", "len": 11}
{"sid": "057_绛侯周勃世家.5.s3", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 3, "text": "击韩信、陈豨、赵利军於楼烦，破之。", "len": 17}
{"sid": "057_绛侯周勃世家.5.s4", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 4, "text": "得豨将宋最、雁门守。", "len": 10}
{"sid": "057_绛侯周勃世家.5.s5", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 5, "text": "因转攻得云中守遫、丞相箕肆、将勋。", "len": 17}
{"sid": "057_绛侯周勃世家.5.s6", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 6, "text": "定雁门郡十七县，云中郡十二县。", "len": 15}
{"sid": "057_绛侯周勃世家.5.s7", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 7, "text": "因复击豨灵丘，破之，斩豨，得豨丞相程纵、将军陈武、都尉高肆。", "len": 30}
{"sid": "057_绛侯周勃世家.5.s8", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 8, "text": "定代郡九县。", "len": 6}
{"sid": "057_绛侯周勃世家.5.s9", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 9, "text": "燕王卢绾反，勃以相国代樊哙将，击下蓟，得绾大将抵、丞相偃、守陉、太尉弱、御史大夫施，屠浑都。", "len": 46}
{"sid": "057_绛侯周勃世家.5.s10", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 10, "text": "破绾军上兰，复击破绾军沮阳。", "len": 14}
{"sid": "057_绛侯周勃世家.5.s11", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 11, "text": "追至长城，定上谷十二县，右北平十六县，辽西、辽东二十九县，渔阳二十二县。", "len": 36}
{"sid": "057_绛侯周勃世家.5.s12", "chapter": "057_绛侯周勃世家", "para": "5", "seq": 12, "text": "最从高帝得相国一人，丞相二人，将军、二千石各三人；别破军二，下城三，定郡五，县七十九，得丞相、大将各一人。", "len": 53}
{"sid": "057_绛侯周勃世家.6.s1", "chapter": "057_绛侯周勃世家", "para": "6", "seq": 1, "text": "勃为人木彊敦厚，高帝以为可属大事。", "len": 17}
{"sid": "057_绛侯周勃世家.6.s2", "chapter": "057_绛侯周勃世家", "para": "6", "seq": 2, "text": "勃不好文学，每召诸生说士，东乡坐而责之：“趣为我语。", "len": 26}
{"sid": "057_绛侯周勃世家.6.s3", "chapter": "057_绛侯周勃世家", "para": "6", "seq": 3, "text": "” 其椎少文如此。", "len": 9}
{"sid": "057_绛侯周勃世家.7.s1", "chapter": "057_绛侯周勃世家", "para": "7", "seq": 1, "text": "勃既定燕而归，高祖已崩矣，以列侯事孝惠帝。", "len": 21}
{"sid": "057_绛侯周勃世家.7.s2", "chapter": "057_绛侯周勃世家", "para": "7", "seq": 2, "text": "孝惠帝六年，置太尉官，以勃为太尉。", "len": 17}
{"sid": "057_绛侯周勃世家.7.s3", "chapter": "057_绛侯周勃世家", "para": "7", "seq": 3, "text": "十岁，高后崩。", "len": 7}
{"sid": "057_绛侯周勃世家.7.s4", "chapter": "057_绛侯周勃世家", "para": "7", "seq": 4, "text": "吕禄以赵王为汉上将军，吕产以吕王为汉相国，秉汉权，欲危刘氏。", "len": 30}
{"sid": "057_绛侯周勃世家.7.s5", "chapter": "057_绛侯周勃世家", "para": "7", "seq": 5, "text": "勃为太尉，不得入军门。", "len": 11}
{"sid": "057_绛侯周勃世家.7.s6", "chapter": "057_绛侯周勃世家", "para": "7", "seq": 6, "text": "陈平为丞相，不得任事。", "len": 11}
{"sid": "057_绛侯周勃世家.7.s7", "chapter": "057_绛侯周勃世家", "para": "7", "seq": 7, "text": "於是勃与平谋，卒诛诸吕而立孝文皇帝。", "len": 18}
{"sid": "057_绛侯周勃世家.7.s8", "chapter": "057_绛侯周勃世家", "para": "7", "seq": 8, "text": "其语在吕后、孝文事中。", "len": 11}
{"sid": "057_绛侯周勃世家.8.s1", "chapter": "057_绛侯周勃世家", "para": "8", "seq": 1, "text": "文帝既立，以勃为右丞相，赐金五千斤，食邑万户。", "len": 23}
{"sid": "057_绛侯周勃世家.8.s2", "chapter": "057_绛侯周勃世家", "para": "8", "seq": 2, "text": "居月馀，人或说勃曰：“君既诛诸吕，立代王，威震天下，而君受厚赏，处尊位，以宠，久之即祸及身矣。", "len": 47}
{"sid": "057_绛侯周勃世家.8.s3", "chapter": "057_绛侯周勃世家", "para": "8", "seq": 3, "text": "” 勃惧，亦自危，乃谢请归相印。", "len": 16}
{"sid": "057_绛侯周勃世家.8.s4", "chapter": "057_绛侯周勃世家", "para": "8", "seq": 4, "text": "上许之。", "len": 4}
{"sid": "057_绛侯周勃世家.8.s5", "chapter": "057_绛侯周勃世家", "para": "8", "seq": 5, "text": "岁馀，丞相平卒，上复以勃为丞相。", "len": 16}
{"sid": "057_绛侯周勃世家.8.s6", "chapter": "057_绛侯周勃世家", "para": "8", "seq": 6, "text": "十馀月，上曰：“前日吾诏列侯就国，或未能行，丞相吾所重，其率先之。", "len": 33}
{"sid": "057_绛侯周勃世家.8.s7", "chapter": "057_绛侯周勃世家", "para": "8", "seq": 7, "text": "” 乃免相就国。", "len": 8}
{"sid": "057_绛侯周勃世家.9.s1", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 1, "text": "岁馀，每河东守尉行县至绛，绛侯勃自畏恐诛，常被甲，令家人持兵以见之。", "len": 34}
{"sid": "057_绛侯周勃世家.9.s2", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 2, "text": "其後人有上书告勃欲反，下廷尉。", "len": 15}
{"sid": "057_绛侯周勃世家.9.s3", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 3, "text": "廷尉下其事长安，逮捕勃治之。", "len": 14}
{"sid": "057_绛侯周勃世家.9.s4", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 4, "text": "勃恐，不知置辞。", "len": 8}
{"sid": "057_绛侯周勃世家.9.s5", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 5, "text": "吏稍侵辱之。", "len": 6}
{"sid": "057_绛侯周勃世家.9.s6", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 6, "text": "勃以千金与狱吏，狱吏乃书牍背示之，曰“以公主为证”。", "len": 26}
{"sid": "057_绛侯周勃世家.9.s7", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 7, "text": "公主者，孝文帝女也，勃太子胜之尚之，故狱吏教引为证。", "len": 26}
{"sid": "057_绛侯周勃世家.9.s8", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 8, "text": "勃之益封受赐，尽以予薄昭。", "len": 13}
{"sid": "057_绛侯周勃世家.9.s9", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 9, "text": "及系急，薄昭为言薄太后，太后亦以为无反事。", "len": 21}
{"sid": "057_绛侯周勃世家.9.s10", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 10, "text": "文帝朝，太后以冒絮提文帝，曰：“绛侯绾皇帝玺，将兵於北军，不以此时反，今居一小县，顾欲反邪！", "len": 46}
{"sid": "057_绛侯周勃世家.9.s11", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 11, "text": "” 文帝既见绛侯狱辞，乃谢曰：“吏方验而出之。", "len": 23}
{"sid": "057_绛侯周勃世家.9.s12", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 12, "text": "” 於是使使持节赦绛侯，复爵邑。", "len": 16}
{"sid": "057_绛侯周勃世家.9.s13", "chapter": "057_绛侯周勃世家", "para": "9", "seq": 13, "text": "绛侯既出，曰：“吾尝将百万军，然安知狱吏之贵乎！”", "len": 25}
{"sid": "057_绛侯周勃世家.10.s1", "chapter": "057_绛侯周勃世家", "para": "10", "seq": 1, "text": "绛侯复就国。", "len": 6}
{"sid": "057_绛侯周勃世家.10.s2", "chapter": "057_绛侯周勃世家", "para": "10", "seq": 2, "text": "孝文帝十一年卒，谥为武侯。", "len": 13}
{"sid": "057_绛侯周勃世家.10.s3", "chapter": "057_绛侯周勃世家", "para": "10", "seq": 3, "text": "子胜之代侯。", "len": 6}
{"sid": "057_绛侯周勃世家.10.s4", "chapter": "057_绛侯周勃世家", "para": "10", "seq": 4, "text": "六岁，尚公主，不相中，坐杀人，国除。", "len": 18}
{"sid": "057_绛侯周勃世家.10.s5", "chapter": "057_绛侯周勃世家", "para": "10", "seq": 5, "text": "绝一岁，文帝乃择绛侯勃子贤者河内守亚夫，封为条侯，续绛侯後。", "len": 30}
{"sid": "057_绛侯周勃世家.11.s1", "chapter": "057_绛侯周勃世家", "para": "11", "seq": 1, "text": "条侯亚夫自未侯为河内守时，许负相之，曰：“君後三岁而侯。", "len": 28}
{"sid": "057_绛侯周勃世家.11.s2", "chapter": "057_绛侯周勃世家", "para": "11", "seq": 2, "text": "侯八岁为将相，持国秉，贵重矣，於人臣无两。", "len": 21}
{"sid": "057_绛侯周勃世家.11.s3", "chapter": "057_绛侯周勃世家", "para": "11", "seq": 3, "text": "其後九岁而君饿死。", "len": 9}
{"sid": "057_绛侯周勃世家.11.s4", "chapter": "057_绛侯周勃世家", "para": "11", "seq": 4, "text": "” 亚夫笑曰：“臣之兄已代父侯矣，有如卒，子当代，亚夫何说侯乎？", "len": 32}
{"sid": "057_绛侯周勃世家.11.s5", "chapter": "057_绛侯周勃世家", "para": "11", "seq": 5, "text": "然既已贵如负言，又何说饿死？", "len": 14}
{"sid": "057_绛侯周勃世家.11.s6", "chapter": "057_绛侯周勃世家", "para": "11", "seq": 6, "text": "指示我。", "len": 4}
{"sid": "057_绛侯周勃世家.11.s7", "chapter": "057_绛侯周勃世家", "para": "11", "seq": 7, "text": "” 许负指其口曰：“有从理入口，此饿死法也。", "len": 22}
{"sid": "057_绛侯周勃世家.11.s8", "chapter": "057_绛侯周勃世家", "para": "11", "seq": 8, "text": "” 居三岁，其兄绛侯胜之有罪，孝文帝择绛侯子贤者，皆推亚夫，乃封亚夫为条侯，续绛侯後。", "len": 43}
{"sid": "057_绛侯周勃世家.12.s1", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 1, "text": "文帝之後六年，匈奴大入边。", "len": 13}
{"sid": "057_绛侯周勃世家.12.s2", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 2, "text": "乃以宗正刘礼为将军，军霸上；祝兹侯徐厉为将军，军棘门；以河内守亚夫为将军，军细柳：以备胡。", "len": 45}
{"sid": "057_绛侯周勃世家.12.s3", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 3, "text": "上自劳军。", "len": 5}
{"sid": "057_绛侯周勃世家.12.s4", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 4, "text": "至霸上及棘门军，直驰入，将以下骑送迎。", "len": 19}
{"sid": "057_绛侯周勃世家.12.s5", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 5, "text": "已而之细柳军，军士吏被甲，锐兵刃，彀弓弩，持满。", "len": 24}
{"sid": "057_绛侯周勃世家.12.s6", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 6, "text": "天子先驱至，不得入。", "len": 10}
{"sid": "057_绛侯周勃世家.12.s7", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 7, "text": "先驱曰：“天子且至！", "len": 10}
{"sid": "057_绛侯周勃世家.12.s8", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 8, "text": "” 军门都尉曰：“将军令曰‘军中闻将军令，不闻天子之诏’。", "len": 29}
{"sid": "057_绛侯周勃世家.12.s9", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 9, "text": "” 居无何，上至，又不得入。", "len": 14}
{"sid": "057_绛侯周勃世家.12.s10", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 10, "text": "於是上乃使使持节诏将军：“吾欲入劳军。", "len": 19}
{"sid": "057_绛侯周勃世家.12.s11", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 11, "text": "” 亚夫乃传言开壁门。", "len": 11}
{"sid": "057_绛侯周勃世家.12.s12", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 12, "text": "壁门士吏谓从属车骑曰：“将军约，军中不得驱驰。", "len": 23}
{"sid": "057_绛侯周勃世家.12.s13", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 13, "text": "” 於是天子乃按辔徐行。", "len": 12}
{"sid": "057_绛侯周勃世家.12.s14", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 14, "text": "至营，将军亚夫持兵揖曰：“介胄之士不拜，请以军礼见。", "len": 26}
{"sid": "057_绛侯周勃世家.12.s15", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 15, "text": "” 天子为动，改容式车。", "len": 12}
{"sid": "057_绛侯周勃世家.12.s16", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 16, "text": "使人称谢：“皇帝敬劳将军。", "len": 13}
{"sid": "057_绛侯周勃世家.12.s17", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 17, "text": "” 成礼而去。", "len": 7}
{"sid": "057_绛侯周勃世家.12.s18", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 18, "text": "既出军门，群臣皆惊。", "len": 10}
{"sid": "057_绛侯周勃世家.12.s19", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 19, "text": "文帝曰：“嗟乎，此真将军矣！", "len": 14}
{"sid": "057_绛侯周勃世家.12.s20", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 20, "text": "曩者霸上、棘门军，若兒戏耳，其将固可袭而虏也。", "len": 23}
{"sid": "057_绛侯周勃世家.12.s21", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 21, "text": "至於亚夫，可得而犯邪！", "len": 11}
{"sid": "057_绛侯周勃世家.12.s22", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 22, "text": "” 称善者久之。", "len": 8}
{"sid": "057_绛侯周勃世家.12.s23", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 23, "text": "月馀，三军皆罢。", "len": 8}
{"sid": "057_绛侯周勃世家.12.s24", "chapter": "057_绛侯周勃世家", "para": "12", "seq": 24, "text": "乃拜亚夫为中尉。", "len": 8}
{"sid": "057_绛侯周勃世家.13.s1", "chapter": "057_绛侯周勃世家", "para": "13", "seq": 1, "text": "孝文且崩时，诫太子曰：“即有缓急，周亚夫真可任将兵。", "len": 26}
{"sid": "057_绛侯周勃世家.13.s2", "chapter": "057_绛侯周勃世家", "para": "13", "seq": 2, "text": "” 文帝崩，拜亚夫为车骑将军。", "len": 15}
{"sid": "057_绛侯周勃世家.14.s1", "chapter": "057_绛侯周勃世家", "para": "14", "seq": 1, "text": "孝景三年，吴楚反。", "len": 9}
{"sid": "057_绛侯周勃世家.14.s2", "chapter": "057_绛侯周勃世家", "para": "14", "seq": 2, "text": "亚夫以中尉为太尉，东击吴楚。", "len": 14}
{"sid": "057_绛侯周勃世家.14.s3", "chapter": "057_绛侯周勃世家", "para": "14", "seq": 3, "text": "因自请上曰：“楚兵剽轻，难与争锋。", "len": 17}
{"sid": "057_绛侯周勃世家.14.s4", "chapter": "057_绛侯周勃世家", "para": "14", "seq": 4, "text": "原以梁委之，绝其粮道，乃可制。", "len": 15}
{"sid": "057_绛侯周勃世家.14.s5", "chapter": "057_绛侯周勃世家", "para": "14", "seq": 5, "text": "” 上许之。", "len": 6}
{"sid": "057_绛侯周勃世家.15.s1", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 1, "text": "太尉既会兵荥阳，吴方攻梁，梁急，请救。", "len": 19}
{"sid": "057_绛侯周勃世家.15.s2", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 2, "text": "太尉引兵东北走昌邑，深壁而守。", "len": 15}
{"sid": "057_绛侯周勃世家.15.s3", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 3, "text": "梁日使使请太尉，太尉守便宜，不肯往。", "len": 18}
{"sid": "057_绛侯周勃世家.15.s4", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 4, "text": "梁上书言景帝，景帝使使诏救梁。", "len": 15}
{"sid": "057_绛侯周勃世家.15.s5", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 5, "text": "太尉不奉诏，坚壁不出，而使轻骑兵弓高侯等绝吴楚兵後食道。", "len": 28}
{"sid": "057_绛侯周勃世家.15.s6", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 6, "text": "吴兵乏粮，饥，数欲挑战，终不出。", "len": 16}
{"sid": "057_绛侯周勃世家.15.s7", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 7, "text": "夜，军中惊，内相攻击扰乱，至於太尉帐下。", "len": 20}
{"sid": "057_绛侯周勃世家.15.s8", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 8, "text": "太尉终卧不起。", "len": 7}
{"sid": "057_绛侯周勃世家.15.s9", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 9, "text": "顷之，复定。", "len": 6}
{"sid": "057_绛侯周勃世家.15.s10", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 10, "text": "後吴奔壁东南陬，太尉使备西北。", "len": 15}
{"sid": "057_绛侯周勃世家.15.s11", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 11, "text": "已而其精兵果奔西北，不得入。", "len": 14}
{"sid": "057_绛侯周勃世家.15.s12", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 12, "text": "吴兵既饿，乃引而去。", "len": 10}
{"sid": "057_绛侯周勃世家.15.s13", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 13, "text": "太尉出精兵追击，大破之。", "len": 12}
{"sid": "057_绛侯周勃世家.15.s14", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 14, "text": "吴王濞弃其军，而与壮士数千人亡走，保於江南丹徒。", "len": 24}
{"sid": "057_绛侯周勃世家.15.s15", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 15, "text": "汉兵因乘胜，遂尽虏之，降其兵，购吴王千金。", "len": 21}
{"sid": "057_绛侯周勃世家.15.s16", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 16, "text": "月馀，越人斩吴王头以告。", "len": 12}
{"sid": "057_绛侯周勃世家.15.s17", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 17, "text": "凡相攻守三月，而吴楚破平。", "len": 13}
{"sid": "057_绛侯周勃世家.15.s18", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 18, "text": "於是诸将乃以太尉计谋为是。", "len": 13}
{"sid": "057_绛侯周勃世家.15.s19", "chapter": "057_绛侯周勃世家", "para": "15", "seq": 19, "text": "由此梁孝王与太尉有卻。", "len": 11}
{"sid": "057_绛侯周勃世家.16.s1", "chapter": "057_绛侯周勃世家", "para": "16", "seq": 1, "text": "归，复置太尉官。", "len": 8}
{"sid": "057_绛侯周勃世家.16.s2", "chapter": "057_绛侯周勃世家", "para": "16", "seq": 2, "text": "五岁，迁为丞相，景帝甚重之。", "len": 14}
{"sid": "057_绛侯周勃世家.16.s3", "chapter": "057_绛侯周勃世家", "para": "16", "seq": 3, "text": "景帝废栗太子，丞相固争之，不得。", "len": 16}
{"sid": "057_绛侯周勃世家.16.s4", "chapter": "057_绛侯周勃世家", "para": "16", "seq": 4, "text": "景帝由此疏之。", "len": 7}
{"sid": "057_绛侯周勃世家.16.s5", "chapter": "057_绛侯周勃世家", "para": "16", "seq": 5, "text": "而梁孝王每朝，常与太后言条侯之短。", "len": 17}
{"sid": "057_绛侯周勃世家.17.s1", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 1, "text": "窦太后曰：“皇后兄王信可侯也。", "len": 15}
{"sid": "057_绛侯周勃世家.17.s2", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 2, "text": "” 景帝让曰：“始南皮、章武侯先帝不侯，及臣即位乃侯之。", "len": 28}
{"sid": "057_绛侯周勃世家.17.s3", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 3, "text": "信未得封也。", "len": 6}
{"sid": "057_绛侯周勃世家.17.s4", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 4, "text": "” 窦太后曰：“人主各以时行耳。", "len": 16}
{"sid": "057_绛侯周勃世家.17.s5", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 5, "text": "自窦长君在时，竟不得侯，死後乃其子彭祖顾得侯。", "len": 23}
{"sid": "057_绛侯周勃世家.17.s6", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 6, "text": "吾甚恨之。", "len": 5}
{"sid": "057_绛侯周勃世家.17.s7", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 7, "text": "帝趣侯信也！", "len": 6}
{"sid": "057_绛侯周勃世家.17.s8", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 8, "text": "” 景帝曰：“请得与丞相议之。", "len": 15}
{"sid": "057_绛侯周勃世家.17.s9", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 9, "text": "” 丞相议之，亚夫曰：“高皇帝约‘非刘氏不得王，非有功不得侯。", "len": 31}
{"sid": "057_绛侯周勃世家.17.s10", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 10, "text": "不如约，天下共击之’。", "len": 11}
{"sid": "057_绛侯周勃世家.17.s11", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 11, "text": "今信虽皇后兄，无功，侯之，非约也。", "len": 17}
{"sid": "057_绛侯周勃世家.17.s12", "chapter": "057_绛侯周勃世家", "para": "17", "seq": 12, "text": "” 景帝默然而止。", "len": 9}
{"sid": "057_绛侯周勃世家.18.s1", "chapter": "057_绛侯周勃世家", "para": "18", "seq": 1, "text": "其後匈奴王徐卢等五人降，景帝欲侯之以劝後。", "len": 21}
{"sid": "057_绛侯周勃世家.18.s2", "chapter": "057_绛侯周勃世家", "para": "18", "seq": 2, "text": "丞相亚夫曰：“彼背其主降陛下，陛下侯之，则何以责人臣不守节者乎？", "len": 32}
{"sid": "057_绛侯周勃世家.18.s3", "chapter": "057_绛侯周勃世家", "para": "18", "seq": 3, "text": "” 景帝曰：“丞相议不可用。", "len": 14}
{"sid": "057_绛侯周勃世家.18.s4", "chapter": "057_绛侯周勃世家", "para": "18", "seq": 4, "text": "” 乃悉封徐卢等为列侯。", "len": 12}
{"sid": "057_绛侯周勃世家.18.s5", "chapter": "057_绛侯周勃世家", "para": "18", "seq": 5, "text": "亚夫因谢病。", "len": 6}
{"sid": "057_绛侯周勃世家.18.s6", "chapter": "057_绛侯周勃世家", "para": "18", "seq": 6, "text": "景帝中三年，以病免相。", "len": 11}
{"sid": "057_绛侯周勃世家.19.s1", "chapter": "057_绛侯周勃世家", "para": "19", "seq": 1, "text": "顷之，景帝居禁中，召条侯，赐食。", "len": 16}
{"sid": "057_绛侯周勃世家.19.s2", "chapter": "057_绛侯周勃世家", "para": "19", "seq": 2, "text": "独置大胾，无切肉，又不置櫡。", "len": 14}
{"sid": "057_绛侯周勃世家.19.s3", "chapter": "057_绛侯周勃世家", "para": "19", "seq": 3, "text": "条侯心不平，顾谓尚席取櫡。", "len": 13}
{"sid": "057_绛侯周勃世家.19.s4", "chapter": "057_绛侯周勃世家", "para": "19", "seq": 4, "text": "景帝视而笑曰：“此不足君所乎？", "len": 15}
{"sid": "057_绛侯周勃世家.19.s5", "chapter": "057_绛侯周勃世家", "para": "19", "seq": 5, "text": "” 条侯免冠谢。", "len": 8}
{"sid": "057_绛侯周勃世家.19.s6", "chapter": "057_绛侯周勃世家", "para": "19", "seq": 6, "text": "上起，条侯因趋出。", "len": 9}
{"sid": "057_绛侯周勃世家.19.s7", "chapter": "057_绛侯周勃世家", "para": "19", "seq": 7, "text": "景帝以目送之，曰：“此怏怏者非少主臣也！”", "len": 21}
{"sid": "057_绛侯周勃世家.20.s1", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 1, "text": "居无何，条侯子为父买工官尚方甲楯五百被可以葬者。", "len": 24}
{"sid": "057_绛侯周勃世家.20.s2", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 2, "text": "取庸苦之，不予钱。", "len": 9}
{"sid": "057_绛侯周勃世家.20.s3", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 3, "text": "庸知其盗买县官器，怒而上变告子，事连汙条侯。", "len": 22}
{"sid": "057_绛侯周勃世家.20.s4", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 4, "text": "书既闻上，上下吏。", "len": 9}
{"sid": "057_绛侯周勃世家.20.s5", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 5, "text": "吏簿责条侯，条侯不对。", "len": 11}
{"sid": "057_绛侯周勃世家.20.s6", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 6, "text": "景帝骂之曰：“吾不用也。", "len": 12}
{"sid": "057_绛侯周勃世家.20.s7", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 7, "text": "” 召诣廷尉。", "len": 7}
{"sid": "057_绛侯周勃世家.20.s8", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 8, "text": "廷尉责曰：“君侯欲反邪？", "len": 12}
{"sid": "057_绛侯周勃世家.20.s9", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 9, "text": "” 亚夫曰：“臣所买器，乃葬器也，何谓反邪？", "len": 22}
{"sid": "057_绛侯周勃世家.20.s10", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 10, "text": "” 吏曰：“君侯纵不反地上，即欲反地下耳。", "len": 21}
{"sid": "057_绛侯周勃世家.20.s11", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 11, "text": "” 吏侵之益急。", "len": 8}
{"sid": "057_绛侯周勃世家.20.s12", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 12, "text": "初，吏捕条侯，条侯欲自杀，夫人止之，以故不得死，遂入廷尉。", "len": 29}
{"sid": "057_绛侯周勃世家.20.s13", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 13, "text": "因不食五日，呕血而死。", "len": 11}
{"sid": "057_绛侯周勃世家.20.s14", "chapter": "057_绛侯周勃世家", "para": "20", "seq": 14, "text": "国除。", "len": 3}
{"sid": "057_绛侯周勃世家.21.s1", "chapter": "057_绛侯周勃世家", "para": "21", "seq": 1, "text": "绝一岁，景帝乃更封绛侯勃他子坚为平曲侯，续绛侯後。", "len": 25}
{"sid": "057_绛侯周勃世家.21.s2", "chapter": "057_绛侯周勃世家", "para": "21", "seq": 2, "text": "十九年卒，谥为共侯。", "len": 10}
{"sid": "057_绛侯周勃世家.21.s3", "chapter": "057_绛侯周勃世家", "para": "21", "seq": 3, "text": "子建德代侯，十三年，为太子太傅。", "len": 16}
{"sid": "057_绛侯周勃世家.21.s4", "chapter": "057_绛侯周勃世家", "para": "21", "seq": 4, "text": "坐酎金不善，元鼎五年，有罪，国除。", "len": 17}
{"sid": "057_绛侯周勃世家.22.s1", "chapter": "057_绛侯周勃世家", "para": "22", "seq": 1, "text": "条侯果饿死。", "len": 6}
{"sid": "057_绛侯周勃世家.22.s2", "chapter": "057_绛侯周勃世家", "para": "22", "seq": 2, "text": "死後，景帝乃封王信为盖侯。", "len": 13}
{"sid": "057_绛侯周勃世家.22.s3", "chapter": "057_绛侯周勃世家", "para": "22", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "057_绛侯周勃世家.23.s1", "chapter": "057_绛侯周勃世家", "para": "23", "seq": 1, "text": "太史公曰：绛侯周勃始为布衣时，鄙朴人也，才能不过凡庸。", "len": 27}
{"sid": "057_绛侯周勃世家.23.s2", "chapter": "057_绛侯周勃世家", "para": "23", "seq": 2, "text": "及从高祖定天下，在将相位，诸吕欲作乱，勃匡国家难，复之乎正。", "len": 30}
{"sid": "057_绛侯周勃世家.23.s3", "chapter": "057_绛侯周勃世家", "para": "23", "seq": 3, "text": "虽伊尹、周公，何以加哉！", "len": 12}
{"sid": "057_绛侯周勃世家.23.s4", "chapter": "057_绛侯周勃世家", "para": "23", "seq": 4, "text": "亚夫之用兵，持威重，执坚刃，穰苴曷有加焉！", "len": 21}
{"sid": "057_绛侯周勃世家.23.s5", "chapter": "057_绛侯周勃世家", "para": "23", "seq": 5, "text": "足己而不学，守节不逊，终以穷困。", "len": 16}
{"sid": "057_绛侯周勃世家.23.s6", "chapter": "057_绛侯周勃世家", "para": "23", "seq": 6, "text": "悲夫！", "len": 3}
{"sid": "057_绛侯周勃世家.23.s7", "chapter": "057_绛侯周勃世家", "para": "23", "seq": 7, "text": "::: ::: 赞", "len": 9}
{"sid": "057_绛侯周勃世家.24.s1", "chapter": "057_绛侯周勃世家", "para": "24", "seq": 1, "text": "绛侯佐汉，质厚敦笃。", "len": 10}
{"sid": "057_绛侯周勃世家.24.s2", "chapter": "057_绛侯周勃世家", "para": "24", "seq": 2, "text": "始击砀东，亦围尸北。", "len": 10}
{"sid": "057_绛侯周勃世家.24.s3", "chapter": "057_绛侯周勃世家", "para": "24", "seq": 3, "text": "所攻必取，所讨咸克。", "len": 10}
{"sid": "057_绛侯周勃世家.24.s4", "chapter": "057_绛侯周勃世家", "para": "24", "seq": 4, "text": "陈豨伏诛，臧荼破国。", "len": 10}
{"sid": "057_绛侯周勃世家.24.s5", "chapter": "057_绛侯周勃世家", "para": "24", "seq": 5, "text": "事居送往，推功伏德。", "len": 10}
{"sid": "057_绛侯周勃世家.24.s6", "chapter": "057_绛侯周勃世家", "para": "24", "seq": 6, "text": "列侯还第，太尉下狱。", "len": 10}
{"sid": "057_绛侯周勃世家.24.s7", "chapter": "057_绛侯周勃世家", "para": "24", "seq": 7, "text": "继相条侯，绍封平曲。", "len": 10}
{"sid": "057_绛侯周勃世家.24.s8", "chapter": "057_绛侯周勃世家", "para": "24", "seq": 8, "text": "惜哉贤将，父子代辱！", "len": 10}
{"sid": "057_绛侯周勃世家.24.s9", "chapter": "057_绛侯周勃世家", "para": "24", "seq": 9, "text": ":::", "len": 3}
