{"sid": "087_李斯列传.1.1.s1", "chapter": "087_李斯列传", "para": "1.1", "seq": 1, "text": "李斯者，楚上蔡人也。", "len": 10}
{"sid": "087_李斯列传.1.1.s2", "chapter": "087_李斯列传", "para": "1.1", "seq": 2, "text": "年少时，为郡小吏，见吏舍厕中鼠食不絜，近人犬，数惊恐之。", "len": 28}
{"sid": "087_李斯列传.1.1.s3", "chapter": "087_李斯列传", "para": "1.1", "seq": 3, "text": "斯入仓，观仓中鼠，食积粟，居大庑之下，不见人犬之忧。", "len": 26}
{"sid": "087_李斯列传.1.1.s4", "chapter": "087_李斯列传", "para": "1.1", "seq": 4, "text": "於是李斯乃叹曰：“人之贤不肖譬如鼠矣，在所自处耳！”", "len": 26}
{"sid": "087_李斯列传.2.1.s1", "chapter": "087_李斯列传", "para": "2.1", "seq": 1, "text": "乃从荀卿学帝王之术。", "len": 10}
{"sid": "087_李斯列传.2.1.s2", "chapter": "087_李斯列传", "para": "2.1", "seq": 2, "text": "学已成，度楚王不足事，而六国皆弱，无可为建功者，欲西入秦。", "len": 29}
{"sid": "087_李斯列传.2.1.s3", "chapter": "087_李斯列传", "para": "2.1", "seq": 3, "text": "辞於荀卿曰：“斯闻得时无怠，今万乘方争时，游者主事。", "len": 26}
{"sid": "087_李斯列传.2.1.s4", "chapter": "087_李斯列传", "para": "2.1", "seq": 4, "text": "今秦王欲吞天下，称帝而治，此布衣驰骛之时而游说者之秋也。", "len": 28}
{"sid": "087_李斯列传.2.1.s5", "chapter": "087_李斯列传", "para": "2.1", "seq": 5, "text": "处卑贱之位而计不为者，此禽鹿视肉，人面而能彊行者耳。", "len": 26}
{"sid": "087_李斯列传.2.1.s6", "chapter": "087_李斯列传", "para": "2.1", "seq": 6, "text": "故诟莫大於卑贱，而悲莫甚於穷困。", "len": 16}
{"sid": "087_李斯列传.2.1.s7", "chapter": "087_李斯列传", "para": "2.1", "seq": 7, "text": "久处卑贱之位，困苦之地，非世而恶利，自讬於无为，此非士之情也。", "len": 31}
{"sid": "087_李斯列传.2.1.s8", "chapter": "087_李斯列传", "para": "2.1", "seq": 8, "text": "故斯将西说秦王矣。”", "len": 10}
{"sid": "087_李斯列传.3.1.s1", "chapter": "087_李斯列传", "para": "3.1", "seq": 1, "text": "至秦，会庄襄王卒，李斯乃求为秦相文信侯吕不韦舍人；不韦贤之，任以为郎。", "len": 35}
{"sid": "087_李斯列传.3.1.s2", "chapter": "087_李斯列传", "para": "3.1", "seq": 2, "text": "李斯因以得说，说秦王曰：“胥人者，去其几也。", "len": 22}
{"sid": "087_李斯列传.3.1.s3", "chapter": "087_李斯列传", "para": "3.1", "seq": 3, "text": "成大功者，在因瑕衅而遂忍之。", "len": 14}
{"sid": "087_李斯列传.3.1.s4", "chapter": "087_李斯列传", "para": "3.1", "seq": 4, "text": "昔者秦穆公之霸，终不东并六国者，何也？", "len": 19}
{"sid": "087_李斯列传.3.1.s5", "chapter": "087_李斯列传", "para": "3.1", "seq": 5, "text": "诸侯尚众，周德未衰，故五伯迭兴，更尊周室。", "len": 21}
{"sid": "087_李斯列传.3.1.s6", "chapter": "087_李斯列传", "para": "3.1", "seq": 6, "text": "自秦孝公以来，周室卑微，诸侯相兼，关东为六国，秦之乘胜役诸侯，盖六世矣。", "len": 36}
{"sid": "087_李斯列传.3.1.s7", "chapter": "087_李斯列传", "para": "3.1", "seq": 7, "text": "今诸侯服秦，譬若郡县。", "len": 11}
{"sid": "087_李斯列传.3.1.s8", "chapter": "087_李斯列传", "para": "3.1", "seq": 8, "text": "夫以秦之彊，大王之贤，由灶上骚除，足以灭诸侯，成帝业，为天下一统，此万世之一时也。", "len": 41}
{"sid": "087_李斯列传.3.1.s9", "chapter": "087_李斯列传", "para": "3.1", "seq": 9, "text": "今怠而不急就，诸侯复彊，相聚约从，虽有黄帝之贤，不能并也。", "len": 29}
{"sid": "087_李斯列传.3.1.s10", "chapter": "087_李斯列传", "para": "3.1", "seq": 10, "text": "” 秦王乃拜斯为长史，听其计，阴遣谋士赍持金玉以游说诸侯。", "len": 29}
{"sid": "087_李斯列传.3.1.s11", "chapter": "087_李斯列传", "para": "3.1", "seq": 11, "text": "诸侯名士可下以财者，厚遗结之；不肯者，利剑刺之。", "len": 24}
{"sid": "087_李斯列传.3.1.s12", "chapter": "087_李斯列传", "para": "3.1", "seq": 12, "text": "离其君臣之计，秦王乃使其良将随其後。", "len": 18}
{"sid": "087_李斯列传.3.1.s13", "chapter": "087_李斯列传", "para": "3.1", "seq": 13, "text": "秦王拜斯为客卿。", "len": 8}
{"sid": "087_李斯列传.4.1.s1", "chapter": "087_李斯列传", "para": "4.1", "seq": 1, "text": "会韩人郑国来间秦，以作注溉渠，已而觉。", "len": 19}
{"sid": "087_李斯列传.4.1.s2", "chapter": "087_李斯列传", "para": "4.1", "seq": 2, "text": "秦宗室大臣皆言秦王曰：“诸侯人来事秦者，大抵为其主游间於秦耳，请一切逐客。", "len": 37}
{"sid": "087_李斯列传.4.1.s3", "chapter": "087_李斯列传", "para": "4.1", "seq": 3, "text": "” 李斯议亦在逐中。", "len": 10}
{"sid": "087_李斯列传.4.1.s4", "chapter": "087_李斯列传", "para": "4.1", "seq": 4, "text": "斯乃上书曰：", "len": 6}
{"sid": "087_李斯列传.4.2.s1", "chapter": "087_李斯列传", "para": "4.2", "seq": 1, "text": "臣闻吏议逐客，窃以为过矣。", "len": 13}
{"sid": "087_李斯列传.4.2.s2", "chapter": "087_李斯列传", "para": "4.2", "seq": 2, "text": "昔缪公求士，西取由余於戎，东得百里奚於宛，迎蹇叔於宋，来丕豹、公孙支於晋。", "len": 37}
{"sid": "087_李斯列传.4.2.s3", "chapter": "087_李斯列传", "para": "4.2", "seq": 3, "text": "此五子者，不产於秦，而缪公用之，并国二十，遂霸西戎。", "len": 26}
{"sid": "087_李斯列传.4.2.s4", "chapter": "087_李斯列传", "para": "4.2", "seq": 4, "text": "孝公用商鞅之法，移风易俗，民以殷盛，国以富彊，百姓乐用，诸侯亲服，获楚、魏之师，举地千里，至今治彊。", "len": 50}
{"sid": "087_李斯列传.4.2.s5", "chapter": "087_李斯列传", "para": "4.2", "seq": 5, "text": "惠王用张仪之计，拔三川之地，西并巴、蜀，北收上郡，南取汉中，包九夷，制鄢、郢，东据成皋之险，割膏腴之壤，遂散六国之从，使之西面事秦，功施到今。", "len": 71}
{"sid": "087_李斯列传.4.2.s6", "chapter": "087_李斯列传", "para": "4.2", "seq": 6, "text": "昭王得范睢，废穰侯，逐华阳，彊公室，杜私门，蚕食诸侯，使秦成帝业。", "len": 33}
{"sid": "087_李斯列传.4.2.s7", "chapter": "087_李斯列传", "para": "4.2", "seq": 7, "text": "此四君者，皆以客之功。", "len": 11}
{"sid": "087_李斯列传.4.2.s8", "chapter": "087_李斯列传", "para": "4.2", "seq": 8, "text": "由此观之，客何负於秦哉！", "len": 12}
{"sid": "087_李斯列传.4.2.s9", "chapter": "087_李斯列传", "para": "4.2", "seq": 9, "text": "向使四君卻客而不内，疏士而不用，是使国无富利之实而秦无彊大之名也。", "len": 33}
{"sid": "087_李斯列传.4.3.s1", "chapter": "087_李斯列传", "para": "4.3", "seq": 1, "text": "今陛下致昆山之玉，有随、和之宝，垂明月之珠，服太阿之剑，乘纤离之马，建翠凤之旗，树灵鼍之鼓。", "len": 46}
{"sid": "087_李斯列传.4.3.s2", "chapter": "087_李斯列传", "para": "4.3", "seq": 2, "text": "此数宝者，秦不生一焉，而陛下说之，何也？", "len": 20}
{"sid": "087_李斯列传.4.3.s3", "chapter": "087_李斯列传", "para": "4.3", "seq": 3, "text": "必秦国之所生然後可，则是夜光之璧不饰朝廷，犀象之器不为玩好，郑、卫之女不充後宫，而骏良駃騠不实外厩，江南金锡不为用，西蜀丹青不为采。", "len": 66}
{"sid": "087_李斯列传.4.3.s4", "chapter": "087_李斯列传", "para": "4.3", "seq": 4, "text": "所以饰後宫充下陈娱心意说耳目者，必出於秦然後可，则是宛珠之簪，傅玑之珥，阿缟之衣，锦绣之饰不进於前，而随俗雅化佳冶窈窕赵女不立於侧也。", "len": 67}
{"sid": "087_李斯列传.4.3.s5", "chapter": "087_李斯列传", "para": "4.3", "seq": 5, "text": "夫击甕叩缶弹筝搏髀，而歌呼呜呜快耳者，真秦之声也；郑、卫、桑间、昭、虞、武、象者，异国之乐也。", "len": 47}
{"sid": "087_李斯列传.4.3.s6", "chapter": "087_李斯列传", "para": "4.3", "seq": 6, "text": "今弃击甕叩缶而就郑卫，退弹筝而取昭虞，若是者何也？", "len": 25}
{"sid": "087_李斯列传.4.3.s7", "chapter": "087_李斯列传", "para": "4.3", "seq": 7, "text": "快意当前，適观而已矣。", "len": 11}
{"sid": "087_李斯列传.4.3.s8", "chapter": "087_李斯列传", "para": "4.3", "seq": 8, "text": "今取人则不然。", "len": 7}
{"sid": "087_李斯列传.4.3.s9", "chapter": "087_李斯列传", "para": "4.3", "seq": 9, "text": "不问可否，不论曲直，非秦者去，为客者逐。", "len": 20}
{"sid": "087_李斯列传.4.3.s10", "chapter": "087_李斯列传", "para": "4.3", "seq": 10, "text": "然则是所重者在乎色乐珠玉，而所轻者在乎人民也。", "len": 23}
{"sid": "087_李斯列传.4.3.s11", "chapter": "087_李斯列传", "para": "4.3", "seq": 11, "text": "此非所以跨海内制诸侯之术也。", "len": 14}
{"sid": "087_李斯列传.4.4.s1", "chapter": "087_李斯列传", "para": "4.4", "seq": 1, "text": "臣闻地广者粟多，国大者人众，兵彊则士勇。", "len": 20}
{"sid": "087_李斯列传.4.4.s2", "chapter": "087_李斯列传", "para": "4.4", "seq": 2, "text": "是以太山不让土壤，故能成其大；河海不择细流，故能就其深；王者不卻众庶，故能明其德。", "len": 41}
{"sid": "087_李斯列传.4.4.s3", "chapter": "087_李斯列传", "para": "4.4", "seq": 3, "text": "是以地无四方，民无异国，四时充美，鬼神降福，此五帝、三王之所以无敌也。", "len": 35}
{"sid": "087_李斯列传.4.4.s4", "chapter": "087_李斯列传", "para": "4.4", "seq": 4, "text": "今乃弃黔首以资敌国，卻宾客以业诸侯，使天下之士退而不敢西向，裹足不入秦，此所谓“藉寇兵而赍盗粮” 者也。", "len": 52}
{"sid": "087_李斯列传.5.s1", "chapter": "087_李斯列传", "para": "5", "seq": 1, "text": "夫物不产於秦，可宝者多；士不产於秦，而原忠者众。", "len": 24}
{"sid": "087_李斯列传.5.s2", "chapter": "087_李斯列传", "para": "5", "seq": 2, "text": "今逐客以资敌国，损民以益雠，内自虚而外树怨於诸侯，求国无危，不可得也。", "len": 35}
{"sid": "087_李斯列传.5.1.s1", "chapter": "087_李斯列传", "para": "5.1", "seq": 1, "text": "秦王乃除逐客之令，复李斯官，卒用其计谋。", "len": 20}
{"sid": "087_李斯列传.5.1.s2", "chapter": "087_李斯列传", "para": "5.1", "seq": 2, "text": "官至廷尉。", "len": 5}
{"sid": "087_李斯列传.5.1.s3", "chapter": "087_李斯列传", "para": "5.1", "seq": 3, "text": "二十馀年，竟并天下，尊主为皇帝，以斯为丞相。", "len": 22}
{"sid": "087_李斯列传.5.1.s4", "chapter": "087_李斯列传", "para": "5.1", "seq": 4, "text": "夷郡县城，销其兵刃，示不复用。", "len": 15}
{"sid": "087_李斯列传.5.1.s5", "chapter": "087_李斯列传", "para": "5.1", "seq": 5, "text": "使秦无尺土之封，不立子弟为王，功臣为诸侯者，使後无战攻之患。", "len": 30}
{"sid": "087_李斯列传.6.1.s1", "chapter": "087_李斯列传", "para": "6.1", "seq": 1, "text": "始皇三十四年，置酒咸阳宫，博士仆射周青臣等颂始皇威德。", "len": 27}
{"sid": "087_李斯列传.6.1.s2", "chapter": "087_李斯列传", "para": "6.1", "seq": 2, "text": "齐人淳于越进谏曰：“臣闻之，殷周之王千馀岁，封子弟功臣自为支辅。", "len": 32}
{"sid": "087_李斯列传.6.1.s3", "chapter": "087_李斯列传", "para": "6.1", "seq": 3, "text": "今陛下有海内，而子弟为匹夫，卒有田常、六卿之患，臣无辅弼，何以相救哉？", "len": 35}
{"sid": "087_李斯列传.6.1.s4", "chapter": "087_李斯列传", "para": "6.1", "seq": 4, "text": "事不师古而能长久者，非所闻也。", "len": 15}
{"sid": "087_李斯列传.6.1.s5", "chapter": "087_李斯列传", "para": "6.1", "seq": 5, "text": "今青臣等又面谀以重陛下过，非忠臣也。", "len": 18}
{"sid": "087_李斯列传.6.1.s6", "chapter": "087_李斯列传", "para": "6.1", "seq": 6, "text": "” 始皇下其议丞相。", "len": 10}
{"sid": "087_李斯列传.6.2.s1", "chapter": "087_李斯列传", "para": "6.2", "seq": 1, "text": "丞相谬其说，绌其辞，乃上书曰：“古者天下散乱，莫能相一，是以诸侯并作，语皆道古以害今，饰虚言以乱实，人善其所私学，以非上所建立。", "len": 64}
{"sid": "087_李斯列传.6.2.s2", "chapter": "087_李斯列传", "para": "6.2", "seq": 2, "text": "今陛下并有天下，别白黑而定一尊；而私学乃相与非法教之制，闻令下，即各以其私学议之，入则心非，出则巷议，非主以为名，异趣以为高，率群下以造谤。", "len": 70}
{"sid": "087_李斯列传.6.2.s3", "chapter": "087_李斯列传", "para": "6.2", "seq": 3, "text": "如此不禁，则主势降乎上，党与成乎下。", "len": 18}
{"sid": "087_李斯列传.6.2.s4", "chapter": "087_李斯列传", "para": "6.2", "seq": 4, "text": "禁之便。", "len": 4}
{"sid": "087_李斯列传.6.2.s5", "chapter": "087_李斯列传", "para": "6.2", "seq": 5, "text": "臣请诸有文学诗书百家语者，蠲除去之。", "len": 18}
{"sid": "087_李斯列传.6.2.s6", "chapter": "087_李斯列传", "para": "6.2", "seq": 6, "text": "令到满三十日弗去，黥为城旦。", "len": 14}
{"sid": "087_李斯列传.6.2.s7", "chapter": "087_李斯列传", "para": "6.2", "seq": 7, "text": "所不去者，医药卜筮种树之书。", "len": 14}
{"sid": "087_李斯列传.6.2.s8", "chapter": "087_李斯列传", "para": "6.2", "seq": 8, "text": "若有欲学者，以吏为师。", "len": 11}
{"sid": "087_李斯列传.6.2.s9", "chapter": "087_李斯列传", "para": "6.2", "seq": 9, "text": "” 始皇可其议，收去诗书百家之语以愚百姓，使天下无以古非今。", "len": 30}
{"sid": "087_李斯列传.6.2.s10", "chapter": "087_李斯列传", "para": "6.2", "seq": 10, "text": "明法度，定律令，皆以始皇起。", "len": 14}
{"sid": "087_李斯列传.6.2.s11", "chapter": "087_李斯列传", "para": "6.2", "seq": 11, "text": "同文书。", "len": 4}
{"sid": "087_李斯列传.6.2.s12", "chapter": "087_李斯列传", "para": "6.2", "seq": 12, "text": "治离宫别馆，周遍天下。", "len": 11}
{"sid": "087_李斯列传.6.2.s13", "chapter": "087_李斯列传", "para": "6.2", "seq": 13, "text": "明年，又巡狩，外攘四夷，斯皆有力焉。", "len": 18}
{"sid": "087_李斯列传.7.1.s1", "chapter": "087_李斯列传", "para": "7.1", "seq": 1, "text": "斯长男由为三川守，诸男皆尚秦公主，女悉嫁秦诸公子。", "len": 25}
{"sid": "087_李斯列传.7.1.s2", "chapter": "087_李斯列传", "para": "7.1", "seq": 2, "text": "三川守李由告归咸阳，李斯置酒於家，百官长皆前为寿，门廷车骑以千数。", "len": 33}
{"sid": "087_李斯列传.7.1.s3", "chapter": "087_李斯列传", "para": "7.1", "seq": 3, "text": "李斯喟然而叹曰：“嗟乎！", "len": 12}
{"sid": "087_李斯列传.7.1.s4", "chapter": "087_李斯列传", "para": "7.1", "seq": 4, "text": "吾闻之荀卿曰’物禁大盛’。", "len": 13}
{"sid": "087_李斯列传.7.1.s5", "chapter": "087_李斯列传", "para": "7.1", "seq": 5, "text": "夫斯乃上蔡布衣，闾巷之黔首，上不知其驽下，遂擢至此。", "len": 26}
{"sid": "087_李斯列传.7.1.s6", "chapter": "087_李斯列传", "para": "7.1", "seq": 6, "text": "当今人臣之位无居臣上者，可谓富贵极矣。", "len": 19}
{"sid": "087_李斯列传.7.1.s7", "chapter": "087_李斯列传", "para": "7.1", "seq": 7, "text": "物极则衰，吾未知所税驾也！”", "len": 14}
{"sid": "087_李斯列传.8.1.s1", "chapter": "087_李斯列传", "para": "8.1", "seq": 1, "text": "始皇三十七年十月，行出游会稽，并海上，北抵琅邪。", "len": 24}
{"sid": "087_李斯列传.8.1.s2", "chapter": "087_李斯列传", "para": "8.1", "seq": 2, "text": "丞相斯、中车府令赵高兼行符玺令事，皆从。", "len": 20}
{"sid": "087_李斯列传.8.1.s3", "chapter": "087_李斯列传", "para": "8.1", "seq": 3, "text": "始皇有二十馀子，长子扶苏以数直谏上，上使监兵上郡，蒙恬为将。", "len": 30}
{"sid": "087_李斯列传.8.1.s4", "chapter": "087_李斯列传", "para": "8.1", "seq": 4, "text": "少子胡亥爱，请从，上许之。", "len": 13}
{"sid": "087_李斯列传.8.1.s5", "chapter": "087_李斯列传", "para": "8.1", "seq": 5, "text": "馀子莫从。", "len": 5}
{"sid": "087_李斯列传.8.2.s1", "chapter": "087_李斯列传", "para": "8.2", "seq": 1, "text": "其年七月，始皇帝至沙丘，病甚，令赵高为书赐公子扶苏曰：“以兵属蒙恬，与丧会咸阳而葬。", "len": 42}
{"sid": "087_李斯列传.8.2.s2", "chapter": "087_李斯列传", "para": "8.2", "seq": 2, "text": "” 书已封，未授使者，始皇崩。", "len": 15}
{"sid": "087_李斯列传.8.2.s3", "chapter": "087_李斯列传", "para": "8.2", "seq": 3, "text": "书及玺皆在赵高所，独子胡亥、丞相李斯、赵高及幸宦者五六人知始皇崩，馀群臣皆莫知也。", "len": 41}
{"sid": "087_李斯列传.8.2.s4", "chapter": "087_李斯列传", "para": "8.2", "seq": 4, "text": "李斯以为上在外崩，无真太子，故祕之。", "len": 18}
{"sid": "087_李斯列传.8.2.s5", "chapter": "087_李斯列传", "para": "8.2", "seq": 5, "text": "置始皇居辒辌车中，百官奏事上食如故，宦者辄从辒辌车中可诸奏事。", "len": 31}
{"sid": "087_李斯列传.9.1.s1", "chapter": "087_李斯列传", "para": "9.1", "seq": 1, "text": "赵高因留所赐扶苏玺书，而谓公子胡亥曰：“上崩，无诏封王诸子而独赐长子书。", "len": 36}
{"sid": "087_李斯列传.9.1.s2", "chapter": "087_李斯列传", "para": "9.1", "seq": 2, "text": "长子至，即立为皇帝，而子无尺寸之地，为之柰何？", "len": 23}
{"sid": "087_李斯列传.9.1.s3", "chapter": "087_李斯列传", "para": "9.1", "seq": 3, "text": "” 胡亥曰：“固也。", "len": 10}
{"sid": "087_李斯列传.9.1.s4", "chapter": "087_李斯列传", "para": "9.1", "seq": 4, "text": "吾闻之，明君知臣，明父知子。", "len": 14}
{"sid": "087_李斯列传.9.1.s5", "chapter": "087_李斯列传", "para": "9.1", "seq": 5, "text": "父捐命，不封诸子，何可言者！", "len": 14}
{"sid": "087_李斯列传.9.1.s6", "chapter": "087_李斯列传", "para": "9.1", "seq": 6, "text": "” 赵高曰：“不然。", "len": 10}
{"sid": "087_李斯列传.9.1.s7", "chapter": "087_李斯列传", "para": "9.1", "seq": 7, "text": "方今天下之权，存亡在子与高及丞相耳，原子图之。", "len": 23}
{"sid": "087_李斯列传.9.1.s8", "chapter": "087_李斯列传", "para": "9.1", "seq": 8, "text": "且夫臣人与见臣於人，制人与见制於人，岂可同日道哉！", "len": 25}
{"sid": "087_李斯列传.9.1.s9", "chapter": "087_李斯列传", "para": "9.1", "seq": 9, "text": "” 胡亥曰：“废兄而立弟，是不义也；不奉父诏而畏死，是不孝也；能薄而材譾，彊因人之功，是不能也：三者逆德，天下不服，身殆倾危，社稷不血食。”", "len": 70}
{"sid": "087_李斯列传.9.2.s1", "chapter": "087_李斯列传", "para": "9.2", "seq": 1, "text": "高曰：“臣闻汤、武杀其主，天下称义焉，不为不忠。", "len": 24}
{"sid": "087_李斯列传.9.2.s2", "chapter": "087_李斯列传", "para": "9.2", "seq": 2, "text": "卫君杀其父，而卫国载其德，孔子著之，不为不孝。", "len": 23}
{"sid": "087_李斯列传.9.2.s3", "chapter": "087_李斯列传", "para": "9.2", "seq": 3, "text": "夫大行不小谨，盛德不辞让，乡曲各有宜而百官不同功。", "len": 25}
{"sid": "087_李斯列传.9.2.s4", "chapter": "087_李斯列传", "para": "9.2", "seq": 4, "text": "故顾小而忘大，後必有害；狐疑犹豫，後必有悔。", "len": 22}
{"sid": "087_李斯列传.9.2.s5", "chapter": "087_李斯列传", "para": "9.2", "seq": 5, "text": "断而敢行，鬼神避之，後有成功。", "len": 15}
{"sid": "087_李斯列传.9.2.s6", "chapter": "087_李斯列传", "para": "9.2", "seq": 6, "text": "原子遂之！", "len": 5}
{"sid": "087_李斯列传.9.2.s7", "chapter": "087_李斯列传", "para": "9.2", "seq": 7, "text": "” 胡亥喟然叹曰：“今大行未发，丧礼未终，岂宜以此事干丞相哉！", "len": 31}
{"sid": "087_李斯列传.9.2.s8", "chapter": "087_李斯列传", "para": "9.2", "seq": 8, "text": "” 赵高曰：“时乎时乎，间不及谋！", "len": 17}
{"sid": "087_李斯列传.9.2.s9", "chapter": "087_李斯列传", "para": "9.2", "seq": 9, "text": "赢粮跃马，唯恐後时！”", "len": 11}
{"sid": "087_李斯列传.9.3.s1", "chapter": "087_李斯列传", "para": "9.3", "seq": 1, "text": "胡亥既然高之言，高曰：“不与丞相谋，恐事不能成，臣请为子与丞相谋之。", "len": 34}
{"sid": "087_李斯列传.9.3.s2", "chapter": "087_李斯列传", "para": "9.3", "seq": 2, "text": "” 高乃谓丞相斯曰：“上崩，赐长子书，与丧会咸阳而立为嗣。", "len": 29}
{"sid": "087_李斯列传.9.3.s3", "chapter": "087_李斯列传", "para": "9.3", "seq": 3, "text": "书未行，今上崩，未有知者也。", "len": 14}
{"sid": "087_李斯列传.9.3.s4", "chapter": "087_李斯列传", "para": "9.3", "seq": 4, "text": "所赐长子书及符玺皆在胡亥所，定太子在君侯与高之口耳。", "len": 26}
{"sid": "087_李斯列传.9.3.s5", "chapter": "087_李斯列传", "para": "9.3", "seq": 5, "text": "事将何如？", "len": 5}
{"sid": "087_李斯列传.9.3.s6", "chapter": "087_李斯列传", "para": "9.3", "seq": 6, "text": "” 斯曰：“安得亡国之言！", "len": 13}
{"sid": "087_李斯列传.9.3.s7", "chapter": "087_李斯列传", "para": "9.3", "seq": 7, "text": "此非人臣所当议也！”", "len": 10}
{"sid": "087_李斯列传.9.4.s1", "chapter": "087_李斯列传", "para": "9.4", "seq": 1, "text": "高曰：“君侯自料能孰与蒙恬？", "len": 14}
{"sid": "087_李斯列传.9.4.s2", "chapter": "087_李斯列传", "para": "9.4", "seq": 2, "text": "功高孰与蒙恬？", "len": 7}
{"sid": "087_李斯列传.9.4.s3", "chapter": "087_李斯列传", "para": "9.4", "seq": 3, "text": "谋远不失孰与蒙恬？", "len": 9}
{"sid": "087_李斯列传.9.4.s4", "chapter": "087_李斯列传", "para": "9.4", "seq": 4, "text": "无怨於天下孰与蒙恬？", "len": 10}
{"sid": "087_李斯列传.9.4.s5", "chapter": "087_李斯列传", "para": "9.4", "seq": 5, "text": "长子旧而信之孰与蒙恬？", "len": 11}
{"sid": "087_李斯列传.9.4.s6", "chapter": "087_李斯列传", "para": "9.4", "seq": 6, "text": "” 斯曰：“此五者皆不及蒙恬，而君责之何深也？", "len": 23}
{"sid": "087_李斯列传.9.4.s7", "chapter": "087_李斯列传", "para": "9.4", "seq": 7, "text": "“高曰：“高固内官之厮役也，幸得以刀笔之文进入秦宫，管事二十馀年，未尝见秦免罢丞相功臣有封及二世者也，卒皆以诛亡。", "len": 57}
{"sid": "087_李斯列传.9.4.s8", "chapter": "087_李斯列传", "para": "9.4", "seq": 8, "text": "皇帝二十馀子，皆君之所知。", "len": 13}
{"sid": "087_李斯列传.9.4.s9", "chapter": "087_李斯列传", "para": "9.4", "seq": 9, "text": "长子刚毅而武勇，信人而奋士，即位必用蒙恬为丞相，君侯终不怀通侯之印归於乡里，明矣。", "len": 41}
{"sid": "087_李斯列传.9.4.s10", "chapter": "087_李斯列传", "para": "9.4", "seq": 10, "text": "高受诏教习胡亥，使学以法事数年矣，未尝见过失。", "len": 23}
{"sid": "087_李斯列传.9.4.s11", "chapter": "087_李斯列传", "para": "9.4", "seq": 11, "text": "慈仁笃厚，轻财重士，辩於心而诎於口，尽礼敬士，秦之诸子未有及此者，可以为嗣。", "len": 38}
{"sid": "087_李斯列传.9.4.s12", "chapter": "087_李斯列传", "para": "9.4", "seq": 12, "text": "君计而定之。”", "len": 7}
{"sid": "087_李斯列传.9.5.s1", "chapter": "087_李斯列传", "para": "9.5", "seq": 1, "text": "斯曰：“君其反位！", "len": 9}
{"sid": "087_李斯列传.9.5.s2", "chapter": "087_李斯列传", "para": "9.5", "seq": 2, "text": "斯奉主之诏，听天之命，何虑之可定也？", "len": 18}
{"sid": "087_李斯列传.9.5.s3", "chapter": "087_李斯列传", "para": "9.5", "seq": 3, "text": "” 高曰：“安可危也，危可安也。", "len": 16}
{"sid": "087_李斯列传.9.5.s4", "chapter": "087_李斯列传", "para": "9.5", "seq": 4, "text": "安危不定，何以贵圣？", "len": 10}
{"sid": "087_李斯列传.9.5.s5", "chapter": "087_李斯列传", "para": "9.5", "seq": 5, "text": "” 斯曰：“斯，上蔡闾巷布衣也，上幸擢为丞相，封为通侯，子孙皆至尊位重禄者，故将以存亡安危属臣也。", "len": 49}
{"sid": "087_李斯列传.9.5.s6", "chapter": "087_李斯列传", "para": "9.5", "seq": 6, "text": "岂可负哉！", "len": 5}
{"sid": "087_李斯列传.9.5.s7", "chapter": "087_李斯列传", "para": "9.5", "seq": 7, "text": "夫忠臣不避死而庶几，孝子不勤劳而见危，人臣各守其职而已矣。", "len": 29}
{"sid": "087_李斯列传.9.5.s8", "chapter": "087_李斯列传", "para": "9.5", "seq": 8, "text": "君其勿复言，将令斯得罪。”", "len": 13}
{"sid": "087_李斯列传.9.6.s1", "chapter": "087_李斯列传", "para": "9.6", "seq": 1, "text": "高曰：“盖闻圣人迁徙无常，就变而从时，见末而知本，观指而睹归。", "len": 31}
{"sid": "087_李斯列传.9.6.s2", "chapter": "087_李斯列传", "para": "9.6", "seq": 2, "text": "物固有之，安得常法哉！", "len": 11}
{"sid": "087_李斯列传.9.6.s3", "chapter": "087_李斯列传", "para": "9.6", "seq": 3, "text": "方今天下之权命悬於胡亥，高能得志焉。", "len": 18}
{"sid": "087_李斯列传.9.6.s4", "chapter": "087_李斯列传", "para": "9.6", "seq": 4, "text": "且夫从外制中谓之惑，从下制上谓之贼。", "len": 18}
{"sid": "087_李斯列传.9.6.s5", "chapter": "087_李斯列传", "para": "9.6", "seq": 5, "text": "故秋霜降者草花落，水摇动者万物作，此必然之效也。", "len": 24}
{"sid": "087_李斯列传.9.6.s6", "chapter": "087_李斯列传", "para": "9.6", "seq": 6, "text": "君何见之晚？", "len": 6}
{"sid": "087_李斯列传.9.6.s7", "chapter": "087_李斯列传", "para": "9.6", "seq": 7, "text": "” 斯曰：“吾闻晋易太子，三世不安；齐桓兄弟争位，身死为戮；纣杀亲戚，不听谏者，国为丘墟，遂危社稷：三者逆天，宗庙不血食。", "len": 61}
{"sid": "087_李斯列传.9.6.s8", "chapter": "087_李斯列传", "para": "9.6", "seq": 8, "text": "斯其犹人哉，安足为谋！", "len": 11}
{"sid": "087_李斯列传.9.6.s9", "chapter": "087_李斯列传", "para": "9.6", "seq": 9, "text": "” 高曰：“上下合同，可以长久；中外若一，事无表里。", "len": 26}
{"sid": "087_李斯列传.9.6.s10", "chapter": "087_李斯列传", "para": "9.6", "seq": 10, "text": "君听臣之计，即长有封侯，世世称孤，必有乔松之寿，孔、墨之智。", "len": 30}
{"sid": "087_李斯列传.9.6.s11", "chapter": "087_李斯列传", "para": "9.6", "seq": 11, "text": "今释此而不从，祸及子孙，足以为寒心。", "len": 18}
{"sid": "087_李斯列传.9.6.s12", "chapter": "087_李斯列传", "para": "9.6", "seq": 12, "text": "善者因祸为福，君何处焉？", "len": 12}
{"sid": "087_李斯列传.9.6.s13", "chapter": "087_李斯列传", "para": "9.6", "seq": 13, "text": "” 斯乃仰天而叹，垂泪太息曰：“嗟乎！", "len": 19}
{"sid": "087_李斯列传.9.6.s14", "chapter": "087_李斯列传", "para": "9.6", "seq": 14, "text": "独遭乱世，既以不能死，安讬命哉！", "len": 16}
{"sid": "087_李斯列传.9.6.s15", "chapter": "087_李斯列传", "para": "9.6", "seq": 15, "text": "” 於是斯乃听高。", "len": 9}
{"sid": "087_李斯列传.10.1.s1", "chapter": "087_李斯列传", "para": "10.1", "seq": 1, "text": "高乃报胡亥曰：“臣请奉太子之明命以报丞相，丞相斯敢不奉令！", "len": 29}
{"sid": "087_李斯列传.10.1.s2", "chapter": "087_李斯列传", "para": "10.1", "seq": 2, "text": "” 於是乃相与谋，诈为受始皇诏丞相，立子胡亥为太子。", "len": 26}
{"sid": "087_李斯列传.10.1.s3", "chapter": "087_李斯列传", "para": "10.1", "seq": 3, "text": "更为书赐长子扶苏曰：“朕巡天下，祷祠名山诸神以延寿命。", "len": 27}
{"sid": "087_李斯列传.10.1.s4", "chapter": "087_李斯列传", "para": "10.1", "seq": 4, "text": "今扶苏与将军蒙恬将师数十万以屯边，十有馀年矣，不能进而前，士卒多秏，无尺寸之功，乃反数上书直言诽谤我所为，以不得罢归为太子，日夜怨望。", "len": 67}
{"sid": "087_李斯列传.10.1.s5", "chapter": "087_李斯列传", "para": "10.1", "seq": 5, "text": "扶苏为人子不孝，其赐剑以自裁！", "len": 15}
{"sid": "087_李斯列传.10.1.s6", "chapter": "087_李斯列传", "para": "10.1", "seq": 6, "text": "将军恬与扶苏居外，不匡正，宜知其谋。", "len": 18}
{"sid": "087_李斯列传.10.1.s7", "chapter": "087_李斯列传", "para": "10.1", "seq": 7, "text": "为人臣不忠，其赐死，以兵属裨将王离。", "len": 18}
{"sid": "087_李斯列传.10.1.s8", "chapter": "087_李斯列传", "para": "10.1", "seq": 8, "text": "” 封其书以皇帝玺，遣胡亥客奉书赐扶苏於上郡。", "len": 23}
{"sid": "087_李斯列传.10.2.s1", "chapter": "087_李斯列传", "para": "10.2", "seq": 1, "text": "使者至，发书，扶苏泣，入内舍，欲自杀。", "len": 19}
{"sid": "087_李斯列传.10.2.s2", "chapter": "087_李斯列传", "para": "10.2", "seq": 2, "text": "蒙恬止扶苏曰：“陛下居外，未立太子，使臣将三十万众守边，公子为监，此天下重任也。", "len": 40}
{"sid": "087_李斯列传.10.2.s3", "chapter": "087_李斯列传", "para": "10.2", "seq": 3, "text": "今一使者来，即自杀，安知其非诈？", "len": 16}
{"sid": "087_李斯列传.10.2.s4", "chapter": "087_李斯列传", "para": "10.2", "seq": 4, "text": "请复请，复请而後死，未暮也。", "len": 14}
{"sid": "087_李斯列传.10.2.s5", "chapter": "087_李斯列传", "para": "10.2", "seq": 5, "text": "” 使者数趣之。", "len": 8}
{"sid": "087_李斯列传.10.2.s6", "chapter": "087_李斯列传", "para": "10.2", "seq": 6, "text": "扶苏为人仁，谓蒙恬曰：“父而赐子死，尚安复请！", "len": 23}
{"sid": "087_李斯列传.10.2.s7", "chapter": "087_李斯列传", "para": "10.2", "seq": 7, "text": "” 即自杀。", "len": 6}
{"sid": "087_李斯列传.10.2.s8", "chapter": "087_李斯列传", "para": "10.2", "seq": 8, "text": "蒙恬不肯死，使者即以属吏，系於阳周。", "len": 18}
{"sid": "087_李斯列传.11.1.s1", "chapter": "087_李斯列传", "para": "11.1", "seq": 1, "text": "使者还报，胡亥、斯、高大喜。", "len": 14}
{"sid": "087_李斯列传.11.1.s2", "chapter": "087_李斯列传", "para": "11.1", "seq": 2, "text": "至咸阳，发丧，太子立为二世皇帝。", "len": 16}
{"sid": "087_李斯列传.11.1.s3", "chapter": "087_李斯列传", "para": "11.1", "seq": 3, "text": "以赵高为郎中令，常侍中用事。", "len": 14}
{"sid": "087_李斯列传.12.1.s1", "chapter": "087_李斯列传", "para": "12.1", "seq": 1, "text": "二世燕居，乃召高与谋事，谓曰：“夫人生居世间也，譬犹骋六骥过决隙也。", "len": 34}
{"sid": "087_李斯列传.12.1.s2", "chapter": "087_李斯列传", "para": "12.1", "seq": 2, "text": "吾既已临天下矣，欲悉耳目之所好，穷心志之所乐，以安宗庙而乐万姓，长有天下，终吾年寿，其道可乎？", "len": 47}
{"sid": "087_李斯列传.12.1.s3", "chapter": "087_李斯列传", "para": "12.1", "seq": 3, "text": "” 高曰：“此贤主之所能行也，而昬乱主之所禁也。", "len": 24}
{"sid": "087_李斯列传.12.1.s4", "chapter": "087_李斯列传", "para": "12.1", "seq": 4, "text": "臣请言之，不敢避斧钺之诛，原陛下少留意焉。", "len": 21}
{"sid": "087_李斯列传.12.1.s5", "chapter": "087_李斯列传", "para": "12.1", "seq": 5, "text": "夫沙丘之谋，诸公子及大臣皆疑焉，而诸公子尽帝兄，大臣又先帝之所置也。", "len": 34}
{"sid": "087_李斯列传.12.1.s6", "chapter": "087_李斯列传", "para": "12.1", "seq": 6, "text": "今陛下初立，此其属意怏怏皆不服，恐为变。", "len": 20}
{"sid": "087_李斯列传.12.1.s7", "chapter": "087_李斯列传", "para": "12.1", "seq": 7, "text": "且蒙恬已死，蒙毅将兵居外，臣战战栗栗，唯恐不终。", "len": 24}
{"sid": "087_李斯列传.12.1.s8", "chapter": "087_李斯列传", "para": "12.1", "seq": 8, "text": "且陛下安得为此乐乎？", "len": 10}
{"sid": "087_李斯列传.12.1.s9", "chapter": "087_李斯列传", "para": "12.1", "seq": 9, "text": "” 二世曰：“为之柰何？", "len": 12}
{"sid": "087_李斯列传.12.1.s10", "chapter": "087_李斯列传", "para": "12.1", "seq": 10, "text": "” 赵高曰：“严法而刻刑，令有罪者相坐诛，至收族，灭大臣而远骨肉；贫者富之，贱者贵之。", "len": 43}
{"sid": "087_李斯列传.12.1.s11", "chapter": "087_李斯列传", "para": "12.1", "seq": 11, "text": "尽除去先帝之故臣，更置陛下之所亲信者近之。", "len": 21}
{"sid": "087_李斯列传.12.1.s12", "chapter": "087_李斯列传", "para": "12.1", "seq": 12, "text": "此则阴德归陛下，害除而奸谋塞，群臣莫不被润泽，蒙厚德，陛下则高枕肆志宠乐矣。", "len": 38}
{"sid": "087_李斯列传.12.1.s13", "chapter": "087_李斯列传", "para": "12.1", "seq": 13, "text": "计莫出於此。", "len": 6}
{"sid": "087_李斯列传.12.1.s14", "chapter": "087_李斯列传", "para": "12.1", "seq": 14, "text": "” 二世然高之言，乃更为法律。", "len": 15}
{"sid": "087_李斯列传.12.1.s15", "chapter": "087_李斯列传", "para": "12.1", "seq": 15, "text": "於是群臣诸公子有罪，辄下高，令鞠治之。", "len": 19}
{"sid": "087_李斯列传.12.1.s16", "chapter": "087_李斯列传", "para": "12.1", "seq": 16, "text": "杀大臣蒙毅等，公子十二人僇死咸阳市，十公主矺死於杜，财物入於县官，相连坐者不可胜数。", "len": 42}
{"sid": "087_李斯列传.12.2.s1", "chapter": "087_李斯列传", "para": "12.2", "seq": 1, "text": "公子高欲奔，恐收族，乃上书曰：“先帝无恙时，臣入则赐食，出则乘舆。", "len": 33}
{"sid": "087_李斯列传.12.2.s2", "chapter": "087_李斯列传", "para": "12.2", "seq": 2, "text": "御府之衣，臣得赐之；中厩之宝马，臣得赐之。", "len": 21}
{"sid": "087_李斯列传.12.2.s3", "chapter": "087_李斯列传", "para": "12.2", "seq": 3, "text": "臣当从死而不能，为人子不孝，为人臣不忠。", "len": 20}
{"sid": "087_李斯列传.12.2.s4", "chapter": "087_李斯列传", "para": "12.2", "seq": 4, "text": "不忠者无名以立於世，臣请从死，原葬郦山之足。", "len": 22}
{"sid": "087_李斯列传.12.2.s5", "chapter": "087_李斯列传", "para": "12.2", "seq": 5, "text": "唯上幸哀怜之。", "len": 7}
{"sid": "087_李斯列传.12.2.s6", "chapter": "087_李斯列传", "para": "12.2", "seq": 6, "text": "” 书上，胡亥大说，召赵高而示之，曰：“此可谓急乎？", "len": 26}
{"sid": "087_李斯列传.12.2.s7", "chapter": "087_李斯列传", "para": "12.2", "seq": 7, "text": "” 赵高曰：“人臣当忧死而不暇，何变之得谋！", "len": 22}
{"sid": "087_李斯列传.12.2.s8", "chapter": "087_李斯列传", "para": "12.2", "seq": 8, "text": "” 胡亥可其书，赐钱十万以葬。", "len": 15}
{"sid": "087_李斯列传.13.1.s1", "chapter": "087_李斯列传", "para": "13.1", "seq": 1, "text": "法令诛罚日益刻深，群臣人人自危，欲畔者众。", "len": 21}
{"sid": "087_李斯列传.13.1.s2", "chapter": "087_李斯列传", "para": "13.1", "seq": 2, "text": "又作阿房之宫，治直、驰道，赋敛愈重，戍徭无已。", "len": 23}
{"sid": "087_李斯列传.13.1.s3", "chapter": "087_李斯列传", "para": "13.1", "seq": 3, "text": "於是楚戍卒陈胜、吴广等乃作乱，起於山东，杰俊相立，自置为侯王，叛秦，兵至鸿门而卻。", "len": 41}
{"sid": "087_李斯列传.13.2.s1", "chapter": "087_李斯列传", "para": "13.2", "seq": 1, "text": "李斯数欲请间谏，二世不许。", "len": 13}
{"sid": "087_李斯列传.13.2.s2", "chapter": "087_李斯列传", "para": "13.2", "seq": 2, "text": "而二世责问李斯曰：“吾有私议而有所闻於韩子也，曰‘尧之有天下也，堂高三尺，采椽不斫，茅茨不翦，虽逆旅之宿不勤於此矣。", "len": 58}
{"sid": "087_李斯列传.13.2.s3", "chapter": "087_李斯列传", "para": "13.2", "seq": 3, "text": "冬日鹿裘，夏日葛衣，粢粝之食，藜藿之羹，饭土匭，啜土鉶，虽监门之养不觳於此矣。", "len": 39}
{"sid": "087_李斯列传.13.2.s4", "chapter": "087_李斯列传", "para": "13.2", "seq": 4, "text": "禹凿龙门，通大夏，疏九河，曲九防，决渟水致之海，而股无胈，胫无毛，手足胼胝，面目黎黑，遂以死于外，葬於会稽，臣虏之劳不烈於此矣’。", "len": 65}
{"sid": "087_李斯列传.13.2.s5", "chapter": "087_李斯列传", "para": "13.2", "seq": 5, "text": "然则夫所贵於有天下者，岂欲苦形劳神，身处逆旅之宿，口食监门之养，手持臣虏之作哉？", "len": 40}
{"sid": "087_李斯列传.13.2.s6", "chapter": "087_李斯列传", "para": "13.2", "seq": 6, "text": "此不肖人之所勉也，非贤者之所务也。", "len": 17}
{"sid": "087_李斯列传.13.2.s7", "chapter": "087_李斯列传", "para": "13.2", "seq": 7, "text": "彼贤人之有天下也，专用天下適己而已矣，此所贵於有天下也。", "len": 28}
{"sid": "087_李斯列传.13.2.s8", "chapter": "087_李斯列传", "para": "13.2", "seq": 8, "text": "夫所谓贤人者，必能安天下而治万民，今身且不能利，将恶能治天下哉！", "len": 32}
{"sid": "087_李斯列传.13.2.s9", "chapter": "087_李斯列传", "para": "13.2", "seq": 9, "text": "故吾原赐志广欲，长享天下而无害，为之柰何？”", "len": 22}
{"sid": "087_李斯列传.13.3.s1", "chapter": "087_李斯列传", "para": "13.3", "seq": 1, "text": "李斯子由为三川守，群盗吴广等西略地，过去弗能禁。", "len": 24}
{"sid": "087_李斯列传.13.3.s2", "chapter": "087_李斯列传", "para": "13.3", "seq": 2, "text": "章邯以破逐广等兵，使者覆案三川相属，诮让斯居三公位，如何令盗如此。", "len": 33}
{"sid": "087_李斯列传.13.3.s3", "chapter": "087_李斯列传", "para": "13.3", "seq": 3, "text": "李斯恐惧，重爵禄，不知所出，乃阿二世意，欲求容，以书对曰：", "len": 29}
{"sid": "087_李斯列传.13.4.s1", "chapter": "087_李斯列传", "para": "13.4", "seq": 1, "text": "夫贤主者，必且能全道而行督责之术者也。", "len": 19}
{"sid": "087_李斯列传.13.4.s2", "chapter": "087_李斯列传", "para": "13.4", "seq": 2, "text": "督责之，则臣不敢不竭能以徇其主矣。", "len": 17}
{"sid": "087_李斯列传.13.4.s3", "chapter": "087_李斯列传", "para": "13.4", "seq": 3, "text": "此臣主之分定，上下之义明，则天下贤不肖莫敢不尽力竭任以徇其君矣。", "len": 32}
{"sid": "087_李斯列传.13.4.s4", "chapter": "087_李斯列传", "para": "13.4", "seq": 4, "text": "是故主独制於天下而无所制也。", "len": 14}
{"sid": "087_李斯列传.13.4.s5", "chapter": "087_李斯列传", "para": "13.4", "seq": 5, "text": "能穷乐之极矣，贤明之主也，可不察焉！", "len": 18}
{"sid": "087_李斯列传.13.5.s1", "chapter": "087_李斯列传", "para": "13.5", "seq": 1, "text": "故申子曰“有天下而不恣睢，命之曰以天下为桎梏” 者，无他焉，不能督责，而顾以其身劳於天下之民，若尧、禹然，故谓之“桎梏” 也。", "len": 63}
{"sid": "087_李斯列传.13.5.s2", "chapter": "087_李斯列传", "para": "13.5", "seq": 2, "text": "夫不能修申、韩之明术，行督责之道，专以天下自適也，而徒务苦形劳神，以身徇百姓，则是黔首之役，非畜天下者也，何足贵哉！", "len": 58}
{"sid": "087_李斯列传.13.5.s3", "chapter": "087_李斯列传", "para": "13.5", "seq": 3, "text": "夫以人徇己，则己贵而人贱；以己徇人，则己贱而人贵。", "len": 25}
{"sid": "087_李斯列传.13.5.s4", "chapter": "087_李斯列传", "para": "13.5", "seq": 4, "text": "故徇人者贱，而人所徇者贵，自古及今，未有不然者也。", "len": 25}
{"sid": "087_李斯列传.13.5.s5", "chapter": "087_李斯列传", "para": "13.5", "seq": 5, "text": "凡古之所为尊贤者，为其贵也；而所为恶不肖者，为其贱也。", "len": 27}
{"sid": "087_李斯列传.13.5.s6", "chapter": "087_李斯列传", "para": "13.5", "seq": 6, "text": "而尧、禹以身徇天下者也，因随而尊之，则亦失所为尊贤之心矣，夫可谓大缪矣。", "len": 36}
{"sid": "087_李斯列传.13.5.s7", "chapter": "087_李斯列传", "para": "13.5", "seq": 7, "text": "谓之为“桎梏”，不亦宜乎？", "len": 13}
{"sid": "087_李斯列传.13.5.s8", "chapter": "087_李斯列传", "para": "13.5", "seq": 8, "text": "不能督责之过也。", "len": 8}
{"sid": "087_李斯列传.13.6.s1", "chapter": "087_李斯列传", "para": "13.6", "seq": 1, "text": "故韩子曰：“慈母有败子而严家无格虏” 者，何也？", "len": 24}
{"sid": "087_李斯列传.13.6.s2", "chapter": "087_李斯列传", "para": "13.6", "seq": 2, "text": "则能罚之加焉必也。", "len": 9}
{"sid": "087_李斯列传.13.6.s3", "chapter": "087_李斯列传", "para": "13.6", "seq": 3, "text": "故商君之法，刑弃灰於道者。", "len": 13}
{"sid": "087_李斯列传.13.6.s4", "chapter": "087_李斯列传", "para": "13.6", "seq": 4, "text": "夫弃灰，薄罪也，而被刑，重罚也。", "len": 16}
{"sid": "087_李斯列传.13.6.s5", "chapter": "087_李斯列传", "para": "13.6", "seq": 5, "text": "彼唯明主为能深督轻罪。", "len": 11}
{"sid": "087_李斯列传.13.6.s6", "chapter": "087_李斯列传", "para": "13.6", "seq": 6, "text": "夫罪轻且督深，而况有重罪乎？", "len": 14}
{"sid": "087_李斯列传.13.6.s7", "chapter": "087_李斯列传", "para": "13.6", "seq": 7, "text": "故民不敢犯也。", "len": 7}
{"sid": "087_李斯列传.13.6.s8", "chapter": "087_李斯列传", "para": "13.6", "seq": 8, "text": "是故韩子曰“布帛寻常，庸人不释，铄金百溢，盗跖不搏” 者，非庸人之心重，寻常之利深，而盗跖之欲浅也；又不以盗跖之行，为轻百镒之重也。", "len": 66}
{"sid": "087_李斯列传.13.6.s9", "chapter": "087_李斯列传", "para": "13.6", "seq": 9, "text": "搏必随手刑，则盗跖不搏百镒；而罚不必行也，则庸人不释寻常。", "len": 29}
{"sid": "087_李斯列传.13.6.s10", "chapter": "087_李斯列传", "para": "13.6", "seq": 10, "text": "是故城高五丈，而楼季不轻犯也；泰山之高百仞，而跛牧其上。", "len": 28}
{"sid": "087_李斯列传.13.6.s11", "chapter": "087_李斯列传", "para": "13.6", "seq": 11, "text": "夫楼季也而难五丈之限，岂跛也而易百仞之高哉？", "len": 22}
{"sid": "087_李斯列传.13.6.s12", "chapter": "087_李斯列传", "para": "13.6", "seq": 12, "text": "峭堑之势异也。", "len": 7}
{"sid": "087_李斯列传.13.6.s13", "chapter": "087_李斯列传", "para": "13.6", "seq": 13, "text": "明主圣王之所以能久处尊位，长执重势，而独擅天下之利者，非有异道也，能独断而审督责，必深罚，故天下不敢犯也。", "len": 53}
{"sid": "087_李斯列传.13.6.s14", "chapter": "087_李斯列传", "para": "13.6", "seq": 14, "text": "今不务所以不犯，而事慈母之所以败子也，则亦不察於圣人之论矣。", "len": 30}
{"sid": "087_李斯列传.13.6.s15", "chapter": "087_李斯列传", "para": "13.6", "seq": 15, "text": "夫不能行圣人之术，则舍为天下役何事哉？", "len": 19}
{"sid": "087_李斯列传.13.6.s16", "chapter": "087_李斯列传", "para": "13.6", "seq": 16, "text": "可不哀邪！", "len": 5}
{"sid": "087_李斯列传.13.7.s1", "chapter": "087_李斯列传", "para": "13.7", "seq": 1, "text": "且夫俭节仁义之人立於朝，则荒肆之乐辍矣；谏说论理之臣间於侧，则流漫之志诎矣；烈士死节之行显於世，则淫康之虞废矣。", "len": 56}
{"sid": "087_李斯列传.13.7.s2", "chapter": "087_李斯列传", "para": "13.7", "seq": 2, "text": "故明主能外此三者，而独操主术以制听从之臣，而修其明法，故身尊而势重也。", "len": 35}
{"sid": "087_李斯列传.13.7.s3", "chapter": "087_李斯列传", "para": "13.7", "seq": 3, "text": "凡贤主者，必将能拂世磨俗，而废其所恶，立其所欲，故生则有尊重之势，死则有贤明之谥也。", "len": 42}
{"sid": "087_李斯列传.13.7.s4", "chapter": "087_李斯列传", "para": "13.7", "seq": 4, "text": "是以明君独断，故权不在臣也。", "len": 14}
{"sid": "087_李斯列传.13.7.s5", "chapter": "087_李斯列传", "para": "13.7", "seq": 5, "text": "然後能灭仁义之涂，掩驰说之口，困烈士之行，塞聪揜明，内独视听，故外不可倾以仁义烈士之行，而内不可夺以谏说忿争之辩。", "len": 57}
{"sid": "087_李斯列传.13.7.s6", "chapter": "087_李斯列传", "para": "13.7", "seq": 6, "text": "故能荦然独行恣睢之心而莫之敢逆。", "len": 16}
{"sid": "087_李斯列传.13.7.s7", "chapter": "087_李斯列传", "para": "13.7", "seq": 7, "text": "若此然後可谓能明申、韩之术，而脩商君之法。", "len": 21}
{"sid": "087_李斯列传.13.7.s8", "chapter": "087_李斯列传", "para": "13.7", "seq": 8, "text": "法脩术明而天下乱者，未之闻也。", "len": 15}
{"sid": "087_李斯列传.13.7.s9", "chapter": "087_李斯列传", "para": "13.7", "seq": 9, "text": "故曰“王道约而易操” 也。", "len": 13}
{"sid": "087_李斯列传.13.7.s10", "chapter": "087_李斯列传", "para": "13.7", "seq": 10, "text": "唯明主为能行之。", "len": 8}
{"sid": "087_李斯列传.13.7.s11", "chapter": "087_李斯列传", "para": "13.7", "seq": 11, "text": "若此则谓督责之诚，则臣无邪，臣无邪则天下安，天下安则主严尊，主严尊则督责必，督责必则所求得，所求得则国家富，国家富则君乐丰。", "len": 62}
{"sid": "087_李斯列传.13.7.s12", "chapter": "087_李斯列传", "para": "13.7", "seq": 12, "text": "故督责之术设，则所欲无不得矣。", "len": 15}
{"sid": "087_李斯列传.13.7.s13", "chapter": "087_李斯列传", "para": "13.7", "seq": 13, "text": "群臣百姓救过不给，何变之敢图？", "len": 15}
{"sid": "087_李斯列传.13.7.s14", "chapter": "087_李斯列传", "para": "13.7", "seq": 14, "text": "若此则帝道备，而可谓能明君臣之术矣。", "len": 18}
{"sid": "087_李斯列传.13.7.s15", "chapter": "087_李斯列传", "para": "13.7", "seq": 15, "text": "虽申、韩复生，不能加也。", "len": 12}
{"sid": "087_李斯列传.13.8.s1", "chapter": "087_李斯列传", "para": "13.8", "seq": 1, "text": "书奏，二世悦。", "len": 7}
{"sid": "087_李斯列传.13.8.s2", "chapter": "087_李斯列传", "para": "13.8", "seq": 2, "text": "於是行督责益严，税民深者为明吏。", "len": 16}
{"sid": "087_李斯列传.13.8.s3", "chapter": "087_李斯列传", "para": "13.8", "seq": 3, "text": "二世曰：“若此则可谓能督责矣。", "len": 15}
{"sid": "087_李斯列传.13.8.s4", "chapter": "087_李斯列传", "para": "13.8", "seq": 4, "text": "” 刑者相半於道，而死人日成积於市。", "len": 18}
{"sid": "087_李斯列传.13.8.s5", "chapter": "087_李斯列传", "para": "13.8", "seq": 5, "text": "杀人众者为忠臣。", "len": 8}
{"sid": "087_李斯列传.13.8.s6", "chapter": "087_李斯列传", "para": "13.8", "seq": 6, "text": "二世曰：“若此则可谓能督责矣。”", "len": 16}
{"sid": "087_李斯列传.14.1.s1", "chapter": "087_李斯列传", "para": "14.1", "seq": 1, "text": "初，赵高为郎中令，所杀及报私怨众多，恐大臣入朝奏事毁恶之，乃说二世曰：“天子所以贵者，但以闻声，群臣莫得见其面，故号曰‘朕’。", "len": 63}
{"sid": "087_李斯列传.14.1.s2", "chapter": "087_李斯列传", "para": "14.1", "seq": 2, "text": "且陛下富於春秋，未必尽通诸事，今坐朝廷，谴举有不当者，则见短於大臣，非所以示神明於天下也。", "len": 45}
{"sid": "087_李斯列传.14.1.s3", "chapter": "087_李斯列传", "para": "14.1", "seq": 3, "text": "且陛下深拱禁中，与臣及侍中习法者待事，事来有以揆之。", "len": 26}
{"sid": "087_李斯列传.14.1.s4", "chapter": "087_李斯列传", "para": "14.1", "seq": 4, "text": "如此则大臣不敢奏疑事，天下称圣主矣。", "len": 18}
{"sid": "087_李斯列传.14.1.s5", "chapter": "087_李斯列传", "para": "14.1", "seq": 5, "text": "” 二世用其计，乃不坐朝廷见大臣，居禁中。", "len": 21}
{"sid": "087_李斯列传.14.1.s6", "chapter": "087_李斯列传", "para": "14.1", "seq": 6, "text": "赵高常侍中用事，事皆决於赵高。", "len": 15}
{"sid": "087_李斯列传.14.2.s1", "chapter": "087_李斯列传", "para": "14.2", "seq": 1, "text": "高闻李斯以为言，乃见丞相曰：“关东群盗多，今上急益发繇治阿房宫，聚狗马无用之物。", "len": 40}
{"sid": "087_李斯列传.14.2.s2", "chapter": "087_李斯列传", "para": "14.2", "seq": 2, "text": "臣欲谏，为位贱。", "len": 8}
{"sid": "087_李斯列传.14.2.s3", "chapter": "087_李斯列传", "para": "14.2", "seq": 3, "text": "此真君侯之事，君何不谏？", "len": 12}
{"sid": "087_李斯列传.14.2.s4", "chapter": "087_李斯列传", "para": "14.2", "seq": 4, "text": "” 李斯曰：“固也，吾欲言之久矣。", "len": 17}
{"sid": "087_李斯列传.14.2.s5", "chapter": "087_李斯列传", "para": "14.2", "seq": 5, "text": "今时上不坐朝廷，上居深宫，吾有所言者，不可传也，欲见无间。", "len": 29}
{"sid": "087_李斯列传.14.2.s6", "chapter": "087_李斯列传", "para": "14.2", "seq": 6, "text": "” 赵高谓曰：“君诚能谏，请为君候上间语君。", "len": 22}
{"sid": "087_李斯列传.14.2.s7", "chapter": "087_李斯列传", "para": "14.2", "seq": 7, "text": "” 於是赵高待二世方燕乐，妇女居前，使人告丞相：“上方间，可奏事。", "len": 33}
{"sid": "087_李斯列传.14.2.s8", "chapter": "087_李斯列传", "para": "14.2", "seq": 8, "text": "” 丞相至宫门上谒，如此者三。", "len": 15}
{"sid": "087_李斯列传.14.2.s9", "chapter": "087_李斯列传", "para": "14.2", "seq": 9, "text": "二世怒曰：“吾常多间日，丞相不来。", "len": 17}
{"sid": "087_李斯列传.14.2.s10", "chapter": "087_李斯列传", "para": "14.2", "seq": 10, "text": "吾方燕私，丞相辄来请事。", "len": 12}
{"sid": "087_李斯列传.14.2.s11", "chapter": "087_李斯列传", "para": "14.2", "seq": 11, "text": "丞相岂少我哉？", "len": 7}
{"sid": "087_李斯列传.14.2.s12", "chapter": "087_李斯列传", "para": "14.2", "seq": 12, "text": "且固我哉？”", "len": 6}
{"sid": "087_李斯列传.14.3.s1", "chapter": "087_李斯列传", "para": "14.3", "seq": 1, "text": "赵高因曰：“如此殆矣！", "len": 11}
{"sid": "087_李斯列传.14.3.s2", "chapter": "087_李斯列传", "para": "14.3", "seq": 2, "text": "夫沙丘之谋，丞相与焉。", "len": 11}
{"sid": "087_李斯列传.14.3.s3", "chapter": "087_李斯列传", "para": "14.3", "seq": 3, "text": "今陛下已立为帝，而丞相贵不益，此其意亦望裂地而王矣。", "len": 26}
{"sid": "087_李斯列传.14.3.s4", "chapter": "087_李斯列传", "para": "14.3", "seq": 4, "text": "且陛下不问臣，臣不敢言。", "len": 12}
{"sid": "087_李斯列传.14.3.s5", "chapter": "087_李斯列传", "para": "14.3", "seq": 5, "text": "丞相长男李由为三川守，楚盗陈胜等皆丞相傍县之子，以故楚盗公行，过三川，城守不肯击。", "len": 41}
{"sid": "087_李斯列传.14.3.s6", "chapter": "087_李斯列传", "para": "14.3", "seq": 6, "text": "高闻其文书相往来，未得其审，故未敢以闻。", "len": 20}
{"sid": "087_李斯列传.14.3.s7", "chapter": "087_李斯列传", "para": "14.3", "seq": 7, "text": "且丞相居外，权重於陛下。", "len": 12}
{"sid": "087_李斯列传.14.3.s8", "chapter": "087_李斯列传", "para": "14.3", "seq": 8, "text": "” 二世以为然。", "len": 8}
{"sid": "087_李斯列传.14.3.s9", "chapter": "087_李斯列传", "para": "14.3", "seq": 9, "text": "欲案丞相，恐其不审，乃使人案验三川守与盗通状。", "len": 23}
{"sid": "087_李斯列传.14.3.s10", "chapter": "087_李斯列传", "para": "14.3", "seq": 10, "text": "李斯闻之。", "len": 5}
{"sid": "087_李斯列传.15.1.s1", "chapter": "087_李斯列传", "para": "15.1", "seq": 1, "text": "是时二世在甘泉，方作觳抵优俳之观。", "len": 17}
{"sid": "087_李斯列传.15.1.s2", "chapter": "087_李斯列传", "para": "15.1", "seq": 2, "text": "李斯不得见，因上书言赵高之短曰：“臣闻之，臣疑其君，无不危国；妾疑其夫，无不危家。", "len": 41}
{"sid": "087_李斯列传.15.1.s3", "chapter": "087_李斯列传", "para": "15.1", "seq": 3, "text": "今有大臣於陛下擅利擅害，与陛下无异，此甚不便。", "len": 23}
{"sid": "087_李斯列传.15.1.s4", "chapter": "087_李斯列传", "para": "15.1", "seq": 4, "text": "昔者司城子罕相宋，身行刑罚，以威行之，期年遂劫其君。", "len": 26}
{"sid": "087_李斯列传.15.1.s5", "chapter": "087_李斯列传", "para": "15.1", "seq": 5, "text": "田常为简公臣，爵列无敌於国，私家之富与公家均，布惠施德，下得百姓，上得群臣，阴取齐国，杀宰予於庭，即弑简公於朝，遂有齐国。", "len": 61}
{"sid": "087_李斯列传.15.1.s6", "chapter": "087_李斯列传", "para": "15.1", "seq": 6, "text": "此天下所明知也。", "len": 8}
{"sid": "087_李斯列传.15.1.s7", "chapter": "087_李斯列传", "para": "15.1", "seq": 7, "text": "今高有邪佚之志，危反之行，如子罕相宋也；私家之富，若田氏之於齐也。", "len": 33}
{"sid": "087_李斯列传.15.1.s8", "chapter": "087_李斯列传", "para": "15.1", "seq": 8, "text": "兼行田常、子罕之逆道而劫陛下之威信，其志若韩为韩安相也。", "len": 28}
{"sid": "087_李斯列传.15.1.s9", "chapter": "087_李斯列传", "para": "15.1", "seq": 9, "text": "陛下不图，臣恐其为变也。”", "len": 13}
{"sid": "087_李斯列传.15.2.s1", "chapter": "087_李斯列传", "para": "15.2", "seq": 1, "text": "二世曰：“何哉？", "len": 8}
{"sid": "087_李斯列传.15.2.s2", "chapter": "087_李斯列传", "para": "15.2", "seq": 2, "text": "夫高，故宦人也，然不为安肆志，不以危易心，絜行脩善，自使至此，以忠得进，以信守位，朕实贤之，而君疑之，何也？", "len": 54}
{"sid": "087_李斯列传.15.2.s3", "chapter": "087_李斯列传", "para": "15.2", "seq": 3, "text": "且朕少失先人，无所识知，不习治民，而君又老，恐与天下绝矣。", "len": 29}
{"sid": "087_李斯列传.15.2.s4", "chapter": "087_李斯列传", "para": "15.2", "seq": 4, "text": "朕非属赵君，当谁任哉？", "len": 11}
{"sid": "087_李斯列传.15.2.s5", "chapter": "087_李斯列传", "para": "15.2", "seq": 5, "text": "且赵君为人精廉彊力，下知人情，上能適朕，君其勿疑。", "len": 25}
{"sid": "087_李斯列传.15.2.s6", "chapter": "087_李斯列传", "para": "15.2", "seq": 6, "text": "” 李斯曰：“不然。", "len": 10}
{"sid": "087_李斯列传.15.2.s7", "chapter": "087_李斯列传", "para": "15.2", "seq": 7, "text": "夫高，故贱人也，无识於理，贪欲无厌，求利不止，列势次主，求欲无穷，臣故曰殆。", "len": 38}
{"sid": "087_李斯列传.15.2.s8", "chapter": "087_李斯列传", "para": "15.2", "seq": 8, "text": "” 二世已前信赵高，恐李斯杀之，乃私告赵高。", "len": 22}
{"sid": "087_李斯列传.15.2.s9", "chapter": "087_李斯列传", "para": "15.2", "seq": 9, "text": "高曰：“丞相所患者独高，高已死，丞相即欲为田常所为。", "len": 26}
{"sid": "087_李斯列传.15.2.s10", "chapter": "087_李斯列传", "para": "15.2", "seq": 10, "text": "” 於是二世曰：“其以李斯属郎中令！”", "len": 19}
{"sid": "087_李斯列传.16.1.s1", "chapter": "087_李斯列传", "para": "16.1", "seq": 1, "text": "赵高案治李斯。", "len": 7}
{"sid": "087_李斯列传.16.1.s2", "chapter": "087_李斯列传", "para": "16.1", "seq": 2, "text": "李斯拘执束缚，居囹圄中，仰天而叹曰：“嗟乎，悲夫！", "len": 25}
{"sid": "087_李斯列传.16.1.s3", "chapter": "087_李斯列传", "para": "16.1", "seq": 3, "text": "不道之君，何可为计哉！", "len": 11}
{"sid": "087_李斯列传.16.1.s4", "chapter": "087_李斯列传", "para": "16.1", "seq": 4, "text": "昔者桀杀关龙逢，纣杀王子比干，吴王夫差杀伍子胥。", "len": 24}
{"sid": "087_李斯列传.16.1.s5", "chapter": "087_李斯列传", "para": "16.1", "seq": 5, "text": "此三臣者，岂不忠哉，然而不免於死，身死而所忠者非也。", "len": 26}
{"sid": "087_李斯列传.16.1.s6", "chapter": "087_李斯列传", "para": "16.1", "seq": 6, "text": "今吾智不及三子，而二世之无道过於桀、纣、夫差，吾以忠死，宜矣。", "len": 31}
{"sid": "087_李斯列传.16.1.s7", "chapter": "087_李斯列传", "para": "16.1", "seq": 7, "text": "且二世之治岂不乱哉！", "len": 10}
{"sid": "087_李斯列传.16.1.s8", "chapter": "087_李斯列传", "para": "16.1", "seq": 8, "text": "日者夷其兄弟而自立也，杀忠臣而贵贱人，作为阿房之宫，赋敛天下。", "len": 31}
{"sid": "087_李斯列传.16.1.s9", "chapter": "087_李斯列传", "para": "16.1", "seq": 9, "text": "吾非不谏也，而不吾听也。", "len": 12}
{"sid": "087_李斯列传.16.1.s10", "chapter": "087_李斯列传", "para": "16.1", "seq": 10, "text": "凡古圣王，饮食有节，车器有数，宫室有度，出令造事，加费而无益於民利者禁，故能长久治安。", "len": 43}
{"sid": "087_李斯列传.16.1.s11", "chapter": "087_李斯列传", "para": "16.1", "seq": 11, "text": "今行逆於昆弟，不顾其咎；侵杀忠臣，不思其殃；大为宫室，厚赋天下，不爱其费：三者已行，天下不听。", "len": 47}
{"sid": "087_李斯列传.16.1.s12", "chapter": "087_李斯列传", "para": "16.1", "seq": 12, "text": "今反者已有天下之半矣，而心尚未寤也，而以赵高为佐，吾必见寇至咸阳，麋鹿游於朝也。”", "len": 41}
{"sid": "087_李斯列传.16.2.s1", "chapter": "087_李斯列传", "para": "16.2", "seq": 1, "text": "於是二世乃使高案丞相狱，治罪，责斯与子由谋反状，皆收捕宗族宾客。", "len": 32}
{"sid": "087_李斯列传.16.2.s2", "chapter": "087_李斯列传", "para": "16.2", "seq": 2, "text": "赵高治斯，榜掠千馀，不胜痛，自诬服。", "len": 18}
{"sid": "087_李斯列传.16.2.s3", "chapter": "087_李斯列传", "para": "16.2", "seq": 3, "text": "斯所以不死者，自负其辩，有功，实无反心，幸得上书自陈，幸二世之寤而赦之。", "len": 36}
{"sid": "087_李斯列传.16.3.s1", "chapter": "087_李斯列传", "para": "16.3", "seq": 1, "text": "李斯乃从狱中上书曰：“臣为丞相治民，三十馀年矣。", "len": 24}
{"sid": "087_李斯列传.16.3.s2", "chapter": "087_李斯列传", "para": "16.3", "seq": 2, "text": "逮秦地之陕隘。", "len": 7}
{"sid": "087_李斯列传.16.3.s3", "chapter": "087_李斯列传", "para": "16.3", "seq": 3, "text": "先王之时秦地不过千里，兵数十万。", "len": 16}
{"sid": "087_李斯列传.16.3.s4", "chapter": "087_李斯列传", "para": "16.3", "seq": 4, "text": "臣尽薄材，谨奉法令，阴行谋臣，资之金玉，使游说诸侯，阴脩甲兵，饰政教，官斗士，尊功臣，盛其爵禄，故终以胁韩弱魏，破燕、赵，夷齐、楚，卒兼六国，虏其王，立秦为天子。", "len": 81}
{"sid": "087_李斯列传.16.3.s5", "chapter": "087_李斯列传", "para": "16.3", "seq": 5, "text": "罪一矣。", "len": 4}
{"sid": "087_李斯列传.16.3.s6", "chapter": "087_李斯列传", "para": "16.3", "seq": 6, "text": "地不广，又北逐胡、貉，南定百越，以见秦之彊。", "len": 22}
{"sid": "087_李斯列传.16.3.s7", "chapter": "087_李斯列传", "para": "16.3", "seq": 7, "text": "罪二矣。", "len": 4}
{"sid": "087_李斯列传.16.3.s8", "chapter": "087_李斯列传", "para": "16.3", "seq": 8, "text": "尊大臣，盛其爵位，以固其亲。", "len": 14}
{"sid": "087_李斯列传.16.3.s9", "chapter": "087_李斯列传", "para": "16.3", "seq": 9, "text": "罪三矣。", "len": 4}
{"sid": "087_李斯列传.16.3.s10", "chapter": "087_李斯列传", "para": "16.3", "seq": 10, "text": "立社稷，脩宗庙，以明主之贤。", "len": 14}
{"sid": "087_李斯列传.16.3.s11", "chapter": "087_李斯列传", "para": "16.3", "seq": 11, "text": "罪四矣。", "len": 4}
{"sid": "087_李斯列传.16.3.s12", "chapter": "087_李斯列传", "para": "16.3", "seq": 12, "text": "更剋画，平斗斛度量文章，布之天下，以树秦之名。", "len": 23}
{"sid": "087_李斯列传.16.3.s13", "chapter": "087_李斯列传", "para": "16.3", "seq": 13, "text": "罪五矣。", "len": 4}
{"sid": "087_李斯列传.16.3.s14", "chapter": "087_李斯列传", "para": "16.3", "seq": 14, "text": "治驰道，兴游观，以见主之得意。", "len": 15}
{"sid": "087_李斯列传.16.3.s15", "chapter": "087_李斯列传", "para": "16.3", "seq": 15, "text": "罪六矣。", "len": 4}
{"sid": "087_李斯列传.16.3.s16", "chapter": "087_李斯列传", "para": "16.3", "seq": 16, "text": "缓刑罚，薄赋敛，以遂主得众之心，万民戴主，死而不忘。", "len": 26}
{"sid": "087_李斯列传.16.3.s17", "chapter": "087_李斯列传", "para": "16.3", "seq": 17, "text": "罪七矣。", "len": 4}
{"sid": "087_李斯列传.16.3.s18", "chapter": "087_李斯列传", "para": "16.3", "seq": 18, "text": "若斯之为臣者，罪足以死固久矣。", "len": 15}
{"sid": "087_李斯列传.16.3.s19", "chapter": "087_李斯列传", "para": "16.3", "seq": 19, "text": "上幸尽其能力，乃得至今，原陛下察之！", "len": 18}
{"sid": "087_李斯列传.16.3.s20", "chapter": "087_李斯列传", "para": "16.3", "seq": 20, "text": "” 书上，赵高使吏弃去不奏，曰：“囚安得上书！”", "len": 24}
{"sid": "087_李斯列传.16.4.s1", "chapter": "087_李斯列传", "para": "16.4", "seq": 1, "text": "赵高使其客十馀辈诈为御史、谒者、侍中，更往覆讯斯。", "len": 25}
{"sid": "087_李斯列传.16.4.s2", "chapter": "087_李斯列传", "para": "16.4", "seq": 2, "text": "斯更以其实对，辄使人复榜之。", "len": 14}
{"sid": "087_李斯列传.16.4.s3", "chapter": "087_李斯列传", "para": "16.4", "seq": 3, "text": "後二世使人验斯，斯以为如前，终不敢更言，辞服。", "len": 23}
{"sid": "087_李斯列传.16.4.s4", "chapter": "087_李斯列传", "para": "16.4", "seq": 4, "text": "奏当上，二世喜曰：“微赵君，几为丞相所卖。", "len": 21}
{"sid": "087_李斯列传.16.4.s5", "chapter": "087_李斯列传", "para": "16.4", "seq": 5, "text": "” 及二世所使案三川之守至，则项梁已击杀之。", "len": 22}
{"sid": "087_李斯列传.16.4.s6", "chapter": "087_李斯列传", "para": "16.4", "seq": 6, "text": "使者来，会丞相下吏，赵高皆妄为反辞。", "len": 18}
{"sid": "087_李斯列传.17.1.s1", "chapter": "087_李斯列传", "para": "17.1", "seq": 1, "text": "二世二年七月，具斯五刑，论腰斩咸阳市。", "len": 19}
{"sid": "087_李斯列传.17.1.s2", "chapter": "087_李斯列传", "para": "17.1", "seq": 2, "text": "斯出狱，与其中子俱执，顾谓其中子曰：“吾欲与若复牵黄犬俱出上蔡东门逐狡兔，岂可得乎！", "len": 42}
{"sid": "087_李斯列传.17.1.s3", "chapter": "087_李斯列传", "para": "17.1", "seq": 3, "text": "” 遂父子相哭，而夷三族。", "len": 13}
{"sid": "087_李斯列传.18.1.s1", "chapter": "087_李斯列传", "para": "18.1", "seq": 1, "text": "李斯已死，二世拜赵高为中丞相，事无大小辄决於高。", "len": 24}
{"sid": "087_李斯列传.18.1.s2", "chapter": "087_李斯列传", "para": "18.1", "seq": 2, "text": "高自知权重，乃献鹿，谓之马。", "len": 14}
{"sid": "087_李斯列传.18.1.s3", "chapter": "087_李斯列传", "para": "18.1", "seq": 3, "text": "二世问左右：“此乃鹿也？", "len": 12}
{"sid": "087_李斯列传.18.1.s4", "chapter": "087_李斯列传", "para": "18.1", "seq": 4, "text": "” 左右皆曰“马也”。", "len": 11}
{"sid": "087_李斯列传.18.1.s5", "chapter": "087_李斯列传", "para": "18.1", "seq": 5, "text": "二世惊，自以为惑，乃召太卜，令卦之，太卜曰：“陛下春秋郊祀，奉宗庙鬼神，斋戒不明，故至于此。", "len": 46}
{"sid": "087_李斯列传.18.1.s6", "chapter": "087_李斯列传", "para": "18.1", "seq": 6, "text": "可依盛德而明斋戒。", "len": 9}
{"sid": "087_李斯列传.18.1.s7", "chapter": "087_李斯列传", "para": "18.1", "seq": 7, "text": "” 於是乃入上林斋戒。", "len": 11}
{"sid": "087_李斯列传.18.1.s8", "chapter": "087_李斯列传", "para": "18.1", "seq": 8, "text": "日游弋猎，有行人入上林中，二世自射杀之。", "len": 20}
{"sid": "087_李斯列传.18.1.s9", "chapter": "087_李斯列传", "para": "18.1", "seq": 9, "text": "赵高教其女婿咸阳令阎乐劾不知何人贼杀人移上林。", "len": 23}
{"sid": "087_李斯列传.18.1.s10", "chapter": "087_李斯列传", "para": "18.1", "seq": 10, "text": "高乃谏二世曰：“天子无故贼杀不辜人，此上帝之禁也，鬼神不享，天且降殃，当远避宫以禳之。", "len": 43}
{"sid": "087_李斯列传.18.1.s11", "chapter": "087_李斯列传", "para": "18.1", "seq": 11, "text": "” 二世乃出居望夷之宫。", "len": 12}
{"sid": "087_李斯列传.18.2.s1", "chapter": "087_李斯列传", "para": "18.2", "seq": 1, "text": "留三日，赵高诈诏卫士，令士皆素服持兵内乡，入告二世曰：“山东群盗兵大至！", "len": 36}
{"sid": "087_李斯列传.18.2.s2", "chapter": "087_李斯列传", "para": "18.2", "seq": 2, "text": "” 二世上观而见之，恐惧，高既因劫令自杀。", "len": 21}
{"sid": "087_李斯列传.18.2.s3", "chapter": "087_李斯列传", "para": "18.2", "seq": 3, "text": "引玺而佩之，左右百官莫从；上殿，殿欲坏者三。", "len": 22}
{"sid": "087_李斯列传.18.2.s4", "chapter": "087_李斯列传", "para": "18.2", "seq": 4, "text": "高自知天弗与，群臣弗许，乃召始皇弟，授之玺。", "len": 22}
{"sid": "087_李斯列传.19.1.s1", "chapter": "087_李斯列传", "para": "19.1", "seq": 1, "text": "子婴既位，患之，乃称疾不听事，与宦者韩谈及其子谋杀高。", "len": 27}
{"sid": "087_李斯列传.19.1.s2", "chapter": "087_李斯列传", "para": "19.1", "seq": 2, "text": "高上谒，请病，因召入，令韩谈刺杀之，夷其三族。", "len": 23}
{"sid": "087_李斯列传.20.1.s1", "chapter": "087_李斯列传", "para": "20.1", "seq": 1, "text": "子婴立三月，沛公兵从武关入，至咸阳，群臣百官皆畔，不適。", "len": 28}
{"sid": "087_李斯列传.20.1.s2", "chapter": "087_李斯列传", "para": "20.1", "seq": 2, "text": "子婴与妻子自系其颈以组，降轵道旁。", "len": 17}
{"sid": "087_李斯列传.20.1.s3", "chapter": "087_李斯列传", "para": "20.1", "seq": 3, "text": "沛公因以属吏。", "len": 7}
{"sid": "087_李斯列传.20.1.s4", "chapter": "087_李斯列传", "para": "20.1", "seq": 4, "text": "项王至而斩之。", "len": 7}
{"sid": "087_李斯列传.20.1.s5", "chapter": "087_李斯列传", "para": "20.1", "seq": 5, "text": "遂以亡天下。", "len": 6}
{"sid": "087_李斯列传.21.s1", "chapter": "087_李斯列传", "para": "21", "seq": 1, "text": "太史公曰：李斯以闾阎历诸侯，入事秦，因以瑕衅，以辅始皇，卒成帝业，斯为三公，可谓尊用矣。", "len": 44}
{"sid": "087_李斯列传.21.s2", "chapter": "087_李斯列传", "para": "21", "seq": 2, "text": "斯知六之归，不务明政以补主上之缺，持爵禄之重，阿顺苟合，严威酷刑，听高邪说，废適立庶。", "len": 43}
{"sid": "087_李斯列传.21.s3", "chapter": "087_李斯列传", "para": "21", "seq": 3, "text": "诸侯已畔，斯乃欲谏争，不亦末乎！", "len": 16}
{"sid": "087_李斯列传.21.s4", "chapter": "087_李斯列传", "para": "21", "seq": 4, "text": "人皆以斯极忠而被五刑死，察其本，乃与俗议之异。", "len": 23}
{"sid": "087_李斯列传.21.s5", "chapter": "087_李斯列传", "para": "21", "seq": 5, "text": "不然，斯之功且与周、召列矣。", "len": 14}
{"sid": "087_李斯列传.21.s6", "chapter": "087_李斯列传", "para": "21", "seq": 6, "text": "::: 赞", "len": 5}
{"sid": "087_李斯列传.22.s1", "chapter": "087_李斯列传", "para": "22", "seq": 1, "text": "鼠在所居，人固择地。", "len": 10}
{"sid": "087_李斯列传.22.s2", "chapter": "087_李斯列传", "para": "22", "seq": 2, "text": "斯效智力，功立名遂。", "len": 10}
{"sid": "087_李斯列传.22.s3", "chapter": "087_李斯列传", "para": "22", "seq": 3, "text": "置酒咸阳，人臣极位。", "len": 10}
{"sid": "087_李斯列传.22.s4", "chapter": "087_李斯列传", "para": "22", "seq": 4, "text": "一夫诳惑，变易神器。", "len": 10}
{"sid": "087_李斯列传.22.s5", "chapter": "087_李斯列传", "para": "22", "seq": 5, "text": "国丧身诛，本同末异。", "len": 10}
{"sid": "087_李斯列传.22.s6", "chapter": "087_李斯列传", "para": "22", "seq": 6, "text": ":::", "len": 3}
