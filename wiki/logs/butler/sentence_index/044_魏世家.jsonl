{"sid": "044_魏世家.1.s1", "chapter": "044_魏世家", "para": "1", "seq": 1, "text": "魏之先，毕公高之後也。", "len": 11}
{"sid": "044_魏世家.1.s2", "chapter": "044_魏世家", "para": "1", "seq": 2, "text": "毕公高与周同姓。", "len": 8}
{"sid": "044_魏世家.1.s3", "chapter": "044_魏世家", "para": "1", "seq": 3, "text": "武王之伐纣，而高封於毕，於是为毕姓。", "len": 18}
{"sid": "044_魏世家.1.s4", "chapter": "044_魏世家", "para": "1", "seq": 4, "text": "其後绝封，为庶人，或在中国，或在夷狄。", "len": 19}
{"sid": "044_魏世家.1.s5", "chapter": "044_魏世家", "para": "1", "seq": 5, "text": "其苗裔曰毕万，事晋献公。", "len": 12}
{"sid": "044_魏世家.2.s1", "chapter": "044_魏世家", "para": "2", "seq": 1, "text": "献公之十六年，赵夙为御，毕万为右，以伐霍、耿、魏，灭之。", "len": 28}
{"sid": "044_魏世家.2.s2", "chapter": "044_魏世家", "para": "2", "seq": 2, "text": "以耿封赵夙，以魏封毕万，为大夫。", "len": 16}
{"sid": "044_魏世家.2.s3", "chapter": "044_魏世家", "para": "2", "seq": 3, "text": "卜偃曰：“毕万之後必大矣，万，满数也；魏，大名也。", "len": 25}
{"sid": "044_魏世家.2.s4", "chapter": "044_魏世家", "para": "2", "seq": 4, "text": "以是始赏，天开之矣，天子曰兆民，诸侯曰万民。", "len": 22}
{"sid": "044_魏世家.2.s5", "chapter": "044_魏世家", "para": "2", "seq": 5, "text": "今命之大，以从满数，其必有众。", "len": 15}
{"sid": "044_魏世家.2.s6", "chapter": "044_魏世家", "para": "2", "seq": 6, "text": "” 初，毕万卜事晋，遇屯之比。", "len": 15}
{"sid": "044_魏世家.2.s7", "chapter": "044_魏世家", "para": "2", "seq": 7, "text": "辛廖占之，曰：“吉。", "len": 10}
{"sid": "044_魏世家.2.s8", "chapter": "044_魏世家", "para": "2", "seq": 8, "text": "屯固比入，吉孰大焉，其必蕃昌。”", "len": 16}
{"sid": "044_魏世家.3.s1", "chapter": "044_魏世家", "para": "3", "seq": 1, "text": "毕万封十一年，晋献公卒，四子争更立，晋乱。", "len": 21}
{"sid": "044_魏世家.3.s2", "chapter": "044_魏世家", "para": "3", "seq": 2, "text": "而毕万之世弥大，从其国名为魏氏。", "len": 16}
{"sid": "044_魏世家.3.s3", "chapter": "044_魏世家", "para": "3", "seq": 3, "text": "生武子。", "len": 4}
{"sid": "044_魏世家.3.s4", "chapter": "044_魏世家", "para": "3", "seq": 4, "text": "魏武子以魏诸子事晋公子重耳。", "len": 14}
{"sid": "044_魏世家.3.s5", "chapter": "044_魏世家", "para": "3", "seq": 5, "text": "晋献公之二十一年，武子从重耳出亡。", "len": 17}
{"sid": "044_魏世家.3.s6", "chapter": "044_魏世家", "para": "3", "seq": 6, "text": "十九年反，重耳立为晋文公，而令魏武子袭魏氏之後封，列为大夫，治於魏。", "len": 34}
{"sid": "044_魏世家.3.s7", "chapter": "044_魏世家", "para": "3", "seq": 7, "text": "生悼子。", "len": 4}
{"sid": "044_魏世家.4.s1", "chapter": "044_魏世家", "para": "4", "seq": 1, "text": "魏悼子徙治霍。", "len": 7}
{"sid": "044_魏世家.4.s2", "chapter": "044_魏世家", "para": "4", "seq": 2, "text": "生魏绛。", "len": 4}
{"sid": "044_魏世家.5.s1", "chapter": "044_魏世家", "para": "5", "seq": 1, "text": "魏绛事晋悼公。", "len": 7}
{"sid": "044_魏世家.5.s2", "chapter": "044_魏世家", "para": "5", "seq": 2, "text": "悼公三年，会诸侯。", "len": 9}
{"sid": "044_魏世家.5.s3", "chapter": "044_魏世家", "para": "5", "seq": 3, "text": "悼公弟杨干乱行，魏绛僇辱杨干。", "len": 15}
{"sid": "044_魏世家.5.s4", "chapter": "044_魏世家", "para": "5", "seq": 4, "text": "悼公怒曰：”合诸侯以为荣，今辱吾弟！", "len": 18}
{"sid": "044_魏世家.5.s5", "chapter": "044_魏世家", "para": "5", "seq": 5, "text": "” 将诛魏绛。", "len": 7}
{"sid": "044_魏世家.5.s6", "chapter": "044_魏世家", "para": "5", "seq": 6, "text": "或说悼公，悼公止。", "len": 9}
{"sid": "044_魏世家.5.s7", "chapter": "044_魏世家", "para": "5", "seq": 7, "text": "卒任魏绛政，使和戎、翟，戎、翟亲附。", "len": 18}
{"sid": "044_魏世家.5.s8", "chapter": "044_魏世家", "para": "5", "seq": 8, "text": "悼公之十一年，曰：“自吾用魏绛，八年之中，九合诸侯，戎、翟和，子之力也。", "len": 36}
{"sid": "044_魏世家.5.s9", "chapter": "044_魏世家", "para": "5", "seq": 9, "text": "” 赐之乐，三让，然後受之。", "len": 14}
{"sid": "044_魏世家.5.s10", "chapter": "044_魏世家", "para": "5", "seq": 10, "text": "徙治安邑。", "len": 5}
{"sid": "044_魏世家.5.s11", "chapter": "044_魏世家", "para": "5", "seq": 11, "text": "魏绛卒，谥为昭子。", "len": 9}
{"sid": "044_魏世家.5.s12", "chapter": "044_魏世家", "para": "5", "seq": 12, "text": "生魏嬴。", "len": 4}
{"sid": "044_魏世家.5.s13", "chapter": "044_魏世家", "para": "5", "seq": 13, "text": "嬴生魏献子。", "len": 6}
{"sid": "044_魏世家.6.s1", "chapter": "044_魏世家", "para": "6", "seq": 1, "text": "献子事晋昭公。", "len": 7}
{"sid": "044_魏世家.6.s2", "chapter": "044_魏世家", "para": "6", "seq": 2, "text": "昭公卒而六卿彊，公室卑。", "len": 12}
{"sid": "044_魏世家.7.s1", "chapter": "044_魏世家", "para": "7", "seq": 1, "text": "晋顷公之十二年，韩宣子老，魏献子为国政。", "len": 20}
{"sid": "044_魏世家.7.s2", "chapter": "044_魏世家", "para": "7", "seq": 2, "text": "晋宗室祁氏、羊舌氏相恶，六卿诛之，尽取其邑为十县，六卿各令其子为之大夫。", "len": 36}
{"sid": "044_魏世家.7.s3", "chapter": "044_魏世家", "para": "7", "seq": 3, "text": "献子与赵简子、中行文子、范献子并为晋卿。", "len": 20}
{"sid": "044_魏世家.8.s1", "chapter": "044_魏世家", "para": "8", "seq": 1, "text": "其後十四岁而孔子相鲁。", "len": 11}
{"sid": "044_魏世家.8.s2", "chapter": "044_魏世家", "para": "8", "seq": 2, "text": "後四岁，赵简子以晋阳之乱也，而与韩、魏共攻范、中行氏。", "len": 27}
{"sid": "044_魏世家.8.s3", "chapter": "044_魏世家", "para": "8", "seq": 3, "text": "魏献子生魏侈。", "len": 7}
{"sid": "044_魏世家.8.s4", "chapter": "044_魏世家", "para": "8", "seq": 4, "text": "魏侈与赵鞅共攻范、中行氏。", "len": 13}
{"sid": "044_魏世家.9.s1", "chapter": "044_魏世家", "para": "9", "seq": 1, "text": "魏侈之孙曰魏桓子，与韩康子、赵襄子共伐灭知伯，分其地。", "len": 27}
{"sid": "044_魏世家.10.s1", "chapter": "044_魏世家", "para": "10", "seq": 1, "text": "桓子之孙曰文侯都。", "len": 9}
{"sid": "044_魏世家.10.s2", "chapter": "044_魏世家", "para": "10", "seq": 2, "text": "魏文侯元年，秦灵公之元年也。", "len": 14}
{"sid": "044_魏世家.10.s3", "chapter": "044_魏世家", "para": "10", "seq": 3, "text": "与韩武子、赵桓子、周威王同时。", "len": 15}
{"sid": "044_魏世家.11.s1", "chapter": "044_魏世家", "para": "11", "seq": 1, "text": "六年，城少梁。", "len": 7}
{"sid": "044_魏世家.11.s2", "chapter": "044_魏世家", "para": "11", "seq": 2, "text": "十三年，使子击围繁、庞，出其民。", "len": 16}
{"sid": "044_魏世家.11.s3", "chapter": "044_魏世家", "para": "11", "seq": 3, "text": "十六年，伐秦，筑临晋元里。", "len": 13}
{"sid": "044_魏世家.12.s1", "chapter": "044_魏世家", "para": "12", "seq": 1, "text": "十七年，伐中山，使子击守之，赵仓唐傅之。", "len": 20}
{"sid": "044_魏世家.12.s2", "chapter": "044_魏世家", "para": "12", "seq": 2, "text": "子击逢文侯之师田子方於朝歌，引车避，下谒。", "len": 21}
{"sid": "044_魏世家.12.s3", "chapter": "044_魏世家", "para": "12", "seq": 3, "text": "田子方不为礼。", "len": 7}
{"sid": "044_魏世家.12.s4", "chapter": "044_魏世家", "para": "12", "seq": 4, "text": "子击因问曰：“富贵者骄人乎？", "len": 14}
{"sid": "044_魏世家.12.s5", "chapter": "044_魏世家", "para": "12", "seq": 5, "text": "且贫贱者骄人乎？", "len": 8}
{"sid": "044_魏世家.12.s6", "chapter": "044_魏世家", "para": "12", "seq": 6, "text": "” 子方曰：”亦贫贱者骄人耳。", "len": 15}
{"sid": "044_魏世家.12.s7", "chapter": "044_魏世家", "para": "12", "seq": 7, "text": "夫诸侯而骄人则失其国，大夫而骄人则失其家。", "len": 21}
{"sid": "044_魏世家.12.s8", "chapter": "044_魏世家", "para": "12", "seq": 8, "text": "贫贱者，行不合，言不用，则去之楚、越，若脱屣然，柰何其同之哉！", "len": 31}
{"sid": "044_魏世家.12.s9", "chapter": "044_魏世家", "para": "12", "seq": 9, "text": "” 子击不怿而去。", "len": 9}
{"sid": "044_魏世家.12.s10", "chapter": "044_魏世家", "para": "12", "seq": 10, "text": "西攻秦，至郑而还，筑雒阴、合阳。", "len": 16}
{"sid": "044_魏世家.13.s1", "chapter": "044_魏世家", "para": "13", "seq": 1, "text": "二十二年，魏、赵、韩列为诸侯。", "len": 15}
{"sid": "044_魏世家.14.s1", "chapter": "044_魏世家", "para": "14", "seq": 1, "text": "二十四年，秦伐我，至阳狐。", "len": 13}
{"sid": "044_魏世家.15.s1", "chapter": "044_魏世家", "para": "15", "seq": 1, "text": "二十五年，子击生子。", "len": 10}
{"sid": "044_魏世家.16.s1", "chapter": "044_魏世家", "para": "16", "seq": 1, "text": "文侯受子夏经艺，客段干木，过其闾，未尝不轼也。", "len": 23}
{"sid": "044_魏世家.16.s2", "chapter": "044_魏世家", "para": "16", "seq": 2, "text": "秦尝欲伐魏，或曰：“魏君贤人是礼，国人称仁，上下和合，未可图也。", "len": 32}
{"sid": "044_魏世家.16.s3", "chapter": "044_魏世家", "para": "16", "seq": 3, "text": "” 文侯由此得誉於诸侯。", "len": 12}
{"sid": "044_魏世家.17.s1", "chapter": "044_魏世家", "para": "17", "seq": 1, "text": "任西门豹守鄴，而河内称治。", "len": 13}
{"sid": "044_魏世家.18.s1", "chapter": "044_魏世家", "para": "18", "seq": 1, "text": "魏文侯谓李克曰：“先生尝教寡人曰’家贫则思良妻|家贫思良妻，国乱思良相，国乱则思良相’。", "len": 44}
{"sid": "044_魏世家.18.s2", "chapter": "044_魏世家", "para": "18", "seq": 2, "text": "今所置非成则璜，二子何如？", "len": 13}
{"sid": "044_魏世家.18.s3", "chapter": "044_魏世家", "para": "18", "seq": 3, "text": "” 李克对曰：”臣闻之，卑不谋尊，疏不谋戚。", "len": 22}
{"sid": "044_魏世家.18.s4", "chapter": "044_魏世家", "para": "18", "seq": 4, "text": "臣在阙门之外，不敢当命。", "len": 12}
{"sid": "044_魏世家.18.s5", "chapter": "044_魏世家", "para": "18", "seq": 5, "text": "” 文侯曰：”先生临事勿让。", "len": 14}
{"sid": "044_魏世家.18.s6", "chapter": "044_魏世家", "para": "18", "seq": 6, "text": "” 李克曰：”君不察故也。", "len": 13}
{"sid": "044_魏世家.18.s7", "chapter": "044_魏世家", "para": "18", "seq": 7, "text": "居视其所亲，富视其所与，达视其所举，穷视其所不为，贫视其所不取，五者足以定之矣，何待克哉！", "len": 45}
{"sid": "044_魏世家.18.s8", "chapter": "044_魏世家", "para": "18", "seq": 8, "text": "” 文侯曰：“先生就舍，寡人之相定矣。", "len": 19}
{"sid": "044_魏世家.18.s9", "chapter": "044_魏世家", "para": "18", "seq": 9, "text": "” 李克趋而出，过翟璜之家。", "len": 14}
{"sid": "044_魏世家.18.s10", "chapter": "044_魏世家", "para": "18", "seq": 10, "text": "翟璜曰：“今者闻君召先生而卜相，果谁为之？", "len": 21}
{"sid": "044_魏世家.18.s11", "chapter": "044_魏世家", "para": "18", "seq": 11, "text": "” 李克曰：“魏成子为相矣。", "len": 14}
{"sid": "044_魏世家.18.s12", "chapter": "044_魏世家", "para": "18", "seq": 12, "text": "” 翟璜忿然作色曰：“以耳目之所睹记，臣何负於魏成子？", "len": 27}
{"sid": "044_魏世家.18.s13", "chapter": "044_魏世家", "para": "18", "seq": 13, "text": "西河之守，臣之所进也。", "len": 11}
{"sid": "044_魏世家.18.s14", "chapter": "044_魏世家", "para": "18", "seq": 14, "text": "君内以鄴为忧，臣进西门豹。", "len": 13}
{"sid": "044_魏世家.18.s15", "chapter": "044_魏世家", "para": "18", "seq": 15, "text": "君谋欲伐中山，臣进乐羊。", "len": 12}
{"sid": "044_魏世家.18.s16", "chapter": "044_魏世家", "para": "18", "seq": 16, "text": "中山以拔，无使守之，臣进先生。", "len": 15}
{"sid": "044_魏世家.18.s17", "chapter": "044_魏世家", "para": "18", "seq": 17, "text": "君之子无傅，臣进屈侯鲋。", "len": 12}
{"sid": "044_魏世家.18.s18", "chapter": "044_魏世家", "para": "18", "seq": 18, "text": "臣何以负於魏成子！", "len": 9}
{"sid": "044_魏世家.18.s19", "chapter": "044_魏世家", "para": "18", "seq": 19, "text": "” 李克曰：”且子之言克於子之君者，岂将比周以求大官哉？", "len": 28}
{"sid": "044_魏世家.18.s20", "chapter": "044_魏世家", "para": "18", "seq": 20, "text": "君问而置相’非成则璜，二子何如’？", "len": 17}
{"sid": "044_魏世家.18.s21", "chapter": "044_魏世家", "para": "18", "seq": 21, "text": "克对曰：’君不察故也。", "len": 11}
{"sid": "044_魏世家.18.s22", "chapter": "044_魏世家", "para": "18", "seq": 22, "text": "居视其所亲，富视其所与，达视其所举，穷视其所不为，贫视其所不取，五者足以定之矣，何待克哉！", "len": 45}
{"sid": "044_魏世家.18.s23", "chapter": "044_魏世家", "para": "18", "seq": 23, "text": "’是以知魏成子之为相也。", "len": 12}
{"sid": "044_魏世家.18.s24", "chapter": "044_魏世家", "para": "18", "seq": 24, "text": "且子安得与魏成子比乎？", "len": 11}
{"sid": "044_魏世家.18.s25", "chapter": "044_魏世家", "para": "18", "seq": 25, "text": "魏成子以食禄千锺，什九在外，什一在内，是以东得卜子夏、田子方、段干木。", "len": 35}
{"sid": "044_魏世家.18.s26", "chapter": "044_魏世家", "para": "18", "seq": 26, "text": "此三人者，君皆师之。", "len": 10}
{"sid": "044_魏世家.18.s27", "chapter": "044_魏世家", "para": "18", "seq": 27, "text": "子之所进五人者，君皆臣之。", "len": 13}
{"sid": "044_魏世家.18.s28", "chapter": "044_魏世家", "para": "18", "seq": 28, "text": "子恶得与魏成子比也？", "len": 10}
{"sid": "044_魏世家.18.s29", "chapter": "044_魏世家", "para": "18", "seq": 29, "text": "” 翟璜逡巡再拜曰：”璜，鄙人也，失对，原卒为弟子。”", "len": 27}
{"sid": "044_魏世家.19.s1", "chapter": "044_魏世家", "para": "19", "seq": 1, "text": "二十六年，虢山崩，壅河。", "len": 12}
{"sid": "044_魏世家.20.s1", "chapter": "044_魏世家", "para": "20", "seq": 1, "text": "三十二年，伐郑。", "len": 8}
{"sid": "044_魏世家.20.s2", "chapter": "044_魏世家", "para": "20", "seq": 2, "text": "城酸枣。", "len": 4}
{"sid": "044_魏世家.20.s3", "chapter": "044_魏世家", "para": "20", "seq": 3, "text": "败秦于注。", "len": 5}
{"sid": "044_魏世家.20.s4", "chapter": "044_魏世家", "para": "20", "seq": 4, "text": "三十五年，齐伐取我襄陵。", "len": 12}
{"sid": "044_魏世家.20.s5", "chapter": "044_魏世家", "para": "20", "seq": 5, "text": "三十六年，秦侵我阴晋。", "len": 11}
{"sid": "044_魏世家.21.s1", "chapter": "044_魏世家", "para": "21", "seq": 1, "text": "三十八年，伐秦，败我武下，得其将识。", "len": 18}
{"sid": "044_魏世家.21.s2", "chapter": "044_魏世家", "para": "21", "seq": 2, "text": "是岁，文侯卒，子击立，是为武侯。", "len": 16}
{"sid": "044_魏世家.22.s1", "chapter": "044_魏世家", "para": "22", "seq": 1, "text": "魏武侯元年，赵敬侯初立，公子朔为乱，不胜，奔魏，与魏袭邯郸，魏败而去。", "len": 35}
{"sid": "044_魏世家.23.s1", "chapter": "044_魏世家", "para": "23", "seq": 1, "text": "二年，城安邑、王垣。", "len": 10}
{"sid": "044_魏世家.24.s1", "chapter": "044_魏世家", "para": "24", "seq": 1, "text": "七年，伐齐，至桑丘。", "len": 10}
{"sid": "044_魏世家.24.s2", "chapter": "044_魏世家", "para": "24", "seq": 2, "text": "九年，翟败我于澮。", "len": 9}
{"sid": "044_魏世家.24.s3", "chapter": "044_魏世家", "para": "24", "seq": 3, "text": "使吴起伐齐，至灵丘。", "len": 10}
{"sid": "044_魏世家.24.s4", "chapter": "044_魏世家", "para": "24", "seq": 4, "text": "齐威王初立。", "len": 6}
{"sid": "044_魏世家.25.s1", "chapter": "044_魏世家", "para": "25", "seq": 1, "text": "十一年，与韩、赵三分晋地，灭其後。", "len": 17}
{"sid": "044_魏世家.26.s1", "chapter": "044_魏世家", "para": "26", "seq": 1, "text": "十三年，秦献公县栎阳。", "len": 11}
{"sid": "044_魏世家.26.s2", "chapter": "044_魏世家", "para": "26", "seq": 2, "text": "十五年，败赵北蔺。", "len": 9}
{"sid": "044_魏世家.27.s1", "chapter": "044_魏世家", "para": "27", "seq": 1, "text": "十六年，伐楚，取鲁阳。", "len": 11}
{"sid": "044_魏世家.27.s2", "chapter": "044_魏世家", "para": "27", "seq": 2, "text": "武侯卒，子立，是为惠王。", "len": 12}
{"sid": "044_魏世家.28.s1", "chapter": "044_魏世家", "para": "28", "seq": 1, "text": "惠王元年，初，武侯卒也，子与公中缓争为太子。", "len": 22}
{"sid": "044_魏世家.28.s2", "chapter": "044_魏世家", "para": "28", "seq": 2, "text": "公孙颀自宋入赵，自赵入韩，谓韩懿侯曰：“魏与公中缓争为太子，君亦闻之乎？", "len": 36}
{"sid": "044_魏世家.28.s3", "chapter": "044_魏世家", "para": "28", "seq": 3, "text": "今魏得王错，挟上党，固半国也。", "len": 15}
{"sid": "044_魏世家.28.s4", "chapter": "044_魏世家", "para": "28", "seq": 4, "text": "因而除之，破魏必矣，不可失也。", "len": 15}
{"sid": "044_魏世家.28.s5", "chapter": "044_魏世家", "para": "28", "seq": 5, "text": "” 懿侯说，乃与赵成侯合军并兵以伐魏，战于浊泽，魏氏大败，魏君围。", "len": 33}
{"sid": "044_魏世家.28.s6", "chapter": "044_魏世家", "para": "28", "seq": 6, "text": "赵谓韩曰：“除魏君，立公中缓，割地而退，我且利。", "len": 24}
{"sid": "044_魏世家.28.s7", "chapter": "044_魏世家", "para": "28", "seq": 7, "text": "” 韩曰：“不可。", "len": 9}
{"sid": "044_魏世家.28.s8", "chapter": "044_魏世家", "para": "28", "seq": 8, "text": "杀魏君，人必曰暴；割地而退，人必曰贪。", "len": 19}
{"sid": "044_魏世家.28.s9", "chapter": "044_魏世家", "para": "28", "seq": 9, "text": "不如两分之。", "len": 6}
{"sid": "044_魏世家.28.s10", "chapter": "044_魏世家", "para": "28", "seq": 10, "text": "魏分为两，不彊於宋、卫，则我终无魏之患矣。", "len": 21}
{"sid": "044_魏世家.28.s11", "chapter": "044_魏世家", "para": "28", "seq": 11, "text": "” 赵不听。", "len": 6}
{"sid": "044_魏世家.28.s12", "chapter": "044_魏世家", "para": "28", "seq": 12, "text": "韩不说，以其少卒夜去。", "len": 11}
{"sid": "044_魏世家.28.s13", "chapter": "044_魏世家", "para": "28", "seq": 13, "text": "惠王之所以身不死，国不分者，二家谋不和也。", "len": 21}
{"sid": "044_魏世家.28.s14", "chapter": "044_魏世家", "para": "28", "seq": 14, "text": "若从一家之谋，则魏必分矣。", "len": 13}
{"sid": "044_魏世家.28.s15", "chapter": "044_魏世家", "para": "28", "seq": 15, "text": "故曰“君终无適子，其国可破也”。", "len": 16}
{"sid": "044_魏世家.29.s1", "chapter": "044_魏世家", "para": "29", "seq": 1, "text": "二年，魏败韩于马陵，败赵于怀。", "len": 15}
{"sid": "044_魏世家.29.s2", "chapter": "044_魏世家", "para": "29", "seq": 2, "text": "三年，齐败我观。", "len": 8}
{"sid": "044_魏世家.29.s3", "chapter": "044_魏世家", "para": "29", "seq": 3, "text": "五年，与韩会宅阳。", "len": 9}
{"sid": "044_魏世家.29.s4", "chapter": "044_魏世家", "para": "29", "seq": 4, "text": "城武堵。", "len": 4}
{"sid": "044_魏世家.29.s5", "chapter": "044_魏世家", "para": "29", "seq": 5, "text": "为秦所败。", "len": 5}
{"sid": "044_魏世家.29.s6", "chapter": "044_魏世家", "para": "29", "seq": 6, "text": "六年，伐取宋仪台。", "len": 9}
{"sid": "044_魏世家.29.s7", "chapter": "044_魏世家", "para": "29", "seq": 7, "text": "九年，伐败韩于澮。", "len": 9}
{"sid": "044_魏世家.29.s8", "chapter": "044_魏世家", "para": "29", "seq": 8, "text": "与秦战少梁，虏我将公孙痤，取庞。", "len": 16}
{"sid": "044_魏世家.29.s9", "chapter": "044_魏世家", "para": "29", "seq": 9, "text": "秦献公卒，子孝公立。", "len": 10}
{"sid": "044_魏世家.30.s1", "chapter": "044_魏世家", "para": "30", "seq": 1, "text": "十年，伐取赵皮牢。", "len": 9}
{"sid": "044_魏世家.30.s2", "chapter": "044_魏世家", "para": "30", "seq": 2, "text": "彗星见。", "len": 4}
{"sid": "044_魏世家.30.s3", "chapter": "044_魏世家", "para": "30", "seq": 3, "text": "十二年，星昼坠，有声。", "len": 11}
{"sid": "044_魏世家.31.s1", "chapter": "044_魏世家", "para": "31", "seq": 1, "text": "十四年，与赵会鄗。", "len": 9}
{"sid": "044_魏世家.31.s2", "chapter": "044_魏世家", "para": "31", "seq": 2, "text": "十五年，鲁、卫、宋、郑君来朝。", "len": 15}
{"sid": "044_魏世家.31.s3", "chapter": "044_魏世家", "para": "31", "seq": 3, "text": "十六年，与秦孝公会杜平。", "len": 12}
{"sid": "044_魏世家.31.s4", "chapter": "044_魏世家", "para": "31", "seq": 4, "text": "侵宋黄池，宋复取之。", "len": 10}
{"sid": "044_魏世家.32.s1", "chapter": "044_魏世家", "para": "32", "seq": 1, "text": "十七年，与秦战元里，秦取我少梁。", "len": 16}
{"sid": "044_魏世家.32.s2", "chapter": "044_魏世家", "para": "32", "seq": 2, "text": "围赵邯郸。", "len": 5}
{"sid": "044_魏世家.32.s3", "chapter": "044_魏世家", "para": "32", "seq": 3, "text": "十八年，拔邯郸。", "len": 8}
{"sid": "044_魏世家.32.s4", "chapter": "044_魏世家", "para": "32", "seq": 4, "text": "赵请救于齐，齐使田忌、孙膑救赵，败魏桂陵。", "len": 21}
{"sid": "044_魏世家.33.s1", "chapter": "044_魏世家", "para": "33", "seq": 1, "text": "十九年，诸侯围我襄陵。", "len": 11}
{"sid": "044_魏世家.33.s2", "chapter": "044_魏世家", "para": "33", "seq": 2, "text": "筑长城，塞固阳。", "len": 8}
{"sid": "044_魏世家.34.s1", "chapter": "044_魏世家", "para": "34", "seq": 1, "text": "二十年，归赵邯郸，与盟漳水上。", "len": 15}
{"sid": "044_魏世家.34.s2", "chapter": "044_魏世家", "para": "34", "seq": 2, "text": "二十一年，与秦会彤。", "len": 10}
{"sid": "044_魏世家.34.s3", "chapter": "044_魏世家", "para": "34", "seq": 3, "text": "赵成侯卒。", "len": 5}
{"sid": "044_魏世家.34.s4", "chapter": "044_魏世家", "para": "34", "seq": 4, "text": "二十八年，齐威王卒。", "len": 10}
{"sid": "044_魏世家.34.s5", "chapter": "044_魏世家", "para": "34", "seq": 5, "text": "中山君相魏。", "len": 6}
{"sid": "044_魏世家.35.s1", "chapter": "044_魏世家", "para": "35", "seq": 1, "text": "三十年，魏伐赵，赵告急齐。", "len": 13}
{"sid": "044_魏世家.35.s2", "chapter": "044_魏世家", "para": "35", "seq": 2, "text": "齐宣王用孙子计，救赵击魏。", "len": 13}
{"sid": "044_魏世家.35.s3", "chapter": "044_魏世家", "para": "35", "seq": 3, "text": "魏遂大兴师，使庞涓将，而令太子申为上将军。", "len": 21}
{"sid": "044_魏世家.35.s4", "chapter": "044_魏世家", "para": "35", "seq": 4, "text": "过外黄，外黄徐子谓太子曰：“臣有百战百胜之术。", "len": 23}
{"sid": "044_魏世家.35.s5", "chapter": "044_魏世家", "para": "35", "seq": 5, "text": "” 太子曰：“可得闻乎？", "len": 12}
{"sid": "044_魏世家.35.s6", "chapter": "044_魏世家", "para": "35", "seq": 6, "text": "” 客曰：“固原效之。", "len": 11}
{"sid": "044_魏世家.35.s7", "chapter": "044_魏世家", "para": "35", "seq": 7, "text": "” 曰：“太子自将攻齐，大胜并莒，则富不过有魏，贵不益为王。", "len": 30}
{"sid": "044_魏世家.35.s8", "chapter": "044_魏世家", "para": "35", "seq": 8, "text": "若战不胜齐，则万世无魏矣。", "len": 13}
{"sid": "044_魏世家.35.s9", "chapter": "044_魏世家", "para": "35", "seq": 9, "text": "此臣之百战百胜之术也。", "len": 11}
{"sid": "044_魏世家.35.s10", "chapter": "044_魏世家", "para": "35", "seq": 10, "text": "” 太子曰：“诺，请必从公之言而还矣。", "len": 19}
{"sid": "044_魏世家.35.s11", "chapter": "044_魏世家", "para": "35", "seq": 11, "text": "” 客曰：“太子虽欲还，不得矣。", "len": 16}
{"sid": "044_魏世家.35.s12", "chapter": "044_魏世家", "para": "35", "seq": 12, "text": "彼劝太子战攻，欲啜汁者众。", "len": 13}
{"sid": "044_魏世家.35.s13", "chapter": "044_魏世家", "para": "35", "seq": 13, "text": "太子虽欲还，恐不得矣。", "len": 11}
{"sid": "044_魏世家.35.s14", "chapter": "044_魏世家", "para": "35", "seq": 14, "text": "” 太子因欲还，其御曰：“将出而还，与北同。", "len": 22}
{"sid": "044_魏世家.35.s15", "chapter": "044_魏世家", "para": "35", "seq": 15, "text": "” 太子果与齐人战，败於马陵。", "len": 15}
{"sid": "044_魏世家.35.s16", "chapter": "044_魏世家", "para": "35", "seq": 16, "text": "齐虏魏太子申，杀将军庞涓，军遂大破。", "len": 18}
{"sid": "044_魏世家.36.s1", "chapter": "044_魏世家", "para": "36", "seq": 1, "text": "三十一年，秦、赵、齐共伐我，秦将商君诈我将军公子卬而袭夺其军，破之。", "len": 34}
{"sid": "044_魏世家.36.s2", "chapter": "044_魏世家", "para": "36", "seq": 2, "text": "秦用商君，东地至河，而齐、赵数破我，安邑近秦，於是徙治大梁。", "len": 30}
{"sid": "044_魏世家.36.s3", "chapter": "044_魏世家", "para": "36", "seq": 3, "text": "以公子赫为太子。", "len": 8}
{"sid": "044_魏世家.37.s1", "chapter": "044_魏世家", "para": "37", "seq": 1, "text": "三十三年，秦孝公卒，商君亡秦归魏，魏怒，不入。", "len": 23}
{"sid": "044_魏世家.37.s2", "chapter": "044_魏世家", "para": "37", "seq": 2, "text": "三十五年，与齐宣王会平阿南。", "len": 14}
{"sid": "044_魏世家.38.s1", "chapter": "044_魏世家", "para": "38", "seq": 1, "text": "惠王数被於军旅，卑礼厚币以招贤者。", "len": 17}
{"sid": "044_魏世家.38.s2", "chapter": "044_魏世家", "para": "38", "seq": 2, "text": "邹衍、淳于髡、孟轲皆至梁。", "len": 13}
{"sid": "044_魏世家.38.s3", "chapter": "044_魏世家", "para": "38", "seq": 3, "text": "梁惠王曰：“寡人不佞，兵三折於外，太子虏，上将死，国以空虚，以羞先君宗庙社稷，寡人甚丑之，叟不远千里，辱幸至弊邑之廷，将何利吾国？", "len": 65}
{"sid": "044_魏世家.38.s4", "chapter": "044_魏世家", "para": "38", "seq": 4, "text": "” 孟轲曰：“君不可以言利若是。", "len": 16}
{"sid": "044_魏世家.38.s5", "chapter": "044_魏世家", "para": "38", "seq": 5, "text": "夫君欲利则大夫欲利，大夫欲利则庶人欲利，上下争利，国则危矣。", "len": 30}
{"sid": "044_魏世家.38.s6", "chapter": "044_魏世家", "para": "38", "seq": 6, "text": "为人君，仁义而已矣，何以利为！”", "len": 16}
{"sid": "044_魏世家.39.s1", "chapter": "044_魏世家", "para": "39", "seq": 1, "text": "三十六年，复与齐王会甄。", "len": 12}
{"sid": "044_魏世家.39.s2", "chapter": "044_魏世家", "para": "39", "seq": 2, "text": "是岁，惠王卒，子襄王立。", "len": 12}
{"sid": "044_魏世家.40.s1", "chapter": "044_魏世家", "para": "40", "seq": 1, "text": "襄王元年，与诸侯会徐州，相王也。", "len": 16}
{"sid": "044_魏世家.40.s2", "chapter": "044_魏世家", "para": "40", "seq": 2, "text": "追尊父惠王为王。", "len": 8}
{"sid": "044_魏世家.41.s1", "chapter": "044_魏世家", "para": "41", "seq": 1, "text": "五年，秦败我龙贾军四万五千于雕阴，围我焦、曲沃。", "len": 24}
{"sid": "044_魏世家.41.s2", "chapter": "044_魏世家", "para": "41", "seq": 2, "text": "予秦河西之地。", "len": 7}
{"sid": "044_魏世家.42.s1", "chapter": "044_魏世家", "para": "42", "seq": 1, "text": "六年，与秦会应。", "len": 8}
{"sid": "044_魏世家.42.s2", "chapter": "044_魏世家", "para": "42", "seq": 2, "text": "秦取我汾阴、皮氏、焦。", "len": 11}
{"sid": "044_魏世家.42.s3", "chapter": "044_魏世家", "para": "42", "seq": 3, "text": "魏伐楚，败之陉山。", "len": 9}
{"sid": "044_魏世家.42.s4", "chapter": "044_魏世家", "para": "42", "seq": 4, "text": "七年，魏尽入上郡于秦。", "len": 11}
{"sid": "044_魏世家.42.s5", "chapter": "044_魏世家", "para": "42", "seq": 5, "text": "秦降我蒲阳。", "len": 6}
{"sid": "044_魏世家.42.s6", "chapter": "044_魏世家", "para": "42", "seq": 6, "text": "八年，秦归我焦、曲沃。", "len": 11}
{"sid": "044_魏世家.43.s1", "chapter": "044_魏世家", "para": "43", "seq": 1, "text": "十二年，楚败我襄陵。", "len": 10}
{"sid": "044_魏世家.43.s2", "chapter": "044_魏世家", "para": "43", "seq": 2, "text": "诸侯执政与秦相张仪会齧桑。", "len": 13}
{"sid": "044_魏世家.43.s3", "chapter": "044_魏世家", "para": "43", "seq": 3, "text": "十三年，张仪相魏。", "len": 9}
{"sid": "044_魏世家.43.s4", "chapter": "044_魏世家", "para": "43", "seq": 4, "text": "魏有女子化为丈夫。", "len": 9}
{"sid": "044_魏世家.43.s5", "chapter": "044_魏世家", "para": "43", "seq": 5, "text": "秦取我曲沃、平周。", "len": 9}
{"sid": "044_魏世家.44.s1", "chapter": "044_魏世家", "para": "44", "seq": 1, "text": "十六年，襄王卒，子哀王立。", "len": 13}
{"sid": "044_魏世家.44.s2", "chapter": "044_魏世家", "para": "44", "seq": 2, "text": "张仪复归秦。", "len": 6}
{"sid": "044_魏世家.45.s1", "chapter": "044_魏世家", "para": "45", "seq": 1, "text": "哀王元年，五国共攻秦，不胜而去。", "len": 16}
{"sid": "044_魏世家.46.s1", "chapter": "044_魏世家", "para": "46", "seq": 1, "text": "二年，齐败我观津。", "len": 9}
{"sid": "044_魏世家.46.s2", "chapter": "044_魏世家", "para": "46", "seq": 2, "text": "五年，秦使樗里子伐取我曲沃，走犀首岸门。", "len": 20}
{"sid": "044_魏世家.46.s3", "chapter": "044_魏世家", "para": "46", "seq": 3, "text": "六年，秦来立公子政为太子。", "len": 13}
{"sid": "044_魏世家.46.s4", "chapter": "044_魏世家", "para": "46", "seq": 4, "text": "与秦会临晋。", "len": 6}
{"sid": "044_魏世家.46.s5", "chapter": "044_魏世家", "para": "46", "seq": 5, "text": "七年，攻齐。", "len": 6}
{"sid": "044_魏世家.46.s6", "chapter": "044_魏世家", "para": "46", "seq": 6, "text": "与秦伐燕。", "len": 5}
{"sid": "044_魏世家.47.s1", "chapter": "044_魏世家", "para": "47", "seq": 1, "text": "八年，伐卫，拔列城二。", "len": 11}
{"sid": "044_魏世家.47.s2", "chapter": "044_魏世家", "para": "47", "seq": 2, "text": "见卫君曰：“请罢魏兵，免成陵君可乎？", "len": 18}
{"sid": "044_魏世家.47.s3", "chapter": "044_魏世家", "para": "47", "seq": 3, "text": "” 卫君曰：”先生果能，孤请世世以卫事先生。", "len": 22}
{"sid": "044_魏世家.47.s4", "chapter": "044_魏世家", "para": "47", "seq": 4, "text": "” 如耳见成陵君曰：“昔者魏伐赵，断羊肠，拔阏与，约斩赵，赵分而为二，所以不亡者，魏为从主也。", "len": 47}
{"sid": "044_魏世家.47.s5", "chapter": "044_魏世家", "para": "47", "seq": 5, "text": "今卫已迫亡，将西请事於秦。", "len": 13}
{"sid": "044_魏世家.47.s6", "chapter": "044_魏世家", "para": "47", "seq": 6, "text": "与其以秦醳卫，不如以魏醳卫，卫之德魏必终无穷。", "len": 23}
{"sid": "044_魏世家.47.s7", "chapter": "044_魏世家", "para": "47", "seq": 7, "text": "” 成陵君曰：“诺。", "len": 10}
{"sid": "044_魏世家.47.s8", "chapter": "044_魏世家", "para": "47", "seq": 8, "text": "” 如耳见魏王曰：“臣有谒於卫。", "len": 16}
{"sid": "044_魏世家.47.s9", "chapter": "044_魏世家", "para": "47", "seq": 9, "text": "卫故周室之别也，其称小国，多宝器。", "len": 17}
{"sid": "044_魏世家.47.s10", "chapter": "044_魏世家", "para": "47", "seq": 10, "text": "今国迫於难而宝器不出者，其心以为攻卫醳卫不以王为主，故宝器虽出必不入於王也。", "len": 38}
{"sid": "044_魏世家.47.s11", "chapter": "044_魏世家", "para": "47", "seq": 11, "text": "臣窃料之，先言醳卫者必受卫者也。", "len": 16}
{"sid": "044_魏世家.47.s12", "chapter": "044_魏世家", "para": "47", "seq": 12, "text": "” 如耳出，成陵君入，以其言见魏王。", "len": 18}
{"sid": "044_魏世家.47.s13", "chapter": "044_魏世家", "para": "47", "seq": 13, "text": "魏王听其说，罢其兵，免成陵君，终身不见。", "len": 20}
{"sid": "044_魏世家.48.s1", "chapter": "044_魏世家", "para": "48", "seq": 1, "text": "九年，与秦王会临晋。", "len": 10}
{"sid": "044_魏世家.48.s2", "chapter": "044_魏世家", "para": "48", "seq": 2, "text": "张仪、魏章皆归于魏。", "len": 10}
{"sid": "044_魏世家.48.s3", "chapter": "044_魏世家", "para": "48", "seq": 3, "text": "魏相田需死，楚害张仪、犀首、薛公。", "len": 17}
{"sid": "044_魏世家.48.s4", "chapter": "044_魏世家", "para": "48", "seq": 4, "text": "楚相昭鱼谓苏代曰：“田需死，吾恐张仪、犀首、薛公有一人相魏者也。", "len": 32}
{"sid": "044_魏世家.48.s5", "chapter": "044_魏世家", "para": "48", "seq": 5, "text": "” 代曰：”然相者欲谁而君便之？", "len": 16}
{"sid": "044_魏世家.48.s6", "chapter": "044_魏世家", "para": "48", "seq": 6, "text": "” 昭鱼曰：“吾欲太子之自相也。", "len": 16}
{"sid": "044_魏世家.48.s7", "chapter": "044_魏世家", "para": "48", "seq": 7, "text": "” 代曰：”请为君北，必相之。", "len": 15}
{"sid": "044_魏世家.48.s8", "chapter": "044_魏世家", "para": "48", "seq": 8, "text": "” 昭鱼曰：”柰何？", "len": 10}
{"sid": "044_魏世家.48.s9", "chapter": "044_魏世家", "para": "48", "seq": 9, "text": "” 对曰：”君其为梁王，代请说君。", "len": 17}
{"sid": "044_魏世家.48.s10", "chapter": "044_魏世家", "para": "48", "seq": 10, "text": "” 昭鱼曰：”柰何？", "len": 10}
{"sid": "044_魏世家.48.s11", "chapter": "044_魏世家", "para": "48", "seq": 11, "text": "” 对曰：”代也从楚来，昭鱼甚忧，曰：’田需死，吾恐张仪、犀首、薛公有一人相魏者也。", "len": 42}
{"sid": "044_魏世家.48.s12", "chapter": "044_魏世家", "para": "48", "seq": 12, "text": "’代曰：‘梁王，长主也，必不相张仪。", "len": 18}
{"sid": "044_魏世家.48.s13", "chapter": "044_魏世家", "para": "48", "seq": 13, "text": "张仪相，必右秦而左魏。", "len": 11}
{"sid": "044_魏世家.48.s14", "chapter": "044_魏世家", "para": "48", "seq": 14, "text": "犀首相，必右韩而左魏。", "len": 11}
{"sid": "044_魏世家.48.s15", "chapter": "044_魏世家", "para": "48", "seq": 15, "text": "薛公相，必右齐而左魏。", "len": 11}
{"sid": "044_魏世家.48.s16", "chapter": "044_魏世家", "para": "48", "seq": 16, "text": "梁王，长主也，必不便也。", "len": 12}
{"sid": "044_魏世家.48.s17", "chapter": "044_魏世家", "para": "48", "seq": 17, "text": "‘王曰：’然则寡人孰相？", "len": 12}
{"sid": "044_魏世家.48.s18", "chapter": "044_魏世家", "para": "48", "seq": 18, "text": "’代曰：’莫若太子之自相。", "len": 13}
{"sid": "044_魏世家.48.s19", "chapter": "044_魏世家", "para": "48", "seq": 19, "text": "太子之自相，是三人者皆以太子为非常相也，皆将务以其国事魏，欲得丞相玺也。", "len": 36}
{"sid": "044_魏世家.48.s20", "chapter": "044_魏世家", "para": "48", "seq": 20, "text": "以魏之彊，而三万乘之国辅之，魏必安矣。", "len": 19}
{"sid": "044_魏世家.48.s21", "chapter": "044_魏世家", "para": "48", "seq": 21, "text": "故曰莫若太子之自相也。", "len": 11}
{"sid": "044_魏世家.48.s22", "chapter": "044_魏世家", "para": "48", "seq": 22, "text": "‘” 遂北见梁王，以此告之。", "len": 14}
{"sid": "044_魏世家.48.s23", "chapter": "044_魏世家", "para": "48", "seq": 23, "text": "太子果相魏。", "len": 6}
{"sid": "044_魏世家.49.s1", "chapter": "044_魏世家", "para": "49", "seq": 1, "text": "十年，张仪死。", "len": 7}
{"sid": "044_魏世家.49.s2", "chapter": "044_魏世家", "para": "49", "seq": 2, "text": "十一年，与秦武王会应。", "len": 11}
{"sid": "044_魏世家.49.s3", "chapter": "044_魏世家", "para": "49", "seq": 3, "text": "十二年，太子朝於秦。", "len": 10}
{"sid": "044_魏世家.49.s4", "chapter": "044_魏世家", "para": "49", "seq": 4, "text": "秦来伐我皮氏，未拔而解。", "len": 12}
{"sid": "044_魏世家.49.s5", "chapter": "044_魏世家", "para": "49", "seq": 5, "text": "十四年，秦来归武王后。", "len": 11}
{"sid": "044_魏世家.49.s6", "chapter": "044_魏世家", "para": "49", "seq": 6, "text": "十六年，秦拔我蒲反、阳晋、封陵。", "len": 16}
{"sid": "044_魏世家.49.s7", "chapter": "044_魏世家", "para": "49", "seq": 7, "text": "十七年，与秦会临晋。", "len": 10}
{"sid": "044_魏世家.49.s8", "chapter": "044_魏世家", "para": "49", "seq": 8, "text": "秦予我蒲反。", "len": 6}
{"sid": "044_魏世家.49.s9", "chapter": "044_魏世家", "para": "49", "seq": 9, "text": "十八年，与秦伐楚。", "len": 9}
{"sid": "044_魏世家.49.s10", "chapter": "044_魏世家", "para": "49", "seq": 10, "text": "二十一年，与齐、韩共败秦军函谷。", "len": 16}
{"sid": "044_魏世家.50.s1", "chapter": "044_魏世家", "para": "50", "seq": 1, "text": "二十三年，秦复予我河外及封陵为和。", "len": 17}
{"sid": "044_魏世家.50.s2", "chapter": "044_魏世家", "para": "50", "seq": 2, "text": "哀王卒，子昭王立。", "len": 9}
{"sid": "044_魏世家.51.s1", "chapter": "044_魏世家", "para": "51", "seq": 1, "text": "昭王元年，秦拔我襄城。", "len": 11}
{"sid": "044_魏世家.51.s2", "chapter": "044_魏世家", "para": "51", "seq": 2, "text": "二年，与秦战，我不利。", "len": 11}
{"sid": "044_魏世家.51.s3", "chapter": "044_魏世家", "para": "51", "seq": 3, "text": "三年，佐韩攻秦，秦将白起败我军伊阙二十四万。", "len": 22}
{"sid": "044_魏世家.51.s4", "chapter": "044_魏世家", "para": "51", "seq": 4, "text": "六年，予秦河东地方四百里。", "len": 13}
{"sid": "044_魏世家.51.s5", "chapter": "044_魏世家", "para": "51", "seq": 5, "text": "芒卯以诈重。", "len": 6}
{"sid": "044_魏世家.51.s6", "chapter": "044_魏世家", "para": "51", "seq": 6, "text": "七年，秦拔我城大小六十一。", "len": 13}
{"sid": "044_魏世家.51.s7", "chapter": "044_魏世家", "para": "51", "seq": 7, "text": "八年，秦昭王为西帝，齐湣王为东帝，月馀，皆复称王归帝。", "len": 27}
{"sid": "044_魏世家.51.s8", "chapter": "044_魏世家", "para": "51", "seq": 8, "text": "九年，秦拔我新垣、曲阳之城。", "len": 14}
{"sid": "044_魏世家.52.s1", "chapter": "044_魏世家", "para": "52", "seq": 1, "text": "十年，齐灭宋，宋王死我温。", "len": 13}
{"sid": "044_魏世家.52.s2", "chapter": "044_魏世家", "para": "52", "seq": 2, "text": "十二年，与秦、赵、韩、燕共伐齐，败之济西，湣王出亡。", "len": 26}
{"sid": "044_魏世家.52.s3", "chapter": "044_魏世家", "para": "52", "seq": 3, "text": "燕独入临菑。", "len": 6}
{"sid": "044_魏世家.52.s4", "chapter": "044_魏世家", "para": "52", "seq": 4, "text": "与秦王会西周。", "len": 7}
{"sid": "044_魏世家.53.s1", "chapter": "044_魏世家", "para": "53", "seq": 1, "text": "十三年，秦拔我安城。", "len": 10}
{"sid": "044_魏世家.53.s2", "chapter": "044_魏世家", "para": "53", "seq": 2, "text": "兵到大梁，去。", "len": 7}
{"sid": "044_魏世家.53.s3", "chapter": "044_魏世家", "para": "53", "seq": 3, "text": "十八年，秦拔郢，楚王徙陈。", "len": 13}
{"sid": "044_魏世家.54.s1", "chapter": "044_魏世家", "para": "54", "seq": 1, "text": "十九年，昭王卒，子安釐王立。", "len": 14}
{"sid": "044_魏世家.55.s1", "chapter": "044_魏世家", "para": "55", "seq": 1, "text": "安釐王元年，秦拔我两城。", "len": 12}
{"sid": "044_魏世家.55.s2", "chapter": "044_魏世家", "para": "55", "seq": 2, "text": "二年，又拔我二城，军大梁下，韩来救，予秦温以和。", "len": 24}
{"sid": "044_魏世家.55.s3", "chapter": "044_魏世家", "para": "55", "seq": 3, "text": "三年，秦拔我四城，斩首四万。", "len": 14}
{"sid": "044_魏世家.55.s4", "chapter": "044_魏世家", "para": "55", "seq": 4, "text": "四年，秦破我及韩、赵，杀十五万人，走我将芒卯。", "len": 23}
{"sid": "044_魏世家.55.s5", "chapter": "044_魏世家", "para": "55", "seq": 5, "text": "魏将段干子请予秦南阳以和。", "len": 13}
{"sid": "044_魏世家.55.s6", "chapter": "044_魏世家", "para": "55", "seq": 6, "text": "苏代谓魏王曰：“欲玺者段干子也，欲地者秦也。", "len": 22}
{"sid": "044_魏世家.55.s7", "chapter": "044_魏世家", "para": "55", "seq": 7, "text": "今王使欲地者制玺，使欲玺者制地，魏氏地不尽则不知已。", "len": 26}
{"sid": "044_魏世家.55.s8", "chapter": "044_魏世家", "para": "55", "seq": 8, "text": "且夫以地事秦，譬犹抱薪救火，薪不尽，火不灭。", "len": 22}
{"sid": "044_魏世家.55.s9", "chapter": "044_魏世家", "para": "55", "seq": 9, "text": "” 王曰：“是则然也。", "len": 11}
{"sid": "044_魏世家.55.s10", "chapter": "044_魏世家", "para": "55", "seq": 10, "text": "虽然，事始已行，不可更矣。", "len": 13}
{"sid": "044_魏世家.55.s11", "chapter": "044_魏世家", "para": "55", "seq": 11, "text": "” 对曰：“王独不见夫博之所以贵枭者，便则食，不便则止矣。", "len": 29}
{"sid": "044_魏世家.55.s12", "chapter": "044_魏世家", "para": "55", "seq": 12, "text": "今王曰’事始已行，不可更’，是何王之用智不如用枭也？”", "len": 27}
{"sid": "044_魏世家.56.s1", "chapter": "044_魏世家", "para": "56", "seq": 1, "text": "九年，秦拔我怀。", "len": 8}
{"sid": "044_魏世家.56.s2", "chapter": "044_魏世家", "para": "56", "seq": 2, "text": "十年，秦太子外质於魏死。", "len": 12}
{"sid": "044_魏世家.56.s3", "chapter": "044_魏世家", "para": "56", "seq": 3, "text": "十一年，秦拔我郪丘。", "len": 10}
{"sid": "044_魏世家.57.s1", "chapter": "044_魏世家", "para": "57", "seq": 1, "text": "秦昭王谓左右曰：“今时韩、魏与始孰彊？", "len": 19}
{"sid": "044_魏世家.57.s2", "chapter": "044_魏世家", "para": "57", "seq": 2, "text": "” 对曰：“不如始彊。", "len": 11}
{"sid": "044_魏世家.57.s3", "chapter": "044_魏世家", "para": "57", "seq": 3, "text": "” 王曰：“今时如耳、魏齐与孟尝、芒卯孰贤？", "len": 22}
{"sid": "044_魏世家.57.s4", "chapter": "044_魏世家", "para": "57", "seq": 4, "text": "“对曰：“不如。", "len": 8}
{"sid": "044_魏世家.57.s5", "chapter": "044_魏世家", "para": "57", "seq": 5, "text": "“王曰：“以孟尝、芒卯之贤，率彊韩、魏以攻秦，犹无柰寡人何也。", "len": 31}
{"sid": "044_魏世家.57.s6", "chapter": "044_魏世家", "para": "57", "seq": 6, "text": "今以无能之如耳、魏齐而率弱韩、魏以伐秦，其无柰寡人何亦明矣。", "len": 30}
{"sid": "044_魏世家.57.s7", "chapter": "044_魏世家", "para": "57", "seq": 7, "text": "“左右皆曰：“甚然。", "len": 10}
{"sid": "044_魏世家.57.s8", "chapter": "044_魏世家", "para": "57", "seq": 8, "text": "“中旗冯琴而对曰：“王之料天下过矣。", "len": 18}
{"sid": "044_魏世家.57.s9", "chapter": "044_魏世家", "para": "57", "seq": 9, "text": "当晋六卿之时，知氏最彊，灭范、中行，又率韩、魏之兵以围赵襄子於晋阳，决晋水以灌晋阳之城，不湛者三版。", "len": 50}
{"sid": "044_魏世家.57.s10", "chapter": "044_魏世家", "para": "57", "seq": 10, "text": "知伯行水，魏桓子御，韩康子为参乘。", "len": 17}
{"sid": "044_魏世家.57.s11", "chapter": "044_魏世家", "para": "57", "seq": 11, "text": "知伯曰：‘吾始不知水之可以亡人之国也，乃今知之。", "len": 24}
{"sid": "044_魏世家.57.s12", "chapter": "044_魏世家", "para": "57", "seq": 12, "text": "‘汾水可以灌安邑，绛水可以灌平阳。", "len": 17}
{"sid": "044_魏世家.57.s13", "chapter": "044_魏世家", "para": "57", "seq": 13, "text": "魏桓子肘韩康子，韩康子履魏桓子，肘足接於车上，而知氏地分，身死国亡，为天下笑。", "len": 39}
{"sid": "044_魏世家.57.s14", "chapter": "044_魏世家", "para": "57", "seq": 14, "text": "今秦兵虽彊，不能过知氏；韩、魏虽弱，尚贤其在晋阳之下也。", "len": 28}
{"sid": "044_魏世家.57.s15", "chapter": "044_魏世家", "para": "57", "seq": 15, "text": "此方其用肘足之时也，原王之勿易也！", "len": 17}
{"sid": "044_魏世家.57.s16", "chapter": "044_魏世家", "para": "57", "seq": 16, "text": "“於是秦王恐。", "len": 7}
{"sid": "044_魏世家.58.s1", "chapter": "044_魏世家", "para": "58", "seq": 1, "text": "齐、楚相约而攻魏，魏使人求救於秦，冠盖相望也，而秦救不至。", "len": 29}
{"sid": "044_魏世家.58.s2", "chapter": "044_魏世家", "para": "58", "seq": 2, "text": "魏人有唐雎者，年九十馀矣，谓魏王曰：“老臣请西说秦王，令兵先臣出。", "len": 33}
{"sid": "044_魏世家.58.s3", "chapter": "044_魏世家", "para": "58", "seq": 3, "text": "” 魏王再拜，遂约车而遣之。", "len": 14}
{"sid": "044_魏世家.58.s4", "chapter": "044_魏世家", "para": "58", "seq": 4, "text": "唐雎到，入见秦王。", "len": 9}
{"sid": "044_魏世家.58.s5", "chapter": "044_魏世家", "para": "58", "seq": 5, "text": "秦王曰：“丈人芒然乃远至此，甚苦矣！", "len": 18}
{"sid": "044_魏世家.58.s6", "chapter": "044_魏世家", "para": "58", "seq": 6, "text": "夫魏之来求救数矣，寡人知魏之急已。", "len": 17}
{"sid": "044_魏世家.58.s7", "chapter": "044_魏世家", "para": "58", "seq": 7, "text": "” 唐雎对曰：“大王已知魏之急而救不发者，臣窃以为用策之臣无任矣。", "len": 33}
{"sid": "044_魏世家.58.s8", "chapter": "044_魏世家", "para": "58", "seq": 8, "text": "夫魏，一万乘之国也，然所以西面而事秦，称东籓，受冠带，祠春秋者，以秦之彊足以为与也。", "len": 42}
{"sid": "044_魏世家.58.s9", "chapter": "044_魏世家", "para": "58", "seq": 9, "text": "今齐、楚之兵已合於魏郊矣，而秦救不发，亦将赖其未急也。", "len": 27}
{"sid": "044_魏世家.58.s10", "chapter": "044_魏世家", "para": "58", "seq": 10, "text": "使之大急，彼且割地而约从，王尚何救焉？", "len": 19}
{"sid": "044_魏世家.58.s11", "chapter": "044_魏世家", "para": "58", "seq": 11, "text": "必待其急而救之，是失一东籓之魏而彊二敌之齐、楚，则王何利焉？", "len": 30}
{"sid": "044_魏世家.58.s12", "chapter": "044_魏世家", "para": "58", "seq": 12, "text": "” 於是秦昭王遽为发兵救魏。", "len": 14}
{"sid": "044_魏世家.58.s13", "chapter": "044_魏世家", "para": "58", "seq": 13, "text": "魏氏复定。", "len": 5}
{"sid": "044_魏世家.59.s1", "chapter": "044_魏世家", "para": "59", "seq": 1, "text": "赵使人谓魏王曰：“为我杀范痤，吾请献七十里之地。", "len": 24}
{"sid": "044_魏世家.59.s2", "chapter": "044_魏世家", "para": "59", "seq": 2, "text": "” 魏王曰：“诺。", "len": 9}
{"sid": "044_魏世家.59.s3", "chapter": "044_魏世家", "para": "59", "seq": 3, "text": "” 使吏捕之，围而未杀。", "len": 12}
{"sid": "044_魏世家.59.s4", "chapter": "044_魏世家", "para": "59", "seq": 4, "text": "痤因上屋骑危，谓使者曰：“与其以死痤市，不如以生痤市。", "len": 27}
{"sid": "044_魏世家.59.s5", "chapter": "044_魏世家", "para": "59", "seq": 5, "text": "有如痤死，赵不予王地，则王将柰何？", "len": 17}
{"sid": "044_魏世家.59.s6", "chapter": "044_魏世家", "para": "59", "seq": 6, "text": "故不若与先定割地，然後杀痤。", "len": 14}
{"sid": "044_魏世家.59.s7", "chapter": "044_魏世家", "para": "59", "seq": 7, "text": "” 魏王曰：“善。", "len": 9}
{"sid": "044_魏世家.59.s8", "chapter": "044_魏世家", "para": "59", "seq": 8, "text": "” 痤因上书信陵君曰：“痤，故魏之免相也，赵以地杀痤而魏王听之，有如彊秦亦将袭赵之欲，则君且柰何？", "len": 49}
{"sid": "044_魏世家.59.s9", "chapter": "044_魏世家", "para": "59", "seq": 9, "text": "” 信陵君言於王而出之。", "len": 12}
{"sid": "044_魏世家.60.s1", "chapter": "044_魏世家", "para": "60", "seq": 1, "text": "魏王以秦救之故，欲亲秦而伐韩，以求故地。", "len": 20}
{"sid": "044_魏世家.60.s2", "chapter": "044_魏世家", "para": "60", "seq": 2, "text": "无忌谓魏王曰：", "len": 7}
{"sid": "044_魏世家.61.s1", "chapter": "044_魏世家", "para": "61", "seq": 1, "text": "秦与戎翟同俗，有虎狼之心，贪戾好利无信，不识礼义德行。", "len": 27}
{"sid": "044_魏世家.61.s2", "chapter": "044_魏世家", "para": "61", "seq": 2, "text": "苟有利焉，不顾亲戚兄弟，若禽兽耳，此天下之所识也，非有所施厚积德也。", "len": 34}
{"sid": "044_魏世家.61.s3", "chapter": "044_魏世家", "para": "61", "seq": 3, "text": "故太后母也，而以忧死；穰侯舅也，功莫大焉，而竟逐之；两弟无罪，而再夺之国。", "len": 37}
{"sid": "044_魏世家.61.s4", "chapter": "044_魏世家", "para": "61", "seq": 4, "text": "此於亲戚若此，而况於仇雠之国乎？", "len": 16}
{"sid": "044_魏世家.61.s5", "chapter": "044_魏世家", "para": "61", "seq": 5, "text": "今王与秦共伐韩而益近秦患，臣甚惑之。", "len": 18}
{"sid": "044_魏世家.61.s6", "chapter": "044_魏世家", "para": "61", "seq": 6, "text": "而王不识则不明，群臣莫以闻则不忠。", "len": 17}
{"sid": "044_魏世家.62.s1", "chapter": "044_魏世家", "para": "62", "seq": 1, "text": "今韩氏以一女子奉一弱主，内有大乱，外交彊秦魏之兵，王以为不亡乎？", "len": 32}
{"sid": "044_魏世家.62.s2", "chapter": "044_魏世家", "para": "62", "seq": 2, "text": "韩亡，秦有郑地，与大梁鄴，王以为安乎？", "len": 19}
{"sid": "044_魏世家.62.s3", "chapter": "044_魏世家", "para": "62", "seq": 3, "text": "王欲得故地，今负彊秦之亲，王以为利乎？", "len": 19}
{"sid": "044_魏世家.63.s1", "chapter": "044_魏世家", "para": "63", "seq": 1, "text": "秦非无事之国也，韩亡之後必将更事，更事必就易与利，就易与利必不伐楚与赵矣。", "len": 37}
{"sid": "044_魏世家.63.s2", "chapter": "044_魏世家", "para": "63", "seq": 2, "text": "是何也？", "len": 4}
{"sid": "044_魏世家.63.s3", "chapter": "044_魏世家", "para": "63", "seq": 3, "text": "夫越山逾河，绝韩上党而攻彊赵，是复阏与之事，秦必不为也。", "len": 28}
{"sid": "044_魏世家.63.s4", "chapter": "044_魏世家", "para": "63", "seq": 4, "text": "若道河内，倍鄴、朝歌，绝漳滏水，与赵兵决於邯郸之郊，是知伯之祸也，秦又不敢。", "len": 38}
{"sid": "044_魏世家.63.s5", "chapter": "044_魏世家", "para": "63", "seq": 5, "text": "伐楚，道涉谷，行三千里。", "len": 12}
{"sid": "044_魏世家.63.s6", "chapter": "044_魏世家", "para": "63", "seq": 6, "text": "而攻冥阸戹之塞，所行甚远，所攻甚难，秦又不为也。", "len": 24}
{"sid": "044_魏世家.63.s7", "chapter": "044_魏世家", "para": "63", "seq": 7, "text": "若道河外，倍大梁，右上蔡、召陵，与楚兵决於陈郊，秦又不敢。", "len": 29}
{"sid": "044_魏世家.63.s8", "chapter": "044_魏世家", "para": "63", "seq": 8, "text": "故曰秦必不伐楚与赵矣，又不攻卫与齐矣。", "len": 19}
{"sid": "044_魏世家.64.s1", "chapter": "044_魏世家", "para": "64", "seq": 1, "text": "夫韩亡之後，兵出之日，非魏无攻已。", "len": 17}
{"sid": "044_魏世家.64.s2", "chapter": "044_魏世家", "para": "64", "seq": 2, "text": "秦固有怀、茅、邢丘，城垝津以临河内，河内、共、汲。", "len": 25}
{"sid": "044_魏世家.64.s3", "chapter": "044_魏世家", "para": "64", "seq": 3, "text": "必危；有郑地，得垣雍，决荧泽水灌大梁，大梁必亡。", "len": 24}
{"sid": "044_魏世家.64.s4", "chapter": "044_魏世家", "para": "64", "seq": 4, "text": "王之使者出过而恶安陵氏於秦，秦之欲诛之久矣。", "len": 22}
{"sid": "044_魏世家.64.s5", "chapter": "044_魏世家", "para": "64", "seq": 5, "text": "秦叶阳、昆阳与舞阳邻，听使者之恶之，随安陵氏而亡之，绕舞阳之北，以东临许，南国必危，国无害乎？", "len": 47}
{"sid": "044_魏世家.65.s1", "chapter": "044_魏世家", "para": "65", "seq": 1, "text": "夫憎韩不爱安陵氏可也，夫不患秦之不爱南国非也。", "len": 23}
{"sid": "044_魏世家.65.s2", "chapter": "044_魏世家", "para": "65", "seq": 2, "text": "异日者，秦在河西晋，国去梁千里，有河山以阑之，有周韩以间之。", "len": 30}
{"sid": "044_魏世家.65.s3", "chapter": "044_魏世家", "para": "65", "seq": 3, "text": "从林乡军以至于今，秦七攻魏，五入囿中，边城尽拔，文台堕，垂都焚，林木伐，麋鹿尽，而国继以围。", "len": 46}
{"sid": "044_魏世家.65.s4", "chapter": "044_魏世家", "para": "65", "seq": 4, "text": "又长驱梁北，东至陶卫之郊，北至平监。", "len": 18}
{"sid": "044_魏世家.65.s5", "chapter": "044_魏世家", "para": "65", "seq": 5, "text": "所亡於秦者，山南山北，河外河内，大县数十，名都数百。", "len": 26}
{"sid": "044_魏世家.65.s6", "chapter": "044_魏世家", "para": "65", "seq": 6, "text": "秦乃在河西晋，去梁千里，而祸若是矣，又况於使秦无韩，有郑地，无河山而阑之，无周韩而间之，去大梁百里，祸必由此矣。", "len": 56}
{"sid": "044_魏世家.66.s1", "chapter": "044_魏世家", "para": "66", "seq": 1, "text": "异日者，从之不成也，楚、魏疑而韩不可得也。", "len": 21}
{"sid": "044_魏世家.66.s2", "chapter": "044_魏世家", "para": "66", "seq": 2, "text": "今韩受兵三年，秦桡之以讲，识亡不听，投质於赵，请为天下雁行顿刃，楚、赵必集兵，皆识秦之欲无穷也，非尽亡天下之国而臣海内，必不休矣。", "len": 65}
{"sid": "044_魏世家.66.s3", "chapter": "044_魏世家", "para": "66", "seq": 3, "text": "是故臣原以从事王，王速受楚赵之约，而挟韩之质以存韩，而求故地，韩必效之。", "len": 36}
{"sid": "044_魏世家.67.s1", "chapter": "044_魏世家", "para": "67", "seq": 1, "text": "夫存韩安魏而利天下，此亦王之天时已。", "len": 18}
{"sid": "044_魏世家.67.s2", "chapter": "044_魏世家", "para": "67", "seq": 2, "text": "通韩上党於共、甯，使道安成，出入赋之，是魏重质韩以其上党也。", "len": 30}
{"sid": "044_魏世家.67.s3", "chapter": "044_魏世家", "para": "67", "seq": 3, "text": "今有其赋，足以富国。", "len": 10}
{"sid": "044_魏世家.67.s4", "chapter": "044_魏世家", "para": "67", "seq": 4, "text": "韩必德魏爱魏重魏畏魏，韩必不敢反魏，是韩则魏之县也。", "len": 26}
{"sid": "044_魏世家.67.s5", "chapter": "044_魏世家", "para": "67", "seq": 5, "text": "魏得韩以为县，卫、大梁、河外必安矣。", "len": 18}
{"sid": "044_魏世家.67.s6", "chapter": "044_魏世家", "para": "67", "seq": 6, "text": "今不存韩，二周、安陵必危，楚、赵大破，卫、齐甚畏，天下西乡而驰秦入朝而为臣不久矣。", "len": 41}
{"sid": "044_魏世家.68.s1", "chapter": "044_魏世家", "para": "68", "seq": 1, "text": "二十年，秦围邯郸，信陵君无忌矫夺将军晋鄙兵以救赵，赵得全。", "len": 29}
{"sid": "044_魏世家.68.s2", "chapter": "044_魏世家", "para": "68", "seq": 2, "text": "无忌因留赵。", "len": 6}
{"sid": "044_魏世家.68.s3", "chapter": "044_魏世家", "para": "68", "seq": 3, "text": "二十六年，秦昭王卒。", "len": 10}
{"sid": "044_魏世家.69.s1", "chapter": "044_魏世家", "para": "69", "seq": 1, "text": "三十年，无忌归魏，率五国兵攻秦，败之河外，走蒙骜。", "len": 25}
{"sid": "044_魏世家.69.s2", "chapter": "044_魏世家", "para": "69", "seq": 2, "text": "魏太子增质於秦，秦怒，欲囚魏太子增。", "len": 18}
{"sid": "044_魏世家.69.s3", "chapter": "044_魏世家", "para": "69", "seq": 3, "text": "或为增谓秦王曰：“公孙喜固谓魏相曰’请以魏疾击秦，秦王怒，必囚增。", "len": 33}
{"sid": "044_魏世家.69.s4", "chapter": "044_魏世家", "para": "69", "seq": 4, "text": "魏王又怒，击秦，秦必伤’。", "len": 13}
{"sid": "044_魏世家.69.s5", "chapter": "044_魏世家", "para": "69", "seq": 5, "text": "今王囚增，是喜之计中也。", "len": 12}
{"sid": "044_魏世家.69.s6", "chapter": "044_魏世家", "para": "69", "seq": 6, "text": "故不若贵增而合魏，以疑之於齐、韩。", "len": 17}
{"sid": "044_魏世家.69.s7", "chapter": "044_魏世家", "para": "69", "seq": 7, "text": "” 秦乃止增。", "len": 7}
{"sid": "044_魏世家.70.s1", "chapter": "044_魏世家", "para": "70", "seq": 1, "text": "三十一年，秦王政初立。", "len": 11}
{"sid": "044_魏世家.71.s1", "chapter": "044_魏世家", "para": "71", "seq": 1, "text": "三十四年，安釐王卒，太子增立，是为景湣王。", "len": 21}
{"sid": "044_魏世家.71.s2", "chapter": "044_魏世家", "para": "71", "seq": 2, "text": "信陵君无忌卒。", "len": 7}
{"sid": "044_魏世家.72.s1", "chapter": "044_魏世家", "para": "72", "seq": 1, "text": "景湣王元年，秦拔我二十城，以为秦东郡。", "len": 19}
{"sid": "044_魏世家.72.s2", "chapter": "044_魏世家", "para": "72", "seq": 2, "text": "二年，秦拔我朝歌。", "len": 9}
{"sid": "044_魏世家.72.s3", "chapter": "044_魏世家", "para": "72", "seq": 3, "text": "徙野王。", "len": 4}
{"sid": "044_魏世家.72.s4", "chapter": "044_魏世家", "para": "72", "seq": 4, "text": "三年，秦拔我汲。", "len": 8}
{"sid": "044_魏世家.72.s5", "chapter": "044_魏世家", "para": "72", "seq": 5, "text": "五年，秦拔我垣、蒲阳、衍。", "len": 13}
{"sid": "044_魏世家.72.s6", "chapter": "044_魏世家", "para": "72", "seq": 6, "text": "十五年，景湣王卒，子王假立。", "len": 14}
{"sid": "044_魏世家.73.s1", "chapter": "044_魏世家", "para": "73", "seq": 1, "text": "王假元年，燕太子丹使荆轲刺秦王，秦王觉之。", "len": 21}
{"sid": "044_魏世家.74.s1", "chapter": "044_魏世家", "para": "74", "seq": 1, "text": "三年，秦灌大梁，虏王假，遂灭魏以为郡县。", "len": 20}
{"sid": "044_魏世家.75.s1", "chapter": "044_魏世家", "para": "75", "seq": 1, "text": "太史公曰：吾適故大梁之墟，墟中人曰：“秦之破梁，引河沟而灌大梁，三月城坏，王请降，遂灭魏。", "len": 45}
{"sid": "044_魏世家.75.s2", "chapter": "044_魏世家", "para": "75", "seq": 2, "text": "” 说者皆曰魏以不用信陵君故，国削弱至於亡，余以为不然。", "len": 28}
{"sid": "044_魏世家.75.s3", "chapter": "044_魏世家", "para": "75", "seq": 3, "text": "天方令秦平海内，其业未成，魏虽得阿衡之佐，曷益乎？", "len": 25}
{"sid": "044_魏世家.75.s4", "chapter": "044_魏世家", "para": "75", "seq": 4, "text": "::: 赞", "len": 5}
{"sid": "044_魏世家.76.s1", "chapter": "044_魏世家", "para": "76", "seq": 1, "text": "毕公之苗，因国为姓。", "len": 10}
{"sid": "044_魏世家.76.s2", "chapter": "044_魏世家", "para": "76", "seq": 2, "text": "大名始赏，盈数自正。", "len": 10}
{"sid": "044_魏世家.76.s3", "chapter": "044_魏世家", "para": "76", "seq": 3, "text": "胤裔繁昌，系载忠正。", "len": 10}
{"sid": "044_魏世家.76.s4", "chapter": "044_魏世家", "para": "76", "seq": 4, "text": "杨干就戮，智氏奔命。", "len": 10}
{"sid": "044_魏世家.76.s5", "chapter": "044_魏世家", "para": "76", "seq": 5, "text": "文始建侯，武实彊盛。", "len": 10}
{"sid": "044_魏世家.76.s6", "chapter": "044_魏世家", "para": "76", "seq": 6, "text": "大梁东徙，长安北侦。", "len": 10}
{"sid": "044_魏世家.76.s7", "chapter": "044_魏世家", "para": "76", "seq": 7, "text": "卯既无功，卬亦外聘。", "len": 10}
{"sid": "044_魏世家.76.s8", "chapter": "044_魏世家", "para": "76", "seq": 8, "text": "王假削弱，虏於秦政。", "len": 10}
{"sid": "044_魏世家.76.s9", "chapter": "044_魏世家", "para": "76", "seq": 9, "text": ":::", "len": 3}
