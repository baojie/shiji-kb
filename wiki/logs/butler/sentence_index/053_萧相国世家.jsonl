{"sid": "053_萧相国世家.1.s1", "chapter": "053_萧相国世家", "para": "1", "seq": 1, "text": "萧相国何者，沛丰人也。", "len": 11}
{"sid": "053_萧相国世家.1.s2", "chapter": "053_萧相国世家", "para": "1", "seq": 2, "text": "以文无害为沛主吏掾。", "len": 10}
{"sid": "053_萧相国世家.2.s1", "chapter": "053_萧相国世家", "para": "2", "seq": 1, "text": "高祖为布衣时，何数以吏事护高祖。", "len": 16}
{"sid": "053_萧相国世家.2.s2", "chapter": "053_萧相国世家", "para": "2", "seq": 2, "text": "高祖为亭长，常左右之。", "len": 11}
{"sid": "053_萧相国世家.2.s3", "chapter": "053_萧相国世家", "para": "2", "seq": 3, "text": "高祖以吏繇咸阳，吏皆送奉钱三，何独以五。", "len": 20}
{"sid": "053_萧相国世家.3.s1", "chapter": "053_萧相国世家", "para": "3", "seq": 1, "text": "秦御史监郡者与从事，常辨之。", "len": 14}
{"sid": "053_萧相国世家.3.s2", "chapter": "053_萧相国世家", "para": "3", "seq": 2, "text": "何乃给泗水卒史事，第一。", "len": 12}
{"sid": "053_萧相国世家.3.s3", "chapter": "053_萧相国世家", "para": "3", "seq": 3, "text": "秦御史欲入言徵何，何固请，得毋行。", "len": 17}
{"sid": "053_萧相国世家.4.s1", "chapter": "053_萧相国世家", "para": "4", "seq": 1, "text": "及高祖起为沛公，何常为丞督事。", "len": 15}
{"sid": "053_萧相国世家.4.s2", "chapter": "053_萧相国世家", "para": "4", "seq": 2, "text": "沛公至咸阳，诸将皆争走金帛财物之府分之，何独先入收秦丞相御史律令图书藏之。", "len": 37}
{"sid": "053_萧相国世家.4.s3", "chapter": "053_萧相国世家", "para": "4", "seq": 3, "text": "沛公为汉王，以何为丞相。", "len": 12}
{"sid": "053_萧相国世家.4.s4", "chapter": "053_萧相国世家", "para": "4", "seq": 4, "text": "项王与诸侯屠烧咸阳而去。", "len": 12}
{"sid": "053_萧相国世家.4.s5", "chapter": "053_萧相国世家", "para": "4", "seq": 5, "text": "汉王所以具知天下阸戹塞，户口多少，彊弱之处，民所疾苦者，以何具得秦图书也。", "len": 37}
{"sid": "053_萧相国世家.4.s6", "chapter": "053_萧相国世家", "para": "4", "seq": 6, "text": "何进言韩信，汉王以信为大将军。", "len": 15}
{"sid": "053_萧相国世家.4.s7", "chapter": "053_萧相国世家", "para": "4", "seq": 7, "text": "语在淮阴侯事中。", "len": 8}
{"sid": "053_萧相国世家.5.s1", "chapter": "053_萧相国世家", "para": "5", "seq": 1, "text": "汉王引兵东定三秦，何以丞相留收巴蜀，填抚谕告，使给军食。", "len": 28}
{"sid": "053_萧相国世家.5.s2", "chapter": "053_萧相国世家", "para": "5", "seq": 2, "text": "汉二年，汉王与诸侯击楚，何守关中，侍太子，治栎阳。", "len": 25}
{"sid": "053_萧相国世家.5.s3", "chapter": "053_萧相国世家", "para": "5", "seq": 3, "text": "为法令约束，立宗庙社稷宫室县邑，辄奏上，可，许以从事；即不及奏上，辄以便宜施行，上来以闻。", "len": 45}
{"sid": "053_萧相国世家.5.s4", "chapter": "053_萧相国世家", "para": "5", "seq": 4, "text": "关中事计户口转漕给军，汉王数失军遁去，何常兴关中卒，辄补缺。", "len": 30}
{"sid": "053_萧相国世家.5.s5", "chapter": "053_萧相国世家", "para": "5", "seq": 5, "text": "上以此专属任何关中事。", "len": 11}
{"sid": "053_萧相国世家.6.s1", "chapter": "053_萧相国世家", "para": "6", "seq": 1, "text": "汉三年，汉王与项羽相距京索之间，上数使使劳苦丞相。", "len": 25}
{"sid": "053_萧相国世家.6.s2", "chapter": "053_萧相国世家", "para": "6", "seq": 2, "text": "鲍生谓丞相曰：“王暴衣露盖，数使使劳苦君者，有疑君心也。", "len": 28}
{"sid": "053_萧相国世家.6.s3", "chapter": "053_萧相国世家", "para": "6", "seq": 3, "text": "为君计，莫若遣君子孙昆弟能胜兵者悉诣军所，上必益信君。", "len": 27}
{"sid": "053_萧相国世家.6.s4", "chapter": "053_萧相国世家", "para": "6", "seq": 4, "text": "” 於是何从其计，汉王大说。", "len": 14}
{"sid": "053_萧相国世家.7.s1", "chapter": "053_萧相国世家", "para": "7", "seq": 1, "text": "汉五年，既杀项羽，定天下，论功行封。", "len": 18}
{"sid": "053_萧相国世家.7.s2", "chapter": "053_萧相国世家", "para": "7", "seq": 2, "text": "群臣争功，岁馀功不决。", "len": 11}
{"sid": "053_萧相国世家.7.s3", "chapter": "053_萧相国世家", "para": "7", "seq": 3, "text": "高祖以萧何功最盛，封为酂侯，所食邑多。", "len": 19}
{"sid": "053_萧相国世家.7.s4", "chapter": "053_萧相国世家", "para": "7", "seq": 4, "text": "功臣皆曰：“臣等身被坚执锐，多者百馀战，少者数十合，攻城略地，大小各有差。", "len": 37}
{"sid": "053_萧相国世家.7.s5", "chapter": "053_萧相国世家", "para": "7", "seq": 5, "text": "今萧何未尝有汗马之劳，徒持文墨议论，不战，顾反居臣等上，何也？", "len": 31}
{"sid": "053_萧相国世家.7.s6", "chapter": "053_萧相国世家", "para": "7", "seq": 6, "text": "” 高帝曰：“诸君知猎乎？", "len": 13}
{"sid": "053_萧相国世家.7.s7", "chapter": "053_萧相国世家", "para": "7", "seq": 7, "text": "” 曰：“知之。", "len": 8}
{"sid": "053_萧相国世家.7.s8", "chapter": "053_萧相国世家", "para": "7", "seq": 8, "text": "” ” 知猎狗乎？", "len": 9}
{"sid": "053_萧相国世家.7.s9", "chapter": "053_萧相国世家", "para": "7", "seq": 9, "text": "“曰：“知之。", "len": 7}
{"sid": "053_萧相国世家.7.s10", "chapter": "053_萧相国世家", "para": "7", "seq": 10, "text": "“高帝曰：“夫猎，追杀兽兔者狗也，而发踪指示兽处者人也。", "len": 28}
{"sid": "053_萧相国世家.7.s11", "chapter": "053_萧相国世家", "para": "7", "seq": 11, "text": "今诸君徒能得走兽耳，功狗也。", "len": 14}
{"sid": "053_萧相国世家.7.s12", "chapter": "053_萧相国世家", "para": "7", "seq": 12, "text": "至如萧何，发踪指示，功人也。", "len": 14}
{"sid": "053_萧相国世家.7.s13", "chapter": "053_萧相国世家", "para": "7", "seq": 13, "text": "且诸君独以身随我，多者两三人。", "len": 15}
{"sid": "053_萧相国世家.7.s14", "chapter": "053_萧相国世家", "para": "7", "seq": 14, "text": "今萧何举宗数十人皆随我，功不可忘也。", "len": 18}
{"sid": "053_萧相国世家.7.s15", "chapter": "053_萧相国世家", "para": "7", "seq": 15, "text": "“群臣皆莫敢言。", "len": 8}
{"sid": "053_萧相国世家.8.s1", "chapter": "053_萧相国世家", "para": "8", "seq": 1, "text": "列侯毕已受封，及奏位次，皆曰：“平阳侯曹参身被七十创，攻城略地，功最多，宜第一。", "len": 40}
{"sid": "053_萧相国世家.8.s2", "chapter": "053_萧相国世家", "para": "8", "seq": 2, "text": "” 上已桡功臣，多封萧何，至位次未有以复难之，然心欲何第一。", "len": 30}
{"sid": "053_萧相国世家.8.s3", "chapter": "053_萧相国世家", "para": "8", "seq": 3, "text": "关内侯鄂君进曰：“群臣议皆误。", "len": 15}
{"sid": "053_萧相国世家.8.s4", "chapter": "053_萧相国世家", "para": "8", "seq": 4, "text": "夫曹参虽有野战略地之功，此特一时之事。", "len": 19}
{"sid": "053_萧相国世家.8.s5", "chapter": "053_萧相国世家", "para": "8", "seq": 5, "text": "夫上与楚相距五岁，常失军亡众，逃身遁者数矣。", "len": 22}
{"sid": "053_萧相国世家.8.s6", "chapter": "053_萧相国世家", "para": "8", "seq": 6, "text": "然萧何常从关中遣军补其处，非上所诏令召，而数万众会上之乏绝者数矣。", "len": 33}
{"sid": "053_萧相国世家.8.s7", "chapter": "053_萧相国世家", "para": "8", "seq": 7, "text": "夫汉与楚相守荥阳数年，军无见粮，萧何转漕关中，给食不乏。", "len": 28}
{"sid": "053_萧相国世家.8.s8", "chapter": "053_萧相国世家", "para": "8", "seq": 8, "text": "陛下虽数亡山东，萧何常全关中以待陛下，此万世之功也。", "len": 26}
{"sid": "053_萧相国世家.8.s9", "chapter": "053_萧相国世家", "para": "8", "seq": 9, "text": "今虽亡曹参等百数，何缺於汉？", "len": 14}
{"sid": "053_萧相国世家.8.s10", "chapter": "053_萧相国世家", "para": "8", "seq": 10, "text": "汉得之不必待以全。", "len": 9}
{"sid": "053_萧相国世家.8.s11", "chapter": "053_萧相国世家", "para": "8", "seq": 11, "text": "柰何欲以一旦之功而加万世之功哉！", "len": 16}
{"sid": "053_萧相国世家.8.s12", "chapter": "053_萧相国世家", "para": "8", "seq": 12, "text": "萧何第一，曹参次之。", "len": 10}
{"sid": "053_萧相国世家.8.s13", "chapter": "053_萧相国世家", "para": "8", "seq": 13, "text": "” 高祖曰：“善。", "len": 9}
{"sid": "053_萧相国世家.8.s14", "chapter": "053_萧相国世家", "para": "8", "seq": 14, "text": "” 於是乃令萧何，赐带剑履上殿，入朝不趋。", "len": 21}
{"sid": "053_萧相国世家.9.s1", "chapter": "053_萧相国世家", "para": "9", "seq": 1, "text": "上曰：“吾闻进贤受上赏。", "len": 12}
{"sid": "053_萧相国世家.9.s2", "chapter": "053_萧相国世家", "para": "9", "seq": 2, "text": "萧何功虽高，得鄂君乃益明。", "len": 13}
{"sid": "053_萧相国世家.9.s3", "chapter": "053_萧相国世家", "para": "9", "seq": 3, "text": "” 於是因鄂君故所食关内侯邑封为安平侯。", "len": 20}
{"sid": "053_萧相国世家.9.s4", "chapter": "053_萧相国世家", "para": "9", "seq": 4, "text": "是日，悉封何父子兄弟十馀人，皆有食邑。", "len": 19}
{"sid": "053_萧相国世家.9.s5", "chapter": "053_萧相国世家", "para": "9", "seq": 5, "text": "乃益封何二千户，以帝尝繇咸阳时何送我独赢钱二也。", "len": 24}
{"sid": "053_萧相国世家.10.s1", "chapter": "053_萧相国世家", "para": "10", "seq": 1, "text": "汉十一年，陈豨反，高祖自将，至邯郸。", "len": 18}
{"sid": "053_萧相国世家.10.s2", "chapter": "053_萧相国世家", "para": "10", "seq": 2, "text": "未罢，淮阴侯谋反关中，吕后用萧何计，诛淮阴侯，语在淮阴事中。", "len": 30}
{"sid": "053_萧相国世家.10.s3", "chapter": "053_萧相国世家", "para": "10", "seq": 3, "text": "上已闻淮阴侯诛，使使拜丞相何为相国，益封五千户，令卒五百人一都尉为相国卫。", "len": 37}
{"sid": "053_萧相国世家.10.s4", "chapter": "053_萧相国世家", "para": "10", "seq": 4, "text": "诸君皆贺，召平独吊。", "len": 10}
{"sid": "053_萧相国世家.10.s5", "chapter": "053_萧相国世家", "para": "10", "seq": 5, "text": "召平者，故秦东陵侯。", "len": 10}
{"sid": "053_萧相国世家.10.s6", "chapter": "053_萧相国世家", "para": "10", "seq": 6, "text": "秦破，为布衣，贫，种瓜於长安城东，瓜美，故世俗谓之“东陵瓜”，从召平以为名也。", "len": 39}
{"sid": "053_萧相国世家.10.s7", "chapter": "053_萧相国世家", "para": "10", "seq": 7, "text": "召平谓相国曰：“祸自此始矣。", "len": 14}
{"sid": "053_萧相国世家.10.s8", "chapter": "053_萧相国世家", "para": "10", "seq": 8, "text": "上暴露於外而君守於中，非被矢石之事而益君封置卫者，以今者淮阴侯新反於中，疑君心矣。", "len": 41}
{"sid": "053_萧相国世家.10.s9", "chapter": "053_萧相国世家", "para": "10", "seq": 9, "text": "夫置卫卫君，非以宠君也。", "len": 12}
{"sid": "053_萧相国世家.10.s10", "chapter": "053_萧相国世家", "para": "10", "seq": 10, "text": "原君让封勿受，悉以家私财佐军，则上心说。", "len": 20}
{"sid": "053_萧相国世家.10.s11", "chapter": "053_萧相国世家", "para": "10", "seq": 11, "text": "” 相国从其计，高帝乃大喜。", "len": 14}
{"sid": "053_萧相国世家.11.s1", "chapter": "053_萧相国世家", "para": "11", "seq": 1, "text": "汉十二年秋，黥布反，上自将击之，数使使问相国何为。", "len": 25}
{"sid": "053_萧相国世家.11.s2", "chapter": "053_萧相国世家", "para": "11", "seq": 2, "text": "相国为上在军，乃拊循勉力百姓，悉以所有佐军，如陈豨时。", "len": 27}
{"sid": "053_萧相国世家.11.s3", "chapter": "053_萧相国世家", "para": "11", "seq": 3, "text": "客有说相国曰：“君灭族不久矣。", "len": 15}
{"sid": "053_萧相国世家.11.s4", "chapter": "053_萧相国世家", "para": "11", "seq": 4, "text": "夫君位为相国，功第一，可复加哉？", "len": 16}
{"sid": "053_萧相国世家.11.s5", "chapter": "053_萧相国世家", "para": "11", "seq": 5, "text": "然君初入关中，得百姓心，十馀年矣，皆附君，常复孳孳得民和。", "len": 29}
{"sid": "053_萧相国世家.11.s6", "chapter": "053_萧相国世家", "para": "11", "seq": 6, "text": "上所为数问君者，畏君倾动关中。", "len": 15}
{"sid": "053_萧相国世家.11.s7", "chapter": "053_萧相国世家", "para": "11", "seq": 7, "text": "今君胡不多买田地，贱贳贷以自汙？", "len": 16}
{"sid": "053_萧相国世家.11.s8", "chapter": "053_萧相国世家", "para": "11", "seq": 8, "text": "上心乃安。", "len": 5}
{"sid": "053_萧相国世家.11.s9", "chapter": "053_萧相国世家", "para": "11", "seq": 9, "text": "” 於是相国从其计，上乃大说。", "len": 15}
{"sid": "053_萧相国世家.12.s1", "chapter": "053_萧相国世家", "para": "12", "seq": 1, "text": "上罢布军归，民道遮行上书，言相国贱彊买民田宅数千万。", "len": 26}
{"sid": "053_萧相国世家.12.s2", "chapter": "053_萧相国世家", "para": "12", "seq": 2, "text": "上至，相国谒。", "len": 7}
{"sid": "053_萧相国世家.12.s3", "chapter": "053_萧相国世家", "para": "12", "seq": 3, "text": "上笑曰：“夫相国乃利民！", "len": 12}
{"sid": "053_萧相国世家.12.s4", "chapter": "053_萧相国世家", "para": "12", "seq": 4, "text": "” 民所上书皆以与相国，曰：“君自谢民。", "len": 20}
{"sid": "053_萧相国世家.12.s5", "chapter": "053_萧相国世家", "para": "12", "seq": 5, "text": "” 相国因为民请曰：“长安地狭，上林中多空地，弃，原令民得入田，毋收稾为禽兽食。", "len": 40}
{"sid": "053_萧相国世家.12.s6", "chapter": "053_萧相国世家", "para": "12", "seq": 6, "text": "” 上大怒曰：“相国多受贾人财物，乃为请吾苑！", "len": 23}
{"sid": "053_萧相国世家.12.s7", "chapter": "053_萧相国世家", "para": "12", "seq": 7, "text": "” 乃下相国廷尉，械系之。", "len": 13}
{"sid": "053_萧相国世家.12.s8", "chapter": "053_萧相国世家", "para": "12", "seq": 8, "text": "数日，王卫尉侍，前问曰：“相国何大罪，陛下系之暴也？", "len": 26}
{"sid": "053_萧相国世家.12.s9", "chapter": "053_萧相国世家", "para": "12", "seq": 9, "text": "” 上曰：“吾闻李斯相秦皇帝，有善归主，有恶自与。", "len": 25}
{"sid": "053_萧相国世家.12.s10", "chapter": "053_萧相国世家", "para": "12", "seq": 10, "text": "今相国多受贾竖金而为民请吾苑，以自媚於民，故系治之。", "len": 26}
{"sid": "053_萧相国世家.12.s11", "chapter": "053_萧相国世家", "para": "12", "seq": 11, "text": "” 王卫尉曰：“夫职事苟有便於民而请之，真宰相事，陛下柰何乃疑相国受贾人钱乎！", "len": 39}
{"sid": "053_萧相国世家.12.s12", "chapter": "053_萧相国世家", "para": "12", "seq": 12, "text": "且陛下距楚数岁，陈豨、黥布反，陛下自将而往，当是时，相国守关中，摇足则关以西非陛下有也。", "len": 44}
{"sid": "053_萧相国世家.12.s13", "chapter": "053_萧相国世家", "para": "12", "seq": 13, "text": "相国不以此时为利，今乃利贾人之金乎？", "len": 18}
{"sid": "053_萧相国世家.12.s14", "chapter": "053_萧相国世家", "para": "12", "seq": 14, "text": "且秦以不闻其过亡天下，李斯之分过，又何足法哉。", "len": 23}
{"sid": "053_萧相国世家.12.s15", "chapter": "053_萧相国世家", "para": "12", "seq": 15, "text": "陛下何疑宰相之浅也。", "len": 10}
{"sid": "053_萧相国世家.12.s16", "chapter": "053_萧相国世家", "para": "12", "seq": 16, "text": "” 高帝不怿。", "len": 7}
{"sid": "053_萧相国世家.12.s17", "chapter": "053_萧相国世家", "para": "12", "seq": 17, "text": "是日，使使持节赦出相国。", "len": 12}
{"sid": "053_萧相国世家.12.s18", "chapter": "053_萧相国世家", "para": "12", "seq": 18, "text": "相国年老，素恭谨，入，徒跣谢。", "len": 15}
{"sid": "053_萧相国世家.12.s19", "chapter": "053_萧相国世家", "para": "12", "seq": 19, "text": "高帝曰：“相国休矣！", "len": 10}
{"sid": "053_萧相国世家.12.s20", "chapter": "053_萧相国世家", "para": "12", "seq": 20, "text": "相国为民请苑，吾不许，我不过为桀纣主，而相国为贤相。", "len": 26}
{"sid": "053_萧相国世家.12.s21", "chapter": "053_萧相国世家", "para": "12", "seq": 21, "text": "吾故系相国，欲令百姓闻吾过也。”", "len": 16}
{"sid": "053_萧相国世家.13.s1", "chapter": "053_萧相国世家", "para": "13", "seq": 1, "text": "何素不与曹参相能，及何病，孝惠自临视相国病，因问曰：“君即百岁後，谁可代君者？", "len": 39}
{"sid": "053_萧相国世家.13.s2", "chapter": "053_萧相国世家", "para": "13", "seq": 2, "text": "” 对曰：“知臣莫如主。", "len": 12}
{"sid": "053_萧相国世家.13.s3", "chapter": "053_萧相国世家", "para": "13", "seq": 3, "text": "” 孝惠曰：“曹参何如？", "len": 12}
{"sid": "053_萧相国世家.13.s4", "chapter": "053_萧相国世家", "para": "13", "seq": 4, "text": "” 何顿首曰：“帝得之矣！", "len": 13}
{"sid": "053_萧相国世家.13.s5", "chapter": "053_萧相国世家", "para": "13", "seq": 5, "text": "臣死不恨矣！”", "len": 7}
{"sid": "053_萧相国世家.14.s1", "chapter": "053_萧相国世家", "para": "14", "seq": 1, "text": "何置田宅必居穷处，为家不治垣屋。", "len": 16}
{"sid": "053_萧相国世家.14.s2", "chapter": "053_萧相国世家", "para": "14", "seq": 2, "text": "曰：“後世贤，师吾俭；不贤，毋为势家所夺。”", "len": 22}
{"sid": "053_萧相国世家.15.s1", "chapter": "053_萧相国世家", "para": "15", "seq": 1, "text": "孝惠二年，相国何卒，谥为文终侯。", "len": 16}
{"sid": "053_萧相国世家.16.s1", "chapter": "053_萧相国世家", "para": "16", "seq": 1, "text": "後嗣以罪失侯者四世，绝，天子辄复求何後，封续酂侯，功臣莫得比焉。", "len": 32}
{"sid": "053_萧相国世家.16.s2", "chapter": "053_萧相国世家", "para": "16", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "053_萧相国世家.17.s1", "chapter": "053_萧相国世家", "para": "17", "seq": 1, "text": "太史公曰：萧相国何於秦时为刀笔吏，录录未有奇节。", "len": 24}
{"sid": "053_萧相国世家.17.s2", "chapter": "053_萧相国世家", "para": "17", "seq": 2, "text": "及汉兴，依日月之末光，何谨守管籥，因民之疾法，顺流与之更始。", "len": 30}
{"sid": "053_萧相国世家.17.s3", "chapter": "053_萧相国世家", "para": "17", "seq": 3, "text": "淮阴、黥布等皆以诛灭，而何之勋烂焉。", "len": 18}
{"sid": "053_萧相国世家.17.s4", "chapter": "053_萧相国世家", "para": "17", "seq": 4, "text": "位冠群臣，声施後世，与闳夭、散宜生等争烈矣。", "len": 22}
{"sid": "053_萧相国世家.17.s5", "chapter": "053_萧相国世家", "para": "17", "seq": 5, "text": "::: ::: 赞", "len": 9}
{"sid": "053_萧相国世家.18.s1", "chapter": "053_萧相国世家", "para": "18", "seq": 1, "text": "萧何为吏，文而无害。", "len": 10}
{"sid": "053_萧相国世家.18.s2", "chapter": "053_萧相国世家", "para": "18", "seq": 2, "text": "及佐兴王，举宗从沛。", "len": 10}
{"sid": "053_萧相国世家.18.s3", "chapter": "053_萧相国世家", "para": "18", "seq": 3, "text": "关中既守，转输是赖。", "len": 10}
{"sid": "053_萧相国世家.18.s4", "chapter": "053_萧相国世家", "para": "18", "seq": 4, "text": "汉军屡疲，秦兵必会。", "len": 10}
{"sid": "053_萧相国世家.18.s5", "chapter": "053_萧相国世家", "para": "18", "seq": 5, "text": "约法可久，收图可大。", "len": 10}
{"sid": "053_萧相国世家.18.s6", "chapter": "053_萧相国世家", "para": "18", "seq": 6, "text": "指兽发踪，其功实最。", "len": 10}
{"sid": "053_萧相国世家.18.s7", "chapter": "053_萧相国世家", "para": "18", "seq": 7, "text": "政称画一，居乃非泰。", "len": 10}
{"sid": "053_萧相国世家.18.s8", "chapter": "053_萧相国世家", "para": "18", "seq": 8, "text": "继绝宠勤，式旌砺带。", "len": 10}
{"sid": "053_萧相国世家.18.s9", "chapter": "053_萧相国世家", "para": "18", "seq": 9, "text": ":::", "len": 3}
