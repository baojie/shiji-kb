{"sid": "046_田敬仲完世家.1.1.s1", "chapter": "046_田敬仲完世家", "para": "1.1", "seq": 1, "text": "陈完者，陈厉公他之子也。", "len": 12}
{"sid": "046_田敬仲完世家.1.1.s2", "chapter": "046_田敬仲完世家", "para": "1.1", "seq": 2, "text": "完生，周太史过陈，陈厉公使卜完，卦得观之否：“是为观国之光，利用宾于王。", "len": 36}
{"sid": "046_田敬仲完世家.1.1.s3", "chapter": "046_田敬仲完世家", "para": "1.1", "seq": 3, "text": "此其代陈有国乎？", "len": 8}
{"sid": "046_田敬仲完世家.1.1.s4", "chapter": "046_田敬仲完世家", "para": "1.1", "seq": 4, "text": "不在此而在异国乎？", "len": 9}
{"sid": "046_田敬仲完世家.1.1.s5", "chapter": "046_田敬仲完世家", "para": "1.1", "seq": 5, "text": "非此其身也，在其子孙。", "len": 11}
{"sid": "046_田敬仲完世家.1.1.s6", "chapter": "046_田敬仲完世家", "para": "1.1", "seq": 6, "text": "若在异国，必姜姓。", "len": 9}
{"sid": "046_田敬仲完世家.1.1.s7", "chapter": "046_田敬仲完世家", "para": "1.1", "seq": 7, "text": "姜姓，四岳之後。", "len": 8}
{"sid": "046_田敬仲完世家.1.1.s8", "chapter": "046_田敬仲完世家", "para": "1.1", "seq": 8, "text": "物莫能两大，陈衰，此其昌乎？”", "len": 15}
{"sid": "046_田敬仲完世家.2.1.s1", "chapter": "046_田敬仲完世家", "para": "2.1", "seq": 1, "text": "厉公者，陈文公少子也，其母蔡女。", "len": 16}
{"sid": "046_田敬仲完世家.2.1.s2", "chapter": "046_田敬仲完世家", "para": "2.1", "seq": 2, "text": "文公卒，厉公兄鲍立，是为桓公。", "len": 15}
{"sid": "046_田敬仲完世家.2.1.s3", "chapter": "046_田敬仲完世家", "para": "2.1", "seq": 3, "text": "桓公与他异母。", "len": 7}
{"sid": "046_田敬仲完世家.2.1.s4", "chapter": "046_田敬仲完世家", "para": "2.1", "seq": 4, "text": "及桓公病，蔡人为他杀桓公鲍及太子免而立他，为厉公。", "len": 25}
{"sid": "046_田敬仲完世家.2.1.s5", "chapter": "046_田敬仲完世家", "para": "2.1", "seq": 5, "text": "厉公既立，娶蔡女。", "len": 9}
{"sid": "046_田敬仲完世家.2.1.s6", "chapter": "046_田敬仲完世家", "para": "2.1", "seq": 6, "text": "蔡女淫於蔡人，数归，厉公亦数如蔡。", "len": 17}
{"sid": "046_田敬仲完世家.2.1.s7", "chapter": "046_田敬仲完世家", "para": "2.1", "seq": 7, "text": "桓公之少子林怨厉公杀其父与兄，乃令蔡人诱厉公而杀之。", "len": 26}
{"sid": "046_田敬仲完世家.2.1.s8", "chapter": "046_田敬仲完世家", "para": "2.1", "seq": 8, "text": "林自立，是为庄公。", "len": 9}
{"sid": "046_田敬仲完世家.2.1.s9", "chapter": "046_田敬仲完世家", "para": "2.1", "seq": 9, "text": "故陈完不得立，为陈大夫。", "len": 12}
{"sid": "046_田敬仲完世家.2.1.s10", "chapter": "046_田敬仲完世家", "para": "2.1", "seq": 10, "text": "厉公之杀，以淫出国，故春秋曰“蔡人杀陈他”，罪之也。", "len": 26}
{"sid": "046_田敬仲完世家.3.1.s1", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 1, "text": "庄公卒，立弟杵臼，是为宣公。", "len": 14}
{"sid": "046_田敬仲完世家.3.1.s2", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 2, "text": "宣公二十一年，杀其太子御寇。", "len": 14}
{"sid": "046_田敬仲完世家.3.1.s3", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 3, "text": "御寇与完相爱，恐祸及己，完故奔齐。", "len": 17}
{"sid": "046_田敬仲完世家.3.1.s4", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 4, "text": "齐桓公欲使为卿，辞曰：“羁旅之臣幸得免负檐，君之惠也，不敢当高位。", "len": 33}
{"sid": "046_田敬仲完世家.3.1.s5", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 5, "text": "” 桓公使为工正。", "len": 9}
{"sid": "046_田敬仲完世家.3.1.s6", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 6, "text": "齐懿仲欲妻完，卜之，占曰：“是谓凤皇于蜚，和鸣锵锵。", "len": 26}
{"sid": "046_田敬仲完世家.3.1.s7", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 7, "text": "有妫之後，将育于姜。", "len": 10}
{"sid": "046_田敬仲完世家.3.1.s8", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 8, "text": "五世其昌，并于正卿。", "len": 10}
{"sid": "046_田敬仲完世家.3.1.s9", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 9, "text": "八世之後，莫之与京。", "len": 10}
{"sid": "046_田敬仲完世家.3.1.s10", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 10, "text": "” 卒妻完。", "len": 6}
{"sid": "046_田敬仲完世家.3.1.s11", "chapter": "046_田敬仲完世家", "para": "3.1", "seq": 11, "text": "完之奔齐，齐桓公立十四年矣。", "len": 14}
{"sid": "046_田敬仲完世家.3.2.s1", "chapter": "046_田敬仲完世家", "para": "3.2", "seq": 1, "text": "完卒，谥为敬仲。", "len": 8}
{"sid": "046_田敬仲完世家.3.2.s2", "chapter": "046_田敬仲完世家", "para": "3.2", "seq": 2, "text": "仲生孟夷。", "len": 5}
{"sid": "046_田敬仲完世家.3.2.s3", "chapter": "046_田敬仲完世家", "para": "3.2", "seq": 3, "text": "敬仲之如齐，以陈字为田氏。", "len": 13}
{"sid": "046_田敬仲完世家.4.1.s1", "chapter": "046_田敬仲完世家", "para": "4.1", "seq": 1, "text": "田孟夷生湣孟庄，田湣孟庄生文子须无。", "len": 18}
{"sid": "046_田敬仲完世家.4.1.s2", "chapter": "046_田敬仲完世家", "para": "4.1", "seq": 2, "text": "田文子事齐庄公。", "len": 8}
{"sid": "046_田敬仲完世家.4.2.s1", "chapter": "046_田敬仲完世家", "para": "4.2", "seq": 1, "text": "晋之大夫栾逞作乱於晋，来奔齐，齐庄公厚客之。", "len": 22}
{"sid": "046_田敬仲完世家.4.2.s2", "chapter": "046_田敬仲完世家", "para": "4.2", "seq": 2, "text": "晏婴与田文子谏，庄公弗听。", "len": 13}
{"sid": "046_田敬仲完世家.4.3.s1", "chapter": "046_田敬仲完世家", "para": "4.3", "seq": 1, "text": "文子卒，生桓子无宇。", "len": 10}
{"sid": "046_田敬仲完世家.4.3.s2", "chapter": "046_田敬仲完世家", "para": "4.3", "seq": 2, "text": "田桓子无宇有力，事齐庄公，甚有宠。", "len": 17}
{"sid": "046_田敬仲完世家.5.1.s1", "chapter": "046_田敬仲完世家", "para": "5.1", "seq": 1, "text": "无宇卒，生武子开与釐子乞。", "len": 13}
{"sid": "046_田敬仲完世家.5.1.s2", "chapter": "046_田敬仲完世家", "para": "5.1", "seq": 2, "text": "田釐子乞事齐景公为大夫，其收赋税於民以小斗受之，其禀予民以大斗，行阴德於民，而景公弗禁。", "len": 44}
{"sid": "046_田敬仲完世家.5.1.s3", "chapter": "046_田敬仲完世家", "para": "5.1", "seq": 3, "text": "由此田氏得齐众心，宗族益彊，民思田氏。", "len": 19}
{"sid": "046_田敬仲完世家.5.1.s4", "chapter": "046_田敬仲完世家", "para": "5.1", "seq": 4, "text": "晏子数谏景公，景公弗听。", "len": 12}
{"sid": "046_田敬仲完世家.5.1.s5", "chapter": "046_田敬仲完世家", "para": "5.1", "seq": 5, "text": "已而使於晋，与叔向私语曰：“齐国之政卒归於田氏矣。”", "len": 26}
{"sid": "046_田敬仲完世家.5.2.s1", "chapter": "046_田敬仲完世家", "para": "5.2", "seq": 1, "text": "晏婴卒後，范、中行氏反晋。", "len": 13}
{"sid": "046_田敬仲完世家.5.2.s2", "chapter": "046_田敬仲完世家", "para": "5.2", "seq": 2, "text": "晋攻之急，范、中行请粟於齐。", "len": 14}
{"sid": "046_田敬仲完世家.5.2.s3", "chapter": "046_田敬仲完世家", "para": "5.2", "seq": 3, "text": "田乞欲为乱，树党於诸侯，乃说景公曰：“范、中行数有德於齐，齐不可不救。", "len": 35}
{"sid": "046_田敬仲完世家.5.2.s4", "chapter": "046_田敬仲完世家", "para": "5.2", "seq": 4, "text": "” 齐使田乞救之而输之粟。", "len": 13}
{"sid": "046_田敬仲完世家.6.1.s1", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 1, "text": "景公太子死，後有宠姬曰芮子，生子荼。", "len": 18}
{"sid": "046_田敬仲完世家.6.1.s2", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 2, "text": "景公病，命其相国惠子与高昭子以子荼为太子。", "len": 21}
{"sid": "046_田敬仲完世家.6.1.s3", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 3, "text": "景公卒，两相高、国立荼，是为晏孺子。", "len": 18}
{"sid": "046_田敬仲完世家.6.1.s4", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 4, "text": "而田乞不说，欲立景公他子阳生。", "len": 15}
{"sid": "046_田敬仲完世家.6.1.s5", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 5, "text": "阳生素与乞欢。", "len": 7}
{"sid": "046_田敬仲完世家.6.1.s6", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 6, "text": "晏孺子之立也，阳生奔鲁。", "len": 12}
{"sid": "046_田敬仲完世家.6.1.s7", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 7, "text": "田乞伪事高昭子、国惠子者，每朝代参乘，言曰：“始诸大夫不欲立孺子。", "len": 33}
{"sid": "046_田敬仲完世家.6.1.s8", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 8, "text": "孺子既立，君相之，大夫皆自危，谋作乱。", "len": 19}
{"sid": "046_田敬仲完世家.6.1.s9", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 9, "text": "” 又绐大夫曰：“高昭子可畏也，及未发先之。", "len": 22}
{"sid": "046_田敬仲完世家.6.1.s10", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 10, "text": "” 诸大夫从之。", "len": 8}
{"sid": "046_田敬仲完世家.6.1.s11", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 11, "text": "田乞、鲍牧与大夫以兵入公室，攻高昭子。", "len": 19}
{"sid": "046_田敬仲完世家.6.1.s12", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 12, "text": "昭子闻之，与国惠子救公。", "len": 12}
{"sid": "046_田敬仲完世家.6.1.s13", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 13, "text": "公师败。", "len": 4}
{"sid": "046_田敬仲完世家.6.1.s14", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 14, "text": "田乞之众追国惠子，惠子奔莒，遂返杀高昭子。", "len": 21}
{"sid": "046_田敬仲完世家.6.1.s15", "chapter": "046_田敬仲完世家", "para": "6.1", "seq": 15, "text": "晏圉奔鲁。", "len": 5}
{"sid": "046_田敬仲完世家.6.2.s1", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 1, "text": "田乞使人之鲁，迎阳生。", "len": 11}
{"sid": "046_田敬仲完世家.6.2.s2", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 2, "text": "阳生至齐，匿田乞家。", "len": 10}
{"sid": "046_田敬仲完世家.6.2.s3", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 3, "text": "请诸大夫曰：“常之母有鱼菽之祭，幸而来会饮。", "len": 22}
{"sid": "046_田敬仲完世家.6.2.s4", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 4, "text": "” 会饮田氏。", "len": 7}
{"sid": "046_田敬仲完世家.6.2.s5", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 5, "text": "田乞盛阳生橐中，置坐中央。", "len": 13}
{"sid": "046_田敬仲完世家.6.2.s6", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 6, "text": "发橐，出阳生，曰：“此乃齐君矣。", "len": 16}
{"sid": "046_田敬仲完世家.6.2.s7", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 7, "text": "” 大夫皆伏谒。", "len": 8}
{"sid": "046_田敬仲完世家.6.2.s8", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 8, "text": "将盟立之，田乞诬曰：“吾与鲍牧谋共立阳生也。", "len": 22}
{"sid": "046_田敬仲完世家.6.2.s9", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 9, "text": "” 鲍牧怒曰：“大夫忘景公之命乎？", "len": 17}
{"sid": "046_田敬仲完世家.6.2.s10", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 10, "text": "” 诸大夫欲悔，阳生乃顿首曰：“可则立之，不可则已。", "len": 26}
{"sid": "046_田敬仲完世家.6.2.s11", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 11, "text": "” 鲍牧恐祸及己，乃复曰：“皆景公之子，何为不可！", "len": 25}
{"sid": "046_田敬仲完世家.6.2.s12", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 12, "text": "” 遂立阳生於田乞之家，是为悼公。", "len": 17}
{"sid": "046_田敬仲完世家.6.2.s13", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 13, "text": "乃使人迁晏孺子於骀，而杀孺子荼。", "len": 16}
{"sid": "046_田敬仲完世家.6.2.s14", "chapter": "046_田敬仲完世家", "para": "6.2", "seq": 14, "text": "悼公既立，田乞为相，专齐政。", "len": 14}
{"sid": "046_田敬仲完世家.6.3.s1", "chapter": "046_田敬仲完世家", "para": "6.3", "seq": 1, "text": "四年，田乞卒，子常代立，是为田成子。", "len": 18}
{"sid": "046_田敬仲完世家.7.1.s1", "chapter": "046_田敬仲完世家", "para": "7.1", "seq": 1, "text": "鲍牧与齐悼公有郄，弑悼公。", "len": 13}
{"sid": "046_田敬仲完世家.7.1.s2", "chapter": "046_田敬仲完世家", "para": "7.1", "seq": 2, "text": "齐人共立其子壬，是为简公。", "len": 13}
{"sid": "046_田敬仲完世家.7.1.s3", "chapter": "046_田敬仲完世家", "para": "7.1", "seq": 3, "text": "田常成子与监止俱为左右相，相简公。", "len": 17}
{"sid": "046_田敬仲完世家.7.1.s4", "chapter": "046_田敬仲完世家", "para": "7.1", "seq": 4, "text": "田常心害监止，监止幸於简公，权弗能去。", "len": 19}
{"sid": "046_田敬仲完世家.7.1.s5", "chapter": "046_田敬仲完世家", "para": "7.1", "seq": 5, "text": "於是田常复脩釐子之政，以大斗出贷，以小斗收。", "len": 22}
{"sid": "046_田敬仲完世家.7.1.s6", "chapter": "046_田敬仲完世家", "para": "7.1", "seq": 6, "text": "齐人歌之曰：“妪乎采芑，归乎田成子！", "len": 18}
{"sid": "046_田敬仲完世家.7.1.s7", "chapter": "046_田敬仲完世家", "para": "7.1", "seq": 7, "text": "” 齐大夫朝，御鞅谏简公曰：“田、监不可并也，君其择焉。", "len": 28}
{"sid": "046_田敬仲完世家.7.1.s8", "chapter": "046_田敬仲完世家", "para": "7.1", "seq": 8, "text": "” 君弗听。", "len": 6}
{"sid": "046_田敬仲完世家.7.2.s1", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 1, "text": "子我者，监止之宗人也，常与田氏有卻。", "len": 18}
{"sid": "046_田敬仲完世家.7.2.s2", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 2, "text": "田氏疏族田豹事子我有宠。", "len": 12}
{"sid": "046_田敬仲完世家.7.2.s3", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 3, "text": "子我曰：“吾欲尽灭田氏適，以豹代田氏宗。", "len": 20}
{"sid": "046_田敬仲完世家.7.2.s4", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 4, "text": "” 豹曰：“臣於田氏疏矣。", "len": 13}
{"sid": "046_田敬仲完世家.7.2.s5", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 5, "text": "” 不听。", "len": 5}
{"sid": "046_田敬仲完世家.7.2.s6", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 6, "text": "已而豹谓田氏曰：“子我将诛田氏，田氏弗先，祸及矣。", "len": 25}
{"sid": "046_田敬仲完世家.7.2.s7", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 7, "text": "” 子我舍公宫，田常兄弟四人乘如公宫，欲杀子我。", "len": 24}
{"sid": "046_田敬仲完世家.7.2.s8", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 8, "text": "子我闭门。", "len": 5}
{"sid": "046_田敬仲完世家.7.2.s9", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 9, "text": "简公与妇人饮檀台，将欲击田常。", "len": 15}
{"sid": "046_田敬仲完世家.7.2.s10", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 10, "text": "太史子馀曰：“田常非敢为乱，将除害。", "len": 18}
{"sid": "046_田敬仲完世家.7.2.s11", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 11, "text": "” 简公乃止。", "len": 7}
{"sid": "046_田敬仲完世家.7.2.s12", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 12, "text": "田常出，闻简公怒，恐诛，将出亡。", "len": 16}
{"sid": "046_田敬仲完世家.7.2.s13", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 13, "text": "田子行曰：“需，事之贼也。", "len": 13}
{"sid": "046_田敬仲完世家.7.2.s14", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 14, "text": "” 田常於是击子我。", "len": 10}
{"sid": "046_田敬仲完世家.7.2.s15", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 15, "text": "子我率其徒攻田氏，不胜，出亡。", "len": 15}
{"sid": "046_田敬仲完世家.7.2.s16", "chapter": "046_田敬仲完世家", "para": "7.2", "seq": 16, "text": "田氏之徒追杀子我及监止。", "len": 12}
{"sid": "046_田敬仲完世家.7.3.s1", "chapter": "046_田敬仲完世家", "para": "7.3", "seq": 1, "text": "简公出奔，田氏之徒追执简公于徐州。", "len": 17}
{"sid": "046_田敬仲完世家.7.3.s2", "chapter": "046_田敬仲完世家", "para": "7.3", "seq": 2, "text": "简公曰：“蚤从御鞅之言，不及此难。", "len": 17}
{"sid": "046_田敬仲完世家.7.3.s3", "chapter": "046_田敬仲完世家", "para": "7.3", "seq": 3, "text": "” 田氏之徒恐简公复立而诛己，遂杀简公。", "len": 20}
{"sid": "046_田敬仲完世家.7.3.s4", "chapter": "046_田敬仲完世家", "para": "7.3", "seq": 4, "text": "简公立四年而杀。", "len": 8}
{"sid": "046_田敬仲完世家.7.3.s5", "chapter": "046_田敬仲完世家", "para": "7.3", "seq": 5, "text": "於是田常立简公弟骜，是为平公。", "len": 15}
{"sid": "046_田敬仲完世家.7.3.s6", "chapter": "046_田敬仲完世家", "para": "7.3", "seq": 6, "text": "平公即位，田常为相。", "len": 10}
{"sid": "046_田敬仲完世家.8.1.s1", "chapter": "046_田敬仲完世家", "para": "8.1", "seq": 1, "text": "田常既杀简公，惧诸侯共诛己，乃尽归鲁、卫侵地，西约晋、韩、魏、赵氏，南通吴、越之使，脩功行赏，亲於百姓，以故齐复定。", "len": 58}
{"sid": "046_田敬仲完世家.8.2.s1", "chapter": "046_田敬仲完世家", "para": "8.2", "seq": 1, "text": "田常言於齐平公曰：“德施人之所欲，君其行之；刑罚人之所恶，臣请行之。", "len": 34}
{"sid": "046_田敬仲完世家.8.2.s2", "chapter": "046_田敬仲完世家", "para": "8.2", "seq": 2, "text": "” 行之五年，齐国之政皆归田常。", "len": 16}
{"sid": "046_田敬仲完世家.8.2.s3", "chapter": "046_田敬仲完世家", "para": "8.2", "seq": 3, "text": "田常於是尽诛鲍、晏、监止及公族之彊者，而割齐自安平以东至琅邪，自为封邑。", "len": 36}
{"sid": "046_田敬仲完世家.8.2.s4", "chapter": "046_田敬仲完世家", "para": "8.2", "seq": 4, "text": "封邑大於平公之所食。", "len": 10}
{"sid": "046_田敬仲完世家.8.3.s1", "chapter": "046_田敬仲完世家", "para": "8.3", "seq": 1, "text": "田常乃选齐国中女子长七尺以上为後宫，後宫以百数，而使宾客舍人出入後宫者不禁。", "len": 38}
{"sid": "046_田敬仲完世家.8.3.s2", "chapter": "046_田敬仲完世家", "para": "8.3", "seq": 2, "text": "及田常卒，有七十馀男。", "len": 11}
{"sid": "046_田敬仲完世家.8.4.s1", "chapter": "046_田敬仲完世家", "para": "8.4", "seq": 1, "text": "田常卒，子襄子盘代立，相齐。", "len": 14}
{"sid": "046_田敬仲完世家.8.4.s2", "chapter": "046_田敬仲完世家", "para": "8.4", "seq": 2, "text": "常谥为成子。", "len": 6}
{"sid": "046_田敬仲完世家.9.1.s1", "chapter": "046_田敬仲完世家", "para": "9.1", "seq": 1, "text": "田襄子既相齐宣公，三晋杀知伯，分其地。", "len": 19}
{"sid": "046_田敬仲完世家.9.1.s2", "chapter": "046_田敬仲完世家", "para": "9.1", "seq": 2, "text": "襄子使其兄弟宗人尽为齐都邑大夫，与三晋通使，且以有齐国。", "len": 28}
{"sid": "046_田敬仲完世家.9.2.s1", "chapter": "046_田敬仲完世家", "para": "9.2", "seq": 1, "text": "襄子卒，子庄子白立。", "len": 10}
{"sid": "046_田敬仲完世家.9.2.s2", "chapter": "046_田敬仲完世家", "para": "9.2", "seq": 2, "text": "田庄子相齐宣公。", "len": 8}
{"sid": "046_田敬仲完世家.9.2.s3", "chapter": "046_田敬仲完世家", "para": "9.2", "seq": 3, "text": "宣公四十三年，伐晋，毁黄城，围阳狐。", "len": 18}
{"sid": "046_田敬仲完世家.9.2.s4", "chapter": "046_田敬仲完世家", "para": "9.2", "seq": 4, "text": "明年，伐鲁、葛及安陵。", "len": 11}
{"sid": "046_田敬仲完世家.9.2.s5", "chapter": "046_田敬仲完世家", "para": "9.2", "seq": 5, "text": "明年，取鲁之一城。", "len": 9}
{"sid": "046_田敬仲完世家.9.3.s1", "chapter": "046_田敬仲完世家", "para": "9.3", "seq": 1, "text": "庄子卒，子太公和立。", "len": 10}
{"sid": "046_田敬仲完世家.9.3.s2", "chapter": "046_田敬仲完世家", "para": "9.3", "seq": 2, "text": "田太公相齐宣公。", "len": 8}
{"sid": "046_田敬仲完世家.9.3.s3", "chapter": "046_田敬仲完世家", "para": "9.3", "seq": 3, "text": "宣公四十八年，取鲁之郕。", "len": 12}
{"sid": "046_田敬仲完世家.9.3.s4", "chapter": "046_田敬仲完世家", "para": "9.3", "seq": 4, "text": "明年，宣公与郑人会西城。", "len": 12}
{"sid": "046_田敬仲完世家.9.3.s5", "chapter": "046_田敬仲完世家", "para": "9.3", "seq": 5, "text": "伐卫，取毌丘。", "len": 7}
{"sid": "046_田敬仲完世家.9.3.s6", "chapter": "046_田敬仲完世家", "para": "9.3", "seq": 6, "text": "宣公五十一年卒，田会自廪丘反。", "len": 15}
{"sid": "046_田敬仲完世家.10.1.s1", "chapter": "046_田敬仲完世家", "para": "10.1", "seq": 1, "text": "宣公卒，子康公贷立。", "len": 10}
{"sid": "046_田敬仲完世家.10.1.s2", "chapter": "046_田敬仲完世家", "para": "10.1", "seq": 2, "text": "贷立十四年，淫於酒妇人，不听政。", "len": 16}
{"sid": "046_田敬仲完世家.10.1.s3", "chapter": "046_田敬仲完世家", "para": "10.1", "seq": 3, "text": "太公乃迁康公於海上，食一城，以奉其先祀。", "len": 20}
{"sid": "046_田敬仲完世家.10.1.s4", "chapter": "046_田敬仲完世家", "para": "10.1", "seq": 4, "text": "明年，鲁败齐平陆。", "len": 9}
{"sid": "046_田敬仲完世家.10.2.s1", "chapter": "046_田敬仲完世家", "para": "10.2", "seq": 1, "text": "三年，太公与魏文侯会浊泽，求为诸侯。", "len": 18}
{"sid": "046_田敬仲完世家.10.2.s2", "chapter": "046_田敬仲完世家", "para": "10.2", "seq": 2, "text": "魏文侯乃使使言周天子及诸侯，请立齐相田和为诸侯。", "len": 24}
{"sid": "046_田敬仲完世家.10.2.s3", "chapter": "046_田敬仲完世家", "para": "10.2", "seq": 3, "text": "周天子许之。", "len": 6}
{"sid": "046_田敬仲完世家.10.2.s4", "chapter": "046_田敬仲完世家", "para": "10.2", "seq": 4, "text": "康公之十九年，田和立为齐侯，列於周室，纪元年。", "len": 23}
{"sid": "046_田敬仲完世家.11.1.s1", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 1, "text": "齐侯太公和立二年，和卒，子桓公午立。", "len": 18}
{"sid": "046_田敬仲完世家.11.1.s2", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 2, "text": "桓公午五年，秦、魏攻韩，韩求救於齐。", "len": 18}
{"sid": "046_田敬仲完世家.11.1.s3", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 3, "text": "齐桓公召大臣而谋曰：“蚤救之孰与晚救之？", "len": 20}
{"sid": "046_田敬仲完世家.11.1.s4", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 4, "text": "” 驺忌曰：”不若勿救。", "len": 12}
{"sid": "046_田敬仲完世家.11.1.s5", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 5, "text": "” 段干朋曰：”不救，则韩且折而入於魏，不若救之。", "len": 25}
{"sid": "046_田敬仲完世家.11.1.s6", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 6, "text": "” 田臣思曰：”过矣君之谋也！", "len": 15}
{"sid": "046_田敬仲完世家.11.1.s7", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 7, "text": "秦、魏攻韩、楚，赵必救之，是天以燕予齐也。", "len": 21}
{"sid": "046_田敬仲完世家.11.1.s8", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 8, "text": "” 桓公曰：“善”。", "len": 10}
{"sid": "046_田敬仲完世家.11.1.s9", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 9, "text": "乃阴告韩使者而遣之。", "len": 10}
{"sid": "046_田敬仲完世家.11.1.s10", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 10, "text": "韩自以为得齐之救，因与秦、魏战。", "len": 16}
{"sid": "046_田敬仲完世家.11.1.s11", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 11, "text": "楚、赵闻之，果起兵而救之。", "len": 13}
{"sid": "046_田敬仲完世家.11.1.s12", "chapter": "046_田敬仲完世家", "para": "11.1", "seq": 12, "text": "齐因起兵袭燕国，取桑丘。", "len": 12}
{"sid": "046_田敬仲完世家.11.2.s1", "chapter": "046_田敬仲完世家", "para": "11.2", "seq": 1, "text": "六年，救卫。", "len": 6}
{"sid": "046_田敬仲完世家.11.2.s2", "chapter": "046_田敬仲完世家", "para": "11.2", "seq": 2, "text": "桓公卒，子威王因齐立。", "len": 11}
{"sid": "046_田敬仲完世家.11.2.s3", "chapter": "046_田敬仲完世家", "para": "11.2", "seq": 3, "text": "是岁，故齐康公卒，绝无後，奉邑皆入田氏。", "len": 20}
{"sid": "046_田敬仲完世家.12.1.s1", "chapter": "046_田敬仲完世家", "para": "12.1", "seq": 1, "text": "齐威王元年，三晋因齐丧来伐我灵丘。", "len": 17}
{"sid": "046_田敬仲完世家.12.1.s2", "chapter": "046_田敬仲完世家", "para": "12.1", "seq": 2, "text": "三年，三晋灭晋後而分其地。", "len": 13}
{"sid": "046_田敬仲完世家.12.1.s3", "chapter": "046_田敬仲完世家", "para": "12.1", "seq": 3, "text": "六年，鲁伐我，入阳关。", "len": 11}
{"sid": "046_田敬仲完世家.12.1.s4", "chapter": "046_田敬仲完世家", "para": "12.1", "seq": 4, "text": "晋伐我，至博陵。", "len": 8}
{"sid": "046_田敬仲完世家.12.1.s5", "chapter": "046_田敬仲完世家", "para": "12.1", "seq": 5, "text": "七年，卫伐我，取薛陵。", "len": 11}
{"sid": "046_田敬仲完世家.12.1.s6", "chapter": "046_田敬仲完世家", "para": "12.1", "seq": 6, "text": "九年，赵伐我，取甄。", "len": 10}
{"sid": "046_田敬仲完世家.13.1.s1", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 1, "text": "威王初即位以来，不治，委政卿大夫，九年之间，诸侯并伐，国人不治。", "len": 32}
{"sid": "046_田敬仲完世家.13.1.s2", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 2, "text": "於是威王召即墨大夫而语之曰：“自子之居即墨也，毁言日至。", "len": 28}
{"sid": "046_田敬仲完世家.13.1.s3", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 3, "text": "然吾使人视即墨，田野辟，民人给，官无留事，东方以宁。", "len": 26}
{"sid": "046_田敬仲完世家.13.1.s4", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 4, "text": "是子不事吾左右以求誉也。", "len": 12}
{"sid": "046_田敬仲完世家.13.1.s5", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 5, "text": "” 封之万家。", "len": 7}
{"sid": "046_田敬仲完世家.13.1.s6", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 6, "text": "召阿大夫语曰：“自子之守阿，誉言日闻。", "len": 19}
{"sid": "046_田敬仲完世家.13.1.s7", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 7, "text": "然使使视阿，田野不辟，民贫苦。", "len": 15}
{"sid": "046_田敬仲完世家.13.1.s8", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 8, "text": "昔日赵攻甄，子弗能救。", "len": 11}
{"sid": "046_田敬仲完世家.13.1.s9", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 9, "text": "卫取薛陵，子弗知。", "len": 9}
{"sid": "046_田敬仲完世家.13.1.s10", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 10, "text": "是子以币厚吾左右以求誉也。", "len": 13}
{"sid": "046_田敬仲完世家.13.1.s11", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 11, "text": "” 是日，烹阿大夫，及左右尝誉者皆并烹之。", "len": 21}
{"sid": "046_田敬仲完世家.13.1.s12", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 12, "text": "遂起兵西击赵、卫，败魏於浊泽而围惠王。", "len": 19}
{"sid": "046_田敬仲完世家.13.1.s13", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 13, "text": "惠王请献观以和解，赵人归我长城。", "len": 16}
{"sid": "046_田敬仲完世家.13.1.s14", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 14, "text": "於是齐国震惧，人人不敢饰非，务尽其诚。", "len": 19}
{"sid": "046_田敬仲完世家.13.1.s15", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 15, "text": "齐国大治。", "len": 5}
{"sid": "046_田敬仲完世家.13.1.s16", "chapter": "046_田敬仲完世家", "para": "13.1", "seq": 16, "text": "诸侯闻之，莫敢致兵於齐二十馀年。", "len": 16}
{"sid": "046_田敬仲完世家.14.1.s1", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 1, "text": "驺忌子以鼓琴见威王，威王说而舍之右室。", "len": 19}
{"sid": "046_田敬仲完世家.14.1.s2", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 2, "text": "须臾，王鼓琴，驺忌子推户入曰：“善哉鼓琴！", "len": 21}
{"sid": "046_田敬仲完世家.14.1.s3", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 3, "text": "” 王勃然不说，去琴按剑曰：“夫子见容未察，何以知其善也？", "len": 29}
{"sid": "046_田敬仲完世家.14.1.s4", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 4, "text": "” 驺忌子曰：“夫大弦浊以春温者，君也；小弦廉折以清者，相也；攫之深，醳之愉者，政令也；钧谐以鸣，大小相益，回邪而不相害者，四时也：吾是以知其善也。", "len": 74}
{"sid": "046_田敬仲完世家.14.1.s5", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 5, "text": "” 王曰：“善语音。", "len": 10}
{"sid": "046_田敬仲完世家.14.1.s6", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 6, "text": "” 驺忌子曰：“何独语音，夫治国家而弭人民皆在其中。", "len": 26}
{"sid": "046_田敬仲完世家.14.1.s7", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 7, "text": "” 王又勃然不说曰：“若夫语五音之纪，信未有如夫子者也。", "len": 28}
{"sid": "046_田敬仲完世家.14.1.s8", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 8, "text": "若夫治国家而弭人民，又何为乎丝桐之间？", "len": 19}
{"sid": "046_田敬仲完世家.14.1.s9", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 9, "text": "” 驺忌子曰：“夫大弦浊以春温者，君也；小弦廉折以清者，相也；攫之深而舍之愉者，政令也；钧谐以鸣，大小相益，回邪而不相害者，四时也。", "len": 66}
{"sid": "046_田敬仲完世家.14.1.s10", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 10, "text": "夫复而不乱者，所以治昌也；连而径者，所以存亡也：故曰琴音调而天下治。", "len": 34}
{"sid": "046_田敬仲完世家.14.1.s11", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 11, "text": "夫治国家而弭人民者，无若乎五音者。", "len": 17}
{"sid": "046_田敬仲完世家.14.1.s12", "chapter": "046_田敬仲完世家", "para": "14.1", "seq": 12, "text": "” 王曰：“善。”", "len": 9}
{"sid": "046_田敬仲完世家.15.1.s1", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 1, "text": "驺忌子见三月而受相印。", "len": 11}
{"sid": "046_田敬仲完世家.15.1.s2", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 2, "text": "淳于髡见之曰：“善说哉！", "len": 12}
{"sid": "046_田敬仲完世家.15.1.s3", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 3, "text": "髡有愚志，原陈诸前。", "len": 10}
{"sid": "046_田敬仲完世家.15.1.s4", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 4, "text": "” 驺忌子曰：“谨受教。", "len": 12}
{"sid": "046_田敬仲完世家.15.1.s5", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 5, "text": "” 淳于髡曰：“得全全昌，失全全亡。", "len": 18}
{"sid": "046_田敬仲完世家.15.1.s6", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 6, "text": "” 驺忌子曰：“谨受令，请谨毋离前。", "len": 18}
{"sid": "046_田敬仲完世家.15.1.s7", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 7, "text": "” 淳于髡曰：“豨膏棘轴，所以为滑也，然而不能运方穿。", "len": 27}
{"sid": "046_田敬仲完世家.15.1.s8", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 8, "text": "” 驺忌子曰：“谨受令，请谨事左右。", "len": 18}
{"sid": "046_田敬仲完世家.15.1.s9", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 9, "text": "” 淳于髡曰：“弓胶昔幹，所以为合也，然而不能傅合疏罅。", "len": 28}
{"sid": "046_田敬仲完世家.15.1.s10", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 10, "text": "” 驺忌子曰：“谨受令，请谨自附於万民。", "len": 20}
{"sid": "046_田敬仲完世家.15.1.s11", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 11, "text": "” 淳于髡曰：“狐裘虽敝，不可补以黄狗之皮。", "len": 22}
{"sid": "046_田敬仲完世家.15.1.s12", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 12, "text": "” 驺忌子曰：“谨受令，请谨择君子，毋杂小人其间。", "len": 25}
{"sid": "046_田敬仲完世家.15.1.s13", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 13, "text": "” 淳于髡曰：“大车不较，不能载其常任；琴瑟不较，不能成其五音。", "len": 32}
{"sid": "046_田敬仲完世家.15.1.s14", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 14, "text": "” 驺忌子曰：“谨受令，请谨脩法律而督奸吏。", "len": 22}
{"sid": "046_田敬仲完世家.15.1.s15", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 15, "text": "” 淳于髡说毕，趋出，至门，而面其仆曰：“是人者，吾语之微言五，其应我若响之应声，是人必封不久矣。", "len": 49}
{"sid": "046_田敬仲完世家.15.1.s16", "chapter": "046_田敬仲完世家", "para": "15.1", "seq": 16, "text": "” 居期年，封以下邳，号曰成侯。", "len": 16}
{"sid": "046_田敬仲完世家.16.1.s1", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 1, "text": "威王二十三年，与赵王会平陆。", "len": 14}
{"sid": "046_田敬仲完世家.16.1.s2", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 2, "text": "二十四年，与魏王会田於郊。", "len": 13}
{"sid": "046_田敬仲完世家.16.1.s3", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 3, "text": "魏王问曰：“王亦有宝乎？", "len": 12}
{"sid": "046_田敬仲完世家.16.1.s4", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 4, "text": "” 威王曰：“无有。", "len": 10}
{"sid": "046_田敬仲完世家.16.1.s5", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 5, "text": "” 梁王曰：“若寡人国小也，尚有径寸之珠照车前後各十二乘者十枚，奈何以万乘之国而无宝乎？", "len": 44}
{"sid": "046_田敬仲完世家.16.1.s6", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 6, "text": "” 威王曰：“寡人之所以为宝与王异。", "len": 18}
{"sid": "046_田敬仲完世家.16.1.s7", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 7, "text": "吾臣有檀子者，使守南城，则楚人不敢为寇东取，泗上十二诸侯皆来朝。", "len": 32}
{"sid": "046_田敬仲完世家.16.1.s8", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 8, "text": "吾臣有朌子者，使守高唐，则赵人不敢东渔於河。", "len": 22}
{"sid": "046_田敬仲完世家.16.1.s9", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 9, "text": "吾吏有黔夫者，使守徐州，则燕人祭北门，赵人祭西门，徙而从者七千馀家。", "len": 34}
{"sid": "046_田敬仲完世家.16.1.s10", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 10, "text": "吾臣有种首者，使备盗贼，则道不拾遗。", "len": 18}
{"sid": "046_田敬仲完世家.16.1.s11", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 11, "text": "将以照千里，岂特十二乘哉！", "len": 13}
{"sid": "046_田敬仲完世家.16.1.s12", "chapter": "046_田敬仲完世家", "para": "16.1", "seq": 12, "text": "” 梁惠王惭，不怿而去。", "len": 12}
{"sid": "046_田敬仲完世家.17.1.s1", "chapter": "046_田敬仲完世家", "para": "17.1", "seq": 1, "text": "二十六年，魏惠王围邯郸，赵求救於齐。", "len": 18}
{"sid": "046_田敬仲完世家.17.1.s2", "chapter": "046_田敬仲完世家", "para": "17.1", "seq": 2, "text": "齐威王召大臣而谋曰：“救赵孰与勿救？", "len": 18}
{"sid": "046_田敬仲完世家.17.1.s3", "chapter": "046_田敬仲完世家", "para": "17.1", "seq": 3, "text": "” 驺忌子曰：“不如勿救。", "len": 13}
{"sid": "046_田敬仲完世家.17.1.s4", "chapter": "046_田敬仲完世家", "para": "17.1", "seq": 4, "text": "” 段干朋曰：“不救则不义，且不利。", "len": 18}
{"sid": "046_田敬仲完世家.17.1.s5", "chapter": "046_田敬仲完世家", "para": "17.1", "seq": 5, "text": "” 威王曰：“何也？", "len": 10}
{"sid": "046_田敬仲完世家.17.1.s6", "chapter": "046_田敬仲完世家", "para": "17.1", "seq": 6, "text": "” 对曰：“夫魏氏并邯郸，其於齐何利哉？", "len": 20}
{"sid": "046_田敬仲完世家.17.1.s7", "chapter": "046_田敬仲完世家", "para": "17.1", "seq": 7, "text": "且夫救赵而军其郊，是赵不伐而魏全也。", "len": 18}
{"sid": "046_田敬仲完世家.17.1.s8", "chapter": "046_田敬仲完世家", "para": "17.1", "seq": 8, "text": "故不如南攻襄陵以弊魏，邯郸拔而乘魏之弊。", "len": 20}
{"sid": "046_田敬仲完世家.17.1.s9", "chapter": "046_田敬仲完世家", "para": "17.1", "seq": 9, "text": "” 威王从其计。", "len": 8}
{"sid": "046_田敬仲完世家.17.2.s1", "chapter": "046_田敬仲完世家", "para": "17.2", "seq": 1, "text": "其後成侯驺忌与田忌不善，公孙阅谓成侯忌曰：“公何不谋伐魏，田忌必将。", "len": 34}
{"sid": "046_田敬仲完世家.17.2.s2", "chapter": "046_田敬仲完世家", "para": "17.2", "seq": 2, "text": "战胜有功，则公之谋中也；战不胜，非前死则後北，而命在公矣。", "len": 29}
{"sid": "046_田敬仲完世家.17.2.s3", "chapter": "046_田敬仲完世家", "para": "17.2", "seq": 3, "text": "” 於是成侯言威王，使田忌南攻襄陵。", "len": 18}
{"sid": "046_田敬仲完世家.17.2.s4", "chapter": "046_田敬仲完世家", "para": "17.2", "seq": 4, "text": "十月，邯郸拔，齐因起兵击魏，大败之桂陵。", "len": 20}
{"sid": "046_田敬仲完世家.17.2.s5", "chapter": "046_田敬仲完世家", "para": "17.2", "seq": 5, "text": "於是齐最彊於诸侯，自称为王，以令天下。", "len": 19}
{"sid": "046_田敬仲完世家.17.3.s1", "chapter": "046_田敬仲完世家", "para": "17.3", "seq": 1, "text": "三十三年，杀其大夫牟辛。", "len": 12}
{"sid": "046_田敬仲完世家.17.4.s1", "chapter": "046_田敬仲完世家", "para": "17.4", "seq": 1, "text": "三十五年，公孙阅又谓成侯忌曰：“公何不令人操十金卜於市，曰‘我田忌之人也。", "len": 37}
{"sid": "046_田敬仲完世家.17.4.s2", "chapter": "046_田敬仲完世家", "para": "17.4", "seq": 2, "text": "吾三战而三胜，声威天下。", "len": 12}
{"sid": "046_田敬仲完世家.17.4.s3", "chapter": "046_田敬仲完世家", "para": "17.4", "seq": 3, "text": "欲为大事，亦吉乎不吉乎’？", "len": 13}
{"sid": "046_田敬仲完世家.17.4.s4", "chapter": "046_田敬仲完世家", "para": "17.4", "seq": 4, "text": "” 卜者出，因令人捕为之卜者，验其辞於王之所。", "len": 23}
{"sid": "046_田敬仲完世家.17.4.s5", "chapter": "046_田敬仲完世家", "para": "17.4", "seq": 5, "text": "田忌闻之，因率其徒袭攻临淄，求成侯，不胜而饹。", "len": 23}
{"sid": "046_田敬仲完世家.17.5.s1", "chapter": "046_田敬仲完世家", "para": "17.5", "seq": 1, "text": "三十六年，威王卒，子宣王辟彊立。", "len": 16}
{"sid": "046_田敬仲完世家.18.1.s1", "chapter": "046_田敬仲完世家", "para": "18.1", "seq": 1, "text": "宣王元年，秦用商鞅。", "len": 10}
{"sid": "046_田敬仲完世家.18.1.s2", "chapter": "046_田敬仲完世家", "para": "18.1", "seq": 2, "text": "周致伯於秦孝公。", "len": 8}
{"sid": "046_田敬仲完世家.18.2.s1", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 1, "text": "二年，魏伐赵。", "len": 7}
{"sid": "046_田敬仲完世家.18.2.s2", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 2, "text": "赵与韩亲，共击魏。", "len": 9}
{"sid": "046_田敬仲完世家.18.2.s3", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 3, "text": "赵不利，战於南梁。", "len": 9}
{"sid": "046_田敬仲完世家.18.2.s4", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 4, "text": "宣王召田忌复故位。", "len": 9}
{"sid": "046_田敬仲完世家.18.2.s5", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 5, "text": "韩氏请救於齐。", "len": 7}
{"sid": "046_田敬仲完世家.18.2.s6", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 6, "text": "宣王召大臣而谋曰：“蚤救孰与晚救？", "len": 17}
{"sid": "046_田敬仲完世家.18.2.s7", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 7, "text": "” 驺忌子曰：“不如勿救。", "len": 13}
{"sid": "046_田敬仲完世家.18.2.s8", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 8, "text": "” 田忌曰：“弗救，则韩且折而入於魏，不如蚤救之。", "len": 25}
{"sid": "046_田敬仲完世家.18.2.s9", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 9, "text": "” 孙子曰：“夫韩、魏之兵未弊而救之，是吾代韩受魏之兵，顾反听命於韩也。", "len": 36}
{"sid": "046_田敬仲完世家.18.2.s10", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 10, "text": "且魏有破国之志，韩见亡，必东面而愬於齐矣。", "len": 21}
{"sid": "046_田敬仲完世家.18.2.s11", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 11, "text": "吾因深结韩之亲而晚承魏之弊，则可重利而得尊名也。", "len": 24}
{"sid": "046_田敬仲完世家.18.2.s12", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 12, "text": "” 宣王曰：“善。", "len": 9}
{"sid": "046_田敬仲完世家.18.2.s13", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 13, "text": "” 乃阴告韩之使者而遣之。", "len": 13}
{"sid": "046_田敬仲完世家.18.2.s14", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 14, "text": "韩因恃齐，五战不胜，而东委国於齐。", "len": 17}
{"sid": "046_田敬仲完世家.18.2.s15", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 15, "text": "齐因起兵，使田忌、田婴将，孙子为师，救韩、赵以击魏，大败之马陵，杀其将庞涓，虏魏太子申。", "len": 44}
{"sid": "046_田敬仲完世家.18.2.s16", "chapter": "046_田敬仲完世家", "para": "18.2", "seq": 16, "text": "其後三晋之王皆因田婴朝齐王於博望，盟而去。", "len": 21}
{"sid": "046_田敬仲完世家.18.3.s1", "chapter": "046_田敬仲完世家", "para": "18.3", "seq": 1, "text": "七年，与魏王会平阿南。", "len": 11}
{"sid": "046_田敬仲完世家.18.3.s2", "chapter": "046_田敬仲完世家", "para": "18.3", "seq": 2, "text": "明年，复会甄。", "len": 7}
{"sid": "046_田敬仲完世家.18.3.s3", "chapter": "046_田敬仲完世家", "para": "18.3", "seq": 3, "text": "魏惠王卒。", "len": 5}
{"sid": "046_田敬仲完世家.18.3.s4", "chapter": "046_田敬仲完世家", "para": "18.3", "seq": 4, "text": "明年，与魏襄王会徐州，诸侯相王也。", "len": 17}
{"sid": "046_田敬仲完世家.18.3.s5", "chapter": "046_田敬仲完世家", "para": "18.3", "seq": 5, "text": "十年，楚围我徐州。", "len": 9}
{"sid": "046_田敬仲完世家.18.3.s6", "chapter": "046_田敬仲完世家", "para": "18.3", "seq": 6, "text": "十一年，与魏伐赵，赵决河水灌齐、魏，兵罢。", "len": 21}
{"sid": "046_田敬仲完世家.18.3.s7", "chapter": "046_田敬仲完世家", "para": "18.3", "seq": 7, "text": "十八年，秦惠王称王。", "len": 10}
{"sid": "046_田敬仲完世家.19.1.s1", "chapter": "046_田敬仲完世家", "para": "19.1", "seq": 1, "text": "宣王喜文学游说之士，自如驺衍、淳于髡、田骈、接予、慎到、环渊之徒七十六人，皆赐列第，为上大夫，不治而议论。", "len": 53}
{"sid": "046_田敬仲完世家.19.1.s2", "chapter": "046_田敬仲完世家", "para": "19.1", "seq": 2, "text": "是以齐稷下学士复盛，且数百千人。", "len": 16}
{"sid": "046_田敬仲完世家.19.2.s1", "chapter": "046_田敬仲完世家", "para": "19.2", "seq": 1, "text": "十九年，宣王卒，子湣王地立。", "len": 14}
{"sid": "046_田敬仲完世家.20.1.s1", "chapter": "046_田敬仲完世家", "para": "20.1", "seq": 1, "text": "湣王元年，秦使张仪与诸侯执政会于齧桑。", "len": 19}
{"sid": "046_田敬仲完世家.20.1.s2", "chapter": "046_田敬仲完世家", "para": "20.1", "seq": 2, "text": "三年，封田婴於薛。", "len": 9}
{"sid": "046_田敬仲完世家.20.1.s3", "chapter": "046_田敬仲完世家", "para": "20.1", "seq": 3, "text": "四年，迎妇于秦。", "len": 8}
{"sid": "046_田敬仲完世家.20.1.s4", "chapter": "046_田敬仲完世家", "para": "20.1", "seq": 4, "text": "七年，与宋攻魏，败之观泽。", "len": 13}
{"sid": "046_田敬仲完世家.21.1.s1", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 1, "text": "十二年，攻魏。", "len": 7}
{"sid": "046_田敬仲完世家.21.1.s2", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 2, "text": "楚围雍氏，秦败屈丐。", "len": 10}
{"sid": "046_田敬仲完世家.21.1.s3", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 3, "text": "苏代谓田轸曰：“臣原有谒於公，其为事甚完，使楚利公，成为福，不成亦为福。", "len": 36}
{"sid": "046_田敬仲完世家.21.1.s4", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 4, "text": "今者臣立於门，客有言曰魏王谓韩冯、张仪曰：‘煮枣将拔，齐兵又进，子来救寡人则可矣；不救寡人，寡人弗能拔。", "len": 52}
{"sid": "046_田敬仲完世家.21.1.s5", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 5, "text": "‘此特转辞也。", "len": 7}
{"sid": "046_田敬仲完世家.21.1.s6", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 6, "text": "秦、韩之兵毋东，旬馀，则魏氏转韩从秦，秦逐张仪，交臂而事齐楚，此公之事成也。", "len": 38}
{"sid": "046_田敬仲完世家.21.1.s7", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 7, "text": "” 田轸曰：“柰何使无东？", "len": 13}
{"sid": "046_田敬仲完世家.21.1.s8", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 8, "text": "” 对曰：“韩冯之救魏之辞，必不谓韩王曰’冯以为魏’，必曰‘冯将以秦韩之兵东卻齐宋，冯因抟三国之兵，乘屈丐之弊，南割於楚，故地必尽得之矣’。", "len": 70}
{"sid": "046_田敬仲完世家.21.1.s9", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 9, "text": "张仪救魏之辞，必不谓秦王曰’仪以为魏’，必曰‘仪且以秦韩之兵东距齐宋，仪将抟三国之兵，乘屈丐之弊，南割於楚，名存亡国，实伐三川而归，此王业也’。", "len": 72}
{"sid": "046_田敬仲完世家.21.1.s10", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 10, "text": "公令楚王与韩氏地，使秦制和，谓秦王曰’请与韩地，而王以施三川，韩氏之兵不用而得地於楚’。", "len": 44}
{"sid": "046_田敬仲完世家.21.1.s11", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 11, "text": "韩冯之东兵之辞且谓秦何？", "len": 12}
{"sid": "046_田敬仲完世家.21.1.s12", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 12, "text": "曰’秦兵不用而得三川，伐楚韩以窘魏，魏氏不敢东，是孤齐也’。", "len": 30}
{"sid": "046_田敬仲完世家.21.1.s13", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 13, "text": "张仪之东兵之辞且谓何？", "len": 11}
{"sid": "046_田敬仲完世家.21.1.s14", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 14, "text": "曰‘秦韩欲地而兵有案，声威发於魏，魏氏之欲不失齐楚者有资矣’。", "len": 31}
{"sid": "046_田敬仲完世家.21.1.s15", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 15, "text": "魏氏转秦韩争事齐楚，楚王欲而无与地，公令秦韩之兵不用而得地，有一大德也。", "len": 36}
{"sid": "046_田敬仲完世家.21.1.s16", "chapter": "046_田敬仲完世家", "para": "21.1", "seq": 16, "text": "秦韩之王劫於韩冯、张仪而东兵以徇服魏，公常执左券以责於秦韩，此其善於公而恶张子多资矣。”", "len": 44}
{"sid": "046_田敬仲完世家.21.2.s1", "chapter": "046_田敬仲完世家", "para": "21.2", "seq": 1, "text": "十三年，秦惠王卒。", "len": 9}
{"sid": "046_田敬仲完世家.21.2.s2", "chapter": "046_田敬仲完世家", "para": "21.2", "seq": 2, "text": "二十三年，与秦击败楚於重丘。", "len": 14}
{"sid": "046_田敬仲完世家.21.2.s3", "chapter": "046_田敬仲完世家", "para": "21.2", "seq": 3, "text": "二十四年，秦使泾阳君质於齐。", "len": 14}
{"sid": "046_田敬仲完世家.21.2.s4", "chapter": "046_田敬仲完世家", "para": "21.2", "seq": 4, "text": "二十五年，归泾阳君于秦。", "len": 12}
{"sid": "046_田敬仲完世家.21.2.s5", "chapter": "046_田敬仲完世家", "para": "21.2", "seq": 5, "text": "孟尝君薛文入秦，即相秦。", "len": 12}
{"sid": "046_田敬仲完世家.21.2.s6", "chapter": "046_田敬仲完世家", "para": "21.2", "seq": 6, "text": "文亡去。", "len": 4}
{"sid": "046_田敬仲完世家.21.2.s7", "chapter": "046_田敬仲完世家", "para": "21.2", "seq": 7, "text": "二十六年，齐与韩魏共攻秦，至函谷军焉。", "len": 19}
{"sid": "046_田敬仲完世家.21.2.s8", "chapter": "046_田敬仲完世家", "para": "21.2", "seq": 8, "text": "二十八年，秦与韩河外以和，兵罢。", "len": 16}
{"sid": "046_田敬仲完世家.21.2.s9", "chapter": "046_田敬仲完世家", "para": "21.2", "seq": 9, "text": "二十九年，赵杀其主父。", "len": 11}
{"sid": "046_田敬仲完世家.21.2.s10", "chapter": "046_田敬仲完世家", "para": "21.2", "seq": 10, "text": "齐佐赵灭中山。", "len": 7}
{"sid": "046_田敬仲完世家.22.1.s1", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 1, "text": "三十六年，王为东帝，秦昭王为西帝。", "len": 17}
{"sid": "046_田敬仲完世家.22.1.s2", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 2, "text": "苏代自燕来，入齐，见於章华东门。", "len": 16}
{"sid": "046_田敬仲完世家.22.1.s3", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 3, "text": "齐王曰：“嘻，善，子来！", "len": 12}
{"sid": "046_田敬仲完世家.22.1.s4", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 4, "text": "秦使魏厓致帝，子以为何如？", "len": 13}
{"sid": "046_田敬仲完世家.22.1.s5", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 5, "text": "” 对曰：“王之问臣也卒，而患之所从来微，原王受之而勿备称也。", "len": 31}
{"sid": "046_田敬仲完世家.22.1.s6", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 6, "text": "秦称之，天下安之，王乃称之，无後也。", "len": 18}
{"sid": "046_田敬仲完世家.22.1.s7", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 7, "text": "且让争帝名，无伤也。", "len": 10}
{"sid": "046_田敬仲完世家.22.1.s8", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 8, "text": "秦称之，天下恶之，王因勿称，以收天下，此大资也。", "len": 24}
{"sid": "046_田敬仲完世家.22.1.s9", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 9, "text": "且天下立两帝，王以天下为尊齐乎？", "len": 16}
{"sid": "046_田敬仲完世家.22.1.s10", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 10, "text": "尊秦乎？", "len": 4}
{"sid": "046_田敬仲完世家.22.1.s11", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 11, "text": "” 王曰：“尊秦。", "len": 9}
{"sid": "046_田敬仲完世家.22.1.s12", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 12, "text": "” 曰：“释帝，天下爱齐乎？", "len": 14}
{"sid": "046_田敬仲完世家.22.1.s13", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 13, "text": "爱秦乎？", "len": 4}
{"sid": "046_田敬仲完世家.22.1.s14", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 14, "text": "” 王曰：“爱齐而憎秦。", "len": 12}
{"sid": "046_田敬仲完世家.22.1.s15", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 15, "text": "” 曰：“两帝立约伐赵，孰与伐桀宋之利？", "len": 20}
{"sid": "046_田敬仲完世家.22.1.s16", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 16, "text": "” 王曰：“伐桀宋利。", "len": 11}
{"sid": "046_田敬仲完世家.22.1.s17", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 17, "text": "” 对曰：“夫约钧，然与秦为帝而天下独尊秦而轻齐，释帝则天下爱齐而憎秦，伐赵不如伐桀宋之利，故原王明释帝以收天下，倍约宾秦，无争重，而王以其间举宋。", "len": 74}
{"sid": "046_田敬仲完世家.22.1.s18", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 18, "text": "夫有宋，卫之阳地危；有济西，赵之阿东国危；有淮北，楚之东国危；有陶、平陆，梁门不开。", "len": 42}
{"sid": "046_田敬仲完世家.22.1.s19", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 19, "text": "释帝而贷之以伐桀宋之事，国重而名尊，燕楚所以形服，天下莫敢不听，此汤武之举也。", "len": 39}
{"sid": "046_田敬仲完世家.22.1.s20", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 20, "text": "敬秦以为名，而後使天下憎之，此所谓以卑为尊者也。", "len": 24}
{"sid": "046_田敬仲完世家.22.1.s21", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 21, "text": "原王孰虑之。", "len": 6}
{"sid": "046_田敬仲完世家.22.1.s22", "chapter": "046_田敬仲完世家", "para": "22.1", "seq": 22, "text": "” 於是齐去帝复为王，秦亦去帝位。", "len": 17}
{"sid": "046_田敬仲完世家.23.1.s1", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 1, "text": "三十八年，伐宋。", "len": 8}
{"sid": "046_田敬仲完世家.23.1.s2", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 2, "text": "秦昭王怒曰：“吾爱宋与爱新城、阳晋同。", "len": 19}
{"sid": "046_田敬仲完世家.23.1.s3", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 3, "text": "韩聂与吾友也，而攻吾所爱，何也？", "len": 16}
{"sid": "046_田敬仲完世家.23.1.s4", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 4, "text": "” 苏代为齐谓秦王曰：“韩聂之攻宋，所以为王也。", "len": 24}
{"sid": "046_田敬仲完世家.23.1.s5", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 5, "text": "齐彊，辅之以宋，楚魏必恐，恐必西事秦，是王不烦一兵，不伤一士，无事而割安邑也，此韩聂之所祷於王也。", "len": 49}
{"sid": "046_田敬仲完世家.23.1.s6", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 6, "text": "” 秦王曰：“吾患齐之难知。", "len": 14}
{"sid": "046_田敬仲完世家.23.1.s7", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 7, "text": "一从一衡，其说何也？", "len": 10}
{"sid": "046_田敬仲完世家.23.1.s8", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 8, "text": "” 对曰：“天下国令齐可知乎？", "len": 15}
{"sid": "046_田敬仲完世家.23.1.s9", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 9, "text": "齐以攻宋，其知事秦以万乘之国自辅，不西事秦则宋治不安。", "len": 27}
{"sid": "046_田敬仲完世家.23.1.s10", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 10, "text": "中国白头游敖之士皆积智欲离齐秦之交，伏式结轶西驰者，未有一人言善齐者也，伏式结轶东驰者，未有一人言善秦者也。", "len": 54}
{"sid": "046_田敬仲完世家.23.1.s11", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 11, "text": "何则？", "len": 3}
{"sid": "046_田敬仲完世家.23.1.s12", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 12, "text": "皆不欲齐秦之合也。", "len": 9}
{"sid": "046_田敬仲完世家.23.1.s13", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 13, "text": "何晋楚之智而齐秦之愚也！", "len": 12}
{"sid": "046_田敬仲完世家.23.1.s14", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 14, "text": "晋楚合必议齐秦，齐秦合必图晋楚，请以此决事。", "len": 22}
{"sid": "046_田敬仲完世家.23.1.s15", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 15, "text": "” 秦王曰：“诺。", "len": 9}
{"sid": "046_田敬仲完世家.23.1.s16", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 16, "text": "” 於是齐遂伐宋，宋王出亡，死於温。", "len": 18}
{"sid": "046_田敬仲完世家.23.1.s17", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 17, "text": "齐南割楚之淮北，西侵三晋，欲以并周室，为天子。", "len": 23}
{"sid": "046_田敬仲完世家.23.1.s18", "chapter": "046_田敬仲完世家", "para": "23.1", "seq": 18, "text": "泗上诸侯邹鲁之君皆称臣，诸侯恐惧。", "len": 17}
{"sid": "046_田敬仲完世家.23.2.s1", "chapter": "046_田敬仲完世家", "para": "23.2", "seq": 1, "text": "三十九年，秦来伐，拔我列城九。", "len": 15}
{"sid": "046_田敬仲完世家.24.1.s1", "chapter": "046_田敬仲完世家", "para": "24.1", "seq": 1, "text": "四十年，燕、秦、楚、三晋合谋，各出锐师以伐，败我济西。", "len": 27}
{"sid": "046_田敬仲完世家.24.1.s2", "chapter": "046_田敬仲完世家", "para": "24.1", "seq": 2, "text": "王解而卻。", "len": 5}
{"sid": "046_田敬仲完世家.24.1.s3", "chapter": "046_田敬仲完世家", "para": "24.1", "seq": 3, "text": "燕将乐毅遂入临淄，尽取齐之宝藏器。", "len": 17}
{"sid": "046_田敬仲完世家.24.1.s4", "chapter": "046_田敬仲完世家", "para": "24.1", "seq": 4, "text": "湣王出亡，之卫。", "len": 8}
{"sid": "046_田敬仲完世家.24.1.s5", "chapter": "046_田敬仲完世家", "para": "24.1", "seq": 5, "text": "卫君辟宫舍之，称臣而共具。", "len": 13}
{"sid": "046_田敬仲完世家.24.1.s6", "chapter": "046_田敬仲完世家", "para": "24.1", "seq": 6, "text": "湣王不逊，人侵之。", "len": 9}
{"sid": "046_田敬仲完世家.24.1.s7", "chapter": "046_田敬仲完世家", "para": "24.1", "seq": 7, "text": "湣王去，走邹、鲁，有骄色，邹、鲁君弗内，遂走莒。", "len": 24}
{"sid": "046_田敬仲完世家.24.1.s8", "chapter": "046_田敬仲完世家", "para": "24.1", "seq": 8, "text": "楚使淖齿将兵救齐，因相齐湣王。", "len": 15}
{"sid": "046_田敬仲完世家.24.1.s9", "chapter": "046_田敬仲完世家", "para": "24.1", "seq": 9, "text": "淖齿遂杀湣王而与燕共分齐之侵地卤器。", "len": 18}
{"sid": "046_田敬仲完世家.25.1.s1", "chapter": "046_田敬仲完世家", "para": "25.1", "seq": 1, "text": "湣王之遇杀，其子法章变名姓为莒太史敫家庸。", "len": 21}
{"sid": "046_田敬仲完世家.25.1.s2", "chapter": "046_田敬仲完世家", "para": "25.1", "seq": 2, "text": "太史敫女奇法章状貌，以为非恆人，怜而常窃衣食之，而与私通焉。", "len": 30}
{"sid": "046_田敬仲完世家.25.1.s3", "chapter": "046_田敬仲完世家", "para": "25.1", "seq": 3, "text": "淖齿既以去莒，莒中人及齐亡臣相聚求湣王子，欲立之。", "len": 25}
{"sid": "046_田敬仲完世家.25.1.s4", "chapter": "046_田敬仲完世家", "para": "25.1", "seq": 4, "text": "法章惧其诛己也，久之，乃敢自言“我湣王子也”。", "len": 23}
{"sid": "046_田敬仲完世家.25.1.s5", "chapter": "046_田敬仲完世家", "para": "25.1", "seq": 5, "text": "於是莒人共立法章，是为襄王。", "len": 14}
{"sid": "046_田敬仲完世家.25.1.s6", "chapter": "046_田敬仲完世家", "para": "25.1", "seq": 6, "text": "以保莒城而布告齐国中：“王已立在莒矣。”", "len": 20}
{"sid": "046_田敬仲完世家.25.2.s1", "chapter": "046_田敬仲完世家", "para": "25.2", "seq": 1, "text": "襄王既立，立太史氏女为王后，是为君王后，生子建。", "len": 24}
{"sid": "046_田敬仲完世家.25.2.s2", "chapter": "046_田敬仲完世家", "para": "25.2", "seq": 2, "text": "太史敫曰：“女不取媒因自嫁，非吾种也，汙吾世。", "len": 23}
{"sid": "046_田敬仲完世家.25.2.s3", "chapter": "046_田敬仲完世家", "para": "25.2", "seq": 3, "text": "” 终身不睹君王后。", "len": 10}
{"sid": "046_田敬仲完世家.25.2.s4", "chapter": "046_田敬仲完世家", "para": "25.2", "seq": 4, "text": "君王后贤，不以不睹故失人子之礼。", "len": 16}
{"sid": "046_田敬仲完世家.25.3.s1", "chapter": "046_田敬仲完世家", "para": "25.3", "seq": 1, "text": "襄王在莒五年，田单以即墨攻破燕军，迎襄王於莒，入临菑。", "len": 27}
{"sid": "046_田敬仲完世家.25.3.s2", "chapter": "046_田敬仲完世家", "para": "25.3", "seq": 2, "text": "齐故地尽复属齐。", "len": 8}
{"sid": "046_田敬仲完世家.25.3.s3", "chapter": "046_田敬仲完世家", "para": "25.3", "seq": 3, "text": "齐封田单为安平君。", "len": 9}
{"sid": "046_田敬仲完世家.25.4.s1", "chapter": "046_田敬仲完世家", "para": "25.4", "seq": 1, "text": "十四年，秦击我刚寿。", "len": 10}
{"sid": "046_田敬仲完世家.25.4.s2", "chapter": "046_田敬仲完世家", "para": "25.4", "seq": 2, "text": "十九年，襄王卒，子建立。", "len": 12}
{"sid": "046_田敬仲完世家.26.1.s1", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 1, "text": "王建立六年，秦攻赵，齐楚救之。", "len": 15}
{"sid": "046_田敬仲完世家.26.1.s2", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 2, "text": "秦计曰：“齐楚救赵，亲则退兵，不亲遂攻之。", "len": 21}
{"sid": "046_田敬仲完世家.26.1.s3", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 3, "text": "” 赵无食，请粟於齐，齐不听。", "len": 15}
{"sid": "046_田敬仲完世家.26.1.s4", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 4, "text": "周子曰：“不如听之以退秦兵，不听则秦兵不卻，是秦之计中而齐楚之计过也。", "len": 35}
{"sid": "046_田敬仲完世家.26.1.s5", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 5, "text": "且赵之於齐楚，扞蔽也，犹齿之有脣也，脣亡则齿寒。", "len": 24}
{"sid": "046_田敬仲完世家.26.1.s6", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 6, "text": "今日亡赵，明日患及齐楚。", "len": 12}
{"sid": "046_田敬仲完世家.26.1.s7", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 7, "text": "且救赵之务，宜若奉漏甕沃焦釜也。", "len": 16}
{"sid": "046_田敬仲完世家.26.1.s8", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 8, "text": "夫救赵，高义也；卻秦兵，显名也。", "len": 16}
{"sid": "046_田敬仲完世家.26.1.s9", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 9, "text": "义救亡国，威卻彊秦之兵，不务为此而务爱粟，为国计者过矣。", "len": 28}
{"sid": "046_田敬仲完世家.26.1.s10", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 10, "text": "” 齐王弗听。", "len": 7}
{"sid": "046_田敬仲完世家.26.1.s11", "chapter": "046_田敬仲完世家", "para": "26.1", "seq": 11, "text": "秦破赵於长平四十馀万，遂围邯郸。", "len": 16}
{"sid": "046_田敬仲完世家.26.2.s1", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 1, "text": "十六年，秦灭周。", "len": 8}
{"sid": "046_田敬仲完世家.26.2.s2", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 2, "text": "君王后卒。", "len": 5}
{"sid": "046_田敬仲完世家.26.2.s3", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 3, "text": "二十三年，秦置东郡。", "len": 10}
{"sid": "046_田敬仲完世家.26.2.s4", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 4, "text": "二十八年，王入朝秦，秦王政置酒咸阳。", "len": 18}
{"sid": "046_田敬仲完世家.26.2.s5", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 5, "text": "三十五年，秦灭韩。", "len": 9}
{"sid": "046_田敬仲完世家.26.2.s6", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 6, "text": "三十七年，秦灭赵。", "len": 9}
{"sid": "046_田敬仲完世家.26.2.s7", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 7, "text": "三十八年，燕使荆轲刺秦王，秦王觉，杀轲。", "len": 20}
{"sid": "046_田敬仲完世家.26.2.s8", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 8, "text": "明年，秦破燕，燕王亡走辽东。", "len": 14}
{"sid": "046_田敬仲完世家.26.2.s9", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 9, "text": "明年，秦灭魏，秦兵次於历下。", "len": 14}
{"sid": "046_田敬仲完世家.26.2.s10", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 10, "text": "四十二年，秦灭楚。", "len": 9}
{"sid": "046_田敬仲完世家.26.2.s11", "chapter": "046_田敬仲完世家", "para": "26.2", "seq": 11, "text": "明年，虏代王嘉，灭燕王喜。", "len": 13}
{"sid": "046_田敬仲完世家.26.3.s1", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 1, "text": "四十四年，秦兵击齐。", "len": 10}
{"sid": "046_田敬仲完世家.26.3.s2", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 2, "text": "齐王听相后胜计，不战，以兵降秦。", "len": 16}
{"sid": "046_田敬仲完世家.26.3.s3", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 3, "text": "秦虏王建，迁之共。", "len": 9}
{"sid": "046_田敬仲完世家.26.3.s4", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 4, "text": "遂灭齐为郡。", "len": 6}
{"sid": "046_田敬仲完世家.26.3.s5", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 5, "text": "天下壹并於秦，秦王政立号为皇帝。", "len": 16}
{"sid": "046_田敬仲完世家.26.3.s6", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 6, "text": "始，君王后贤，事秦谨，与诸侯信，齐亦东边海上，秦日夜攻三晋、燕、楚，五国各自救於秦，以故王建立四十馀年不受兵。", "len": 55}
{"sid": "046_田敬仲完世家.26.3.s7", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 7, "text": "君王后死，后胜相齐，多受秦间金，多使宾客入秦，秦又多予金，客皆为反间，劝王去从朝秦，不脩攻战之备，不助五国攻秦，秦以故得灭五国。", "len": 64}
{"sid": "046_田敬仲完世家.26.3.s8", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 8, "text": "五国已亡，秦兵卒入临淄，民莫敢格者。", "len": 18}
{"sid": "046_田敬仲完世家.26.3.s9", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 9, "text": "王建遂降，迁於共。", "len": 9}
{"sid": "046_田敬仲完世家.26.3.s10", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 10, "text": "故齐人怨王建不蚤与诸侯合从攻秦，听奸臣宾客以亡其国，歌之曰：“松耶柏耶？", "len": 36}
{"sid": "046_田敬仲完世家.26.3.s11", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 11, "text": "住建共者客耶？", "len": 7}
{"sid": "046_田敬仲完世家.26.3.s12", "chapter": "046_田敬仲完世家", "para": "26.3", "seq": 12, "text": "” 疾建用客之不详也。", "len": 11}
{"sid": "046_田敬仲完世家.27.1.s1", "chapter": "046_田敬仲完世家", "para": "27.1", "seq": 1, "text": "太史公曰：盖孔子晚而喜易。", "len": 13}
{"sid": "046_田敬仲完世家.27.1.s2", "chapter": "046_田敬仲完世家", "para": "27.1", "seq": 2, "text": "易之为术，幽明远矣，非通人达才孰能注意焉！", "len": 21}
{"sid": "046_田敬仲完世家.27.1.s3", "chapter": "046_田敬仲完世家", "para": "27.1", "seq": 3, "text": "故周太史之卦田敬仲完，占至十世之後；及完奔齐，懿仲卜之亦云。", "len": 30}
{"sid": "046_田敬仲完世家.27.1.s4", "chapter": "046_田敬仲完世家", "para": "27.1", "seq": 4, "text": "田乞及常所以比犯二君，专齐国之政，非必事势之渐然也，盖若遵厌兆祥云。", "len": 34}
{"sid": "046_田敬仲完世家.27.1.s5", "chapter": "046_田敬仲完世家", "para": "27.1", "seq": 5, "text": "::: 赞", "len": 5}
{"sid": "046_田敬仲完世家.28.s1", "chapter": "046_田敬仲完世家", "para": "28", "seq": 1, "text": "田完避难，奔于大姜； 始辞羁旅，终然凤皇。", "len": 21}
{"sid": "046_田敬仲完世家.28.s2", "chapter": "046_田敬仲完世家", "para": "28", "seq": 2, "text": "物莫两盛，代五其昌。", "len": 10}
{"sid": "046_田敬仲完世家.28.s3", "chapter": "046_田敬仲完世家", "para": "28", "seq": 3, "text": "二君比犯，三晋争强。", "len": 10}
{"sid": "046_田敬仲完世家.28.s4", "chapter": "046_田敬仲完世家", "para": "28", "seq": 4, "text": "和始擅命，威遂称王。", "len": 10}
{"sid": "046_田敬仲完世家.28.s5", "chapter": "046_田敬仲完世家", "para": "28", "seq": 5, "text": "祭急燕、赵，弟列康、庄。", "len": 12}
{"sid": "046_田敬仲完世家.28.s6", "chapter": "046_田敬仲完世家", "para": "28", "seq": 6, "text": "秦假东帝，莒立法章。", "len": 10}
{"sid": "046_田敬仲完世家.28.s7", "chapter": "046_田敬仲完世家", "para": "28", "seq": 7, "text": "王建失国，松柏苍苍。", "len": 10}
{"sid": "046_田敬仲完世家.28.s8", "chapter": "046_田敬仲完世家", "para": "28", "seq": 8, "text": ":::", "len": 3}
