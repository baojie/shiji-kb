{"sid": "066_伍子胥列传.1.s1", "chapter": "066_伍子胥列传", "para": "1", "seq": 1, "text": "伍子胥者，楚人也，名员。", "len": 12}
{"sid": "066_伍子胥列传.1.s2", "chapter": "066_伍子胥列传", "para": "1", "seq": 2, "text": "员父曰伍奢。", "len": 6}
{"sid": "066_伍子胥列传.1.s3", "chapter": "066_伍子胥列传", "para": "1", "seq": 3, "text": "员兄曰伍尚。", "len": 6}
{"sid": "066_伍子胥列传.1.s4", "chapter": "066_伍子胥列传", "para": "1", "seq": 4, "text": "其先曰伍举，以直谏事楚庄王，有显，故其後世有名於楚。", "len": 26}
{"sid": "066_伍子胥列传.2.s1", "chapter": "066_伍子胥列传", "para": "2", "seq": 1, "text": "楚平王有太子名曰建，使伍奢为太傅，费无忌为少傅。", "len": 24}
{"sid": "066_伍子胥列传.2.s2", "chapter": "066_伍子胥列传", "para": "2", "seq": 2, "text": "无忌不忠於太子建。", "len": 9}
{"sid": "066_伍子胥列传.2.s3", "chapter": "066_伍子胥列传", "para": "2", "seq": 3, "text": "平王使无忌为太子取妇於秦，秦女好，无忌驰归报平王曰：“秦女绝美，王可自取，而更为太子取妇。", "len": 45}
{"sid": "066_伍子胥列传.2.s4", "chapter": "066_伍子胥列传", "para": "2", "seq": 4, "text": "“平王遂自取秦女而绝爱幸之，生子轸。", "len": 18}
{"sid": "066_伍子胥列传.2.s5", "chapter": "066_伍子胥列传", "para": "2", "seq": 5, "text": "更为太子取妇。", "len": 7}
{"sid": "066_伍子胥列传.3.s1", "chapter": "066_伍子胥列传", "para": "3", "seq": 1, "text": "无忌既以秦女自媚於平王，因去太子而事平王。", "len": 21}
{"sid": "066_伍子胥列传.3.s2", "chapter": "066_伍子胥列传", "para": "3", "seq": 2, "text": "恐一旦平王卒而太子立，杀己，乃因谗太子建。", "len": 21}
{"sid": "066_伍子胥列传.3.s3", "chapter": "066_伍子胥列传", "para": "3", "seq": 3, "text": "建母，蔡女也，无宠於平王。", "len": 13}
{"sid": "066_伍子胥列传.3.s4", "chapter": "066_伍子胥列传", "para": "3", "seq": 4, "text": "平王稍益疏建，使建守城父，备边兵。", "len": 17}
{"sid": "066_伍子胥列传.4.s1", "chapter": "066_伍子胥列传", "para": "4", "seq": 1, "text": "顷之，无忌又日夜言太子短於王曰：“太子以秦女之故，不能无怨望，原王少自备也。", "len": 38}
{"sid": "066_伍子胥列传.4.s2", "chapter": "066_伍子胥列传", "para": "4", "seq": 2, "text": "自太子居城父，将兵，外交诸侯，且欲入为乱矣。", "len": 22}
{"sid": "066_伍子胥列传.4.s3", "chapter": "066_伍子胥列传", "para": "4", "seq": 3, "text": "“平王乃召其太傅伍奢考问之。", "len": 14}
{"sid": "066_伍子胥列传.4.s4", "chapter": "066_伍子胥列传", "para": "4", "seq": 4, "text": "伍奢知无忌谗太子於平王，因曰：“王独柰何以谗贼小臣疏骨肉之亲乎？", "len": 32}
{"sid": "066_伍子胥列传.4.s5", "chapter": "066_伍子胥列传", "para": "4", "seq": 5, "text": "“无忌曰：“王今不制，其事成矣。", "len": 16}
{"sid": "066_伍子胥列传.4.s6", "chapter": "066_伍子胥列传", "para": "4", "seq": 6, "text": "王且见禽。", "len": 5}
{"sid": "066_伍子胥列传.4.s7", "chapter": "066_伍子胥列传", "para": "4", "seq": 7, "text": "“於是平王怒，囚伍奢，而使城父司马奋扬往杀太子。", "len": 24}
{"sid": "066_伍子胥列传.4.s8", "chapter": "066_伍子胥列传", "para": "4", "seq": 8, "text": "行未至，奋扬使人先告太子：“太子急去，不然将诛。", "len": 24}
{"sid": "066_伍子胥列传.4.s9", "chapter": "066_伍子胥列传", "para": "4", "seq": 9, "text": "“太子建亡奔宋。", "len": 8}
{"sid": "066_伍子胥列传.5.s1", "chapter": "066_伍子胥列传", "para": "5", "seq": 1, "text": "无忌言於平王曰：“伍奢有二子，皆贤，不诛且为楚忧。", "len": 25}
{"sid": "066_伍子胥列传.5.s2", "chapter": "066_伍子胥列传", "para": "5", "seq": 2, "text": "可以其父质而召之，不然且为楚患。", "len": 16}
{"sid": "066_伍子胥列传.5.s3", "chapter": "066_伍子胥列传", "para": "5", "seq": 3, "text": "“王使使谓伍奢曰：“能致汝二子则生，不能则死。", "len": 23}
{"sid": "066_伍子胥列传.5.s4", "chapter": "066_伍子胥列传", "para": "5", "seq": 4, "text": "“伍奢曰：“尚为人仁，呼必来。", "len": 15}
{"sid": "066_伍子胥列传.5.s5", "chapter": "066_伍子胥列传", "para": "5", "seq": 5, "text": "员为人刚戾忍卼，能成大事，彼见来之并禽，其势必不来。", "len": 26}
{"sid": "066_伍子胥列传.5.s6", "chapter": "066_伍子胥列传", "para": "5", "seq": 6, "text": "“王不听，使人召二子曰：“来，吾生汝父；不来，今杀奢也。", "len": 28}
{"sid": "066_伍子胥列传.5.s7", "chapter": "066_伍子胥列传", "para": "5", "seq": 7, "text": "“伍尚欲往，员曰：“楚之召我兄弟，非欲以生我父也，恐有脱者後生患，故以父为质，诈召二子。", "len": 44}
{"sid": "066_伍子胥列传.5.s8", "chapter": "066_伍子胥列传", "para": "5", "seq": 8, "text": "二子到，则父子俱死。", "len": 10}
{"sid": "066_伍子胥列传.5.s9", "chapter": "066_伍子胥列传", "para": "5", "seq": 9, "text": "何益父之死？", "len": 6}
{"sid": "066_伍子胥列传.5.s10", "chapter": "066_伍子胥列传", "para": "5", "seq": 10, "text": "往而令雠不得报耳。", "len": 9}
{"sid": "066_伍子胥列传.5.s11", "chapter": "066_伍子胥列传", "para": "5", "seq": 11, "text": "不如奔他国，借力以雪父之耻，俱灭，无为也。", "len": 21}
{"sid": "066_伍子胥列传.5.s12", "chapter": "066_伍子胥列传", "para": "5", "seq": 12, "text": "“伍尚曰：“我知往终不能全父命。", "len": 16}
{"sid": "066_伍子胥列传.5.s13", "chapter": "066_伍子胥列传", "para": "5", "seq": 13, "text": "然恨父召我以求生而不往，後不能雪耻，终为天下笑耳。", "len": 25}
{"sid": "066_伍子胥列传.5.s14", "chapter": "066_伍子胥列传", "para": "5", "seq": 14, "text": "“谓员：“可去矣！", "len": 9}
{"sid": "066_伍子胥列传.5.s15", "chapter": "066_伍子胥列传", "para": "5", "seq": 15, "text": "汝能报杀父之雠，我将归死。", "len": 13}
{"sid": "066_伍子胥列传.5.s16", "chapter": "066_伍子胥列传", "para": "5", "seq": 16, "text": "“尚既就执，使者捕伍胥。", "len": 12}
{"sid": "066_伍子胥列传.5.s17", "chapter": "066_伍子胥列传", "para": "5", "seq": 17, "text": "伍胥贯弓执矢乡使者，使者不敢进，伍胥遂亡。", "len": 21}
{"sid": "066_伍子胥列传.5.s18", "chapter": "066_伍子胥列传", "para": "5", "seq": 18, "text": "闻太子建之在宋，往从之。", "len": 12}
{"sid": "066_伍子胥列传.5.s19", "chapter": "066_伍子胥列传", "para": "5", "seq": 19, "text": "奢闻子胥之亡也，曰：“楚国君臣且苦兵矣。", "len": 20}
{"sid": "066_伍子胥列传.5.s20", "chapter": "066_伍子胥列传", "para": "5", "seq": 20, "text": "“伍尚至楚，楚并杀奢与尚也。", "len": 14}
{"sid": "066_伍子胥列传.6.s1", "chapter": "066_伍子胥列传", "para": "6", "seq": 1, "text": "伍胥既至宋，宋有华氏之乱，乃与太子建俱奔於郑。", "len": 23}
{"sid": "066_伍子胥列传.6.s2", "chapter": "066_伍子胥列传", "para": "6", "seq": 2, "text": "郑人甚善之。", "len": 6}
{"sid": "066_伍子胥列传.6.s3", "chapter": "066_伍子胥列传", "para": "6", "seq": 3, "text": "太子建又適晋，晋顷公曰：“太子既善郑，郑信太子。", "len": 24}
{"sid": "066_伍子胥列传.6.s4", "chapter": "066_伍子胥列传", "para": "6", "seq": 4, "text": "太子能为我内应，而我攻其外，灭郑必矣。", "len": 19}
{"sid": "066_伍子胥列传.6.s5", "chapter": "066_伍子胥列传", "para": "6", "seq": 5, "text": "灭郑而封太子。", "len": 7}
{"sid": "066_伍子胥列传.6.s6", "chapter": "066_伍子胥列传", "para": "6", "seq": 6, "text": "“太子乃还郑。", "len": 7}
{"sid": "066_伍子胥列传.6.s7", "chapter": "066_伍子胥列传", "para": "6", "seq": 7, "text": "事未会，会自私欲杀其从者，从者知其谋，乃告之於郑。", "len": 25}
{"sid": "066_伍子胥列传.6.s8", "chapter": "066_伍子胥列传", "para": "6", "seq": 8, "text": "郑定公与子产诛杀太子建。", "len": 12}
{"sid": "066_伍子胥列传.6.s9", "chapter": "066_伍子胥列传", "para": "6", "seq": 9, "text": "建有子名胜。", "len": 6}
{"sid": "066_伍子胥列传.6.s10", "chapter": "066_伍子胥列传", "para": "6", "seq": 10, "text": "伍胥惧，乃与胜俱奔吴。", "len": 11}
{"sid": "066_伍子胥列传.6.s11", "chapter": "066_伍子胥列传", "para": "6", "seq": 11, "text": "到昭关，昭关欲执之。", "len": 10}
{"sid": "066_伍子胥列传.6.s12", "chapter": "066_伍子胥列传", "para": "6", "seq": 12, "text": "伍胥遂与胜独身步走，几不得脱。", "len": 15}
{"sid": "066_伍子胥列传.6.s13", "chapter": "066_伍子胥列传", "para": "6", "seq": 13, "text": "追者在後。", "len": 5}
{"sid": "066_伍子胥列传.6.s14", "chapter": "066_伍子胥列传", "para": "6", "seq": 14, "text": "至江，江上有一渔父乘船，知伍胥之急，乃渡伍胥。", "len": 23}
{"sid": "066_伍子胥列传.6.s15", "chapter": "066_伍子胥列传", "para": "6", "seq": 15, "text": "伍胥既渡，解其剑曰：“此剑直百金，以与父。", "len": 21}
{"sid": "066_伍子胥列传.6.s16", "chapter": "066_伍子胥列传", "para": "6", "seq": 16, "text": "“父曰：“楚国之法，得伍胥者赐粟五万石，爵执珪，岂徒百金剑邪！", "len": 31}
{"sid": "066_伍子胥列传.6.s17", "chapter": "066_伍子胥列传", "para": "6", "seq": 17, "text": "“不受。", "len": 4}
{"sid": "066_伍子胥列传.6.s18", "chapter": "066_伍子胥列传", "para": "6", "seq": 18, "text": "伍胥未至吴而疾，止中道，乞食。", "len": 15}
{"sid": "066_伍子胥列传.6.s19", "chapter": "066_伍子胥列传", "para": "6", "seq": 19, "text": "至於吴，吴王僚方用事，公子光为将。", "len": 17}
{"sid": "066_伍子胥列传.6.s20", "chapter": "066_伍子胥列传", "para": "6", "seq": 20, "text": "伍胥乃因公子光以求见吴王。", "len": 13}
{"sid": "066_伍子胥列传.7.s1", "chapter": "066_伍子胥列传", "para": "7", "seq": 1, "text": "久之，楚平王以其边邑锺离与吴边邑卑梁氏俱蚕，两女子争桑相攻，乃大怒，至於两国举兵相伐。", "len": 43}
{"sid": "066_伍子胥列传.7.s2", "chapter": "066_伍子胥列传", "para": "7", "seq": 2, "text": "吴使公子光伐楚，拔其锺离、居巢而归。", "len": 18}
{"sid": "066_伍子胥列传.7.s3", "chapter": "066_伍子胥列传", "para": "7", "seq": 3, "text": "伍子胥说吴王僚曰：“楚可破也。", "len": 15}
{"sid": "066_伍子胥列传.7.s4", "chapter": "066_伍子胥列传", "para": "7", "seq": 4, "text": "原复遣公子光。", "len": 7}
{"sid": "066_伍子胥列传.7.s5", "chapter": "066_伍子胥列传", "para": "7", "seq": 5, "text": "“公子光谓吴王曰：“彼伍胥父兄为戮於楚，而劝王伐楚者，欲以自报其雠耳。", "len": 35}
{"sid": "066_伍子胥列传.7.s6", "chapter": "066_伍子胥列传", "para": "7", "seq": 6, "text": "伐楚未可破也。", "len": 7}
{"sid": "066_伍子胥列传.7.s7", "chapter": "066_伍子胥列传", "para": "7", "seq": 7, "text": "“伍胥知公子光有内志，欲杀王而自立，未可说以外事，乃进专诸於公子光，退而与太子建之子胜耕於野。", "len": 47}
{"sid": "066_伍子胥列传.8.s1", "chapter": "066_伍子胥列传", "para": "8", "seq": 1, "text": "五年而楚平王卒。", "len": 8}
{"sid": "066_伍子胥列传.8.s2", "chapter": "066_伍子胥列传", "para": "8", "seq": 2, "text": "初，平王所夺太子建秦女生子轸，及平王卒，轸竟立为後，是为昭王。", "len": 31}
{"sid": "066_伍子胥列传.8.s3", "chapter": "066_伍子胥列传", "para": "8", "seq": 3, "text": "吴王僚因楚丧，使二公子将兵往袭楚。", "len": 17}
{"sid": "066_伍子胥列传.8.s4", "chapter": "066_伍子胥列传", "para": "8", "seq": 4, "text": "楚发兵绝吴兵之後，不得归。", "len": 13}
{"sid": "066_伍子胥列传.8.s5", "chapter": "066_伍子胥列传", "para": "8", "seq": 5, "text": "吴国内空，而公子光乃令专诸袭刺吴王僚而自立，是为吴王阖庐。", "len": 29}
{"sid": "066_伍子胥列传.8.s6", "chapter": "066_伍子胥列传", "para": "8", "seq": 6, "text": "阖庐既立，得志，乃召伍员以为行人，而与谋国事。", "len": 23}
{"sid": "066_伍子胥列传.9.s1", "chapter": "066_伍子胥列传", "para": "9", "seq": 1, "text": "楚诛其大臣郤宛、伯州犁，伯州犁之孙伯嚭亡奔吴，吴亦以嚭为大夫。", "len": 31}
{"sid": "066_伍子胥列传.9.s2", "chapter": "066_伍子胥列传", "para": "9", "seq": 2, "text": "前王僚所遣二公子将兵伐楚者，道绝不得归。", "len": 20}
{"sid": "066_伍子胥列传.9.s3", "chapter": "066_伍子胥列传", "para": "9", "seq": 3, "text": "後闻阖庐弑王僚自立，遂以其兵降楚，楚封之於舒。", "len": 23}
{"sid": "066_伍子胥列传.9.s4", "chapter": "066_伍子胥列传", "para": "9", "seq": 4, "text": "阖庐立三年，乃兴师与伍胥、伯嚭伐楚，拔舒，遂禽故吴反二将军。", "len": 30}
{"sid": "066_伍子胥列传.9.s5", "chapter": "066_伍子胥列传", "para": "9", "seq": 5, "text": "因欲至郢，将军孙武曰：“民劳，未可，且待之。", "len": 22}
{"sid": "066_伍子胥列传.9.s6", "chapter": "066_伍子胥列传", "para": "9", "seq": 6, "text": "“乃归。", "len": 4}
{"sid": "066_伍子胥列传.10.s1", "chapter": "066_伍子胥列传", "para": "10", "seq": 1, "text": "四年，吴伐楚，取六与灊。", "len": 12}
{"sid": "066_伍子胥列传.10.s2", "chapter": "066_伍子胥列传", "para": "10", "seq": 2, "text": "五年，伐越，败之。", "len": 9}
{"sid": "066_伍子胥列传.10.s3", "chapter": "066_伍子胥列传", "para": "10", "seq": 3, "text": "六年，楚昭王使公子囊瓦将兵伐吴。", "len": 16}
{"sid": "066_伍子胥列传.10.s4", "chapter": "066_伍子胥列传", "para": "10", "seq": 4, "text": "吴使伍员迎击，大破楚军於豫章，取楚之居巢。", "len": 21}
{"sid": "066_伍子胥列传.11.s1", "chapter": "066_伍子胥列传", "para": "11", "seq": 1, "text": "九年，吴王阖庐谓子胥、孙武曰：“始子言郢未可入，今果何如？", "len": 29}
{"sid": "066_伍子胥列传.11.s2", "chapter": "066_伍子胥列传", "para": "11", "seq": 2, "text": "“二子对曰：“楚将囊瓦贪，而唐、蔡皆怨之。", "len": 21}
{"sid": "066_伍子胥列传.11.s3", "chapter": "066_伍子胥列传", "para": "11", "seq": 3, "text": "王必欲大伐之，必先得唐、蔡乃可。", "len": 16}
{"sid": "066_伍子胥列传.11.s4", "chapter": "066_伍子胥列传", "para": "11", "seq": 4, "text": "“阖庐听之，悉兴师与唐、蔡伐楚，与楚夹汉水而陈。", "len": 24}
{"sid": "066_伍子胥列传.11.s5", "chapter": "066_伍子胥列传", "para": "11", "seq": 5, "text": "吴王之弟夫概将兵请从，王不听，遂以其属五千人击楚将子常。", "len": 28}
{"sid": "066_伍子胥列传.11.s6", "chapter": "066_伍子胥列传", "para": "11", "seq": 6, "text": "子常败走，奔郑。", "len": 8}
{"sid": "066_伍子胥列传.11.s7", "chapter": "066_伍子胥列传", "para": "11", "seq": 7, "text": "於是吴乘胜而前，五战，遂至郢。", "len": 15}
{"sid": "066_伍子胥列传.11.s8", "chapter": "066_伍子胥列传", "para": "11", "seq": 8, "text": "己卯，楚昭王出奔。", "len": 9}
{"sid": "066_伍子胥列传.11.s9", "chapter": "066_伍子胥列传", "para": "11", "seq": 9, "text": "庚辰，吴王入郢。", "len": 8}
{"sid": "066_伍子胥列传.12.s1", "chapter": "066_伍子胥列传", "para": "12", "seq": 1, "text": "昭王出亡，入云梦；盗击王，王走郧。", "len": 17}
{"sid": "066_伍子胥列传.12.s2", "chapter": "066_伍子胥列传", "para": "12", "seq": 2, "text": "郧公弟怀曰：“平王杀我父，我杀其子，不亦可乎！", "len": 23}
{"sid": "066_伍子胥列传.12.s3", "chapter": "066_伍子胥列传", "para": "12", "seq": 3, "text": "“郧公恐其弟杀王，与王奔随。", "len": 14}
{"sid": "066_伍子胥列传.12.s4", "chapter": "066_伍子胥列传", "para": "12", "seq": 4, "text": "吴兵围随，谓随人曰：“周之子孙在汉川者，楚尽灭之。", "len": 25}
{"sid": "066_伍子胥列传.12.s5", "chapter": "066_伍子胥列传", "para": "12", "seq": 5, "text": "“随人欲杀王，王子綦匿王，己自为王以当之。", "len": 21}
{"sid": "066_伍子胥列传.12.s6", "chapter": "066_伍子胥列传", "para": "12", "seq": 6, "text": "随人卜与王於吴，不吉，乃谢吴不与王。", "len": 18}
{"sid": "066_伍子胥列传.13.s1", "chapter": "066_伍子胥列传", "para": "13", "seq": 1, "text": "始伍员与申包胥为交，员之亡也，谓包胥曰：“我必覆楚。", "len": 26}
{"sid": "066_伍子胥列传.13.s2", "chapter": "066_伍子胥列传", "para": "13", "seq": 2, "text": "“包胥曰：“我必存之。", "len": 11}
{"sid": "066_伍子胥列传.13.s3", "chapter": "066_伍子胥列传", "para": "13", "seq": 3, "text": "“及吴兵入郢，伍子胥求昭王。", "len": 14}
{"sid": "066_伍子胥列传.13.s4", "chapter": "066_伍子胥列传", "para": "13", "seq": 4, "text": "既不得，乃掘楚平王墓，出其尸，鞭之三百，然後已。", "len": 24}
{"sid": "066_伍子胥列传.13.s5", "chapter": "066_伍子胥列传", "para": "13", "seq": 5, "text": "申包胥亡於山中，使人谓子胥曰：“子之报雠，其以甚乎！", "len": 26}
{"sid": "066_伍子胥列传.13.s6", "chapter": "066_伍子胥列传", "para": "13", "seq": 6, "text": "吾闻之，人众者胜天，天定亦能破人。", "len": 17}
{"sid": "066_伍子胥列传.13.s7", "chapter": "066_伍子胥列传", "para": "13", "seq": 7, "text": "今子故平王之臣，亲北面而事之，今至於僇死人，此岂其无天道之极乎！", "len": 32}
{"sid": "066_伍子胥列传.13.s8", "chapter": "066_伍子胥列传", "para": "13", "seq": 8, "text": "“伍子胥曰：“为我谢申包胥曰，吾日莫途远，吾故倒行而逆施|倒行逆施之。", "len": 35}
{"sid": "066_伍子胥列传.13.s9", "chapter": "066_伍子胥列传", "para": "13", "seq": 9, "text": "”於是申包胥走秦告急，求救於秦。", "len": 16}
{"sid": "066_伍子胥列传.13.s10", "chapter": "066_伍子胥列传", "para": "13", "seq": 10, "text": "秦不许。", "len": 4}
{"sid": "066_伍子胥列传.13.s11", "chapter": "066_伍子胥列传", "para": "13", "seq": 11, "text": "包胥立於秦廷，昼夜哭，七日七夜不绝其声。", "len": 20}
{"sid": "066_伍子胥列传.13.s12", "chapter": "066_伍子胥列传", "para": "13", "seq": 12, "text": "秦哀公怜之，曰：“楚虽无道，有臣若是，可无存乎！", "len": 24}
{"sid": "066_伍子胥列传.13.s13", "chapter": "066_伍子胥列传", "para": "13", "seq": 13, "text": "“乃遣车五百乘救楚击吴。", "len": 12}
{"sid": "066_伍子胥列传.13.s14", "chapter": "066_伍子胥列传", "para": "13", "seq": 14, "text": "六月，败吴兵於稷。", "len": 9}
{"sid": "066_伍子胥列传.13.s15", "chapter": "066_伍子胥列传", "para": "13", "seq": 15, "text": "会吴王久留楚求昭王，而阖庐弟夫概乃亡归，自立为王。", "len": 25}
{"sid": "066_伍子胥列传.13.s16", "chapter": "066_伍子胥列传", "para": "13", "seq": 16, "text": "阖庐闻之，乃释楚而归，击其弟夫概。", "len": 17}
{"sid": "066_伍子胥列传.13.s17", "chapter": "066_伍子胥列传", "para": "13", "seq": 17, "text": "夫概败走，遂奔楚。", "len": 9}
{"sid": "066_伍子胥列传.13.s18", "chapter": "066_伍子胥列传", "para": "13", "seq": 18, "text": "楚昭王见吴有内乱，乃复入郢。", "len": 14}
{"sid": "066_伍子胥列传.13.s19", "chapter": "066_伍子胥列传", "para": "13", "seq": 19, "text": "封夫概於堂谿，为堂谿氏。", "len": 12}
{"sid": "066_伍子胥列传.13.s20", "chapter": "066_伍子胥列传", "para": "13", "seq": 20, "text": "楚复与吴战，败吴，吴王乃归。", "len": 14}
{"sid": "066_伍子胥列传.14.s1", "chapter": "066_伍子胥列传", "para": "14", "seq": 1, "text": "後二岁，阖庐使太子夫差将兵伐楚，取番。", "len": 19}
{"sid": "066_伍子胥列传.14.s2", "chapter": "066_伍子胥列传", "para": "14", "seq": 2, "text": "楚惧吴复大来，乃去郢，徙於鄀。", "len": 15}
{"sid": "066_伍子胥列传.14.s3", "chapter": "066_伍子胥列传", "para": "14", "seq": 3, "text": "当是时，吴以伍子胥、孙武之谋，西破彊楚，北威齐晋，南服越人。", "len": 30}
{"sid": "066_伍子胥列传.15.s1", "chapter": "066_伍子胥列传", "para": "15", "seq": 1, "text": "其後四年，孔子相鲁。", "len": 10}
{"sid": "066_伍子胥列传.16.s1", "chapter": "066_伍子胥列传", "para": "16", "seq": 1, "text": "後五年，伐越。", "len": 7}
{"sid": "066_伍子胥列传.16.s2", "chapter": "066_伍子胥列传", "para": "16", "seq": 2, "text": "越王句践迎击，败吴於姑苏，伤阖庐指，军卻。", "len": 21}
{"sid": "066_伍子胥列传.16.s3", "chapter": "066_伍子胥列传", "para": "16", "seq": 3, "text": "阖庐病创将死，谓太子夫差曰：“尔忘句践杀尔父乎？", "len": 24}
{"sid": "066_伍子胥列传.16.s4", "chapter": "066_伍子胥列传", "para": "16", "seq": 4, "text": "“夫差对曰：“不敢忘。", "len": 11}
{"sid": "066_伍子胥列传.16.s5", "chapter": "066_伍子胥列传", "para": "16", "seq": 5, "text": "“是夕，阖庐死。", "len": 8}
{"sid": "066_伍子胥列传.16.s6", "chapter": "066_伍子胥列传", "para": "16", "seq": 6, "text": "夫差既立为王，以伯嚭为太宰，习战射。", "len": 18}
{"sid": "066_伍子胥列传.16.s7", "chapter": "066_伍子胥列传", "para": "16", "seq": 7, "text": "二年後伐越，败越於夫湫。", "len": 12}
{"sid": "066_伍子胥列传.16.s8", "chapter": "066_伍子胥列传", "para": "16", "seq": 8, "text": "越王句践乃以馀兵五千人栖於会稽之上，使大夫种厚币遗吴太宰嚭以请和，求委国为臣妾。", "len": 40}
{"sid": "066_伍子胥列传.16.s9", "chapter": "066_伍子胥列传", "para": "16", "seq": 9, "text": "吴王将许之。", "len": 6}
{"sid": "066_伍子胥列传.16.s10", "chapter": "066_伍子胥列传", "para": "16", "seq": 10, "text": "伍子胥谏曰：“越王为人能辛苦。", "len": 15}
{"sid": "066_伍子胥列传.16.s11", "chapter": "066_伍子胥列传", "para": "16", "seq": 11, "text": "今王不灭，後必悔之。", "len": 10}
{"sid": "066_伍子胥列传.16.s12", "chapter": "066_伍子胥列传", "para": "16", "seq": 12, "text": "“吴王不听，用太宰嚭计，与越平。", "len": 16}
{"sid": "066_伍子胥列传.17.s1", "chapter": "066_伍子胥列传", "para": "17", "seq": 1, "text": "其後五年，而吴王闻齐景公死而大臣争宠，新君弱，乃兴师北伐齐。", "len": 30}
{"sid": "066_伍子胥列传.17.s2", "chapter": "066_伍子胥列传", "para": "17", "seq": 2, "text": "伍子胥谏曰：“句践食不重味，吊死问疾，且欲有所用之也。", "len": 27}
{"sid": "066_伍子胥列传.17.s3", "chapter": "066_伍子胥列传", "para": "17", "seq": 3, "text": "此人不死，必为吴患。", "len": 10}
{"sid": "066_伍子胥列传.17.s4", "chapter": "066_伍子胥列传", "para": "17", "seq": 4, "text": "今吴之有越，犹人之有腹心疾也。", "len": 15}
{"sid": "066_伍子胥列传.17.s5", "chapter": "066_伍子胥列传", "para": "17", "seq": 5, "text": "而王不先越而乃务齐，不亦谬乎！", "len": 15}
{"sid": "066_伍子胥列传.17.s6", "chapter": "066_伍子胥列传", "para": "17", "seq": 6, "text": "” 吴王不听，伐齐，大败齐师於艾陵，遂威邹鲁之君以归。", "len": 27}
{"sid": "066_伍子胥列传.17.s7", "chapter": "066_伍子胥列传", "para": "17", "seq": 7, "text": "益疏子胥之谋。", "len": 7}
{"sid": "066_伍子胥列传.18.s1", "chapter": "066_伍子胥列传", "para": "18", "seq": 1, "text": "其後四年，吴王将北伐齐，越王句践用子贡之谋，乃率其众以助吴，而重宝以献遗太宰嚭。", "len": 40}
{"sid": "066_伍子胥列传.18.s2", "chapter": "066_伍子胥列传", "para": "18", "seq": 2, "text": "太宰嚭既数受越赂，其爱信越殊甚，日夜为言於吴王。", "len": 24}
{"sid": "066_伍子胥列传.18.s3", "chapter": "066_伍子胥列传", "para": "18", "seq": 3, "text": "吴王信用嚭之计。", "len": 8}
{"sid": "066_伍子胥列传.18.s4", "chapter": "066_伍子胥列传", "para": "18", "seq": 4, "text": "伍子胥谏曰：“夫越，腹心之病，今信其浮辞诈伪而贪齐。", "len": 26}
{"sid": "066_伍子胥列传.18.s5", "chapter": "066_伍子胥列传", "para": "18", "seq": 5, "text": "破齐，譬犹石田，无所用之。", "len": 13}
{"sid": "066_伍子胥列传.18.s6", "chapter": "066_伍子胥列传", "para": "18", "seq": 6, "text": "且盘庚之诰曰：‘有颠越不恭，劓殄灭之，俾无遗育，无使易种于兹邑。", "len": 32}
{"sid": "066_伍子胥列传.18.s7", "chapter": "066_伍子胥列传", "para": "18", "seq": 7, "text": "’此商之所以兴。", "len": 8}
{"sid": "066_伍子胥列传.18.s8", "chapter": "066_伍子胥列传", "para": "18", "seq": 8, "text": "原王释齐而先越；若不然，後将悔之无及。", "len": 19}
{"sid": "066_伍子胥列传.18.s9", "chapter": "066_伍子胥列传", "para": "18", "seq": 9, "text": "” 而吴王不听，使子胥於齐。", "len": 14}
{"sid": "066_伍子胥列传.18.s10", "chapter": "066_伍子胥列传", "para": "18", "seq": 10, "text": "子胥临行，谓其子曰：“吾数谏王，王不用，吾今见吴之亡矣。", "len": 28}
{"sid": "066_伍子胥列传.18.s11", "chapter": "066_伍子胥列传", "para": "18", "seq": 11, "text": "汝与吴俱亡，无益也。", "len": 10}
{"sid": "066_伍子胥列传.18.s12", "chapter": "066_伍子胥列传", "para": "18", "seq": 12, "text": "” 乃属其子於齐鲍牧，而还报吴。", "len": 16}
{"sid": "066_伍子胥列传.19.s1", "chapter": "066_伍子胥列传", "para": "19", "seq": 1, "text": "吴太宰嚭既与子胥有隙，因谗曰：“子胥为人刚暴，少恩，猜贼，其怨望恐为深祸也。", "len": 38}
{"sid": "066_伍子胥列传.19.s2", "chapter": "066_伍子胥列传", "para": "19", "seq": 2, "text": "前日王欲伐齐，子胥以为不可，王卒伐之而有大功。", "len": 23}
{"sid": "066_伍子胥列传.19.s3", "chapter": "066_伍子胥列传", "para": "19", "seq": 3, "text": "子胥耻其计谋不用，乃反怨望。", "len": 14}
{"sid": "066_伍子胥列传.19.s4", "chapter": "066_伍子胥列传", "para": "19", "seq": 4, "text": "而今王又复伐齐，子胥专愎彊谏，沮毁用事，徒幸吴之败以自胜其计谋耳。", "len": 33}
{"sid": "066_伍子胥列传.19.s5", "chapter": "066_伍子胥列传", "para": "19", "seq": 5, "text": "今王自行，悉国中武力以伐齐，而子胥谏不用，因辍谢，详病不行。", "len": 30}
{"sid": "066_伍子胥列传.19.s6", "chapter": "066_伍子胥列传", "para": "19", "seq": 6, "text": "王不可不备，此起祸不难。", "len": 12}
{"sid": "066_伍子胥列传.19.s7", "chapter": "066_伍子胥列传", "para": "19", "seq": 7, "text": "且嚭使人微伺之，其使於齐也，乃属其子於齐之鲍氏。", "len": 24}
{"sid": "066_伍子胥列传.19.s8", "chapter": "066_伍子胥列传", "para": "19", "seq": 8, "text": "夫为人臣，内不得意，外倚诸侯，自以为先王之谋臣，今不见用，常鞅鞅怨望。", "len": 35}
{"sid": "066_伍子胥列传.19.s9", "chapter": "066_伍子胥列传", "para": "19", "seq": 9, "text": "原王早图之。", "len": 6}
{"sid": "066_伍子胥列传.19.s10", "chapter": "066_伍子胥列传", "para": "19", "seq": 10, "text": "“吴王曰：“微子之言，吾亦疑之。", "len": 16}
{"sid": "066_伍子胥列传.19.s11", "chapter": "066_伍子胥列传", "para": "19", "seq": 11, "text": "“乃使使赐伍子胥属镂之剑，曰：“子以此死。", "len": 21}
{"sid": "066_伍子胥列传.19.s12", "chapter": "066_伍子胥列传", "para": "19", "seq": 12, "text": "“伍子胥仰天叹曰：“嗟乎！", "len": 13}
{"sid": "066_伍子胥列传.19.s13", "chapter": "066_伍子胥列传", "para": "19", "seq": 13, "text": "谗臣嚭为乱矣，王乃反诛我。", "len": 13}
{"sid": "066_伍子胥列传.19.s14", "chapter": "066_伍子胥列传", "para": "19", "seq": 14, "text": "我令若父霸。", "len": 6}
{"sid": "066_伍子胥列传.19.s15", "chapter": "066_伍子胥列传", "para": "19", "seq": 15, "text": "自若未立时，诸公子争立，我以死争之於先王，几不得立。", "len": 26}
{"sid": "066_伍子胥列传.19.s16", "chapter": "066_伍子胥列传", "para": "19", "seq": 16, "text": "若既得立，欲分吴国予我，我顾不敢望也。", "len": 19}
{"sid": "066_伍子胥列传.19.s17", "chapter": "066_伍子胥列传", "para": "19", "seq": 17, "text": "然今若听谀臣言以杀长者。", "len": 12}
{"sid": "066_伍子胥列传.19.s18", "chapter": "066_伍子胥列传", "para": "19", "seq": 18, "text": "“乃告其舍人曰：“必树吾墓上以梓，令可以为器；而抉吾眼县吴东门之上，以观越寇之入灭吴也。", "len": 44}
{"sid": "066_伍子胥列传.19.s19", "chapter": "066_伍子胥列传", "para": "19", "seq": 19, "text": "“乃自刭死。", "len": 6}
{"sid": "066_伍子胥列传.19.s20", "chapter": "066_伍子胥列传", "para": "19", "seq": 20, "text": "吴王闻之大怒，乃取子胥尸盛以鸱夷革，浮之江中。", "len": 23}
{"sid": "066_伍子胥列传.19.s21", "chapter": "066_伍子胥列传", "para": "19", "seq": 21, "text": "吴人怜之，为立祠於江上，因命曰胥山。", "len": 18}
{"sid": "066_伍子胥列传.20.s1", "chapter": "066_伍子胥列传", "para": "20", "seq": 1, "text": "吴王既诛伍子胥，遂伐齐。", "len": 12}
{"sid": "066_伍子胥列传.20.s2", "chapter": "066_伍子胥列传", "para": "20", "seq": 2, "text": "齐鲍氏杀其君悼公而立阳生。", "len": 13}
{"sid": "066_伍子胥列传.20.s3", "chapter": "066_伍子胥列传", "para": "20", "seq": 3, "text": "吴王欲讨其贼，不胜而去。", "len": 12}
{"sid": "066_伍子胥列传.20.s4", "chapter": "066_伍子胥列传", "para": "20", "seq": 4, "text": "其後二年，吴王召鲁卫之君会之橐皋。", "len": 17}
{"sid": "066_伍子胥列传.20.s5", "chapter": "066_伍子胥列传", "para": "20", "seq": 5, "text": "其明年，因北大会诸侯於黄池，以令周室。", "len": 19}
{"sid": "066_伍子胥列传.20.s6", "chapter": "066_伍子胥列传", "para": "20", "seq": 6, "text": "越王句践袭杀吴太子，破吴兵。", "len": 14}
{"sid": "066_伍子胥列传.20.s7", "chapter": "066_伍子胥列传", "para": "20", "seq": 7, "text": "吴王闻之，乃归，使使厚币与越平。", "len": 16}
{"sid": "066_伍子胥列传.20.s8", "chapter": "066_伍子胥列传", "para": "20", "seq": 8, "text": "後九年，越王句践遂灭吴，杀王夫差；而诛太宰嚭，以不忠於其君，而外受重赂，与己比周也。", "len": 42}
{"sid": "066_伍子胥列传.21.s1", "chapter": "066_伍子胥列传", "para": "21", "seq": 1, "text": "伍子胥初所与俱亡故楚太子建之子胜者，在於吴。", "len": 22}
{"sid": "066_伍子胥列传.21.s2", "chapter": "066_伍子胥列传", "para": "21", "seq": 2, "text": "吴王夫差之时，楚惠王欲召胜归楚。", "len": 16}
{"sid": "066_伍子胥列传.21.s3", "chapter": "066_伍子胥列传", "para": "21", "seq": 3, "text": "叶公谏曰：“胜好勇而阴求死士，殆有私乎！", "len": 20}
{"sid": "066_伍子胥列传.21.s4", "chapter": "066_伍子胥列传", "para": "21", "seq": 4, "text": "“惠王不听。", "len": 6}
{"sid": "066_伍子胥列传.21.s5", "chapter": "066_伍子胥列传", "para": "21", "seq": 5, "text": "遂召胜，使居楚之边邑鄢，号为白公。", "len": 17}
{"sid": "066_伍子胥列传.21.s6", "chapter": "066_伍子胥列传", "para": "21", "seq": 6, "text": "白公归楚三年而吴诛子胥。", "len": 12}
{"sid": "066_伍子胥列传.22.s1", "chapter": "066_伍子胥列传", "para": "22", "seq": 1, "text": "白公胜既归楚，怨郑之杀其父，乃阴养死士求报郑。", "len": 23}
{"sid": "066_伍子胥列传.22.s2", "chapter": "066_伍子胥列传", "para": "22", "seq": 2, "text": "归楚五年，请伐郑，楚令尹子西许之。", "len": 17}
{"sid": "066_伍子胥列传.22.s3", "chapter": "066_伍子胥列传", "para": "22", "seq": 3, "text": "兵未发而晋伐郑，郑请救於楚。", "len": 14}
{"sid": "066_伍子胥列传.22.s4", "chapter": "066_伍子胥列传", "para": "22", "seq": 4, "text": "楚使子西往救，与盟而还。", "len": 12}
{"sid": "066_伍子胥列传.22.s5", "chapter": "066_伍子胥列传", "para": "22", "seq": 5, "text": "白公胜怒曰：“非郑之仇，乃子西也。", "len": 17}
{"sid": "066_伍子胥列传.22.s6", "chapter": "066_伍子胥列传", "para": "22", "seq": 6, "text": "“胜自砺剑，人问曰：“何以为？", "len": 15}
{"sid": "066_伍子胥列传.22.s7", "chapter": "066_伍子胥列传", "para": "22", "seq": 7, "text": "“胜曰：“欲以杀子西。", "len": 11}
{"sid": "066_伍子胥列传.22.s8", "chapter": "066_伍子胥列传", "para": "22", "seq": 8, "text": "“子西闻之，笑曰：“胜如卵耳，何能为也。“", "len": 21}
{"sid": "066_伍子胥列传.23.s1", "chapter": "066_伍子胥列传", "para": "23", "seq": 1, "text": "其後四岁，白公胜与石乞袭杀楚令尹子西、司马子綦於朝。", "len": 26}
{"sid": "066_伍子胥列传.23.s2", "chapter": "066_伍子胥列传", "para": "23", "seq": 2, "text": "石乞曰：“不杀王，不可。", "len": 12}
{"sid": "066_伍子胥列传.23.s3", "chapter": "066_伍子胥列传", "para": "23", "seq": 3, "text": "“乃劫王如高府。", "len": 8}
{"sid": "066_伍子胥列传.23.s4", "chapter": "066_伍子胥列传", "para": "23", "seq": 4, "text": "石乞从者屈固负楚惠王亡走昭夫人之宫。", "len": 18}
{"sid": "066_伍子胥列传.23.s5", "chapter": "066_伍子胥列传", "para": "23", "seq": 5, "text": "叶公闻白公为乱，率其国人攻白公。", "len": 16}
{"sid": "066_伍子胥列传.23.s6", "chapter": "066_伍子胥列传", "para": "23", "seq": 6, "text": "白公之徒败，亡走山中，自杀。", "len": 14}
{"sid": "066_伍子胥列传.23.s7", "chapter": "066_伍子胥列传", "para": "23", "seq": 7, "text": "而虏石乞，而问白公尸处，不言将亨。", "len": 17}
{"sid": "066_伍子胥列传.23.s8", "chapter": "066_伍子胥列传", "para": "23", "seq": 8, "text": "石乞曰：“事成为卿，不成而亨，固其职也。", "len": 20}
{"sid": "066_伍子胥列传.23.s9", "chapter": "066_伍子胥列传", "para": "23", "seq": 9, "text": "“终不肯告其尸处。", "len": 9}
{"sid": "066_伍子胥列传.23.s10", "chapter": "066_伍子胥列传", "para": "23", "seq": 10, "text": "遂亨石乞，而求惠王复立之。", "len": 13}
{"sid": "066_伍子胥列传.23.s11", "chapter": "066_伍子胥列传", "para": "23", "seq": 11, "text": "::: 太史公曰", "len": 8}
{"sid": "066_伍子胥列传.24.s1", "chapter": "066_伍子胥列传", "para": "24", "seq": 1, "text": "太史公曰：怨毒之於人甚矣哉！", "len": 14}
{"sid": "066_伍子胥列传.24.s2", "chapter": "066_伍子胥列传", "para": "24", "seq": 2, "text": "王者尚不能行之於臣下，况同列乎！", "len": 16}
{"sid": "066_伍子胥列传.24.s3", "chapter": "066_伍子胥列传", "para": "24", "seq": 3, "text": "向令伍子胥从奢俱死，何异蝼蚁。", "len": 15}
{"sid": "066_伍子胥列传.24.s4", "chapter": "066_伍子胥列传", "para": "24", "seq": 4, "text": "弃小义，雪大耻，名垂於後世，悲夫！", "len": 17}
{"sid": "066_伍子胥列传.24.s5", "chapter": "066_伍子胥列传", "para": "24", "seq": 5, "text": "方子胥窘於江上，道乞食，志岂尝须臾忘郢邪？", "len": 21}
{"sid": "066_伍子胥列传.24.s6", "chapter": "066_伍子胥列传", "para": "24", "seq": 6, "text": "故隐忍就功名，非烈丈夫孰能致此哉？", "len": 17}
{"sid": "066_伍子胥列传.24.s7", "chapter": "066_伍子胥列传", "para": "24", "seq": 7, "text": "白公如不自立为君者，其功谋亦不可胜道者哉！", "len": 21}
{"sid": "066_伍子胥列传.24.s8", "chapter": "066_伍子胥列传", "para": "24", "seq": 8, "text": "::: ::: 赞", "len": 9}
{"sid": "066_伍子胥列传.25.s1", "chapter": "066_伍子胥列传", "para": "25", "seq": 1, "text": "谗人罔极，交乱四国。", "len": 10}
{"sid": "066_伍子胥列传.25.s2", "chapter": "066_伍子胥列传", "para": "25", "seq": 2, "text": "嗟彼伍氏，被兹凶慝！", "len": 10}
{"sid": "066_伍子胥列传.25.s3", "chapter": "066_伍子胥列传", "para": "25", "seq": 3, "text": "员独忍诟，志复冤毒。", "len": 10}
{"sid": "066_伍子胥列传.25.s4", "chapter": "066_伍子胥列传", "para": "25", "seq": 4, "text": "霸吴起师，伐楚逐北。", "len": 10}
{"sid": "066_伍子胥列传.25.s5", "chapter": "066_伍子胥列传", "para": "25", "seq": 5, "text": "鞭尸雪耻，抉眼弃德。", "len": 10}
{"sid": "066_伍子胥列传.25.s6", "chapter": "066_伍子胥列传", "para": "25", "seq": 6, "text": ":::", "len": 3}
