{"sid": "096_张丞相列传.1.s1", "chapter": "096_张丞相列传", "para": "1", "seq": 1, "text": "张丞相苍者，阳武人也。", "len": 11}
{"sid": "096_张丞相列传.1.s2", "chapter": "096_张丞相列传", "para": "1", "seq": 2, "text": "好书律历。", "len": 5}
{"sid": "096_张丞相列传.1.s3", "chapter": "096_张丞相列传", "para": "1", "seq": 3, "text": "秦时为御史，主柱下方书。", "len": 12}
{"sid": "096_张丞相列传.1.s4", "chapter": "096_张丞相列传", "para": "1", "seq": 4, "text": "有罪，亡归。", "len": 6}
{"sid": "096_张丞相列传.1.s5", "chapter": "096_张丞相列传", "para": "1", "seq": 5, "text": "及沛公略地过阳武，苍以客从攻南阳。", "len": 17}
{"sid": "096_张丞相列传.1.s6", "chapter": "096_张丞相列传", "para": "1", "seq": 6, "text": "苍坐法当斩，解衣伏质，身长大，肥白如瓠，时王陵见而怪其美士，乃言沛公，赦勿斩。", "len": 39}
{"sid": "096_张丞相列传.1.s7", "chapter": "096_张丞相列传", "para": "1", "seq": 7, "text": "遂从西入武关，至咸阳。", "len": 11}
{"sid": "096_张丞相列传.1.s8", "chapter": "096_张丞相列传", "para": "1", "seq": 8, "text": "沛公立为汉王，入汉中，还定三秦。", "len": 16}
{"sid": "096_张丞相列传.1.s9", "chapter": "096_张丞相列传", "para": "1", "seq": 9, "text": "陈馀击走常山王张耳，耳归汉，汉乃以张苍为常山守。", "len": 24}
{"sid": "096_张丞相列传.1.s10", "chapter": "096_张丞相列传", "para": "1", "seq": 10, "text": "从淮阴侯击赵，苍得陈馀。", "len": 12}
{"sid": "096_张丞相列传.1.s11", "chapter": "096_张丞相列传", "para": "1", "seq": 11, "text": "赵地已平，汉王以苍为代相，备边寇。", "len": 17}
{"sid": "096_张丞相列传.1.s12", "chapter": "096_张丞相列传", "para": "1", "seq": 12, "text": "已而徙为赵相，相赵王耳。", "len": 12}
{"sid": "096_张丞相列传.1.s13", "chapter": "096_张丞相列传", "para": "1", "seq": 13, "text": "耳卒，相赵王敖。", "len": 8}
{"sid": "096_张丞相列传.1.s14", "chapter": "096_张丞相列传", "para": "1", "seq": 14, "text": "复徙相代王。", "len": 6}
{"sid": "096_张丞相列传.1.s15", "chapter": "096_张丞相列传", "para": "1", "seq": 15, "text": "燕王臧荼反，高祖往击之。", "len": 12}
{"sid": "096_张丞相列传.1.s16", "chapter": "096_张丞相列传", "para": "1", "seq": 16, "text": "苍以代相从攻臧荼有功，以六年中封为北平侯，食邑千二百户。", "len": 28}
{"sid": "096_张丞相列传.2.s1", "chapter": "096_张丞相列传", "para": "2", "seq": 1, "text": "迁为计相，一月，更以列侯为主计四岁。", "len": 18}
{"sid": "096_张丞相列传.2.s2", "chapter": "096_张丞相列传", "para": "2", "seq": 2, "text": "是时萧何为相国，而张苍乃自秦时为柱下史，明习天下图书计籍。", "len": 29}
{"sid": "096_张丞相列传.2.s3", "chapter": "096_张丞相列传", "para": "2", "seq": 3, "text": "苍又善用算律历，故令苍以列侯居相府，领主郡国上计者。", "len": 26}
{"sid": "096_张丞相列传.2.s4", "chapter": "096_张丞相列传", "para": "2", "seq": 4, "text": "黥布反亡，汉立皇子长为淮南王，而张苍相之。", "len": 21}
{"sid": "096_张丞相列传.2.s5", "chapter": "096_张丞相列传", "para": "2", "seq": 5, "text": "十四年，迁为御史大夫。", "len": 11}
{"sid": "096_张丞相列传.3.s1", "chapter": "096_张丞相列传", "para": "3", "seq": 1, "text": "周昌者，沛人也。", "len": 8}
{"sid": "096_张丞相列传.3.s2", "chapter": "096_张丞相列传", "para": "3", "seq": 2, "text": "其从兄曰周苛，秦时皆为泗水卒史。", "len": 16}
{"sid": "096_张丞相列传.3.s3", "chapter": "096_张丞相列传", "para": "3", "seq": 3, "text": "及高祖起沛，击破泗水守监，於是周昌、周苛自卒史从沛公，沛公以周昌为职志，周苛为客。", "len": 41}
{"sid": "096_张丞相列传.3.s4", "chapter": "096_张丞相列传", "para": "3", "seq": 4, "text": "从入关，破秦。", "len": 7}
{"sid": "096_张丞相列传.3.s5", "chapter": "096_张丞相列传", "para": "3", "seq": 5, "text": "沛公立为汉王，以周苛为御史大夫，周昌为中尉。", "len": 22}
{"sid": "096_张丞相列传.4.s1", "chapter": "096_张丞相列传", "para": "4", "seq": 1, "text": "汉王四年，楚围汉王荥阳急，汉王遁出去，而使周苛守荥阳城。", "len": 28}
{"sid": "096_张丞相列传.4.s2", "chapter": "096_张丞相列传", "para": "4", "seq": 2, "text": "楚破荥阳城，欲令周苛将。", "len": 12}
{"sid": "096_张丞相列传.4.s3", "chapter": "096_张丞相列传", "para": "4", "seq": 3, "text": "苛骂曰：“若趣降汉王！", "len": 11}
{"sid": "096_张丞相列传.4.s4", "chapter": "096_张丞相列传", "para": "4", "seq": 4, "text": "不然，今为虏矣！", "len": 8}
{"sid": "096_张丞相列传.4.s5", "chapter": "096_张丞相列传", "para": "4", "seq": 5, "text": "” 项羽怒，亨周苛。", "len": 10}
{"sid": "096_张丞相列传.4.s6", "chapter": "096_张丞相列传", "para": "4", "seq": 6, "text": "於是乃拜周昌为御史大夫。", "len": 12}
{"sid": "096_张丞相列传.4.s7", "chapter": "096_张丞相列传", "para": "4", "seq": 7, "text": "常从击破项籍。", "len": 7}
{"sid": "096_张丞相列传.4.s8", "chapter": "096_张丞相列传", "para": "4", "seq": 8, "text": "以六年中与萧、曹等俱封：封周昌为汾阴侯；周苛子周成以父死事，封为高景侯。", "len": 36}
{"sid": "096_张丞相列传.5.s1", "chapter": "096_张丞相列传", "para": "5", "seq": 1, "text": "昌为人彊力，敢直言，自萧、曹等皆卑下之。", "len": 20}
{"sid": "096_张丞相列传.5.s2", "chapter": "096_张丞相列传", "para": "5", "seq": 2, "text": "昌尝燕时入奏事，高帝方拥戚姬，昌还走，高帝逐得，骑周昌项，问曰：“我何如主也？", "len": 39}
{"sid": "096_张丞相列传.5.s3", "chapter": "096_张丞相列传", "para": "5", "seq": 3, "text": "” 昌仰曰：“陛下即桀纣之主也。", "len": 16}
{"sid": "096_张丞相列传.5.s4", "chapter": "096_张丞相列传", "para": "5", "seq": 4, "text": "” 於是上笑之，然尤惮周昌。", "len": 14}
{"sid": "096_张丞相列传.5.s5", "chapter": "096_张丞相列传", "para": "5", "seq": 5, "text": "及帝欲废太子，而立戚姬子如意为太子，大臣固争之，莫能得；上以留侯策即止。", "len": 36}
{"sid": "096_张丞相列传.5.s6", "chapter": "096_张丞相列传", "para": "5", "seq": 6, "text": "而周昌廷争之彊，上问其说，昌为人吃，又盛怒，曰：“臣口不能言，然臣期期知其不可。", "len": 40}
{"sid": "096_张丞相列传.5.s7", "chapter": "096_张丞相列传", "para": "5", "seq": 7, "text": "陛下虽欲废太子，臣期期不奉诏。", "len": 15}
{"sid": "096_张丞相列传.5.s8", "chapter": "096_张丞相列传", "para": "5", "seq": 8, "text": "” 上欣然而笑。", "len": 8}
{"sid": "096_张丞相列传.5.s9", "chapter": "096_张丞相列传", "para": "5", "seq": 9, "text": "既罢，吕后侧耳於东箱听，见周昌，为跪谢曰：“微君，太子几废。”", "len": 31}
{"sid": "096_张丞相列传.6.s1", "chapter": "096_张丞相列传", "para": "6", "seq": 1, "text": "是後戚姬子如意为赵王，年十岁，高祖忧即万岁之後不全也。", "len": 27}
{"sid": "096_张丞相列传.6.s2", "chapter": "096_张丞相列传", "para": "6", "seq": 2, "text": "赵尧年少，为符玺御史。", "len": 11}
{"sid": "096_张丞相列传.6.s3", "chapter": "096_张丞相列传", "para": "6", "seq": 3, "text": "赵人方与公谓御史大夫周昌曰：“君之史赵尧，年虽少，然奇才也，君必异之，是且代君之位。", "len": 42}
{"sid": "096_张丞相列传.6.s4", "chapter": "096_张丞相列传", "para": "6", "seq": 4, "text": "” 周昌笑曰；“尧年少，刀笔吏耳，何能至是乎！", "len": 23}
{"sid": "096_张丞相列传.6.s5", "chapter": "096_张丞相列传", "para": "6", "seq": 5, "text": "” 居顷之，赵尧侍高祖。", "len": 12}
{"sid": "096_张丞相列传.6.s6", "chapter": "096_张丞相列传", "para": "6", "seq": 6, "text": "高祖独心不乐，悲歌，群臣不知上之所以然。", "len": 20}
{"sid": "096_张丞相列传.6.s7", "chapter": "096_张丞相列传", "para": "6", "seq": 7, "text": "赵尧进请问曰：“陛下所为不乐，非为赵王年少而戚夫人与吕后有卻邪？", "len": 32}
{"sid": "096_张丞相列传.6.s8", "chapter": "096_张丞相列传", "para": "6", "seq": 8, "text": "备万岁之後而赵王不能自全乎？", "len": 14}
{"sid": "096_张丞相列传.6.s9", "chapter": "096_张丞相列传", "para": "6", "seq": 9, "text": "” 高祖曰：“然。", "len": 9}
{"sid": "096_张丞相列传.6.s10", "chapter": "096_张丞相列传", "para": "6", "seq": 10, "text": "吾私忧之，不知所出。", "len": 10}
{"sid": "096_张丞相列传.6.s11", "chapter": "096_张丞相列传", "para": "6", "seq": 11, "text": "” 尧曰：“陛下独宜为赵王置贵彊相，及吕后、太子、群臣素所敬惮乃可。", "len": 34}
{"sid": "096_张丞相列传.6.s12", "chapter": "096_张丞相列传", "para": "6", "seq": 12, "text": "” 高祖曰：“然。", "len": 9}
{"sid": "096_张丞相列传.6.s13", "chapter": "096_张丞相列传", "para": "6", "seq": 13, "text": "吾念之欲如是，而群臣谁可者？", "len": 14}
{"sid": "096_张丞相列传.6.s14", "chapter": "096_张丞相列传", "para": "6", "seq": 14, "text": "” 尧曰：“御史大夫周昌，其人坚忍质直，且自吕后、太子及大臣皆素敬惮之。", "len": 36}
{"sid": "096_张丞相列传.6.s15", "chapter": "096_张丞相列传", "para": "6", "seq": 15, "text": "独昌可。", "len": 4}
{"sid": "096_张丞相列传.6.s16", "chapter": "096_张丞相列传", "para": "6", "seq": 16, "text": "” 高祖曰：“善。", "len": 9}
{"sid": "096_张丞相列传.6.s17", "chapter": "096_张丞相列传", "para": "6", "seq": 17, "text": "” 於是乃召周昌，谓曰：“吾欲固烦公，公彊为我相赵王。", "len": 27}
{"sid": "096_张丞相列传.6.s18", "chapter": "096_张丞相列传", "para": "6", "seq": 18, "text": "” 周昌泣曰：“臣初起从陛下，陛下独柰何中道而弃之於诸侯乎？", "len": 30}
{"sid": "096_张丞相列传.6.s19", "chapter": "096_张丞相列传", "para": "6", "seq": 19, "text": "” 高祖曰：“吾极知其左迁，然吾私忧赵王，念非公无可者。", "len": 28}
{"sid": "096_张丞相列传.6.s20", "chapter": "096_张丞相列传", "para": "6", "seq": 20, "text": "公不得已彊行！", "len": 7}
{"sid": "096_张丞相列传.6.s21", "chapter": "096_张丞相列传", "para": "6", "seq": 21, "text": "” 於是徙御史大夫周昌为赵相。", "len": 15}
{"sid": "096_张丞相列传.7.s1", "chapter": "096_张丞相列传", "para": "7", "seq": 1, "text": "既行久之，高祖持御史大夫印弄之，曰：“谁可以为御史大夫者？", "len": 29}
{"sid": "096_张丞相列传.7.s2", "chapter": "096_张丞相列传", "para": "7", "seq": 2, "text": "” 孰视赵尧，曰：“无以易尧。", "len": 15}
{"sid": "096_张丞相列传.7.s3", "chapter": "096_张丞相列传", "para": "7", "seq": 3, "text": "” 遂拜赵尧为御史大夫。", "len": 12}
{"sid": "096_张丞相列传.7.s4", "chapter": "096_张丞相列传", "para": "7", "seq": 4, "text": "尧亦前有军功食邑，及以御史大夫从击陈豨有功，封为江邑侯。", "len": 28}
{"sid": "096_张丞相列传.8.s1", "chapter": "096_张丞相列传", "para": "8", "seq": 1, "text": "高祖崩，吕太后使使召赵王，其相周昌令王称疾不行。", "len": 24}
{"sid": "096_张丞相列传.8.s2", "chapter": "096_张丞相列传", "para": "8", "seq": 2, "text": "使者三反，周昌固为不遣赵王。", "len": 14}
{"sid": "096_张丞相列传.8.s3", "chapter": "096_张丞相列传", "para": "8", "seq": 3, "text": "於是高后患之，乃使使召周昌。", "len": 14}
{"sid": "096_张丞相列传.8.s4", "chapter": "096_张丞相列传", "para": "8", "seq": 4, "text": "周昌至，谒高后，高后怒而骂周昌曰：“尔不知我之怨戚氏乎？", "len": 28}
{"sid": "096_张丞相列传.8.s5", "chapter": "096_张丞相列传", "para": "8", "seq": 5, "text": "而不遣赵王，何？", "len": 8}
{"sid": "096_张丞相列传.8.s6", "chapter": "096_张丞相列传", "para": "8", "seq": 6, "text": "” 昌既徵，高后使使召赵王，赵王果来。", "len": 19}
{"sid": "096_张丞相列传.8.s7", "chapter": "096_张丞相列传", "para": "8", "seq": 7, "text": "至长安月馀，饮药而死。", "len": 11}
{"sid": "096_张丞相列传.8.s8", "chapter": "096_张丞相列传", "para": "8", "seq": 8, "text": "周昌因谢病不朝见，三岁而死。", "len": 14}
{"sid": "096_张丞相列传.9.s1", "chapter": "096_张丞相列传", "para": "9", "seq": 1, "text": "後五岁，高后闻御史大夫江邑侯赵尧高祖时定赵王如意之画，乃抵尧罪，以广阿侯任敖为御史大夫。", "len": 44}
{"sid": "096_张丞相列传.10.s1", "chapter": "096_张丞相列传", "para": "10", "seq": 1, "text": "任敖者，故沛狱吏。", "len": 9}
{"sid": "096_张丞相列传.10.s2", "chapter": "096_张丞相列传", "para": "10", "seq": 2, "text": "高祖尝辟吏，吏系吕后，遇之不谨。", "len": 16}
{"sid": "096_张丞相列传.10.s3", "chapter": "096_张丞相列传", "para": "10", "seq": 3, "text": "任敖素善高祖，怒，击伤主吕后吏。", "len": 16}
{"sid": "096_张丞相列传.10.s4", "chapter": "096_张丞相列传", "para": "10", "seq": 4, "text": "及高祖初起，敖以客从为御史，守丰二岁，高祖立为汉王，东击项籍，敖迁为上党守。", "len": 38}
{"sid": "096_张丞相列传.10.s5", "chapter": "096_张丞相列传", "para": "10", "seq": 5, "text": "陈豨反时，敖坚守，封为广阿侯，食千八百户。", "len": 21}
{"sid": "096_张丞相列传.10.s6", "chapter": "096_张丞相列传", "para": "10", "seq": 6, "text": "高后时为御史大夫。", "len": 9}
{"sid": "096_张丞相列传.10.s7", "chapter": "096_张丞相列传", "para": "10", "seq": 7, "text": "三岁免，以平阳侯曹窋为御史大夫。", "len": 16}
{"sid": "096_张丞相列传.10.s8", "chapter": "096_张丞相列传", "para": "10", "seq": 8, "text": "高后崩，与大臣共诛吕禄等。", "len": 13}
{"sid": "096_张丞相列传.10.s9", "chapter": "096_张丞相列传", "para": "10", "seq": 9, "text": "免，以淮南相张苍为御史大夫。", "len": 14}
{"sid": "096_张丞相列传.11.s1", "chapter": "096_张丞相列传", "para": "11", "seq": 1, "text": "苍与绛侯等尊立代王为孝文皇帝。", "len": 15}
{"sid": "096_张丞相列传.11.s2", "chapter": "096_张丞相列传", "para": "11", "seq": 2, "text": "四年，丞相灌婴卒，张苍为丞相。", "len": 15}
{"sid": "096_张丞相列传.12.s1", "chapter": "096_张丞相列传", "para": "12", "seq": 1, "text": "自汉兴至孝文二十馀年，会天下初定，将相公卿皆军吏。", "len": 25}
{"sid": "096_张丞相列传.12.s2", "chapter": "096_张丞相列传", "para": "12", "seq": 2, "text": "张苍为计相时，绪正律历。", "len": 12}
{"sid": "096_张丞相列传.12.s3", "chapter": "096_张丞相列传", "para": "12", "seq": 3, "text": "以高祖十月始至霸上，因故秦时本以十月为岁首，弗革。", "len": 25}
{"sid": "096_张丞相列传.12.s4", "chapter": "096_张丞相列传", "para": "12", "seq": 4, "text": "推五德之运，以为汉当水德之时，尚黑如故。", "len": 20}
{"sid": "096_张丞相列传.12.s5", "chapter": "096_张丞相列传", "para": "12", "seq": 5, "text": "吹律调乐，入之音声，及以比定律令。", "len": 17}
{"sid": "096_张丞相列传.12.s6", "chapter": "096_张丞相列传", "para": "12", "seq": 6, "text": "若百工，天下作程品。", "len": 10}
{"sid": "096_张丞相列传.12.s7", "chapter": "096_张丞相列传", "para": "12", "seq": 7, "text": "至於为丞相，卒就之，故汉家言律历者，本之张苍。", "len": 23}
{"sid": "096_张丞相列传.12.s8", "chapter": "096_张丞相列传", "para": "12", "seq": 8, "text": "苍本好书，无所不观，无所不通，而尤善律历。", "len": 21}
{"sid": "096_张丞相列传.13.s1", "chapter": "096_张丞相列传", "para": "13", "seq": 1, "text": "张苍德王陵。", "len": 6}
{"sid": "096_张丞相列传.13.s2", "chapter": "096_张丞相列传", "para": "13", "seq": 2, "text": "王陵者，安国侯也。", "len": 9}
{"sid": "096_张丞相列传.13.s3", "chapter": "096_张丞相列传", "para": "13", "seq": 3, "text": "及苍贵，常父事王陵。", "len": 10}
{"sid": "096_张丞相列传.13.s4", "chapter": "096_张丞相列传", "para": "13", "seq": 4, "text": "陵死後，苍为丞相，洗沐，常先朝陵夫人上食，然后敢归家。", "len": 27}
{"sid": "096_张丞相列传.14.s1", "chapter": "096_张丞相列传", "para": "14", "seq": 1, "text": "苍为丞相十馀年，鲁人公孙臣上书言汉土德时，其符有黄龙当见。", "len": 29}
{"sid": "096_张丞相列传.14.s2", "chapter": "096_张丞相列传", "para": "14", "seq": 2, "text": "诏下其议张苍，张苍以为非是，罢之。", "len": 17}
{"sid": "096_张丞相列传.14.s3", "chapter": "096_张丞相列传", "para": "14", "seq": 3, "text": "其後黄龙见成纪，於是文帝召公孙臣以为博士，草土德之历制度，更元年。", "len": 33}
{"sid": "096_张丞相列传.14.s4", "chapter": "096_张丞相列传", "para": "14", "seq": 4, "text": "张丞相由此自绌，谢病称老。", "len": 13}
{"sid": "096_张丞相列传.14.s5", "chapter": "096_张丞相列传", "para": "14", "seq": 5, "text": "苍任人为中候，大为奸利，上以让苍，苍遂病免。", "len": 22}
{"sid": "096_张丞相列传.14.s6", "chapter": "096_张丞相列传", "para": "14", "seq": 6, "text": "苍为丞相十五岁而免。", "len": 10}
{"sid": "096_张丞相列传.14.s7", "chapter": "096_张丞相列传", "para": "14", "seq": 7, "text": "孝景前五年，苍卒，谥为文侯。", "len": 14}
{"sid": "096_张丞相列传.14.s8", "chapter": "096_张丞相列传", "para": "14", "seq": 8, "text": "子康侯代，八年卒。", "len": 9}
{"sid": "096_张丞相列传.14.s9", "chapter": "096_张丞相列传", "para": "14", "seq": 9, "text": "子类代为侯，八年，坐临诸侯丧後就位不敬，国除。", "len": 23}
{"sid": "096_张丞相列传.15.s1", "chapter": "096_张丞相列传", "para": "15", "seq": 1, "text": "初，张苍父长不满五尺，及生苍，苍长八尺馀，为侯、丞相。", "len": 27}
{"sid": "096_张丞相列传.15.s2", "chapter": "096_张丞相列传", "para": "15", "seq": 2, "text": "苍子复长。", "len": 5}
{"sid": "096_张丞相列传.15.s3", "chapter": "096_张丞相列传", "para": "15", "seq": 3, "text": "及孙类，长六尺馀，坐法失侯。", "len": 14}
{"sid": "096_张丞相列传.15.s4", "chapter": "096_张丞相列传", "para": "15", "seq": 4, "text": "苍之免相後，老，口中无齿，食乳，女子为乳母。", "len": 22}
{"sid": "096_张丞相列传.15.s5", "chapter": "096_张丞相列传", "para": "15", "seq": 5, "text": "妻妾以百数，尝孕者不复幸。", "len": 13}
{"sid": "096_张丞相列传.15.s6", "chapter": "096_张丞相列传", "para": "15", "seq": 6, "text": "苍年百有馀岁而卒。", "len": 9}
{"sid": "096_张丞相列传.16.s1", "chapter": "096_张丞相列传", "para": "16", "seq": 1, "text": "申屠丞相嘉者，梁人，以材官蹶张从高帝击项籍，迁为队率。", "len": 27}
{"sid": "096_张丞相列传.16.s2", "chapter": "096_张丞相列传", "para": "16", "seq": 2, "text": "从击黥布军，为都尉。", "len": 10}
{"sid": "096_张丞相列传.16.s3", "chapter": "096_张丞相列传", "para": "16", "seq": 3, "text": "孝惠时，为淮阳守。", "len": 9}
{"sid": "096_张丞相列传.16.s4", "chapter": "096_张丞相列传", "para": "16", "seq": 4, "text": "孝文帝元年，举故吏士二千石从高皇帝者，悉以为关内侯，食邑二十四人，而申屠嘉食邑五百户。", "len": 43}
{"sid": "096_张丞相列传.16.s5", "chapter": "096_张丞相列传", "para": "16", "seq": 5, "text": "张苍已为丞相，嘉迁为御史大夫。", "len": 15}
{"sid": "096_张丞相列传.16.s6", "chapter": "096_张丞相列传", "para": "16", "seq": 6, "text": "张苍免相，孝文帝欲用皇后弟窦广国为丞相，曰：“恐天下以吾私广国。", "len": 32}
{"sid": "096_张丞相列传.16.s7", "chapter": "096_张丞相列传", "para": "16", "seq": 7, "text": "” 广国贤有行，故欲相之，念久之不可，而高帝时大臣又皆多死，馀见无可者，乃以御史大夫嘉为丞相，因故邑封为故安侯。", "len": 56}
{"sid": "096_张丞相列传.17.s1", "chapter": "096_张丞相列传", "para": "17", "seq": 1, "text": "嘉为人廉直，门不受私谒。", "len": 12}
{"sid": "096_张丞相列传.17.s2", "chapter": "096_张丞相列传", "para": "17", "seq": 2, "text": "是时太中大夫邓通方隆爱幸，赏赐累巨万。", "len": 19}
{"sid": "096_张丞相列传.17.s3", "chapter": "096_张丞相列传", "para": "17", "seq": 3, "text": "文帝尝燕饮通家，其宠如是。", "len": 13}
{"sid": "096_张丞相列传.17.s4", "chapter": "096_张丞相列传", "para": "17", "seq": 4, "text": "是时丞相入朝，而通居上傍，有怠慢之礼。", "len": 19}
{"sid": "096_张丞相列传.17.s5", "chapter": "096_张丞相列传", "para": "17", "seq": 5, "text": "丞相奏事毕，因言曰：“陛下爱幸臣，则富贵之；至於朝廷之礼，不可以不肃！", "len": 35}
{"sid": "096_张丞相列传.17.s6", "chapter": "096_张丞相列传", "para": "17", "seq": 6, "text": "” 上曰：“君勿言，吾私之。", "len": 14}
{"sid": "096_张丞相列传.17.s7", "chapter": "096_张丞相列传", "para": "17", "seq": 7, "text": "” 罢朝坐府中，嘉为檄召邓通诣丞相府，不来，且斩通。", "len": 26}
{"sid": "096_张丞相列传.17.s8", "chapter": "096_张丞相列传", "para": "17", "seq": 8, "text": "通恐，入言文帝。", "len": 8}
{"sid": "096_张丞相列传.17.s9", "chapter": "096_张丞相列传", "para": "17", "seq": 9, "text": "文帝曰：“汝第往，吾今使人召若。", "len": 16}
{"sid": "096_张丞相列传.17.s10", "chapter": "096_张丞相列传", "para": "17", "seq": 10, "text": "” 通至丞相府，免冠，徒跣，顿首谢。", "len": 18}
{"sid": "096_张丞相列传.17.s11", "chapter": "096_张丞相列传", "para": "17", "seq": 11, "text": "嘉坐自如，故不为礼，责曰：“夫朝廷者，高皇帝之朝廷也。", "len": 27}
{"sid": "096_张丞相列传.17.s12", "chapter": "096_张丞相列传", "para": "17", "seq": 12, "text": "通小臣，戏殿上，大不敬，当斩。", "len": 15}
{"sid": "096_张丞相列传.17.s13", "chapter": "096_张丞相列传", "para": "17", "seq": 13, "text": "吏今行斩之！", "len": 6}
{"sid": "096_张丞相列传.17.s14", "chapter": "096_张丞相列传", "para": "17", "seq": 14, "text": "” 通顿首，首尽出血，不解。", "len": 14}
{"sid": "096_张丞相列传.17.s15", "chapter": "096_张丞相列传", "para": "17", "seq": 15, "text": "文帝度丞相已困通，使使者持节召通，而谢丞相曰：“此吾弄臣，君释之。", "len": 33}
{"sid": "096_张丞相列传.17.s16", "chapter": "096_张丞相列传", "para": "17", "seq": 16, "text": "” 邓通既至，为文帝泣曰：“丞相几杀臣。”", "len": 21}
{"sid": "096_张丞相列传.18.s1", "chapter": "096_张丞相列传", "para": "18", "seq": 1, "text": "嘉为丞相五岁，孝文帝崩，孝景帝即位。", "len": 18}
{"sid": "096_张丞相列传.18.s2", "chapter": "096_张丞相列传", "para": "18", "seq": 2, "text": "二年，晁错为内史，贵幸用事，诸法令多所请变更，议以谪罚侵削诸侯。", "len": 32}
{"sid": "096_张丞相列传.18.s3", "chapter": "096_张丞相列传", "para": "18", "seq": 3, "text": "而丞相嘉自绌所言不用，疾错。", "len": 14}
{"sid": "096_张丞相列传.18.s4", "chapter": "096_张丞相列传", "para": "18", "seq": 4, "text": "错为内史，门东出，不便，更穿一门南出。", "len": 19}
{"sid": "096_张丞相列传.18.s5", "chapter": "096_张丞相列传", "para": "18", "seq": 5, "text": "南出者，太上皇庙堧垣。", "len": 11}
{"sid": "096_张丞相列传.18.s6", "chapter": "096_张丞相列传", "para": "18", "seq": 6, "text": "嘉闻之，欲因此以法错擅穿宗庙垣为门，奏请诛错。", "len": 23}
{"sid": "096_张丞相列传.18.s7", "chapter": "096_张丞相列传", "para": "18", "seq": 7, "text": "错客有语错，错恐，夜入宫上谒，自归景帝。", "len": 20}
{"sid": "096_张丞相列传.18.s8", "chapter": "096_张丞相列传", "para": "18", "seq": 8, "text": "至朝，丞相奏请诛内史错。", "len": 12}
{"sid": "096_张丞相列传.18.s9", "chapter": "096_张丞相列传", "para": "18", "seq": 9, "text": "景帝曰：“错所穿非真庙垣，乃外堧垣，故他官居其中，且又我使为之，错无罪。", "len": 36}
{"sid": "096_张丞相列传.18.s10", "chapter": "096_张丞相列传", "para": "18", "seq": 10, "text": "” 罢朝，嘉谓长史曰：“吾悔不先斩错，乃先请之，为错所卖。", "len": 29}
{"sid": "096_张丞相列传.18.s11", "chapter": "096_张丞相列传", "para": "18", "seq": 11, "text": "” 至舍，因欧血而死。", "len": 11}
{"sid": "096_张丞相列传.18.s12", "chapter": "096_张丞相列传", "para": "18", "seq": 12, "text": "谥为节侯。", "len": 5}
{"sid": "096_张丞相列传.18.s13", "chapter": "096_张丞相列传", "para": "18", "seq": 13, "text": "子共侯蔑代，三年卒。", "len": 10}
{"sid": "096_张丞相列传.18.s14", "chapter": "096_张丞相列传", "para": "18", "seq": 14, "text": "子侯去病代，三十一年卒。", "len": 12}
{"sid": "096_张丞相列传.18.s15", "chapter": "096_张丞相列传", "para": "18", "seq": 15, "text": "子侯臾代，六岁，坐为九江太守受故官送有罪，国除。", "len": 24}
{"sid": "096_张丞相列传.19.s1", "chapter": "096_张丞相列传", "para": "19", "seq": 1, "text": "自申屠嘉死之後，景帝时开封侯陶青、桃侯刘舍为丞相。", "len": 25}
{"sid": "096_张丞相列传.19.s2", "chapter": "096_张丞相列传", "para": "19", "seq": 2, "text": "及今上时，柏至侯许昌、平棘侯薛泽、武彊侯庄青翟、高陵侯赵周等为丞相。", "len": 34}
{"sid": "096_张丞相列传.19.s3", "chapter": "096_张丞相列传", "para": "19", "seq": 3, "text": "皆以列侯继嗣，娖娖廉谨，为丞相备员而已，无所能发明功名有著於当世者。", "len": 34}
{"sid": "096_张丞相列传.20.s1", "chapter": "096_张丞相列传", "para": "20", "seq": 1, "text": "太史公曰：“张苍文学律历，为汉名相，而绌贾生、公孙臣等言正朔服色事而不遵，明用秦之颛顼历，何哉？", "len": 48}
{"sid": "096_张丞相列传.20.s2", "chapter": "096_张丞相列传", "para": "20", "seq": 2, "text": "周昌，木彊人也。", "len": 8}
{"sid": "096_张丞相列传.20.s3", "chapter": "096_张丞相列传", "para": "20", "seq": 3, "text": "任敖以旧德用。", "len": 7}
{"sid": "096_张丞相列传.20.s4", "chapter": "096_张丞相列传", "para": "20", "seq": 4, "text": "申屠嘉可谓刚毅守节矣，然无术学，殆与萧、曹、陈平异矣。", "len": 27}
{"sid": "096_张丞相列传.21.s1", "chapter": "096_张丞相列传", "para": "21", "seq": 1, "text": "孝武时丞相多甚，不记，莫录其行起居状略，且纪征和以来。", "len": 27}
{"sid": "096_张丞相列传.22.s1", "chapter": "096_张丞相列传", "para": "22", "seq": 1, "text": "有车丞相，长陵人也。", "len": 10}
{"sid": "096_张丞相列传.22.s2", "chapter": "096_张丞相列传", "para": "22", "seq": 2, "text": "卒而有韦丞相代。", "len": 8}
{"sid": "096_张丞相列传.22.s3", "chapter": "096_张丞相列传", "para": "22", "seq": 3, "text": "韦丞相贤者，鲁人也。", "len": 10}
{"sid": "096_张丞相列传.22.s4", "chapter": "096_张丞相列传", "para": "22", "seq": 4, "text": "以读书术为吏，至大鸿胪。", "len": 12}
{"sid": "096_张丞相列传.22.s5", "chapter": "096_张丞相列传", "para": "22", "seq": 5, "text": "有相工相之，当至丞相。", "len": 11}
{"sid": "096_张丞相列传.22.s6", "chapter": "096_张丞相列传", "para": "22", "seq": 6, "text": "有男四人，使相工相之，至第二子，其名玄成。", "len": 21}
{"sid": "096_张丞相列传.22.s7", "chapter": "096_张丞相列传", "para": "22", "seq": 7, "text": "相工曰：“此子贵，当封。", "len": 12}
{"sid": "096_张丞相列传.22.s8", "chapter": "096_张丞相列传", "para": "22", "seq": 8, "text": "” 韦丞相言曰：“我即为丞相，有长子，是安从得之？", "len": 25}
{"sid": "096_张丞相列传.22.s9", "chapter": "096_张丞相列传", "para": "22", "seq": 9, "text": "” 後竟为丞相，病死，而长子有罪论，不得嗣，而立玄成。", "len": 27}
{"sid": "096_张丞相列传.22.s10", "chapter": "096_张丞相列传", "para": "22", "seq": 10, "text": "玄成时佯狂，不肯立，竟立之，有让国之名。", "len": 20}
{"sid": "096_张丞相列传.22.s11", "chapter": "096_张丞相列传", "para": "22", "seq": 11, "text": "後坐骑至庙，不敬，有诏夺爵一级，为关内侯，失列侯，得食其故国邑。", "len": 32}
{"sid": "096_张丞相列传.22.s12", "chapter": "096_张丞相列传", "para": "22", "seq": 12, "text": "韦丞相卒，有魏丞相代。", "len": 11}
{"sid": "096_张丞相列传.23.s1", "chapter": "096_张丞相列传", "para": "23", "seq": 1, "text": "魏丞相相者，济阴人也。", "len": 11}
{"sid": "096_张丞相列传.23.s2", "chapter": "096_张丞相列传", "para": "23", "seq": 2, "text": "以文吏至丞相。", "len": 7}
{"sid": "096_张丞相列传.23.s3", "chapter": "096_张丞相列传", "para": "23", "seq": 3, "text": "其人好武，皆令诸吏带剑，带剑前奏事。", "len": 18}
{"sid": "096_张丞相列传.23.s4", "chapter": "096_张丞相列传", "para": "23", "seq": 4, "text": "或有不带剑者，当入奏事，至乃借剑而敢入奏事。", "len": 22}
{"sid": "096_张丞相列传.23.s5", "chapter": "096_张丞相列传", "para": "23", "seq": 5, "text": "其时京兆尹赵君，丞相奏以免罪，使人执魏丞相，欲求脱罪而不听。", "len": 30}
{"sid": "096_张丞相列传.23.s6", "chapter": "096_张丞相列传", "para": "23", "seq": 6, "text": "复使人胁恐魏丞相，以夫人贼杀待婢事而私独奏请验之，发吏卒至丞相舍，捕奴婢笞击问之，实不以兵刃杀也。", "len": 49}
{"sid": "096_张丞相列传.23.s7", "chapter": "096_张丞相列传", "para": "23", "seq": 7, "text": "而丞相司直繁君奏京兆尹赵君迫胁丞相，诬以夫人贼杀婢，发吏卒围捕丞相舍，不道；又得擅屏骑士事，赵京兆坐要斩。", "len": 53}
{"sid": "096_张丞相列传.23.s8", "chapter": "096_张丞相列传", "para": "23", "seq": 8, "text": "又有使掾陈平等劾中尚书，疑以独擅劫事而坐之，大不敬，长史以下皆坐死，或下蚕室。", "len": 39}
{"sid": "096_张丞相列传.23.s9", "chapter": "096_张丞相列传", "para": "23", "seq": 9, "text": "而魏丞相竟以丞相病死。", "len": 11}
{"sid": "096_张丞相列传.23.s10", "chapter": "096_张丞相列传", "para": "23", "seq": 10, "text": "子嗣。", "len": 3}
{"sid": "096_张丞相列传.23.s11", "chapter": "096_张丞相列传", "para": "23", "seq": 11, "text": "後坐骑至庙，不敬，有诏夺爵一级，为关内侯，失列侯，得食其故国邑。", "len": 32}
{"sid": "096_张丞相列传.23.s12", "chapter": "096_张丞相列传", "para": "23", "seq": 12, "text": "魏丞相卒，以御史大夫邴吉代。", "len": 14}
{"sid": "096_张丞相列传.24.s1", "chapter": "096_张丞相列传", "para": "24", "seq": 1, "text": "邴丞相吉者，鲁国人也。", "len": 11}
{"sid": "096_张丞相列传.24.s2", "chapter": "096_张丞相列传", "para": "24", "seq": 2, "text": "以读书好法令至御史大夫。", "len": 12}
{"sid": "096_张丞相列传.24.s3", "chapter": "096_张丞相列传", "para": "24", "seq": 3, "text": "孝宣帝时，以有旧故，封为列侯，而因为丞相。", "len": 21}
{"sid": "096_张丞相列传.24.s4", "chapter": "096_张丞相列传", "para": "24", "seq": 4, "text": "明於事，有大智，後世称之。", "len": 13}
{"sid": "096_张丞相列传.24.s5", "chapter": "096_张丞相列传", "para": "24", "seq": 5, "text": "以丞相病死。", "len": 6}
{"sid": "096_张丞相列传.24.s6", "chapter": "096_张丞相列传", "para": "24", "seq": 6, "text": "子显嗣。", "len": 4}
{"sid": "096_张丞相列传.24.s7", "chapter": "096_张丞相列传", "para": "24", "seq": 7, "text": "後坐骑至庙，不敬，有诏夺爵一级，失列侯，得食故国邑。", "len": 26}
{"sid": "096_张丞相列传.24.s8", "chapter": "096_张丞相列传", "para": "24", "seq": 8, "text": "显为吏至太仆，坐官毛乱，身及子男有奸赃，免为庶人。", "len": 25}
{"sid": "096_张丞相列传.25.s1", "chapter": "096_张丞相列传", "para": "25", "seq": 1, "text": "邴丞相卒，黄丞相代。", "len": 10}
{"sid": "096_张丞相列传.25.s2", "chapter": "096_张丞相列传", "para": "25", "seq": 2, "text": "长安中有善相工田文者，与韦丞相、魏丞相、邴丞相微贱时会於客家，田文言曰：“今此三君者，皆丞相也。", "len": 48}
{"sid": "096_张丞相列传.25.s3", "chapter": "096_张丞相列传", "para": "25", "seq": 3, "text": "” 其後三人竟更相代为丞相，何见之明也。", "len": 20}
{"sid": "096_张丞相列传.26.s1", "chapter": "096_张丞相列传", "para": "26", "seq": 1, "text": "黄丞相霸者，淮阳人也。", "len": 11}
{"sid": "096_张丞相列传.26.s2", "chapter": "096_张丞相列传", "para": "26", "seq": 2, "text": "以读书为吏，至颍川太守。", "len": 12}
{"sid": "096_张丞相列传.26.s3", "chapter": "096_张丞相列传", "para": "26", "seq": 3, "text": "治颍川，以礼义条教喻告化之。", "len": 14}
{"sid": "096_张丞相列传.26.s4", "chapter": "096_张丞相列传", "para": "26", "seq": 4, "text": "犯法者，风晓令自杀。", "len": 10}
{"sid": "096_张丞相列传.26.s5", "chapter": "096_张丞相列传", "para": "26", "seq": 5, "text": "化大行，名声闻。", "len": 8}
{"sid": "096_张丞相列传.26.s6", "chapter": "096_张丞相列传", "para": "26", "seq": 6, "text": "孝宣帝下制曰：“颍川太守霸，以宣布诏令治民，道不拾遗，男女异路，狱中无重囚。", "len": 38}
{"sid": "096_张丞相列传.26.s7", "chapter": "096_张丞相列传", "para": "26", "seq": 7, "text": "赐爵关内侯，黄金百斤。", "len": 11}
{"sid": "096_张丞相列传.26.s8", "chapter": "096_张丞相列传", "para": "26", "seq": 8, "text": "” 徵为京兆尹而至丞相，复以礼义为治。", "len": 19}
{"sid": "096_张丞相列传.26.s9", "chapter": "096_张丞相列传", "para": "26", "seq": 9, "text": "以丞相病死。", "len": 6}
{"sid": "096_张丞相列传.26.s10", "chapter": "096_张丞相列传", "para": "26", "seq": 10, "text": "子嗣，後为列侯。", "len": 8}
{"sid": "096_张丞相列传.26.s11", "chapter": "096_张丞相列传", "para": "26", "seq": 11, "text": "黄丞相卒，以御史大夫于定国代。", "len": 15}
{"sid": "096_张丞相列传.26.s12", "chapter": "096_张丞相列传", "para": "26", "seq": 12, "text": "于丞相已有廷尉传，在张廷尉语中。", "len": 16}
{"sid": "096_张丞相列传.26.s13", "chapter": "096_张丞相列传", "para": "26", "seq": 13, "text": "于丞相去，御史大夫韦玄成代。", "len": 14}
{"sid": "096_张丞相列传.27.s1", "chapter": "096_张丞相列传", "para": "27", "seq": 1, "text": "韦丞相玄成者，即前韦丞相子也。", "len": 15}
{"sid": "096_张丞相列传.27.s2", "chapter": "096_张丞相列传", "para": "27", "seq": 2, "text": "代父，後失列侯。", "len": 8}
{"sid": "096_张丞相列传.27.s3", "chapter": "096_张丞相列传", "para": "27", "seq": 3, "text": "其人少时好读书，明於诗、论语。", "len": 15}
{"sid": "096_张丞相列传.27.s4", "chapter": "096_张丞相列传", "para": "27", "seq": 4, "text": "为吏至卫尉，徙为太子太傅。", "len": 13}
{"sid": "096_张丞相列传.27.s5", "chapter": "096_张丞相列传", "para": "27", "seq": 5, "text": "御史大夫薛君免，为御史大夫。", "len": 14}
{"sid": "096_张丞相列传.27.s6", "chapter": "096_张丞相列传", "para": "27", "seq": 6, "text": "于丞相乞骸骨免，而为丞相，因封故邑为扶阳侯。", "len": 22}
{"sid": "096_张丞相列传.27.s7", "chapter": "096_张丞相列传", "para": "27", "seq": 7, "text": "数年，病死。", "len": 6}
{"sid": "096_张丞相列传.27.s8", "chapter": "096_张丞相列传", "para": "27", "seq": 8, "text": "孝元帝亲临丧，赐赏甚厚。", "len": 12}
{"sid": "096_张丞相列传.27.s9", "chapter": "096_张丞相列传", "para": "27", "seq": 9, "text": "子嗣後。", "len": 4}
{"sid": "096_张丞相列传.27.s10", "chapter": "096_张丞相列传", "para": "27", "seq": 10, "text": "其治容容随世俗浮沈，而见谓谄巧。", "len": 16}
{"sid": "096_张丞相列传.27.s11", "chapter": "096_张丞相列传", "para": "27", "seq": 11, "text": "而相工本谓之当为侯代父，而後失之；复自游宦而起，至丞相。", "len": 28}
{"sid": "096_张丞相列传.27.s12", "chapter": "096_张丞相列传", "para": "27", "seq": 12, "text": "父子俱为丞相，世间美之，岂不命哉！", "len": 17}
{"sid": "096_张丞相列传.27.s13", "chapter": "096_张丞相列传", "para": "27", "seq": 13, "text": "相工其先知之。", "len": 7}
{"sid": "096_张丞相列传.27.s14", "chapter": "096_张丞相列传", "para": "27", "seq": 14, "text": "韦丞相卒，御史大夫匡衡代。", "len": 13}
{"sid": "096_张丞相列传.28.s1", "chapter": "096_张丞相列传", "para": "28", "seq": 1, "text": "丞相匡衡者，东海人也。", "len": 11}
{"sid": "096_张丞相列传.28.s2", "chapter": "096_张丞相列传", "para": "28", "seq": 2, "text": "好读书，从博士受诗。", "len": 10}
{"sid": "096_张丞相列传.28.s3", "chapter": "096_张丞相列传", "para": "28", "seq": 3, "text": "家贫，衡佣作以给食饮。", "len": 11}
{"sid": "096_张丞相列传.28.s4", "chapter": "096_张丞相列传", "para": "28", "seq": 4, "text": "才下，数射策不中，至九，乃中丙科。", "len": 17}
{"sid": "096_张丞相列传.28.s5", "chapter": "096_张丞相列传", "para": "28", "seq": 5, "text": "其经以不中科故明习。", "len": 10}
{"sid": "096_张丞相列传.28.s6", "chapter": "096_张丞相列传", "para": "28", "seq": 6, "text": "补平原文学卒史。", "len": 8}
{"sid": "096_张丞相列传.28.s7", "chapter": "096_张丞相列传", "para": "28", "seq": 7, "text": "数年，郡不尊敬。", "len": 8}
{"sid": "096_张丞相列传.28.s8", "chapter": "096_张丞相列传", "para": "28", "seq": 8, "text": "御史徵之，以补百石属荐为郎，而补博士，拜为太子少傅，而事孝元帝。", "len": 32}
{"sid": "096_张丞相列传.28.s9", "chapter": "096_张丞相列传", "para": "28", "seq": 9, "text": "孝元好诗，而迁为光禄勋，居殿中为师，授教左右，而县官坐其旁听，甚善之，日以尊贵。", "len": 40}
{"sid": "096_张丞相列传.28.s10", "chapter": "096_张丞相列传", "para": "28", "seq": 10, "text": "御史大夫郑弘坐事免，而匡君为御史大夫。", "len": 19}
{"sid": "096_张丞相列传.28.s11", "chapter": "096_张丞相列传", "para": "28", "seq": 11, "text": "岁馀，韦丞相死，匡君代为丞相，封乐安侯。", "len": 20}
{"sid": "096_张丞相列传.28.s12", "chapter": "096_张丞相列传", "para": "28", "seq": 12, "text": "以十年之间，不出长安城门而至丞相，岂非遇时而命也哉！", "len": 26}
{"sid": "096_张丞相列传.28.s13", "chapter": "096_张丞相列传", "para": "28", "seq": 13, "text": "::: 太史公曰", "len": 8}
{"sid": "096_张丞相列传.39.s1", "chapter": "096_张丞相列传", "para": "39", "seq": 1, "text": "太史公曰：深惟士之游宦所以至封侯者，微甚。", "len": 21}
{"sid": "096_张丞相列传.39.s2", "chapter": "096_张丞相列传", "para": "39", "seq": 2, "text": "然多至御史大夫即去者。", "len": 11}
{"sid": "096_张丞相列传.39.s3", "chapter": "096_张丞相列传", "para": "39", "seq": 3, "text": "诸为大夫而丞相次也，其心冀幸丞相物故也。", "len": 20}
{"sid": "096_张丞相列传.39.s4", "chapter": "096_张丞相列传", "para": "39", "seq": 4, "text": "或乃阴私相毁害，欲代之。", "len": 12}
{"sid": "096_张丞相列传.39.s5", "chapter": "096_张丞相列传", "para": "39", "seq": 5, "text": "然守之日久不得，或为之日少而得之，至於封侯，真命也夫！", "len": 27}
{"sid": "096_张丞相列传.39.s6", "chapter": "096_张丞相列传", "para": "39", "seq": 6, "text": "御史大夫郑君守之数年不得，匡君居之未满岁，而韦丞相死，即代之矣，岂可以智巧得哉！", "len": 40}
{"sid": "096_张丞相列传.39.s7", "chapter": "096_张丞相列传", "para": "39", "seq": 7, "text": "多有贤圣之才，困戹不得者众甚也。", "len": 16}
{"sid": "096_张丞相列传.39.s8", "chapter": "096_张丞相列传", "para": "39", "seq": 8, "text": "::: ::: 赞", "len": 9}
{"sid": "096_张丞相列传.40.s1", "chapter": "096_张丞相列传", "para": "40", "seq": 1, "text": "张苍主计，天下作程。", "len": 10}
{"sid": "096_张丞相列传.40.s2", "chapter": "096_张丞相列传", "para": "40", "seq": 2, "text": "孙臣始绌，秦历尚行。", "len": 10}
{"sid": "096_张丞相列传.40.s3", "chapter": "096_张丞相列传", "para": "40", "seq": 3, "text": "御史亚相，相国阿衡。", "len": 10}
{"sid": "096_张丞相列传.40.s4", "chapter": "096_张丞相列传", "para": "40", "seq": 4, "text": "申屠面折，周子廷争。", "len": 10}
{"sid": "096_张丞相列传.40.s5", "chapter": "096_张丞相列传", "para": "40", "seq": 5, "text": "其他娖々，无所发明。", "len": 10}
{"sid": "096_张丞相列传.40.s6", "chapter": "096_张丞相列传", "para": "40", "seq": 6, "text": ":::", "len": 3}
