{"sid": "091_黥布列传.1.s1", "chapter": "091_黥布列传", "para": "1", "seq": 1, "text": "黥布者，六人也，姓英氏。", "len": 12}
{"sid": "091_黥布列传.1.s2", "chapter": "091_黥布列传", "para": "1", "seq": 2, "text": "秦时为布衣。", "len": 6}
{"sid": "091_黥布列传.1.s3", "chapter": "091_黥布列传", "para": "1", "seq": 3, "text": "少年，有客相之曰：“当刑而王。", "len": 15}
{"sid": "091_黥布列传.1.s4", "chapter": "091_黥布列传", "para": "1", "seq": 4, "text": "” 及壮，坐法黥。", "len": 9}
{"sid": "091_黥布列传.1.s5", "chapter": "091_黥布列传", "para": "1", "seq": 5, "text": "布欣然笑曰；“人相我当刑而王，几是乎？", "len": 19}
{"sid": "091_黥布列传.1.s6", "chapter": "091_黥布列传", "para": "1", "seq": 6, "text": "” 人有闻者，共俳笑之。", "len": 12}
{"sid": "091_黥布列传.1.s7", "chapter": "091_黥布列传", "para": "1", "seq": 7, "text": "布已论输丽山，丽山之徒数十万人，布皆与其徒长豪桀交通，乃率其曹偶，亡之江中为群盗。", "len": 41}
{"sid": "091_黥布列传.2.s1", "chapter": "091_黥布列传", "para": "2", "seq": 1, "text": "陈胜之起也，布乃见番君，与其众叛秦，聚兵数千人。", "len": 24}
{"sid": "091_黥布列传.2.s2", "chapter": "091_黥布列传", "para": "2", "seq": 2, "text": "番君以其女妻之。", "len": 8}
{"sid": "091_黥布列传.2.s3", "chapter": "091_黥布列传", "para": "2", "seq": 3, "text": "章邯之灭陈胜，破吕臣军，布乃引兵北击秦左右校，破之清波，引兵而东。", "len": 33}
{"sid": "091_黥布列传.2.s4", "chapter": "091_黥布列传", "para": "2", "seq": 4, "text": "闻项梁定江东会稽，涉江而西。", "len": 14}
{"sid": "091_黥布列传.2.s5", "chapter": "091_黥布列传", "para": "2", "seq": 5, "text": "陈婴以项氏世为楚将，乃以兵属项梁，渡淮南，英布、蒲将军亦以兵属项梁。", "len": 34}
{"sid": "091_黥布列传.3.s1", "chapter": "091_黥布列传", "para": "3", "seq": 1, "text": "项梁涉淮而西，击景驹、秦嘉等，布常冠军。", "len": 20}
{"sid": "091_黥布列传.3.s2", "chapter": "091_黥布列传", "para": "3", "seq": 2, "text": "项梁至薛，闻陈王定死，乃立楚怀王。", "len": 17}
{"sid": "091_黥布列传.3.s3", "chapter": "091_黥布列传", "para": "3", "seq": 3, "text": "项梁号为武信君，英布为当阳君。", "len": 15}
{"sid": "091_黥布列传.3.s4", "chapter": "091_黥布列传", "para": "3", "seq": 4, "text": "项梁败死定陶，怀王徙都彭城，诸将英布亦皆保聚彭城。", "len": 25}
{"sid": "091_黥布列传.3.s5", "chapter": "091_黥布列传", "para": "3", "seq": 5, "text": "当是时，秦急围赵，赵数使人请救。", "len": 16}
{"sid": "091_黥布列传.3.s6", "chapter": "091_黥布列传", "para": "3", "seq": 6, "text": "怀王使宋义为上将，范曾为末将，项籍为次将，英在、蒲将军皆为将军，悉属宋义，北救赵。", "len": 41}
{"sid": "091_黥布列传.3.s7", "chapter": "091_黥布列传", "para": "3", "seq": 7, "text": "及项籍杀宋义於河上，怀王因立籍为上将军，诸将皆属项籍。", "len": 27}
{"sid": "091_黥布列传.3.s8", "chapter": "091_黥布列传", "para": "3", "seq": 8, "text": "项籍使布先渡河击秦，布数有利，籍乃悉引兵涉河从之，遂破秦军，降章邯等。", "len": 35}
{"sid": "091_黥布列传.3.s9", "chapter": "091_黥布列传", "para": "3", "seq": 9, "text": "楚兵常胜，功冠诸侯。", "len": 10}
{"sid": "091_黥布列传.3.s10", "chapter": "091_黥布列传", "para": "3", "seq": 10, "text": "诸侯兵皆以服属楚者，以布数以少败众也。", "len": 19}
{"sid": "091_黥布列传.4.s1", "chapter": "091_黥布列传", "para": "4", "seq": 1, "text": "项籍之引兵西至新安，又使布等夜击阬章邯秦卒二十馀万人。", "len": 27}
{"sid": "091_黥布列传.4.s2", "chapter": "091_黥布列传", "para": "4", "seq": 2, "text": "至关，不得入，又使布等先从间道破关下军，遂得入，至咸阳。", "len": 28}
{"sid": "091_黥布列传.4.s3", "chapter": "091_黥布列传", "para": "4", "seq": 3, "text": "布常为军锋。", "len": 6}
{"sid": "091_黥布列传.4.s4", "chapter": "091_黥布列传", "para": "4", "seq": 4, "text": "项王封诸将，立布为九江王，都六。", "len": 16}
{"sid": "091_黥布列传.5.s1", "chapter": "091_黥布列传", "para": "5", "seq": 1, "text": "汉元年四月，诸侯皆罢戏下，各就国。", "len": 17}
{"sid": "091_黥布列传.5.s2", "chapter": "091_黥布列传", "para": "5", "seq": 2, "text": "项氏立怀王为义帝，徙都长沙，乃阴令九江王布等行击之。", "len": 26}
{"sid": "091_黥布列传.5.s3", "chapter": "091_黥布列传", "para": "5", "seq": 3, "text": "其八月，布使将击义帝，追杀之郴县。", "len": 17}
{"sid": "091_黥布列传.6.s1", "chapter": "091_黥布列传", "para": "6", "seq": 1, "text": "汉二年，齐王田荣畔楚，项王往击齐，徵兵九江，九江王布称病不往，遣将将数千人行。", "len": 39}
{"sid": "091_黥布列传.6.s2", "chapter": "091_黥布列传", "para": "6", "seq": 2, "text": "汉之败楚彭城，布又称病不佐楚。", "len": 15}
{"sid": "091_黥布列传.6.s3", "chapter": "091_黥布列传", "para": "6", "seq": 3, "text": "项王由此怨布，数使使者诮让召布，布愈恐，不敢往。", "len": 24}
{"sid": "091_黥布列传.6.s4", "chapter": "091_黥布列传", "para": "6", "seq": 4, "text": "项王方北忧齐、赵，西患汉，所与者独九江王，又多布材，欲亲用之，以故未击。", "len": 36}
{"sid": "091_黥布列传.7.s1", "chapter": "091_黥布列传", "para": "7", "seq": 1, "text": "汉三年，汉王击楚，大战彭城，不利，出梁地，至虞，谓左右曰：“如彼等者，无足与计天下事。", "len": 43}
{"sid": "091_黥布列传.7.s2", "chapter": "091_黥布列传", "para": "7", "seq": 2, "text": "” 谒者随何进曰：“不审陛下所谓。", "len": 17}
{"sid": "091_黥布列传.7.s3", "chapter": "091_黥布列传", "para": "7", "seq": 3, "text": "” 汉王曰：“孰能为我使淮南，令之发兵倍楚，留项王於齐数月，我之取天下可以百全。", "len": 40}
{"sid": "091_黥布列传.7.s4", "chapter": "091_黥布列传", "para": "7", "seq": 4, "text": "” 随何曰：“臣请使之。", "len": 12}
{"sid": "091_黥布列传.7.s5", "chapter": "091_黥布列传", "para": "7", "seq": 5, "text": "” 乃与二十人俱，使淮南。", "len": 13}
{"sid": "091_黥布列传.7.s6", "chapter": "091_黥布列传", "para": "7", "seq": 6, "text": "至，因太宰主之，三日不得见。", "len": 14}
{"sid": "091_黥布列传.7.s7", "chapter": "091_黥布列传", "para": "7", "seq": 7, "text": "随何因说太宰曰：“王之不见何，必以楚为彊，以汉为弱，此臣之所以为使。", "len": 34}
{"sid": "091_黥布列传.7.s8", "chapter": "091_黥布列传", "para": "7", "seq": 8, "text": "使何得见，言之而是邪，是大王所欲闻也；言之而非邪，使何等二十人伏斧质淮南市，以明王倍汉而与楚也。", "len": 48}
{"sid": "091_黥布列传.7.s9", "chapter": "091_黥布列传", "para": "7", "seq": 9, "text": "” 太宰乃言之王，王见之。", "len": 13}
{"sid": "091_黥布列传.7.s10", "chapter": "091_黥布列传", "para": "7", "seq": 10, "text": "随何曰：“汉王使臣敬进书大王御者，窃怪大王与楚何亲也。", "len": 27}
{"sid": "091_黥布列传.7.s11", "chapter": "091_黥布列传", "para": "7", "seq": 11, "text": "” 淮南王曰：“寡人北乡而臣事之。", "len": 17}
{"sid": "091_黥布列传.7.s12", "chapter": "091_黥布列传", "para": "7", "seq": 12, "text": "” 随何曰：“大王与项王俱列为诸侯，北乡而臣事之，必以楚为彊，可以讬国也。", "len": 37}
{"sid": "091_黥布列传.7.s13", "chapter": "091_黥布列传", "para": "7", "seq": 13, "text": "项王伐齐，身负板筑，以为士卒先，大王宜悉淮南之众，身自将之，为楚军前锋，今乃发四千人以助楚。", "len": 46}
{"sid": "091_黥布列传.7.s14", "chapter": "091_黥布列传", "para": "7", "seq": 14, "text": "夫北面而臣事人者，固若是乎？", "len": 14}
{"sid": "091_黥布列传.7.s15", "chapter": "091_黥布列传", "para": "7", "seq": 15, "text": "夫汉王战於彭城，项王未出齐也，大王宜骚淮南之兵渡淮，日夜会战彭城下，大王抚万人之众，无一人渡淮者，垂拱而观其孰胜。", "len": 57}
{"sid": "091_黥布列传.7.s16", "chapter": "091_黥布列传", "para": "7", "seq": 16, "text": "夫讬国於人者，固若是乎？", "len": 12}
{"sid": "091_黥布列传.7.s17", "chapter": "091_黥布列传", "para": "7", "seq": 17, "text": "大王提空名以乡楚，而欲厚自讬，臣窃为大王不取也。", "len": 24}
{"sid": "091_黥布列传.7.s18", "chapter": "091_黥布列传", "para": "7", "seq": 18, "text": "然而大王不背楚者，以汉为弱也。", "len": 15}
{"sid": "091_黥布列传.7.s19", "chapter": "091_黥布列传", "para": "7", "seq": 19, "text": "夫楚兵虽彊，天下负之以不义之名，以其背盟约而杀义帝也。", "len": 27}
{"sid": "091_黥布列传.7.s20", "chapter": "091_黥布列传", "para": "7", "seq": 20, "text": "然而楚王恃战胜自彊，汉王收诸侯，还守成皋、荥阳，下蜀、汉之粟，深沟壁垒，分卒守徼乘塞，楚人还兵，间以梁地，深入敌国八九百里，欲战则不得，攻城则力不能，老弱转粮千里之外；楚兵至荥阳、成皋，汉坚守而不动，进则不得攻，退则不得解。", "len": 112}
{"sid": "091_黥布列传.7.s21", "chapter": "091_黥布列传", "para": "7", "seq": 21, "text": "故曰楚兵不足恃也。", "len": 9}
{"sid": "091_黥布列传.7.s22", "chapter": "091_黥布列传", "para": "7", "seq": 22, "text": "使楚胜汉，则诸侯自危惧而相救。", "len": 15}
{"sid": "091_黥布列传.7.s23", "chapter": "091_黥布列传", "para": "7", "seq": 23, "text": "夫楚之彊，適足以致天下之兵耳。", "len": 15}
{"sid": "091_黥布列传.7.s24", "chapter": "091_黥布列传", "para": "7", "seq": 24, "text": "故楚不如汉，其势易见也。", "len": 12}
{"sid": "091_黥布列传.7.s25", "chapter": "091_黥布列传", "para": "7", "seq": 25, "text": "今大王不与万全之汉而自讬於危亡之楚，臣窃为大王惑之。", "len": 26}
{"sid": "091_黥布列传.7.s26", "chapter": "091_黥布列传", "para": "7", "seq": 26, "text": "臣非以淮南之兵足以亡楚也。", "len": 13}
{"sid": "091_黥布列传.7.s27", "chapter": "091_黥布列传", "para": "7", "seq": 27, "text": "夫大王发兵而倍楚，项王必留；留数月，汉之取天下可以万全。", "len": 28}
{"sid": "091_黥布列传.7.s28", "chapter": "091_黥布列传", "para": "7", "seq": 28, "text": "臣请与大王提剑而归汉，汉王必裂地而封大王，又况淮南，淮南必大王有也。", "len": 34}
{"sid": "091_黥布列传.7.s29", "chapter": "091_黥布列传", "para": "7", "seq": 29, "text": "故汉王敬使使臣进愚计，原大王之留意也。", "len": 19}
{"sid": "091_黥布列传.7.s30", "chapter": "091_黥布列传", "para": "7", "seq": 30, "text": "” 淮南王曰：“请奉命。", "len": 12}
{"sid": "091_黥布列传.7.s31", "chapter": "091_黥布列传", "para": "7", "seq": 31, "text": "” 阴许畔楚与汉，未敢泄也。", "len": 14}
{"sid": "091_黥布列传.8.s1", "chapter": "091_黥布列传", "para": "8", "seq": 1, "text": "楚使者在，方急责英布发兵，舍传舍。", "len": 17}
{"sid": "091_黥布列传.8.s2", "chapter": "091_黥布列传", "para": "8", "seq": 2, "text": "随何直入，坐楚使者上坐，曰：“九江王已归汉，楚何以得发兵？", "len": 29}
{"sid": "091_黥布列传.8.s3", "chapter": "091_黥布列传", "para": "8", "seq": 3, "text": "” 布愕然。", "len": 6}
{"sid": "091_黥布列传.8.s4", "chapter": "091_黥布列传", "para": "8", "seq": 4, "text": "楚使者起。", "len": 5}
{"sid": "091_黥布列传.8.s5", "chapter": "091_黥布列传", "para": "8", "seq": 5, "text": "何因说布曰：“事已搆，可遂杀楚使者，无使归，而疾走汉并力。", "len": 29}
{"sid": "091_黥布列传.8.s6", "chapter": "091_黥布列传", "para": "8", "seq": 6, "text": "” 布曰：“如使者教，因起兵而击之耳。", "len": 19}
{"sid": "091_黥布列传.8.s7", "chapter": "091_黥布列传", "para": "8", "seq": 7, "text": "” 於是杀使者，因起兵而攻楚。", "len": 15}
{"sid": "091_黥布列传.8.s8", "chapter": "091_黥布列传", "para": "8", "seq": 8, "text": "楚使项声、龙且攻淮南，项王留而攻下邑。", "len": 19}
{"sid": "091_黥布列传.8.s9", "chapter": "091_黥布列传", "para": "8", "seq": 9, "text": "数月，龙且击淮南，破布军。", "len": 13}
{"sid": "091_黥布列传.8.s10", "chapter": "091_黥布列传", "para": "8", "seq": 10, "text": "布欲引兵走汉，恐楚王杀之，故间行与何俱归汉。", "len": 22}
{"sid": "091_黥布列传.9.s1", "chapter": "091_黥布列传", "para": "9", "seq": 1, "text": "淮南王至，上方踞床洗，召布入见，布大怒，悔来，欲自杀。", "len": 27}
{"sid": "091_黥布列传.9.s2", "chapter": "091_黥布列传", "para": "9", "seq": 2, "text": "出就舍，帐御饮食从官如汉王居，布又大喜过望。", "len": 22}
{"sid": "091_黥布列传.9.s3", "chapter": "091_黥布列传", "para": "9", "seq": 3, "text": "於是乃使人入九江。", "len": 9}
{"sid": "091_黥布列传.9.s4", "chapter": "091_黥布列传", "para": "9", "seq": 4, "text": "楚已使项伯收九江兵，尽杀布妻子。", "len": 16}
{"sid": "091_黥布列传.9.s5", "chapter": "091_黥布列传", "para": "9", "seq": 5, "text": "布使者颇得故人幸臣，将众数千人归汉。", "len": 18}
{"sid": "091_黥布列传.9.s6", "chapter": "091_黥布列传", "para": "9", "seq": 6, "text": "汉益分布兵而与俱北，收兵至成皋。", "len": 16}
{"sid": "091_黥布列传.9.s7", "chapter": "091_黥布列传", "para": "9", "seq": 7, "text": "四年七月，立布为淮南王，与击项籍。", "len": 17}
{"sid": "091_黥布列传.10.s1", "chapter": "091_黥布列传", "para": "10", "seq": 1, "text": "汉五年，布使人入九江，得数县。", "len": 15}
{"sid": "091_黥布列传.10.s2", "chapter": "091_黥布列传", "para": "10", "seq": 2, "text": "六年，布与刘贾入九江，诱大司马周殷，周殷反楚，遂举九江兵与汉击楚，破之垓下。", "len": 38}
{"sid": "091_黥布列传.11.s1", "chapter": "091_黥布列传", "para": "11", "seq": 1, "text": "项籍死，天下定，上置酒。", "len": 12}
{"sid": "091_黥布列传.11.s2", "chapter": "091_黥布列传", "para": "11", "seq": 2, "text": "上折随何之功，谓何为腐儒，为天下安用腐儒。", "len": 21}
{"sid": "091_黥布列传.11.s3", "chapter": "091_黥布列传", "para": "11", "seq": 3, "text": "随何跪曰：“夫陛下引兵攻彭城，楚王未去齐也，陛下发步卒五万人，骑五千，能以取淮南乎？", "len": 42}
{"sid": "091_黥布列传.11.s4", "chapter": "091_黥布列传", "para": "11", "seq": 4, "text": "” 上曰：“不能。", "len": 9}
{"sid": "091_黥布列传.11.s5", "chapter": "091_黥布列传", "para": "11", "seq": 5, "text": "” 随何曰：“陛下使何与二十人使淮南，至，如陛下之意，是何之功贤於步卒五万人骑五千也。", "len": 43}
{"sid": "091_黥布列传.11.s6", "chapter": "091_黥布列传", "para": "11", "seq": 6, "text": "然而陛下谓何腐儒，为天下安用腐儒，何也？", "len": 20}
{"sid": "091_黥布列传.11.s7", "chapter": "091_黥布列传", "para": "11", "seq": 7, "text": "” 上曰：“吾方图子之功。", "len": 13}
{"sid": "091_黥布列传.11.s8", "chapter": "091_黥布列传", "para": "11", "seq": 8, "text": "” 乃以随何为护军中尉。", "len": 12}
{"sid": "091_黥布列传.11.s9", "chapter": "091_黥布列传", "para": "11", "seq": 9, "text": "布遂剖符为淮南王，都六，九江、庐江、衡山、豫章郡皆属布。", "len": 28}
{"sid": "091_黥布列传.12.s1", "chapter": "091_黥布列传", "para": "12", "seq": 1, "text": "七年，朝陈。", "len": 6}
{"sid": "091_黥布列传.12.s2", "chapter": "091_黥布列传", "para": "12", "seq": 2, "text": "八年，朝雒阳。", "len": 7}
{"sid": "091_黥布列传.12.s3", "chapter": "091_黥布列传", "para": "12", "seq": 3, "text": "九年，朝长安。", "len": 7}
{"sid": "091_黥布列传.13.s1", "chapter": "091_黥布列传", "para": "13", "seq": 1, "text": "十一年，高后诛淮阴侯，布因心恐。", "len": 16}
{"sid": "091_黥布列传.13.s2", "chapter": "091_黥布列传", "para": "13", "seq": 2, "text": "夏，汉诛梁王彭越，醢之，盛其醢遍赐诸侯。", "len": 20}
{"sid": "091_黥布列传.13.s3", "chapter": "091_黥布列传", "para": "13", "seq": 3, "text": "至淮南，淮南王方猎，见醢，因大恐，阴令人部聚兵，候伺旁郡警急。", "len": 31}
{"sid": "091_黥布列传.14.s1", "chapter": "091_黥布列传", "para": "14", "seq": 1, "text": "布所幸姬疾，请就医，医家与中大夫贲赫对门，姬数如医家，贲赫自以为侍中，乃厚餽遗，从姬饮医家。", "len": 46}
{"sid": "091_黥布列传.14.s2", "chapter": "091_黥布列传", "para": "14", "seq": 2, "text": "姬侍王，从容语次，誉赫长者也。", "len": 15}
{"sid": "091_黥布列传.14.s3", "chapter": "091_黥布列传", "para": "14", "seq": 3, "text": "王怒曰：“汝安从知之？", "len": 11}
{"sid": "091_黥布列传.14.s4", "chapter": "091_黥布列传", "para": "14", "seq": 4, "text": "” 具说状。", "len": 6}
{"sid": "091_黥布列传.14.s5", "chapter": "091_黥布列传", "para": "14", "seq": 5, "text": "王疑其与乱。", "len": 6}
{"sid": "091_黥布列传.14.s6", "chapter": "091_黥布列传", "para": "14", "seq": 6, "text": "赫恐，称病。", "len": 6}
{"sid": "091_黥布列传.14.s7", "chapter": "091_黥布列传", "para": "14", "seq": 7, "text": "王愈怒，欲捕赫。", "len": 8}
{"sid": "091_黥布列传.14.s8", "chapter": "091_黥布列传", "para": "14", "seq": 8, "text": "赫言变事，乘传诣长安。", "len": 11}
{"sid": "091_黥布列传.14.s9", "chapter": "091_黥布列传", "para": "14", "seq": 9, "text": "布使人追，不及。", "len": 8}
{"sid": "091_黥布列传.14.s10", "chapter": "091_黥布列传", "para": "14", "seq": 10, "text": "赫至，上变，言布谋反有端，可先未发诛也。", "len": 20}
{"sid": "091_黥布列传.14.s11", "chapter": "091_黥布列传", "para": "14", "seq": 11, "text": "上读其书，语萧相国。", "len": 10}
{"sid": "091_黥布列传.14.s12", "chapter": "091_黥布列传", "para": "14", "seq": 12, "text": "相国曰：“布不宜有此，恐仇怨妄诬之。", "len": 18}
{"sid": "091_黥布列传.14.s13", "chapter": "091_黥布列传", "para": "14", "seq": 13, "text": "请击赫，使人微验淮南王。", "len": 12}
{"sid": "091_黥布列传.14.s14", "chapter": "091_黥布列传", "para": "14", "seq": 14, "text": "” 淮南王布见赫以罪亡，上变，固已疑其言国阴事；汉使又来，颇有所验，遂族赫家，发兵反。", "len": 43}
{"sid": "091_黥布列传.14.s15", "chapter": "091_黥布列传", "para": "14", "seq": 15, "text": "反书闻，上乃赦贲赫，以为将军。", "len": 15}
{"sid": "091_黥布列传.15.s1", "chapter": "091_黥布列传", "para": "15", "seq": 1, "text": "上召诸将问曰：“布反，为之柰何？", "len": 16}
{"sid": "091_黥布列传.15.s2", "chapter": "091_黥布列传", "para": "15", "seq": 2, "text": "” 皆曰；“发兵击之，阬竖子耳。", "len": 16}
{"sid": "091_黥布列传.15.s3", "chapter": "091_黥布列传", "para": "15", "seq": 3, "text": "何能为乎！", "len": 5}
{"sid": "091_黥布列传.15.s4", "chapter": "091_黥布列传", "para": "15", "seq": 4, "text": "” 汝阴侯滕公召故楚令尹问之。", "len": 15}
{"sid": "091_黥布列传.15.s5", "chapter": "091_黥布列传", "para": "15", "seq": 5, "text": "令尹曰：“是故当反。", "len": 10}
{"sid": "091_黥布列传.15.s6", "chapter": "091_黥布列传", "para": "15", "seq": 6, "text": "” 滕公曰：“上裂地而王之，疏爵而贵之，南面而立万乘之主，其反何也？", "len": 34}
{"sid": "091_黥布列传.15.s7", "chapter": "091_黥布列传", "para": "15", "seq": 7, "text": "” 令尹曰：“往年杀彭越，前年杀韩信，此三人者，同功一体之人也。", "len": 32}
{"sid": "091_黥布列传.15.s8", "chapter": "091_黥布列传", "para": "15", "seq": 8, "text": "自疑祸及身，故反耳。", "len": 10}
{"sid": "091_黥布列传.15.s9", "chapter": "091_黥布列传", "para": "15", "seq": 9, "text": "” 滕公言之上曰：“臣客故楚令尹薛公者，其人有筹筴之计，可问。", "len": 31}
{"sid": "091_黥布列传.15.s10", "chapter": "091_黥布列传", "para": "15", "seq": 10, "text": "” 上乃召见问薛公。", "len": 10}
{"sid": "091_黥布列传.15.s11", "chapter": "091_黥布列传", "para": "15", "seq": 11, "text": "薛公对曰：“布反不足怪也。", "len": 13}
{"sid": "091_黥布列传.15.s12", "chapter": "091_黥布列传", "para": "15", "seq": 12, "text": "使布出於上计，山东非汉之有也；出於中计，胜败之数未可知也；出於下计，陛下安枕而卧矣。", "len": 42}
{"sid": "091_黥布列传.15.s13", "chapter": "091_黥布列传", "para": "15", "seq": 13, "text": "” 上曰：“何谓上计？", "len": 11}
{"sid": "091_黥布列传.15.s14", "chapter": "091_黥布列传", "para": "15", "seq": 14, "text": "” 令尹对曰：“东取吴，西取楚，并齐取鲁，传檄燕、赵，固守其所，山东非汉之有也。", "len": 40}
{"sid": "091_黥布列传.15.s15", "chapter": "091_黥布列传", "para": "15", "seq": 15, "text": "” “何谓中计？", "len": 8}
{"sid": "091_黥布列传.15.s16", "chapter": "091_黥布列传", "para": "15", "seq": 16, "text": "” “东取吴，西取楚，并韩取魏，据敖庾之粟，塞成皋之口，胜败之数未可知也。", "len": 37}
{"sid": "091_黥布列传.15.s17", "chapter": "091_黥布列传", "para": "15", "seq": 17, "text": "” “何谓下计？", "len": 8}
{"sid": "091_黥布列传.15.s18", "chapter": "091_黥布列传", "para": "15", "seq": 18, "text": "” “东取吴，西取下蔡，归重於越，身归长沙，陛下安枕而卧，汉无事矣。", "len": 34}
{"sid": "091_黥布列传.15.s19", "chapter": "091_黥布列传", "para": "15", "seq": 19, "text": "” 上曰：“是计将安出？", "len": 12}
{"sid": "091_黥布列传.15.s20", "chapter": "091_黥布列传", "para": "15", "seq": 20, "text": "” 令尹对曰：“出下计。", "len": 12}
{"sid": "091_黥布列传.15.s21", "chapter": "091_黥布列传", "para": "15", "seq": 21, "text": "” 上曰：“何谓废上中计而出下计？", "len": 17}
{"sid": "091_黥布列传.15.s22", "chapter": "091_黥布列传", "para": "15", "seq": 22, "text": "” 令尹曰：“布故丽山之徒也，自致万乘之主，此皆为身，不顾後为百姓万世虑者也，故曰出下计。", "len": 45}
{"sid": "091_黥布列传.15.s23", "chapter": "091_黥布列传", "para": "15", "seq": 23, "text": "” 上曰：“善。", "len": 8}
{"sid": "091_黥布列传.15.s24", "chapter": "091_黥布列传", "para": "15", "seq": 24, "text": "” 封薛公千户。", "len": 8}
{"sid": "091_黥布列传.15.s25", "chapter": "091_黥布列传", "para": "15", "seq": 25, "text": "乃立皇子长为淮南王。", "len": 10}
{"sid": "091_黥布列传.15.s26", "chapter": "091_黥布列传", "para": "15", "seq": 26, "text": "上遂发兵自将东击布。", "len": 10}
{"sid": "091_黥布列传.16.s1", "chapter": "091_黥布列传", "para": "16", "seq": 1, "text": "布之初反，谓其将曰：“上老矣，厌兵，必不能来。", "len": 23}
{"sid": "091_黥布列传.16.s2", "chapter": "091_黥布列传", "para": "16", "seq": 2, "text": "使诸将，诸将独患淮阴、彭越，今皆已死，馀不足畏也。", "len": 25}
{"sid": "091_黥布列传.16.s3", "chapter": "091_黥布列传", "para": "16", "seq": 3, "text": "” 故遂反。", "len": 6}
{"sid": "091_黥布列传.16.s4", "chapter": "091_黥布列传", "para": "16", "seq": 4, "text": "果如薛公筹之，东击荆，荆王刘贾走死富陵。", "len": 20}
{"sid": "091_黥布列传.16.s5", "chapter": "091_黥布列传", "para": "16", "seq": 5, "text": "尽劫其兵，渡淮击楚。", "len": 10}
{"sid": "091_黥布列传.16.s6", "chapter": "091_黥布列传", "para": "16", "seq": 6, "text": "楚发兵与战徐、僮间，为三军，欲以相救为奇。", "len": 21}
{"sid": "091_黥布列传.16.s7", "chapter": "091_黥布列传", "para": "16", "seq": 7, "text": "或说楚将曰：“布善用兵，民素畏之。", "len": 17}
{"sid": "091_黥布列传.16.s8", "chapter": "091_黥布列传", "para": "16", "seq": 8, "text": "且兵法，诸侯战其地为散地。", "len": 13}
{"sid": "091_黥布列传.16.s9", "chapter": "091_黥布列传", "para": "16", "seq": 9, "text": "今别为三，彼败吾一军，馀皆走，安能相救！", "len": 20}
{"sid": "091_黥布列传.16.s10", "chapter": "091_黥布列传", "para": "16", "seq": 10, "text": "” 不听。", "len": 5}
{"sid": "091_黥布列传.16.s11", "chapter": "091_黥布列传", "para": "16", "seq": 11, "text": "布果破其一军，其二军散走。", "len": 13}
{"sid": "091_黥布列传.17.s1", "chapter": "091_黥布列传", "para": "17", "seq": 1, "text": "遂西，与上兵遇蕲西，会甀。", "len": 13}
{"sid": "091_黥布列传.17.s2", "chapter": "091_黥布列传", "para": "17", "seq": 2, "text": "布兵精甚，上乃壁庸城，望布军置陈如项籍军，上恶之。", "len": 25}
{"sid": "091_黥布列传.17.s3", "chapter": "091_黥布列传", "para": "17", "seq": 3, "text": "与布相望见，遥谓布曰：“何苦而反？", "len": 17}
{"sid": "091_黥布列传.17.s4", "chapter": "091_黥布列传", "para": "17", "seq": 4, "text": "” 布曰：“欲为帝耳。", "len": 11}
{"sid": "091_黥布列传.17.s5", "chapter": "091_黥布列传", "para": "17", "seq": 5, "text": "” 上怒骂之，遂大战。", "len": 11}
{"sid": "091_黥布列传.17.s6", "chapter": "091_黥布列传", "para": "17", "seq": 6, "text": "布军败走，渡淮，数止战，不利，与百馀人走江南。", "len": 23}
{"sid": "091_黥布列传.17.s7", "chapter": "091_黥布列传", "para": "17", "seq": 7, "text": "布故与番君婚，以故长沙哀王使人绐布，伪与亡，诱走越，故信而随之番阳。", "len": 34}
{"sid": "091_黥布列传.17.s8", "chapter": "091_黥布列传", "para": "17", "seq": 8, "text": "番阳人杀布兹乡民田舍，遂灭黥布。", "len": 16}
{"sid": "091_黥布列传.18.s1", "chapter": "091_黥布列传", "para": "18", "seq": 1, "text": "立皇子长为淮南王，封贲赫为期思侯，诸将率多以功封者。", "len": 26}
{"sid": "091_黥布列传.18.s2", "chapter": "091_黥布列传", "para": "18", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "091_黥布列传.19.s1", "chapter": "091_黥布列传", "para": "19", "seq": 1, "text": "太史公曰：英布者，其先岂春秋所见楚灭英、六，皋陶之後哉？", "len": 28}
{"sid": "091_黥布列传.19.s2", "chapter": "091_黥布列传", "para": "19", "seq": 2, "text": "身被刑法，何其拔兴之暴也！", "len": 13}
{"sid": "091_黥布列传.19.s3", "chapter": "091_黥布列传", "para": "19", "seq": 3, "text": "项氏之所阬杀人以千万数，而布常为首虐。", "len": 19}
{"sid": "091_黥布列传.19.s4", "chapter": "091_黥布列传", "para": "19", "seq": 4, "text": "功冠诸侯，用此得王，亦不免於身为世大僇。", "len": 20}
{"sid": "091_黥布列传.19.s5", "chapter": "091_黥布列传", "para": "19", "seq": 5, "text": "祸之兴自爱姬殖，妒媢生患，竟以灭国！", "len": 18}
{"sid": "091_黥布列传.19.s6", "chapter": "091_黥布列传", "para": "19", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "091_黥布列传.20.s1", "chapter": "091_黥布列传", "para": "20", "seq": 1, "text": "九江初筮，当刑而王。", "len": 10}
{"sid": "091_黥布列传.20.s2", "chapter": "091_黥布列传", "para": "20", "seq": 2, "text": "既免徒中，聚盗江上。", "len": 10}
{"sid": "091_黥布列传.20.s3", "chapter": "091_黥布列传", "para": "20", "seq": 3, "text": "再雄楚卒，频破秦将。", "len": 10}
{"sid": "091_黥布列传.20.s4", "chapter": "091_黥布列传", "para": "20", "seq": 4, "text": "病为羽疑，归受汉杖。", "len": 10}
{"sid": "091_黥布列传.20.s5", "chapter": "091_黥布列传", "para": "20", "seq": 5, "text": "贲赫见毁，卒致无妄。", "len": 10}
{"sid": "091_黥布列传.20.s6", "chapter": "091_黥布列传", "para": "20", "seq": 6, "text": ":::", "len": 3}
