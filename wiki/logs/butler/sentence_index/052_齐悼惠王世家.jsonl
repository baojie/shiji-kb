{"sid": "052_齐悼惠王世家.1.s1", "chapter": "052_齐悼惠王世家", "para": "1", "seq": 1, "text": "齐悼惠王刘肥者，高祖长庶男也。", "len": 15}
{"sid": "052_齐悼惠王世家.1.s2", "chapter": "052_齐悼惠王世家", "para": "1", "seq": 2, "text": "其母外妇也，曰曹氏。", "len": 10}
{"sid": "052_齐悼惠王世家.1.s3", "chapter": "052_齐悼惠王世家", "para": "1", "seq": 3, "text": "高祖六年，立肥为齐王，食七十城，诸民能齐言者皆予齐王。", "len": 27}
{"sid": "052_齐悼惠王世家.2.s1", "chapter": "052_齐悼惠王世家", "para": "2", "seq": 1, "text": "齐王，孝惠帝兄也。", "len": 9}
{"sid": "052_齐悼惠王世家.2.s2", "chapter": "052_齐悼惠王世家", "para": "2", "seq": 2, "text": "孝惠帝二年，齐王入朝。", "len": 11}
{"sid": "052_齐悼惠王世家.2.s3", "chapter": "052_齐悼惠王世家", "para": "2", "seq": 3, "text": "惠帝与齐王燕饮，亢礼如家人。", "len": 14}
{"sid": "052_齐悼惠王世家.2.s4", "chapter": "052_齐悼惠王世家", "para": "2", "seq": 4, "text": "吕太后怒，且诛齐王。", "len": 10}
{"sid": "052_齐悼惠王世家.2.s5", "chapter": "052_齐悼惠王世家", "para": "2", "seq": 5, "text": "齐王惧不得脱，乃用其内史勋计，献城阳郡，以为鲁元公主汤沐邑。", "len": 30}
{"sid": "052_齐悼惠王世家.2.s6", "chapter": "052_齐悼惠王世家", "para": "2", "seq": 6, "text": "吕太后喜，乃得辞就国。", "len": 11}
{"sid": "052_齐悼惠王世家.3.s1", "chapter": "052_齐悼惠王世家", "para": "3", "seq": 1, "text": "悼惠王即位十三年，以惠帝六年卒。", "len": 16}
{"sid": "052_齐悼惠王世家.3.s2", "chapter": "052_齐悼惠王世家", "para": "3", "seq": 2, "text": "子襄立，是为哀王。", "len": 9}
{"sid": "052_齐悼惠王世家.4.s1", "chapter": "052_齐悼惠王世家", "para": "4", "seq": 1, "text": "哀王元年，孝惠帝崩，吕太后称制，天下事皆决於高后。", "len": 25}
{"sid": "052_齐悼惠王世家.4.s2", "chapter": "052_齐悼惠王世家", "para": "4", "seq": 2, "text": "二年，高后立其兄子郦侯吕台为吕王，割齐之济南郡为吕王奉邑。", "len": 29}
{"sid": "052_齐悼惠王世家.5.s1", "chapter": "052_齐悼惠王世家", "para": "5", "seq": 1, "text": "哀王三年，其弟章入宿卫於汉，吕太后封为硃虚侯，以吕禄女妻之。", "len": 30}
{"sid": "052_齐悼惠王世家.5.s2", "chapter": "052_齐悼惠王世家", "para": "5", "seq": 2, "text": "後四年，封章弟兴居为东牟侯，皆宿卫长安中。", "len": 21}
{"sid": "052_齐悼惠王世家.6.s1", "chapter": "052_齐悼惠王世家", "para": "6", "seq": 1, "text": "哀王八年，高后割齐琅邪郡立营陵侯刘泽为琅邪王。", "len": 23}
{"sid": "052_齐悼惠王世家.7.s1", "chapter": "052_齐悼惠王世家", "para": "7", "seq": 1, "text": "其明年，赵王友入朝，幽死于邸。", "len": 15}
{"sid": "052_齐悼惠王世家.7.s2", "chapter": "052_齐悼惠王世家", "para": "7", "seq": 2, "text": "三赵王皆废。", "len": 6}
{"sid": "052_齐悼惠王世家.7.s3", "chapter": "052_齐悼惠王世家", "para": "7", "seq": 3, "text": "高后立诸吕诸吕为三王，擅权用事。", "len": 16}
{"sid": "052_齐悼惠王世家.8.s1", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 1, "text": "硃虚侯年二十，有气力，忿刘氏不得职。", "len": 18}
{"sid": "052_齐悼惠王世家.8.s2", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 2, "text": "尝入待高后燕饮，高后令硃虚侯刘章为酒吏。", "len": 20}
{"sid": "052_齐悼惠王世家.8.s3", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 3, "text": "章自请曰：“臣，将种也，请得以军法行酒。", "len": 20}
{"sid": "052_齐悼惠王世家.8.s4", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 4, "text": "” 高后曰：“可。", "len": 9}
{"sid": "052_齐悼惠王世家.8.s5", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 5, "text": "” 酒酣，章进饮歌舞。", "len": 11}
{"sid": "052_齐悼惠王世家.8.s6", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 6, "text": "已而曰：“请为太后言耕田歌。", "len": 14}
{"sid": "052_齐悼惠王世家.8.s7", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 7, "text": "” 高后兒子畜之，笑曰：“顾而父知田耳。", "len": 20}
{"sid": "052_齐悼惠王世家.8.s8", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 8, "text": "若生而为王子，安知田乎？", "len": 12}
{"sid": "052_齐悼惠王世家.8.s9", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 9, "text": "” 章曰：“臣知之。", "len": 10}
{"sid": "052_齐悼惠王世家.8.s10", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 10, "text": "” 太后曰：“试为我言田。", "len": 13}
{"sid": "052_齐悼惠王世家.8.s11", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 11, "text": "” 章曰：“深耕穊种，立苗欲疏，非其种者，鉏而去之。", "len": 26}
{"sid": "052_齐悼惠王世家.8.s12", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 12, "text": "” 吕后默然。", "len": 7}
{"sid": "052_齐悼惠王世家.8.s13", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 13, "text": "顷之，诸吕有一人醉，亡酒，章追，拔剑斩之，而还报曰：“有亡酒一人，臣谨行法斩之。", "len": 40}
{"sid": "052_齐悼惠王世家.8.s14", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 14, "text": "” 太后左右皆大惊。", "len": 10}
{"sid": "052_齐悼惠王世家.8.s15", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 15, "text": "业已许其军法，无以罪也。", "len": 12}
{"sid": "052_齐悼惠王世家.8.s16", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 16, "text": "因罢。", "len": 3}
{"sid": "052_齐悼惠王世家.8.s17", "chapter": "052_齐悼惠王世家", "para": "8", "seq": 17, "text": "自是之後，诸吕惮硃虚侯，虽大臣皆依硃虚侯，刘氏为益彊。", "len": 27}
{"sid": "052_齐悼惠王世家.9.s1", "chapter": "052_齐悼惠王世家", "para": "9", "seq": 1, "text": "其明年，高后崩。", "len": 8}
{"sid": "052_齐悼惠王世家.9.s2", "chapter": "052_齐悼惠王世家", "para": "9", "seq": 2, "text": "赵王吕禄为上将军，吕王产为相国，皆居长安中，聚兵以威大臣，欲为乱。", "len": 33}
{"sid": "052_齐悼惠王世家.9.s3", "chapter": "052_齐悼惠王世家", "para": "9", "seq": 3, "text": "硃虚侯章以吕禄女为妇，知其谋，乃使人阴出告其兄齐王，欲令发兵西，硃虚侯、东牟侯为内应，以诛诸吕，因立齐王为帝。", "len": 55}
{"sid": "052_齐悼惠王世家.10.s1", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 1, "text": "齐王既闻此计，乃与其舅父驷钧、郎中令祝午、中尉魏勃阴谋发兵。", "len": 30}
{"sid": "052_齐悼惠王世家.10.s2", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 2, "text": "齐相召平闻之，乃发卒卫王宫。", "len": 14}
{"sid": "052_齐悼惠王世家.10.s3", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 3, "text": "魏勃绐召平曰：“王欲发兵，非有汉虎符验也。", "len": 21}
{"sid": "052_齐悼惠王世家.10.s4", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 4, "text": "而相君围王，固善。", "len": 9}
{"sid": "052_齐悼惠王世家.10.s5", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 5, "text": "勃请为君将兵卫卫王。", "len": 10}
{"sid": "052_齐悼惠王世家.10.s6", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 6, "text": "” 召平信之，乃使魏勃将兵围王宫。", "len": 17}
{"sid": "052_齐悼惠王世家.10.s7", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 7, "text": "勃既将兵，使围相府。", "len": 10}
{"sid": "052_齐悼惠王世家.10.s8", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 8, "text": "召平曰：“嗟乎！", "len": 8}
{"sid": "052_齐悼惠王世家.10.s9", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 9, "text": "道家之言‘当断不断，反受其乱’，乃是也。", "len": 20}
{"sid": "052_齐悼惠王世家.10.s10", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 10, "text": "” 遂自杀。", "len": 6}
{"sid": "052_齐悼惠王世家.10.s11", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 11, "text": "於是齐王以驷钧为相，魏勃为将军，祝午为内史，悉发国中兵。", "len": 28}
{"sid": "052_齐悼惠王世家.10.s12", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 12, "text": "使祝午东诈琅邪王曰：“吕氏作乱，齐王发兵欲西诛之。", "len": 25}
{"sid": "052_齐悼惠王世家.10.s13", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 13, "text": "齐王自以兒子，年少，不习兵革之事，原举国委大王。", "len": 24}
{"sid": "052_齐悼惠王世家.10.s14", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 14, "text": "大王自高帝将也，习战事。", "len": 12}
{"sid": "052_齐悼惠王世家.10.s15", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 15, "text": "齐王不敢离兵，使臣请大王幸之临菑见齐王计事，并将齐兵以西平关中之乱。", "len": 34}
{"sid": "052_齐悼惠王世家.10.s16", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 16, "text": "” 琅邪王信之，以为然，驰见齐王。", "len": 17}
{"sid": "052_齐悼惠王世家.10.s17", "chapter": "052_齐悼惠王世家", "para": "10", "seq": 17, "text": "齐王与魏勃等因留琅邪王，而使祝午尽发琅邪国而并将其兵。", "len": 27}
{"sid": "052_齐悼惠王世家.11.s1", "chapter": "052_齐悼惠王世家", "para": "11", "seq": 1, "text": "琅邪王刘泽既见欺，不得反国，乃说齐王曰：“齐悼惠王高皇帝长子，推本言之，而大王高皇帝適长孙也，当立。", "len": 50}
{"sid": "052_齐悼惠王世家.11.s2", "chapter": "052_齐悼惠王世家", "para": "11", "seq": 2, "text": "今诸大臣狐疑未有所定，而泽於刘氏最为长年，大臣固待泽决计。", "len": 29}
{"sid": "052_齐悼惠王世家.11.s3", "chapter": "052_齐悼惠王世家", "para": "11", "seq": 3, "text": "今大王留臣无为也，不如使我入关计事。", "len": 18}
{"sid": "052_齐悼惠王世家.11.s4", "chapter": "052_齐悼惠王世家", "para": "11", "seq": 4, "text": "” 齐王以为然，乃益具车送琅邪王。", "len": 17}
{"sid": "052_齐悼惠王世家.12.s1", "chapter": "052_齐悼惠王世家", "para": "12", "seq": 1, "text": "琅邪王既行，齐遂举兵西攻吕国之济南。", "len": 18}
{"sid": "052_齐悼惠王世家.12.s2", "chapter": "052_齐悼惠王世家", "para": "12", "seq": 2, "text": "於是齐哀王遗诸侯王书曰：“高帝平定天下，王诸子弟，悼惠王於齐。", "len": 31}
{"sid": "052_齐悼惠王世家.12.s3", "chapter": "052_齐悼惠王世家", "para": "12", "seq": 3, "text": "悼惠王薨，惠帝使留侯张良立臣为齐王。", "len": 18}
{"sid": "052_齐悼惠王世家.12.s4", "chapter": "052_齐悼惠王世家", "para": "12", "seq": 4, "text": "惠帝崩，高后用事，春秋高，听诸吕擅废高帝所立，又杀三赵王，灭梁、燕、赵以王诸吕，分齐国为四。", "len": 46}
{"sid": "052_齐悼惠王世家.12.s5", "chapter": "052_齐悼惠王世家", "para": "12", "seq": 5, "text": "忠臣进谏，上惑乱不听。", "len": 11}
{"sid": "052_齐悼惠王世家.12.s6", "chapter": "052_齐悼惠王世家", "para": "12", "seq": 6, "text": "今高后崩，皇帝春秋富，未能治天下，固恃大臣诸。", "len": 23}
{"sid": "052_齐悼惠王世家.12.s7", "chapter": "052_齐悼惠王世家", "para": "12", "seq": 7, "text": "今诸吕又擅自尊官，聚兵严威，劫列侯忠臣，矫制以令天下，宗庙所以危。", "len": 33}
{"sid": "052_齐悼惠王世家.12.s8", "chapter": "052_齐悼惠王世家", "para": "12", "seq": 8, "text": "今寡人率兵入诛不当为王者。”", "len": 14}
{"sid": "052_齐悼惠王世家.13.s1", "chapter": "052_齐悼惠王世家", "para": "13", "seq": 1, "text": "汉闻齐发兵而西，相国吕产乃遣大将军灌婴东击之。", "len": 23}
{"sid": "052_齐悼惠王世家.13.s2", "chapter": "052_齐悼惠王世家", "para": "13", "seq": 2, "text": "灌婴至荥阳，乃谋曰：“诸吕将兵居关中，欲危刘氏而自立。", "len": 27}
{"sid": "052_齐悼惠王世家.13.s3", "chapter": "052_齐悼惠王世家", "para": "13", "seq": 3, "text": "我今破齐还报，是益吕氏资也。", "len": 14}
{"sid": "052_齐悼惠王世家.13.s4", "chapter": "052_齐悼惠王世家", "para": "13", "seq": 4, "text": "” 乃留兵屯荥阳，使使喻齐王及诸侯，与连和，以待吕氏之变而共诛之。", "len": 33}
{"sid": "052_齐悼惠王世家.13.s5", "chapter": "052_齐悼惠王世家", "para": "13", "seq": 5, "text": "齐王闻之，乃西取其故济南郡，亦屯兵於齐西界以待约。", "len": 25}
{"sid": "052_齐悼惠王世家.14.s1", "chapter": "052_齐悼惠王世家", "para": "14", "seq": 1, "text": "吕禄、吕产欲作乱关中，硃虚侯与太尉勃、丞相平等诛之。", "len": 26}
{"sid": "052_齐悼惠王世家.14.s2", "chapter": "052_齐悼惠王世家", "para": "14", "seq": 2, "text": "硃虚侯首先斩吕产，於是太尉勃等乃得尽诛诸吕。", "len": 22}
{"sid": "052_齐悼惠王世家.14.s3", "chapter": "052_齐悼惠王世家", "para": "14", "seq": 3, "text": "而琅邪王亦从齐至长安。", "len": 11}
{"sid": "052_齐悼惠王世家.15.s1", "chapter": "052_齐悼惠王世家", "para": "15", "seq": 1, "text": "大臣议欲立齐王，而琅邪王及大臣曰：“齐王母家驷钧，恶戾，虎而冠者也。", "len": 34}
{"sid": "052_齐悼惠王世家.15.s2", "chapter": "052_齐悼惠王世家", "para": "15", "seq": 2, "text": "方以吕氏故几乱天下，今又立齐王，是欲复为吕氏也。", "len": 24}
{"sid": "052_齐悼惠王世家.15.s3", "chapter": "052_齐悼惠王世家", "para": "15", "seq": 3, "text": "代王母家薄氏，君子长者；且代王又亲高帝子，於今见在，且最为长。", "len": 31}
{"sid": "052_齐悼惠王世家.15.s4", "chapter": "052_齐悼惠王世家", "para": "15", "seq": 4, "text": "以子则顺，以善人则大臣安。", "len": 13}
{"sid": "052_齐悼惠王世家.15.s5", "chapter": "052_齐悼惠王世家", "para": "15", "seq": 5, "text": "” 於是大臣乃谋迎立代王，而遣硃虚侯以诛吕氏事告齐王，令罢兵。", "len": 31}
{"sid": "052_齐悼惠王世家.16.s1", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 1, "text": "灌婴在荥阳，闻魏勃本教齐王反，既诛吕氏，罢齐兵，使使召责问魏勃。", "len": 32}
{"sid": "052_齐悼惠王世家.16.s2", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 2, "text": "勃曰：“失火之家，岂暇先言大人而後救火乎！", "len": 21}
{"sid": "052_齐悼惠王世家.16.s3", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 3, "text": "” 因退立，股战而栗，恐不能言者，终无他语。", "len": 22}
{"sid": "052_齐悼惠王世家.16.s4", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 4, "text": "灌将军熟视笑曰：“人谓魏勃勇，妄庸人耳，何能为乎！", "len": 25}
{"sid": "052_齐悼惠王世家.16.s5", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 5, "text": "” 乃罢魏勃。", "len": 7}
{"sid": "052_齐悼惠王世家.16.s6", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 6, "text": "魏勃父以善鼓琴见秦皇帝。", "len": 12}
{"sid": "052_齐悼惠王世家.16.s7", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 7, "text": "及魏勃少时，欲求见齐相曹参，家贫无以自通，乃常独早夜埽齐相舍人门外。", "len": 34}
{"sid": "052_齐悼惠王世家.16.s8", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 8, "text": "相舍人怪之，以为物，而伺之，得勃。", "len": 17}
{"sid": "052_齐悼惠王世家.16.s9", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 9, "text": "勃曰：“原见相君，无因，故为子埽，欲以求见。", "len": 22}
{"sid": "052_齐悼惠王世家.16.s10", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 10, "text": "” 於是舍人见勃曹参，因以为舍人。", "len": 17}
{"sid": "052_齐悼惠王世家.16.s11", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 11, "text": "一为参御，言事，参以为贤，言之齐悼惠王。", "len": 20}
{"sid": "052_齐悼惠王世家.16.s12", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 12, "text": "悼惠王召见，则拜为内史。", "len": 12}
{"sid": "052_齐悼惠王世家.16.s13", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 13, "text": "始，悼惠王得自置二千石。", "len": 12}
{"sid": "052_齐悼惠王世家.16.s14", "chapter": "052_齐悼惠王世家", "para": "16", "seq": 14, "text": "及悼惠王卒而哀王立，勃用事，重於齐相。", "len": 19}
{"sid": "052_齐悼惠王世家.17.s1", "chapter": "052_齐悼惠王世家", "para": "17", "seq": 1, "text": "王既罢兵归，而代王来立，是为孝文帝。", "len": 18}
{"sid": "052_齐悼惠王世家.18.s1", "chapter": "052_齐悼惠王世家", "para": "18", "seq": 1, "text": "孝文帝元年，尽以高后时所割齐之城阳、琅邪、济南郡复与齐，而徙琅邪王王燕，益封硃虚侯、东牟侯各二千户。", "len": 50}
{"sid": "052_齐悼惠王世家.19.s1", "chapter": "052_齐悼惠王世家", "para": "19", "seq": 1, "text": "是岁，齐哀王卒，太子立，是为文王。", "len": 17}
{"sid": "052_齐悼惠王世家.20.s1", "chapter": "052_齐悼惠王世家", "para": "20", "seq": 1, "text": "齐文王元年，汉以齐之城阳郡立硃虚侯为城阳王，以齐济北郡立东牟侯为济北王。", "len": 36}
{"sid": "052_齐悼惠王世家.21.s1", "chapter": "052_齐悼惠王世家", "para": "21", "seq": 1, "text": "二年，济北王反，汉诛杀之，地入于汉。", "len": 18}
{"sid": "052_齐悼惠王世家.22.s1", "chapter": "052_齐悼惠王世家", "para": "22", "seq": 1, "text": "後二年，孝文帝尽封齐悼惠王子罢军等七人皆为列侯。", "len": 24}
{"sid": "052_齐悼惠王世家.23.s1", "chapter": "052_齐悼惠王世家", "para": "23", "seq": 1, "text": "齐文王立十四年卒，无子，国除，地入于汉。", "len": 20}
{"sid": "052_齐悼惠王世家.24.s1", "chapter": "052_齐悼惠王世家", "para": "24", "seq": 1, "text": "後一岁，孝文帝以所封悼惠王子分齐为王，齐孝王将闾以悼惠王子杨虚侯为齐王。", "len": 36}
{"sid": "052_齐悼惠王世家.24.s2", "chapter": "052_齐悼惠王世家", "para": "24", "seq": 2, "text": "故齐别郡尽以王悼惠王子：子志为济北王，子辟光为济南王，子贤为菑川王，子卬为胶西王，子雄渠为胶东王，与城阳、齐凡七王。", "len": 58}
{"sid": "052_齐悼惠王世家.25.s1", "chapter": "052_齐悼惠王世家", "para": "25", "seq": 1, "text": "齐孝王十一年，吴王濞、楚王戊反，兴兵西，告诸侯曰“将诛汉贼臣晁错以安宗庙”。", "len": 38}
{"sid": "052_齐悼惠王世家.25.s2", "chapter": "052_齐悼惠王世家", "para": "25", "seq": 2, "text": "胶西、胶东、菑川、济南皆擅发兵应吴楚。", "len": 19}
{"sid": "052_齐悼惠王世家.25.s3", "chapter": "052_齐悼惠王世家", "para": "25", "seq": 3, "text": "欲与齐，齐孝王狐疑，城守不听，三国兵共围齐。", "len": 22}
{"sid": "052_齐悼惠王世家.25.s4", "chapter": "052_齐悼惠王世家", "para": "25", "seq": 4, "text": "齐王使路中大夫告於天子。", "len": 12}
{"sid": "052_齐悼惠王世家.25.s5", "chapter": "052_齐悼惠王世家", "para": "25", "seq": 5, "text": "天子复令路中大夫还告齐王：“善坚守，吾兵今破吴楚矣。", "len": 26}
{"sid": "052_齐悼惠王世家.25.s6", "chapter": "052_齐悼惠王世家", "para": "25", "seq": 6, "text": "” 路中大夫至，三国兵围临菑数重，无从入。", "len": 21}
{"sid": "052_齐悼惠王世家.25.s7", "chapter": "052_齐悼惠王世家", "para": "25", "seq": 7, "text": "三国将劫与路中大夫盟，曰：“若反言汉已破矣，齐趣下三国，不且见屠。", "len": 33}
{"sid": "052_齐悼惠王世家.25.s8", "chapter": "052_齐悼惠王世家", "para": "25", "seq": 8, "text": "” 路中大夫既许之，至城下，望见齐王，曰：“汉已发兵百万，使太尉周亚夫击破吴楚，方引兵救齐，齐必坚守无下！", "len": 53}
{"sid": "052_齐悼惠王世家.25.s9", "chapter": "052_齐悼惠王世家", "para": "25", "seq": 9, "text": "” 三国将诛路中大夫。", "len": 11}
{"sid": "052_齐悼惠王世家.26.s1", "chapter": "052_齐悼惠王世家", "para": "26", "seq": 1, "text": "齐初围急，阴与三国通谋，约未定，会闻路中大夫从汉来，喜，及其大臣乃复劝王毋下三国。", "len": 41}
{"sid": "052_齐悼惠王世家.26.s2", "chapter": "052_齐悼惠王世家", "para": "26", "seq": 2, "text": "居无何，汉将栾布、平阳侯等兵至齐，击破三国兵，解齐围。", "len": 27}
{"sid": "052_齐悼惠王世家.26.s3", "chapter": "052_齐悼惠王世家", "para": "26", "seq": 3, "text": "已而复闻齐初与三国有谋，将欲移兵伐齐。", "len": 19}
{"sid": "052_齐悼惠王世家.26.s4", "chapter": "052_齐悼惠王世家", "para": "26", "seq": 4, "text": "齐孝王惧，乃饮药自杀。", "len": 11}
{"sid": "052_齐悼惠王世家.26.s5", "chapter": "052_齐悼惠王世家", "para": "26", "seq": 5, "text": "景帝闻之，以为齐首善，以迫劫有谋，非其罪也，乃立孝王太子寿为齐王，是为懿王，续齐後。", "len": 42}
{"sid": "052_齐悼惠王世家.26.s6", "chapter": "052_齐悼惠王世家", "para": "26", "seq": 6, "text": "而胶西、胶东、济南、菑川王咸诛灭，地入于汉。", "len": 22}
{"sid": "052_齐悼惠王世家.26.s7", "chapter": "052_齐悼惠王世家", "para": "26", "seq": 7, "text": "徙济北王王菑川。", "len": 8}
{"sid": "052_齐悼惠王世家.26.s8", "chapter": "052_齐悼惠王世家", "para": "26", "seq": 8, "text": "齐懿王立二十二年卒，子次景立，是为厉王。", "len": 20}
{"sid": "052_齐悼惠王世家.27.s1", "chapter": "052_齐悼惠王世家", "para": "27", "seq": 1, "text": "齐厉王，其母曰纪太后。", "len": 11}
{"sid": "052_齐悼惠王世家.27.s2", "chapter": "052_齐悼惠王世家", "para": "27", "seq": 2, "text": "太后取其弟纪氏女为厉王后。", "len": 13}
{"sid": "052_齐悼惠王世家.27.s3", "chapter": "052_齐悼惠王世家", "para": "27", "seq": 3, "text": "王不爱纪氏女。", "len": 7}
{"sid": "052_齐悼惠王世家.27.s4", "chapter": "052_齐悼惠王世家", "para": "27", "seq": 4, "text": "太后欲其家重宠，令其长女纪翁主入王宫，正其後宫，毋令得近王，欲令爱纪氏女。", "len": 37}
{"sid": "052_齐悼惠王世家.27.s5", "chapter": "052_齐悼惠王世家", "para": "27", "seq": 5, "text": "王因与其姊翁主奸。", "len": 9}
{"sid": "052_齐悼惠王世家.28.s1", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 1, "text": "齐有宦者徐甲，入事汉皇太后。", "len": 14}
{"sid": "052_齐悼惠王世家.28.s2", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 2, "text": "皇太后有爱女曰脩成君，脩成君非刘氏，太后怜之。", "len": 23}
{"sid": "052_齐悼惠王世家.28.s3", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 3, "text": "脩成君有女名娥，太后欲嫁之於诸侯，宦者甲乃请使齐，必令王上书请娥。", "len": 33}
{"sid": "052_齐悼惠王世家.28.s4", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 4, "text": "皇太后喜，使甲之齐。", "len": 10}
{"sid": "052_齐悼惠王世家.28.s5", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 5, "text": "是时齐人主父偃知甲之使齐以取后事，亦因谓甲：“即事成，幸言偃女原得充王後宫。", "len": 38}
{"sid": "052_齐悼惠王世家.28.s6", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 6, "text": "” 甲既至齐，风以此事。", "len": 12}
{"sid": "052_齐悼惠王世家.28.s7", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 7, "text": "纪太后大怒，曰：“王有后，後宫具备。", "len": 18}
{"sid": "052_齐悼惠王世家.28.s8", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 8, "text": "且甲，齐贫人，急乃为宦者，入事汉，无补益，乃欲乱吾王家！", "len": 28}
{"sid": "052_齐悼惠王世家.28.s9", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 9, "text": "且主父偃何为者？", "len": 8}
{"sid": "052_齐悼惠王世家.28.s10", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 10, "text": "乃欲以女充後宫！", "len": 8}
{"sid": "052_齐悼惠王世家.28.s11", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 11, "text": "” 徐甲大穷，还报皇太后曰：“王已原尚娥，然有一害，恐如燕王。", "len": 31}
{"sid": "052_齐悼惠王世家.28.s12", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 12, "text": "” 燕王者，与其子昆弟奸，新坐以死，亡国，故以燕感太后。", "len": 28}
{"sid": "052_齐悼惠王世家.28.s13", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 13, "text": "太后曰：“无复言嫁女齐事。", "len": 13}
{"sid": "052_齐悼惠王世家.28.s14", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 14, "text": "” 事浸浔闻於天子。", "len": 10}
{"sid": "052_齐悼惠王世家.28.s15", "chapter": "052_齐悼惠王世家", "para": "28", "seq": 15, "text": "主父偃由此亦与齐有卻。", "len": 11}
{"sid": "052_齐悼惠王世家.29.s1", "chapter": "052_齐悼惠王世家", "para": "29", "seq": 1, "text": "主父偃方幸於天子，用事，因言：“齐临菑十万户，市租千金，人众殷富，巨於长安，此非天子亲弟爱子不得王此。", "len": 51}
{"sid": "052_齐悼惠王世家.29.s2", "chapter": "052_齐悼惠王世家", "para": "29", "seq": 2, "text": "今齐王於亲属益疏。", "len": 9}
{"sid": "052_齐悼惠王世家.29.s3", "chapter": "052_齐悼惠王世家", "para": "29", "seq": 3, "text": "” 乃从容言：“吕太后时齐欲反，吴楚时孝王几为乱。", "len": 25}
{"sid": "052_齐悼惠王世家.29.s4", "chapter": "052_齐悼惠王世家", "para": "29", "seq": 4, "text": "今闻齐王与其姊乱。", "len": 9}
{"sid": "052_齐悼惠王世家.29.s5", "chapter": "052_齐悼惠王世家", "para": "29", "seq": 5, "text": "” 於是天子乃拜主父偃为齐相，且正其事。", "len": 20}
{"sid": "052_齐悼惠王世家.29.s6", "chapter": "052_齐悼惠王世家", "para": "29", "seq": 6, "text": "主父偃既至齐，乃急治王後宫宦者为王通於姊翁主所者，令其辞证皆引王。", "len": 33}
{"sid": "052_齐悼惠王世家.29.s7", "chapter": "052_齐悼惠王世家", "para": "29", "seq": 7, "text": "王年少，惧大罪为吏所执诛，乃饮药自杀。", "len": 19}
{"sid": "052_齐悼惠王世家.29.s8", "chapter": "052_齐悼惠王世家", "para": "29", "seq": 8, "text": "绝无後。", "len": 4}
{"sid": "052_齐悼惠王世家.30.s1", "chapter": "052_齐悼惠王世家", "para": "30", "seq": 1, "text": "是时赵王惧主父偃一出废齐，恐其渐疏骨肉，乃上书言偃受金及轻重之短。", "len": 33}
{"sid": "052_齐悼惠王世家.30.s2", "chapter": "052_齐悼惠王世家", "para": "30", "seq": 2, "text": "天子亦既囚偃。", "len": 7}
{"sid": "052_齐悼惠王世家.30.s3", "chapter": "052_齐悼惠王世家", "para": "30", "seq": 3, "text": "公孙弘言：“齐王以忧死毋後，国入汉，非诛偃无以塞天下之望。", "len": 29}
{"sid": "052_齐悼惠王世家.30.s4", "chapter": "052_齐悼惠王世家", "para": "30", "seq": 4, "text": "” 遂诛偃。", "len": 6}
{"sid": "052_齐悼惠王世家.31.s1", "chapter": "052_齐悼惠王世家", "para": "31", "seq": 1, "text": "齐厉王立五年死，毋後，国入于汉。", "len": 16}
{"sid": "052_齐悼惠王世家.32.s1", "chapter": "052_齐悼惠王世家", "para": "32", "seq": 1, "text": "齐悼惠王後尚有二国，城阳及菑川。", "len": 16}
{"sid": "052_齐悼惠王世家.32.s2", "chapter": "052_齐悼惠王世家", "para": "32", "seq": 2, "text": "菑川地比齐。", "len": 6}
{"sid": "052_齐悼惠王世家.32.s3", "chapter": "052_齐悼惠王世家", "para": "32", "seq": 3, "text": "天子怜齐，为悼惠王冢园在郡，割临菑东环悼惠王冢园邑尽以予菑川，以奉悼惠王祭祀。", "len": 39}
{"sid": "052_齐悼惠王世家.33.s1", "chapter": "052_齐悼惠王世家", "para": "33", "seq": 1, "text": "城阳景王章，齐悼惠王子，以硃虚侯与大臣共诛诸吕，而章身首先斩相国吕王产於未央宫。", "len": 40}
{"sid": "052_齐悼惠王世家.33.s2", "chapter": "052_齐悼惠王世家", "para": "33", "seq": 2, "text": "孝文帝既立，益封章二千户，赐金千斤。", "len": 18}
{"sid": "052_齐悼惠王世家.33.s3", "chapter": "052_齐悼惠王世家", "para": "33", "seq": 3, "text": "孝文二年，以齐之城阳郡立章为城阳王。", "len": 18}
{"sid": "052_齐悼惠王世家.33.s4", "chapter": "052_齐悼惠王世家", "para": "33", "seq": 4, "text": "立二年卒，子喜立，是为共王。", "len": 14}
{"sid": "052_齐悼惠王世家.34.s1", "chapter": "052_齐悼惠王世家", "para": "34", "seq": 1, "text": "共王八年，徙王淮南。", "len": 10}
{"sid": "052_齐悼惠王世家.34.s2", "chapter": "052_齐悼惠王世家", "para": "34", "seq": 2, "text": "四年，复还王城阳。", "len": 9}
{"sid": "052_齐悼惠王世家.34.s3", "chapter": "052_齐悼惠王世家", "para": "34", "seq": 3, "text": "凡三十三年卒，子延立，是为顷王。", "len": 16}
{"sid": "052_齐悼惠王世家.35.s1", "chapter": "052_齐悼惠王世家", "para": "35", "seq": 1, "text": "顷王二十年卒，子义立，是为敬王。", "len": 16}
{"sid": "052_齐悼惠王世家.35.s2", "chapter": "052_齐悼惠王世家", "para": "35", "seq": 2, "text": "敬王九年卒，子武立，是为惠王。", "len": 15}
{"sid": "052_齐悼惠王世家.35.s3", "chapter": "052_齐悼惠王世家", "para": "35", "seq": 3, "text": "惠王十一年卒，子顺立，是为荒王。", "len": 16}
{"sid": "052_齐悼惠王世家.35.s4", "chapter": "052_齐悼惠王世家", "para": "35", "seq": 4, "text": "荒王四十六年卒，子恢立，是为戴王。", "len": 17}
{"sid": "052_齐悼惠王世家.35.s5", "chapter": "052_齐悼惠王世家", "para": "35", "seq": 5, "text": "戴王八年卒，子景立，至建始三年，十五岁，卒。", "len": 22}
{"sid": "052_齐悼惠王世家.36.s1", "chapter": "052_齐悼惠王世家", "para": "36", "seq": 1, "text": "济北王兴居，齐悼惠王子，以东牟侯助大臣诛诸吕，功少。", "len": 26}
{"sid": "052_齐悼惠王世家.36.s2", "chapter": "052_齐悼惠王世家", "para": "36", "seq": 2, "text": "及文帝从代来，兴居曰：“请与太仆婴入清宫。", "len": 21}
{"sid": "052_齐悼惠王世家.36.s3", "chapter": "052_齐悼惠王世家", "para": "36", "seq": 3, "text": "” 废少帝，共与大臣尊立孝文帝。", "len": 16}
{"sid": "052_齐悼惠王世家.37.s1", "chapter": "052_齐悼惠王世家", "para": "37", "seq": 1, "text": "孝文帝二年，以齐之济北郡立兴居为济北王，与城阳王俱立。", "len": 27}
{"sid": "052_齐悼惠王世家.37.s2", "chapter": "052_齐悼惠王世家", "para": "37", "seq": 2, "text": "立二年，反。", "len": 6}
{"sid": "052_齐悼惠王世家.37.s3", "chapter": "052_齐悼惠王世家", "para": "37", "seq": 3, "text": "始大臣诛吕氏时，硃虚侯功尤大，许尽以赵地王硃虚侯，尽以梁地王东牟侯。", "len": 34}
{"sid": "052_齐悼惠王世家.37.s4", "chapter": "052_齐悼惠王世家", "para": "37", "seq": 4, "text": "及孝文帝立，闻硃虚、东牟之初欲立齐王，故绌其功。", "len": 24}
{"sid": "052_齐悼惠王世家.37.s5", "chapter": "052_齐悼惠王世家", "para": "37", "seq": 5, "text": "及二年，王诸子，乃割齐二郡以王章、兴居。", "len": 20}
{"sid": "052_齐悼惠王世家.37.s6", "chapter": "052_齐悼惠王世家", "para": "37", "seq": 6, "text": "章、兴居自以失职夺功。", "len": 11}
{"sid": "052_齐悼惠王世家.37.s7", "chapter": "052_齐悼惠王世家", "para": "37", "seq": 7, "text": "章死，而兴居闻匈奴大入汉，汉多发兵，使丞相灌婴击之，文帝亲幸太原，以为天子自击胡，遂发兵反於济北。", "len": 49}
{"sid": "052_齐悼惠王世家.37.s8", "chapter": "052_齐悼惠王世家", "para": "37", "seq": 8, "text": "天子闻之，罢丞相及行兵，皆归长安。", "len": 17}
{"sid": "052_齐悼惠王世家.37.s9", "chapter": "052_齐悼惠王世家", "para": "37", "seq": 9, "text": "使棘蒲侯柴将军击破虏济北王，王自杀，地入于汉，为郡。", "len": 26}
{"sid": "052_齐悼惠王世家.38.s1", "chapter": "052_齐悼惠王世家", "para": "38", "seq": 1, "text": "後十年，文帝十六年，复以齐悼惠王子安都侯志为济北王。", "len": 26}
{"sid": "052_齐悼惠王世家.38.s2", "chapter": "052_齐悼惠王世家", "para": "38", "seq": 2, "text": "十一年，吴楚反时，志坚守，不与诸侯合谋。", "len": 20}
{"sid": "052_齐悼惠王世家.38.s3", "chapter": "052_齐悼惠王世家", "para": "38", "seq": 3, "text": "吴楚已平，徙志王菑川。", "len": 11}
{"sid": "052_齐悼惠王世家.39.s1", "chapter": "052_齐悼惠王世家", "para": "39", "seq": 1, "text": "济南王辟光，齐悼惠王子，以勒侯孝文十六年为济南王。", "len": 25}
{"sid": "052_齐悼惠王世家.39.s2", "chapter": "052_齐悼惠王世家", "para": "39", "seq": 2, "text": "十一年，与吴楚反。", "len": 9}
{"sid": "052_齐悼惠王世家.39.s3", "chapter": "052_齐悼惠王世家", "para": "39", "seq": 3, "text": "汉击破，杀辟光，以济南为郡，地入于汉。", "len": 19}
{"sid": "052_齐悼惠王世家.40.s1", "chapter": "052_齐悼惠王世家", "para": "40", "seq": 1, "text": "菑川王贤，齐悼惠王子，以武城侯文帝十六年为菑川王。", "len": 25}
{"sid": "052_齐悼惠王世家.40.s2", "chapter": "052_齐悼惠王世家", "para": "40", "seq": 2, "text": "十一年，与吴楚反，汉击破，杀贤。", "len": 16}
{"sid": "052_齐悼惠王世家.41.s1", "chapter": "052_齐悼惠王世家", "para": "41", "seq": 1, "text": "天子因徙济北王志王菑川。", "len": 12}
{"sid": "052_齐悼惠王世家.41.s2", "chapter": "052_齐悼惠王世家", "para": "41", "seq": 2, "text": "志亦齐悼惠王子，以安都侯王济北。", "len": 16}
{"sid": "052_齐悼惠王世家.41.s3", "chapter": "052_齐悼惠王世家", "para": "41", "seq": 3, "text": "菑川王反，毋後，乃徙济北王王菑川。", "len": 17}
{"sid": "052_齐悼惠王世家.41.s4", "chapter": "052_齐悼惠王世家", "para": "41", "seq": 4, "text": "凡立三十五年卒，谥为懿王。", "len": 13}
{"sid": "052_齐悼惠王世家.41.s5", "chapter": "052_齐悼惠王世家", "para": "41", "seq": 5, "text": "子建代立，是为靖王。", "len": 10}
{"sid": "052_齐悼惠王世家.41.s6", "chapter": "052_齐悼惠王世家", "para": "41", "seq": 6, "text": "二十年卒，子遗代立，是为顷王。", "len": 15}
{"sid": "052_齐悼惠王世家.41.s7", "chapter": "052_齐悼惠王世家", "para": "41", "seq": 7, "text": "三十六年卒，子终古立，是为思王。", "len": 16}
{"sid": "052_齐悼惠王世家.41.s8", "chapter": "052_齐悼惠王世家", "para": "41", "seq": 8, "text": "二十八年卒，子尚立，是为孝王。", "len": 15}
{"sid": "052_齐悼惠王世家.41.s9", "chapter": "052_齐悼惠王世家", "para": "41", "seq": 9, "text": "五年卒，子横立，至建始三年，十一岁，卒。", "len": 20}
{"sid": "052_齐悼惠王世家.42.s1", "chapter": "052_齐悼惠王世家", "para": "42", "seq": 1, "text": "胶西王卬，齐悼惠王子，以昌平侯文帝十六年为胶西王。", "len": 25}
{"sid": "052_齐悼惠王世家.42.s2", "chapter": "052_齐悼惠王世家", "para": "42", "seq": 2, "text": "十一年，与吴楚反。", "len": 9}
{"sid": "052_齐悼惠王世家.42.s3", "chapter": "052_齐悼惠王世家", "para": "42", "seq": 3, "text": "汉击破，杀卬，地入于汉，为胶西郡。", "len": 17}
{"sid": "052_齐悼惠王世家.43.s1", "chapter": "052_齐悼惠王世家", "para": "43", "seq": 1, "text": "胶东王雄渠，齐悼惠王子，以白石侯文帝十六年为胶东王。", "len": 26}
{"sid": "052_齐悼惠王世家.43.s2", "chapter": "052_齐悼惠王世家", "para": "43", "seq": 2, "text": "十一年，与吴楚反，汉击破，杀雄渠，地入于汉，为胶东郡。", "len": 27}
{"sid": "052_齐悼惠王世家.43.s3", "chapter": "052_齐悼惠王世家", "para": "43", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "052_齐悼惠王世家.44.s1", "chapter": "052_齐悼惠王世家", "para": "44", "seq": 1, "text": "太史公曰：诸侯大国无过齐悼惠王。", "len": 16}
{"sid": "052_齐悼惠王世家.44.s2", "chapter": "052_齐悼惠王世家", "para": "44", "seq": 2, "text": "以海内初定，子弟少，激秦之无尺土封，故大封同姓，以填万民之心。", "len": 31}
{"sid": "052_齐悼惠王世家.44.s3", "chapter": "052_齐悼惠王世家", "para": "44", "seq": 3, "text": "及後分裂，固其理也。", "len": 10}
{"sid": "052_齐悼惠王世家.44.s4", "chapter": "052_齐悼惠王世家", "para": "44", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "052_齐悼惠王世家.45.s1", "chapter": "052_齐悼惠王世家", "para": "45", "seq": 1, "text": "汉矫秦制，树屏自彊。", "len": 10}
{"sid": "052_齐悼惠王世家.45.s2", "chapter": "052_齐悼惠王世家", "para": "45", "seq": 2, "text": "表海大国，悉封齐王。", "len": 10}
{"sid": "052_齐悼惠王世家.45.s3", "chapter": "052_齐悼惠王世家", "para": "45", "seq": 3, "text": "吕后肆怒，乃献城阳。", "len": 10}
{"sid": "052_齐悼惠王世家.45.s4", "chapter": "052_齐悼惠王世家", "para": "45", "seq": 4, "text": "哀王嗣立，其力不量。", "len": 10}
{"sid": "052_齐悼惠王世家.45.s5", "chapter": "052_齐悼惠王世家", "para": "45", "seq": 5, "text": "硃虚仕汉，功大策长。", "len": 10}
{"sid": "052_齐悼惠王世家.45.s6", "chapter": "052_齐悼惠王世家", "para": "45", "seq": 6, "text": "东牟受赏，称乱贻殃。", "len": 10}
{"sid": "052_齐悼惠王世家.45.s7", "chapter": "052_齐悼惠王世家", "para": "45", "seq": 7, "text": "胶东、济北，雄渠，辟光。", "len": 12}
{"sid": "052_齐悼惠王世家.45.s8", "chapter": "052_齐悼惠王世家", "para": "45", "seq": 8, "text": "齐虽七国，忠孝者昌。", "len": 10}
{"sid": "052_齐悼惠王世家.45.s9", "chapter": "052_齐悼惠王世家", "para": "45", "seq": 9, "text": ":::", "len": 3}
