{"sid": "073_白起王翦列传.1.s1", "chapter": "073_白起王翦列传", "para": "1", "seq": 1, "text": "白起者，郿人也。", "len": 8}
{"sid": "073_白起王翦列传.1.s2", "chapter": "073_白起王翦列传", "para": "1", "seq": 2, "text": "善用兵，事秦昭王。", "len": 9}
{"sid": "073_白起王翦列传.1.s3", "chapter": "073_白起王翦列传", "para": "1", "seq": 3, "text": "昭王十三年，而白起为左庶长，将而击韩之新城。", "len": 22}
{"sid": "073_白起王翦列传.1.s4", "chapter": "073_白起王翦列传", "para": "1", "seq": 4, "text": "是岁，穰侯相秦，举任鄙以为汉中守。", "len": 17}
{"sid": "073_白起王翦列传.1.s5", "chapter": "073_白起王翦列传", "para": "1", "seq": 5, "text": "其明年，白起为左更，攻韩、魏於伊阙，斩首二十四万，又虏其将公孙喜，拔五城。", "len": 37}
{"sid": "073_白起王翦列传.1.s6", "chapter": "073_白起王翦列传", "para": "1", "seq": 6, "text": "起迁为国尉。", "len": 6}
{"sid": "073_白起王翦列传.1.s7", "chapter": "073_白起王翦列传", "para": "1", "seq": 7, "text": "涉河取韩安邑以东，到乾河。", "len": 13}
{"sid": "073_白起王翦列传.1.s8", "chapter": "073_白起王翦列传", "para": "1", "seq": 8, "text": "明年，白起为大良造。", "len": 10}
{"sid": "073_白起王翦列传.1.s9", "chapter": "073_白起王翦列传", "para": "1", "seq": 9, "text": "攻魏，拔之，取城小大六十一。", "len": 14}
{"sid": "073_白起王翦列传.1.s10", "chapter": "073_白起王翦列传", "para": "1", "seq": 10, "text": "明年，起与客卿错攻垣城，拔之。", "len": 15}
{"sid": "073_白起王翦列传.1.s11", "chapter": "073_白起王翦列传", "para": "1", "seq": 11, "text": "後五年，白起攻赵，拔光狼城。", "len": 14}
{"sid": "073_白起王翦列传.1.s12", "chapter": "073_白起王翦列传", "para": "1", "seq": 12, "text": "後七年，白起攻楚，拔鄢、邓五城。", "len": 16}
{"sid": "073_白起王翦列传.1.s13", "chapter": "073_白起王翦列传", "para": "1", "seq": 13, "text": "其明年，攻楚，拔郢，烧夷陵，遂东至竟陵。", "len": 20}
{"sid": "073_白起王翦列传.1.s14", "chapter": "073_白起王翦列传", "para": "1", "seq": 14, "text": "楚王亡去郢，东走徙陈。", "len": 11}
{"sid": "073_白起王翦列传.1.s15", "chapter": "073_白起王翦列传", "para": "1", "seq": 15, "text": "秦以郢为南郡。", "len": 7}
{"sid": "073_白起王翦列传.1.s16", "chapter": "073_白起王翦列传", "para": "1", "seq": 16, "text": "白起迁为武安君。", "len": 8}
{"sid": "073_白起王翦列传.1.s17", "chapter": "073_白起王翦列传", "para": "1", "seq": 17, "text": "武安君因取楚，定巫、黔中郡。", "len": 14}
{"sid": "073_白起王翦列传.1.s18", "chapter": "073_白起王翦列传", "para": "1", "seq": 18, "text": "昭王三十四年，白起攻魏，拔华阳，走芒卯，而虏三晋将，斩首十三万。", "len": 32}
{"sid": "073_白起王翦列传.1.s19", "chapter": "073_白起王翦列传", "para": "1", "seq": 19, "text": "与赵将贾偃战，沈其卒二万人於河中。", "len": 17}
{"sid": "073_白起王翦列传.1.s20", "chapter": "073_白起王翦列传", "para": "1", "seq": 20, "text": "昭王四十三年，白起攻韩陉城，拔五城，斩首五万。", "len": 23}
{"sid": "073_白起王翦列传.1.s21", "chapter": "073_白起王翦列传", "para": "1", "seq": 21, "text": "四十四年，白起攻南阳太行道，绝之。", "len": 17}
{"sid": "073_白起王翦列传.2.s1", "chapter": "073_白起王翦列传", "para": "2", "seq": 1, "text": "四十五年，伐韩之野王。", "len": 11}
{"sid": "073_白起王翦列传.2.s2", "chapter": "073_白起王翦列传", "para": "2", "seq": 2, "text": "野王降秦，上党道绝。", "len": 10}
{"sid": "073_白起王翦列传.2.s3", "chapter": "073_白起王翦列传", "para": "2", "seq": 3, "text": "其守冯亭与民谋曰：“郑道已绝，韩必不可得为民。", "len": 23}
{"sid": "073_白起王翦列传.2.s4", "chapter": "073_白起王翦列传", "para": "2", "seq": 4, "text": "秦兵日进，韩不能应，不如以上党归赵。", "len": 18}
{"sid": "073_白起王翦列传.2.s5", "chapter": "073_白起王翦列传", "para": "2", "seq": 5, "text": "赵若受我，秦怒，必攻赵。", "len": 12}
{"sid": "073_白起王翦列传.2.s6", "chapter": "073_白起王翦列传", "para": "2", "seq": 6, "text": "赵被兵，必亲韩。", "len": 8}
{"sid": "073_白起王翦列传.2.s7", "chapter": "073_白起王翦列传", "para": "2", "seq": 7, "text": "韩赵为一，则可以当秦。", "len": 11}
{"sid": "073_白起王翦列传.2.s8", "chapter": "073_白起王翦列传", "para": "2", "seq": 8, "text": "” 因使人报赵。", "len": 8}
{"sid": "073_白起王翦列传.2.s9", "chapter": "073_白起王翦列传", "para": "2", "seq": 9, "text": "赵孝成王与平阳君、平原君计之。", "len": 15}
{"sid": "073_白起王翦列传.2.s10", "chapter": "073_白起王翦列传", "para": "2", "seq": 10, "text": "平阳君曰：“不如勿受。", "len": 11}
{"sid": "073_白起王翦列传.2.s11", "chapter": "073_白起王翦列传", "para": "2", "seq": 11, "text": "受之，祸大於所得。", "len": 9}
{"sid": "073_白起王翦列传.2.s12", "chapter": "073_白起王翦列传", "para": "2", "seq": 12, "text": "” 平原君曰：“无故得一郡，受之便。", "len": 18}
{"sid": "073_白起王翦列传.2.s13", "chapter": "073_白起王翦列传", "para": "2", "seq": 13, "text": "” 赵受之，因封冯亭为华阳君。", "len": 15}
{"sid": "073_白起王翦列传.3.s1", "chapter": "073_白起王翦列传", "para": "3", "seq": 1, "text": "四十六年，秦攻韩缑氏、蔺，拔之。", "len": 16}
{"sid": "073_白起王翦列传.4.s1", "chapter": "073_白起王翦列传", "para": "4", "seq": 1, "text": "四十七年，秦使左庶长王龁攻韩，取上党。", "len": 19}
{"sid": "073_白起王翦列传.4.s2", "chapter": "073_白起王翦列传", "para": "4", "seq": 2, "text": "上党民走赵。", "len": 6}
{"sid": "073_白起王翦列传.4.s3", "chapter": "073_白起王翦列传", "para": "4", "seq": 3, "text": "赵军长平，以按据上党民。", "len": 12}
{"sid": "073_白起王翦列传.4.s4", "chapter": "073_白起王翦列传", "para": "4", "seq": 4, "text": "四月，龁因攻赵。", "len": 8}
{"sid": "073_白起王翦列传.4.s5", "chapter": "073_白起王翦列传", "para": "4", "seq": 5, "text": "赵使廉颇将。", "len": 6}
{"sid": "073_白起王翦列传.4.s6", "chapter": "073_白起王翦列传", "para": "4", "seq": 6, "text": "赵军士卒犯秦斥兵，秦斥兵斩赵裨将茄。", "len": 18}
{"sid": "073_白起王翦列传.4.s7", "chapter": "073_白起王翦列传", "para": "4", "seq": 7, "text": "六月，陷赵军，取二鄣四尉。", "len": 13}
{"sid": "073_白起王翦列传.4.s8", "chapter": "073_白起王翦列传", "para": "4", "seq": 8, "text": "七月，赵军筑垒壁而守之。", "len": 12}
{"sid": "073_白起王翦列传.4.s9", "chapter": "073_白起王翦列传", "para": "4", "seq": 9, "text": "秦又攻其垒，取二尉，败其阵，夺西垒壁。", "len": 19}
{"sid": "073_白起王翦列传.4.s10", "chapter": "073_白起王翦列传", "para": "4", "seq": 10, "text": "廉颇坚壁以待秦，秦数挑战，赵兵不出。", "len": 18}
{"sid": "073_白起王翦列传.4.s11", "chapter": "073_白起王翦列传", "para": "4", "seq": 11, "text": "赵王数以为让。", "len": 7}
{"sid": "073_白起王翦列传.4.s12", "chapter": "073_白起王翦列传", "para": "4", "seq": 12, "text": "而秦相应侯又使人行千金於赵为反间，曰：“秦之所恶，独畏马服子赵括将耳，廉颇易与，且降矣。", "len": 44}
{"sid": "073_白起王翦列传.4.s13", "chapter": "073_白起王翦列传", "para": "4", "seq": 13, "text": "” 赵王既怒廉颇军多失亡，军数败，又反坚壁不敢战，而又闻秦反间之言，因使赵括代廉颇将以击秦。", "len": 46}
{"sid": "073_白起王翦列传.4.s14", "chapter": "073_白起王翦列传", "para": "4", "seq": 14, "text": "秦闻马服子将，乃阴使武安君白起为上将军。", "len": 20}
{"sid": "073_白起王翦列传.4.s15", "chapter": "073_白起王翦列传", "para": "4", "seq": 15, "text": "而王龁为尉裨将，令军中有敢泄武安君将者斩。", "len": 21}
{"sid": "073_白起王翦列传.4.s16", "chapter": "073_白起王翦列传", "para": "4", "seq": 16, "text": "赵括至，则出兵击秦军。", "len": 11}
{"sid": "073_白起王翦列传.4.s17", "chapter": "073_白起王翦列传", "para": "4", "seq": 17, "text": "秦军详败而走，张二奇兵以劫之。", "len": 15}
{"sid": "073_白起王翦列传.4.s18", "chapter": "073_白起王翦列传", "para": "4", "seq": 18, "text": "赵军逐胜，追造秦壁。", "len": 10}
{"sid": "073_白起王翦列传.4.s19", "chapter": "073_白起王翦列传", "para": "4", "seq": 19, "text": "壁坚拒不得入，而秦奇兵二万五千人绝赵军後，又一军五千骑绝赵壁间，赵军分而为二，粮道绝。", "len": 43}
{"sid": "073_白起王翦列传.4.s20", "chapter": "073_白起王翦列传", "para": "4", "seq": 20, "text": "而秦出轻兵击之。", "len": 8}
{"sid": "073_白起王翦列传.4.s21", "chapter": "073_白起王翦列传", "para": "4", "seq": 21, "text": "赵战不利，因筑壁坚守，以待救至。", "len": 16}
{"sid": "073_白起王翦列传.4.s22", "chapter": "073_白起王翦列传", "para": "4", "seq": 22, "text": "秦王闻赵食道绝，王自之河内，赐民爵各一级，发年十五以上悉诣长平，遮绝赵救及粮食。", "len": 40}
{"sid": "073_白起王翦列传.5.s1", "chapter": "073_白起王翦列传", "para": "5", "seq": 1, "text": "至九月，赵卒不得食四十六日，皆内阴相杀食。", "len": 21}
{"sid": "073_白起王翦列传.5.s2", "chapter": "073_白起王翦列传", "para": "5", "seq": 2, "text": "来攻秦垒，欲出。", "len": 8}
{"sid": "073_白起王翦列传.5.s3", "chapter": "073_白起王翦列传", "para": "5", "seq": 3, "text": "为四队，四五复之，不能出。", "len": 13}
{"sid": "073_白起王翦列传.5.s4", "chapter": "073_白起王翦列传", "para": "5", "seq": 4, "text": "其将军赵括出锐卒自搏战，秦军射杀赵括。", "len": 19}
{"sid": "073_白起王翦列传.5.s5", "chapter": "073_白起王翦列传", "para": "5", "seq": 5, "text": "括军败，卒四十万人降武安君。", "len": 14}
{"sid": "073_白起王翦列传.5.s6", "chapter": "073_白起王翦列传", "para": "5", "seq": 6, "text": "武安君计曰：“前秦已拔上党，上党民不乐为秦而归赵。", "len": 25}
{"sid": "073_白起王翦列传.5.s7", "chapter": "073_白起王翦列传", "para": "5", "seq": 7, "text": "赵卒反覆。", "len": 5}
{"sid": "073_白起王翦列传.5.s8", "chapter": "073_白起王翦列传", "para": "5", "seq": 8, "text": "非尽杀之，恐为乱。", "len": 9}
{"sid": "073_白起王翦列传.5.s9", "chapter": "073_白起王翦列传", "para": "5", "seq": 9, "text": "” 乃挟诈而尽阬杀之，遗其小者二百四十人归赵。", "len": 23}
{"sid": "073_白起王翦列传.5.s10", "chapter": "073_白起王翦列传", "para": "5", "seq": 10, "text": "前後斩首虏四十五万人。", "len": 11}
{"sid": "073_白起王翦列传.5.s11", "chapter": "073_白起王翦列传", "para": "5", "seq": 11, "text": "赵人大震。", "len": 5}
{"sid": "073_白起王翦列传.6.s1", "chapter": "073_白起王翦列传", "para": "6", "seq": 1, "text": "四十八年十月，秦复定上党郡。", "len": 14}
{"sid": "073_白起王翦列传.6.s2", "chapter": "073_白起王翦列传", "para": "6", "seq": 2, "text": "秦分军为二：王龁攻皮牢，拔之；司马梗定太原。", "len": 22}
{"sid": "073_白起王翦列传.6.s3", "chapter": "073_白起王翦列传", "para": "6", "seq": 3, "text": "韩、赵恐，使苏代厚币说秦相应侯曰：“武安君禽马服子乎？", "len": 27}
{"sid": "073_白起王翦列传.6.s4", "chapter": "073_白起王翦列传", "para": "6", "seq": 4, "text": "” 曰：“然。", "len": 7}
{"sid": "073_白起王翦列传.6.s5", "chapter": "073_白起王翦列传", "para": "6", "seq": 5, "text": "” 又曰：“即围邯郸乎？", "len": 12}
{"sid": "073_白起王翦列传.6.s6", "chapter": "073_白起王翦列传", "para": "6", "seq": 6, "text": "” 曰：“然。", "len": 7}
{"sid": "073_白起王翦列传.6.s7", "chapter": "073_白起王翦列传", "para": "6", "seq": 7, "text": "” “赵亡则秦王王矣，武安君为三公。", "len": 18}
{"sid": "073_白起王翦列传.6.s8", "chapter": "073_白起王翦列传", "para": "6", "seq": 8, "text": "武安君所为秦战胜攻取者七十馀城，南定鄢、郢、汉中，北禽赵括之军，虽周、召、吕望之功不益於此矣。", "len": 47}
{"sid": "073_白起王翦列传.6.s9", "chapter": "073_白起王翦列传", "para": "6", "seq": 9, "text": "今赵亡，秦王王，则武安君必为三公，君能为之下乎？", "len": 24}
{"sid": "073_白起王翦列传.6.s10", "chapter": "073_白起王翦列传", "para": "6", "seq": 10, "text": "虽无欲为之下，固不得已矣。", "len": 13}
{"sid": "073_白起王翦列传.6.s11", "chapter": "073_白起王翦列传", "para": "6", "seq": 11, "text": "秦尝攻韩，围邢丘，困上党，上党之民皆反为赵，天下不乐为秦民之日久矣。", "len": 34}
{"sid": "073_白起王翦列传.6.s12", "chapter": "073_白起王翦列传", "para": "6", "seq": 12, "text": "今亡赵，北地入燕，东地入齐，南地入韩、魏，则君之所得民亡几何人。", "len": 32}
{"sid": "073_白起王翦列传.6.s13", "chapter": "073_白起王翦列传", "para": "6", "seq": 13, "text": "故不如因而割之，无以为武安君功也。", "len": 17}
{"sid": "073_白起王翦列传.6.s14", "chapter": "073_白起王翦列传", "para": "6", "seq": 14, "text": "” 於是应侯言於秦王曰：“秦兵劳，请许韩、赵之割地以和，且休士卒。", "len": 33}
{"sid": "073_白起王翦列传.6.s15", "chapter": "073_白起王翦列传", "para": "6", "seq": 15, "text": "” 王听之，割韩垣雍、赵六城以和。", "len": 17}
{"sid": "073_白起王翦列传.6.s16", "chapter": "073_白起王翦列传", "para": "6", "seq": 16, "text": "正月，皆罢兵。", "len": 7}
{"sid": "073_白起王翦列传.6.s17", "chapter": "073_白起王翦列传", "para": "6", "seq": 17, "text": "武安君闻之，由是与应侯有隙。", "len": 14}
{"sid": "073_白起王翦列传.7.s1", "chapter": "073_白起王翦列传", "para": "7", "seq": 1, "text": "其九月，秦复发兵，使五大夫王陵攻赵邯郸。", "len": 20}
{"sid": "073_白起王翦列传.7.s2", "chapter": "073_白起王翦列传", "para": "7", "seq": 2, "text": "是时武安君病，不任行。", "len": 11}
{"sid": "073_白起王翦列传.7.s3", "chapter": "073_白起王翦列传", "para": "7", "seq": 3, "text": "四十九年正月，陵攻邯郸，少利，秦益发兵佐陵。", "len": 22}
{"sid": "073_白起王翦列传.7.s4", "chapter": "073_白起王翦列传", "para": "7", "seq": 4, "text": "陵兵亡五校。", "len": 6}
{"sid": "073_白起王翦列传.7.s5", "chapter": "073_白起王翦列传", "para": "7", "seq": 5, "text": "武安君病愈，秦王欲使武安君代陵将。", "len": 17}
{"sid": "073_白起王翦列传.7.s6", "chapter": "073_白起王翦列传", "para": "7", "seq": 6, "text": "武安君言曰：“邯郸实未易攻也。", "len": 15}
{"sid": "073_白起王翦列传.7.s7", "chapter": "073_白起王翦列传", "para": "7", "seq": 7, "text": "且诸侯救日至，彼诸侯怨秦之日久矣。", "len": 17}
{"sid": "073_白起王翦列传.7.s8", "chapter": "073_白起王翦列传", "para": "7", "seq": 8, "text": "今秦虽破长平军，而秦卒死者过半，国内空。", "len": 20}
{"sid": "073_白起王翦列传.7.s9", "chapter": "073_白起王翦列传", "para": "7", "seq": 9, "text": "远绝河山而争人国都，赵应其内，诸侯攻其外，破秦军必矣。", "len": 27}
{"sid": "073_白起王翦列传.7.s10", "chapter": "073_白起王翦列传", "para": "7", "seq": 10, "text": "不可。", "len": 3}
{"sid": "073_白起王翦列传.7.s11", "chapter": "073_白起王翦列传", "para": "7", "seq": 11, "text": "” 秦王自命，不行；乃使应侯请之，武安君终辞不肯行，遂称病。", "len": 30}
{"sid": "073_白起王翦列传.8.s1", "chapter": "073_白起王翦列传", "para": "8", "seq": 1, "text": "秦王使王龁代陵将，八九月围邯郸，不能拔。", "len": 20}
{"sid": "073_白起王翦列传.8.s2", "chapter": "073_白起王翦列传", "para": "8", "seq": 2, "text": "楚使春申君及魏公子将兵数十万攻秦军，秦军多失亡。", "len": 24}
{"sid": "073_白起王翦列传.8.s3", "chapter": "073_白起王翦列传", "para": "8", "seq": 3, "text": "武安君言曰：“秦不听臣计，今如何矣！", "len": 18}
{"sid": "073_白起王翦列传.8.s4", "chapter": "073_白起王翦列传", "para": "8", "seq": 4, "text": "” 秦王闻之，怒，彊起武安君，武安君遂称病笃。", "len": 23}
{"sid": "073_白起王翦列传.8.s5", "chapter": "073_白起王翦列传", "para": "8", "seq": 5, "text": "应侯请之，不起。", "len": 8}
{"sid": "073_白起王翦列传.8.s6", "chapter": "073_白起王翦列传", "para": "8", "seq": 6, "text": "於是免武安君为士伍，迁之阴密。", "len": 15}
{"sid": "073_白起王翦列传.8.s7", "chapter": "073_白起王翦列传", "para": "8", "seq": 7, "text": "武安君病，未能行。", "len": 9}
{"sid": "073_白起王翦列传.8.s8", "chapter": "073_白起王翦列传", "para": "8", "seq": 8, "text": "居三月，诸侯攻秦军急，秦军数卻，使者日至。", "len": 21}
{"sid": "073_白起王翦列传.8.s9", "chapter": "073_白起王翦列传", "para": "8", "seq": 9, "text": "秦王乃使人遣白起，不得留咸阳中。", "len": 16}
{"sid": "073_白起王翦列传.8.s10", "chapter": "073_白起王翦列传", "para": "8", "seq": 10, "text": "武安君既行，出咸阳西门十里，至杜邮。", "len": 18}
{"sid": "073_白起王翦列传.8.s11", "chapter": "073_白起王翦列传", "para": "8", "seq": 11, "text": "秦昭王与应侯群臣议曰：“白起之迁，其意尚怏怏不服，有馀言。", "len": 29}
{"sid": "073_白起王翦列传.8.s12", "chapter": "073_白起王翦列传", "para": "8", "seq": 12, "text": "” 秦王乃使使者赐之剑，自裁。", "len": 15}
{"sid": "073_白起王翦列传.8.s13", "chapter": "073_白起王翦列传", "para": "8", "seq": 13, "text": "武安君引剑将自刭，曰：“我何罪于天而至此哉？", "len": 22}
{"sid": "073_白起王翦列传.8.s14", "chapter": "073_白起王翦列传", "para": "8", "seq": 14, "text": "” 良久，曰：“我固当死。", "len": 13}
{"sid": "073_白起王翦列传.8.s15", "chapter": "073_白起王翦列传", "para": "8", "seq": 15, "text": "长平之战，赵卒降者数十万人，我诈而尽阬之，是足以死。", "len": 26}
{"sid": "073_白起王翦列传.8.s16", "chapter": "073_白起王翦列传", "para": "8", "seq": 16, "text": "” 遂自杀。", "len": 6}
{"sid": "073_白起王翦列传.8.s17", "chapter": "073_白起王翦列传", "para": "8", "seq": 17, "text": "武安君之死也，以秦昭王五十年十一月。", "len": 18}
{"sid": "073_白起王翦列传.8.s18", "chapter": "073_白起王翦列传", "para": "8", "seq": 18, "text": "死而非其罪，秦人怜之，乡邑皆祭祀焉。", "len": 18}
{"sid": "073_白起王翦列传.9.s1", "chapter": "073_白起王翦列传", "para": "9", "seq": 1, "text": "王翦者，频阳东乡人也。", "len": 11}
{"sid": "073_白起王翦列传.9.s2", "chapter": "073_白起王翦列传", "para": "9", "seq": 2, "text": "少而好兵，事秦始皇。", "len": 10}
{"sid": "073_白起王翦列传.9.s3", "chapter": "073_白起王翦列传", "para": "9", "seq": 3, "text": "始皇十一年，翦将攻赵阏与，破之，拔九城，十八年，翦将攻赵。", "len": 29}
{"sid": "073_白起王翦列传.9.s4", "chapter": "073_白起王翦列传", "para": "9", "seq": 4, "text": "岁馀，遂拔赵，赵王降，尽定赵地为郡。", "len": 18}
{"sid": "073_白起王翦列传.9.s5", "chapter": "073_白起王翦列传", "para": "9", "seq": 5, "text": "明年，燕使荆轲为贼於秦，秦王使王翦攻燕。", "len": 20}
{"sid": "073_白起王翦列传.9.s6", "chapter": "073_白起王翦列传", "para": "9", "seq": 6, "text": "燕王喜走辽东，翦遂定燕蓟而还。", "len": 15}
{"sid": "073_白起王翦列传.9.s7", "chapter": "073_白起王翦列传", "para": "9", "seq": 7, "text": "秦使翦子王贲击荆，荆兵败。", "len": 13}
{"sid": "073_白起王翦列传.9.s8", "chapter": "073_白起王翦列传", "para": "9", "seq": 8, "text": "还击魏，魏王降，遂定魏地。", "len": 13}
{"sid": "073_白起王翦列传.10.s1", "chapter": "073_白起王翦列传", "para": "10", "seq": 1, "text": "秦始皇既灭三晋，走燕王，而数破荆师。", "len": 18}
{"sid": "073_白起王翦列传.10.s2", "chapter": "073_白起王翦列传", "para": "10", "seq": 2, "text": "秦将李信者，年少壮勇，尝以兵数千逐燕太子丹至於衍水中，卒破得丹，始皇以为贤勇。", "len": 39}
{"sid": "073_白起王翦列传.10.s3", "chapter": "073_白起王翦列传", "para": "10", "seq": 3, "text": "於是始皇问李信：“吾欲攻取荆，於将军度用几何人而足？", "len": 26}
{"sid": "073_白起王翦列传.10.s4", "chapter": "073_白起王翦列传", "para": "10", "seq": 4, "text": "” 李信曰：“不过用二十万人。", "len": 15}
{"sid": "073_白起王翦列传.10.s5", "chapter": "073_白起王翦列传", "para": "10", "seq": 5, "text": "” 始皇问王翦，王翦曰：“非六十万人不可。", "len": 21}
{"sid": "073_白起王翦列传.10.s6", "chapter": "073_白起王翦列传", "para": "10", "seq": 6, "text": "” 始皇曰：“王将军老矣，何怯也！", "len": 17}
{"sid": "073_白起王翦列传.10.s7", "chapter": "073_白起王翦列传", "para": "10", "seq": 7, "text": "李将军果势壮勇，其言是也。", "len": 13}
{"sid": "073_白起王翦列传.10.s8", "chapter": "073_白起王翦列传", "para": "10", "seq": 8, "text": "” 遂使李信及蒙恬将二十万南伐荆。", "len": 17}
{"sid": "073_白起王翦列传.10.s9", "chapter": "073_白起王翦列传", "para": "10", "seq": 9, "text": "王翦言不用，因谢病，归老於频阳。", "len": 16}
{"sid": "073_白起王翦列传.10.s10", "chapter": "073_白起王翦列传", "para": "10", "seq": 10, "text": "李信攻平与，蒙恬攻寝，大破荆军。", "len": 16}
{"sid": "073_白起王翦列传.10.s11", "chapter": "073_白起王翦列传", "para": "10", "seq": 11, "text": "信又攻鄢郢，破之，於是引兵而西，与蒙恬会城父。", "len": 23}
{"sid": "073_白起王翦列传.10.s12", "chapter": "073_白起王翦列传", "para": "10", "seq": 12, "text": "荆人因随之，三日三夜不顿舍，大破李信军，入两壁，杀七都尉，秦军走。", "len": 33}
{"sid": "073_白起王翦列传.11.s1", "chapter": "073_白起王翦列传", "para": "11", "seq": 1, "text": "始皇闻之，大怒，自驰如频阳，见谢王翦曰：“寡人以不用将军计，李信果辱秦军。", "len": 37}
{"sid": "073_白起王翦列传.11.s2", "chapter": "073_白起王翦列传", "para": "11", "seq": 2, "text": "今闻荆兵日进而西，将军虽病，独忍弃寡人乎！", "len": 21}
{"sid": "073_白起王翦列传.11.s3", "chapter": "073_白起王翦列传", "para": "11", "seq": 3, "text": "” 王翦谢曰：“老臣罢病悖乱，唯大王更择贤将。", "len": 23}
{"sid": "073_白起王翦列传.11.s4", "chapter": "073_白起王翦列传", "para": "11", "seq": 4, "text": "” 始皇谢曰：“已矣，将军勿复言！", "len": 17}
{"sid": "073_白起王翦列传.11.s5", "chapter": "073_白起王翦列传", "para": "11", "seq": 5, "text": "” 王翦曰：“大王必不得已用臣，非六十万人不可。", "len": 24}
{"sid": "073_白起王翦列传.11.s6", "chapter": "073_白起王翦列传", "para": "11", "seq": 6, "text": "” 始皇曰：“为听将军计耳。", "len": 14}
{"sid": "073_白起王翦列传.11.s7", "chapter": "073_白起王翦列传", "para": "11", "seq": 7, "text": "” 於是王翦将兵六十万人，始皇自送至灞上。", "len": 21}
{"sid": "073_白起王翦列传.11.s8", "chapter": "073_白起王翦列传", "para": "11", "seq": 8, "text": "王翦行，请美田宅园池甚众。", "len": 13}
{"sid": "073_白起王翦列传.11.s9", "chapter": "073_白起王翦列传", "para": "11", "seq": 9, "text": "始皇曰：“将军行矣，何忧贫乎？", "len": 15}
{"sid": "073_白起王翦列传.11.s10", "chapter": "073_白起王翦列传", "para": "11", "seq": 10, "text": "” 王翦曰：“为大王将，有功终不得封侯，故及大王之乡臣，臣亦及时以请园池为子孙业耳。", "len": 42}
{"sid": "073_白起王翦列传.11.s11", "chapter": "073_白起王翦列传", "para": "11", "seq": 11, "text": "” 始皇大笑。", "len": 7}
{"sid": "073_白起王翦列传.11.s12", "chapter": "073_白起王翦列传", "para": "11", "seq": 12, "text": "王翦既至关，使使还请善田者五辈。", "len": 16}
{"sid": "073_白起王翦列传.11.s13", "chapter": "073_白起王翦列传", "para": "11", "seq": 13, "text": "或曰：“将军之乞贷，亦已甚矣。", "len": 15}
{"sid": "073_白起王翦列传.11.s14", "chapter": "073_白起王翦列传", "para": "11", "seq": 14, "text": "” 王翦曰：“不然。", "len": 10}
{"sid": "073_白起王翦列传.11.s15", "chapter": "073_白起王翦列传", "para": "11", "seq": 15, "text": "夫秦王怚而不信人。", "len": 9}
{"sid": "073_白起王翦列传.11.s16", "chapter": "073_白起王翦列传", "para": "11", "seq": 16, "text": "今空秦国甲士而专委於我，我不多请田宅为子孙业以自坚，顾令秦王坐而疑我邪？”", "len": 37}
{"sid": "073_白起王翦列传.12.s1", "chapter": "073_白起王翦列传", "para": "12", "seq": 1, "text": "王翦果代李信击荆。", "len": 9}
{"sid": "073_白起王翦列传.12.s2", "chapter": "073_白起王翦列传", "para": "12", "seq": 2, "text": "荆闻王翦益军而来，乃悉国中兵以拒秦。", "len": 18}
{"sid": "073_白起王翦列传.12.s3", "chapter": "073_白起王翦列传", "para": "12", "seq": 3, "text": "王翦至，坚壁而守之，不肯战。", "len": 14}
{"sid": "073_白起王翦列传.12.s4", "chapter": "073_白起王翦列传", "para": "12", "seq": 4, "text": "荆兵数出挑战，终不出。", "len": 11}
{"sid": "073_白起王翦列传.12.s5", "chapter": "073_白起王翦列传", "para": "12", "seq": 5, "text": "王翦日休士洗沐，而善饮食抚循之，亲与士卒同食。", "len": 23}
{"sid": "073_白起王翦列传.12.s6", "chapter": "073_白起王翦列传", "para": "12", "seq": 6, "text": "久之，王翦使人问军中戏乎？", "len": 13}
{"sid": "073_白起王翦列传.12.s7", "chapter": "073_白起王翦列传", "para": "12", "seq": 7, "text": "对曰：“方投石超距。", "len": 10}
{"sid": "073_白起王翦列传.12.s8", "chapter": "073_白起王翦列传", "para": "12", "seq": 8, "text": "” 於是王翦曰：“士卒可用矣。", "len": 15}
{"sid": "073_白起王翦列传.12.s9", "chapter": "073_白起王翦列传", "para": "12", "seq": 9, "text": "” 荆数挑战而秦不出，乃引而东。", "len": 16}
{"sid": "073_白起王翦列传.12.s10", "chapter": "073_白起王翦列传", "para": "12", "seq": 10, "text": "翦因举兵追之，令壮士击，大破荆军。", "len": 17}
{"sid": "073_白起王翦列传.12.s11", "chapter": "073_白起王翦列传", "para": "12", "seq": 11, "text": "至蕲南，杀其将军项燕，荆兵遂败走。", "len": 17}
{"sid": "073_白起王翦列传.12.s12", "chapter": "073_白起王翦列传", "para": "12", "seq": 12, "text": "秦因乘胜略定荆地城邑。", "len": 11}
{"sid": "073_白起王翦列传.12.s13", "chapter": "073_白起王翦列传", "para": "12", "seq": 13, "text": "岁馀，虏荆王负刍，竟平荆地为郡县。", "len": 17}
{"sid": "073_白起王翦列传.12.s14", "chapter": "073_白起王翦列传", "para": "12", "seq": 14, "text": "因南征百越之君。", "len": 8}
{"sid": "073_白起王翦列传.12.s15", "chapter": "073_白起王翦列传", "para": "12", "seq": 15, "text": "而王翦子王贲，与李信破定燕、齐地。", "len": 17}
{"sid": "073_白起王翦列传.13.s1", "chapter": "073_白起王翦列传", "para": "13", "seq": 1, "text": "秦始皇二十六年，尽并天下，王氏、蒙氏功为多，名施於後世。", "len": 28}
{"sid": "073_白起王翦列传.14.s1", "chapter": "073_白起王翦列传", "para": "14", "seq": 1, "text": "秦二世之时，王翦及其子贲皆已死，而又灭蒙氏。", "len": 22}
{"sid": "073_白起王翦列传.14.s2", "chapter": "073_白起王翦列传", "para": "14", "seq": 2, "text": "陈胜之反秦，秦使王翦之孙王离击赵，围赵王及张耳钜鹿城。", "len": 27}
{"sid": "073_白起王翦列传.14.s3", "chapter": "073_白起王翦列传", "para": "14", "seq": 3, "text": "或曰：“王离，秦之名将也。", "len": 13}
{"sid": "073_白起王翦列传.14.s4", "chapter": "073_白起王翦列传", "para": "14", "seq": 4, "text": "今将彊秦之兵，攻新造之赵，举之必矣。", "len": 18}
{"sid": "073_白起王翦列传.14.s5", "chapter": "073_白起王翦列传", "para": "14", "seq": 5, "text": "” 客曰：“不然。", "len": 9}
{"sid": "073_白起王翦列传.14.s6", "chapter": "073_白起王翦列传", "para": "14", "seq": 6, "text": "夫为将三世者必败。", "len": 9}
{"sid": "073_白起王翦列传.14.s7", "chapter": "073_白起王翦列传", "para": "14", "seq": 7, "text": "必败者何也？", "len": 6}
{"sid": "073_白起王翦列传.14.s8", "chapter": "073_白起王翦列传", "para": "14", "seq": 8, "text": "必其所杀伐多矣，其後受其不祥。", "len": 15}
{"sid": "073_白起王翦列传.14.s9", "chapter": "073_白起王翦列传", "para": "14", "seq": 9, "text": "今王离已三世将矣。", "len": 9}
{"sid": "073_白起王翦列传.14.s10", "chapter": "073_白起王翦列传", "para": "14", "seq": 10, "text": "” 居无何，项羽救赵，击秦军，果虏王离，王离军遂降诸侯。", "len": 28}
{"sid": "073_白起王翦列传.14.s11", "chapter": "073_白起王翦列传", "para": "14", "seq": 11, "text": "::: 太史公曰", "len": 8}
{"sid": "073_白起王翦列传.15.s1", "chapter": "073_白起王翦列传", "para": "15", "seq": 1, "text": "太史公曰：鄙语云“尺有所短，寸有所长”。", "len": 20}
{"sid": "073_白起王翦列传.15.s2", "chapter": "073_白起王翦列传", "para": "15", "seq": 2, "text": "白起料敌合变，出奇无穷，声震天下，然不能救患於应侯。", "len": 26}
{"sid": "073_白起王翦列传.15.s3", "chapter": "073_白起王翦列传", "para": "15", "seq": 3, "text": "王翦为秦将，夷六国，当是时，翦为宿将，始皇师之，然不能辅秦建德，固其根本，偷合取容，以至筊身。", "len": 47}
{"sid": "073_白起王翦列传.15.s4", "chapter": "073_白起王翦列传", "para": "15", "seq": 4, "text": "及孙王离为项羽所虏，不亦宜乎！", "len": 15}
{"sid": "073_白起王翦列传.15.s5", "chapter": "073_白起王翦列传", "para": "15", "seq": 5, "text": "彼各有所短也。", "len": 7}
{"sid": "073_白起王翦列传.15.s6", "chapter": "073_白起王翦列传", "para": "15", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "073_白起王翦列传.16.s1", "chapter": "073_白起王翦列传", "para": "16", "seq": 1, "text": "白起、王翦，俱善用兵。", "len": 11}
{"sid": "073_白起王翦列传.16.s2", "chapter": "073_白起王翦列传", "para": "16", "seq": 2, "text": "递为秦将，拔齐破荆。", "len": 10}
{"sid": "073_白起王翦列传.16.s3", "chapter": "073_白起王翦列传", "para": "16", "seq": 3, "text": "赵任马服，长平遂阬。", "len": 10}
{"sid": "073_白起王翦列传.16.s4", "chapter": "073_白起王翦列传", "para": "16", "seq": 4, "text": "楚陷李信，霸上卒行。", "len": 10}
{"sid": "073_白起王翦列传.16.s5", "chapter": "073_白起王翦列传", "para": "16", "seq": 5, "text": "贲、离继出，三代无名。", "len": 11}
{"sid": "073_白起王翦列传.16.s6", "chapter": "073_白起王翦列传", "para": "16", "seq": 6, "text": ":::", "len": 3}
