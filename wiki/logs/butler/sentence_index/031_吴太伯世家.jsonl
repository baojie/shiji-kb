{"sid": "031_吴太伯世家.1.1.s1", "chapter": "031_吴太伯世家", "para": "1.1", "seq": 1, "text": "吴太伯，太伯弟仲雍，皆周太王之子，而王季历之兄也。", "len": 25}
{"sid": "031_吴太伯世家.1.2.s1", "chapter": "031_吴太伯世家", "para": "1.2", "seq": 1, "text": "季历贤，而有圣子昌，太王欲立季历以及昌，於是太佰、仲雍二人乃奔荆蛮，文身断发，示不可用，以避季历。", "len": 49}
{"sid": "031_吴太伯世家.1.3.s1", "chapter": "031_吴太伯世家", "para": "1.3", "seq": 1, "text": "季历果立，是为王季，而昌为文王。", "len": 16}
{"sid": "031_吴太伯世家.1.4.s1", "chapter": "031_吴太伯世家", "para": "1.4", "seq": 1, "text": "太伯之奔荆蛮，自号句吴。", "len": 12}
{"sid": "031_吴太伯世家.1.4.s2", "chapter": "031_吴太伯世家", "para": "1.4", "seq": 2, "text": "荆蛮义之，从而归之千馀家，立为吴太伯。", "len": 19}
{"sid": "031_吴太伯世家.2.1.s1", "chapter": "031_吴太伯世家", "para": "2.1", "seq": 1, "text": "太伯卒，无子，弟仲雍立，是为吴仲雍。", "len": 18}
{"sid": "031_吴太伯世家.2.2.s1", "chapter": "031_吴太伯世家", "para": "2.2", "seq": 1, "text": "仲雍卒，子季简立。", "len": 9}
{"sid": "031_吴太伯世家.2.2.s2", "chapter": "031_吴太伯世家", "para": "2.2", "seq": 2, "text": "季简卒，子叔达立。", "len": 9}
{"sid": "031_吴太伯世家.2.2.s3", "chapter": "031_吴太伯世家", "para": "2.2", "seq": 3, "text": "叔达卒，子周章立。", "len": 9}
{"sid": "031_吴太伯世家.2.3.s1", "chapter": "031_吴太伯世家", "para": "2.3", "seq": 1, "text": "是时周武王克殷，求太伯、仲雍之後，得周章。", "len": 21}
{"sid": "031_吴太伯世家.2.3.s2", "chapter": "031_吴太伯世家", "para": "2.3", "seq": 2, "text": "周章已君吴，因而封之。", "len": 11}
{"sid": "031_吴太伯世家.2.4.s1", "chapter": "031_吴太伯世家", "para": "2.4", "seq": 1, "text": "乃封周章弟虞仲於周之北故夏虚，是为虞仲，列为诸侯。", "len": 25}
{"sid": "031_吴太伯世家.3.1.s1", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 1, "text": "周章卒，子熊遂立，熊遂卒，子柯相立。", "len": 18}
{"sid": "031_吴太伯世家.3.1.s2", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 2, "text": "柯相卒，子彊鸠夷立。", "len": 10}
{"sid": "031_吴太伯世家.3.1.s3", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 3, "text": "彊鸠夷卒，子馀桥疑吾立。", "len": 12}
{"sid": "031_吴太伯世家.3.1.s4", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 4, "text": "馀桥疑吾卒，子柯卢立。", "len": 11}
{"sid": "031_吴太伯世家.3.1.s5", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 5, "text": "柯卢卒，子周繇立。", "len": 9}
{"sid": "031_吴太伯世家.3.1.s6", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 6, "text": "周繇卒，子屈羽立。", "len": 9}
{"sid": "031_吴太伯世家.3.1.s7", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 7, "text": "屈羽卒，子夷吾立。", "len": 9}
{"sid": "031_吴太伯世家.3.1.s8", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 8, "text": "夷吾卒，子禽处立。", "len": 9}
{"sid": "031_吴太伯世家.3.1.s9", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 9, "text": "禽处卒，子转立。", "len": 8}
{"sid": "031_吴太伯世家.3.1.s10", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 10, "text": "转卒，子颇高立。", "len": 8}
{"sid": "031_吴太伯世家.3.1.s11", "chapter": "031_吴太伯世家", "para": "3.1", "seq": 11, "text": "颇高卒，子句卑立。", "len": 9}
{"sid": "031_吴太伯世家.3.2.s1", "chapter": "031_吴太伯世家", "para": "3.2", "seq": 1, "text": "是时晋献公灭周北虞公，以开晋伐虢也。", "len": 18}
{"sid": "031_吴太伯世家.3.3.s1", "chapter": "031_吴太伯世家", "para": "3.3", "seq": 1, "text": "句卑卒，子去齐立。", "len": 9}
{"sid": "031_吴太伯世家.3.3.s2", "chapter": "031_吴太伯世家", "para": "3.3", "seq": 2, "text": "去齐卒，子寿梦立。", "len": 9}
{"sid": "031_吴太伯世家.3.3.s3", "chapter": "031_吴太伯世家", "para": "3.3", "seq": 3, "text": "寿梦立而吴始益大，称王。", "len": 12}
{"sid": "031_吴太伯世家.4.1.s1", "chapter": "031_吴太伯世家", "para": "4.1", "seq": 1, "text": "自太伯作吴，五世而武王克殷，封其後为二：其一虞，在中国；其一吴，在夷蛮。", "len": 36}
{"sid": "031_吴太伯世家.4.2.s1", "chapter": "031_吴太伯世家", "para": "4.2", "seq": 1, "text": "十二世而晋灭中国之虞。", "len": 11}
{"sid": "031_吴太伯世家.4.2.s2", "chapter": "031_吴太伯世家", "para": "4.2", "seq": 2, "text": "中国之虞灭二世，而夷蛮之吴兴。", "len": 15}
{"sid": "031_吴太伯世家.4.3.s1", "chapter": "031_吴太伯世家", "para": "4.3", "seq": 1, "text": "大凡从太伯至寿梦十九世。", "len": 12}
{"sid": "031_吴太伯世家.5.1.s1", "chapter": "031_吴太伯世家", "para": "5.1", "seq": 1, "text": "王寿梦二年，楚之亡大夫申公巫臣怨楚将子反而奔晋，自晋使吴，教吴用兵乘车，令其子为吴行人，吴於是始通於中国。", "len": 53}
{"sid": "031_吴太伯世家.5.1.s2", "chapter": "031_吴太伯世家", "para": "5.1", "seq": 2, "text": "吴伐楚。", "len": 4}
{"sid": "031_吴太伯世家.5.2.s1", "chapter": "031_吴太伯世家", "para": "5.2", "seq": 1, "text": "十六年，楚共王伐吴，至衡山。", "len": 14}
{"sid": "031_吴太伯世家.6.1.s1", "chapter": "031_吴太伯世家", "para": "6.1", "seq": 1, "text": "二十五年，王寿梦卒。", "len": 10}
{"sid": "031_吴太伯世家.6.1.s2", "chapter": "031_吴太伯世家", "para": "6.1", "seq": 2, "text": "寿梦有子四人，长曰诸樊，次曰馀祭，次曰馀眛，次曰季札。", "len": 27}
{"sid": "031_吴太伯世家.6.2.s1", "chapter": "031_吴太伯世家", "para": "6.2", "seq": 1, "text": "季札贤，而寿梦欲立之，季札让不可，於是乃立长子诸樊，摄行事当国。", "len": 32}
{"sid": "031_吴太伯世家.7.1.s1", "chapter": "031_吴太伯世家", "para": "7.1", "seq": 1, "text": "王诸樊元年，诸樊已除丧，让位季札。", "len": 17}
{"sid": "031_吴太伯世家.7.2.s1", "chapter": "031_吴太伯世家", "para": "7.2", "seq": 1, "text": "季札谢曰： “曹宣公之卒也，诸侯与曹人不义曹君，将立子臧，子臧去之，以成曹君，君子曰‘能守节矣’。", "len": 49}
{"sid": "031_吴太伯世家.7.2.s2", "chapter": "031_吴太伯世家", "para": "7.2", "seq": 2, "text": "君义嗣，谁敢干君！", "len": 9}
{"sid": "031_吴太伯世家.7.2.s3", "chapter": "031_吴太伯世家", "para": "7.2", "seq": 3, "text": "有国，非吾节也。", "len": 8}
{"sid": "031_吴太伯世家.7.2.s4", "chapter": "031_吴太伯世家", "para": "7.2", "seq": 4, "text": "札虽不材，原附於子臧之义。”", "len": 14}
{"sid": "031_吴太伯世家.7.3.s1", "chapter": "031_吴太伯世家", "para": "7.3", "seq": 1, "text": "吴人固立季札，季札弃其室而耕，乃舍之。", "len": 19}
{"sid": "031_吴太伯世家.7.4.s1", "chapter": "031_吴太伯世家", "para": "7.4", "seq": 1, "text": "秋，吴伐楚，楚败我师。", "len": 11}
{"sid": "031_吴太伯世家.7.4.s2", "chapter": "031_吴太伯世家", "para": "7.4", "seq": 2, "text": "四年，晋平公初立。", "len": 9}
{"sid": "031_吴太伯世家.8.1.s1", "chapter": "031_吴太伯世家", "para": "8.1", "seq": 1, "text": "十三年，王诸樊卒。", "len": 9}
{"sid": "031_吴太伯世家.8.1.s2", "chapter": "031_吴太伯世家", "para": "8.1", "seq": 2, "text": "有命授弟馀祭，欲传以次，必致国於季札而止，以称先王寿梦之意，且嘉季札之义，兄弟皆欲致国，令以渐至焉。", "len": 50}
{"sid": "031_吴太伯世家.8.2.s1", "chapter": "031_吴太伯世家", "para": "8.2", "seq": 1, "text": "季札封於延陵，故号曰延陵季子。", "len": 15}
{"sid": "031_吴太伯世家.9.1.s1", "chapter": "031_吴太伯世家", "para": "9.1", "seq": 1, "text": "王馀祭三年，齐相庆封有罪，自齐来奔吴。", "len": 19}
{"sid": "031_吴太伯世家.9.1.s2", "chapter": "031_吴太伯世家", "para": "9.1", "seq": 2, "text": "吴予庆封硃方之县，以为奉邑，以女妻之，富於在齐。", "len": 24}
{"sid": "031_吴太伯世家.10.1.s1", "chapter": "031_吴太伯世家", "para": "10.1", "seq": 1, "text": "四年，吴使季札聘於鲁，请观周乐。", "len": 16}
{"sid": "031_吴太伯世家.10.2.s1", "chapter": "031_吴太伯世家", "para": "10.2", "seq": 1, "text": "为歌周南、召南。", "len": 8}
{"sid": "031_吴太伯世家.10.2.s2", "chapter": "031_吴太伯世家", "para": "10.2", "seq": 2, "text": "曰： “美哉，始基之矣，犹未也。", "len": 16}
{"sid": "031_吴太伯世家.10.2.s3", "chapter": "031_吴太伯世家", "para": "10.2", "seq": 3, "text": "然勤而不怨。”", "len": 7}
{"sid": "031_吴太伯世家.10.3.s1", "chapter": "031_吴太伯世家", "para": "10.3", "seq": 1, "text": "歌邶、鄘、卫。", "len": 7}
{"sid": "031_吴太伯世家.10.3.s2", "chapter": "031_吴太伯世家", "para": "10.3", "seq": 2, "text": "曰： “美哉，渊乎，忧而不困者也。", "len": 17}
{"sid": "031_吴太伯世家.10.3.s3", "chapter": "031_吴太伯世家", "para": "10.3", "seq": 3, "text": "吾闻卫康叔、武公之德如是，是其卫风乎？”", "len": 20}
{"sid": "031_吴太伯世家.10.4.s1", "chapter": "031_吴太伯世家", "para": "10.4", "seq": 1, "text": "歌王。", "len": 3}
{"sid": "031_吴太伯世家.10.4.s2", "chapter": "031_吴太伯世家", "para": "10.4", "seq": 2, "text": "曰： “美哉，思而不惧，其周之东乎？”", "len": 19}
{"sid": "031_吴太伯世家.10.5.s1", "chapter": "031_吴太伯世家", "para": "10.5", "seq": 1, "text": "歌郑。", "len": 3}
{"sid": "031_吴太伯世家.10.5.s2", "chapter": "031_吴太伯世家", "para": "10.5", "seq": 2, "text": "曰： “其细已甚，民不堪也，是其先亡乎？”", "len": 21}
{"sid": "031_吴太伯世家.10.6.s1", "chapter": "031_吴太伯世家", "para": "10.6", "seq": 1, "text": "歌齐。", "len": 3}
{"sid": "031_吴太伯世家.10.6.s2", "chapter": "031_吴太伯世家", "para": "10.6", "seq": 2, "text": "曰： “美哉，泱泱乎大风也哉。", "len": 15}
{"sid": "031_吴太伯世家.10.6.s3", "chapter": "031_吴太伯世家", "para": "10.6", "seq": 3, "text": "表东海者，其太公乎？", "len": 10}
{"sid": "031_吴太伯世家.10.6.s4", "chapter": "031_吴太伯世家", "para": "10.6", "seq": 4, "text": "国未可量也。”", "len": 7}
{"sid": "031_吴太伯世家.10.7.s1", "chapter": "031_吴太伯世家", "para": "10.7", "seq": 1, "text": "歌豳。", "len": 3}
{"sid": "031_吴太伯世家.10.7.s2", "chapter": "031_吴太伯世家", "para": "10.7", "seq": 2, "text": "曰： “美哉，荡荡乎，乐而不淫，其周公之东乎？”", "len": 24}
{"sid": "031_吴太伯世家.10.8.s1", "chapter": "031_吴太伯世家", "para": "10.8", "seq": 1, "text": "歌秦。", "len": 3}
{"sid": "031_吴太伯世家.10.8.s2", "chapter": "031_吴太伯世家", "para": "10.8", "seq": 2, "text": "曰： “此之谓夏声。", "len": 10}
{"sid": "031_吴太伯世家.10.8.s3", "chapter": "031_吴太伯世家", "para": "10.8", "seq": 3, "text": "夫能夏则大，大之至也，其周之旧乎？”", "len": 18}
{"sid": "031_吴太伯世家.10.9.s1", "chapter": "031_吴太伯世家", "para": "10.9", "seq": 1, "text": "歌魏。", "len": 3}
{"sid": "031_吴太伯世家.10.9.s2", "chapter": "031_吴太伯世家", "para": "10.9", "seq": 2, "text": "曰： “美哉，沨沨乎，大而，俭而易，行以德辅，此则盟主也。”", "len": 30}
{"sid": "031_吴太伯世家.10.10.s1", "chapter": "031_吴太伯世家", "para": "10.10", "seq": 1, "text": "歌唐。", "len": 3}
{"sid": "031_吴太伯世家.10.10.s2", "chapter": "031_吴太伯世家", "para": "10.10", "seq": 2, "text": "曰： “思深哉，其有陶唐氏之遗风乎？", "len": 18}
{"sid": "031_吴太伯世家.10.10.s3", "chapter": "031_吴太伯世家", "para": "10.10", "seq": 3, "text": "不然，何忧之远也？", "len": 9}
{"sid": "031_吴太伯世家.10.10.s4", "chapter": "031_吴太伯世家", "para": "10.10", "seq": 4, "text": "非令德之後，谁能若是！”", "len": 12}
{"sid": "031_吴太伯世家.10.11.s1", "chapter": "031_吴太伯世家", "para": "10.11", "seq": 1, "text": "歌陈。", "len": 3}
{"sid": "031_吴太伯世家.10.11.s2", "chapter": "031_吴太伯世家", "para": "10.11", "seq": 2, "text": "曰： “国无主，其能久乎？”", "len": 14}
{"sid": "031_吴太伯世家.10.12.s1", "chapter": "031_吴太伯世家", "para": "10.12", "seq": 1, "text": "自郐以下，无讥焉。", "len": 9}
{"sid": "031_吴太伯世家.10.13.s1", "chapter": "031_吴太伯世家", "para": "10.13", "seq": 1, "text": "歌小雅。", "len": 4}
{"sid": "031_吴太伯世家.10.13.s2", "chapter": "031_吴太伯世家", "para": "10.13", "seq": 2, "text": "曰： “美哉，思而不贰，怨而不言，其周德之衰乎？", "len": 24}
{"sid": "031_吴太伯世家.10.13.s3", "chapter": "031_吴太伯世家", "para": "10.13", "seq": 3, "text": "犹有先王之遗民也。”", "len": 10}
{"sid": "031_吴太伯世家.10.14.s1", "chapter": "031_吴太伯世家", "para": "10.14", "seq": 1, "text": "歌大雅。", "len": 4}
{"sid": "031_吴太伯世家.10.14.s2", "chapter": "031_吴太伯世家", "para": "10.14", "seq": 2, "text": "曰： “广哉，熙熙乎，曲而有直体，其文王之德乎？”", "len": 25}
{"sid": "031_吴太伯世家.10.15.s1", "chapter": "031_吴太伯世家", "para": "10.15", "seq": 1, "text": "歌颂。", "len": 3}
{"sid": "031_吴太伯世家.10.15.s2", "chapter": "031_吴太伯世家", "para": "10.15", "seq": 2, "text": "曰： “至矣哉，直而不倨，曲而不诎，近而不偪，远而不携，而迁不淫，复而不厌，哀而不愁，乐而不荒，用而不匮，广而不宣，施而不费，取而不贪，处而不厎，行而不流。", "len": 78}
{"sid": "031_吴太伯世家.10.15.s3", "chapter": "031_吴太伯世家", "para": "10.15", "seq": 3, "text": "五声和，八风平，节有度，守有序，盛德之所同也。”", "len": 24}
{"sid": "031_吴太伯世家.10.16.s1", "chapter": "031_吴太伯世家", "para": "10.16", "seq": 1, "text": "见舞象箾、南籥者，曰： “美哉，犹有感。”", "len": 21}
{"sid": "031_吴太伯世家.10.17.s1", "chapter": "031_吴太伯世家", "para": "10.17", "seq": 1, "text": "见舞大武，曰： “美哉，周之盛也其若此乎？”", "len": 22}
{"sid": "031_吴太伯世家.10.18.s1", "chapter": "031_吴太伯世家", "para": "10.18", "seq": 1, "text": "见舞韶护者，曰： “圣人之弘也，犹有惭德，圣人之难也！”", "len": 28}
{"sid": "031_吴太伯世家.10.19.s1", "chapter": "031_吴太伯世家", "para": "10.19", "seq": 1, "text": "见舞大夏，曰： “美哉，勤而不德！", "len": 17}
{"sid": "031_吴太伯世家.10.19.s2", "chapter": "031_吴太伯世家", "para": "10.19", "seq": 2, "text": "非禹其谁能及之？”", "len": 9}
{"sid": "031_吴太伯世家.10.20.s1", "chapter": "031_吴太伯世家", "para": "10.20", "seq": 1, "text": "见舞招箾，曰： “德至矣哉，大矣，如天之无不焘也，如地之无不载也，虽甚盛德，无以加矣。", "len": 43}
{"sid": "031_吴太伯世家.10.20.s2", "chapter": "031_吴太伯世家", "para": "10.20", "seq": 2, "text": "观止矣，若有他乐，吾不敢观。”", "len": 15}
{"sid": "031_吴太伯世家.11.1.s1", "chapter": "031_吴太伯世家", "para": "11.1", "seq": 1, "text": "去鲁，遂使齐。", "len": 7}
{"sid": "031_吴太伯世家.11.1.s2", "chapter": "031_吴太伯世家", "para": "11.1", "seq": 2, "text": "说晏平仲曰： “子速纳邑与政。", "len": 15}
{"sid": "031_吴太伯世家.11.1.s3", "chapter": "031_吴太伯世家", "para": "11.1", "seq": 3, "text": "无邑无政，乃免於难。", "len": 10}
{"sid": "031_吴太伯世家.11.1.s4", "chapter": "031_吴太伯世家", "para": "11.1", "seq": 4, "text": "齐国之政将有所归；未得所归，难未息也。”", "len": 20}
{"sid": "031_吴太伯世家.11.2.s1", "chapter": "031_吴太伯世家", "para": "11.2", "seq": 1, "text": "故晏子因陈桓子以纳政与邑，是以免於栾高之难。", "len": 22}
{"sid": "031_吴太伯世家.12.1.s1", "chapter": "031_吴太伯世家", "para": "12.1", "seq": 1, "text": "去齐，使於郑。", "len": 7}
{"sid": "031_吴太伯世家.12.1.s2", "chapter": "031_吴太伯世家", "para": "12.1", "seq": 2, "text": "见子产，如旧交。", "len": 8}
{"sid": "031_吴太伯世家.12.1.s3", "chapter": "031_吴太伯世家", "para": "12.1", "seq": 3, "text": "谓子产曰： “郑之执政侈，难将至矣，政必及子。", "len": 23}
{"sid": "031_吴太伯世家.12.1.s4", "chapter": "031_吴太伯世家", "para": "12.1", "seq": 4, "text": "子为政，慎以礼。", "len": 8}
{"sid": "031_吴太伯世家.12.1.s5", "chapter": "031_吴太伯世家", "para": "12.1", "seq": 5, "text": "不然，郑国将败。”", "len": 9}
{"sid": "031_吴太伯世家.12.2.s1", "chapter": "031_吴太伯世家", "para": "12.2", "seq": 1, "text": "去郑，適卫。", "len": 6}
{"sid": "031_吴太伯世家.12.2.s2", "chapter": "031_吴太伯世家", "para": "12.2", "seq": 2, "text": "说蘧瑗、史狗、史、公子荆、公叔发、公子朝曰： “卫多君子，未有患也。”", "len": 35}
{"sid": "031_吴太伯世家.13.1.s1", "chapter": "031_吴太伯世家", "para": "13.1", "seq": 1, "text": "自卫如晋，将舍於宿，闻锺声，曰： “异哉！", "len": 21}
{"sid": "031_吴太伯世家.13.1.s2", "chapter": "031_吴太伯世家", "para": "13.1", "seq": 2, "text": "吾闻之，辩而不德，必加於戮。", "len": 14}
{"sid": "031_吴太伯世家.13.1.s3", "chapter": "031_吴太伯世家", "para": "13.1", "seq": 3, "text": "夫子获罪於君以在此，惧犹不足，而又可以畔乎？", "len": 22}
{"sid": "031_吴太伯世家.13.1.s4", "chapter": "031_吴太伯世家", "para": "13.1", "seq": 4, "text": "夫子之在此，犹燕之巢于幕也。", "len": 14}
{"sid": "031_吴太伯世家.13.1.s5", "chapter": "031_吴太伯世家", "para": "13.1", "seq": 5, "text": "君在殡而可以乐乎？”", "len": 10}
{"sid": "031_吴太伯世家.13.2.s1", "chapter": "031_吴太伯世家", "para": "13.2", "seq": 1, "text": "遂去之。", "len": 4}
{"sid": "031_吴太伯世家.13.2.s2", "chapter": "031_吴太伯世家", "para": "13.2", "seq": 2, "text": "文子闻之，终身不听琴瑟。", "len": 12}
{"sid": "031_吴太伯世家.14.1.s1", "chapter": "031_吴太伯世家", "para": "14.1", "seq": 1, "text": "適晋，说赵文子、韩宣子、魏献子曰： “晋国其萃於三家乎！”", "len": 29}
{"sid": "031_吴太伯世家.14.2.s1", "chapter": "031_吴太伯世家", "para": "14.2", "seq": 1, "text": "将去，谓叔向曰： “吾子勉之！", "len": 15}
{"sid": "031_吴太伯世家.14.2.s2", "chapter": "031_吴太伯世家", "para": "14.2", "seq": 2, "text": "君侈而多良，大夫皆富，政将在三家。", "len": 17}
{"sid": "031_吴太伯世家.14.2.s3", "chapter": "031_吴太伯世家", "para": "14.2", "seq": 3, "text": "吾子直，必思自免於难。”", "len": 12}
{"sid": "031_吴太伯世家.15.1.s1", "chapter": "031_吴太伯世家", "para": "15.1", "seq": 1, "text": "季札之初使，北过徐君。", "len": 11}
{"sid": "031_吴太伯世家.15.1.s2", "chapter": "031_吴太伯世家", "para": "15.1", "seq": 2, "text": "徐君好季札剑，口弗敢言。", "len": 12}
{"sid": "031_吴太伯世家.15.1.s3", "chapter": "031_吴太伯世家", "para": "15.1", "seq": 3, "text": "季札心知之，为使上国，未献。", "len": 14}
{"sid": "031_吴太伯世家.15.2.s1", "chapter": "031_吴太伯世家", "para": "15.2", "seq": 1, "text": "还至徐，徐君已死，於是乃解其宝剑，系之徐君冢树而去。", "len": 26}
{"sid": "031_吴太伯世家.15.3.s1", "chapter": "031_吴太伯世家", "para": "15.3", "seq": 1, "text": "从者曰： “徐君已死，尚谁予乎？”", "len": 17}
{"sid": "031_吴太伯世家.15.4.s1", "chapter": "031_吴太伯世家", "para": "15.4", "seq": 1, "text": "季子曰： “不然。", "len": 9}
{"sid": "031_吴太伯世家.15.4.s2", "chapter": "031_吴太伯世家", "para": "15.4", "seq": 2, "text": "始吾心已许之，岂以死倍吾心哉！”", "len": 16}
{"sid": "031_吴太伯世家.16.1.s1", "chapter": "031_吴太伯世家", "para": "16.1", "seq": 1, "text": "七年，楚公子围弑其王夹敖而代立，是为灵王。", "len": 21}
{"sid": "031_吴太伯世家.16.2.s1", "chapter": "031_吴太伯世家", "para": "16.2", "seq": 1, "text": "十年，楚灵王会诸侯而以伐吴之硃方，以诛齐庆封。", "len": 23}
{"sid": "031_吴太伯世家.16.2.s2", "chapter": "031_吴太伯世家", "para": "16.2", "seq": 2, "text": "吴亦攻楚，取三邑而去。", "len": 11}
{"sid": "031_吴太伯世家.16.3.s1", "chapter": "031_吴太伯世家", "para": "16.3", "seq": 1, "text": "十一年，楚伐吴，至雩娄。", "len": 12}
{"sid": "031_吴太伯世家.16.3.s2", "chapter": "031_吴太伯世家", "para": "16.3", "seq": 2, "text": "十二年，楚复来伐，次於乾谿，楚师败走。", "len": 19}
{"sid": "031_吴太伯世家.17.1.s1", "chapter": "031_吴太伯世家", "para": "17.1", "seq": 1, "text": "十七年，王馀祭卒，弟馀眛立。", "len": 14}
{"sid": "031_吴太伯世家.17.2.s1", "chapter": "031_吴太伯世家", "para": "17.2", "seq": 1, "text": "王馀眛二年，楚公子弃疾弑其君灵王代立焉。", "len": 20}
{"sid": "031_吴太伯世家.18.1.s1", "chapter": "031_吴太伯世家", "para": "18.1", "seq": 1, "text": "四年，王馀眛卒，欲授弟季札。", "len": 14}
{"sid": "031_吴太伯世家.18.1.s2", "chapter": "031_吴太伯世家", "para": "18.1", "seq": 2, "text": "季札让，逃去。", "len": 7}
{"sid": "031_吴太伯世家.18.2.s1", "chapter": "031_吴太伯世家", "para": "18.2", "seq": 1, "text": "於是吴人曰： “先王有命，兄卒弟代立，必致季子。", "len": 24}
{"sid": "031_吴太伯世家.18.2.s2", "chapter": "031_吴太伯世家", "para": "18.2", "seq": 2, "text": "季子今逃位，则王馀眛後立。", "len": 13}
{"sid": "031_吴太伯世家.18.2.s3", "chapter": "031_吴太伯世家", "para": "18.2", "seq": 3, "text": "今卒，其子当代。”", "len": 9}
{"sid": "031_吴太伯世家.18.3.s1", "chapter": "031_吴太伯世家", "para": "18.3", "seq": 1, "text": "乃立王馀眛之子僚为王。", "len": 11}
{"sid": "031_吴太伯世家.19.1.s1", "chapter": "031_吴太伯世家", "para": "19.1", "seq": 1, "text": "王僚二年，公子光伐楚，败而亡王舟。", "len": 17}
{"sid": "031_吴太伯世家.19.1.s2", "chapter": "031_吴太伯世家", "para": "19.1", "seq": 2, "text": "光惧，袭楚，复得王舟而还。", "len": 13}
{"sid": "031_吴太伯世家.20.1.s1", "chapter": "031_吴太伯世家", "para": "20.1", "seq": 1, "text": "五年，楚之亡臣伍子胥来奔，公子光客之。", "len": 19}
{"sid": "031_吴太伯世家.20.2.s1", "chapter": "031_吴太伯世家", "para": "20.2", "seq": 1, "text": "公子光者，王诸樊之子也。", "len": 12}
{"sid": "031_吴太伯世家.20.2.s2", "chapter": "031_吴太伯世家", "para": "20.2", "seq": 2, "text": "常以为吾父兄弟四人，当传至季子。", "len": 16}
{"sid": "031_吴太伯世家.20.2.s3", "chapter": "031_吴太伯世家", "para": "20.2", "seq": 3, "text": "季子即不受国，光父先立。", "len": 12}
{"sid": "031_吴太伯世家.20.2.s4", "chapter": "031_吴太伯世家", "para": "20.2", "seq": 4, "text": "即不传季子，光当立。", "len": 10}
{"sid": "031_吴太伯世家.20.2.s5", "chapter": "031_吴太伯世家", "para": "20.2", "seq": 5, "text": "阴纳贤士，欲以袭王僚。", "len": 11}
{"sid": "031_吴太伯世家.21.1.s1", "chapter": "031_吴太伯世家", "para": "21.1", "seq": 1, "text": "八年，吴使公子光伐楚，败楚师，迎楚故太子建母於居巢以归。", "len": 28}
{"sid": "031_吴太伯世家.21.1.s2", "chapter": "031_吴太伯世家", "para": "21.1", "seq": 2, "text": "因北伐，败陈、蔡之师。", "len": 11}
{"sid": "031_吴太伯世家.21.2.s1", "chapter": "031_吴太伯世家", "para": "21.2", "seq": 1, "text": "九年，公子光伐楚，拔居巢、锺离。", "len": 16}
{"sid": "031_吴太伯世家.21.3.s1", "chapter": "031_吴太伯世家", "para": "21.3", "seq": 1, "text": "初，楚边邑卑梁氏之处女与吴边邑之女争桑，二女家怒相灭，两国边邑长闻之，怒而相攻，灭吴之边邑。", "len": 46}
{"sid": "031_吴太伯世家.21.3.s2", "chapter": "031_吴太伯世家", "para": "21.3", "seq": 2, "text": "吴王怒，故遂伐楚，取两都而去。", "len": 15}
{"sid": "031_吴太伯世家.22.1.s1", "chapter": "031_吴太伯世家", "para": "22.1", "seq": 1, "text": "伍子胥之初奔吴，说吴王僚以伐楚之利。", "len": 18}
{"sid": "031_吴太伯世家.22.2.s1", "chapter": "031_吴太伯世家", "para": "22.2", "seq": 1, "text": "公子光曰： “胥之父兄为僇於楚，欲自报其仇耳。", "len": 23}
{"sid": "031_吴太伯世家.22.2.s2", "chapter": "031_吴太伯世家", "para": "22.2", "seq": 2, "text": "未见其利。”", "len": 6}
{"sid": "031_吴太伯世家.22.3.s1", "chapter": "031_吴太伯世家", "para": "22.3", "seq": 1, "text": "於是伍员知光有他志，乃求勇士专诸，见之光。", "len": 21}
{"sid": "031_吴太伯世家.22.3.s2", "chapter": "031_吴太伯世家", "para": "22.3", "seq": 2, "text": "光喜，乃客伍子胥。", "len": 9}
{"sid": "031_吴太伯世家.22.3.s3", "chapter": "031_吴太伯世家", "para": "22.3", "seq": 3, "text": "子胥退而耕於野，以待专诸之事。", "len": 15}
{"sid": "031_吴太伯世家.23.1.s1", "chapter": "031_吴太伯世家", "para": "23.1", "seq": 1, "text": "十二年冬，楚平王卒。", "len": 10}
{"sid": "031_吴太伯世家.23.2.s1", "chapter": "031_吴太伯世家", "para": "23.2", "seq": 1, "text": "十三年春，吴欲因楚丧而伐之，使公子盖馀、烛庸以兵围楚之六、灊。", "len": 31}
{"sid": "031_吴太伯世家.23.2.s2", "chapter": "031_吴太伯世家", "para": "23.2", "seq": 2, "text": "使季札於晋，以观诸侯之变。", "len": 13}
{"sid": "031_吴太伯世家.23.2.s3", "chapter": "031_吴太伯世家", "para": "23.2", "seq": 3, "text": "楚发兵绝吴兵後，吴兵不得还。", "len": 14}
{"sid": "031_吴太伯世家.23.3.s1", "chapter": "031_吴太伯世家", "para": "23.3", "seq": 1, "text": "於是吴公子光曰： “此时不可失也。”", "len": 18}
{"sid": "031_吴太伯世家.23.4.s1", "chapter": "031_吴太伯世家", "para": "23.4", "seq": 1, "text": "告专诸曰： “不索何获！", "len": 12}
{"sid": "031_吴太伯世家.23.4.s2", "chapter": "031_吴太伯世家", "para": "23.4", "seq": 2, "text": "我真王嗣，当立，吾欲求之。", "len": 13}
{"sid": "031_吴太伯世家.23.4.s3", "chapter": "031_吴太伯世家", "para": "23.4", "seq": 3, "text": "季子虽至，不吾废也。”", "len": 11}
{"sid": "031_吴太伯世家.23.5.s1", "chapter": "031_吴太伯世家", "para": "23.5", "seq": 1, "text": "专诸曰： “王僚可杀也。", "len": 12}
{"sid": "031_吴太伯世家.23.5.s2", "chapter": "031_吴太伯世家", "para": "23.5", "seq": 2, "text": "母老子弱，而两公子将兵攻楚，楚绝其路。", "len": 19}
{"sid": "031_吴太伯世家.23.5.s3", "chapter": "031_吴太伯世家", "para": "23.5", "seq": 3, "text": "方今吴外困於楚，而内空无骨鲠之臣，是无柰我何。”", "len": 24}
{"sid": "031_吴太伯世家.23.6.s1", "chapter": "031_吴太伯世家", "para": "23.6", "seq": 1, "text": "光曰： “我身，子之身也。”", "len": 14}
{"sid": "031_吴太伯世家.23.7.s1", "chapter": "031_吴太伯世家", "para": "23.7", "seq": 1, "text": "四月丙子，光伏甲士於窟室，而谒王僚饮。", "len": 19}
{"sid": "031_吴太伯世家.23.7.s2", "chapter": "031_吴太伯世家", "para": "23.7", "seq": 2, "text": "王僚使兵陈於道，自王宫至光之家，门阶户席，皆王僚之亲也，人夹持铍。", "len": 33}
{"sid": "031_吴太伯世家.23.8.s1", "chapter": "031_吴太伯世家", "para": "23.8", "seq": 1, "text": "公子光详为足疾，入于窟室，使专诸置匕首於炙鱼之中以进食。", "len": 28}
{"sid": "031_吴太伯世家.23.8.s2", "chapter": "031_吴太伯世家", "para": "23.8", "seq": 2, "text": "手匕首刺王僚，铍交於匈，遂弑王僚。", "len": 17}
{"sid": "031_吴太伯世家.23.9.s1", "chapter": "031_吴太伯世家", "para": "23.9", "seq": 1, "text": "公子光竟代立为王，是为吴王阖庐。", "len": 16}
{"sid": "031_吴太伯世家.23.9.s2", "chapter": "031_吴太伯世家", "para": "23.9", "seq": 2, "text": "阖庐乃以专诸子为卿。", "len": 10}
{"sid": "031_吴太伯世家.24.1.s1", "chapter": "031_吴太伯世家", "para": "24.1", "seq": 1, "text": "季子至，曰： “苟先君无废祀，民人无废主，社稷有奉，乃吾君也。", "len": 31}
{"sid": "031_吴太伯世家.24.1.s2", "chapter": "031_吴太伯世家", "para": "24.1", "seq": 2, "text": "吾敢谁怨乎？", "len": 6}
{"sid": "031_吴太伯世家.24.1.s3", "chapter": "031_吴太伯世家", "para": "24.1", "seq": 3, "text": "哀死事生，以待天命。", "len": 10}
{"sid": "031_吴太伯世家.24.1.s4", "chapter": "031_吴太伯世家", "para": "24.1", "seq": 4, "text": "非我生乱，立者从之，先人之道也。”", "len": 17}
{"sid": "031_吴太伯世家.24.2.s1", "chapter": "031_吴太伯世家", "para": "24.2", "seq": 1, "text": "复命，哭僚墓，复位而待。", "len": 12}
{"sid": "031_吴太伯世家.24.3.s1", "chapter": "031_吴太伯世家", "para": "24.3", "seq": 1, "text": "吴公子烛庸、盖馀二人将兵遇围於楚者，闻公子光弑王僚自立，乃以其兵降楚，楚封之於舒。", "len": 41}
{"sid": "031_吴太伯世家.25.1.s1", "chapter": "031_吴太伯世家", "para": "25.1", "seq": 1, "text": "王阖庐元年，举伍子胥为行人而与谋国事。", "len": 19}
{"sid": "031_吴太伯世家.25.1.s2", "chapter": "031_吴太伯世家", "para": "25.1", "seq": 2, "text": "楚诛伯州犁，其孙伯嚭亡奔吴，吴以为大夫。", "len": 20}
{"sid": "031_吴太伯世家.26.1.s1", "chapter": "031_吴太伯世家", "para": "26.1", "seq": 1, "text": "三年，吴王阖庐与子胥、伯嚭将兵伐楚，拔舒，杀吴亡将二公子。", "len": 29}
{"sid": "031_吴太伯世家.26.1.s2", "chapter": "031_吴太伯世家", "para": "26.1", "seq": 2, "text": "光谋欲入郢，将军孙武曰： “民劳，未可，待之。”", "len": 24}
{"sid": "031_吴太伯世家.26.2.s1", "chapter": "031_吴太伯世家", "para": "26.2", "seq": 1, "text": "四年，伐楚，取六与灊。", "len": 11}
{"sid": "031_吴太伯世家.26.3.s1", "chapter": "031_吴太伯世家", "para": "26.3", "seq": 1, "text": "五年，伐越，败之。", "len": 9}
{"sid": "031_吴太伯世家.26.4.s1", "chapter": "031_吴太伯世家", "para": "26.4", "seq": 1, "text": "六年，楚使子常囊瓦伐吴。", "len": 12}
{"sid": "031_吴太伯世家.26.4.s2", "chapter": "031_吴太伯世家", "para": "26.4", "seq": 2, "text": "迎而击之，大败楚军於豫章，取楚之居巢而还。", "len": 21}
{"sid": "031_吴太伯世家.27.1.s1", "chapter": "031_吴太伯世家", "para": "27.1", "seq": 1, "text": "九年，吴王阖庐请伍子胥、孙武曰： “始子之言郢未可入，今果如何？”", "len": 33}
{"sid": "031_吴太伯世家.27.2.s1", "chapter": "031_吴太伯世家", "para": "27.2", "seq": 1, "text": "二子对曰： “楚将子常贪，而唐、蔡皆怨之。", "len": 21}
{"sid": "031_吴太伯世家.27.2.s2", "chapter": "031_吴太伯世家", "para": "27.2", "seq": 2, "text": "王必欲大伐，必得唐、蔡乃可。”", "len": 15}
{"sid": "031_吴太伯世家.27.3.s1", "chapter": "031_吴太伯世家", "para": "27.3", "seq": 1, "text": "阖庐从之，悉兴师，与唐、蔡西伐楚，至於汉水。", "len": 22}
{"sid": "031_吴太伯世家.27.3.s2", "chapter": "031_吴太伯世家", "para": "27.3", "seq": 2, "text": "楚亦发兵拒吴，夹水陈。", "len": 11}
{"sid": "031_吴太伯世家.27.4.s1", "chapter": "031_吴太伯世家", "para": "27.4", "seq": 1, "text": "吴王阖庐弟夫欲战，阖庐弗许。", "len": 14}
{"sid": "031_吴太伯世家.27.4.s2", "chapter": "031_吴太伯世家", "para": "27.4", "seq": 2, "text": "夫曰： “王已属臣兵，兵以利为上，尚何待焉？”", "len": 23}
{"sid": "031_吴太伯世家.27.5.s1", "chapter": "031_吴太伯世家", "para": "27.5", "seq": 1, "text": "遂以其部五千人袭冒楚，楚兵大败，走。", "len": 18}
{"sid": "031_吴太伯世家.27.6.s1", "chapter": "031_吴太伯世家", "para": "27.6", "seq": 1, "text": "於是吴王遂纵兵追之。", "len": 10}
{"sid": "031_吴太伯世家.27.6.s2", "chapter": "031_吴太伯世家", "para": "27.6", "seq": 2, "text": "比至郢，五战，楚五败。", "len": 11}
{"sid": "031_吴太伯世家.27.6.s3", "chapter": "031_吴太伯世家", "para": "27.6", "seq": 3, "text": "楚昭王亡出郢，奔郧。", "len": 10}
{"sid": "031_吴太伯世家.27.6.s4", "chapter": "031_吴太伯世家", "para": "27.6", "seq": 4, "text": "郧公弟欲弑昭王，昭王与郧公奔随。", "len": 16}
{"sid": "031_吴太伯世家.27.7.s1", "chapter": "031_吴太伯世家", "para": "27.7", "seq": 1, "text": "而吴兵遂入郢。", "len": 7}
{"sid": "031_吴太伯世家.27.7.s2", "chapter": "031_吴太伯世家", "para": "27.7", "seq": 2, "text": "子胥、伯嚭鞭平王之尸以报父雠。", "len": 15}
{"sid": "031_吴太伯世家.28.1.s1", "chapter": "031_吴太伯世家", "para": "28.1", "seq": 1, "text": "十年春，越闻吴王之在郢，国空，乃伐吴。", "len": 19}
{"sid": "031_吴太伯世家.28.1.s2", "chapter": "031_吴太伯世家", "para": "28.1", "seq": 2, "text": "吴使别兵击越。", "len": 7}
{"sid": "031_吴太伯世家.28.2.s1", "chapter": "031_吴太伯世家", "para": "28.2", "seq": 1, "text": "楚告急秦，秦遣兵救楚击吴，吴师败。", "len": 17}
{"sid": "031_吴太伯世家.28.3.s1", "chapter": "031_吴太伯世家", "para": "28.3", "seq": 1, "text": "阖庐弟夫见秦越交败吴，吴王留楚不去，夫亡归吴而自立为吴王。", "len": 29}
{"sid": "031_吴太伯世家.28.3.s2", "chapter": "031_吴太伯世家", "para": "28.3", "seq": 2, "text": "阖庐闻之，乃引兵归，攻夫。", "len": 13}
{"sid": "031_吴太伯世家.28.3.s3", "chapter": "031_吴太伯世家", "para": "28.3", "seq": 3, "text": "夫败奔楚。", "len": 5}
{"sid": "031_吴太伯世家.28.4.s1", "chapter": "031_吴太伯世家", "para": "28.4", "seq": 1, "text": "楚昭王乃得以九月复入郢，而封夫於堂谿，为堂谿氏。", "len": 24}
{"sid": "031_吴太伯世家.28.5.s1", "chapter": "031_吴太伯世家", "para": "28.5", "seq": 1, "text": "十一年，吴王使太子夫差伐楚，取番。", "len": 17}
{"sid": "031_吴太伯世家.28.5.s2", "chapter": "031_吴太伯世家", "para": "28.5", "seq": 2, "text": "楚恐而去郢徙鄀。", "len": 8}
{"sid": "031_吴太伯世家.29.1.s1", "chapter": "031_吴太伯世家", "para": "29.1", "seq": 1, "text": "十五年，孔子相鲁。", "len": 9}
{"sid": "031_吴太伯世家.30.1.s1", "chapter": "031_吴太伯世家", "para": "30.1", "seq": 1, "text": "十九年夏，吴伐越，越王句践迎击之槜李。", "len": 19}
{"sid": "031_吴太伯世家.30.1.s2", "chapter": "031_吴太伯世家", "para": "30.1", "seq": 2, "text": "越使死士挑战，三行造吴师，呼，自刭。", "len": 18}
{"sid": "031_吴太伯世家.30.1.s3", "chapter": "031_吴太伯世家", "para": "30.1", "seq": 3, "text": "吴师观之，越因伐吴，败之姑苏，伤吴王阖庐指，军卻七里。", "len": 27}
{"sid": "031_吴太伯世家.30.2.s1", "chapter": "031_吴太伯世家", "para": "30.2", "seq": 1, "text": "吴王病伤而死。", "len": 7}
{"sid": "031_吴太伯世家.30.2.s2", "chapter": "031_吴太伯世家", "para": "30.2", "seq": 2, "text": "阖庐使立太子夫差，谓曰： “尔而忘句践杀汝父乎？”", "len": 25}
{"sid": "031_吴太伯世家.30.3.s1", "chapter": "031_吴太伯世家", "para": "30.3", "seq": 1, "text": "对曰： “不敢！”", "len": 9}
{"sid": "031_吴太伯世家.30.4.s1", "chapter": "031_吴太伯世家", "para": "30.4", "seq": 1, "text": "三年，乃报越。", "len": 7}
{"sid": "031_吴太伯世家.31.1.s1", "chapter": "031_吴太伯世家", "para": "31.1", "seq": 1, "text": "王夫差元年，以大夫伯嚭为太宰。", "len": 15}
{"sid": "031_吴太伯世家.31.1.s2", "chapter": "031_吴太伯世家", "para": "31.1", "seq": 2, "text": "习战射，常以报越为志。", "len": 11}
{"sid": "031_吴太伯世家.31.2.s1", "chapter": "031_吴太伯世家", "para": "31.2", "seq": 1, "text": "二年，吴王悉精兵以伐越，败之夫椒，报姑苏也。", "len": 22}
{"sid": "031_吴太伯世家.31.3.s1", "chapter": "031_吴太伯世家", "para": "31.3", "seq": 1, "text": "越王句践乃以甲兵五千人栖於会稽，使大夫种因吴太宰嚭而行成，请委国为臣妾。", "len": 36}
{"sid": "031_吴太伯世家.32.1.s1", "chapter": "031_吴太伯世家", "para": "32.1", "seq": 1, "text": "吴王将许之，伍子胥谏曰： “昔有过氏杀斟灌以伐斟寻，灭夏后帝相。", "len": 32}
{"sid": "031_吴太伯世家.32.1.s2", "chapter": "031_吴太伯世家", "para": "32.1", "seq": 2, "text": "帝相之妃后缗方娠，逃於有仍而生少康。", "len": 18}
{"sid": "031_吴太伯世家.32.1.s3", "chapter": "031_吴太伯世家", "para": "32.1", "seq": 3, "text": "少康为有仍牧正。", "len": 8}
{"sid": "031_吴太伯世家.32.1.s4", "chapter": "031_吴太伯世家", "para": "32.1", "seq": 4, "text": "有过又欲杀少康，少康奔有虞。", "len": 14}
{"sid": "031_吴太伯世家.32.1.s5", "chapter": "031_吴太伯世家", "para": "32.1", "seq": 5, "text": "有虞思夏德，於是妻之以二女而邑之於纶，有田一成，有众一旅。", "len": 29}
{"sid": "031_吴太伯世家.32.1.s6", "chapter": "031_吴太伯世家", "para": "32.1", "seq": 6, "text": "後遂收夏众，抚其官职。", "len": 11}
{"sid": "031_吴太伯世家.32.1.s7", "chapter": "031_吴太伯世家", "para": "32.1", "seq": 7, "text": "使人诱之，遂灭有过氏，复禹之绩，祀夏配天，不失旧物。", "len": 26}
{"sid": "031_吴太伯世家.32.1.s8", "chapter": "031_吴太伯世家", "para": "32.1", "seq": 8, "text": "今吴不如有过之彊，而句践大於少康。", "len": 17}
{"sid": "031_吴太伯世家.32.1.s9", "chapter": "031_吴太伯世家", "para": "32.1", "seq": 9, "text": "今不因此而灭之，又将之，不亦难乎！", "len": 17}
{"sid": "031_吴太伯世家.32.1.s10", "chapter": "031_吴太伯世家", "para": "32.1", "seq": 10, "text": "且句践为人能辛苦，今不灭，後必悔之。”", "len": 19}
{"sid": "031_吴太伯世家.32.2.s1", "chapter": "031_吴太伯世家", "para": "32.2", "seq": 1, "text": "吴王不听，听太宰嚭，卒许越平，与盟而罢兵去。", "len": 22}
{"sid": "031_吴太伯世家.33.1.s1", "chapter": "031_吴太伯世家", "para": "33.1", "seq": 1, "text": "七年，吴王夫差闻齐景公死而大臣争宠，新君弱，乃兴师北伐齐。", "len": 29}
{"sid": "031_吴太伯世家.33.2.s1", "chapter": "031_吴太伯世家", "para": "33.2", "seq": 1, "text": "子胥谏曰： “越王句践食不重味，衣不重采，吊死问疾，且欲有所用其众。", "len": 34}
{"sid": "031_吴太伯世家.33.2.s2", "chapter": "031_吴太伯世家", "para": "33.2", "seq": 2, "text": "此人不死，必为吴患。", "len": 10}
{"sid": "031_吴太伯世家.33.2.s3", "chapter": "031_吴太伯世家", "para": "33.2", "seq": 3, "text": "今越在腹心疾而王不先，而务齐，不亦谬乎！”", "len": 21}
{"sid": "031_吴太伯世家.33.3.s1", "chapter": "031_吴太伯世家", "para": "33.3", "seq": 1, "text": "吴王不听，遂北伐齐，败齐师於艾陵。", "len": 17}
{"sid": "031_吴太伯世家.33.3.s2", "chapter": "031_吴太伯世家", "para": "33.3", "seq": 2, "text": "至缯，召鲁哀公而徵百牢。", "len": 12}
{"sid": "031_吴太伯世家.33.3.s3", "chapter": "031_吴太伯世家", "para": "33.3", "seq": 3, "text": "季康子使子贡以周礼说太宰嚭，乃得止。", "len": 18}
{"sid": "031_吴太伯世家.33.3.s4", "chapter": "031_吴太伯世家", "para": "33.3", "seq": 4, "text": "因留略地於齐鲁之南。", "len": 10}
{"sid": "031_吴太伯世家.33.4.s1", "chapter": "031_吴太伯世家", "para": "33.4", "seq": 1, "text": "九年，为驺伐鲁，至与鲁盟乃去。", "len": 15}
{"sid": "031_吴太伯世家.33.5.s1", "chapter": "031_吴太伯世家", "para": "33.5", "seq": 1, "text": "十年，因伐齐而归。", "len": 9}
{"sid": "031_吴太伯世家.33.6.s1", "chapter": "031_吴太伯世家", "para": "33.6", "seq": 1, "text": "十一年，复北伐齐。", "len": 9}
{"sid": "031_吴太伯世家.34.1.s1", "chapter": "031_吴太伯世家", "para": "34.1", "seq": 1, "text": "越王句践率其众以朝吴，厚献遗之，吴王喜。", "len": 20}
{"sid": "031_吴太伯世家.34.2.s1", "chapter": "031_吴太伯世家", "para": "34.2", "seq": 1, "text": "唯子胥惧，曰： “是弃吴也。”", "len": 15}
{"sid": "031_吴太伯世家.34.3.s1", "chapter": "031_吴太伯世家", "para": "34.3", "seq": 1, "text": "谏曰： “越在腹心，今得志於齐，犹石田，无所用。", "len": 24}
{"sid": "031_吴太伯世家.34.3.s2", "chapter": "031_吴太伯世家", "para": "34.3", "seq": 2, "text": "且盘庚之诰有颠越勿遗，商之以兴。”", "len": 17}
{"sid": "031_吴太伯世家.34.4.s1", "chapter": "031_吴太伯世家", "para": "34.4", "seq": 1, "text": "吴王不听，使子胥於齐，子胥属其子於齐鲍氏，还报吴王。", "len": 26}
{"sid": "031_吴太伯世家.34.4.s2", "chapter": "031_吴太伯世家", "para": "34.4", "seq": 2, "text": "吴王闻之，大怒，赐子胥属镂之剑以死。", "len": 18}
{"sid": "031_吴太伯世家.34.5.s1", "chapter": "031_吴太伯世家", "para": "34.5", "seq": 1, "text": "将死，曰： “树吾墓上以梓，令可为器。", "len": 19}
{"sid": "031_吴太伯世家.34.5.s2", "chapter": "031_吴太伯世家", "para": "34.5", "seq": 2, "text": "抉吾眼置之吴东门，以观越之灭吴也。”", "len": 18}
{"sid": "031_吴太伯世家.35.1.s1", "chapter": "031_吴太伯世家", "para": "35.1", "seq": 1, "text": "齐鲍氏弑齐悼公。", "len": 8}
{"sid": "031_吴太伯世家.35.1.s2", "chapter": "031_吴太伯世家", "para": "35.1", "seq": 2, "text": "吴王闻之，哭於军门外三日，乃从海上攻齐。", "len": 20}
{"sid": "031_吴太伯世家.35.1.s3", "chapter": "031_吴太伯世家", "para": "35.1", "seq": 3, "text": "齐人败吴，吴王乃引兵归。", "len": 12}
{"sid": "031_吴太伯世家.36.1.s1", "chapter": "031_吴太伯世家", "para": "36.1", "seq": 1, "text": "十三年，吴召鲁、卫之君会於橐皋。", "len": 16}
{"sid": "031_吴太伯世家.37.1.s1", "chapter": "031_吴太伯世家", "para": "37.1", "seq": 1, "text": "十四年春，吴王北会诸侯於黄池，欲霸中国以全周室。", "len": 24}
{"sid": "031_吴太伯世家.37.2.s1", "chapter": "031_吴太伯世家", "para": "37.2", "seq": 1, "text": "六月子，越王句践伐吴。", "len": 11}
{"sid": "031_吴太伯世家.37.2.s2", "chapter": "031_吴太伯世家", "para": "37.2", "seq": 2, "text": "乙酉，越五千人与吴战。", "len": 11}
{"sid": "031_吴太伯世家.37.2.s3", "chapter": "031_吴太伯世家", "para": "37.2", "seq": 3, "text": "丙戌，虏吴太子友。", "len": 9}
{"sid": "031_吴太伯世家.37.2.s4", "chapter": "031_吴太伯世家", "para": "37.2", "seq": 4, "text": "丁亥，入吴。", "len": 6}
{"sid": "031_吴太伯世家.37.3.s1", "chapter": "031_吴太伯世家", "para": "37.3", "seq": 1, "text": "吴人告败於王夫差，夫差恶其闻也。", "len": 16}
{"sid": "031_吴太伯世家.37.3.s2", "chapter": "031_吴太伯世家", "para": "37.3", "seq": 2, "text": "或泄其语，吴王怒，斩七人於幕下。", "len": 16}
{"sid": "031_吴太伯世家.37.4.s1", "chapter": "031_吴太伯世家", "para": "37.4", "seq": 1, "text": "七月辛丑，吴王与晋定公争长。", "len": 14}
{"sid": "031_吴太伯世家.37.4.s2", "chapter": "031_吴太伯世家", "para": "37.4", "seq": 2, "text": "吴王曰： “於周室我为长。”", "len": 14}
{"sid": "031_吴太伯世家.37.5.s1", "chapter": "031_吴太伯世家", "para": "37.5", "seq": 1, "text": "晋定公曰： “於姬姓我为伯。”", "len": 15}
{"sid": "031_吴太伯世家.37.6.s1", "chapter": "031_吴太伯世家", "para": "37.6", "seq": 1, "text": "赵鞅怒，将伐吴，乃长晋定公。", "len": 14}
{"sid": "031_吴太伯世家.37.7.s1", "chapter": "031_吴太伯世家", "para": "37.7", "seq": 1, "text": "吴王已盟，与晋别，欲伐宋。", "len": 13}
{"sid": "031_吴太伯世家.37.7.s2", "chapter": "031_吴太伯世家", "para": "37.7", "seq": 2, "text": "太宰嚭曰： “可胜而不能居也。”", "len": 16}
{"sid": "031_吴太伯世家.37.8.s1", "chapter": "031_吴太伯世家", "para": "37.8", "seq": 1, "text": "乃引兵归国。", "len": 6}
{"sid": "031_吴太伯世家.37.8.s2", "chapter": "031_吴太伯世家", "para": "37.8", "seq": 2, "text": "国亡太子，内空，王居外久，士皆罢敝，於是乃使厚币以与越平。", "len": 29}
{"sid": "031_吴太伯世家.38.1.s1", "chapter": "031_吴太伯世家", "para": "38.1", "seq": 1, "text": "十五年，齐田常杀简公。", "len": 11}
{"sid": "031_吴太伯世家.39.1.s1", "chapter": "031_吴太伯世家", "para": "39.1", "seq": 1, "text": "十八年，越益彊。", "len": 8}
{"sid": "031_吴太伯世家.39.1.s2", "chapter": "031_吴太伯世家", "para": "39.1", "seq": 2, "text": "越王句践率兵伐败吴师於笠泽。", "len": 14}
{"sid": "031_吴太伯世家.39.1.s3", "chapter": "031_吴太伯世家", "para": "39.1", "seq": 3, "text": "楚灭陈。", "len": 4}
{"sid": "031_吴太伯世家.40.1.s1", "chapter": "031_吴太伯世家", "para": "40.1", "seq": 1, "text": "二十年，越王句践复伐吴。", "len": 12}
{"sid": "031_吴太伯世家.40.2.s1", "chapter": "031_吴太伯世家", "para": "40.2", "seq": 1, "text": "二十一年，遂围吴。", "len": 9}
{"sid": "031_吴太伯世家.40.3.s1", "chapter": "031_吴太伯世家", "para": "40.3", "seq": 1, "text": "二十三年十一月丁卯，越败吴。", "len": 14}
{"sid": "031_吴太伯世家.41.1.s1", "chapter": "031_吴太伯世家", "para": "41.1", "seq": 1, "text": "越王句践欲迁吴王夫差於甬东，予百家居之。", "len": 20}
{"sid": "031_吴太伯世家.41.2.s1", "chapter": "031_吴太伯世家", "para": "41.2", "seq": 1, "text": "吴王曰： “孤老矣，不能事君王也。", "len": 17}
{"sid": "031_吴太伯世家.41.2.s2", "chapter": "031_吴太伯世家", "para": "41.2", "seq": 2, "text": "吾悔不用子胥之言，自令陷此。”", "len": 15}
{"sid": "031_吴太伯世家.41.3.s1", "chapter": "031_吴太伯世家", "para": "41.3", "seq": 1, "text": "遂自刭死。", "len": 5}
{"sid": "031_吴太伯世家.41.4.s1", "chapter": "031_吴太伯世家", "para": "41.4", "seq": 1, "text": "越王灭吴，诛太宰嚭，以为不忠，而归。", "len": 18}
{"sid": "031_吴太伯世家.41.4.s2", "chapter": "031_吴太伯世家", "para": "41.4", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "031_吴太伯世家.42.1.s1", "chapter": "031_吴太伯世家", "para": "42.1", "seq": 1, "text": "太史公曰：孔子言“太伯可谓至德矣，三以天下让，民无得而称焉”。", "len": 31}
{"sid": "031_吴太伯世家.42.1.s2", "chapter": "031_吴太伯世家", "para": "42.1", "seq": 2, "text": "余读春秋古文，乃知中国之虞与荆蛮句吴兄弟也。", "len": 22}
{"sid": "031_吴太伯世家.42.1.s3", "chapter": "031_吴太伯世家", "para": "42.1", "seq": 3, "text": "延陵季子之仁心，慕义无穷，见微而知清浊|见微知著。", "len": 25}
{"sid": "031_吴太伯世家.42.1.s4", "chapter": "031_吴太伯世家", "para": "42.1", "seq": 4, "text": "呜呼，又何其闳览博物君子也！", "len": 14}
{"sid": "031_吴太伯世家.42.1.s5", "chapter": "031_吴太伯世家", "para": "42.1", "seq": 5, "text": "::: ::: 赞", "len": 9}
{"sid": "031_吴太伯世家.42.2.s1", "chapter": "031_吴太伯世家", "para": "42.2", "seq": 1, "text": "太伯作吴，高让雄图。", "len": 10}
{"sid": "031_吴太伯世家.42.2.s2", "chapter": "031_吴太伯世家", "para": "42.2", "seq": 2, "text": "周章受国，别封於虞。", "len": 10}
{"sid": "031_吴太伯世家.42.2.s3", "chapter": "031_吴太伯世家", "para": "42.2", "seq": 3, "text": "寿梦初霸，始用兵车。", "len": 10}
{"sid": "031_吴太伯世家.42.2.s4", "chapter": "031_吴太伯世家", "para": "42.2", "seq": 4, "text": "三子递立，延陵不居。", "len": 10}
{"sid": "031_吴太伯世家.42.2.s5", "chapter": "031_吴太伯世家", "para": "42.2", "seq": 5, "text": "光既篡位，是称阖闾。", "len": 10}
{"sid": "031_吴太伯世家.42.2.s6", "chapter": "031_吴太伯世家", "para": "42.2", "seq": 6, "text": "王僚见杀，贼由专诸。", "len": 10}
{"sid": "031_吴太伯世家.42.2.s7", "chapter": "031_吴太伯世家", "para": "42.2", "seq": 7, "text": "夫差轻越，取败姑苏。", "len": 10}
{"sid": "031_吴太伯世家.42.2.s8", "chapter": "031_吴太伯世家", "para": "42.2", "seq": 8, "text": "甬东之耻，空惭伍胥。", "len": 10}
{"sid": "031_吴太伯世家.42.2.s9", "chapter": "031_吴太伯世家", "para": "42.2", "seq": 9, "text": ":::", "len": 3}
