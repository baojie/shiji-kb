{"sid": "003_殷本纪.1.s1", "chapter": "003_殷本纪", "para": "1", "seq": 1, "text": "殷契，母曰简狄，有娀氏之女，为帝喾次妃。", "len": 20}
{"sid": "003_殷本纪.1.s2", "chapter": "003_殷本纪", "para": "1", "seq": 2, "text": "三人行浴，见玄鸟堕其卵，简狄取吞之，因孕生契。", "len": 23}
{"sid": "003_殷本纪.1.s3", "chapter": "003_殷本纪", "para": "1", "seq": 3, "text": "契长而佐禹治水有功。", "len": 10}
{"sid": "003_殷本纪.1.s4", "chapter": "003_殷本纪", "para": "1", "seq": 4, "text": "帝舜乃命契曰：“百姓不亲，五品不训，汝为司徒而敬敷五教，五教在宽。", "len": 33}
{"sid": "003_殷本纪.1.s5", "chapter": "003_殷本纪", "para": "1", "seq": 5, "text": "” 封于商，赐姓子氏。", "len": 11}
{"sid": "003_殷本纪.1.s6", "chapter": "003_殷本纪", "para": "1", "seq": 6, "text": "契兴於唐、虞、大禹之际，功业著於百姓，百姓以平。", "len": 24}
{"sid": "003_殷本纪.2.s1", "chapter": "003_殷本纪", "para": "2", "seq": 1, "text": "契卒，子昭明立。", "len": 8}
{"sid": "003_殷本纪.2.s2", "chapter": "003_殷本纪", "para": "2", "seq": 2, "text": "昭明卒，子相土立。", "len": 9}
{"sid": "003_殷本纪.2.s3", "chapter": "003_殷本纪", "para": "2", "seq": 3, "text": "相土卒，子昌若立。", "len": 9}
{"sid": "003_殷本纪.2.s4", "chapter": "003_殷本纪", "para": "2", "seq": 4, "text": "昌若卒，子曹圉立。", "len": 9}
{"sid": "003_殷本纪.2.s5", "chapter": "003_殷本纪", "para": "2", "seq": 5, "text": "曹圉卒，子冥立。", "len": 8}
{"sid": "003_殷本纪.2.s6", "chapter": "003_殷本纪", "para": "2", "seq": 6, "text": "冥卒，子振立。", "len": 7}
{"sid": "003_殷本纪.2.s7", "chapter": "003_殷本纪", "para": "2", "seq": 7, "text": "振卒，子微立。", "len": 7}
{"sid": "003_殷本纪.2.s8", "chapter": "003_殷本纪", "para": "2", "seq": 8, "text": "微卒，子报丁立。", "len": 8}
{"sid": "003_殷本纪.2.s9", "chapter": "003_殷本纪", "para": "2", "seq": 9, "text": "报丁卒，子报乙立。", "len": 9}
{"sid": "003_殷本纪.2.s10", "chapter": "003_殷本纪", "para": "2", "seq": 10, "text": "报乙卒，子报丙立。", "len": 9}
{"sid": "003_殷本纪.2.s11", "chapter": "003_殷本纪", "para": "2", "seq": 11, "text": "报丙卒，子主壬立。", "len": 9}
{"sid": "003_殷本纪.2.s12", "chapter": "003_殷本纪", "para": "2", "seq": 12, "text": "主壬卒，子主癸立。", "len": 9}
{"sid": "003_殷本纪.2.s13", "chapter": "003_殷本纪", "para": "2", "seq": 13, "text": "主癸卒，子天乙立，是为成汤。", "len": 14}
{"sid": "003_殷本纪.3.s1", "chapter": "003_殷本纪", "para": "3", "seq": 1, "text": "成汤，自契至汤八迁。", "len": 10}
{"sid": "003_殷本纪.3.s2", "chapter": "003_殷本纪", "para": "3", "seq": 2, "text": "汤始居亳，从先王居，作帝诰。", "len": 14}
{"sid": "003_殷本纪.4.s1", "chapter": "003_殷本纪", "para": "4", "seq": 1, "text": "汤征诸侯。", "len": 5}
{"sid": "003_殷本纪.4.s2", "chapter": "003_殷本纪", "para": "4", "seq": 2, "text": "葛伯不祀，汤始伐之。", "len": 10}
{"sid": "003_殷本纪.4.s3", "chapter": "003_殷本纪", "para": "4", "seq": 3, "text": "汤曰：“予有言：人视水见形，视民知治不。", "len": 20}
{"sid": "003_殷本纪.4.s4", "chapter": "003_殷本纪", "para": "4", "seq": 4, "text": "” 伊尹曰：“明哉！", "len": 10}
{"sid": "003_殷本纪.4.s5", "chapter": "003_殷本纪", "para": "4", "seq": 5, "text": "言能听，道乃进。", "len": 8}
{"sid": "003_殷本纪.4.s6", "chapter": "003_殷本纪", "para": "4", "seq": 6, "text": "君国子民，为善者皆在王官。", "len": 13}
{"sid": "003_殷本纪.4.s7", "chapter": "003_殷本纪", "para": "4", "seq": 7, "text": "勉哉，勉哉！", "len": 6}
{"sid": "003_殷本纪.4.s8", "chapter": "003_殷本纪", "para": "4", "seq": 8, "text": "” 汤曰：“汝不能敬命，予大罚殛之，无有攸赦。”", "len": 24}
{"sid": "003_殷本纪.4.1.s1", "chapter": "003_殷本纪", "para": "4.1", "seq": 1, "text": "作汤征。", "len": 4}
{"sid": "003_殷本纪.5.s1", "chapter": "003_殷本纪", "para": "5", "seq": 1, "text": "伊尹名阿衡。", "len": 6}
{"sid": "003_殷本纪.5.s2", "chapter": "003_殷本纪", "para": "5", "seq": 2, "text": "阿衡欲奸汤而无由，乃为有莘氏媵臣，负鼎俎，以滋味说汤，致于王道。", "len": 32}
{"sid": "003_殷本纪.5.s3", "chapter": "003_殷本纪", "para": "5", "seq": 3, "text": "或曰，伊尹处士，汤使人聘迎之，五反然後肯往从汤，言素王及九主之事。", "len": 33}
{"sid": "003_殷本纪.5.s4", "chapter": "003_殷本纪", "para": "5", "seq": 4, "text": "汤举任以国政。", "len": 7}
{"sid": "003_殷本纪.5.s5", "chapter": "003_殷本纪", "para": "5", "seq": 5, "text": "伊尹去汤適夏。", "len": 7}
{"sid": "003_殷本纪.5.s6", "chapter": "003_殷本纪", "para": "5", "seq": 6, "text": "既丑有夏，复归于亳。", "len": 10}
{"sid": "003_殷本纪.5.s7", "chapter": "003_殷本纪", "para": "5", "seq": 7, "text": "入自北门，遇女鸠、女房，作女鸠女房。", "len": 18}
{"sid": "003_殷本纪.6.s1", "chapter": "003_殷本纪", "para": "6", "seq": 1, "text": "汤出，见野张网四面，祝曰：“自天下四方皆入吾网。”", "len": 25}
{"sid": "003_殷本纪.6.1.s1", "chapter": "003_殷本纪", "para": "6.1", "seq": 1, "text": "汤曰：“嘻，尽之矣！", "len": 10}
{"sid": "003_殷本纪.6.1.s2", "chapter": "003_殷本纪", "para": "6.1", "seq": 2, "text": "” 乃去其三面，祝曰：“欲左，左。", "len": 17}
{"sid": "003_殷本纪.6.1.s3", "chapter": "003_殷本纪", "para": "6.1", "seq": 3, "text": "欲右，右。", "len": 5}
{"sid": "003_殷本纪.6.1.s4", "chapter": "003_殷本纪", "para": "6.1", "seq": 4, "text": "不用命，乃入吾网。”", "len": 10}
{"sid": "003_殷本纪.6.2.s1", "chapter": "003_殷本纪", "para": "6.2", "seq": 1, "text": "诸侯闻之，曰：“汤德至矣，及禽兽。", "len": 17}
{"sid": "003_殷本纪.6.2.s2", "chapter": "003_殷本纪", "para": "6.2", "seq": 2, "text": "” 当是时，夏桀为虐政淫荒，而诸侯昆吾氏为乱。", "len": 23}
{"sid": "003_殷本纪.6.2.s3", "chapter": "003_殷本纪", "para": "6.2", "seq": 3, "text": "汤乃兴师率诸侯，伊尹从汤，汤自把钺以伐昆吾，遂伐桀。", "len": 26}
{"sid": "003_殷本纪.6.2.s4", "chapter": "003_殷本纪", "para": "6.2", "seq": 4, "text": "[6.2.1] 汤曰：“格女众庶，来，女悉听朕言。", "len": 25}
{"sid": "003_殷本纪.6.2.s5", "chapter": "003_殷本纪", "para": "6.2", "seq": 5, "text": "匪台小子敢行举乱，有夏多罪，予维闻女众言，夏氏有罪。", "len": 26}
{"sid": "003_殷本纪.6.2.s6", "chapter": "003_殷本纪", "para": "6.2", "seq": 6, "text": "予畏上帝，不敢不正。", "len": 10}
{"sid": "003_殷本纪.6.2.s7", "chapter": "003_殷本纪", "para": "6.2", "seq": 7, "text": "今夏多罪，天命殛之。", "len": 10}
{"sid": "003_殷本纪.6.2.s8", "chapter": "003_殷本纪", "para": "6.2", "seq": 8, "text": "今女有众，女曰’我君不恤我众，舍我啬事而割政’。", "len": 24}
{"sid": "003_殷本纪.6.2.s9", "chapter": "003_殷本纪", "para": "6.2", "seq": 9, "text": "女其曰‘有罪，其柰何’？", "len": 12}
{"sid": "003_殷本纪.6.2.s10", "chapter": "003_殷本纪", "para": "6.2", "seq": 10, "text": "夏王率止众力，率夺夏国。", "len": 12}
{"sid": "003_殷本纪.6.2.s11", "chapter": "003_殷本纪", "para": "6.2", "seq": 11, "text": "有众率怠不和，曰‘是日何时丧？", "len": 15}
{"sid": "003_殷本纪.6.2.s12", "chapter": "003_殷本纪", "para": "6.2", "seq": 12, "text": "予与女皆亡’！", "len": 7}
{"sid": "003_殷本纪.6.2.s13", "chapter": "003_殷本纪", "para": "6.2", "seq": 13, "text": "夏德若兹，今朕必往。", "len": 10}
{"sid": "003_殷本纪.6.2.s14", "chapter": "003_殷本纪", "para": "6.2", "seq": 14, "text": "尔尚及予一人致天之罚，予其大理女。", "len": 17}
{"sid": "003_殷本纪.6.2.s15", "chapter": "003_殷本纪", "para": "6.2", "seq": 15, "text": "女毋不信，朕不食言。", "len": 10}
{"sid": "003_殷本纪.6.2.s16", "chapter": "003_殷本纪", "para": "6.2", "seq": 16, "text": "女不从誓言，予则帑僇女，无有攸赦。”", "len": 18}
{"sid": "003_殷本纪.6.3.s1", "chapter": "003_殷本纪", "para": "6.3", "seq": 1, "text": "以告令师，作汤誓。", "len": 9}
{"sid": "003_殷本纪.6.3.s2", "chapter": "003_殷本纪", "para": "6.3", "seq": 2, "text": "於是汤曰“吾甚武”，号曰武王。", "len": 15}
{"sid": "003_殷本纪.7.s1", "chapter": "003_殷本纪", "para": "7", "seq": 1, "text": "桀败於有娀之虚，桀奔於鸣条，夏师败绩。", "len": 19}
{"sid": "003_殷本纪.7.s2", "chapter": "003_殷本纪", "para": "7", "seq": 2, "text": "汤遂伐三飐，俘厥宝玉，义伯、仲伯作典宝。", "len": 20}
{"sid": "003_殷本纪.7.s3", "chapter": "003_殷本纪", "para": "7", "seq": 3, "text": "汤既胜夏，欲迁其社，不可，作夏社。", "len": 17}
{"sid": "003_殷本纪.7.s4", "chapter": "003_殷本纪", "para": "7", "seq": 4, "text": "伊尹报。", "len": 4}
{"sid": "003_殷本纪.7.s5", "chapter": "003_殷本纪", "para": "7", "seq": 5, "text": "於是诸侯毕服，汤乃践天子位，平定海内。", "len": 19}
{"sid": "003_殷本纪.8.s1", "chapter": "003_殷本纪", "para": "8", "seq": 1, "text": "汤归至于泰卷陶，中纻作诰。", "len": 13}
{"sid": "003_殷本纪.8.s2", "chapter": "003_殷本纪", "para": "8", "seq": 2, "text": "既绌夏命，还亳，作汤诰： [8.1] “维三月，王自至於东郊。", "len": 31}
{"sid": "003_殷本纪.8.s3", "chapter": "003_殷本纪", "para": "8", "seq": 3, "text": "告诸侯群后：’毋不有功於民，勤力乃事。", "len": 19}
{"sid": "003_殷本纪.8.s4", "chapter": "003_殷本纪", "para": "8", "seq": 4, "text": "予乃大罚殛女，毋予怨。", "len": 11}
{"sid": "003_殷本纪.8.s5", "chapter": "003_殷本纪", "para": "8", "seq": 5, "text": "’ [8.2] 曰：’古禹、皋陶久劳于外，其有功乎民，民乃有安。", "len": 32}
{"sid": "003_殷本纪.8.s6", "chapter": "003_殷本纪", "para": "8", "seq": 6, "text": "东为江，北为济，西为河，南为淮，四渎已修，万民乃有居。", "len": 27}
{"sid": "003_殷本纪.8.s7", "chapter": "003_殷本纪", "para": "8", "seq": 7, "text": "后稷降播，农殖百穀。", "len": 10}
{"sid": "003_殷本纪.8.s8", "chapter": "003_殷本纪", "para": "8", "seq": 8, "text": "三公咸有功于民，故后有立。", "len": 13}
{"sid": "003_殷本纪.8.s9", "chapter": "003_殷本纪", "para": "8", "seq": 9, "text": "昔蚩尤与其大夫作乱百姓，帝乃弗予，有状。", "len": 20}
{"sid": "003_殷本纪.8.s10", "chapter": "003_殷本纪", "para": "8", "seq": 10, "text": "先王言不可不勉。", "len": 8}
{"sid": "003_殷本纪.8.s11", "chapter": "003_殷本纪", "para": "8", "seq": 11, "text": "’ [8.3] 曰：’不道，毋之在国，女毋我怨。’”", "len": 26}
{"sid": "003_殷本纪.8.4.s1", "chapter": "003_殷本纪", "para": "8.4", "seq": 1, "text": "以令诸侯。", "len": 5}
{"sid": "003_殷本纪.8.4.s2", "chapter": "003_殷本纪", "para": "8.4", "seq": 2, "text": "伊尹作咸有一德，咎单作明居。", "len": 14}
{"sid": "003_殷本纪.9.s1", "chapter": "003_殷本纪", "para": "9", "seq": 1, "text": "汤乃改正朔，易服色，上白，朝会以昼。", "len": 18}
{"sid": "003_殷本纪.10.s1", "chapter": "003_殷本纪", "para": "10", "seq": 1, "text": "汤崩，太子太丁未立而卒，於是乃立太丁之弟外丙，是为帝外丙。", "len": 29}
{"sid": "003_殷本纪.10.s2", "chapter": "003_殷本纪", "para": "10", "seq": 2, "text": "帝外丙即位三年，崩，立外丙之弟中壬，是为帝中壬。", "len": 24}
{"sid": "003_殷本纪.10.s3", "chapter": "003_殷本纪", "para": "10", "seq": 3, "text": "帝中壬即位四年，崩，伊尹乃立太丁之子太甲。", "len": 21}
{"sid": "003_殷本纪.10.s4", "chapter": "003_殷本纪", "para": "10", "seq": 4, "text": "太甲，成汤適长孙也，是为帝太甲。", "len": 16}
{"sid": "003_殷本纪.10.s5", "chapter": "003_殷本纪", "para": "10", "seq": 5, "text": "帝太甲元年，伊尹作伊训，作肆命，作徂后。", "len": 20}
{"sid": "003_殷本纪.11.s1", "chapter": "003_殷本纪", "para": "11", "seq": 1, "text": "帝太甲既立三年，不明，暴虐，不遵汤法，乱德，於是伊尹放之於桐宫。", "len": 32}
{"sid": "003_殷本纪.11.s2", "chapter": "003_殷本纪", "para": "11", "seq": 2, "text": "三年，伊尹摄行政当国，以朝诸侯。", "len": 16}
{"sid": "003_殷本纪.12.s1", "chapter": "003_殷本纪", "para": "12", "seq": 1, "text": "帝太甲居桐宫三年，悔过自责，反善，於是伊尹乃迎帝太甲而授之政。", "len": 31}
{"sid": "003_殷本纪.12.s2", "chapter": "003_殷本纪", "para": "12", "seq": 2, "text": "帝太甲修德，诸侯咸归殷，百姓以宁。", "len": 17}
{"sid": "003_殷本纪.12.s3", "chapter": "003_殷本纪", "para": "12", "seq": 3, "text": "伊尹嘉之，乃作太甲训三篇，襃帝太甲，称太宗。", "len": 22}
{"sid": "003_殷本纪.13.s1", "chapter": "003_殷本纪", "para": "13", "seq": 1, "text": "太宗崩，子沃丁立。", "len": 9}
{"sid": "003_殷本纪.13.s2", "chapter": "003_殷本纪", "para": "13", "seq": 2, "text": "帝沃丁之时，伊尹卒。", "len": 10}
{"sid": "003_殷本纪.13.s3", "chapter": "003_殷本纪", "para": "13", "seq": 3, "text": "既葬伊尹於亳，咎单遂训伊尹事，作沃丁。", "len": 19}
{"sid": "003_殷本纪.14.s1", "chapter": "003_殷本纪", "para": "14", "seq": 1, "text": "沃丁崩，弟太庚立，是为帝太庚。", "len": 15}
{"sid": "003_殷本纪.14.s2", "chapter": "003_殷本纪", "para": "14", "seq": 2, "text": "帝太庚崩，子帝小甲立。", "len": 11}
{"sid": "003_殷本纪.14.s3", "chapter": "003_殷本纪", "para": "14", "seq": 3, "text": "帝小甲崩，弟雍己立，是为帝雍己。", "len": 16}
{"sid": "003_殷本纪.14.s4", "chapter": "003_殷本纪", "para": "14", "seq": 4, "text": "殷道衰，诸侯或不至。", "len": 10}
{"sid": "003_殷本纪.15.s1", "chapter": "003_殷本纪", "para": "15", "seq": 1, "text": "帝雍己崩，弟太戊立，是为帝太戊。", "len": 16}
{"sid": "003_殷本纪.15.s2", "chapter": "003_殷本纪", "para": "15", "seq": 2, "text": "帝太戊立伊陟为相。", "len": 9}
{"sid": "003_殷本纪.15.s3", "chapter": "003_殷本纪", "para": "15", "seq": 3, "text": "亳有祥桑穀共生於朝，一暮大拱。", "len": 15}
{"sid": "003_殷本纪.15.s4", "chapter": "003_殷本纪", "para": "15", "seq": 4, "text": "帝太戊惧，问伊陟。", "len": 9}
{"sid": "003_殷本纪.15.s5", "chapter": "003_殷本纪", "para": "15", "seq": 5, "text": "[15.1] 伊陟曰：“臣闻妖不胜德，帝之政其有阙与？", "len": 27}
{"sid": "003_殷本纪.15.s6", "chapter": "003_殷本纪", "para": "15", "seq": 6, "text": "帝其修德。”", "len": 6}
{"sid": "003_殷本纪.15.2.s1", "chapter": "003_殷本纪", "para": "15.2", "seq": 1, "text": "太戊从之，而祥桑枯死而去。", "len": 13}
{"sid": "003_殷本纪.15.2.s2", "chapter": "003_殷本纪", "para": "15.2", "seq": 2, "text": "伊陟赞言于巫咸。", "len": 8}
{"sid": "003_殷本纪.15.2.s3", "chapter": "003_殷本纪", "para": "15.2", "seq": 3, "text": "巫咸治王家有成，作咸艾，作太戊。", "len": 16}
{"sid": "003_殷本纪.15.2.s4", "chapter": "003_殷本纪", "para": "15.2", "seq": 4, "text": "帝太戊赞伊陟于庙，言弗臣，伊陟让，作原命。", "len": 21}
{"sid": "003_殷本纪.15.2.s5", "chapter": "003_殷本纪", "para": "15.2", "seq": 5, "text": "殷复兴，诸侯归之，故称中宗。", "len": 14}
{"sid": "003_殷本纪.16.s1", "chapter": "003_殷本纪", "para": "16", "seq": 1, "text": "中宗崩，子帝中丁立。", "len": 10}
{"sid": "003_殷本纪.16.s2", "chapter": "003_殷本纪", "para": "16", "seq": 2, "text": "帝中丁迁于隞。", "len": 7}
{"sid": "003_殷本纪.16.s3", "chapter": "003_殷本纪", "para": "16", "seq": 3, "text": "河亶甲居相。", "len": 6}
{"sid": "003_殷本纪.16.s4", "chapter": "003_殷本纪", "para": "16", "seq": 4, "text": "祖乙迁于邢。", "len": 6}
{"sid": "003_殷本纪.16.s5", "chapter": "003_殷本纪", "para": "16", "seq": 5, "text": "帝中丁崩，弟外壬立，是为帝外壬。", "len": 16}
{"sid": "003_殷本纪.16.s6", "chapter": "003_殷本纪", "para": "16", "seq": 6, "text": "仲丁书阙不具。", "len": 7}
{"sid": "003_殷本纪.16.s7", "chapter": "003_殷本纪", "para": "16", "seq": 7, "text": "帝外壬崩，弟河亶甲立，是为帝河亶甲。", "len": 18}
{"sid": "003_殷本纪.16.s8", "chapter": "003_殷本纪", "para": "16", "seq": 8, "text": "河亶甲时，殷复衰。", "len": 9}
{"sid": "003_殷本纪.17.s1", "chapter": "003_殷本纪", "para": "17", "seq": 1, "text": "河亶甲崩，子帝祖乙立。", "len": 11}
{"sid": "003_殷本纪.17.s2", "chapter": "003_殷本纪", "para": "17", "seq": 2, "text": "帝祖乙立，殷复兴。", "len": 9}
{"sid": "003_殷本纪.17.s3", "chapter": "003_殷本纪", "para": "17", "seq": 3, "text": "巫贤任职。", "len": 5}
{"sid": "003_殷本纪.18.s1", "chapter": "003_殷本纪", "para": "18", "seq": 1, "text": "祖乙崩，子帝祖辛立。", "len": 10}
{"sid": "003_殷本纪.18.s2", "chapter": "003_殷本纪", "para": "18", "seq": 2, "text": "帝祖辛崩，弟沃甲立，是为帝沃甲。", "len": 16}
{"sid": "003_殷本纪.18.s3", "chapter": "003_殷本纪", "para": "18", "seq": 3, "text": "帝沃甲崩，立沃甲兄祖辛之子祖丁，是为帝祖丁。", "len": 22}
{"sid": "003_殷本纪.18.s4", "chapter": "003_殷本纪", "para": "18", "seq": 4, "text": "帝祖丁崩，立弟沃甲之子南庚，是为帝南庚。", "len": 20}
{"sid": "003_殷本纪.18.s5", "chapter": "003_殷本纪", "para": "18", "seq": 5, "text": "帝南庚崩，立帝祖丁之子阳甲，是为帝阳甲。", "len": 20}
{"sid": "003_殷本纪.18.s6", "chapter": "003_殷本纪", "para": "18", "seq": 6, "text": "帝阳甲之时，殷衰。", "len": 9}
{"sid": "003_殷本纪.19.s1", "chapter": "003_殷本纪", "para": "19", "seq": 1, "text": "自中丁以来，废適而更立诸弟子，弟子或争相代立，比九世乱，於是诸侯莫朝。", "len": 35}
{"sid": "003_殷本纪.20.s1", "chapter": "003_殷本纪", "para": "20", "seq": 1, "text": "帝阳甲崩，弟盘庚立，是为帝盘庚。", "len": 16}
{"sid": "003_殷本纪.20.s2", "chapter": "003_殷本纪", "para": "20", "seq": 2, "text": "帝盘庚之时，殷已都河北，盘庚渡河南，复居成汤之故居，乃五迁，无定处。", "len": 34}
{"sid": "003_殷本纪.20.s3", "chapter": "003_殷本纪", "para": "20", "seq": 3, "text": "殷民咨胥皆怨，不欲徙。", "len": 11}
{"sid": "003_殷本纪.20.s4", "chapter": "003_殷本纪", "para": "20", "seq": 4, "text": "盘庚乃告谕诸侯大臣曰：“昔高后成汤与尔之先祖俱定天下，法则可修。", "len": 32}
{"sid": "003_殷本纪.20.s5", "chapter": "003_殷本纪", "para": "20", "seq": 5, "text": "舍而弗勉，何以成德！", "len": 10}
{"sid": "003_殷本纪.20.s6", "chapter": "003_殷本纪", "para": "20", "seq": 6, "text": "” 乃遂涉河南，治亳，行汤之政，然後百姓由宁，殷道复兴。", "len": 28}
{"sid": "003_殷本纪.20.s7", "chapter": "003_殷本纪", "para": "20", "seq": 7, "text": "诸侯来朝，以其遵成汤之德也。", "len": 14}
{"sid": "003_殷本纪.21.s1", "chapter": "003_殷本纪", "para": "21", "seq": 1, "text": "帝盘庚崩，弟小辛立，是为帝小辛。", "len": 16}
{"sid": "003_殷本纪.21.s2", "chapter": "003_殷本纪", "para": "21", "seq": 2, "text": "帝小辛立，殷复衰。", "len": 9}
{"sid": "003_殷本纪.21.s3", "chapter": "003_殷本纪", "para": "21", "seq": 3, "text": "百姓思盘庚，乃作盘庚三篇。", "len": 13}
{"sid": "003_殷本纪.21.s4", "chapter": "003_殷本纪", "para": "21", "seq": 4, "text": "帝小辛崩，弟小乙立，是为帝小乙。", "len": 16}
{"sid": "003_殷本纪.22.s1", "chapter": "003_殷本纪", "para": "22", "seq": 1, "text": "帝小乙崩，子帝武丁立。", "len": 11}
{"sid": "003_殷本纪.22.s2", "chapter": "003_殷本纪", "para": "22", "seq": 2, "text": "帝武丁即位，思复兴殷，而未得其佐。", "len": 17}
{"sid": "003_殷本纪.22.s3", "chapter": "003_殷本纪", "para": "22", "seq": 3, "text": "三年不言，政事决定於冢宰，以观国风。", "len": 18}
{"sid": "003_殷本纪.22.s4", "chapter": "003_殷本纪", "para": "22", "seq": 4, "text": "武丁夜梦得圣人，名曰说。", "len": 12}
{"sid": "003_殷本纪.22.s5", "chapter": "003_殷本纪", "para": "22", "seq": 5, "text": "以梦所见视群臣百吏，皆非也。", "len": 14}
{"sid": "003_殷本纪.22.s6", "chapter": "003_殷本纪", "para": "22", "seq": 6, "text": "於是乃使百工营求之野，得说於傅险中。", "len": 18}
{"sid": "003_殷本纪.22.s7", "chapter": "003_殷本纪", "para": "22", "seq": 7, "text": "是时说为胥靡，筑於傅险。", "len": 12}
{"sid": "003_殷本纪.22.s8", "chapter": "003_殷本纪", "para": "22", "seq": 8, "text": "见於武丁，武丁曰是也。", "len": 11}
{"sid": "003_殷本纪.22.s9", "chapter": "003_殷本纪", "para": "22", "seq": 9, "text": "得而与之语，果圣人，举以为相，殷国大治。", "len": 20}
{"sid": "003_殷本纪.22.s10", "chapter": "003_殷本纪", "para": "22", "seq": 10, "text": "故遂以傅险姓之，号曰傅说。", "len": 13}
{"sid": "003_殷本纪.23.s1", "chapter": "003_殷本纪", "para": "23", "seq": 1, "text": "帝武丁祭成汤，明日，有飞雉登鼎耳而呴，武丁惧。", "len": 23}
{"sid": "003_殷本纪.23.s2", "chapter": "003_殷本纪", "para": "23", "seq": 2, "text": "祖己曰：“王勿忧，先修政事。", "len": 14}
{"sid": "003_殷本纪.23.s3", "chapter": "003_殷本纪", "para": "23", "seq": 3, "text": "” 祖己乃训王曰：“唯天监下典厥义，降年有永有不永，非天夭民，中绝其命。", "len": 36}
{"sid": "003_殷本纪.23.s4", "chapter": "003_殷本纪", "para": "23", "seq": 4, "text": "民有不若德，不听罪，天既附命正厥德，乃曰其奈何。", "len": 24}
{"sid": "003_殷本纪.23.s5", "chapter": "003_殷本纪", "para": "23", "seq": 5, "text": "呜呼！", "len": 3}
{"sid": "003_殷本纪.23.s6", "chapter": "003_殷本纪", "para": "23", "seq": 6, "text": "王嗣敬民，罔非天继，常祀毋礼于弃道。", "len": 18}
{"sid": "003_殷本纪.23.s7", "chapter": "003_殷本纪", "para": "23", "seq": 7, "text": "” 武丁修政行德，天下咸驩，殷道复兴。", "len": 19}
{"sid": "003_殷本纪.24.s1", "chapter": "003_殷本纪", "para": "24", "seq": 1, "text": "帝武丁崩，子帝祖庚立。", "len": 11}
{"sid": "003_殷本纪.24.s2", "chapter": "003_殷本纪", "para": "24", "seq": 2, "text": "祖己嘉武丁之以祥雉为德，立其庙为高宗，遂作高宗肜日及训。", "len": 28}
{"sid": "003_殷本纪.25.s1", "chapter": "003_殷本纪", "para": "25", "seq": 1, "text": "帝祖庚崩，弟祖甲立，是为帝甲。", "len": 15}
{"sid": "003_殷本纪.25.s2", "chapter": "003_殷本纪", "para": "25", "seq": 2, "text": "帝甲淫乱，殷复衰。", "len": 9}
{"sid": "003_殷本纪.26.s1", "chapter": "003_殷本纪", "para": "26", "seq": 1, "text": "帝甲崩，子帝廪辛立。", "len": 10}
{"sid": "003_殷本纪.26.s2", "chapter": "003_殷本纪", "para": "26", "seq": 2, "text": "帝廪辛崩，弟庚丁立，是为帝庚丁。", "len": 16}
{"sid": "003_殷本纪.26.s3", "chapter": "003_殷本纪", "para": "26", "seq": 3, "text": "帝庚丁崩，子帝武乙立。", "len": 11}
{"sid": "003_殷本纪.26.s4", "chapter": "003_殷本纪", "para": "26", "seq": 4, "text": "殷复去亳，徙河北。", "len": 9}
{"sid": "003_殷本纪.27.s1", "chapter": "003_殷本纪", "para": "27", "seq": 1, "text": "帝武乙无道，为偶人，谓之天神。", "len": 15}
{"sid": "003_殷本纪.27.s2", "chapter": "003_殷本纪", "para": "27", "seq": 2, "text": "与之博，令人为行。", "len": 9}
{"sid": "003_殷本纪.27.s3", "chapter": "003_殷本纪", "para": "27", "seq": 3, "text": "天神不胜，乃僇辱之。", "len": 10}
{"sid": "003_殷本纪.27.s4", "chapter": "003_殷本纪", "para": "27", "seq": 4, "text": "为革囊，盛血，卬而射之，命曰“射天”。", "len": 19}
{"sid": "003_殷本纪.27.s5", "chapter": "003_殷本纪", "para": "27", "seq": 5, "text": "武乙猎於河渭之间，暴雷，武乙震死。", "len": 17}
{"sid": "003_殷本纪.27.s6", "chapter": "003_殷本纪", "para": "27", "seq": 6, "text": "子帝太丁立。", "len": 6}
{"sid": "003_殷本纪.27.s7", "chapter": "003_殷本纪", "para": "27", "seq": 7, "text": "帝太丁崩，子帝乙立。", "len": 10}
{"sid": "003_殷本纪.27.s8", "chapter": "003_殷本纪", "para": "27", "seq": 8, "text": "帝乙立，殷益衰。", "len": 8}
{"sid": "003_殷本纪.28.s1", "chapter": "003_殷本纪", "para": "28", "seq": 1, "text": "帝乙长子曰微子启，启母贱，不得嗣。", "len": 17}
{"sid": "003_殷本纪.28.s2", "chapter": "003_殷本纪", "para": "28", "seq": 2, "text": "少子辛，辛母正后，辛为嗣。", "len": 13}
{"sid": "003_殷本纪.28.s3", "chapter": "003_殷本纪", "para": "28", "seq": 3, "text": "帝乙崩，子辛立，是为帝辛，天下谓之纣。", "len": 19}
{"sid": "003_殷本纪.29.s1", "chapter": "003_殷本纪", "para": "29", "seq": 1, "text": "帝纣资辨捷疾，闻见甚敏；材力过人，手格猛兽；知足以距谏，言足以饰非；矜人臣以能，高天下以声，以为皆出己之下。", "len": 54}
{"sid": "003_殷本纪.29.s2", "chapter": "003_殷本纪", "para": "29", "seq": 2, "text": "好酒淫乐，嬖於妇人。", "len": 10}
{"sid": "003_殷本纪.29.s3", "chapter": "003_殷本纪", "para": "29", "seq": 3, "text": "爱妲己，妲己之言是从。", "len": 11}
{"sid": "003_殷本纪.29.s4", "chapter": "003_殷本纪", "para": "29", "seq": 4, "text": "於是使师涓作新淫声，北里之舞，靡靡之乐。", "len": 20}
{"sid": "003_殷本纪.29.s5", "chapter": "003_殷本纪", "para": "29", "seq": 5, "text": "厚赋税以实鹿台之钱，而盈钜桥之粟。", "len": 17}
{"sid": "003_殷本纪.29.s6", "chapter": "003_殷本纪", "para": "29", "seq": 6, "text": "益收狗马奇物，充仞宫室。", "len": 12}
{"sid": "003_殷本纪.29.s7", "chapter": "003_殷本纪", "para": "29", "seq": 7, "text": "益广沙丘苑台，多取野兽蜚鸟置其中。", "len": 17}
{"sid": "003_殷本纪.29.s8", "chapter": "003_殷本纪", "para": "29", "seq": 8, "text": "慢於鬼神。", "len": 5}
{"sid": "003_殷本纪.29.s9", "chapter": "003_殷本纪", "para": "29", "seq": 9, "text": "大勣乐戏於沙丘，以酒为池，县肉为林，使男女倮相逐其间，为长夜之饮。", "len": 33}
{"sid": "003_殷本纪.30.s1", "chapter": "003_殷本纪", "para": "30", "seq": 1, "text": "百姓怨望而诸侯有畔者，於是纣乃重刑辟，有砲格之法。", "len": 25}
{"sid": "003_殷本纪.30.s2", "chapter": "003_殷本纪", "para": "30", "seq": 2, "text": "以西伯昌、九侯、鄂侯为三公。", "len": 14}
{"sid": "003_殷本纪.30.s3", "chapter": "003_殷本纪", "para": "30", "seq": 3, "text": "九侯有好女，入之纣。", "len": 10}
{"sid": "003_殷本纪.30.s4", "chapter": "003_殷本纪", "para": "30", "seq": 4, "text": "九侯女不憙淫，纣怒，杀之，而醢九侯。", "len": 18}
{"sid": "003_殷本纪.30.s5", "chapter": "003_殷本纪", "para": "30", "seq": 5, "text": "鄂侯争之强，辨之疾，并脯鄂侯。", "len": 15}
{"sid": "003_殷本纪.30.s6", "chapter": "003_殷本纪", "para": "30", "seq": 6, "text": "西伯昌闻之，窃叹。", "len": 9}
{"sid": "003_殷本纪.30.s7", "chapter": "003_殷本纪", "para": "30", "seq": 7, "text": "崇侯虎知之，以告纣，纣囚西伯羑里。", "len": 17}
{"sid": "003_殷本纪.30.s8", "chapter": "003_殷本纪", "para": "30", "seq": 8, "text": "西伯之臣闳夭之徒，求美女奇物善马以献纣，纣乃赦西伯。", "len": 26}
{"sid": "003_殷本纪.30.s9", "chapter": "003_殷本纪", "para": "30", "seq": 9, "text": "西伯出而献洛西之地，以请除砲格之刑。", "len": 18}
{"sid": "003_殷本纪.30.s10", "chapter": "003_殷本纪", "para": "30", "seq": 10, "text": "纣乃许之，赐弓矢斧钺，使得征伐，为西伯。", "len": 20}
{"sid": "003_殷本纪.30.s11", "chapter": "003_殷本纪", "para": "30", "seq": 11, "text": "而用费中为政。", "len": 7}
{"sid": "003_殷本纪.30.s12", "chapter": "003_殷本纪", "para": "30", "seq": 12, "text": "费中善谀，好利，殷人弗亲。", "len": 13}
{"sid": "003_殷本纪.30.s13", "chapter": "003_殷本纪", "para": "30", "seq": 13, "text": "纣又用恶来。", "len": 6}
{"sid": "003_殷本纪.30.s14", "chapter": "003_殷本纪", "para": "30", "seq": 14, "text": "恶来善毁谗，诸侯以此益疏。", "len": 13}
{"sid": "003_殷本纪.31.s1", "chapter": "003_殷本纪", "para": "31", "seq": 1, "text": "西伯归，乃阴修德行善，诸侯多叛纣而往归西伯。", "len": 22}
{"sid": "003_殷本纪.31.s2", "chapter": "003_殷本纪", "para": "31", "seq": 2, "text": "西伯滋大，纣由是稍失权重。", "len": 13}
{"sid": "003_殷本纪.31.s3", "chapter": "003_殷本纪", "para": "31", "seq": 3, "text": "王子比干谏，弗听。", "len": 9}
{"sid": "003_殷本纪.31.s4", "chapter": "003_殷本纪", "para": "31", "seq": 4, "text": "商容贤者，百姓爱之，纣废之。", "len": 14}
{"sid": "003_殷本纪.31.s5", "chapter": "003_殷本纪", "para": "31", "seq": 5, "text": "及西伯伐饥国，灭之，纣之臣祖伊闻之而咎周，恐，奔告纣曰：“天既讫我殷命，假人元龟，无敢知吉，非先王不相我後人，维王淫虐用自绝，故天弃我，不有安食，不虞知天性，不迪率典。", "len": 84}
{"sid": "003_殷本纪.31.s6", "chapter": "003_殷本纪", "para": "31", "seq": 6, "text": "今我民罔不欲丧，曰’天曷不降威，大命胡不至’？", "len": 23}
{"sid": "003_殷本纪.31.s7", "chapter": "003_殷本纪", "para": "31", "seq": 7, "text": "今王其柰何？", "len": 6}
{"sid": "003_殷本纪.31.s8", "chapter": "003_殷本纪", "para": "31", "seq": 8, "text": "” 纣曰：“我生不有命在天乎！", "len": 15}
{"sid": "003_殷本纪.31.s9", "chapter": "003_殷本纪", "para": "31", "seq": 9, "text": "” 祖伊反，曰：“纣不可谏矣。", "len": 15}
{"sid": "003_殷本纪.31.s10", "chapter": "003_殷本纪", "para": "31", "seq": 10, "text": "” 西伯既卒，周武王之东伐，至盟津，诸侯叛殷会周者八百。", "len": 28}
{"sid": "003_殷本纪.31.s11", "chapter": "003_殷本纪", "para": "31", "seq": 11, "text": "诸侯皆曰：“纣可伐矣。", "len": 11}
{"sid": "003_殷本纪.31.s12", "chapter": "003_殷本纪", "para": "31", "seq": 12, "text": "” 武王曰：“尔未知天命。", "len": 13}
{"sid": "003_殷本纪.31.s13", "chapter": "003_殷本纪", "para": "31", "seq": 13, "text": "” 乃复归。", "len": 6}
{"sid": "003_殷本纪.32.s1", "chapter": "003_殷本纪", "para": "32", "seq": 1, "text": "纣愈淫乱不止。", "len": 7}
{"sid": "003_殷本纪.32.s2", "chapter": "003_殷本纪", "para": "32", "seq": 2, "text": "微子数谏不听，乃与大师、少师谋，遂去。", "len": 19}
{"sid": "003_殷本纪.32.s3", "chapter": "003_殷本纪", "para": "32", "seq": 3, "text": "比干曰：“为人臣者，不得不以死争。", "len": 17}
{"sid": "003_殷本纪.32.s4", "chapter": "003_殷本纪", "para": "32", "seq": 4, "text": "” 乃强谏纣。", "len": 7}
{"sid": "003_殷本纪.32.s5", "chapter": "003_殷本纪", "para": "32", "seq": 5, "text": "纣怒曰：“吾闻圣人心有七窍。", "len": 14}
{"sid": "003_殷本纪.32.s6", "chapter": "003_殷本纪", "para": "32", "seq": 6, "text": "” 剖比干，观其心。", "len": 10}
{"sid": "003_殷本纪.32.s7", "chapter": "003_殷本纪", "para": "32", "seq": 7, "text": "箕子惧，乃详狂为奴，纣又囚之。", "len": 15}
{"sid": "003_殷本纪.32.s8", "chapter": "003_殷本纪", "para": "32", "seq": 8, "text": "殷之大师、少师乃持其祭乐器奔周。", "len": 16}
{"sid": "003_殷本纪.32.s9", "chapter": "003_殷本纪", "para": "32", "seq": 9, "text": "周武王於是遂率诸侯伐纣。", "len": 12}
{"sid": "003_殷本纪.32.s10", "chapter": "003_殷本纪", "para": "32", "seq": 10, "text": "纣亦发兵距之牧野。", "len": 9}
{"sid": "003_殷本纪.32.s11", "chapter": "003_殷本纪", "para": "32", "seq": 11, "text": "甲子日，纣兵败。", "len": 8}
{"sid": "003_殷本纪.32.s12", "chapter": "003_殷本纪", "para": "32", "seq": 12, "text": "纣走入，登鹿台，衣其宝玉衣，赴火而死。", "len": 19}
{"sid": "003_殷本纪.32.s13", "chapter": "003_殷本纪", "para": "32", "seq": 13, "text": "周武王遂斩纣头，县之白旗。", "len": 13}
{"sid": "003_殷本纪.32.s14", "chapter": "003_殷本纪", "para": "32", "seq": 14, "text": "杀妲己。", "len": 4}
{"sid": "003_殷本纪.32.s15", "chapter": "003_殷本纪", "para": "32", "seq": 15, "text": "释箕子之囚，封|封土比干之墓，表商容之闾。", "len": 21}
{"sid": "003_殷本纪.32.s16", "chapter": "003_殷本纪", "para": "32", "seq": 16, "text": "封|分封纣子武庚、禄父，以续殷祀，令修行盘庚之政。", "len": 25}
{"sid": "003_殷本纪.32.s17", "chapter": "003_殷本纪", "para": "32", "seq": 17, "text": "殷民大说。", "len": 5}
{"sid": "003_殷本纪.32.s18", "chapter": "003_殷本纪", "para": "32", "seq": 18, "text": "於是周武王为天子。", "len": 9}
{"sid": "003_殷本纪.32.s19", "chapter": "003_殷本纪", "para": "32", "seq": 19, "text": "其後世贬帝号，号为王。", "len": 11}
{"sid": "003_殷本纪.32.s20", "chapter": "003_殷本纪", "para": "32", "seq": 20, "text": "而封殷後为诸侯，属周。", "len": 11}
{"sid": "003_殷本纪.33.s1", "chapter": "003_殷本纪", "para": "33", "seq": 1, "text": "周武王崩，武庚与管叔、蔡叔作乱，成王命周公诛之，而立微子於宋，以续殷後焉。", "len": 37}
{"sid": "003_殷本纪.33.s2", "chapter": "003_殷本纪", "para": "33", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "003_殷本纪.34.s1", "chapter": "003_殷本纪", "para": "34", "seq": 1, "text": "太史公曰：余以颂次契之事，自成汤以来，采於书诗。", "len": 24}
{"sid": "003_殷本纪.34.s2", "chapter": "003_殷本纪", "para": "34", "seq": 2, "text": "契为子姓，其後分封，以国为姓，有殷氏、来氏、宋氏、空桐氏、稚氏、北殷氏、目夷氏。", "len": 40}
{"sid": "003_殷本纪.34.s3", "chapter": "003_殷本纪", "para": "34", "seq": 3, "text": "孔子曰，殷路车为善，而色尚白。", "len": 15}
{"sid": "003_殷本纪.34.s4", "chapter": "003_殷本纪", "para": "34", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "003_殷本纪.35.s1", "chapter": "003_殷本纪", "para": "35", "seq": 1, "text": "简狄吞乙，是为殷祖。", "len": 10}
{"sid": "003_殷本纪.35.s2", "chapter": "003_殷本纪", "para": "35", "seq": 2, "text": "玄王启商，伊尹负俎。", "len": 10}
{"sid": "003_殷本纪.35.s3", "chapter": "003_殷本纪", "para": "35", "seq": 3, "text": "上开三面，下献九主。", "len": 10}
{"sid": "003_殷本纪.35.s4", "chapter": "003_殷本纪", "para": "35", "seq": 4, "text": "旋师泰卷，继相臣扈。", "len": 10}
{"sid": "003_殷本纪.35.s5", "chapter": "003_殷本纪", "para": "35", "seq": 5, "text": "迁嚣圮耿，不常厥土。", "len": 10}
{"sid": "003_殷本纪.35.s6", "chapter": "003_殷本纪", "para": "35", "seq": 6, "text": "武乙无道，祸因射天。", "len": 10}
{"sid": "003_殷本纪.35.s7", "chapter": "003_殷本纪", "para": "35", "seq": 7, "text": "帝辛淫乱，拒谏贼贤。", "len": 10}
{"sid": "003_殷本纪.35.s8", "chapter": "003_殷本纪", "para": "35", "seq": 8, "text": "九侯见醢，砲格兴焉。", "len": 10}
{"sid": "003_殷本纪.35.s9", "chapter": "003_殷本纪", "para": "35", "seq": 9, "text": "黄钺斯杖，白旗是悬。", "len": 10}
{"sid": "003_殷本纪.35.s10", "chapter": "003_殷本纪", "para": "35", "seq": 10, "text": "哀哉琼室，殷祀用迁！", "len": 10}
{"sid": "003_殷本纪.35.s11", "chapter": "003_殷本纪", "para": "35", "seq": 11, "text": ":::", "len": 3}
