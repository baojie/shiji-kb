{"sid": "037_卫康叔世家.1.s1", "chapter": "037_卫康叔世家", "para": "1", "seq": 1, "text": "卫康叔名封，周武王同母少弟也。", "len": 15}
{"sid": "037_卫康叔世家.1.s2", "chapter": "037_卫康叔世家", "para": "1", "seq": 2, "text": "其次尚有厓季，厓季最少。", "len": 12}
{"sid": "037_卫康叔世家.2.s1", "chapter": "037_卫康叔世家", "para": "2", "seq": 1, "text": "武王已克殷纣，复以殷馀民封纣子武庚禄父，比诸侯，以奉其先祀勿绝。", "len": 32}
{"sid": "037_卫康叔世家.2.s2", "chapter": "037_卫康叔世家", "para": "2", "seq": 2, "text": "为武庚未集，恐其有贼心，武王乃令其弟管叔、蔡叔傅相武庚禄父，以和其民。", "len": 35}
{"sid": "037_卫康叔世家.2.s3", "chapter": "037_卫康叔世家", "para": "2", "seq": 3, "text": "武王既崩，成王少。", "len": 9}
{"sid": "037_卫康叔世家.2.s4", "chapter": "037_卫康叔世家", "para": "2", "seq": 4, "text": "周公旦代成王治，当国。", "len": 11}
{"sid": "037_卫康叔世家.2.s5", "chapter": "037_卫康叔世家", "para": "2", "seq": 5, "text": "管叔、蔡叔疑周公，乃与武庚禄父作乱，欲攻成周。", "len": 23}
{"sid": "037_卫康叔世家.2.s6", "chapter": "037_卫康叔世家", "para": "2", "seq": 6, "text": "周公旦以成王命兴师伐殷，杀武庚禄父、管叔，放蔡叔，以武庚殷馀民封康叔为卫君，居河、淇间故商墟。", "len": 47}
{"sid": "037_卫康叔世家.3.s1", "chapter": "037_卫康叔世家", "para": "3", "seq": 1, "text": "周公旦惧康叔齿少，乃申告康叔曰：“必求殷之贤人君子长者，问其先殷所以兴，所以亡，而务爱民。", "len": 45}
{"sid": "037_卫康叔世家.3.s2", "chapter": "037_卫康叔世家", "para": "3", "seq": 2, "text": "” 告以纣所以亡者以淫於酒，酒之失，妇人是用，故纣之乱自此始。", "len": 31}
{"sid": "037_卫康叔世家.3.s3", "chapter": "037_卫康叔世家", "para": "3", "seq": 3, "text": "为梓材，示君子可法则。", "len": 11}
{"sid": "037_卫康叔世家.3.s4", "chapter": "037_卫康叔世家", "para": "3", "seq": 4, "text": "故谓之康诰、酒诰、梓材以命之。", "len": 15}
{"sid": "037_卫康叔世家.3.s5", "chapter": "037_卫康叔世家", "para": "3", "seq": 5, "text": "康叔之国，既以此命，能和集其民，民大说。", "len": 20}
{"sid": "037_卫康叔世家.4.s1", "chapter": "037_卫康叔世家", "para": "4", "seq": 1, "text": "成王长，用事，举康叔为周司寇，赐卫宝祭器，以章有德。", "len": 26}
{"sid": "037_卫康叔世家.5.s1", "chapter": "037_卫康叔世家", "para": "5", "seq": 1, "text": "康叔卒，子康伯代立。", "len": 10}
{"sid": "037_卫康叔世家.5.s2", "chapter": "037_卫康叔世家", "para": "5", "seq": 2, "text": "康伯卒，子考伯立。", "len": 9}
{"sid": "037_卫康叔世家.5.s3", "chapter": "037_卫康叔世家", "para": "5", "seq": 3, "text": "考伯卒，子嗣伯立。", "len": 9}
{"sid": "037_卫康叔世家.5.s4", "chapter": "037_卫康叔世家", "para": "5", "seq": 4, "text": "嗣伯卒，子榅伯立。", "len": 9}
{"sid": "037_卫康叔世家.5.s5", "chapter": "037_卫康叔世家", "para": "5", "seq": 5, "text": "榅伯卒，子靖伯立。", "len": 9}
{"sid": "037_卫康叔世家.5.s6", "chapter": "037_卫康叔世家", "para": "5", "seq": 6, "text": "靖伯卒，子贞伯立。", "len": 9}
{"sid": "037_卫康叔世家.5.s7", "chapter": "037_卫康叔世家", "para": "5", "seq": 7, "text": "贞伯卒，子顷侯立。", "len": 9}
{"sid": "037_卫康叔世家.6.s1", "chapter": "037_卫康叔世家", "para": "6", "seq": 1, "text": "顷侯厚赂周夷王，夷王命卫为侯。", "len": 15}
{"sid": "037_卫康叔世家.6.s2", "chapter": "037_卫康叔世家", "para": "6", "seq": 2, "text": "顷侯立十二年卒，子釐侯立。", "len": 13}
{"sid": "037_卫康叔世家.7.s1", "chapter": "037_卫康叔世家", "para": "7", "seq": 1, "text": "釐侯十三年，周厉王出奔于彘，共和行政焉。", "len": 20}
{"sid": "037_卫康叔世家.7.s2", "chapter": "037_卫康叔世家", "para": "7", "seq": 2, "text": "二十八年，周宣王立。", "len": 10}
{"sid": "037_卫康叔世家.8.s1", "chapter": "037_卫康叔世家", "para": "8", "seq": 1, "text": "四十二年，釐侯卒，太子共伯馀立为君。", "len": 18}
{"sid": "037_卫康叔世家.8.s2", "chapter": "037_卫康叔世家", "para": "8", "seq": 2, "text": "共伯弟和有宠於釐侯，多予之赂；和以其赂赂士，以袭攻共伯於墓上，共伯入釐侯羡自杀。", "len": 40}
{"sid": "037_卫康叔世家.8.s3", "chapter": "037_卫康叔世家", "para": "8", "seq": 3, "text": "卫人因葬之釐侯旁，谥曰共伯，而立和为卫侯，是为武公。", "len": 26}
{"sid": "037_卫康叔世家.9.s1", "chapter": "037_卫康叔世家", "para": "9", "seq": 1, "text": "武公即位，修康叔之政，百姓和集。", "len": 16}
{"sid": "037_卫康叔世家.9.s2", "chapter": "037_卫康叔世家", "para": "9", "seq": 2, "text": "四十二年，犬戎杀周幽王，武公将兵往佐周平戎，甚有功，周平王命武公为公。", "len": 35}
{"sid": "037_卫康叔世家.9.s3", "chapter": "037_卫康叔世家", "para": "9", "seq": 3, "text": "五十五年，卒，子庄公扬立。", "len": 13}
{"sid": "037_卫康叔世家.10.s1", "chapter": "037_卫康叔世家", "para": "10", "seq": 1, "text": "庄公五年，取齐女为夫人，好而无子。", "len": 17}
{"sid": "037_卫康叔世家.10.s2", "chapter": "037_卫康叔世家", "para": "10", "seq": 2, "text": "又取陈女为夫人，生子，蚤死。", "len": 14}
{"sid": "037_卫康叔世家.10.s3", "chapter": "037_卫康叔世家", "para": "10", "seq": 3, "text": "陈女女弟亦幸於庄公，而生子完。", "len": 15}
{"sid": "037_卫康叔世家.10.s4", "chapter": "037_卫康叔世家", "para": "10", "seq": 4, "text": "完母死，庄公令夫人齐女子之，立为太子。", "len": 19}
{"sid": "037_卫康叔世家.10.s5", "chapter": "037_卫康叔世家", "para": "10", "seq": 5, "text": "庄公有宠妾，生子州吁。", "len": 11}
{"sid": "037_卫康叔世家.10.s6", "chapter": "037_卫康叔世家", "para": "10", "seq": 6, "text": "十八年，州吁长，好兵，庄公使将。", "len": 16}
{"sid": "037_卫康叔世家.10.s7", "chapter": "037_卫康叔世家", "para": "10", "seq": 7, "text": "石碏谏庄公曰：“庶子好兵，使将，乱自此起。", "len": 21}
{"sid": "037_卫康叔世家.10.s8", "chapter": "037_卫康叔世家", "para": "10", "seq": 8, "text": "” 不听。", "len": 5}
{"sid": "037_卫康叔世家.10.s9", "chapter": "037_卫康叔世家", "para": "10", "seq": 9, "text": "二十三年，庄公卒，太子完立，是为桓公。", "len": 19}
{"sid": "037_卫康叔世家.11.s1", "chapter": "037_卫康叔世家", "para": "11", "seq": 1, "text": "桓公二年，弟州吁骄奢，桓公绌之，州吁出奔。", "len": 21}
{"sid": "037_卫康叔世家.11.s2", "chapter": "037_卫康叔世家", "para": "11", "seq": 2, "text": "十三年，郑伯弟段攻其兄，不胜，亡，而州吁求与之友。", "len": 25}
{"sid": "037_卫康叔世家.11.s3", "chapter": "037_卫康叔世家", "para": "11", "seq": 3, "text": "十六年，州吁收聚卫亡人以袭杀桓公，州吁自立为卫君。", "len": 25}
{"sid": "037_卫康叔世家.11.s4", "chapter": "037_卫康叔世家", "para": "11", "seq": 4, "text": "为郑伯弟段欲伐郑，请宋、陈、蔡与俱，三国皆许州吁。", "len": 25}
{"sid": "037_卫康叔世家.11.s5", "chapter": "037_卫康叔世家", "para": "11", "seq": 5, "text": "州吁新立，好兵，弑桓公，卫人皆不爱。", "len": 18}
{"sid": "037_卫康叔世家.11.s6", "chapter": "037_卫康叔世家", "para": "11", "seq": 6, "text": "石碏乃因桓公母家於陈，详为善州吁。", "len": 17}
{"sid": "037_卫康叔世家.11.s7", "chapter": "037_卫康叔世家", "para": "11", "seq": 7, "text": "至郑郊，石碏与陈侯共谋，使右宰丑进食，因杀州吁于濮，而迎桓公弟晋於邢而立之，是为宣公。", "len": 43}
{"sid": "037_卫康叔世家.12.s1", "chapter": "037_卫康叔世家", "para": "12", "seq": 1, "text": "宣公七年，鲁弑其君隐公。", "len": 12}
{"sid": "037_卫康叔世家.12.s2", "chapter": "037_卫康叔世家", "para": "12", "seq": 2, "text": "九年，宋督弑其君殇公，及孔父。", "len": 15}
{"sid": "037_卫康叔世家.12.s3", "chapter": "037_卫康叔世家", "para": "12", "seq": 3, "text": "十年，晋曲沃庄伯弑其君哀侯。", "len": 14}
{"sid": "037_卫康叔世家.13.s1", "chapter": "037_卫康叔世家", "para": "13", "seq": 1, "text": "十八年，初，宣公爱夫人夷姜，夷姜生子伋，以为太子，而令右公子傅之。", "len": 33}
{"sid": "037_卫康叔世家.13.s2", "chapter": "037_卫康叔世家", "para": "13", "seq": 2, "text": "右公子为太子取齐女，未入室，而宣公见所欲为太子妇者好，说而自取之，更为太子取他女。", "len": 41}
{"sid": "037_卫康叔世家.13.s3", "chapter": "037_卫康叔世家", "para": "13", "seq": 3, "text": "宣公得齐女，生子寿、子朔，令左公子傅之。", "len": 20}
{"sid": "037_卫康叔世家.13.s4", "chapter": "037_卫康叔世家", "para": "13", "seq": 4, "text": "太子伋母死，宣公正夫人与朔共谗恶太子伋。", "len": 20}
{"sid": "037_卫康叔世家.13.s5", "chapter": "037_卫康叔世家", "para": "13", "seq": 5, "text": "宣公自以其夺太子妻也，心恶太子，欲废之。", "len": 20}
{"sid": "037_卫康叔世家.13.s6", "chapter": "037_卫康叔世家", "para": "13", "seq": 6, "text": "及闻其恶，大怒，乃使太子伋於齐而令盗遮界上杀之，与太子白旄，而告界盗见持白旄者杀之。", "len": 42}
{"sid": "037_卫康叔世家.13.s7", "chapter": "037_卫康叔世家", "para": "13", "seq": 7, "text": "且行，子朔之兄寿，太子异母弟也，知朔之恶太子而君欲杀之，乃谓太子曰：“界盗见太子白旄，即杀太子，太子可毋行。", "len": 54}
{"sid": "037_卫康叔世家.13.s8", "chapter": "037_卫康叔世家", "para": "13", "seq": 8, "text": "” 太子曰：“逆父命求生，不可。", "len": 16}
{"sid": "037_卫康叔世家.13.s9", "chapter": "037_卫康叔世家", "para": "13", "seq": 9, "text": "” 遂行。", "len": 5}
{"sid": "037_卫康叔世家.13.s10", "chapter": "037_卫康叔世家", "para": "13", "seq": 10, "text": "寿见太子不止，扑盗其沧旄而先驰至界。", "len": 18}
{"sid": "037_卫康叔世家.13.s11", "chapter": "037_卫康叔世家", "para": "13", "seq": 11, "text": "界盗见其验，即杀之。", "len": 10}
{"sid": "037_卫康叔世家.13.s12", "chapter": "037_卫康叔世家", "para": "13", "seq": 12, "text": "寿已死，而太子伋又至，谓盗曰：“所当杀乃我也。", "len": 23}
{"sid": "037_卫康叔世家.13.s13", "chapter": "037_卫康叔世家", "para": "13", "seq": 13, "text": "” 盗并杀太子伋，以报宣公。", "len": 14}
{"sid": "037_卫康叔世家.13.s14", "chapter": "037_卫康叔世家", "para": "13", "seq": 14, "text": "宣公乃以子朔为太子。", "len": 10}
{"sid": "037_卫康叔世家.13.s15", "chapter": "037_卫康叔世家", "para": "13", "seq": 15, "text": "十九年，宣公卒，太子朔立，是为惠公。", "len": 18}
{"sid": "037_卫康叔世家.14.s1", "chapter": "037_卫康叔世家", "para": "14", "seq": 1, "text": "左右公子不平朔之立也，惠公四年，左右公子怨惠公之谗杀前太子伋而代立，乃作乱，攻惠公，立太子伋之弟黔牟为君，惠公奔齐。", "len": 58}
{"sid": "037_卫康叔世家.15.s1", "chapter": "037_卫康叔世家", "para": "15", "seq": 1, "text": "卫君黔牟立八年，齐襄公率诸侯奉王命共伐卫，纳卫惠公，诛左右公子。", "len": 32}
{"sid": "037_卫康叔世家.15.s2", "chapter": "037_卫康叔世家", "para": "15", "seq": 2, "text": "卫君黔牟奔于周，惠公复立。", "len": 13}
{"sid": "037_卫康叔世家.15.s3", "chapter": "037_卫康叔世家", "para": "15", "seq": 3, "text": "惠公立三年出亡，亡八年复入，与前通年凡十三年矣。", "len": 24}
{"sid": "037_卫康叔世家.16.s1", "chapter": "037_卫康叔世家", "para": "16", "seq": 1, "text": "二十五年，惠公怨周之容舍黔牟，与燕伐周。", "len": 20}
{"sid": "037_卫康叔世家.16.s2", "chapter": "037_卫康叔世家", "para": "16", "seq": 2, "text": "周惠王奔温，卫、燕立惠王弟穨为王。", "len": 17}
{"sid": "037_卫康叔世家.16.s3", "chapter": "037_卫康叔世家", "para": "16", "seq": 3, "text": "二十九年，郑复纳惠王。", "len": 11}
{"sid": "037_卫康叔世家.16.s4", "chapter": "037_卫康叔世家", "para": "16", "seq": 4, "text": "三十一年，惠公卒，子懿公赤立。", "len": 15}
{"sid": "037_卫康叔世家.17.s1", "chapter": "037_卫康叔世家", "para": "17", "seq": 1, "text": "懿公即位，好鹤，淫乐奢侈。", "len": 13}
{"sid": "037_卫康叔世家.17.s2", "chapter": "037_卫康叔世家", "para": "17", "seq": 2, "text": "九年，翟伐卫，卫懿公欲发兵，兵或畔。", "len": 18}
{"sid": "037_卫康叔世家.17.s3", "chapter": "037_卫康叔世家", "para": "17", "seq": 3, "text": "大臣言曰：“君好穀，穀可令击翟。", "len": 16}
{"sid": "037_卫康叔世家.17.s4", "chapter": "037_卫康叔世家", "para": "17", "seq": 4, "text": "” 翟於是遂入，杀懿公。", "len": 12}
{"sid": "037_卫康叔世家.18.s1", "chapter": "037_卫康叔世家", "para": "18", "seq": 1, "text": "懿公之立也，百姓大臣皆不服。", "len": 14}
{"sid": "037_卫康叔世家.18.s2", "chapter": "037_卫康叔世家", "para": "18", "seq": 2, "text": "自懿公父惠公朔之谗杀太子伋代立至於懿公，常欲败之，卒灭惠公之後而更立黔牟之弟昭伯顽之子申为君，是为戴公。", "len": 52}
{"sid": "037_卫康叔世家.19.s1", "chapter": "037_卫康叔世家", "para": "19", "seq": 1, "text": "戴公申元年卒。", "len": 7}
{"sid": "037_卫康叔世家.19.s2", "chapter": "037_卫康叔世家", "para": "19", "seq": 2, "text": "齐桓公以卫数乱，乃率诸侯伐翟，为卫筑楚丘，立戴公弟毁为卫君，初，翟杀懿公也，卫人怜之，思复立宣公前死太子伋之後，伋子又死，而代伋死者子寿又无子。", "len": 72}
{"sid": "037_卫康叔世家.19.s3", "chapter": "037_卫康叔世家", "para": "19", "seq": 3, "text": "太子伋同母弟二人：其一曰黔牟，黔牟尝代惠公为君，八年复去；其二曰昭伯。", "len": 35}
{"sid": "037_卫康叔世家.19.s4", "chapter": "037_卫康叔世家", "para": "19", "seq": 4, "text": "昭伯、黔牟皆已前死，故立昭伯子申为戴公。", "len": 20}
{"sid": "037_卫康叔世家.19.s5", "chapter": "037_卫康叔世家", "para": "19", "seq": 5, "text": "戴公卒，复立其弟毁为文公。", "len": 13}
{"sid": "037_卫康叔世家.20.s1", "chapter": "037_卫康叔世家", "para": "20", "seq": 1, "text": "文公初立，轻赋平罪，身自劳，与百姓同苦，以收卫民。", "len": 25}
{"sid": "037_卫康叔世家.21.s1", "chapter": "037_卫康叔世家", "para": "21", "seq": 1, "text": "十六年，晋公子重耳过，无礼。", "len": 14}
{"sid": "037_卫康叔世家.21.s2", "chapter": "037_卫康叔世家", "para": "21", "seq": 2, "text": "十七年，齐桓公卒。", "len": 9}
{"sid": "037_卫康叔世家.21.s3", "chapter": "037_卫康叔世家", "para": "21", "seq": 3, "text": "二十五年，文公卒，子成公郑立。", "len": 15}
{"sid": "037_卫康叔世家.22.s1", "chapter": "037_卫康叔世家", "para": "22", "seq": 1, "text": "成公三年，晋欲假道於卫救宋，成公不许。", "len": 19}
{"sid": "037_卫康叔世家.22.s2", "chapter": "037_卫康叔世家", "para": "22", "seq": 2, "text": "晋更从南河度，救宋。", "len": 10}
{"sid": "037_卫康叔世家.22.s3", "chapter": "037_卫康叔世家", "para": "22", "seq": 3, "text": "徵师於卫，卫大夫欲许，成公不肯。", "len": 16}
{"sid": "037_卫康叔世家.22.s4", "chapter": "037_卫康叔世家", "para": "22", "seq": 4, "text": "大夫元咺攻成公，成公出奔。", "len": 13}
{"sid": "037_卫康叔世家.22.s5", "chapter": "037_卫康叔世家", "para": "22", "seq": 5, "text": "晋文公重耳伐卫，分其地予宋，讨前过无礼及不救宋患也。", "len": 26}
{"sid": "037_卫康叔世家.22.s6", "chapter": "037_卫康叔世家", "para": "22", "seq": 6, "text": "卫成公遂出奔陈。", "len": 8}
{"sid": "037_卫康叔世家.22.s7", "chapter": "037_卫康叔世家", "para": "22", "seq": 7, "text": "二岁，如周求入，与晋文公会。", "len": 14}
{"sid": "037_卫康叔世家.22.s8", "chapter": "037_卫康叔世家", "para": "22", "seq": 8, "text": "晋使人鸩卫成公，成公私於周主鸩，令薄，得不死。", "len": 23}
{"sid": "037_卫康叔世家.22.s9", "chapter": "037_卫康叔世家", "para": "22", "seq": 9, "text": "已而周为请晋文公，卒入之卫，而诛元咺，卫君瑕出奔。", "len": 25}
{"sid": "037_卫康叔世家.22.s10", "chapter": "037_卫康叔世家", "para": "22", "seq": 10, "text": "七年，晋文公卒。", "len": 8}
{"sid": "037_卫康叔世家.22.s11", "chapter": "037_卫康叔世家", "para": "22", "seq": 11, "text": "十二年，成公朝晋襄公。", "len": 11}
{"sid": "037_卫康叔世家.22.s12", "chapter": "037_卫康叔世家", "para": "22", "seq": 12, "text": "十四年，秦穆公卒。", "len": 9}
{"sid": "037_卫康叔世家.22.s13", "chapter": "037_卫康叔世家", "para": "22", "seq": 13, "text": "二十六年，齐邴歜弑其君懿公。", "len": 14}
{"sid": "037_卫康叔世家.22.s14", "chapter": "037_卫康叔世家", "para": "22", "seq": 14, "text": "三十五年，成公卒，子穆公立。", "len": 14}
{"sid": "037_卫康叔世家.23.s1", "chapter": "037_卫康叔世家", "para": "23", "seq": 1, "text": "穆公二年，楚庄王伐陈，杀夏徵舒。", "len": 16}
{"sid": "037_卫康叔世家.23.s2", "chapter": "037_卫康叔世家", "para": "23", "seq": 2, "text": "三年，楚庄王围郑，郑降，复释之。", "len": 16}
{"sid": "037_卫康叔世家.23.s3", "chapter": "037_卫康叔世家", "para": "23", "seq": 3, "text": "十一年，孙良夫救鲁伐齐，复得侵地。", "len": 17}
{"sid": "037_卫康叔世家.23.s4", "chapter": "037_卫康叔世家", "para": "23", "seq": 4, "text": "穆公卒，子定公臧立。", "len": 10}
{"sid": "037_卫康叔世家.23.s5", "chapter": "037_卫康叔世家", "para": "23", "seq": 5, "text": "定公十二年卒，子献公衎立。", "len": 13}
{"sid": "037_卫康叔世家.24.s1", "chapter": "037_卫康叔世家", "para": "24", "seq": 1, "text": "献公十三年，公令师曹教宫妾鼓琴，妾不善，曹笞之。", "len": 24}
{"sid": "037_卫康叔世家.24.s2", "chapter": "037_卫康叔世家", "para": "24", "seq": 2, "text": "妾以幸恶曹於公，公亦笞曹三百。", "len": 15}
{"sid": "037_卫康叔世家.24.s3", "chapter": "037_卫康叔世家", "para": "24", "seq": 3, "text": "十八年，献公戒孙文子、甯惠子食，皆往。", "len": 19}
{"sid": "037_卫康叔世家.24.s4", "chapter": "037_卫康叔世家", "para": "24", "seq": 4, "text": "日旰不召，而去射鸿於囿。", "len": 12}
{"sid": "037_卫康叔世家.24.s5", "chapter": "037_卫康叔世家", "para": "24", "seq": 5, "text": "二子从之，公不释射服与之言。", "len": 14}
{"sid": "037_卫康叔世家.24.s6", "chapter": "037_卫康叔世家", "para": "24", "seq": 6, "text": "二子怒，如宿。", "len": 7}
{"sid": "037_卫康叔世家.24.s7", "chapter": "037_卫康叔世家", "para": "24", "seq": 7, "text": "孙文子子数侍公饮，使师曹歌巧言之卒章。", "len": 19}
{"sid": "037_卫康叔世家.24.s8", "chapter": "037_卫康叔世家", "para": "24", "seq": 8, "text": "师曹又怒公之尝笞三百，乃歌之，欲以怒孙文子，报卫献公。", "len": 27}
{"sid": "037_卫康叔世家.24.s9", "chapter": "037_卫康叔世家", "para": "24", "seq": 9, "text": "文子语蘧伯玉，伯玉曰：“臣不知也。", "len": 17}
{"sid": "037_卫康叔世家.24.s10", "chapter": "037_卫康叔世家", "para": "24", "seq": 10, "text": "” 遂攻出献公。", "len": 8}
{"sid": "037_卫康叔世家.24.s11", "chapter": "037_卫康叔世家", "para": "24", "seq": 11, "text": "献公奔齐，齐置卫献公於聚邑。", "len": 14}
{"sid": "037_卫康叔世家.24.s12", "chapter": "037_卫康叔世家", "para": "24", "seq": 12, "text": "孙文子、甯惠子共立定公弟秋为卫君，是为殇公。", "len": 22}
{"sid": "037_卫康叔世家.25.s1", "chapter": "037_卫康叔世家", "para": "25", "seq": 1, "text": "殇公秋立，封孙文子林父於宿。", "len": 14}
{"sid": "037_卫康叔世家.25.s2", "chapter": "037_卫康叔世家", "para": "25", "seq": 2, "text": "十二年，甯喜与孙林父争宠相恶，殇公使甯喜攻孙林父。", "len": 25}
{"sid": "037_卫康叔世家.25.s3", "chapter": "037_卫康叔世家", "para": "25", "seq": 3, "text": "林父奔晋，复求入故卫献公。", "len": 13}
{"sid": "037_卫康叔世家.25.s4", "chapter": "037_卫康叔世家", "para": "25", "seq": 4, "text": "献公在齐，齐景公闻之，与卫献公如晋求入。", "len": 20}
{"sid": "037_卫康叔世家.25.s5", "chapter": "037_卫康叔世家", "para": "25", "seq": 5, "text": "晋为伐卫，诱与盟。", "len": 9}
{"sid": "037_卫康叔世家.25.s6", "chapter": "037_卫康叔世家", "para": "25", "seq": 6, "text": "卫殇公会晋平公，平公执殇公与甯喜而复入卫献公。", "len": 23}
{"sid": "037_卫康叔世家.25.s7", "chapter": "037_卫康叔世家", "para": "25", "seq": 7, "text": "献公亡在外十二年而入。", "len": 11}
{"sid": "037_卫康叔世家.26.s1", "chapter": "037_卫康叔世家", "para": "26", "seq": 1, "text": "献公後元年，诛甯喜。", "len": 10}
{"sid": "037_卫康叔世家.27.s1", "chapter": "037_卫康叔世家", "para": "27", "seq": 1, "text": "三年，吴延陵季子使过卫，见蘧伯玉、史鰌，曰：“卫多君子，其国无故。", "len": 33}
{"sid": "037_卫康叔世家.27.s2", "chapter": "037_卫康叔世家", "para": "27", "seq": 2, "text": "” 过宿，孙林父为击磬，曰：“不乐，音大悲，使卫乱乃此矣。", "len": 29}
{"sid": "037_卫康叔世家.27.s3", "chapter": "037_卫康叔世家", "para": "27", "seq": 3, "text": "” 是年，献公卒，子襄公恶立。", "len": 15}
{"sid": "037_卫康叔世家.28.s1", "chapter": "037_卫康叔世家", "para": "28", "seq": 1, "text": "襄公六年，楚灵王会诸侯，襄公称病不往。", "len": 19}
{"sid": "037_卫康叔世家.29.s1", "chapter": "037_卫康叔世家", "para": "29", "seq": 1, "text": "九年，襄公卒。", "len": 7}
{"sid": "037_卫康叔世家.29.s2", "chapter": "037_卫康叔世家", "para": "29", "seq": 2, "text": "初，襄公有贱妾，幸之，有身，梦有人谓曰：“我康叔也，令若子必有卫，名而子曰’元’。", "len": 41}
{"sid": "037_卫康叔世家.29.s3", "chapter": "037_卫康叔世家", "para": "29", "seq": 3, "text": "” 妾怪之，问孔成子。", "len": 11}
{"sid": "037_卫康叔世家.29.s4", "chapter": "037_卫康叔世家", "para": "29", "seq": 4, "text": "成子曰：“康叔者，卫祖也。", "len": 13}
{"sid": "037_卫康叔世家.29.s5", "chapter": "037_卫康叔世家", "para": "29", "seq": 5, "text": "” 及生子，男也，以告襄公。", "len": 14}
{"sid": "037_卫康叔世家.29.s6", "chapter": "037_卫康叔世家", "para": "29", "seq": 6, "text": "襄公曰：“天所置也。", "len": 10}
{"sid": "037_卫康叔世家.29.s7", "chapter": "037_卫康叔世家", "para": "29", "seq": 7, "text": "” 名之曰元。", "len": 7}
{"sid": "037_卫康叔世家.29.s8", "chapter": "037_卫康叔世家", "para": "29", "seq": 8, "text": "襄公夫人无子，於是乃立元为嗣，是为灵公。", "len": 20}
{"sid": "037_卫康叔世家.30.s1", "chapter": "037_卫康叔世家", "para": "30", "seq": 1, "text": "灵公五年，朝晋昭公。", "len": 10}
{"sid": "037_卫康叔世家.30.s2", "chapter": "037_卫康叔世家", "para": "30", "seq": 2, "text": "六年，楚公子弃疾弑灵王自立，为平王。", "len": 18}
{"sid": "037_卫康叔世家.30.s3", "chapter": "037_卫康叔世家", "para": "30", "seq": 3, "text": "十一年，火。", "len": 6}
{"sid": "037_卫康叔世家.31.s1", "chapter": "037_卫康叔世家", "para": "31", "seq": 1, "text": "三十八年，孔子来，禄之如鲁。", "len": 14}
{"sid": "037_卫康叔世家.31.s2", "chapter": "037_卫康叔世家", "para": "31", "seq": 2, "text": "後有隙，孔子去。", "len": 8}
{"sid": "037_卫康叔世家.31.s3", "chapter": "037_卫康叔世家", "para": "31", "seq": 3, "text": "後复来。", "len": 4}
{"sid": "037_卫康叔世家.32.s1", "chapter": "037_卫康叔世家", "para": "32", "seq": 1, "text": "三十九年，太子蒯聩与灵公夫人南子有恶，欲杀南子。", "len": 24}
{"sid": "037_卫康叔世家.32.s2", "chapter": "037_卫康叔世家", "para": "32", "seq": 2, "text": "蒯聩与其徒戏阳谋，朝，使杀夫人。", "len": 16}
{"sid": "037_卫康叔世家.32.s3", "chapter": "037_卫康叔世家", "para": "32", "seq": 3, "text": "戏阳後悔，不果。", "len": 8}
{"sid": "037_卫康叔世家.32.s4", "chapter": "037_卫康叔世家", "para": "32", "seq": 4, "text": "蒯聩数目之，夫人觉之，惧，呼曰：“太子欲杀我！", "len": 23}
{"sid": "037_卫康叔世家.32.s5", "chapter": "037_卫康叔世家", "para": "32", "seq": 5, "text": "” 灵公怒，太子蒯聩奔宋，已而之晋赵氏。", "len": 20}
{"sid": "037_卫康叔世家.33.s1", "chapter": "037_卫康叔世家", "para": "33", "seq": 1, "text": "四十二年春，灵公游于郊，令子郢仆。", "len": 17}
{"sid": "037_卫康叔世家.33.s2", "chapter": "037_卫康叔世家", "para": "33", "seq": 2, "text": "郢，灵公少子也，字子南。", "len": 12}
{"sid": "037_卫康叔世家.33.s3", "chapter": "037_卫康叔世家", "para": "33", "seq": 3, "text": "灵公怨太子出奔，谓郢曰：“我将立若为後。", "len": 20}
{"sid": "037_卫康叔世家.33.s4", "chapter": "037_卫康叔世家", "para": "33", "seq": 4, "text": "” 郢对曰：“郢不足以辱社稷，君更图之。", "len": 20}
{"sid": "037_卫康叔世家.33.s5", "chapter": "037_卫康叔世家", "para": "33", "seq": 5, "text": "” 夏，灵公卒，夫人命子郢为太子，曰：“此灵公命也。", "len": 26}
{"sid": "037_卫康叔世家.33.s6", "chapter": "037_卫康叔世家", "para": "33", "seq": 6, "text": "” 郢曰：“亡人太子蒯聩之子辄在也，不敢当。", "len": 22}
{"sid": "037_卫康叔世家.33.s7", "chapter": "037_卫康叔世家", "para": "33", "seq": 7, "text": "” 於是卫乃以辄为君，是为出公。", "len": 16}
{"sid": "037_卫康叔世家.34.s1", "chapter": "037_卫康叔世家", "para": "34", "seq": 1, "text": "六月乙酉，赵简子欲入蒯聩，乃令阳虎诈命卫十馀人衰绖归，简子送蒯聩。", "len": 33}
{"sid": "037_卫康叔世家.34.s2", "chapter": "037_卫康叔世家", "para": "34", "seq": 2, "text": "卫人闻之，发兵击蒯聩。", "len": 11}
{"sid": "037_卫康叔世家.34.s3", "chapter": "037_卫康叔世家", "para": "34", "seq": 3, "text": "蒯聩不得入，入宿而保，卫人亦罢兵。", "len": 17}
{"sid": "037_卫康叔世家.35.s1", "chapter": "037_卫康叔世家", "para": "35", "seq": 1, "text": "出公辄四年，齐田乞弑其君孺子。", "len": 15}
{"sid": "037_卫康叔世家.35.s2", "chapter": "037_卫康叔世家", "para": "35", "seq": 2, "text": "八年，齐鲍子弑其君悼公。", "len": 12}
{"sid": "037_卫康叔世家.36.s1", "chapter": "037_卫康叔世家", "para": "36", "seq": 1, "text": "孔子自陈入卫。", "len": 7}
{"sid": "037_卫康叔世家.36.s2", "chapter": "037_卫康叔世家", "para": "36", "seq": 2, "text": "九年，孔文子问兵於仲尼，仲尼不对。", "len": 17}
{"sid": "037_卫康叔世家.36.s3", "chapter": "037_卫康叔世家", "para": "36", "seq": 3, "text": "其後鲁迎仲尼，仲尼反鲁。", "len": 12}
{"sid": "037_卫康叔世家.37.s1", "chapter": "037_卫康叔世家", "para": "37", "seq": 1, "text": "十二年，初，孔圉文子取太子蒯聩之姊，生悝。", "len": 21}
{"sid": "037_卫康叔世家.37.s2", "chapter": "037_卫康叔世家", "para": "37", "seq": 2, "text": "孔氏之竖浑良夫美好，孔文子卒，良夫通於悝母。", "len": 22}
{"sid": "037_卫康叔世家.37.s3", "chapter": "037_卫康叔世家", "para": "37", "seq": 3, "text": "太子在宿，悝母使良夫於太子。", "len": 14}
{"sid": "037_卫康叔世家.37.s4", "chapter": "037_卫康叔世家", "para": "37", "seq": 4, "text": "太子与良夫言曰：“苟能入我国，报子以乘轩，免子三死，毋所与。", "len": 30}
{"sid": "037_卫康叔世家.37.s5", "chapter": "037_卫康叔世家", "para": "37", "seq": 5, "text": "” 与之盟，许以悝母为妻。", "len": 13}
{"sid": "037_卫康叔世家.37.s6", "chapter": "037_卫康叔世家", "para": "37", "seq": 6, "text": "闰月，良夫与太子入，舍孔氏之外圃。", "len": 17}
{"sid": "037_卫康叔世家.37.s7", "chapter": "037_卫康叔世家", "para": "37", "seq": 7, "text": "昏，二人蒙衣而乘，宦者罗御，如孔氏。", "len": 18}
{"sid": "037_卫康叔世家.37.s8", "chapter": "037_卫康叔世家", "para": "37", "seq": 8, "text": "孔氏之老栾甯问之，称姻妾以告。", "len": 15}
{"sid": "037_卫康叔世家.37.s9", "chapter": "037_卫康叔世家", "para": "37", "seq": 9, "text": "遂入，適伯姬氏。", "len": 8}
{"sid": "037_卫康叔世家.37.s10", "chapter": "037_卫康叔世家", "para": "37", "seq": 10, "text": "既食，悝母杖戈而先，太子与五人介，舆猳从之。", "len": 22}
{"sid": "037_卫康叔世家.37.s11", "chapter": "037_卫康叔世家", "para": "37", "seq": 11, "text": "伯姬劫悝於厕，彊盟之，遂劫以登台。", "len": 17}
{"sid": "037_卫康叔世家.37.s12", "chapter": "037_卫康叔世家", "para": "37", "seq": 12, "text": "栾甯将饮酒，炙未熟，闻乱，使告仲由。", "len": 18}
{"sid": "037_卫康叔世家.37.s13", "chapter": "037_卫康叔世家", "para": "37", "seq": 13, "text": "召护驾乘车，行爵食炙，奉出公辄奔鲁。", "len": 18}
{"sid": "037_卫康叔世家.38.s1", "chapter": "037_卫康叔世家", "para": "38", "seq": 1, "text": "仲由将入，遇子羔将出，曰：“门已闭矣。", "len": 19}
{"sid": "037_卫康叔世家.38.s2", "chapter": "037_卫康叔世家", "para": "38", "seq": 2, "text": "” 子路曰：“吾姑至矣。", "len": 12}
{"sid": "037_卫康叔世家.38.s3", "chapter": "037_卫康叔世家", "para": "38", "seq": 3, "text": "” 子羔曰：“不及，莫践其难。", "len": 15}
{"sid": "037_卫康叔世家.38.s4", "chapter": "037_卫康叔世家", "para": "38", "seq": 4, "text": "” 子路曰：“食焉不辟其难。", "len": 14}
{"sid": "037_卫康叔世家.38.s5", "chapter": "037_卫康叔世家", "para": "38", "seq": 5, "text": "” 子羔遂出。", "len": 7}
{"sid": "037_卫康叔世家.38.s6", "chapter": "037_卫康叔世家", "para": "38", "seq": 6, "text": "子路入，及门，公孙敢阖门，曰：“毋入为也！", "len": 21}
{"sid": "037_卫康叔世家.38.s7", "chapter": "037_卫康叔世家", "para": "38", "seq": 7, "text": "” 子路曰：“是公孙也？", "len": 12}
{"sid": "037_卫康叔世家.38.s8", "chapter": "037_卫康叔世家", "para": "38", "seq": 8, "text": "求利而逃其难。", "len": 7}
{"sid": "037_卫康叔世家.38.s9", "chapter": "037_卫康叔世家", "para": "38", "seq": 9, "text": "由不然，利其禄，必救其患。", "len": 13}
{"sid": "037_卫康叔世家.38.s10", "chapter": "037_卫康叔世家", "para": "38", "seq": 10, "text": "” 有使者出，子路乃得入。", "len": 13}
{"sid": "037_卫康叔世家.38.s11", "chapter": "037_卫康叔世家", "para": "38", "seq": 11, "text": "曰：“太子焉用孔悝？", "len": 10}
{"sid": "037_卫康叔世家.38.s12", "chapter": "037_卫康叔世家", "para": "38", "seq": 12, "text": "虽杀之，必或继之。", "len": 9}
{"sid": "037_卫康叔世家.38.s13", "chapter": "037_卫康叔世家", "para": "38", "seq": 13, "text": "” 且曰：“太子无勇。", "len": 11}
{"sid": "037_卫康叔世家.38.s14", "chapter": "037_卫康叔世家", "para": "38", "seq": 14, "text": "若燔台，必舍孔叔。", "len": 9}
{"sid": "037_卫康叔世家.38.s15", "chapter": "037_卫康叔世家", "para": "38", "seq": 15, "text": "” 太子闻之，惧，下石乞、盂黡敌子路，以戈击之，割缨。", "len": 27}
{"sid": "037_卫康叔世家.38.s16", "chapter": "037_卫康叔世家", "para": "38", "seq": 16, "text": "子路曰：“君子死，冠不免。", "len": 13}
{"sid": "037_卫康叔世家.38.s17", "chapter": "037_卫康叔世家", "para": "38", "seq": 17, "text": "” 结缨而死。", "len": 7}
{"sid": "037_卫康叔世家.38.s18", "chapter": "037_卫康叔世家", "para": "38", "seq": 18, "text": "孔子闻卫乱，曰：“嗟乎！", "len": 12}
{"sid": "037_卫康叔世家.38.s19", "chapter": "037_卫康叔世家", "para": "38", "seq": 19, "text": "柴也其来乎？", "len": 6}
{"sid": "037_卫康叔世家.38.s20", "chapter": "037_卫康叔世家", "para": "38", "seq": 20, "text": "由也其死矣。", "len": 6}
{"sid": "037_卫康叔世家.38.s21", "chapter": "037_卫康叔世家", "para": "38", "seq": 21, "text": "” 孔悝竟立太子蒯聩，是为庄公。", "len": 16}
{"sid": "037_卫康叔世家.39.s1", "chapter": "037_卫康叔世家", "para": "39", "seq": 1, "text": "庄公蒯聩者，出公父也，居外，怨大夫莫迎立。", "len": 21}
{"sid": "037_卫康叔世家.39.s2", "chapter": "037_卫康叔世家", "para": "39", "seq": 2, "text": "元年即位，欲尽诛大臣，曰：“寡人居外久矣，子亦尝闻之乎？", "len": 28}
{"sid": "037_卫康叔世家.39.s3", "chapter": "037_卫康叔世家", "para": "39", "seq": 3, "text": "” 群臣欲作乱，乃止。", "len": 11}
{"sid": "037_卫康叔世家.40.s1", "chapter": "037_卫康叔世家", "para": "40", "seq": 1, "text": "二年，鲁孔丘卒。", "len": 8}
{"sid": "037_卫康叔世家.41.s1", "chapter": "037_卫康叔世家", "para": "41", "seq": 1, "text": "三年，庄公上城，见戎州。", "len": 12}
{"sid": "037_卫康叔世家.41.s2", "chapter": "037_卫康叔世家", "para": "41", "seq": 2, "text": "曰：“戎虏何为是？", "len": 9}
{"sid": "037_卫康叔世家.41.s3", "chapter": "037_卫康叔世家", "para": "41", "seq": 3, "text": "” 戎州病之。", "len": 7}
{"sid": "037_卫康叔世家.41.s4", "chapter": "037_卫康叔世家", "para": "41", "seq": 4, "text": "十月，戎州告赵简子，简子围卫。", "len": 15}
{"sid": "037_卫康叔世家.41.s5", "chapter": "037_卫康叔世家", "para": "41", "seq": 5, "text": "十一月，庄公出奔，卫人立公子斑师为卫君。", "len": 20}
{"sid": "037_卫康叔世家.41.s6", "chapter": "037_卫康叔世家", "para": "41", "seq": 6, "text": "齐伐卫，虏斑师，更立公子起为卫君。", "len": 17}
{"sid": "037_卫康叔世家.42.s1", "chapter": "037_卫康叔世家", "para": "42", "seq": 1, "text": "卫君起元年，卫石曼尃逐其君起，起奔齐。", "len": 19}
{"sid": "037_卫康叔世家.42.s2", "chapter": "037_卫康叔世家", "para": "42", "seq": 2, "text": "卫出公辄自齐复归立。", "len": 10}
{"sid": "037_卫康叔世家.42.s3", "chapter": "037_卫康叔世家", "para": "42", "seq": 3, "text": "初，出公立十二年亡，亡在外四年复入。", "len": 18}
{"sid": "037_卫康叔世家.42.s4", "chapter": "037_卫康叔世家", "para": "42", "seq": 4, "text": "出公後元年，赏从亡者。", "len": 11}
{"sid": "037_卫康叔世家.42.s5", "chapter": "037_卫康叔世家", "para": "42", "seq": 5, "text": "立二十一年卒，出公季父黔攻出公子而自立，是为悼公。", "len": 25}
{"sid": "037_卫康叔世家.43.s1", "chapter": "037_卫康叔世家", "para": "43", "seq": 1, "text": "悼公五年卒，子敬公弗立。", "len": 12}
{"sid": "037_卫康叔世家.43.s2", "chapter": "037_卫康叔世家", "para": "43", "seq": 2, "text": "敬公十九年卒，子昭公纠立。", "len": 13}
{"sid": "037_卫康叔世家.43.s3", "chapter": "037_卫康叔世家", "para": "43", "seq": 3, "text": "是时三晋彊，卫如小侯，属之。", "len": 14}
{"sid": "037_卫康叔世家.44.s1", "chapter": "037_卫康叔世家", "para": "44", "seq": 1, "text": "昭公六年，公子亹弑之代立，是为怀公。", "len": 18}
{"sid": "037_卫康叔世家.44.s2", "chapter": "037_卫康叔世家", "para": "44", "seq": 2, "text": "怀公十一年，公子穨弑怀公而代立，是为慎公。", "len": 21}
{"sid": "037_卫康叔世家.44.s3", "chapter": "037_卫康叔世家", "para": "44", "seq": 3, "text": "慎公父，公子適；適父，敬公也。", "len": 15}
{"sid": "037_卫康叔世家.44.s4", "chapter": "037_卫康叔世家", "para": "44", "seq": 4, "text": "慎公四十二年卒，子声公训立。", "len": 14}
{"sid": "037_卫康叔世家.44.s5", "chapter": "037_卫康叔世家", "para": "44", "seq": 5, "text": "声公十一年卒，子成侯立。", "len": 12}
{"sid": "037_卫康叔世家.45.s1", "chapter": "037_卫康叔世家", "para": "45", "seq": 1, "text": "成侯十一年，公孙鞅入秦。", "len": 12}
{"sid": "037_卫康叔世家.45.s2", "chapter": "037_卫康叔世家", "para": "45", "seq": 2, "text": "十六年，卫更贬号曰侯。", "len": 11}
{"sid": "037_卫康叔世家.46.s1", "chapter": "037_卫康叔世家", "para": "46", "seq": 1, "text": "二十九年，成侯卒，子平侯立。", "len": 14}
{"sid": "037_卫康叔世家.46.s2", "chapter": "037_卫康叔世家", "para": "46", "seq": 2, "text": "平侯八年卒，子嗣君立。", "len": 11}
{"sid": "037_卫康叔世家.47.s1", "chapter": "037_卫康叔世家", "para": "47", "seq": 1, "text": "嗣君五年，更贬号曰君，独有濮阳。", "len": 16}
{"sid": "037_卫康叔世家.48.s1", "chapter": "037_卫康叔世家", "para": "48", "seq": 1, "text": "四十二年卒，子怀君立。", "len": 11}
{"sid": "037_卫康叔世家.48.s2", "chapter": "037_卫康叔世家", "para": "48", "seq": 2, "text": "怀君三十一年，朝魏，魏囚杀怀君。", "len": 16}
{"sid": "037_卫康叔世家.48.s3", "chapter": "037_卫康叔世家", "para": "48", "seq": 3, "text": "魏更立嗣君弟，是为元君。", "len": 12}
{"sid": "037_卫康叔世家.48.s4", "chapter": "037_卫康叔世家", "para": "48", "seq": 4, "text": "元君为魏婿，故魏立之。", "len": 11}
{"sid": "037_卫康叔世家.48.s5", "chapter": "037_卫康叔世家", "para": "48", "seq": 5, "text": "元君十四年，秦拔魏东地，秦初置东郡，更徙卫野王县，而并濮阳为东郡。", "len": 33}
{"sid": "037_卫康叔世家.48.s6", "chapter": "037_卫康叔世家", "para": "48", "seq": 6, "text": "二十五年，元君卒，子君角立。", "len": 14}
{"sid": "037_卫康叔世家.49.s1", "chapter": "037_卫康叔世家", "para": "49", "seq": 1, "text": "君角九年，秦并天下，立为始皇帝。", "len": 16}
{"sid": "037_卫康叔世家.49.s2", "chapter": "037_卫康叔世家", "para": "49", "seq": 2, "text": "二十一年，二世废君角为庶人，卫绝祀。", "len": 18}
{"sid": "037_卫康叔世家.49.s3", "chapter": "037_卫康叔世家", "para": "49", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "037_卫康叔世家.50.s1", "chapter": "037_卫康叔世家", "para": "50", "seq": 1, "text": "太史公曰：余读世家言，至於宣公之太子以妇见诛，弟寿争死以相让，此与晋太子申生不敢明骊姬之过同，俱恶伤父之志。", "len": 54}
{"sid": "037_卫康叔世家.50.s2", "chapter": "037_卫康叔世家", "para": "50", "seq": 2, "text": "然卒死亡，何其悲也！", "len": 10}
{"sid": "037_卫康叔世家.50.s3", "chapter": "037_卫康叔世家", "para": "50", "seq": 3, "text": "或父子相杀，兄弟相灭，亦独何哉？", "len": 16}
{"sid": "037_卫康叔世家.50.s4", "chapter": "037_卫康叔世家", "para": "50", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "037_卫康叔世家.51.s1", "chapter": "037_卫康叔世家", "para": "51", "seq": 1, "text": "司寇受封，梓材有作。", "len": 10}
{"sid": "037_卫康叔世家.51.s2", "chapter": "037_卫康叔世家", "para": "51", "seq": 2, "text": "成锡厥器，夷加其爵。", "len": 10}
{"sid": "037_卫康叔世家.51.s3", "chapter": "037_卫康叔世家", "para": "51", "seq": 3, "text": "暨武能脩，从文始约。", "len": 10}
{"sid": "037_卫康叔世家.51.s4", "chapter": "037_卫康叔世家", "para": "51", "seq": 4, "text": "诗美归燕，传矜石碏。", "len": 10}
{"sid": "037_卫康叔世家.51.s5", "chapter": "037_卫康叔世家", "para": "51", "seq": 5, "text": "皮冠射鸿，乘轩使穀。", "len": 10}
{"sid": "037_卫康叔世家.51.s6", "chapter": "037_卫康叔世家", "para": "51", "seq": 6, "text": "宣纵淫嬖，衅生伋、朔。", "len": 11}
{"sid": "037_卫康叔世家.51.s7", "chapter": "037_卫康叔世家", "para": "51", "seq": 7, "text": "蒯聩得罪，出公行恶。", "len": 10}
{"sid": "037_卫康叔世家.51.s8", "chapter": "037_卫康叔世家", "para": "51", "seq": 8, "text": "卫祚日衰，失於君角。", "len": 10}
{"sid": "037_卫康叔世家.51.s9", "chapter": "037_卫康叔世家", "para": "51", "seq": 9, "text": ":::", "len": 3}
