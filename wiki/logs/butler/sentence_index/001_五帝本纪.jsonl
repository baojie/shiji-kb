{"sid": "001_五帝本纪.1.s1", "chapter": "001_五帝本纪", "para": "1", "seq": 1, "text": "黄帝者，少典之子，姓公孙，名曰轩辕。", "len": 18}
{"sid": "001_五帝本纪.1.s2", "chapter": "001_五帝本纪", "para": "1", "seq": 2, "text": "生而神灵，弱而能言，幼而徇齐，长而敦敏，成而聪明。", "len": 25}
{"sid": "001_五帝本纪.1.1.s1", "chapter": "001_五帝本纪", "para": "1.1", "seq": 1, "text": "轩辕之时，神农氏世衰。", "len": 11}
{"sid": "001_五帝本纪.1.1.s2", "chapter": "001_五帝本纪", "para": "1.1", "seq": 2, "text": "诸侯相侵伐，暴虐百姓，而神农氏弗能征。", "len": 19}
{"sid": "001_五帝本纪.1.1.s3", "chapter": "001_五帝本纪", "para": "1.1", "seq": 3, "text": "於是轩辕乃习用干戈，以征不享，诸侯咸来宾从。", "len": 22}
{"sid": "001_五帝本纪.1.1.s4", "chapter": "001_五帝本纪", "para": "1.1", "seq": 4, "text": "而蚩尤最为暴，莫能伐。", "len": 11}
{"sid": "001_五帝本纪.1.1.s5", "chapter": "001_五帝本纪", "para": "1.1", "seq": 5, "text": "炎帝欲侵陵诸侯，诸侯咸归轩辕。", "len": 15}
{"sid": "001_五帝本纪.1.1.s6", "chapter": "001_五帝本纪", "para": "1.1", "seq": 6, "text": "轩辕乃修德振兵，治五气，蓺五种，抚万民，度四方，教熊罴貔貅貙虎，以与炎帝战於阪泉之野。", "len": 43}
{"sid": "001_五帝本纪.1.1.s7", "chapter": "001_五帝本纪", "para": "1.1", "seq": 7, "text": "三战，然後得其志。", "len": 9}
{"sid": "001_五帝本纪.1.2.s1", "chapter": "001_五帝本纪", "para": "1.2", "seq": 1, "text": "蚩尤作乱，不用帝命。", "len": 10}
{"sid": "001_五帝本纪.1.2.s2", "chapter": "001_五帝本纪", "para": "1.2", "seq": 2, "text": "於是黄帝乃徵师诸侯，与蚩尤战於涿鹿之野，遂擒杀蚩尤。", "len": 26}
{"sid": "001_五帝本纪.1.3.s1", "chapter": "001_五帝本纪", "para": "1.3", "seq": 1, "text": "而诸侯咸尊轩辕为天子，代神农氏，是为黄帝。", "len": 21}
{"sid": "001_五帝本纪.1.3.s2", "chapter": "001_五帝本纪", "para": "1.3", "seq": 2, "text": "天下有不顺者，黄帝从而征之，平者去之，披山通道，未尝宁居。", "len": 29}
{"sid": "001_五帝本纪.2.s1", "chapter": "001_五帝本纪", "para": "2", "seq": 1, "text": "东至于海，登丸山，及岱宗。", "len": 13}
{"sid": "001_五帝本纪.2.s2", "chapter": "001_五帝本纪", "para": "2", "seq": 2, "text": "西至于空桐，登鸡头。", "len": 10}
{"sid": "001_五帝本纪.2.s3", "chapter": "001_五帝本纪", "para": "2", "seq": 3, "text": "南至于江，登熊、湘。", "len": 10}
{"sid": "001_五帝本纪.2.s4", "chapter": "001_五帝本纪", "para": "2", "seq": 4, "text": "北逐荤粥，合符釜山，而邑于涿鹿之阿。", "len": 18}
{"sid": "001_五帝本纪.3.s1", "chapter": "001_五帝本纪", "para": "3", "seq": 1, "text": "迁徙往来无常处，以师兵为营卫。", "len": 15}
{"sid": "001_五帝本纪.3.s2", "chapter": "001_五帝本纪", "para": "3", "seq": 2, "text": "官名皆以云命，为云师。", "len": 11}
{"sid": "001_五帝本纪.3.s3", "chapter": "001_五帝本纪", "para": "3", "seq": 3, "text": "置左右大监，监于万国。", "len": 11}
{"sid": "001_五帝本纪.3.s4", "chapter": "001_五帝本纪", "para": "3", "seq": 4, "text": "万国和，而鬼神山川封禅与为多焉。", "len": 16}
{"sid": "001_五帝本纪.3.s5", "chapter": "001_五帝本纪", "para": "3", "seq": 5, "text": "获宝鼎，迎日推策。", "len": 9}
{"sid": "001_五帝本纪.3.s6", "chapter": "001_五帝本纪", "para": "3", "seq": 6, "text": "举风后、力牧、常先、大鸿以治民。", "len": 16}
{"sid": "001_五帝本纪.3.s7", "chapter": "001_五帝本纪", "para": "3", "seq": 7, "text": "顺天地之纪，幽明之占，死生之说，存亡之难。", "len": 21}
{"sid": "001_五帝本纪.3.s8", "chapter": "001_五帝本纪", "para": "3", "seq": 8, "text": "时播百穀草木，淳化鸟兽蟲蛾，旁罗日月星辰水波土石金玉，劳勤心力耳目，节用水火材物。", "len": 41}
{"sid": "001_五帝本纪.3.s9", "chapter": "001_五帝本纪", "para": "3", "seq": 9, "text": "有土德之瑞，故号黄帝。", "len": 11}
{"sid": "001_五帝本纪.4.s1", "chapter": "001_五帝本纪", "para": "4", "seq": 1, "text": "黄帝二十五子，其得姓者十四人。", "len": 15}
{"sid": "001_五帝本纪.4.1.s1", "chapter": "001_五帝本纪", "para": "4.1", "seq": 1, "text": "黄帝居轩辕之丘，而娶於西陵之女，是为嫘祖。", "len": 21}
{"sid": "001_五帝本纪.4.1.s2", "chapter": "001_五帝本纪", "para": "4.1", "seq": 2, "text": "嫘祖为黄帝正妃，生二子，其後皆有天下： 其一曰玄嚣，是为青阳，青阳降居江水； 其二曰昌意，降居若水。", "len": 50}
{"sid": "001_五帝本纪.4.1.s3", "chapter": "001_五帝本纪", "para": "4.1", "seq": 3, "text": "昌意娶蜀山氏女，曰昌仆，生高阳，高阳有圣德焉。", "len": 23}
{"sid": "001_五帝本纪.4.2.s1", "chapter": "001_五帝本纪", "para": "4.2", "seq": 1, "text": "黄帝崩，葬桥山。", "len": 8}
{"sid": "001_五帝本纪.4.2.s2", "chapter": "001_五帝本纪", "para": "4.2", "seq": 2, "text": "其孙昌意之子高阳立，是为帝颛顼也。", "len": 17}
{"sid": "001_五帝本纪.5.s1", "chapter": "001_五帝本纪", "para": "5", "seq": 1, "text": "帝颛顼高阳者，黄帝之孙而昌意之子也。", "len": 18}
{"sid": "001_五帝本纪.5.s2", "chapter": "001_五帝本纪", "para": "5", "seq": 2, "text": "静渊以有谋，疏通而知事；养材以任地，载时以象天，依鬼神以制义，治气以教化，絜诚以祭祀。", "len": 43}
{"sid": "001_五帝本纪.5.s3", "chapter": "001_五帝本纪", "para": "5", "seq": 3, "text": "北至于幽陵， 南至于交阯， 西至于流沙， 东至于蟠木。", "len": 27}
{"sid": "001_五帝本纪.5.s4", "chapter": "001_五帝本纪", "para": "5", "seq": 4, "text": "动静之物，大小之神，日月所照，莫不砥属。", "len": 20}
{"sid": "001_五帝本纪.6.s1", "chapter": "001_五帝本纪", "para": "6", "seq": 1, "text": "帝颛顼生子曰穷蝉。", "len": 9}
{"sid": "001_五帝本纪.6.s2", "chapter": "001_五帝本纪", "para": "6", "seq": 2, "text": "颛顼崩，而玄嚣之孙高辛立，是为帝喾。", "len": 18}
{"sid": "001_五帝本纪.7.s1", "chapter": "001_五帝本纪", "para": "7", "seq": 1, "text": "帝喾高辛者，黄帝之曾孙也。", "len": 13}
{"sid": "001_五帝本纪.7.s2", "chapter": "001_五帝本纪", "para": "7", "seq": 2, "text": "高辛父曰蟜极，蟜极父曰玄嚣，玄嚣父曰黄帝。", "len": 21}
{"sid": "001_五帝本纪.7.s3", "chapter": "001_五帝本纪", "para": "7", "seq": 3, "text": "自玄嚣与蟜极皆不得在位，至高辛即帝位。", "len": 19}
{"sid": "001_五帝本纪.7.s4", "chapter": "001_五帝本纪", "para": "7", "seq": 4, "text": "高辛於颛顼为族子。", "len": 9}
{"sid": "001_五帝本纪.8.s1", "chapter": "001_五帝本纪", "para": "8", "seq": 1, "text": "高辛生而神灵，自言其名。", "len": 12}
{"sid": "001_五帝本纪.8.s2", "chapter": "001_五帝本纪", "para": "8", "seq": 2, "text": "普施利物，不於其身。", "len": 10}
{"sid": "001_五帝本纪.8.s3", "chapter": "001_五帝本纪", "para": "8", "seq": 3, "text": "聪以知远，明以察微。", "len": 10}
{"sid": "001_五帝本纪.8.s4", "chapter": "001_五帝本纪", "para": "8", "seq": 4, "text": "顺天之义，知民之急。", "len": 10}
{"sid": "001_五帝本纪.8.s5", "chapter": "001_五帝本纪", "para": "8", "seq": 5, "text": "仁而威，惠而信，脩身而天下服。", "len": 15}
{"sid": "001_五帝本纪.8.s6", "chapter": "001_五帝本纪", "para": "8", "seq": 6, "text": "取地之财而节用之， 抚教万民而利诲之， 历日月而迎送之， 明鬼神而敬事之。", "len": 37}
{"sid": "001_五帝本纪.8.s7", "chapter": "001_五帝本纪", "para": "8", "seq": 7, "text": "其色郁郁，其德嶷嶷。", "len": 10}
{"sid": "001_五帝本纪.8.s8", "chapter": "001_五帝本纪", "para": "8", "seq": 8, "text": "其动也时，其服也士。", "len": 10}
{"sid": "001_五帝本纪.8.s9", "chapter": "001_五帝本纪", "para": "8", "seq": 9, "text": "帝喾溉执中而遍天下，日月所照，风雨所至，莫不从服。", "len": 25}
{"sid": "001_五帝本纪.9.s1", "chapter": "001_五帝本纪", "para": "9", "seq": 1, "text": "帝喾娶陈锋氏女，生放勋。", "len": 12}
{"sid": "001_五帝本纪.9.s2", "chapter": "001_五帝本纪", "para": "9", "seq": 2, "text": "娶娵訾氏女，生挚。", "len": 9}
{"sid": "001_五帝本纪.9.s3", "chapter": "001_五帝本纪", "para": "9", "seq": 3, "text": "帝喾崩，而挚代立。", "len": 9}
{"sid": "001_五帝本纪.9.s4", "chapter": "001_五帝本纪", "para": "9", "seq": 4, "text": "帝挚立，不善，而弟放勋立，是为帝尧。", "len": 18}
{"sid": "001_五帝本纪.10.s1", "chapter": "001_五帝本纪", "para": "10", "seq": 1, "text": "帝尧者，放勋。", "len": 7}
{"sid": "001_五帝本纪.10.s2", "chapter": "001_五帝本纪", "para": "10", "seq": 2, "text": "其仁如天，其知如神。", "len": 10}
{"sid": "001_五帝本纪.10.s3", "chapter": "001_五帝本纪", "para": "10", "seq": 3, "text": "就之如日，望之如云。", "len": 10}
{"sid": "001_五帝本纪.10.s4", "chapter": "001_五帝本纪", "para": "10", "seq": 4, "text": "富而不骄，贵而不舒。", "len": 10}
{"sid": "001_五帝本纪.10.s5", "chapter": "001_五帝本纪", "para": "10", "seq": 5, "text": "黄收纯衣，彤车乘白马。", "len": 11}
{"sid": "001_五帝本纪.10.s6", "chapter": "001_五帝本纪", "para": "10", "seq": 6, "text": "能明驯德，以亲九族。", "len": 10}
{"sid": "001_五帝本纪.10.s7", "chapter": "001_五帝本纪", "para": "10", "seq": 7, "text": "九族既睦，便章百姓。", "len": 10}
{"sid": "001_五帝本纪.10.s8", "chapter": "001_五帝本纪", "para": "10", "seq": 8, "text": "百姓昭明，合和万国。", "len": 10}
{"sid": "001_五帝本纪.11.s1", "chapter": "001_五帝本纪", "para": "11", "seq": 1, "text": "乃命羲、和，敬顺昊天，数法日月星辰，敬授民时。", "len": 23}
{"sid": "001_五帝本纪.11.s2", "chapter": "001_五帝本纪", "para": "11", "seq": 2, "text": "[11.1] 分命羲仲，居郁夷，曰旸谷。", "len": 20}
{"sid": "001_五帝本纪.11.s3", "chapter": "001_五帝本纪", "para": "11", "seq": 3, "text": "敬道日出，便程东作。", "len": 10}
{"sid": "001_五帝本纪.11.s4", "chapter": "001_五帝本纪", "para": "11", "seq": 4, "text": "日中，星鸟，以殷中春。", "len": 11}
{"sid": "001_五帝本纪.11.s5", "chapter": "001_五帝本纪", "para": "11", "seq": 5, "text": "其民析，鸟兽字微。", "len": 9}
{"sid": "001_五帝本纪.11.s6", "chapter": "001_五帝本纪", "para": "11", "seq": 6, "text": "[11.2] 申命羲叔，居南交。", "len": 16}
{"sid": "001_五帝本纪.11.s7", "chapter": "001_五帝本纪", "para": "11", "seq": 7, "text": "便程南为，敬致。", "len": 8}
{"sid": "001_五帝本纪.11.s8", "chapter": "001_五帝本纪", "para": "11", "seq": 8, "text": "日永，星火，以正中夏。", "len": 11}
{"sid": "001_五帝本纪.11.s9", "chapter": "001_五帝本纪", "para": "11", "seq": 9, "text": "其民因，鸟兽希革。", "len": 9}
{"sid": "001_五帝本纪.11.s10", "chapter": "001_五帝本纪", "para": "11", "seq": 10, "text": "[11.3] 申命和仲，居西土，曰昧谷。", "len": 20}
{"sid": "001_五帝本纪.11.s11", "chapter": "001_五帝本纪", "para": "11", "seq": 11, "text": "敬道日入，便程西成。", "len": 10}
{"sid": "001_五帝本纪.11.s12", "chapter": "001_五帝本纪", "para": "11", "seq": 12, "text": "夜中，星虚，以正中秋。", "len": 11}
{"sid": "001_五帝本纪.11.s13", "chapter": "001_五帝本纪", "para": "11", "seq": 13, "text": "其民夷易，鸟兽毛毨。", "len": 10}
{"sid": "001_五帝本纪.11.s14", "chapter": "001_五帝本纪", "para": "11", "seq": 14, "text": "[11.4] 申命和叔；居北方，曰幽都。", "len": 20}
{"sid": "001_五帝本纪.11.s15", "chapter": "001_五帝本纪", "para": "11", "seq": 15, "text": "便在伏物。", "len": 5}
{"sid": "001_五帝本纪.11.s16", "chapter": "001_五帝本纪", "para": "11", "seq": 16, "text": "日短，星昴，以正中冬。", "len": 11}
{"sid": "001_五帝本纪.11.s17", "chapter": "001_五帝本纪", "para": "11", "seq": 17, "text": "其民燠，鸟兽氄毛。", "len": 9}
{"sid": "001_五帝本纪.11.5.s1", "chapter": "001_五帝本纪", "para": "11.5", "seq": 1, "text": "岁三百六十六日，以闰月正四时。", "len": 15}
{"sid": "001_五帝本纪.11.5.s2", "chapter": "001_五帝本纪", "para": "11.5", "seq": 2, "text": "信饬百官，众功皆兴。", "len": 10}
{"sid": "001_五帝本纪.12.s1", "chapter": "001_五帝本纪", "para": "12", "seq": 1, "text": "尧曰：“谁可顺此事？", "len": 10}
{"sid": "001_五帝本纪.12.s2", "chapter": "001_五帝本纪", "para": "12", "seq": 2, "text": "” 放齐曰：“嗣子丹硃开明。", "len": 14}
{"sid": "001_五帝本纪.12.s3", "chapter": "001_五帝本纪", "para": "12", "seq": 3, "text": "” 尧曰：“吁！", "len": 8}
{"sid": "001_五帝本纪.12.s4", "chapter": "001_五帝本纪", "para": "12", "seq": 4, "text": "顽凶，不用。", "len": 6}
{"sid": "001_五帝本纪.12.s5", "chapter": "001_五帝本纪", "para": "12", "seq": 5, "text": "” 尧又曰：“谁可者？", "len": 11}
{"sid": "001_五帝本纪.12.s6", "chapter": "001_五帝本纪", "para": "12", "seq": 6, "text": "” 讙兜曰：“共工旁聚布功，可用。", "len": 17}
{"sid": "001_五帝本纪.12.s7", "chapter": "001_五帝本纪", "para": "12", "seq": 7, "text": "” 尧曰：“共工善言，其用僻，似恭漫天，不可。", "len": 23}
{"sid": "001_五帝本纪.12.s8", "chapter": "001_五帝本纪", "para": "12", "seq": 8, "text": "” 尧又曰：“嗟，四岳，汤汤洪水滔天，浩浩怀山襄陵，下民其忧，有能使治者？", "len": 37}
{"sid": "001_五帝本纪.12.s9", "chapter": "001_五帝本纪", "para": "12", "seq": 9, "text": "” 皆曰鲧可。", "len": 7}
{"sid": "001_五帝本纪.12.s10", "chapter": "001_五帝本纪", "para": "12", "seq": 10, "text": "尧曰：“鲧负命毁族，不可。", "len": 13}
{"sid": "001_五帝本纪.12.s11", "chapter": "001_五帝本纪", "para": "12", "seq": 11, "text": "” 岳曰：“异哉，试不可用而已。", "len": 16}
{"sid": "001_五帝本纪.12.s12", "chapter": "001_五帝本纪", "para": "12", "seq": 12, "text": "” 尧於是听岳用鲧。", "len": 10}
{"sid": "001_五帝本纪.12.s13", "chapter": "001_五帝本纪", "para": "12", "seq": 13, "text": "九岁，功用不成。", "len": 8}
{"sid": "001_五帝本纪.13.1.s1", "chapter": "001_五帝本纪", "para": "13.1", "seq": 1, "text": "尧曰：“嗟！", "len": 6}
{"sid": "001_五帝本纪.13.1.s2", "chapter": "001_五帝本纪", "para": "13.1", "seq": 2, "text": "四岳：朕在位七十载，汝能庸命，践朕位？", "len": 19}
{"sid": "001_五帝本纪.13.1.s3", "chapter": "001_五帝本纪", "para": "13.1", "seq": 3, "text": "” 岳应曰：“鄙德忝帝位。", "len": 13}
{"sid": "001_五帝本纪.13.1.s4", "chapter": "001_五帝本纪", "para": "13.1", "seq": 4, "text": "” 尧曰：“悉举贵戚及疏远隐匿者。", "len": 17}
{"sid": "001_五帝本纪.13.1.s5", "chapter": "001_五帝本纪", "para": "13.1", "seq": 5, "text": "” 众皆言於尧曰：“有矜在民间，曰虞舜。", "len": 20}
{"sid": "001_五帝本纪.13.1.s6", "chapter": "001_五帝本纪", "para": "13.1", "seq": 6, "text": "” 尧曰：“然，朕闻之。", "len": 12}
{"sid": "001_五帝本纪.13.1.s7", "chapter": "001_五帝本纪", "para": "13.1", "seq": 7, "text": "其何如？", "len": 4}
{"sid": "001_五帝本纪.13.1.s8", "chapter": "001_五帝本纪", "para": "13.1", "seq": 8, "text": "” 岳曰：“盲者子。", "len": 10}
{"sid": "001_五帝本纪.13.1.s9", "chapter": "001_五帝本纪", "para": "13.1", "seq": 9, "text": "父顽，母嚚，弟傲，能和以孝，烝烝治，不至奸。", "len": 22}
{"sid": "001_五帝本纪.13.1.s10", "chapter": "001_五帝本纪", "para": "13.1", "seq": 10, "text": "” 尧曰：“吾其试哉。”", "len": 12}
{"sid": "001_五帝本纪.13.2.s1", "chapter": "001_五帝本纪", "para": "13.2", "seq": 1, "text": "於是尧妻之二女，观其德於二女。", "len": 15}
{"sid": "001_五帝本纪.13.2.s2", "chapter": "001_五帝本纪", "para": "13.2", "seq": 2, "text": "舜饬下二女於妫汭，如妇礼。", "len": 13}
{"sid": "001_五帝本纪.13.2.s3", "chapter": "001_五帝本纪", "para": "13.2", "seq": 3, "text": "尧善之，乃使舜慎和五典，五典能从。", "len": 17}
{"sid": "001_五帝本纪.13.2.s4", "chapter": "001_五帝本纪", "para": "13.2", "seq": 4, "text": "乃遍入百官，百官时序。", "len": 11}
{"sid": "001_五帝本纪.13.2.s5", "chapter": "001_五帝本纪", "para": "13.2", "seq": 5, "text": "宾於四门，四门穆穆，诸侯远方宾客皆敬。", "len": 19}
{"sid": "001_五帝本纪.13.2.s6", "chapter": "001_五帝本纪", "para": "13.2", "seq": 6, "text": "尧使舜入山林川泽，暴风雷雨，舜行不迷。", "len": 19}
{"sid": "001_五帝本纪.13.2.s7", "chapter": "001_五帝本纪", "para": "13.2", "seq": 7, "text": "尧以为圣，召舜曰：“女谋事至而言可绩，三年矣。", "len": 23}
{"sid": "001_五帝本纪.13.2.s8", "chapter": "001_五帝本纪", "para": "13.2", "seq": 8, "text": "女登帝位。", "len": 5}
{"sid": "001_五帝本纪.13.2.s9", "chapter": "001_五帝本纪", "para": "13.2", "seq": 9, "text": "” 舜让於德不怿。", "len": 9}
{"sid": "001_五帝本纪.13.2.s10", "chapter": "001_五帝本纪", "para": "13.2", "seq": 10, "text": "正月上日，舜受终於文祖。", "len": 12}
{"sid": "001_五帝本纪.13.2.s11", "chapter": "001_五帝本纪", "para": "13.2", "seq": 11, "text": "文祖者，尧大祖也。", "len": 9}
{"sid": "001_五帝本纪.14.s1", "chapter": "001_五帝本纪", "para": "14", "seq": 1, "text": "於是帝尧老，命舜摄行天子之政，以观天命。", "len": 20}
{"sid": "001_五帝本纪.14.s2", "chapter": "001_五帝本纪", "para": "14", "seq": 2, "text": "舜乃在璿玑玉衡，以齐七政。", "len": 13}
{"sid": "001_五帝本纪.14.s3", "chapter": "001_五帝本纪", "para": "14", "seq": 3, "text": "遂类于上帝，禋于六宗，望于山川，辩于群神。", "len": 21}
{"sid": "001_五帝本纪.14.s4", "chapter": "001_五帝本纪", "para": "14", "seq": 4, "text": "揖五瑞，择吉月日，见四岳诸牧，班瑞。", "len": 18}
{"sid": "001_五帝本纪.14.1.s1", "chapter": "001_五帝本纪", "para": "14.1", "seq": 1, "text": "岁二月，东巡狩，至於岱宗，祡，望秩於山川。", "len": 21}
{"sid": "001_五帝本纪.14.1.s2", "chapter": "001_五帝本纪", "para": "14.1", "seq": 2, "text": "遂见东方君长，合时月正日，同律度量衡，脩五礼五玉三帛二生一死为挚，如五器，卒乃复。", "len": 41}
{"sid": "001_五帝本纪.14.1.s3", "chapter": "001_五帝本纪", "para": "14.1", "seq": 3, "text": "五月，南巡狩；八月，西巡狩；十一月，北巡狩：皆如初。", "len": 26}
{"sid": "001_五帝本纪.14.1.s4", "chapter": "001_五帝本纪", "para": "14.1", "seq": 4, "text": "归，至于祖祢庙，用特牛礼。", "len": 13}
{"sid": "001_五帝本纪.14.2.s1", "chapter": "001_五帝本纪", "para": "14.2", "seq": 1, "text": "五岁一巡狩，群后四朝。", "len": 11}
{"sid": "001_五帝本纪.14.2.s2", "chapter": "001_五帝本纪", "para": "14.2", "seq": 2, "text": "遍告以言，明试以功，车服以庸。", "len": 15}
{"sid": "001_五帝本纪.14.2.s3", "chapter": "001_五帝本纪", "para": "14.2", "seq": 3, "text": "肇十有二州，决川。", "len": 9}
{"sid": "001_五帝本纪.14.2.s4", "chapter": "001_五帝本纪", "para": "14.2", "seq": 4, "text": "象以典刑，流宥五刑，鞭作官刑，扑作教刑，金作赎刑。", "len": 25}
{"sid": "001_五帝本纪.14.2.s5", "chapter": "001_五帝本纪", "para": "14.2", "seq": 5, "text": "眚灾过，赦；怙终贼，刑。", "len": 12}
{"sid": "001_五帝本纪.14.2.s6", "chapter": "001_五帝本纪", "para": "14.2", "seq": 6, "text": "钦哉，钦哉，惟刑之静哉！", "len": 12}
{"sid": "001_五帝本纪.15.s1", "chapter": "001_五帝本纪", "para": "15", "seq": 1, "text": "讙兜进言共工，尧曰不可而试之工师，共工果淫辟。", "len": 23}
{"sid": "001_五帝本纪.15.s2", "chapter": "001_五帝本纪", "para": "15", "seq": 2, "text": "四岳举鲧治鸿水，尧以为不可，岳彊请试之，试之而无功，故百姓不便。", "len": 32}
{"sid": "001_五帝本纪.15.s3", "chapter": "001_五帝本纪", "para": "15", "seq": 3, "text": "三苗在江淮、荆州数为乱。", "len": 12}
{"sid": "001_五帝本纪.15.s4", "chapter": "001_五帝本纪", "para": "15", "seq": 4, "text": "於是舜归而言於帝， 请流共工於幽陵，以变北狄； 放驩兜於崇山，以变南蛮； 迁三苗於三危，以变西戎； 殛鲧於羽山，以变东夷：", "len": 61}
{"sid": "001_五帝本纪.15.1.s1", "chapter": "001_五帝本纪", "para": "15.1", "seq": 1, "text": "四罪而天下咸服。", "len": 8}
{"sid": "001_五帝本纪.16.s1", "chapter": "001_五帝本纪", "para": "16", "seq": 1, "text": "尧立七十年得舜，二十年而老，令舜摄行天子之政，荐之於天。", "len": 28}
{"sid": "001_五帝本纪.16.s2", "chapter": "001_五帝本纪", "para": "16", "seq": 2, "text": "尧辟位凡二十八年而崩。", "len": 11}
{"sid": "001_五帝本纪.16.s3", "chapter": "001_五帝本纪", "para": "16", "seq": 3, "text": "百姓悲哀，如丧父母。", "len": 10}
{"sid": "001_五帝本纪.16.s4", "chapter": "001_五帝本纪", "para": "16", "seq": 4, "text": "三年，四方莫举乐，以思尧。", "len": 13}
{"sid": "001_五帝本纪.16.1.s1", "chapter": "001_五帝本纪", "para": "16.1", "seq": 1, "text": "尧知子丹硃之不肖，不足授天下，於是乃权授舜。", "len": 22}
{"sid": "001_五帝本纪.16.1.s2", "chapter": "001_五帝本纪", "para": "16.1", "seq": 2, "text": "授舜，则天下得其利而丹硃病；授丹硃，则天下病而丹硃得其利。", "len": 29}
{"sid": "001_五帝本纪.16.1.s3", "chapter": "001_五帝本纪", "para": "16.1", "seq": 3, "text": "尧曰“终不以天下之病而利一人”，而卒授舜以天下。", "len": 24}
{"sid": "001_五帝本纪.16.2.s1", "chapter": "001_五帝本纪", "para": "16.2", "seq": 1, "text": "尧崩，三年之丧毕，舜让辟丹硃於南河之南。", "len": 20}
{"sid": "001_五帝本纪.16.2.s2", "chapter": "001_五帝本纪", "para": "16.2", "seq": 2, "text": "诸侯朝觐者不之丹硃而之舜，狱讼者不之丹硃而之舜，讴歌者不讴歌丹硃而讴歌舜。", "len": 37}
{"sid": "001_五帝本纪.16.2.s3", "chapter": "001_五帝本纪", "para": "16.2", "seq": 3, "text": "舜曰“天也”，夫而後之中国践天子位焉，是为帝舜。", "len": 24}
{"sid": "001_五帝本纪.17.s1", "chapter": "001_五帝本纪", "para": "17", "seq": 1, "text": "虞舜者，名曰重华。", "len": 9}
{"sid": "001_五帝本纪.17.s2", "chapter": "001_五帝本纪", "para": "17", "seq": 2, "text": "重华父曰瞽叟，瞽叟父曰桥牛，桥牛父曰句望，句望父曰敬康，敬康父曰穷蝉，穷蝉父曰帝颛顼，颛顼父曰昌意：以至舜七世矣。", "len": 57}
{"sid": "001_五帝本纪.17.s3", "chapter": "001_五帝本纪", "para": "17", "seq": 3, "text": "自从穷蝉以至帝舜，皆微为庶人。", "len": 15}
{"sid": "001_五帝本纪.18.s1", "chapter": "001_五帝本纪", "para": "18", "seq": 1, "text": "舜父瞽叟盲，而舜母死，瞽叟更娶妻而生象，象傲。", "len": 23}
{"sid": "001_五帝本纪.18.s2", "chapter": "001_五帝本纪", "para": "18", "seq": 2, "text": "瞽叟爱後妻子，常欲杀舜，舜避逃；及有小过，则受罪。", "len": 25}
{"sid": "001_五帝本纪.18.s3", "chapter": "001_五帝本纪", "para": "18", "seq": 3, "text": "顺事父及後母与弟，日以笃谨，匪有解。", "len": 18}
{"sid": "001_五帝本纪.19.s1", "chapter": "001_五帝本纪", "para": "19", "seq": 1, "text": "舜，冀州之人也。", "len": 8}
{"sid": "001_五帝本纪.19.s2", "chapter": "001_五帝本纪", "para": "19", "seq": 2, "text": "舜耕历山，渔雷泽，陶河滨，作什器於寿丘，就时於负夏。", "len": 26}
{"sid": "001_五帝本纪.19.s3", "chapter": "001_五帝本纪", "para": "19", "seq": 3, "text": "舜父瞽叟顽，母嚚，弟象傲，皆欲杀舜。", "len": 18}
{"sid": "001_五帝本纪.19.s4", "chapter": "001_五帝本纪", "para": "19", "seq": 4, "text": "舜顺適不失子道，兄弟孝慈。", "len": 13}
{"sid": "001_五帝本纪.19.s5", "chapter": "001_五帝本纪", "para": "19", "seq": 5, "text": "欲杀，不可得；即求，尝在侧。", "len": 14}
{"sid": "001_五帝本纪.20.s1", "chapter": "001_五帝本纪", "para": "20", "seq": 1, "text": "舜年二十以孝闻。", "len": 8}
{"sid": "001_五帝本纪.20.s2", "chapter": "001_五帝本纪", "para": "20", "seq": 2, "text": "三十而帝尧问可用者，四岳咸荐虞舜，曰可。", "len": 20}
{"sid": "001_五帝本纪.20.s3", "chapter": "001_五帝本纪", "para": "20", "seq": 3, "text": "於是尧乃以二女妻舜以观其内，使九男与处以观其外。", "len": 24}
{"sid": "001_五帝本纪.20.s4", "chapter": "001_五帝本纪", "para": "20", "seq": 4, "text": "舜居妫汭，内行弥谨。", "len": 10}
{"sid": "001_五帝本纪.20.s5", "chapter": "001_五帝本纪", "para": "20", "seq": 5, "text": "尧二女不敢以贵骄事舜亲戚，甚有妇道。", "len": 18}
{"sid": "001_五帝本纪.20.s6", "chapter": "001_五帝本纪", "para": "20", "seq": 6, "text": "尧九男皆益笃。", "len": 7}
{"sid": "001_五帝本纪.20.s7", "chapter": "001_五帝本纪", "para": "20", "seq": 7, "text": "舜耕历山，历山之人皆让畔；渔雷泽，雷泽上人皆让居；陶河滨，河滨器皆不苦窳。", "len": 37}
{"sid": "001_五帝本纪.20.s8", "chapter": "001_五帝本纪", "para": "20", "seq": 8, "text": "一年而所居成聚，二年成邑，三年成都。", "len": 18}
{"sid": "001_五帝本纪.20.s9", "chapter": "001_五帝本纪", "para": "20", "seq": 9, "text": "尧乃赐舜絺衣，与琴，为筑仓廪，予牛羊。", "len": 19}
{"sid": "001_五帝本纪.20.1.s1", "chapter": "001_五帝本纪", "para": "20.1", "seq": 1, "text": "瞽叟尚复欲杀之，使舜上涂廪，瞽叟从下纵火焚廪。", "len": 23}
{"sid": "001_五帝本纪.20.1.s2", "chapter": "001_五帝本纪", "para": "20.1", "seq": 2, "text": "舜乃以两笠自扞而下，去，得不死。", "len": 16}
{"sid": "001_五帝本纪.20.2.s1", "chapter": "001_五帝本纪", "para": "20.2", "seq": 1, "text": "後瞽叟又使舜穿井，舜穿井为匿空旁出。", "len": 18}
{"sid": "001_五帝本纪.20.2.s2", "chapter": "001_五帝本纪", "para": "20.2", "seq": 2, "text": "舜既入深，瞽叟与象共下土实井，舜从匿空出，去。", "len": 23}
{"sid": "001_五帝本纪.20.2.s3", "chapter": "001_五帝本纪", "para": "20.2", "seq": 3, "text": "瞽叟、象喜，以舜为已死。", "len": 12}
{"sid": "001_五帝本纪.20.2.s4", "chapter": "001_五帝本纪", "para": "20.2", "seq": 4, "text": "象曰：“本谋者象。", "len": 9}
{"sid": "001_五帝本纪.20.2.s5", "chapter": "001_五帝本纪", "para": "20.2", "seq": 5, "text": "” 象与其父母分，於是曰：“舜妻尧二女，与琴，象取之。", "len": 27}
{"sid": "001_五帝本纪.20.2.s6", "chapter": "001_五帝本纪", "para": "20.2", "seq": 6, "text": "牛羊仓廪予父母。", "len": 8}
{"sid": "001_五帝本纪.20.2.s7", "chapter": "001_五帝本纪", "para": "20.2", "seq": 7, "text": "” 象乃止舜宫居，鼓其琴。", "len": 13}
{"sid": "001_五帝本纪.20.2.s8", "chapter": "001_五帝本纪", "para": "20.2", "seq": 8, "text": "舜往见之。", "len": 5}
{"sid": "001_五帝本纪.20.2.s9", "chapter": "001_五帝本纪", "para": "20.2", "seq": 9, "text": "象鄂不怿，曰：“我思舜正郁陶！", "len": 15}
{"sid": "001_五帝本纪.20.2.s10", "chapter": "001_五帝本纪", "para": "20.2", "seq": 10, "text": "” 舜曰：“然，尔其庶矣！”", "len": 14}
{"sid": "001_五帝本纪.20.3.s1", "chapter": "001_五帝本纪", "para": "20.3", "seq": 1, "text": "舜复事瞽叟爱弟弥谨。", "len": 10}
{"sid": "001_五帝本纪.20.3.s2", "chapter": "001_五帝本纪", "para": "20.3", "seq": 2, "text": "於是尧乃试舜五典百官，皆治。", "len": 14}
{"sid": "001_五帝本纪.21.s1", "chapter": "001_五帝本纪", "para": "21", "seq": 1, "text": "昔高阳氏有才子八人，世得其利，谓之“八恺”。", "len": 22}
{"sid": "001_五帝本纪.21.s2", "chapter": "001_五帝本纪", "para": "21", "seq": 2, "text": "高辛氏有才子八人，世谓之“八元”。", "len": 17}
{"sid": "001_五帝本纪.21.s3", "chapter": "001_五帝本纪", "para": "21", "seq": 3, "text": "此十六族者，世济其美，不陨其名。", "len": 16}
{"sid": "001_五帝本纪.21.s4", "chapter": "001_五帝本纪", "para": "21", "seq": 4, "text": "至於尧，尧未能举。", "len": 9}
{"sid": "001_五帝本纪.21.s5", "chapter": "001_五帝本纪", "para": "21", "seq": 5, "text": "舜举八恺，使主后土，以揆百事，莫不时序。", "len": 20}
{"sid": "001_五帝本纪.21.s6", "chapter": "001_五帝本纪", "para": "21", "seq": 6, "text": "举八元，使布五教于四方，父义，母慈，兄友，弟恭，子孝，内平外成。", "len": 32}
{"sid": "001_五帝本纪.22.s1", "chapter": "001_五帝本纪", "para": "22", "seq": 1, "text": "昔帝鸿氏有不才子，掩义隐贼，好行凶慝，天下谓之浑沌。", "len": 26}
{"sid": "001_五帝本纪.22.s2", "chapter": "001_五帝本纪", "para": "22", "seq": 2, "text": "少暤氏有不才子，毁信恶忠，崇饰恶言，天下谓之穷奇。", "len": 25}
{"sid": "001_五帝本纪.22.s3", "chapter": "001_五帝本纪", "para": "22", "seq": 3, "text": "颛顼氏有不才子，不可教训，不知话言，天下谓之檮杌。", "len": 25}
{"sid": "001_五帝本纪.22.s4", "chapter": "001_五帝本纪", "para": "22", "seq": 4, "text": "此三族世忧之。", "len": 7}
{"sid": "001_五帝本纪.22.s5", "chapter": "001_五帝本纪", "para": "22", "seq": 5, "text": "至于尧，尧未能去。", "len": 9}
{"sid": "001_五帝本纪.22.s6", "chapter": "001_五帝本纪", "para": "22", "seq": 6, "text": "缙云氏有不才子，贪于饮食，冒于货贿，天下谓之饕餮。", "len": 25}
{"sid": "001_五帝本纪.22.1.s1", "chapter": "001_五帝本纪", "para": "22.1", "seq": 1, "text": "天下恶之，比之三凶。", "len": 10}
{"sid": "001_五帝本纪.22.1.s2", "chapter": "001_五帝本纪", "para": "22.1", "seq": 2, "text": "舜宾於四门，乃流四凶族，迁于四裔，以御螭魅，於是四门辟，言毋凶人也。", "len": 34}
{"sid": "001_五帝本纪.23.s1", "chapter": "001_五帝本纪", "para": "23", "seq": 1, "text": "舜入于大麓，烈风雷雨不迷，尧乃知舜之足授天下。", "len": 23}
{"sid": "001_五帝本纪.23.s2", "chapter": "001_五帝本纪", "para": "23", "seq": 2, "text": "尧老，使舜摄行天子政，巡狩。", "len": 14}
{"sid": "001_五帝本纪.23.s3", "chapter": "001_五帝本纪", "para": "23", "seq": 3, "text": "舜得举用事二十年，而尧使摄政。", "len": 15}
{"sid": "001_五帝本纪.23.s4", "chapter": "001_五帝本纪", "para": "23", "seq": 4, "text": "摄政八年而尧崩。", "len": 8}
{"sid": "001_五帝本纪.23.s5", "chapter": "001_五帝本纪", "para": "23", "seq": 5, "text": "三年丧毕，让丹硃，天下归舜。", "len": 14}
{"sid": "001_五帝本纪.23.1.s1", "chapter": "001_五帝本纪", "para": "23.1", "seq": 1, "text": "而禹、皋陶、契、后稷、伯夷、夔、龙、倕、益、彭祖自尧时而皆举用，未有分职。", "len": 37}
{"sid": "001_五帝本纪.23.1.s2", "chapter": "001_五帝本纪", "para": "23.1", "seq": 2, "text": "於是舜乃至於文祖，谋于四岳，辟四门，明通四方耳目，命十二牧论帝德，行厚德，远佞人，则蛮夷率服。", "len": 47}
{"sid": "001_五帝本纪.23.2.s1", "chapter": "001_五帝本纪", "para": "23.2", "seq": 1, "text": "舜谓四岳曰：“有能奋庸美尧之事者，使居官相事？", "len": 23}
{"sid": "001_五帝本纪.23.2.s2", "chapter": "001_五帝本纪", "para": "23.2", "seq": 2, "text": "” [23.2.1] 皆曰：“伯禹为司空，可美帝功。", "len": 26}
{"sid": "001_五帝本纪.23.2.s3", "chapter": "001_五帝本纪", "para": "23.2", "seq": 3, "text": "” 舜曰：“嗟，然！", "len": 10}
{"sid": "001_五帝本纪.23.2.s4", "chapter": "001_五帝本纪", "para": "23.2", "seq": 4, "text": "禹，汝平水土，维是勉哉。", "len": 12}
{"sid": "001_五帝本纪.23.2.s5", "chapter": "001_五帝本纪", "para": "23.2", "seq": 5, "text": "” 禹拜稽首，让於稷、契与皋陶。", "len": 16}
{"sid": "001_五帝本纪.23.2.s6", "chapter": "001_五帝本纪", "para": "23.2", "seq": 6, "text": "舜曰：“然，往矣。", "len": 9}
{"sid": "001_五帝本纪.23.2.s7", "chapter": "001_五帝本纪", "para": "23.2", "seq": 7, "text": "” [23.2.2] 舜曰：“弃，黎民始饥，汝后稷播时百穀。", "len": 30}
{"sid": "001_五帝本纪.23.2.s8", "chapter": "001_五帝本纪", "para": "23.2", "seq": 8, "text": "” [23.2.3] 舜曰：“契，百姓不亲，五品不驯，汝为司徒，而敬敷五教，在宽。", "len": 41}
{"sid": "001_五帝本纪.23.2.s9", "chapter": "001_五帝本纪", "para": "23.2", "seq": 9, "text": "” [23.2.4] 舜曰：“皋陶，蛮夷猾夏，寇贼奸轨，汝作士，五刑有服，五服三就；五流有度，五度三居：维明能信。", "len": 57}
{"sid": "001_五帝本纪.23.2.s10", "chapter": "001_五帝本纪", "para": "23.2", "seq": 10, "text": "” [23.2.5] 舜曰：“谁能驯予工？", "len": 21}
{"sid": "001_五帝本纪.23.2.s11", "chapter": "001_五帝本纪", "para": "23.2", "seq": 11, "text": "” 皆曰垂可。", "len": 7}
{"sid": "001_五帝本纪.23.2.s12", "chapter": "001_五帝本纪", "para": "23.2", "seq": 12, "text": "於是以垂为共工。", "len": 8}
{"sid": "001_五帝本纪.23.2.s13", "chapter": "001_五帝本纪", "para": "23.2", "seq": 13, "text": "[23.2.6] 舜曰：“谁能驯予上下草木鸟兽？", "len": 24}
{"sid": "001_五帝本纪.23.2.s14", "chapter": "001_五帝本纪", "para": "23.2", "seq": 14, "text": "” 皆曰益可。", "len": 7}
{"sid": "001_五帝本纪.23.2.s15", "chapter": "001_五帝本纪", "para": "23.2", "seq": 15, "text": "於是以益为朕虞。", "len": 8}
{"sid": "001_五帝本纪.23.2.s16", "chapter": "001_五帝本纪", "para": "23.2", "seq": 16, "text": "益拜稽首，让于诸臣硃虎、熊罴。", "len": 15}
{"sid": "001_五帝本纪.23.2.s17", "chapter": "001_五帝本纪", "para": "23.2", "seq": 17, "text": "舜曰：“往矣，汝谐。", "len": 10}
{"sid": "001_五帝本纪.23.2.s18", "chapter": "001_五帝本纪", "para": "23.2", "seq": 18, "text": "” 遂以硃虎、熊罴为佐。", "len": 12}
{"sid": "001_五帝本纪.23.2.s19", "chapter": "001_五帝本纪", "para": "23.2", "seq": 19, "text": "[23.2.7] 舜曰：“嗟！", "len": 15}
{"sid": "001_五帝本纪.23.2.s20", "chapter": "001_五帝本纪", "para": "23.2", "seq": 20, "text": "四岳，有能典朕三礼？", "len": 10}
{"sid": "001_五帝本纪.23.2.s21", "chapter": "001_五帝本纪", "para": "23.2", "seq": 21, "text": "” 皆曰伯夷可。", "len": 8}
{"sid": "001_五帝本纪.23.2.s22", "chapter": "001_五帝本纪", "para": "23.2", "seq": 22, "text": "舜曰：“嗟！", "len": 6}
{"sid": "001_五帝本纪.23.2.s23", "chapter": "001_五帝本纪", "para": "23.2", "seq": 23, "text": "伯夷，以汝为秩宗，夙夜维敬，直哉维静絜。", "len": 20}
{"sid": "001_五帝本纪.23.2.s24", "chapter": "001_五帝本纪", "para": "23.2", "seq": 24, "text": "” 伯夷让夔、龙。", "len": 9}
{"sid": "001_五帝本纪.23.2.s25", "chapter": "001_五帝本纪", "para": "23.2", "seq": 25, "text": "[23.2.8] 舜曰：“然。", "len": 15}
{"sid": "001_五帝本纪.23.2.s26", "chapter": "001_五帝本纪", "para": "23.2", "seq": 26, "text": "以夔为典乐，教稺子，直而温，宽而栗，刚而毋虐，简而毋傲；诗言意，歌长言，声依永，律和声，八音能谐，毋相夺伦，神人以和。", "len": 59}
{"sid": "001_五帝本纪.23.2.s27", "chapter": "001_五帝本纪", "para": "23.2", "seq": 27, "text": "” 夔曰：“於！", "len": 8}
{"sid": "001_五帝本纪.23.2.s28", "chapter": "001_五帝本纪", "para": "23.2", "seq": 28, "text": "予击石拊石，百兽率舞。", "len": 11}
{"sid": "001_五帝本纪.23.2.s29", "chapter": "001_五帝本纪", "para": "23.2", "seq": 29, "text": "” [23.2.9] 舜曰：“龙，朕畏忌谗说殄伪，振惊朕众，命汝为纳言，夙夜出入朕命，惟信。”", "len": 47}
{"sid": "001_五帝本纪.23.3.s1", "chapter": "001_五帝本纪", "para": "23.3", "seq": 1, "text": "舜曰：“嗟！", "len": 6}
{"sid": "001_五帝本纪.23.3.s2", "chapter": "001_五帝本纪", "para": "23.3", "seq": 2, "text": "女二十有二人，敬哉，惟时相天事。", "len": 16}
{"sid": "001_五帝本纪.23.3.s3", "chapter": "001_五帝本纪", "para": "23.3", "seq": 3, "text": "” 三岁一考功，三考绌陟，远近众功咸兴。", "len": 20}
{"sid": "001_五帝本纪.23.3.s4", "chapter": "001_五帝本纪", "para": "23.3", "seq": 4, "text": "分北三苗。", "len": 5}
{"sid": "001_五帝本纪.24.s1", "chapter": "001_五帝本纪", "para": "24", "seq": 1, "text": "此二十二人咸成厥功： 皋陶为大理，平，民各伏得其实； 伯夷主礼，上下咸让； 垂主工师，百工致功； 益主虞，山泽辟； 弃主稷，百穀时茂； 契主司徒，百姓亲和； 龙主宾客，远人至； 十二牧行而九州莫敢辟违；", "len": 101}
{"sid": "001_五帝本纪.24.1.s1", "chapter": "001_五帝本纪", "para": "24.1", "seq": 1, "text": "唯禹之功为大，披九山，通九泽，决九河，定九州，各以其职来贡，不失厥宜。", "len": 35}
{"sid": "001_五帝本纪.24.1.s2", "chapter": "001_五帝本纪", "para": "24.1", "seq": 2, "text": "方五千里，至于荒服。", "len": 10}
{"sid": "001_五帝本纪.24.1.s3", "chapter": "001_五帝本纪", "para": "24.1", "seq": 3, "text": "南抚交阯、北发，西戎、析枝、渠廋、氐、羌，北山戎、发、息慎，东长、鸟夷，四海之内咸戴帝舜之功。", "len": 47}
{"sid": "001_五帝本纪.24.1.s4", "chapter": "001_五帝本纪", "para": "24.1", "seq": 4, "text": "於是禹乃兴九招之乐，致异物，凤皇来翔。", "len": 19}
{"sid": "001_五帝本纪.24.1.s5", "chapter": "001_五帝本纪", "para": "24.1", "seq": 5, "text": "天下明德皆自虞帝始。", "len": 10}
{"sid": "001_五帝本纪.25.s1", "chapter": "001_五帝本纪", "para": "25", "seq": 1, "text": "舜年二十以孝闻，年三十尧举之，年五十摄行天子事，年五十八尧崩，年六十一代尧践帝位。", "len": 41}
{"sid": "001_五帝本纪.25.s2", "chapter": "001_五帝本纪", "para": "25", "seq": 2, "text": "践帝位三十九年，南巡狩，崩於苍梧之野。", "len": 19}
{"sid": "001_五帝本纪.25.s3", "chapter": "001_五帝本纪", "para": "25", "seq": 3, "text": "葬於江南九疑，是为零陵。", "len": 12}
{"sid": "001_五帝本纪.25.1.s1", "chapter": "001_五帝本纪", "para": "25.1", "seq": 1, "text": "舜之践帝位，载天子旗，往朝父瞽叟，夔夔唯谨，如子道。", "len": 26}
{"sid": "001_五帝本纪.25.1.s2", "chapter": "001_五帝本纪", "para": "25.1", "seq": 2, "text": "封弟象为诸侯。", "len": 7}
{"sid": "001_五帝本纪.25.1.s3", "chapter": "001_五帝本纪", "para": "25.1", "seq": 3, "text": "舜子商均亦不肖，舜乃豫荐禹於天。", "len": 16}
{"sid": "001_五帝本纪.25.1.s4", "chapter": "001_五帝本纪", "para": "25.1", "seq": 4, "text": "十七年而崩。", "len": 6}
{"sid": "001_五帝本纪.25.1.s5", "chapter": "001_五帝本纪", "para": "25.1", "seq": 5, "text": "三年丧毕，禹亦乃让舜子，如舜让尧子。", "len": 18}
{"sid": "001_五帝本纪.25.1.s6", "chapter": "001_五帝本纪", "para": "25.1", "seq": 6, "text": "诸侯归之，然後禹践天子位。", "len": 13}
{"sid": "001_五帝本纪.25.2.s1", "chapter": "001_五帝本纪", "para": "25.2", "seq": 1, "text": "尧子丹硃，舜子商均，皆有疆土，以奉先祀。", "len": 20}
{"sid": "001_五帝本纪.25.2.s2", "chapter": "001_五帝本纪", "para": "25.2", "seq": 2, "text": "服其服，礼乐如之。", "len": 9}
{"sid": "001_五帝本纪.25.2.s3", "chapter": "001_五帝本纪", "para": "25.2", "seq": 3, "text": "以客见天子，天子弗臣，示不敢专也。", "len": 17}
{"sid": "001_五帝本纪.26.s1", "chapter": "001_五帝本纪", "para": "26", "seq": 1, "text": "自黄帝至舜、禹，皆同姓而异其国号，以章明德。", "len": 22}
{"sid": "001_五帝本纪.26.s2", "chapter": "001_五帝本纪", "para": "26", "seq": 2, "text": "故黄帝为有熊， 帝颛顼为高阳， 帝喾为高辛， 帝尧为陶唐， 帝舜为有虞。", "len": 36}
{"sid": "001_五帝本纪.26.s3", "chapter": "001_五帝本纪", "para": "26", "seq": 3, "text": "帝禹为夏后而别氏，姓姒氏。", "len": 13}
{"sid": "001_五帝本纪.26.s4", "chapter": "001_五帝本纪", "para": "26", "seq": 4, "text": "契为商，姓子氏。", "len": 8}
{"sid": "001_五帝本纪.26.s5", "chapter": "001_五帝本纪", "para": "26", "seq": 5, "text": "弃为周，姓姬氏。", "len": 8}
{"sid": "001_五帝本纪.27.s1", "chapter": "001_五帝本纪", "para": "27", "seq": 1, "text": "太史公曰：学者多称五帝，尚矣。", "len": 15}
{"sid": "001_五帝本纪.27.s2", "chapter": "001_五帝本纪", "para": "27", "seq": 2, "text": "然尚书独载尧以来；而百家言黄帝，其文不雅驯，荐绅先生难言之。", "len": 30}
{"sid": "001_五帝本纪.27.s3", "chapter": "001_五帝本纪", "para": "27", "seq": 3, "text": "孔子所传宰予问五帝德及帝系姓，儒者或不传。", "len": 21}
{"sid": "001_五帝本纪.27.s4", "chapter": "001_五帝本纪", "para": "27", "seq": 4, "text": "余尝西至空桐，北过涿鹿，东渐於海，南浮江淮矣，至长老皆各往往称黄帝、尧、舜之处，风教固殊焉，总之不离古文者近是。", "len": 56}
{"sid": "001_五帝本纪.27.s5", "chapter": "001_五帝本纪", "para": "27", "seq": 5, "text": "予观春秋、国语，其发明五帝德、帝系姓章矣，顾弟弗深考，其所表见皆不虚。", "len": 35}
{"sid": "001_五帝本纪.27.s6", "chapter": "001_五帝本纪", "para": "27", "seq": 6, "text": "书缺有间矣，其轶乃时时见於他说。", "len": 16}
{"sid": "001_五帝本纪.27.s7", "chapter": "001_五帝本纪", "para": "27", "seq": 7, "text": "非好学深思，心知其意，固难为浅见寡闻道也。", "len": 21}
{"sid": "001_五帝本纪.27.s8", "chapter": "001_五帝本纪", "para": "27", "seq": 8, "text": "余并论次，择其言尤雅者，故著为本纪书首。", "len": 20}
{"sid": "001_五帝本纪.27.s9", "chapter": "001_五帝本纪", "para": "27", "seq": 9, "text": "::: 赞", "len": 5}
{"sid": "001_五帝本纪.28.s1", "chapter": "001_五帝本纪", "para": "28", "seq": 1, "text": "帝出少典，居于轩丘。", "len": 10}
{"sid": "001_五帝本纪.28.s2", "chapter": "001_五帝本纪", "para": "28", "seq": 2, "text": "既代炎历，遂擒蚩尤。", "len": 10}
{"sid": "001_五帝本纪.28.s3", "chapter": "001_五帝本纪", "para": "28", "seq": 3, "text": "高阳嗣位，静深有谋。", "len": 10}
{"sid": "001_五帝本纪.28.s4", "chapter": "001_五帝本纪", "para": "28", "seq": 4, "text": "小大远近，莫不怀柔。", "len": 10}
{"sid": "001_五帝本纪.28.s5", "chapter": "001_五帝本纪", "para": "28", "seq": 5, "text": "爰洎帝喾，列圣同休。", "len": 10}
{"sid": "001_五帝本纪.28.s6", "chapter": "001_五帝本纪", "para": "28", "seq": 6, "text": "帝挚之弟，其号放勋。", "len": 10}
{"sid": "001_五帝本纪.28.s7", "chapter": "001_五帝本纪", "para": "28", "seq": 7, "text": "就之如日，望之如云。", "len": 10}
{"sid": "001_五帝本纪.28.s8", "chapter": "001_五帝本纪", "para": "28", "seq": 8, "text": "郁夷东作，昧谷西曛。", "len": 10}
{"sid": "001_五帝本纪.28.s9", "chapter": "001_五帝本纪", "para": "28", "seq": 9, "text": "明扬仄陋，玄德升闻。", "len": 10}
{"sid": "001_五帝本纪.28.s10", "chapter": "001_五帝本纪", "para": "28", "seq": 10, "text": "能让天下，贤哉二君！", "len": 10}
{"sid": "001_五帝本纪.28.s11", "chapter": "001_五帝本纪", "para": "28", "seq": 11, "text": ":::", "len": 3}
