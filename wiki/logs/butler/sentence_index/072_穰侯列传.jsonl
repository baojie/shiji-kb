{"sid": "072_穰侯列传.1.s1", "chapter": "072_穰侯列传", "para": "1", "seq": 1, "text": "穰侯魏厓者，秦昭王母宣太后弟也。", "len": 16}
{"sid": "072_穰侯列传.1.s2", "chapter": "072_穰侯列传", "para": "1", "seq": 2, "text": "其先楚人，姓羋氏。", "len": 9}
{"sid": "072_穰侯列传.2.s1", "chapter": "072_穰侯列传", "para": "2", "seq": 1, "text": "秦武王卒，无子，立其弟为昭王。", "len": 15}
{"sid": "072_穰侯列传.2.s2", "chapter": "072_穰侯列传", "para": "2", "seq": 2, "text": "昭王母故号为羋八子，及昭王即位，羋八子号为宣太后。", "len": 25}
{"sid": "072_穰侯列传.2.s3", "chapter": "072_穰侯列传", "para": "2", "seq": 3, "text": "宣太后非武王母。", "len": 8}
{"sid": "072_穰侯列传.2.s4", "chapter": "072_穰侯列传", "para": "2", "seq": 4, "text": "武王母号曰惠文后，先武王死。", "len": 14}
{"sid": "072_穰侯列传.2.s5", "chapter": "072_穰侯列传", "para": "2", "seq": 5, "text": "宣太后二弟：其异父长弟曰穰侯，姓魏氏，名厓；同父弟曰羋戎，为华阳君。", "len": 34}
{"sid": "072_穰侯列传.2.s6", "chapter": "072_穰侯列传", "para": "2", "seq": 6, "text": "而昭王同母弟曰高陵君、泾阳君。", "len": 15}
{"sid": "072_穰侯列传.2.s7", "chapter": "072_穰侯列传", "para": "2", "seq": 7, "text": "而魏厓最贤，自惠王、武王时任职用事。", "len": 18}
{"sid": "072_穰侯列传.2.s8", "chapter": "072_穰侯列传", "para": "2", "seq": 8, "text": "武王卒，诸弟争立，唯魏厓力为能立昭王。", "len": 19}
{"sid": "072_穰侯列传.2.s9", "chapter": "072_穰侯列传", "para": "2", "seq": 9, "text": "昭王即位，以厓为将军，卫咸阳。", "len": 15}
{"sid": "072_穰侯列传.2.s10", "chapter": "072_穰侯列传", "para": "2", "seq": 10, "text": "诛季君之乱，而逐武王后出之魏，昭王诸兄弟不善者皆灭之，威振秦国。", "len": 32}
{"sid": "072_穰侯列传.2.s11", "chapter": "072_穰侯列传", "para": "2", "seq": 11, "text": "昭王少，宣太后自治，任魏厓为政。", "len": 16}
{"sid": "072_穰侯列传.3.s1", "chapter": "072_穰侯列传", "para": "3", "seq": 1, "text": "昭王七年，樗里子死，而使泾阳君质於齐。", "len": 19}
{"sid": "072_穰侯列传.3.s2", "chapter": "072_穰侯列传", "para": "3", "seq": 2, "text": "赵人楼缓来相秦，赵不利，乃使仇液之秦，请以魏厓为秦相。", "len": 27}
{"sid": "072_穰侯列传.3.s3", "chapter": "072_穰侯列传", "para": "3", "seq": 3, "text": "仇液将行，其客宋公谓液曰：“秦不听公，楼缓必怨公。", "len": 25}
{"sid": "072_穰侯列传.3.s4", "chapter": "072_穰侯列传", "para": "3", "seq": 4, "text": "公不若谓楼缓曰‘请为公毋急秦’。", "len": 16}
{"sid": "072_穰侯列传.3.s5", "chapter": "072_穰侯列传", "para": "3", "seq": 5, "text": "秦王见赵请相魏厓之不急，且不听公。", "len": 17}
{"sid": "072_穰侯列传.3.s6", "chapter": "072_穰侯列传", "para": "3", "seq": 6, "text": "公言而事不成，以德楼子；事成，魏厓故德公矣。", "len": 22}
{"sid": "072_穰侯列传.3.s7", "chapter": "072_穰侯列传", "para": "3", "seq": 7, "text": "” 於是仇液从之。", "len": 9}
{"sid": "072_穰侯列传.3.s8", "chapter": "072_穰侯列传", "para": "3", "seq": 8, "text": "而秦果免楼缓而魏厓相秦。", "len": 12}
{"sid": "072_穰侯列传.4.s1", "chapter": "072_穰侯列传", "para": "4", "seq": 1, "text": "欲诛吕礼，礼出奔齐。", "len": 10}
{"sid": "072_穰侯列传.4.s2", "chapter": "072_穰侯列传", "para": "4", "seq": 2, "text": "昭王十四年，魏厓举白起，使代向寿将而攻韩、魏，败之伊阙，斩首二十四万，虏魏将公孙喜。", "len": 42}
{"sid": "072_穰侯列传.4.s3", "chapter": "072_穰侯列传", "para": "4", "seq": 3, "text": "明年，又取楚之宛、叶。", "len": 11}
{"sid": "072_穰侯列传.4.s4", "chapter": "072_穰侯列传", "para": "4", "seq": 4, "text": "魏厓谢病免相，以客卿寿烛为相。", "len": 15}
{"sid": "072_穰侯列传.4.s5", "chapter": "072_穰侯列传", "para": "4", "seq": 5, "text": "其明年，烛免，复相厓，乃封魏厓於穰，复益封陶，号曰穰侯。", "len": 28}
{"sid": "072_穰侯列传.5.s1", "chapter": "072_穰侯列传", "para": "5", "seq": 1, "text": "穰侯封四岁，为秦将攻魏。", "len": 12}
{"sid": "072_穰侯列传.5.s2", "chapter": "072_穰侯列传", "para": "5", "seq": 2, "text": "魏献河东方四百里。", "len": 9}
{"sid": "072_穰侯列传.5.s3", "chapter": "072_穰侯列传", "para": "5", "seq": 3, "text": "拔魏之河内，取城大小六十馀。", "len": 14}
{"sid": "072_穰侯列传.5.s4", "chapter": "072_穰侯列传", "para": "5", "seq": 4, "text": "昭王十九年，秦称西帝，齐称东帝。", "len": 16}
{"sid": "072_穰侯列传.5.s5", "chapter": "072_穰侯列传", "para": "5", "seq": 5, "text": "月馀，吕礼来，而齐、秦各复归帝为王。", "len": 18}
{"sid": "072_穰侯列传.5.s6", "chapter": "072_穰侯列传", "para": "5", "seq": 6, "text": "魏厓复相秦，六岁而免。", "len": 11}
{"sid": "072_穰侯列传.5.s7", "chapter": "072_穰侯列传", "para": "5", "seq": 7, "text": "免二岁，复相秦。", "len": 8}
{"sid": "072_穰侯列传.5.s8", "chapter": "072_穰侯列传", "para": "5", "seq": 8, "text": "四岁，而使白起拔楚之郢，秦置南郡。", "len": 17}
{"sid": "072_穰侯列传.5.s9", "chapter": "072_穰侯列传", "para": "5", "seq": 9, "text": "乃封白起为武安君。", "len": 9}
{"sid": "072_穰侯列传.5.s10", "chapter": "072_穰侯列传", "para": "5", "seq": 10, "text": "白起者，穰侯之所任举也，相善。", "len": 15}
{"sid": "072_穰侯列传.5.s11", "chapter": "072_穰侯列传", "para": "5", "seq": 11, "text": "於是穰侯之富，富於王室。", "len": 12}
{"sid": "072_穰侯列传.6.s1", "chapter": "072_穰侯列传", "para": "6", "seq": 1, "text": "昭王三十二年，穰侯为相国，将兵攻魏，走芒卯，入北宅，遂围大梁。", "len": 31}
{"sid": "072_穰侯列传.6.s2", "chapter": "072_穰侯列传", "para": "6", "seq": 2, "text": "梁大夫须贾说穰侯曰：“臣闻魏之长吏谓魏王曰：’昔梁惠王伐赵，战胜三梁，拔邯郸；赵氏不割，而邯郸复归。", "len": 50}
{"sid": "072_穰侯列传.6.s3", "chapter": "072_穰侯列传", "para": "6", "seq": 3, "text": "齐人攻卫，拔故国，杀子良；卫人不割，而故地复反。", "len": 24}
{"sid": "072_穰侯列传.6.s4", "chapter": "072_穰侯列传", "para": "6", "seq": 4, "text": "卫、赵之所以国全兵劲而地不并於诸侯者，以其能忍难而重出地也。", "len": 30}
{"sid": "072_穰侯列传.6.s5", "chapter": "072_穰侯列传", "para": "6", "seq": 5, "text": "宋、中山数伐割地，而国随以亡。", "len": 15}
{"sid": "072_穰侯列传.6.s6", "chapter": "072_穰侯列传", "para": "6", "seq": 6, "text": "臣以为卫、赵可法，而宋、中山可为戒也。", "len": 19}
{"sid": "072_穰侯列传.6.s7", "chapter": "072_穰侯列传", "para": "6", "seq": 7, "text": "秦，贪戾之国也，而毋亲。", "len": 12}
{"sid": "072_穰侯列传.6.s8", "chapter": "072_穰侯列传", "para": "6", "seq": 8, "text": "蚕食魏氏，又尽晋国，战胜暴子，割八县，地未毕入，兵复出矣。", "len": 29}
{"sid": "072_穰侯列传.6.s9", "chapter": "072_穰侯列传", "para": "6", "seq": 9, "text": "夫秦何厌之有哉！", "len": 8}
{"sid": "072_穰侯列传.6.s10", "chapter": "072_穰侯列传", "para": "6", "seq": 10, "text": "今又走芒卯，入北宅，此非敢攻梁也，且劫王以求多割地。", "len": 26}
{"sid": "072_穰侯列传.6.s11", "chapter": "072_穰侯列传", "para": "6", "seq": 11, "text": "王必勿听也。", "len": 6}
{"sid": "072_穰侯列传.6.s12", "chapter": "072_穰侯列传", "para": "6", "seq": 12, "text": "今王背楚、赵而讲秦，楚、赵怒而去王，与王争事秦，秦必受之。", "len": 29}
{"sid": "072_穰侯列传.6.s13", "chapter": "072_穰侯列传", "para": "6", "seq": 13, "text": "秦挟楚、赵之兵以复攻梁，则国求无亡不可得也。", "len": 22}
{"sid": "072_穰侯列传.6.s14", "chapter": "072_穰侯列传", "para": "6", "seq": 14, "text": "原王之必无讲也。", "len": 8}
{"sid": "072_穰侯列传.6.s15", "chapter": "072_穰侯列传", "para": "6", "seq": 15, "text": "王若欲讲，少割而有质；不然，必见欺。", "len": 18}
{"sid": "072_穰侯列传.6.s16", "chapter": "072_穰侯列传", "para": "6", "seq": 16, "text": "’此臣之所闻於魏也，原君之以是虑事也。", "len": 19}
{"sid": "072_穰侯列传.6.s17", "chapter": "072_穰侯列传", "para": "6", "seq": 17, "text": "周书曰‘惟命不于常’，此言幸之不可数也。", "len": 20}
{"sid": "072_穰侯列传.6.s18", "chapter": "072_穰侯列传", "para": "6", "seq": 18, "text": "夫战胜暴子，割八县，此非兵力之精也，又非计之工也，天幸为多矣。", "len": 31}
{"sid": "072_穰侯列传.6.s19", "chapter": "072_穰侯列传", "para": "6", "seq": 19, "text": "今又走芒卯，入北宅，以攻大梁，是以天幸自为常也。", "len": 24}
{"sid": "072_穰侯列传.6.s20", "chapter": "072_穰侯列传", "para": "6", "seq": 20, "text": "智者不然。", "len": 5}
{"sid": "072_穰侯列传.6.s21", "chapter": "072_穰侯列传", "para": "6", "seq": 21, "text": "臣闻魏氏悉其百县胜甲以上戍大梁，臣以为不下三十万。", "len": 25}
{"sid": "072_穰侯列传.6.s22", "chapter": "072_穰侯列传", "para": "6", "seq": 22, "text": "以三十万之众守梁七仞之城，臣以为汤、武复生，不易攻也。", "len": 27}
{"sid": "072_穰侯列传.6.s23", "chapter": "072_穰侯列传", "para": "6", "seq": 23, "text": "夫轻背楚、赵之兵，陵七仞之城，战三十万之众，而志必举之，臣以为自天地始分以至于今，未尝有者也。", "len": 47}
{"sid": "072_穰侯列传.6.s24", "chapter": "072_穰侯列传", "para": "6", "seq": 24, "text": "攻而不拔，秦兵必罢，陶邑必亡，则前功必弃矣。", "len": 22}
{"sid": "072_穰侯列传.6.s25", "chapter": "072_穰侯列传", "para": "6", "seq": 25, "text": "今魏氏方疑，可以少割收也。", "len": 13}
{"sid": "072_穰侯列传.6.s26", "chapter": "072_穰侯列传", "para": "6", "seq": 26, "text": "原君逮楚、赵之兵未至於梁，亟以少割收魏。", "len": 20}
{"sid": "072_穰侯列传.6.s27", "chapter": "072_穰侯列传", "para": "6", "seq": 27, "text": "魏方疑而得以少割为利，必欲之，则君得所欲矣。", "len": 22}
{"sid": "072_穰侯列传.6.s28", "chapter": "072_穰侯列传", "para": "6", "seq": 28, "text": "楚、赵怒於魏之先己也，必争事秦，从以此散，而君後择焉。", "len": 27}
{"sid": "072_穰侯列传.6.s29", "chapter": "072_穰侯列传", "para": "6", "seq": 29, "text": "且君之得地岂必以兵哉！", "len": 11}
{"sid": "072_穰侯列传.6.s30", "chapter": "072_穰侯列传", "para": "6", "seq": 30, "text": "割晋国，秦兵不攻，而魏必效绛安邑。", "len": 17}
{"sid": "072_穰侯列传.6.s31", "chapter": "072_穰侯列传", "para": "6", "seq": 31, "text": "又为陶开两道，几尽故宋，卫必效单父。", "len": 18}
{"sid": "072_穰侯列传.6.s32", "chapter": "072_穰侯列传", "para": "6", "seq": 32, "text": "秦兵可全，而君制之，何索而不得，何为而不成！", "len": 22}
{"sid": "072_穰侯列传.6.s33", "chapter": "072_穰侯列传", "para": "6", "seq": 33, "text": "原君熟虑之而无行危。", "len": 10}
{"sid": "072_穰侯列传.6.s34", "chapter": "072_穰侯列传", "para": "6", "seq": 34, "text": "” 穰侯曰：“善。", "len": 9}
{"sid": "072_穰侯列传.6.s35", "chapter": "072_穰侯列传", "para": "6", "seq": 35, "text": "” 乃罢梁围。", "len": 7}
{"sid": "072_穰侯列传.7.s1", "chapter": "072_穰侯列传", "para": "7", "seq": 1, "text": "明年，魏背秦，与齐从亲。", "len": 12}
{"sid": "072_穰侯列传.7.s2", "chapter": "072_穰侯列传", "para": "7", "seq": 2, "text": "秦使穰侯伐魏，斩首四万，走魏将暴鸢，得魏三县。", "len": 23}
{"sid": "072_穰侯列传.7.s3", "chapter": "072_穰侯列传", "para": "7", "seq": 3, "text": "穰侯益封。", "len": 5}
{"sid": "072_穰侯列传.8.s1", "chapter": "072_穰侯列传", "para": "8", "seq": 1, "text": "明年，穰侯与白起客卿胡阳复攻赵、韩、魏，破芒卯於华阳下，斩首十万，取魏之卷、蔡阳、长社，赵氏观津。", "len": 49}
{"sid": "072_穰侯列传.8.s2", "chapter": "072_穰侯列传", "para": "8", "seq": 2, "text": "且与赵观津，益赵以兵，伐齐。", "len": 14}
{"sid": "072_穰侯列传.8.s3", "chapter": "072_穰侯列传", "para": "8", "seq": 3, "text": "齐襄王惧，使苏代为齐阴遗穰侯书曰：“臣闻往来者言曰‘秦将益赵甲四万以伐齐’，臣窃必之敝邑之王曰‘秦王明而熟於计，穰侯智而习於事，必不益赵甲四万以伐齐’。", "len": 76}
{"sid": "072_穰侯列传.8.s4", "chapter": "072_穰侯列传", "para": "8", "seq": 4, "text": "是何也？", "len": 4}
{"sid": "072_穰侯列传.8.s5", "chapter": "072_穰侯列传", "para": "8", "seq": 5, "text": "夫三晋之相与也，秦之深雠也。", "len": 14}
{"sid": "072_穰侯列传.8.s6", "chapter": "072_穰侯列传", "para": "8", "seq": 6, "text": "百相背也，百相欺也，不为不信，不为无行。", "len": 20}
{"sid": "072_穰侯列传.8.s7", "chapter": "072_穰侯列传", "para": "8", "seq": 7, "text": "今破齐以肥赵。", "len": 7}
{"sid": "072_穰侯列传.8.s8", "chapter": "072_穰侯列传", "para": "8", "seq": 8, "text": "赵，秦之深雠，不利於秦。", "len": 12}
{"sid": "072_穰侯列传.8.s9", "chapter": "072_穰侯列传", "para": "8", "seq": 9, "text": "此一也。", "len": 4}
{"sid": "072_穰侯列传.8.s10", "chapter": "072_穰侯列传", "para": "8", "seq": 10, "text": "秦之谋者，必曰‘破齐，弊晋、楚，而後制晋、楚之胜’。", "len": 26}
{"sid": "072_穰侯列传.8.s11", "chapter": "072_穰侯列传", "para": "8", "seq": 11, "text": "夫齐，罢国也，以天下攻齐，如以千钧之弩决溃筴也，必死，安能弊晋、楚？", "len": 34}
{"sid": "072_穰侯列传.8.s12", "chapter": "072_穰侯列传", "para": "8", "seq": 12, "text": "此二也。", "len": 4}
{"sid": "072_穰侯列传.8.s13", "chapter": "072_穰侯列传", "para": "8", "seq": 13, "text": "秦少出兵，则晋、楚不信也；多出兵，则晋、楚为制於秦。", "len": 26}
{"sid": "072_穰侯列传.8.s14", "chapter": "072_穰侯列传", "para": "8", "seq": 14, "text": "齐恐，不走秦，必走晋、楚。", "len": 13}
{"sid": "072_穰侯列传.8.s15", "chapter": "072_穰侯列传", "para": "8", "seq": 15, "text": "此三也。", "len": 4}
{"sid": "072_穰侯列传.8.s16", "chapter": "072_穰侯列传", "para": "8", "seq": 16, "text": "秦割齐以啖晋、楚，晋、楚案之以兵，秦反受敌。", "len": 22}
{"sid": "072_穰侯列传.8.s17", "chapter": "072_穰侯列传", "para": "8", "seq": 17, "text": "此四也。", "len": 4}
{"sid": "072_穰侯列传.8.s18", "chapter": "072_穰侯列传", "para": "8", "seq": 18, "text": "是晋、楚以秦谋齐，以齐谋秦也，何晋、楚之智而秦、齐之愚？", "len": 28}
{"sid": "072_穰侯列传.8.s19", "chapter": "072_穰侯列传", "para": "8", "seq": 19, "text": "此五也。", "len": 4}
{"sid": "072_穰侯列传.8.s20", "chapter": "072_穰侯列传", "para": "8", "seq": 20, "text": "故得安邑以善事之，亦必无患矣。", "len": 15}
{"sid": "072_穰侯列传.8.s21", "chapter": "072_穰侯列传", "para": "8", "seq": 21, "text": "秦有安邑，韩氏必无上党矣。", "len": 13}
{"sid": "072_穰侯列传.8.s22", "chapter": "072_穰侯列传", "para": "8", "seq": 22, "text": "取天下之肠胃，与出兵而惧其不反也，孰利？", "len": 20}
{"sid": "072_穰侯列传.8.s23", "chapter": "072_穰侯列传", "para": "8", "seq": 23, "text": "臣故曰秦王明而熟於计，穰侯智而习於事，必不益赵甲四万以代齐矣。", "len": 31}
{"sid": "072_穰侯列传.8.s24", "chapter": "072_穰侯列传", "para": "8", "seq": 24, "text": "” 於是穰侯不行，引兵而归。", "len": 14}
{"sid": "072_穰侯列传.9.s1", "chapter": "072_穰侯列传", "para": "9", "seq": 1, "text": "昭王三十六年，相国穰侯言客卿灶，欲伐齐取刚、寿，以广其陶邑。", "len": 30}
{"sid": "072_穰侯列传.9.s2", "chapter": "072_穰侯列传", "para": "9", "seq": 2, "text": "於是魏人范睢自谓张禄先生，讥穰侯之伐齐，乃越三晋以攻齐也，以此时奸说秦昭王。", "len": 38}
{"sid": "072_穰侯列传.9.s3", "chapter": "072_穰侯列传", "para": "9", "seq": 3, "text": "昭王於是用范睢。", "len": 8}
{"sid": "072_穰侯列传.9.s4", "chapter": "072_穰侯列传", "para": "9", "seq": 4, "text": "范睢言宣太后专制，穰侯擅权於诸侯，泾阳君、高陵君之属太侈，富於王室。", "len": 34}
{"sid": "072_穰侯列传.9.s5", "chapter": "072_穰侯列传", "para": "9", "seq": 5, "text": "於是秦昭王悟，乃免相国，令泾阳之属皆出关，就封邑。", "len": 25}
{"sid": "072_穰侯列传.9.s6", "chapter": "072_穰侯列传", "para": "9", "seq": 6, "text": "穰侯出关，辎车千乘有馀。", "len": 12}
{"sid": "072_穰侯列传.10.s1", "chapter": "072_穰侯列传", "para": "10", "seq": 1, "text": "穰侯卒於陶，而因葬焉。", "len": 11}
{"sid": "072_穰侯列传.10.s2", "chapter": "072_穰侯列传", "para": "10", "seq": 2, "text": "秦复收陶为郡。", "len": 7}
{"sid": "072_穰侯列传.10.s3", "chapter": "072_穰侯列传", "para": "10", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "072_穰侯列传.11.s1", "chapter": "072_穰侯列传", "para": "11", "seq": 1, "text": "太史公曰：穰侯，昭王亲舅也。", "len": 14}
{"sid": "072_穰侯列传.11.s2", "chapter": "072_穰侯列传", "para": "11", "seq": 2, "text": "而秦所以东益地，弱诸侯，尝称帝於天下，天下皆西乡稽首者，穰侯之功也。", "len": 34}
{"sid": "072_穰侯列传.11.s3", "chapter": "072_穰侯列传", "para": "11", "seq": 3, "text": "及其贵极富溢，一夫开说，身折势夺而以忧死，况於羁旅之臣乎！", "len": 29}
{"sid": "072_穰侯列传.11.s4", "chapter": "072_穰侯列传", "para": "11", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "072_穰侯列传.12.s1", "chapter": "072_穰侯列传", "para": "12", "seq": 1, "text": "穰侯智识，应变无方。", "len": 10}
{"sid": "072_穰侯列传.12.s2", "chapter": "072_穰侯列传", "para": "12", "seq": 2, "text": "内倚太后，外辅昭王。", "len": 10}
{"sid": "072_穰侯列传.12.s3", "chapter": "072_穰侯列传", "para": "12", "seq": 3, "text": "四登相位，再列封疆。", "len": 10}
{"sid": "072_穰侯列传.12.s4", "chapter": "072_穰侯列传", "para": "12", "seq": 4, "text": "摧齐挠楚，破魏围梁。", "len": 10}
{"sid": "072_穰侯列传.12.s5", "chapter": "072_穰侯列传", "para": "12", "seq": 5, "text": "一夫开说，忧愤而亡。", "len": 10}
{"sid": "072_穰侯列传.12.s6", "chapter": "072_穰侯列传", "para": "12", "seq": 6, "text": ":::", "len": 3}
