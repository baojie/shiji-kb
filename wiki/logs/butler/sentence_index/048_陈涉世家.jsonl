{"sid": "048_陈涉世家.1.1.s1", "chapter": "048_陈涉世家", "para": "1.1", "seq": 1, "text": "陈胜者，阳城人也，字涉。", "len": 12}
{"sid": "048_陈涉世家.1.1.s2", "chapter": "048_陈涉世家", "para": "1.1", "seq": 2, "text": "吴广者，阳夏人也，字叔。", "len": 12}
{"sid": "048_陈涉世家.1.1.s3", "chapter": "048_陈涉世家", "para": "1.1", "seq": 3, "text": "陈涉少时，尝与人佣耕，辍耕之垄上，怅恨久之，曰：“苟富贵，无相忘。", "len": 33}
{"sid": "048_陈涉世家.1.1.s4", "chapter": "048_陈涉世家", "para": "1.1", "seq": 4, "text": "” 庸者笑而应曰：“若为庸耕，何富贵也？", "len": 20}
{"sid": "048_陈涉世家.1.1.s5", "chapter": "048_陈涉世家", "para": "1.1", "seq": 5, "text": "” 陈涉太息曰：“嗟乎，燕雀安知鸿鹄之志哉！”", "len": 23}
{"sid": "048_陈涉世家.2.1.s1", "chapter": "048_陈涉世家", "para": "2.1", "seq": 1, "text": "二世元年七月，发闾左適戍渔阳，九百人屯大泽乡。", "len": 23}
{"sid": "048_陈涉世家.2.1.s2", "chapter": "048_陈涉世家", "para": "2.1", "seq": 2, "text": "陈胜、吴广皆次当行，为屯长。", "len": 14}
{"sid": "048_陈涉世家.2.1.s3", "chapter": "048_陈涉世家", "para": "2.1", "seq": 3, "text": "会天大雨，道不通，度已失期。", "len": 14}
{"sid": "048_陈涉世家.2.1.s4", "chapter": "048_陈涉世家", "para": "2.1", "seq": 4, "text": "失期，法皆斩。", "len": 7}
{"sid": "048_陈涉世家.2.1.s5", "chapter": "048_陈涉世家", "para": "2.1", "seq": 5, "text": "陈胜、吴广乃谋曰：“今亡亦死，举大计亦死，等死，死国可乎？", "len": 29}
{"sid": "048_陈涉世家.2.1.s6", "chapter": "048_陈涉世家", "para": "2.1", "seq": 6, "text": "” 陈胜曰：“天下苦秦久矣。", "len": 14}
{"sid": "048_陈涉世家.2.1.s7", "chapter": "048_陈涉世家", "para": "2.1", "seq": 7, "text": "吾闻二世少子也，不当立，当立者乃公子扶苏。", "len": 21}
{"sid": "048_陈涉世家.2.1.s8", "chapter": "048_陈涉世家", "para": "2.1", "seq": 8, "text": "扶苏以数谏故，上使外将兵。", "len": 13}
{"sid": "048_陈涉世家.2.1.s9", "chapter": "048_陈涉世家", "para": "2.1", "seq": 9, "text": "今或闻无罪，二世杀之。", "len": 11}
{"sid": "048_陈涉世家.2.1.s10", "chapter": "048_陈涉世家", "para": "2.1", "seq": 10, "text": "百姓多闻其贤，未知其死也。", "len": 13}
{"sid": "048_陈涉世家.2.1.s11", "chapter": "048_陈涉世家", "para": "2.1", "seq": 11, "text": "项燕为楚将，数有功，爱士卒，楚人怜之。", "len": 19}
{"sid": "048_陈涉世家.2.1.s12", "chapter": "048_陈涉世家", "para": "2.1", "seq": 12, "text": "或以为死，或以为亡。", "len": 10}
{"sid": "048_陈涉世家.2.1.s13", "chapter": "048_陈涉世家", "para": "2.1", "seq": 13, "text": "今诚以吾众诈自称公子扶苏、项燕，为天下唱，宜多应者。", "len": 26}
{"sid": "048_陈涉世家.2.1.s14", "chapter": "048_陈涉世家", "para": "2.1", "seq": 14, "text": "” 吴广以为然。", "len": 8}
{"sid": "048_陈涉世家.2.1.s15", "chapter": "048_陈涉世家", "para": "2.1", "seq": 15, "text": "乃行卜。", "len": 4}
{"sid": "048_陈涉世家.2.1.s16", "chapter": "048_陈涉世家", "para": "2.1", "seq": 16, "text": "卜者知其指意，曰：“足下事皆成，有功。", "len": 19}
{"sid": "048_陈涉世家.2.1.s17", "chapter": "048_陈涉世家", "para": "2.1", "seq": 17, "text": "然足下卜之鬼乎！", "len": 8}
{"sid": "048_陈涉世家.2.1.s18", "chapter": "048_陈涉世家", "para": "2.1", "seq": 18, "text": "” 陈胜、吴广喜，念鬼，曰：“此教我先威众耳。", "len": 23}
{"sid": "048_陈涉世家.2.1.s19", "chapter": "048_陈涉世家", "para": "2.1", "seq": 19, "text": "” 乃丹书帛曰“陈胜王”，置人所罾鱼腹中。", "len": 21}
{"sid": "048_陈涉世家.2.1.s20", "chapter": "048_陈涉世家", "para": "2.1", "seq": 20, "text": "卒买鱼烹食，得鱼腹中书，固以怪之矣。", "len": 18}
{"sid": "048_陈涉世家.2.1.s21", "chapter": "048_陈涉世家", "para": "2.1", "seq": 21, "text": "又间令吴广之次所旁丛祠中，夜篝火，狐鸣呼曰“大楚兴，陈胜王”。", "len": 31}
{"sid": "048_陈涉世家.2.1.s22", "chapter": "048_陈涉世家", "para": "2.1", "seq": 22, "text": "卒皆夜惊恐。", "len": 6}
{"sid": "048_陈涉世家.2.1.s23", "chapter": "048_陈涉世家", "para": "2.1", "seq": 23, "text": "旦日，卒中往往语，皆指目陈胜。", "len": 15}
{"sid": "048_陈涉世家.2.2.s1", "chapter": "048_陈涉世家", "para": "2.2", "seq": 1, "text": "吴广素爱人，士卒多为用者。", "len": 13}
{"sid": "048_陈涉世家.2.2.s2", "chapter": "048_陈涉世家", "para": "2.2", "seq": 2, "text": "将尉醉，广故数言欲亡，忿恚尉，令辱之，以激怒其众。", "len": 25}
{"sid": "048_陈涉世家.2.2.s3", "chapter": "048_陈涉世家", "para": "2.2", "seq": 3, "text": "尉果笞广。", "len": 5}
{"sid": "048_陈涉世家.2.2.s4", "chapter": "048_陈涉世家", "para": "2.2", "seq": 4, "text": "尉剑挺，广起，夺而杀尉。", "len": 12}
{"sid": "048_陈涉世家.2.2.s5", "chapter": "048_陈涉世家", "para": "2.2", "seq": 5, "text": "陈胜佐之，并杀两尉。", "len": 10}
{"sid": "048_陈涉世家.2.2.s6", "chapter": "048_陈涉世家", "para": "2.2", "seq": 6, "text": "召令徒属曰：“公等遇雨，皆已失期，失期当斩。", "len": 22}
{"sid": "048_陈涉世家.2.2.s7", "chapter": "048_陈涉世家", "para": "2.2", "seq": 7, "text": "藉弟令毋斩，而戍死者固十六七。", "len": 15}
{"sid": "048_陈涉世家.2.2.s8", "chapter": "048_陈涉世家", "para": "2.2", "seq": 8, "text": "且壮士不死即已，死即举大名耳，王侯将相宁有种乎！", "len": 24}
{"sid": "048_陈涉世家.2.2.s9", "chapter": "048_陈涉世家", "para": "2.2", "seq": 9, "text": "” 徒属皆曰：“敬受命。", "len": 12}
{"sid": "048_陈涉世家.2.2.s10", "chapter": "048_陈涉世家", "para": "2.2", "seq": 10, "text": "” 乃诈称公子扶苏、项燕，从民欲也。", "len": 18}
{"sid": "048_陈涉世家.2.2.s11", "chapter": "048_陈涉世家", "para": "2.2", "seq": 11, "text": "袒右，称大楚。", "len": 7}
{"sid": "048_陈涉世家.2.2.s12", "chapter": "048_陈涉世家", "para": "2.2", "seq": 12, "text": "为坛而盟，祭以尉首。", "len": 10}
{"sid": "048_陈涉世家.2.2.s13", "chapter": "048_陈涉世家", "para": "2.2", "seq": 13, "text": "陈胜自立为将军，吴广为都尉。", "len": 14}
{"sid": "048_陈涉世家.2.2.s14", "chapter": "048_陈涉世家", "para": "2.2", "seq": 14, "text": "攻大泽乡，收而攻蕲。", "len": 10}
{"sid": "048_陈涉世家.2.2.s15", "chapter": "048_陈涉世家", "para": "2.2", "seq": 15, "text": "蕲下，乃令符离人葛婴将兵徇蕲以东。", "len": 17}
{"sid": "048_陈涉世家.2.2.s16", "chapter": "048_陈涉世家", "para": "2.2", "seq": 16, "text": "攻铚、酂、苦、柘、谯皆下之。", "len": 14}
{"sid": "048_陈涉世家.2.2.s17", "chapter": "048_陈涉世家", "para": "2.2", "seq": 17, "text": "行收兵。", "len": 4}
{"sid": "048_陈涉世家.2.2.s18", "chapter": "048_陈涉世家", "para": "2.2", "seq": 18, "text": "比至陈，车六七百乘，骑千馀，卒数万人。", "len": 19}
{"sid": "048_陈涉世家.2.2.s19", "chapter": "048_陈涉世家", "para": "2.2", "seq": 19, "text": "攻陈，陈守令皆不在，独守丞与战谯门中。", "len": 19}
{"sid": "048_陈涉世家.2.2.s20", "chapter": "048_陈涉世家", "para": "2.2", "seq": 20, "text": "弗胜，守丞死，乃入据陈。", "len": 12}
{"sid": "048_陈涉世家.2.2.s21", "chapter": "048_陈涉世家", "para": "2.2", "seq": 21, "text": "数日，号令召三老、豪杰与皆来会计事。", "len": 18}
{"sid": "048_陈涉世家.2.2.s22", "chapter": "048_陈涉世家", "para": "2.2", "seq": 22, "text": "三老、豪杰皆曰：“将军身被坚执锐，伐无道，诛暴秦，复立楚国之社稷，功宜为王。", "len": 38}
{"sid": "048_陈涉世家.2.2.s23", "chapter": "048_陈涉世家", "para": "2.2", "seq": 23, "text": "” 陈涉乃立为王，号为张楚。", "len": 14}
{"sid": "048_陈涉世家.3.1.s1", "chapter": "048_陈涉世家", "para": "3.1", "seq": 1, "text": "当此时，诸郡县苦秦吏者，皆刑其长吏，杀之以应陈涉。", "len": 25}
{"sid": "048_陈涉世家.3.1.s2", "chapter": "048_陈涉世家", "para": "3.1", "seq": 2, "text": "乃以吴叔为假王，监诸将以西击荥阳。", "len": 17}
{"sid": "048_陈涉世家.3.1.s3", "chapter": "048_陈涉世家", "para": "3.1", "seq": 3, "text": "令陈人武臣、张耳、陈馀徇赵地，令汝阴人邓宗徇九江郡。", "len": 26}
{"sid": "048_陈涉世家.3.1.s4", "chapter": "048_陈涉世家", "para": "3.1", "seq": 4, "text": "当此时，楚兵数千人为聚者，不可胜数。", "len": 18}
{"sid": "048_陈涉世家.3.2.s1", "chapter": "048_陈涉世家", "para": "3.2", "seq": 1, "text": "葛婴至东城，立襄彊为楚王。", "len": 13}
{"sid": "048_陈涉世家.3.2.s2", "chapter": "048_陈涉世家", "para": "3.2", "seq": 2, "text": "婴後闻陈王已立，因杀襄彊，还报。", "len": 16}
{"sid": "048_陈涉世家.3.2.s3", "chapter": "048_陈涉世家", "para": "3.2", "seq": 3, "text": "至陈，陈王诛杀葛婴。", "len": 10}
{"sid": "048_陈涉世家.3.2.s4", "chapter": "048_陈涉世家", "para": "3.2", "seq": 4, "text": "陈王令魏人周市北徇魏地。", "len": 12}
{"sid": "048_陈涉世家.3.2.s5", "chapter": "048_陈涉世家", "para": "3.2", "seq": 5, "text": "吴广围荥阳。", "len": 6}
{"sid": "048_陈涉世家.3.2.s6", "chapter": "048_陈涉世家", "para": "3.2", "seq": 6, "text": "李由为三川守，守荥阳，吴叔弗能下。", "len": 17}
{"sid": "048_陈涉世家.3.2.s7", "chapter": "048_陈涉世家", "para": "3.2", "seq": 7, "text": "陈王徵国之豪杰与计，以上蔡人房君蔡赐为上柱国。", "len": 23}
{"sid": "048_陈涉世家.4.1.s1", "chapter": "048_陈涉世家", "para": "4.1", "seq": 1, "text": "周文，陈之贤人也，尝为项燕军视日，事春申君，自言习兵，陈王与之将军印，西击秦。", "len": 39}
{"sid": "048_陈涉世家.4.1.s2", "chapter": "048_陈涉世家", "para": "4.1", "seq": 2, "text": "行收兵至关，车千乘，卒数十万，至戏，军焉。", "len": 21}
{"sid": "048_陈涉世家.4.1.s3", "chapter": "048_陈涉世家", "para": "4.1", "seq": 3, "text": "秦令少府章邯免郦山徒、人奴产子生，悉发以击楚大军，尽败之。", "len": 29}
{"sid": "048_陈涉世家.4.1.s4", "chapter": "048_陈涉世家", "para": "4.1", "seq": 4, "text": "周文败，走出关，止次曹阳二三月。", "len": 16}
{"sid": "048_陈涉世家.4.1.s5", "chapter": "048_陈涉世家", "para": "4.1", "seq": 5, "text": "章邯追败之，复走次渑池十馀日。", "len": 15}
{"sid": "048_陈涉世家.4.1.s6", "chapter": "048_陈涉世家", "para": "4.1", "seq": 6, "text": "章邯击，大破之。", "len": 8}
{"sid": "048_陈涉世家.4.1.s7", "chapter": "048_陈涉世家", "para": "4.1", "seq": 7, "text": "周文自刭，军遂不战。", "len": 10}
{"sid": "048_陈涉世家.5.1.s1", "chapter": "048_陈涉世家", "para": "5.1", "seq": 1, "text": "武臣到邯郸，自立为赵王，陈馀为大将军，张耳、召骚为左右丞相。", "len": 30}
{"sid": "048_陈涉世家.5.1.s2", "chapter": "048_陈涉世家", "para": "5.1", "seq": 2, "text": "陈王怒，捕系武臣等家室，欲诛之。", "len": 16}
{"sid": "048_陈涉世家.5.1.s3", "chapter": "048_陈涉世家", "para": "5.1", "seq": 3, "text": "柱国曰：“秦未亡而诛赵王将相家属，此生一秦也。", "len": 23}
{"sid": "048_陈涉世家.5.1.s4", "chapter": "048_陈涉世家", "para": "5.1", "seq": 4, "text": "不如因而立之。", "len": 7}
{"sid": "048_陈涉世家.5.1.s5", "chapter": "048_陈涉世家", "para": "5.1", "seq": 5, "text": "” 陈王乃遣使者贺赵，而徙系武臣等家属宫中，而封耳子张敖为成都君，趣赵兵亟入关。", "len": 40}
{"sid": "048_陈涉世家.5.1.s6", "chapter": "048_陈涉世家", "para": "5.1", "seq": 6, "text": "赵王将相相与谋曰：”王王赵，非楚意也。", "len": 19}
{"sid": "048_陈涉世家.5.1.s7", "chapter": "048_陈涉世家", "para": "5.1", "seq": 7, "text": "楚已诛秦，必加兵於赵。", "len": 11}
{"sid": "048_陈涉世家.5.1.s8", "chapter": "048_陈涉世家", "para": "5.1", "seq": 8, "text": "计莫如毋西兵，使使北徇燕地以自广也。", "len": 18}
{"sid": "048_陈涉世家.5.1.s9", "chapter": "048_陈涉世家", "para": "5.1", "seq": 9, "text": "赵南据大河，北有燕、代，楚虽胜秦，不敢制赵。", "len": 22}
{"sid": "048_陈涉世家.5.1.s10", "chapter": "048_陈涉世家", "para": "5.1", "seq": 10, "text": "若楚不胜秦，必重赵。", "len": 10}
{"sid": "048_陈涉世家.5.1.s11", "chapter": "048_陈涉世家", "para": "5.1", "seq": 11, "text": "赵乘秦之弊，可以得志於天下。", "len": 14}
{"sid": "048_陈涉世家.5.1.s12", "chapter": "048_陈涉世家", "para": "5.1", "seq": 12, "text": "” 赵王以为然，因不西兵，而遣故上谷卒史韩广将兵北徇燕地。", "len": 29}
{"sid": "048_陈涉世家.6.1.s1", "chapter": "048_陈涉世家", "para": "6.1", "seq": 1, "text": "燕故贵人豪杰谓韩广曰：“楚已立王，赵又已立王。", "len": 23}
{"sid": "048_陈涉世家.6.1.s2", "chapter": "048_陈涉世家", "para": "6.1", "seq": 2, "text": "燕虽小，亦万乘之国也，原将军立为燕王。", "len": 19}
{"sid": "048_陈涉世家.6.1.s3", "chapter": "048_陈涉世家", "para": "6.1", "seq": 3, "text": "” 韩广曰：”广母在赵，不可。", "len": 15}
{"sid": "048_陈涉世家.6.1.s4", "chapter": "048_陈涉世家", "para": "6.1", "seq": 4, "text": "” 燕人曰：“赵方西忧秦，南忧楚，其力不能禁我。", "len": 24}
{"sid": "048_陈涉世家.6.1.s5", "chapter": "048_陈涉世家", "para": "6.1", "seq": 5, "text": "且以楚之彊，不敢害赵王将相之家，赵独安敢害将军之家！", "len": 26}
{"sid": "048_陈涉世家.6.1.s6", "chapter": "048_陈涉世家", "para": "6.1", "seq": 6, "text": "” 韩广以为然，乃自立为燕王。", "len": 15}
{"sid": "048_陈涉世家.6.1.s7", "chapter": "048_陈涉世家", "para": "6.1", "seq": 7, "text": "居数月，赵奉燕王母及家属归之燕。", "len": 16}
{"sid": "048_陈涉世家.7.1.s1", "chapter": "048_陈涉世家", "para": "7.1", "seq": 1, "text": "当此之时，诸将之徇地者，不可胜数。", "len": 17}
{"sid": "048_陈涉世家.7.1.s2", "chapter": "048_陈涉世家", "para": "7.1", "seq": 2, "text": "周市北徇地至狄，狄人田儋杀狄令，自立为齐王，以齐反击周市。", "len": 29}
{"sid": "048_陈涉世家.7.1.s3", "chapter": "048_陈涉世家", "para": "7.1", "seq": 3, "text": "市军散，还至魏地，欲立魏後故甯陵君咎为魏王。", "len": 22}
{"sid": "048_陈涉世家.7.1.s4", "chapter": "048_陈涉世家", "para": "7.1", "seq": 4, "text": "时咎在陈王所，不得之魏。", "len": 12}
{"sid": "048_陈涉世家.7.1.s5", "chapter": "048_陈涉世家", "para": "7.1", "seq": 5, "text": "魏地已定，欲相与立周市为魏王，周市不肯。", "len": 20}
{"sid": "048_陈涉世家.7.1.s6", "chapter": "048_陈涉世家", "para": "7.1", "seq": 6, "text": "使者五反，陈王乃立甯陵君咎为魏王，遣之国。", "len": 21}
{"sid": "048_陈涉世家.7.1.s7", "chapter": "048_陈涉世家", "para": "7.1", "seq": 7, "text": "周市卒为相。", "len": 6}
{"sid": "048_陈涉世家.8.1.s1", "chapter": "048_陈涉世家", "para": "8.1", "seq": 1, "text": "将军田臧等相与谋曰：“周章军已破矣，秦兵旦暮至，我围荥阳城弗能下，秦军至，必大败。", "len": 41}
{"sid": "048_陈涉世家.8.1.s2", "chapter": "048_陈涉世家", "para": "8.1", "seq": 2, "text": "不如少遗兵，足以守荥阳，悉精兵迎秦军。", "len": 19}
{"sid": "048_陈涉世家.8.1.s3", "chapter": "048_陈涉世家", "para": "8.1", "seq": 3, "text": "今假王骄，不知兵权，不可与计，非诛之，事恐败。", "len": 23}
{"sid": "048_陈涉世家.8.1.s4", "chapter": "048_陈涉世家", "para": "8.1", "seq": 4, "text": "” 因相与矫王令以诛吴叔，献其首於陈王。", "len": 20}
{"sid": "048_陈涉世家.8.1.s5", "chapter": "048_陈涉世家", "para": "8.1", "seq": 5, "text": "陈王使使赐田臧楚令尹印，使为上将。", "len": 17}
{"sid": "048_陈涉世家.8.1.s6", "chapter": "048_陈涉世家", "para": "8.1", "seq": 6, "text": "田臧乃使诸将李归等守荥阳城，自以精兵西迎秦军於敖仓。", "len": 26}
{"sid": "048_陈涉世家.8.1.s7", "chapter": "048_陈涉世家", "para": "8.1", "seq": 7, "text": "与战，田臧死，军破。", "len": 10}
{"sid": "048_陈涉世家.8.1.s8", "chapter": "048_陈涉世家", "para": "8.1", "seq": 8, "text": "章邯进兵击李归等荥阳下，破之，李归等死。", "len": 20}
{"sid": "048_陈涉世家.8.2.s1", "chapter": "048_陈涉世家", "para": "8.2", "seq": 1, "text": "阳城人邓说将兵居郯，章邯别将击破之，邓说军散走陈。", "len": 25}
{"sid": "048_陈涉世家.8.2.s2", "chapter": "048_陈涉世家", "para": "8.2", "seq": 2, "text": "铚人伍徐将兵居许，章邯击破之，伍徐军皆散走陈。", "len": 23}
{"sid": "048_陈涉世家.8.2.s3", "chapter": "048_陈涉世家", "para": "8.2", "seq": 3, "text": "陈王诛邓说。", "len": 6}
{"sid": "048_陈涉世家.9.1.s1", "chapter": "048_陈涉世家", "para": "9.1", "seq": 1, "text": "陈王初立时，陵人秦嘉、铚人董緤、符离人硃鸡石、取虑人郑布、徐人丁疾等皆特起，将兵围东海守庆於郯。", "len": 48}
{"sid": "048_陈涉世家.9.1.s2", "chapter": "048_陈涉世家", "para": "9.1", "seq": 2, "text": "陈王闻，乃使武平君畔为将军，监郯下军。", "len": 19}
{"sid": "048_陈涉世家.9.1.s3", "chapter": "048_陈涉世家", "para": "9.1", "seq": 3, "text": "秦嘉不受命，嘉自立为大司马，恶属武平君。", "len": 20}
{"sid": "048_陈涉世家.9.1.s4", "chapter": "048_陈涉世家", "para": "9.1", "seq": 4, "text": "告军吏曰：“武平君年少，不知兵事，勿听！", "len": 20}
{"sid": "048_陈涉世家.9.1.s5", "chapter": "048_陈涉世家", "para": "9.1", "seq": 5, "text": "” 因矫以王命杀武平君畔。", "len": 13}
{"sid": "048_陈涉世家.10.1.s1", "chapter": "048_陈涉世家", "para": "10.1", "seq": 1, "text": "章邯已破伍徐，击陈，柱国房君死。", "len": 16}
{"sid": "048_陈涉世家.10.1.s2", "chapter": "048_陈涉世家", "para": "10.1", "seq": 2, "text": "章邯又进兵击陈西张贺军。", "len": 12}
{"sid": "048_陈涉世家.10.1.s3", "chapter": "048_陈涉世家", "para": "10.1", "seq": 3, "text": "陈王出监战，军破，张贺死。", "len": 13}
{"sid": "048_陈涉世家.10.2.s1", "chapter": "048_陈涉世家", "para": "10.2", "seq": 1, "text": "腊月，陈王之汝阴，还至下城父，其御庄贾杀以降秦。", "len": 24}
{"sid": "048_陈涉世家.10.2.s2", "chapter": "048_陈涉世家", "para": "10.2", "seq": 2, "text": "陈胜葬砀，谥曰隐王。", "len": 10}
{"sid": "048_陈涉世家.11.1.s1", "chapter": "048_陈涉世家", "para": "11.1", "seq": 1, "text": "陈王故涓人将军吕臣为仓头军，起新阳，攻陈下之，杀庄贾，复以陈为楚。", "len": 33}
{"sid": "048_陈涉世家.12.1.s1", "chapter": "048_陈涉世家", "para": "12.1", "seq": 1, "text": "初，陈王至陈，令铚人宋留将兵定南阳，入武关。", "len": 22}
{"sid": "048_陈涉世家.12.1.s2", "chapter": "048_陈涉世家", "para": "12.1", "seq": 2, "text": "留已徇南阳，闻陈王死，南阳复为秦。", "len": 17}
{"sid": "048_陈涉世家.12.1.s3", "chapter": "048_陈涉世家", "para": "12.1", "seq": 3, "text": "宋留不能入武关，乃东至新蔡，遇秦军，宋留以军降秦。", "len": 25}
{"sid": "048_陈涉世家.12.1.s4", "chapter": "048_陈涉世家", "para": "12.1", "seq": 4, "text": "秦传留至咸阳，车裂留以徇。", "len": 13}
{"sid": "048_陈涉世家.13.1.s1", "chapter": "048_陈涉世家", "para": "13.1", "seq": 1, "text": "秦嘉等闻陈王军破出走，乃立景驹为楚王，引兵之方与，欲击秦军定陶下。", "len": 33}
{"sid": "048_陈涉世家.13.1.s2", "chapter": "048_陈涉世家", "para": "13.1", "seq": 2, "text": "使公孙庆使齐王，欲与并力俱进。", "len": 15}
{"sid": "048_陈涉世家.13.1.s3", "chapter": "048_陈涉世家", "para": "13.1", "seq": 3, "text": "齐王曰：“闻陈王战败，不知其死生，楚安得不请而立王！", "len": 26}
{"sid": "048_陈涉世家.13.1.s4", "chapter": "048_陈涉世家", "para": "13.1", "seq": 4, "text": "” 公孙庆曰：“齐不请楚而立王，楚何故请齐而立王！", "len": 25}
{"sid": "048_陈涉世家.13.1.s5", "chapter": "048_陈涉世家", "para": "13.1", "seq": 5, "text": "且楚首事，当令於天下。", "len": 11}
{"sid": "048_陈涉世家.13.1.s6", "chapter": "048_陈涉世家", "para": "13.1", "seq": 6, "text": "” 田儋诛杀公孙庆。", "len": 10}
{"sid": "048_陈涉世家.13.2.s1", "chapter": "048_陈涉世家", "para": "13.2", "seq": 1, "text": "秦左右校复攻陈，下之。", "len": 11}
{"sid": "048_陈涉世家.13.2.s2", "chapter": "048_陈涉世家", "para": "13.2", "seq": 2, "text": "吕将军走，收兵复聚。", "len": 10}
{"sid": "048_陈涉世家.13.2.s3", "chapter": "048_陈涉世家", "para": "13.2", "seq": 3, "text": "鄱盗当阳君黥布之兵相收，复击秦左右校，破之青波，复以陈为楚。", "len": 30}
{"sid": "048_陈涉世家.13.2.s4", "chapter": "048_陈涉世家", "para": "13.2", "seq": 4, "text": "会项梁立怀王孙心为楚王。", "len": 12}
{"sid": "048_陈涉世家.14.1.s1", "chapter": "048_陈涉世家", "para": "14.1", "seq": 1, "text": "陈胜王凡六月。", "len": 7}
{"sid": "048_陈涉世家.14.1.s2", "chapter": "048_陈涉世家", "para": "14.1", "seq": 2, "text": "已为王，王陈。", "len": 7}
{"sid": "048_陈涉世家.14.1.s3", "chapter": "048_陈涉世家", "para": "14.1", "seq": 3, "text": "其故人尝与庸耕者闻之，之陈，扣宫门曰：“吾欲见涉。", "len": 25}
{"sid": "048_陈涉世家.14.1.s4", "chapter": "048_陈涉世家", "para": "14.1", "seq": 4, "text": "” 宫门令欲缚之。", "len": 9}
{"sid": "048_陈涉世家.14.1.s5", "chapter": "048_陈涉世家", "para": "14.1", "seq": 5, "text": "自辩数，乃置，不肯为通。", "len": 12}
{"sid": "048_陈涉世家.14.1.s6", "chapter": "048_陈涉世家", "para": "14.1", "seq": 6, "text": "陈王出，遮道而呼涉。", "len": 10}
{"sid": "048_陈涉世家.14.1.s7", "chapter": "048_陈涉世家", "para": "14.1", "seq": 7, "text": "陈王闻之，乃召见，载与俱归。", "len": 14}
{"sid": "048_陈涉世家.14.1.s8", "chapter": "048_陈涉世家", "para": "14.1", "seq": 8, "text": "入宫，见殿屋帷帐，客曰：“夥颐！", "len": 16}
{"sid": "048_陈涉世家.14.1.s9", "chapter": "048_陈涉世家", "para": "14.1", "seq": 9, "text": "涉之为王沈沈者！", "len": 8}
{"sid": "048_陈涉世家.14.1.s10", "chapter": "048_陈涉世家", "para": "14.1", "seq": 10, "text": "” 楚人谓多为夥，故天下传之，夥涉为王，由陈涉始。", "len": 25}
{"sid": "048_陈涉世家.14.1.s11", "chapter": "048_陈涉世家", "para": "14.1", "seq": 11, "text": "客出入愈益发舒，言陈王故情。", "len": 14}
{"sid": "048_陈涉世家.14.1.s12", "chapter": "048_陈涉世家", "para": "14.1", "seq": 12, "text": "或说陈王曰：“客愚无知，颛妄言，轻威。", "len": 19}
{"sid": "048_陈涉世家.14.1.s13", "chapter": "048_陈涉世家", "para": "14.1", "seq": 13, "text": "” 陈王斩之。", "len": 7}
{"sid": "048_陈涉世家.14.1.s14", "chapter": "048_陈涉世家", "para": "14.1", "seq": 14, "text": "诸陈王故人皆自引去，由是无亲陈王者。", "len": 18}
{"sid": "048_陈涉世家.14.1.s15", "chapter": "048_陈涉世家", "para": "14.1", "seq": 15, "text": "陈王以硃房为中正，胡武为司过，主司群臣。", "len": 20}
{"sid": "048_陈涉世家.14.1.s16", "chapter": "048_陈涉世家", "para": "14.1", "seq": 16, "text": "诸将徇地，至，令之不是者，系而罪之，以苛察为忠。", "len": 24}
{"sid": "048_陈涉世家.14.1.s17", "chapter": "048_陈涉世家", "para": "14.1", "seq": 17, "text": "其所不善者，弗下吏，辄自治之。", "len": 15}
{"sid": "048_陈涉世家.14.1.s18", "chapter": "048_陈涉世家", "para": "14.1", "seq": 18, "text": "陈王信用之。", "len": 6}
{"sid": "048_陈涉世家.14.1.s19", "chapter": "048_陈涉世家", "para": "14.1", "seq": 19, "text": "诸将以其故不亲附，此其所以败也。", "len": 16}
{"sid": "048_陈涉世家.15.1.s1", "chapter": "048_陈涉世家", "para": "15.1", "seq": 1, "text": "陈胜虽已死，其所置遣侯王将相竟亡秦，由涉首事也。", "len": 24}
{"sid": "048_陈涉世家.15.1.s2", "chapter": "048_陈涉世家", "para": "15.1", "seq": 2, "text": "高祖时为陈涉置守冢三十家砀，至今血食。", "len": 19}
{"sid": "048_陈涉世家.16.1.s1", "chapter": "048_陈涉世家", "para": "16.1", "seq": 1, "text": "褚先生曰：地形险阻，所以为固也；兵革刑法，所以为治也。", "len": 27}
{"sid": "048_陈涉世家.16.1.s2", "chapter": "048_陈涉世家", "para": "16.1", "seq": 2, "text": "犹未足恃也。", "len": 6}
{"sid": "048_陈涉世家.16.1.s3", "chapter": "048_陈涉世家", "para": "16.1", "seq": 3, "text": "夫先王以仁义为本，而以固塞文法为枝叶，岂不然哉！", "len": 24}
{"sid": "048_陈涉世家.16.1.s4", "chapter": "048_陈涉世家", "para": "16.1", "seq": 4, "text": "吾闻贾生之称曰：", "len": 8}
{"sid": "048_陈涉世家.17.1.s1", "chapter": "048_陈涉世家", "para": "17.1", "seq": 1, "text": "“秦孝公据殽函之固，拥雍州之地，君臣固守，以窥周室。", "len": 26}
{"sid": "048_陈涉世家.17.1.s2", "chapter": "048_陈涉世家", "para": "17.1", "seq": 2, "text": "有席卷天下，包举宇内，囊括四海之意，并吞八荒之心。", "len": 25}
{"sid": "048_陈涉世家.17.1.s3", "chapter": "048_陈涉世家", "para": "17.1", "seq": 3, "text": "当是时也，商君佐之，内立法度，务耕织，脩守战之备；外连衡而斗诸侯。", "len": 33}
{"sid": "048_陈涉世家.17.1.s4", "chapter": "048_陈涉世家", "para": "17.1", "seq": 4, "text": "於是秦人拱手而取西河之外。", "len": 13}
{"sid": "048_陈涉世家.17.2.s1", "chapter": "048_陈涉世家", "para": "17.2", "seq": 1, "text": "“孝公既没，惠文王、武王、昭王蒙故业，因遗策，南取汉中，西举巴蜀，东割膏腴之地，收要害之郡。", "len": 46}
{"sid": "048_陈涉世家.17.2.s2", "chapter": "048_陈涉世家", "para": "17.2", "seq": 2, "text": "诸侯恐惧，会盟而谋弱秦。", "len": 12}
{"sid": "048_陈涉世家.17.2.s3", "chapter": "048_陈涉世家", "para": "17.2", "seq": 3, "text": "不爱珍器重宝肥饶之地，以致天下之士。", "len": 18}
{"sid": "048_陈涉世家.17.2.s4", "chapter": "048_陈涉世家", "para": "17.2", "seq": 4, "text": "合从缔交，相与为一。", "len": 10}
{"sid": "048_陈涉世家.17.2.s5", "chapter": "048_陈涉世家", "para": "17.2", "seq": 5, "text": "当此之时，齐有孟尝，赵有平原，楚有春申，魏有信陵：此四君者，皆明知而忠信，厚而爱人，尊贤而重士。", "len": 48}
{"sid": "048_陈涉世家.17.2.s6", "chapter": "048_陈涉世家", "para": "17.2", "seq": 6, "text": "约从连衡，兼韩、魏、燕、赵、宋、卫、中山之众。", "len": 23}
{"sid": "048_陈涉世家.17.2.s7", "chapter": "048_陈涉世家", "para": "17.2", "seq": 7, "text": "於是六国之士有甯越、徐尚、苏秦、杜赫之属为之谋，齐明、周勣、陈轸、邵滑、楼缓、翟景、苏厉、乐毅之徒通其意，吴起、孙膑、带他、兒良、王廖、田忌、廉颇、赵奢之伦制其兵。", "len": 82}
{"sid": "048_陈涉世家.17.2.s8", "chapter": "048_陈涉世家", "para": "17.2", "seq": 8, "text": "尝以什倍之地，百万之师，仰关而攻秦。", "len": 18}
{"sid": "048_陈涉世家.17.2.s9", "chapter": "048_陈涉世家", "para": "17.2", "seq": 9, "text": "秦人开关而延敌，九国之师遁逃而不敢进。", "len": 19}
{"sid": "048_陈涉世家.17.2.s10", "chapter": "048_陈涉世家", "para": "17.2", "seq": 10, "text": "秦无亡矢遗镞之费，而天下固已困矣。", "len": 17}
{"sid": "048_陈涉世家.17.2.s11", "chapter": "048_陈涉世家", "para": "17.2", "seq": 11, "text": "於是从散约败，争割地而赂秦。", "len": 14}
{"sid": "048_陈涉世家.17.2.s12", "chapter": "048_陈涉世家", "para": "17.2", "seq": 12, "text": "秦有馀力而制其弊，追亡逐北，伏尸百万，流血漂橹，因利乘便，宰割天下，分裂山河，彊国请服，弱国入朝。", "len": 49}
{"sid": "048_陈涉世家.17.3.s1", "chapter": "048_陈涉世家", "para": "17.3", "seq": 1, "text": "“施及孝文王、庄襄王，享国之日浅，国家无事。", "len": 22}
{"sid": "048_陈涉世家.17.4.s1", "chapter": "048_陈涉世家", "para": "17.4", "seq": 1, "text": "“及至始皇，奋六世之馀烈，振长策而御宇内，吞二周而亡诸侯，履至尊而制六合，执敲朴以鞭笞天下，威振四海。", "len": 51}
{"sid": "048_陈涉世家.17.4.s2", "chapter": "048_陈涉世家", "para": "17.4", "seq": 2, "text": "南取百越之地，以为桂林、象郡，百越之君俯首系颈，委命下吏。", "len": 29}
{"sid": "048_陈涉世家.17.4.s3", "chapter": "048_陈涉世家", "para": "17.4", "seq": 3, "text": "乃使蒙恬北筑长城而守籓篱，卻匈奴七百馀里，胡人不敢南下而牧马，士亦不敢贯弓而报怨。", "len": 41}
{"sid": "048_陈涉世家.17.4.s4", "chapter": "048_陈涉世家", "para": "17.4", "seq": 4, "text": "於是废先王之道，燔百家之言，以愚黔首。", "len": 19}
{"sid": "048_陈涉世家.17.4.s5", "chapter": "048_陈涉世家", "para": "17.4", "seq": 5, "text": "堕名城，杀豪俊，收天下之兵聚之咸阳，销锋鍉，铸以为金人十二，以弱天下之民。", "len": 37}
{"sid": "048_陈涉世家.17.4.s6", "chapter": "048_陈涉世家", "para": "17.4", "seq": 6, "text": "然後践华为城，因河为池，据亿丈之城，临不测之谿以为固。", "len": 27}
{"sid": "048_陈涉世家.17.4.s7", "chapter": "048_陈涉世家", "para": "17.4", "seq": 7, "text": "良将劲弩，守要害之处，信臣精卒，陈利兵而谁何。", "len": 23}
{"sid": "048_陈涉世家.17.4.s8", "chapter": "048_陈涉世家", "para": "17.4", "seq": 8, "text": "天下已定，始皇之心，自以为关中之固，金城千里，子孙帝王万世之业也。", "len": 33}
{"sid": "048_陈涉世家.17.5.s1", "chapter": "048_陈涉世家", "para": "17.5", "seq": 1, "text": "“始皇既没，馀威振於殊俗。", "len": 13}
{"sid": "048_陈涉世家.17.5.s2", "chapter": "048_陈涉世家", "para": "17.5", "seq": 2, "text": "然而陈涉甕牖绳枢之子，甿隶之人，而迁徙之徒也。", "len": 23}
{"sid": "048_陈涉世家.17.5.s3", "chapter": "048_陈涉世家", "para": "17.5", "seq": 3, "text": "材能不及中人，非有仲尼、墨翟之贤，陶硃、猗顿之富也。", "len": 26}
{"sid": "048_陈涉世家.17.5.s4", "chapter": "048_陈涉世家", "para": "17.5", "seq": 4, "text": "蹑足行伍之间，俯仰仟佰之中，率罢散之卒，将数百之众，转而攻秦。", "len": 31}
{"sid": "048_陈涉世家.17.5.s5", "chapter": "048_陈涉世家", "para": "17.5", "seq": 5, "text": "斩木为兵，揭竿为旗，天下云会响应，赢粮而景从，山东豪俊遂并起而亡秦族矣。", "len": 36}
{"sid": "048_陈涉世家.17.6.s1", "chapter": "048_陈涉世家", "para": "17.6", "seq": 1, "text": "“且天下非小弱也；雍州之地，殽函之固自若也。", "len": 22}
{"sid": "048_陈涉世家.17.6.s2", "chapter": "048_陈涉世家", "para": "17.6", "seq": 2, "text": "陈涉之位，非尊於齐、楚、燕、赵、韩、魏、宋、卫、中山之君也；鉏櫌棘矜，非銛於句戟长铩也；適戍之众，非俦於九国之师也；深谋远虑，行军用兵之道，非及乡时之士也。", "len": 78}
{"sid": "048_陈涉世家.17.6.s3", "chapter": "048_陈涉世家", "para": "17.6", "seq": 3, "text": "然而成败异变，功业相反也。", "len": 13}
{"sid": "048_陈涉世家.17.6.s4", "chapter": "048_陈涉世家", "para": "17.6", "seq": 4, "text": "尝试使山东之国与陈涉度长絜大，比权量力，则不可同年而语矣。", "len": 29}
{"sid": "048_陈涉世家.17.6.s5", "chapter": "048_陈涉世家", "para": "17.6", "seq": 5, "text": "然而秦以区区之地。", "len": 9}
{"sid": "048_陈涉世家.17.6.s6", "chapter": "048_陈涉世家", "para": "17.6", "seq": 6, "text": "致万乘之权，抑八州而朝同列，百有馀年矣。", "len": 20}
{"sid": "048_陈涉世家.17.6.s7", "chapter": "048_陈涉世家", "para": "17.6", "seq": 7, "text": "然後以六合为家，殽函为宫。", "len": 13}
{"sid": "048_陈涉世家.17.6.s8", "chapter": "048_陈涉世家", "para": "17.6", "seq": 8, "text": "一夫作难而七庙堕，身死人手，为天下笑者，何也？", "len": 23}
{"sid": "048_陈涉世家.17.6.s9", "chapter": "048_陈涉世家", "para": "17.6", "seq": 9, "text": "仁义不施，而攻守之势异也。", "len": 13}
{"sid": "048_陈涉世家.17.6.s10", "chapter": "048_陈涉世家", "para": "17.6", "seq": 10, "text": "” ::: 赞", "len": 7}
{"sid": "048_陈涉世家.18.s1", "chapter": "048_陈涉世家", "para": "18", "seq": 1, "text": "天下匈匈，海内乏主， 掎鹿争捷，瞻乌爰处。", "len": 21}
{"sid": "048_陈涉世家.18.s2", "chapter": "048_陈涉世家", "para": "18", "seq": 2, "text": "陈胜首事，厥号张楚。", "len": 10}
{"sid": "048_陈涉世家.18.s3", "chapter": "048_陈涉世家", "para": "18", "seq": 3, "text": "鬼怪是凭，鸿鹄自许。", "len": 10}
{"sid": "048_陈涉世家.18.s4", "chapter": "048_陈涉世家", "para": "18", "seq": 4, "text": "葛婴东下，周文西拒。", "len": 10}
{"sid": "048_陈涉世家.18.s5", "chapter": "048_陈涉世家", "para": "18", "seq": 5, "text": "始亲硃房，又任胡武。", "len": 10}
{"sid": "048_陈涉世家.18.s6", "chapter": "048_陈涉世家", "para": "18", "seq": 6, "text": "夥颐见杀，腹心不与。", "len": 10}
{"sid": "048_陈涉世家.18.s7", "chapter": "048_陈涉世家", "para": "18", "seq": 7, "text": "庄贾何人，反噬城父！", "len": 10}
{"sid": "048_陈涉世家.18.s8", "chapter": "048_陈涉世家", "para": "18", "seq": 8, "text": ":::", "len": 3}
