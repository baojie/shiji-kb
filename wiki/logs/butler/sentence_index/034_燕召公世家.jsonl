{"sid": "034_燕召公世家.1.1.s1", "chapter": "034_燕召公世家", "para": "1.1", "seq": 1, "text": "召公奭与周同姓，姓姬氏。", "len": 12}
{"sid": "034_燕召公世家.1.1.s2", "chapter": "034_燕召公世家", "para": "1.1", "seq": 2, "text": "周武王之灭纣，封召公於北燕。", "len": 14}
{"sid": "034_燕召公世家.2.1.s1", "chapter": "034_燕召公世家", "para": "2.1", "seq": 1, "text": "其在成王时，召公为三公：自陕以西，召公主之；自陕以东，周公主之。", "len": 32}
{"sid": "034_燕召公世家.2.1.s2", "chapter": "034_燕召公世家", "para": "2.1", "seq": 2, "text": "成王既幼，周公摄政，当国践祚，召公疑之，作君奭。", "len": 24}
{"sid": "034_燕召公世家.2.1.s3", "chapter": "034_燕召公世家", "para": "2.1", "seq": 3, "text": "君奭不说周公。", "len": 7}
{"sid": "034_燕召公世家.2.1.s4", "chapter": "034_燕召公世家", "para": "2.1", "seq": 4, "text": "周公乃称“汤时有伊尹，假于皇天；在太戊时，则有若伊陟、臣扈，假于上帝，巫咸治王家；在祖乙时，则有若巫贤；在武丁时，则有若甘般：率维兹有陈，保乂有殷”。", "len": 75}
{"sid": "034_燕召公世家.2.1.s5", "chapter": "034_燕召公世家", "para": "2.1", "seq": 5, "text": "於是召公乃说。", "len": 7}
{"sid": "034_燕召公世家.3.1.s1", "chapter": "034_燕召公世家", "para": "3.1", "seq": 1, "text": "召公之治西方，甚得兆民和。", "len": 13}
{"sid": "034_燕召公世家.3.1.s2", "chapter": "034_燕召公世家", "para": "3.1", "seq": 2, "text": "召公巡行乡邑，有棠树，决狱政事其下，自侯伯至庶人各得其所，无失职者。", "len": 34}
{"sid": "034_燕召公世家.3.1.s3", "chapter": "034_燕召公世家", "para": "3.1", "seq": 3, "text": "召公卒，而民人思召公之政，怀棠树不敢伐，哥咏之，作甘棠之诗。", "len": 30}
{"sid": "034_燕召公世家.4.1.s1", "chapter": "034_燕召公世家", "para": "4.1", "seq": 1, "text": "自召公已下九世至惠侯。", "len": 11}
{"sid": "034_燕召公世家.4.1.s2", "chapter": "034_燕召公世家", "para": "4.1", "seq": 2, "text": "燕惠侯当周厉王奔彘，共和之时。", "len": 15}
{"sid": "034_燕召公世家.5.1.s1", "chapter": "034_燕召公世家", "para": "5.1", "seq": 1, "text": "惠侯卒，子釐侯立。", "len": 9}
{"sid": "034_燕召公世家.5.1.s2", "chapter": "034_燕召公世家", "para": "5.1", "seq": 2, "text": "是岁，周宣王初即位。", "len": 10}
{"sid": "034_燕召公世家.5.1.s3", "chapter": "034_燕召公世家", "para": "5.1", "seq": 3, "text": "釐侯二十一年，郑桓公初封於郑。", "len": 15}
{"sid": "034_燕召公世家.5.1.s4", "chapter": "034_燕召公世家", "para": "5.1", "seq": 4, "text": "三十六年，釐侯卒，子顷侯立。", "len": 14}
{"sid": "034_燕召公世家.5.2.s1", "chapter": "034_燕召公世家", "para": "5.2", "seq": 1, "text": "顷侯二十年，周幽王淫乱，为犬戎所弑。", "len": 18}
{"sid": "034_燕召公世家.5.2.s2", "chapter": "034_燕召公世家", "para": "5.2", "seq": 2, "text": "秦始列为诸侯。", "len": 7}
{"sid": "034_燕召公世家.5.3.s1", "chapter": "034_燕召公世家", "para": "5.3", "seq": 1, "text": "二十四年，顷侯卒，子哀侯立。", "len": 14}
{"sid": "034_燕召公世家.5.3.s2", "chapter": "034_燕召公世家", "para": "5.3", "seq": 2, "text": "哀侯二年卒，子郑侯立。", "len": 11}
{"sid": "034_燕召公世家.5.3.s3", "chapter": "034_燕召公世家", "para": "5.3", "seq": 3, "text": "郑侯三十六年卒，子缪侯立。", "len": 13}
{"sid": "034_燕召公世家.6.1.s1", "chapter": "034_燕召公世家", "para": "6.1", "seq": 1, "text": "缪侯七年，而鲁隐公元年也。", "len": 13}
{"sid": "034_燕召公世家.6.1.s2", "chapter": "034_燕召公世家", "para": "6.1", "seq": 2, "text": "十八年卒，子宣侯立。", "len": 10}
{"sid": "034_燕召公世家.6.1.s3", "chapter": "034_燕召公世家", "para": "6.1", "seq": 3, "text": "宣侯十三年卒，子桓侯立。", "len": 12}
{"sid": "034_燕召公世家.6.1.s4", "chapter": "034_燕召公世家", "para": "6.1", "seq": 4, "text": "桓侯七年卒，子庄公立。", "len": 11}
{"sid": "034_燕召公世家.7.1.s1", "chapter": "034_燕召公世家", "para": "7.1", "seq": 1, "text": "庄公十二年，齐桓公始霸。", "len": 12}
{"sid": "034_燕召公世家.7.1.s2", "chapter": "034_燕召公世家", "para": "7.1", "seq": 2, "text": "十六年，与宋、卫共伐周惠王，惠王出奔温，立惠王弟穨为周王。", "len": 29}
{"sid": "034_燕召公世家.7.1.s3", "chapter": "034_燕召公世家", "para": "7.1", "seq": 3, "text": "十七年，郑执燕仲父而内惠王于周。", "len": 16}
{"sid": "034_燕召公世家.7.1.s4", "chapter": "034_燕召公世家", "para": "7.1", "seq": 4, "text": "二十七年，山戎来侵我，齐桓公救燕，遂北伐山戎而还。", "len": 25}
{"sid": "034_燕召公世家.7.1.s5", "chapter": "034_燕召公世家", "para": "7.1", "seq": 5, "text": "燕君送齐桓公出境，桓公因割燕所至地予燕，使燕共贡天子，如成周时职；使燕复修召公之法。", "len": 42}
{"sid": "034_燕召公世家.7.1.s6", "chapter": "034_燕召公世家", "para": "7.1", "seq": 6, "text": "三十三年卒，子襄公立。", "len": 11}
{"sid": "034_燕召公世家.8.1.s1", "chapter": "034_燕召公世家", "para": "8.1", "seq": 1, "text": "襄公二十六年，晋文公为践土之会，称伯。", "len": 19}
{"sid": "034_燕召公世家.8.1.s2", "chapter": "034_燕召公世家", "para": "8.1", "seq": 2, "text": "三十一年，秦师败于殽。", "len": 11}
{"sid": "034_燕召公世家.8.1.s3", "chapter": "034_燕召公世家", "para": "8.1", "seq": 3, "text": "三十七年，秦穆公卒。", "len": 10}
{"sid": "034_燕召公世家.8.1.s4", "chapter": "034_燕召公世家", "para": "8.1", "seq": 4, "text": "四十年，襄公卒，桓公立。", "len": 12}
{"sid": "034_燕召公世家.8.2.s1", "chapter": "034_燕召公世家", "para": "8.2", "seq": 1, "text": "桓公十六年卒，宣公立。", "len": 11}
{"sid": "034_燕召公世家.8.2.s2", "chapter": "034_燕召公世家", "para": "8.2", "seq": 2, "text": "宣公十五年卒，昭公立。", "len": 11}
{"sid": "034_燕召公世家.8.2.s3", "chapter": "034_燕召公世家", "para": "8.2", "seq": 3, "text": "昭公十三年卒，武公立。", "len": 11}
{"sid": "034_燕召公世家.8.2.s4", "chapter": "034_燕召公世家", "para": "8.2", "seq": 4, "text": "是岁晋灭三郤大夫。", "len": 9}
{"sid": "034_燕召公世家.8.3.s1", "chapter": "034_燕召公世家", "para": "8.3", "seq": 1, "text": "武公十九年卒，文公立。", "len": 11}
{"sid": "034_燕召公世家.8.3.s2", "chapter": "034_燕召公世家", "para": "8.3", "seq": 2, "text": "文公六年卒，懿公立。", "len": 10}
{"sid": "034_燕召公世家.8.3.s3", "chapter": "034_燕召公世家", "para": "8.3", "seq": 3, "text": "懿公元年，齐崔杼弑其君庄公。", "len": 14}
{"sid": "034_燕召公世家.8.3.s4", "chapter": "034_燕召公世家", "para": "8.3", "seq": 4, "text": "四年卒，子惠公立。", "len": 9}
{"sid": "034_燕召公世家.9.1.s1", "chapter": "034_燕召公世家", "para": "9.1", "seq": 1, "text": "惠公元年，齐高止来奔。", "len": 11}
{"sid": "034_燕召公世家.9.1.s2", "chapter": "034_燕召公世家", "para": "9.1", "seq": 2, "text": "六年，惠公多宠姬，公欲去诸大夫而立宠姬宋，大夫共诛姬宋，惠公惧，奔齐。", "len": 35}
{"sid": "034_燕召公世家.9.1.s3", "chapter": "034_燕召公世家", "para": "9.1", "seq": 3, "text": "四年，齐高偃如晋，请共伐燕，入其君。", "len": 18}
{"sid": "034_燕召公世家.9.1.s4", "chapter": "034_燕召公世家", "para": "9.1", "seq": 4, "text": "晋平公许，与齐伐燕，入惠公。", "len": 14}
{"sid": "034_燕召公世家.9.1.s5", "chapter": "034_燕召公世家", "para": "9.1", "seq": 5, "text": "惠公至燕而死。", "len": 7}
{"sid": "034_燕召公世家.9.1.s6", "chapter": "034_燕召公世家", "para": "9.1", "seq": 6, "text": "燕立悼公。", "len": 5}
{"sid": "034_燕召公世家.10.1.s1", "chapter": "034_燕召公世家", "para": "10.1", "seq": 1, "text": "悼公七年卒，共公立。", "len": 10}
{"sid": "034_燕召公世家.10.1.s2", "chapter": "034_燕召公世家", "para": "10.1", "seq": 2, "text": "共公五年卒，平公立。", "len": 10}
{"sid": "034_燕召公世家.10.1.s3", "chapter": "034_燕召公世家", "para": "10.1", "seq": 3, "text": "晋公室卑，六卿始彊大。", "len": 11}
{"sid": "034_燕召公世家.10.1.s4", "chapter": "034_燕召公世家", "para": "10.1", "seq": 4, "text": "平公十八年，吴王阖闾破楚入郢。", "len": 15}
{"sid": "034_燕召公世家.10.1.s5", "chapter": "034_燕召公世家", "para": "10.1", "seq": 5, "text": "十九年卒，简公立。", "len": 9}
{"sid": "034_燕召公世家.10.1.s6", "chapter": "034_燕召公世家", "para": "10.1", "seq": 6, "text": "简公十二年卒，献公立。", "len": 11}
{"sid": "034_燕召公世家.10.1.s7", "chapter": "034_燕召公世家", "para": "10.1", "seq": 7, "text": "晋赵鞅围范、中行於朝歌。", "len": 12}
{"sid": "034_燕召公世家.10.1.s8", "chapter": "034_燕召公世家", "para": "10.1", "seq": 8, "text": "献公十二年，齐田常弑其君简公。", "len": 15}
{"sid": "034_燕召公世家.10.1.s9", "chapter": "034_燕召公世家", "para": "10.1", "seq": 9, "text": "十四年，孔子卒。", "len": 8}
{"sid": "034_燕召公世家.10.1.s10", "chapter": "034_燕召公世家", "para": "10.1", "seq": 10, "text": "二十八年，献公卒，孝公立。", "len": 13}
{"sid": "034_燕召公世家.11.1.s1", "chapter": "034_燕召公世家", "para": "11.1", "seq": 1, "text": "孝公十二年，韩、魏、赵灭知伯，分其地，三晋彊。", "len": 23}
{"sid": "034_燕召公世家.11.2.s1", "chapter": "034_燕召公世家", "para": "11.2", "seq": 1, "text": "十五年，孝公卒，成公立。", "len": 12}
{"sid": "034_燕召公世家.11.2.s2", "chapter": "034_燕召公世家", "para": "11.2", "seq": 2, "text": "成公十六年卒，湣公立。", "len": 11}
{"sid": "034_燕召公世家.11.2.s3", "chapter": "034_燕召公世家", "para": "11.2", "seq": 3, "text": "湣公三十一年卒，釐公立。", "len": 12}
{"sid": "034_燕召公世家.11.2.s4", "chapter": "034_燕召公世家", "para": "11.2", "seq": 4, "text": "是岁，三晋列为诸侯。", "len": 10}
{"sid": "034_燕召公世家.12.1.s1", "chapter": "034_燕召公世家", "para": "12.1", "seq": 1, "text": "釐公三十年，伐败齐于林营。", "len": 13}
{"sid": "034_燕召公世家.12.1.s2", "chapter": "034_燕召公世家", "para": "12.1", "seq": 2, "text": "釐公卒，桓公立。", "len": 8}
{"sid": "034_燕召公世家.12.1.s3", "chapter": "034_燕召公世家", "para": "12.1", "seq": 3, "text": "桓公十一年卒，文公立。", "len": 11}
{"sid": "034_燕召公世家.12.1.s4", "chapter": "034_燕召公世家", "para": "12.1", "seq": 4, "text": "是岁，秦献公卒。", "len": 8}
{"sid": "034_燕召公世家.12.1.s5", "chapter": "034_燕召公世家", "para": "12.1", "seq": 5, "text": "秦益彊。", "len": 4}
{"sid": "034_燕召公世家.13.1.s1", "chapter": "034_燕召公世家", "para": "13.1", "seq": 1, "text": "文公十九年，齐威王卒。", "len": 11}
{"sid": "034_燕召公世家.13.1.s2", "chapter": "034_燕召公世家", "para": "13.1", "seq": 2, "text": "二十八年，苏秦始来见，说文公。", "len": 15}
{"sid": "034_燕召公世家.13.1.s3", "chapter": "034_燕召公世家", "para": "13.1", "seq": 3, "text": "文公予车马金帛以至赵，赵肃侯用之。", "len": 17}
{"sid": "034_燕召公世家.13.1.s4", "chapter": "034_燕召公世家", "para": "13.1", "seq": 4, "text": "因约六国，为从长。", "len": 9}
{"sid": "034_燕召公世家.13.1.s5", "chapter": "034_燕召公世家", "para": "13.1", "seq": 5, "text": "秦惠王以其女为燕太子妇。", "len": 12}
{"sid": "034_燕召公世家.13.2.s1", "chapter": "034_燕召公世家", "para": "13.2", "seq": 1, "text": "二十九年，文公卒，太子立，是为易王。", "len": 18}
{"sid": "034_燕召公世家.14.1.s1", "chapter": "034_燕召公世家", "para": "14.1", "seq": 1, "text": "易王初立，齐宣王因燕丧伐我，取十城；苏秦说齐，使复归燕十城。", "len": 30}
{"sid": "034_燕召公世家.14.1.s2", "chapter": "034_燕召公世家", "para": "14.1", "seq": 2, "text": "十年，燕君为王。", "len": 8}
{"sid": "034_燕召公世家.14.1.s3", "chapter": "034_燕召公世家", "para": "14.1", "seq": 3, "text": "苏秦与燕文公夫人私通，惧诛，乃说王使齐为反间，欲以乱齐。", "len": 28}
{"sid": "034_燕召公世家.14.1.s4", "chapter": "034_燕召公世家", "para": "14.1", "seq": 4, "text": "易王立十二年卒，子燕哙立。", "len": 13}
{"sid": "034_燕召公世家.15.1.s1", "chapter": "034_燕召公世家", "para": "15.1", "seq": 1, "text": "燕哙既立，齐人杀苏秦。", "len": 11}
{"sid": "034_燕召公世家.15.1.s2", "chapter": "034_燕召公世家", "para": "15.1", "seq": 2, "text": "苏秦之在燕，与其相子之为婚，而苏代与子之交。", "len": 22}
{"sid": "034_燕召公世家.15.1.s3", "chapter": "034_燕召公世家", "para": "15.1", "seq": 3, "text": "及苏秦死，而齐宣王复用苏代。", "len": 14}
{"sid": "034_燕召公世家.15.1.s4", "chapter": "034_燕召公世家", "para": "15.1", "seq": 4, "text": "燕哙三年，与楚、三晋攻秦，不胜而还。", "len": 18}
{"sid": "034_燕召公世家.15.1.s5", "chapter": "034_燕召公世家", "para": "15.1", "seq": 5, "text": "子之相燕，贵重，主断。", "len": 11}
{"sid": "034_燕召公世家.15.1.s6", "chapter": "034_燕召公世家", "para": "15.1", "seq": 6, "text": "苏代为齐使於燕，燕王问曰：“齐王奚如？", "len": 19}
{"sid": "034_燕召公世家.15.1.s7", "chapter": "034_燕召公世家", "para": "15.1", "seq": 7, "text": "” 对曰：“必不霸。", "len": 10}
{"sid": "034_燕召公世家.15.1.s8", "chapter": "034_燕召公世家", "para": "15.1", "seq": 8, "text": "” 燕王曰：“何也？", "len": 10}
{"sid": "034_燕召公世家.15.1.s9", "chapter": "034_燕召公世家", "para": "15.1", "seq": 9, "text": "” 对曰：“不信其臣。", "len": 11}
{"sid": "034_燕召公世家.15.1.s10", "chapter": "034_燕召公世家", "para": "15.1", "seq": 10, "text": "” 苏代欲以激燕王以尊子之也。", "len": 15}
{"sid": "034_燕召公世家.15.1.s11", "chapter": "034_燕召公世家", "para": "15.1", "seq": 11, "text": "於是燕王大信子之。", "len": 9}
{"sid": "034_燕召公世家.15.1.s12", "chapter": "034_燕召公世家", "para": "15.1", "seq": 12, "text": "子之因遗苏代百金，而听其所使。", "len": 15}
{"sid": "034_燕召公世家.15.2.s1", "chapter": "034_燕召公世家", "para": "15.2", "seq": 1, "text": "鹿毛寿谓燕王：“不如以国让相子之。", "len": 17}
{"sid": "034_燕召公世家.15.2.s2", "chapter": "034_燕召公世家", "para": "15.2", "seq": 2, "text": "人之谓尧贤者，以其让天下於许由，许由不受，有让天下之名而实不失天下。", "len": 34}
{"sid": "034_燕召公世家.15.2.s3", "chapter": "034_燕召公世家", "para": "15.2", "seq": 3, "text": "今王以国让於子之，子之必不敢受，是王与尧同行也。", "len": 24}
{"sid": "034_燕召公世家.15.2.s4", "chapter": "034_燕召公世家", "para": "15.2", "seq": 4, "text": "” 燕王因属国於子之，子之大重。", "len": 16}
{"sid": "034_燕召公世家.15.2.s5", "chapter": "034_燕召公世家", "para": "15.2", "seq": 5, "text": "或曰：“禹荐益，已而以启人为吏。", "len": 16}
{"sid": "034_燕召公世家.15.2.s6", "chapter": "034_燕召公世家", "para": "15.2", "seq": 6, "text": "及老，而以启人为不足任乎天下，传之於益。", "len": 20}
{"sid": "034_燕召公世家.15.2.s7", "chapter": "034_燕召公世家", "para": "15.2", "seq": 7, "text": "已而启与交党攻益，夺之。", "len": 12}
{"sid": "034_燕召公世家.15.2.s8", "chapter": "034_燕召公世家", "para": "15.2", "seq": 8, "text": "天下谓禹名传天下於益，已而实令启自取之。", "len": 20}
{"sid": "034_燕召公世家.15.2.s9", "chapter": "034_燕召公世家", "para": "15.2", "seq": 9, "text": "今王言属国於子之，而吏无非太子人者，是名属子之而实太子用事也。", "len": 31}
{"sid": "034_燕召公世家.15.2.s10", "chapter": "034_燕召公世家", "para": "15.2", "seq": 10, "text": "” 王因收印自三百石吏已上而效之子之。", "len": 19}
{"sid": "034_燕召公世家.15.2.s11", "chapter": "034_燕召公世家", "para": "15.2", "seq": 11, "text": "子之南面行王事，而哙老不听政，顾为臣，国事皆决於子之。", "len": 27}
{"sid": "034_燕召公世家.15.3.s1", "chapter": "034_燕召公世家", "para": "15.3", "seq": 1, "text": "三年，国大乱，百姓恫恐。", "len": 12}
{"sid": "034_燕召公世家.15.3.s2", "chapter": "034_燕召公世家", "para": "15.3", "seq": 2, "text": "将军市被与太子平谋，将攻子之。", "len": 15}
{"sid": "034_燕召公世家.15.3.s3", "chapter": "034_燕召公世家", "para": "15.3", "seq": 3, "text": "诸将谓齐湣王曰：“因而赴之，破燕必矣。", "len": 19}
{"sid": "034_燕召公世家.15.3.s4", "chapter": "034_燕召公世家", "para": "15.3", "seq": 4, "text": "” 齐王因令人谓燕太子平曰：“寡人闻太子之义，将废私而立公，饬君臣之义，明父子之位。", "len": 42}
{"sid": "034_燕召公世家.15.3.s5", "chapter": "034_燕召公世家", "para": "15.3", "seq": 5, "text": "寡人之国小，不足以为先後。", "len": 13}
{"sid": "034_燕召公世家.15.3.s6", "chapter": "034_燕召公世家", "para": "15.3", "seq": 6, "text": "虽然，则唯太子所以令之。", "len": 12}
{"sid": "034_燕召公世家.15.3.s7", "chapter": "034_燕召公世家", "para": "15.3", "seq": 7, "text": "” 太子因要党聚众，将军市被围公宫，攻子之，不克。", "len": 25}
{"sid": "034_燕召公世家.15.3.s8", "chapter": "034_燕召公世家", "para": "15.3", "seq": 8, "text": "将军市被及百姓反攻太子平，将军市被死，以徇。", "len": 22}
{"sid": "034_燕召公世家.15.3.s9", "chapter": "034_燕召公世家", "para": "15.3", "seq": 9, "text": "因搆难数月，死者数万，众人恫恐，百姓离志。", "len": 21}
{"sid": "034_燕召公世家.15.3.s10", "chapter": "034_燕召公世家", "para": "15.3", "seq": 10, "text": "孟轲谓齐王曰：“今伐燕，此文、武之时，不可失也。", "len": 24}
{"sid": "034_燕召公世家.15.3.s11", "chapter": "034_燕召公世家", "para": "15.3", "seq": 11, "text": "” 王因令章子将五都之兵，以因北地之众以伐燕。", "len": 23}
{"sid": "034_燕召公世家.15.3.s12", "chapter": "034_燕召公世家", "para": "15.3", "seq": 12, "text": "士卒不战，城门不闭，燕君哙死，齐大胜。", "len": 19}
{"sid": "034_燕召公世家.15.3.s13", "chapter": "034_燕召公世家", "para": "15.3", "seq": 13, "text": "燕子之亡二年，而燕人共立太子平，是为燕昭王。", "len": 22}
{"sid": "034_燕召公世家.16.1.s1", "chapter": "034_燕召公世家", "para": "16.1", "seq": 1, "text": "燕昭王於破燕之後即位，卑身厚币以招贤者。", "len": 20}
{"sid": "034_燕召公世家.16.1.s2", "chapter": "034_燕召公世家", "para": "16.1", "seq": 2, "text": "谓郭隗曰：“齐因孤之国乱而袭破燕，孤极知燕小力少，不足以报。", "len": 30}
{"sid": "034_燕召公世家.16.1.s3", "chapter": "034_燕召公世家", "para": "16.1", "seq": 3, "text": "然诚得贤士以共国，以雪先王之耻，孤之原也。", "len": 21}
{"sid": "034_燕召公世家.16.1.s4", "chapter": "034_燕召公世家", "para": "16.1", "seq": 4, "text": "先生视可者，得身事之。", "len": 11}
{"sid": "034_燕召公世家.16.1.s5", "chapter": "034_燕召公世家", "para": "16.1", "seq": 5, "text": "” 郭隗曰：“王必欲致士，先从隗始。", "len": 18}
{"sid": "034_燕召公世家.16.1.s6", "chapter": "034_燕召公世家", "para": "16.1", "seq": 6, "text": "况贤於隗者，岂远千里哉！", "len": 12}
{"sid": "034_燕召公世家.16.1.s7", "chapter": "034_燕召公世家", "para": "16.1", "seq": 7, "text": "” 於是昭王为隗改筑宫而师事之。", "len": 16}
{"sid": "034_燕召公世家.16.1.s8", "chapter": "034_燕召公世家", "para": "16.1", "seq": 8, "text": "乐毅自魏往，邹衍自齐往，剧辛自赵往，士争趋燕。", "len": 23}
{"sid": "034_燕召公世家.16.1.s9", "chapter": "034_燕召公世家", "para": "16.1", "seq": 9, "text": "燕王吊死问孤，与百姓同甘苦。", "len": 14}
{"sid": "034_燕召公世家.17.1.s1", "chapter": "034_燕召公世家", "para": "17.1", "seq": 1, "text": "二十八年，燕国殷富，士卒乐轶轻战，於是遂以乐毅为上将军，与秦、楚、三晋合谋以伐齐。", "len": 41}
{"sid": "034_燕召公世家.17.1.s2", "chapter": "034_燕召公世家", "para": "17.1", "seq": 2, "text": "齐兵败，湣王出亡於外。", "len": 11}
{"sid": "034_燕召公世家.17.1.s3", "chapter": "034_燕召公世家", "para": "17.1", "seq": 3, "text": "燕兵独追北，入至临淄，尽取齐宝，烧其宫室宗庙。", "len": 23}
{"sid": "034_燕召公世家.17.1.s4", "chapter": "034_燕召公世家", "para": "17.1", "seq": 4, "text": "齐城之不下者，独唯聊、莒、即墨，其馀皆属燕，六岁。", "len": 25}
{"sid": "034_燕召公世家.17.2.s1", "chapter": "034_燕召公世家", "para": "17.2", "seq": 1, "text": "昭王三十三年卒，子惠王立。", "len": 13}
{"sid": "034_燕召公世家.18.1.s1", "chapter": "034_燕召公世家", "para": "18.1", "seq": 1, "text": "惠王为太子时，与乐毅有隙；及即位，疑毅，使骑劫代将。", "len": 26}
{"sid": "034_燕召公世家.18.1.s2", "chapter": "034_燕召公世家", "para": "18.1", "seq": 2, "text": "乐毅亡走赵。", "len": 6}
{"sid": "034_燕召公世家.18.1.s3", "chapter": "034_燕召公世家", "para": "18.1", "seq": 3, "text": "齐田单以即墨击败燕军，骑劫死，燕兵引归，齐悉复得其故城。", "len": 28}
{"sid": "034_燕召公世家.18.1.s4", "chapter": "034_燕召公世家", "para": "18.1", "seq": 4, "text": "湣王死于莒，乃立其子为襄王。", "len": 14}
{"sid": "034_燕召公世家.18.2.s1", "chapter": "034_燕召公世家", "para": "18.2", "seq": 1, "text": "惠王七年卒。", "len": 6}
{"sid": "034_燕召公世家.18.2.s2", "chapter": "034_燕召公世家", "para": "18.2", "seq": 2, "text": "韩、魏、楚共伐燕。", "len": 9}
{"sid": "034_燕召公世家.18.2.s3", "chapter": "034_燕召公世家", "para": "18.2", "seq": 3, "text": "燕武成王立。", "len": 6}
{"sid": "034_燕召公世家.19.1.s1", "chapter": "034_燕召公世家", "para": "19.1", "seq": 1, "text": "武成王七年，齐田单伐我，拔中阳。", "len": 16}
{"sid": "034_燕召公世家.19.1.s2", "chapter": "034_燕召公世家", "para": "19.1", "seq": 2, "text": "十三年，秦败赵於长平四十馀万。", "len": 15}
{"sid": "034_燕召公世家.19.1.s3", "chapter": "034_燕召公世家", "para": "19.1", "seq": 3, "text": "十四年，武成王卒，子孝王立。", "len": 14}
{"sid": "034_燕召公世家.19.2.s1", "chapter": "034_燕召公世家", "para": "19.2", "seq": 1, "text": "孝王元年，秦围邯郸者解去。", "len": 13}
{"sid": "034_燕召公世家.19.2.s2", "chapter": "034_燕召公世家", "para": "19.2", "seq": 2, "text": "三年卒，子今王喜立。", "len": 10}
{"sid": "034_燕召公世家.20.1.s1", "chapter": "034_燕召公世家", "para": "20.1", "seq": 1, "text": "今王喜四年，秦昭王卒。", "len": 11}
{"sid": "034_燕召公世家.20.1.s2", "chapter": "034_燕召公世家", "para": "20.1", "seq": 2, "text": "燕王命相栗腹约欢赵，以五百金为赵王酒。", "len": 19}
{"sid": "034_燕召公世家.20.1.s3", "chapter": "034_燕召公世家", "para": "20.1", "seq": 3, "text": "还报燕王曰：“赵王壮者皆死长平，其孤未壮，可伐也。", "len": 25}
{"sid": "034_燕召公世家.20.1.s4", "chapter": "034_燕召公世家", "para": "20.1", "seq": 4, "text": "” 王召昌国君乐间问之。", "len": 12}
{"sid": "034_燕召公世家.20.1.s5", "chapter": "034_燕召公世家", "para": "20.1", "seq": 5, "text": "对曰：“赵四战之国，其民习兵，不可伐。", "len": 19}
{"sid": "034_燕召公世家.20.1.s6", "chapter": "034_燕召公世家", "para": "20.1", "seq": 6, "text": "” 王曰：“吾以五而伐一。", "len": 13}
{"sid": "034_燕召公世家.20.1.s7", "chapter": "034_燕召公世家", "para": "20.1", "seq": 7, "text": "” 对曰：“不可。", "len": 9}
{"sid": "034_燕召公世家.20.1.s8", "chapter": "034_燕召公世家", "para": "20.1", "seq": 8, "text": "” 燕王怒，群臣皆以为可。", "len": 13}
{"sid": "034_燕召公世家.20.1.s9", "chapter": "034_燕召公世家", "para": "20.1", "seq": 9, "text": "卒起二军，车二千乘，栗腹将而攻鄗，卿秦攻代。", "len": 22}
{"sid": "034_燕召公世家.20.1.s10", "chapter": "034_燕召公世家", "para": "20.1", "seq": 10, "text": "唯独大夫将渠谓燕王曰：“与人通关约交，以五百金饮人之王，使者报而反攻之，不祥，兵无成功。", "len": 44}
{"sid": "034_燕召公世家.20.1.s11", "chapter": "034_燕召公世家", "para": "20.1", "seq": 11, "text": "” 燕王不听，自将偏军随之。", "len": 14}
{"sid": "034_燕召公世家.20.1.s12", "chapter": "034_燕召公世家", "para": "20.1", "seq": 12, "text": "将渠引燕王绶止之曰：“王必无自往，往无成功。", "len": 22}
{"sid": "034_燕召公世家.20.1.s13", "chapter": "034_燕召公世家", "para": "20.1", "seq": 13, "text": "” 王槅之以足。", "len": 8}
{"sid": "034_燕召公世家.20.1.s14", "chapter": "034_燕召公世家", "para": "20.1", "seq": 14, "text": "将渠泣曰：“臣非以自为，为王也！", "len": 16}
{"sid": "034_燕召公世家.20.1.s15", "chapter": "034_燕召公世家", "para": "20.1", "seq": 15, "text": "” 燕军至宋子，赵使廉颇将，击破栗腹於鄗。", "len": 21}
{"sid": "034_燕召公世家.20.1.s16", "chapter": "034_燕召公世家", "para": "20.1", "seq": 16, "text": "破卿秦於代。", "len": 6}
{"sid": "034_燕召公世家.20.1.s17", "chapter": "034_燕召公世家", "para": "20.1", "seq": 17, "text": "乐间奔赵。", "len": 5}
{"sid": "034_燕召公世家.20.1.s18", "chapter": "034_燕召公世家", "para": "20.1", "seq": 18, "text": "廉颇逐之五百馀里，围其国。", "len": 13}
{"sid": "034_燕召公世家.20.1.s19", "chapter": "034_燕召公世家", "para": "20.1", "seq": 19, "text": "燕人请和，赵人不许，必令将渠处和。", "len": 17}
{"sid": "034_燕召公世家.20.1.s20", "chapter": "034_燕召公世家", "para": "20.1", "seq": 20, "text": "燕相将渠以处和。", "len": 8}
{"sid": "034_燕召公世家.20.1.s21", "chapter": "034_燕召公世家", "para": "20.1", "seq": 21, "text": "赵听将渠，解燕围。", "len": 9}
{"sid": "034_燕召公世家.21.1.s1", "chapter": "034_燕召公世家", "para": "21.1", "seq": 1, "text": "六年，秦灭东周，置三川郡。", "len": 13}
{"sid": "034_燕召公世家.21.1.s2", "chapter": "034_燕召公世家", "para": "21.1", "seq": 2, "text": "七年，秦拔赵榆次三十七城，秦置大原郡。", "len": 19}
{"sid": "034_燕召公世家.21.1.s3", "chapter": "034_燕召公世家", "para": "21.1", "seq": 3, "text": "九年，秦王政初即位。", "len": 10}
{"sid": "034_燕召公世家.21.1.s4", "chapter": "034_燕召公世家", "para": "21.1", "seq": 4, "text": "十年，赵使廉颇将攻繁阳，拔之。", "len": 15}
{"sid": "034_燕召公世家.21.1.s5", "chapter": "034_燕召公世家", "para": "21.1", "seq": 5, "text": "赵孝成王卒，悼襄王立。", "len": 11}
{"sid": "034_燕召公世家.21.1.s6", "chapter": "034_燕召公世家", "para": "21.1", "seq": 6, "text": "使乐乘代廉颇，廉颇不听，攻乐乘，乐乘走，廉颇奔大梁。", "len": 26}
{"sid": "034_燕召公世家.21.1.s7", "chapter": "034_燕召公世家", "para": "21.1", "seq": 7, "text": "十二年，赵使李牧攻燕，拔武遂、方城。", "len": 18}
{"sid": "034_燕召公世家.21.1.s8", "chapter": "034_燕召公世家", "para": "21.1", "seq": 8, "text": "剧辛故居赵，与庞暖善，已而亡走燕。", "len": 17}
{"sid": "034_燕召公世家.21.1.s9", "chapter": "034_燕召公世家", "para": "21.1", "seq": 9, "text": "燕见赵数困于秦，而廉颇去，令庞暖将也，欲因赵弊攻之。", "len": 26}
{"sid": "034_燕召公世家.21.1.s10", "chapter": "034_燕召公世家", "para": "21.1", "seq": 10, "text": "问剧辛，辛曰：“庞暖易与耳。", "len": 14}
{"sid": "034_燕召公世家.21.1.s11", "chapter": "034_燕召公世家", "para": "21.1", "seq": 11, "text": "” 燕使剧辛将击赵，赵使庞暖击之，取燕军二万，杀剧辛。", "len": 27}
{"sid": "034_燕召公世家.21.1.s12", "chapter": "034_燕召公世家", "para": "21.1", "seq": 12, "text": "秦拔魏二十城，置东郡。", "len": 11}
{"sid": "034_燕召公世家.21.1.s13", "chapter": "034_燕召公世家", "para": "21.1", "seq": 13, "text": "十九年，秦拔赵之鄴九城。", "len": 12}
{"sid": "034_燕召公世家.21.1.s14", "chapter": "034_燕召公世家", "para": "21.1", "seq": 14, "text": "赵悼襄王卒。", "len": 6}
{"sid": "034_燕召公世家.21.1.s15", "chapter": "034_燕召公世家", "para": "21.1", "seq": 15, "text": "二十三年，太子丹质於秦，亡归燕。", "len": 16}
{"sid": "034_燕召公世家.21.1.s16", "chapter": "034_燕召公世家", "para": "21.1", "seq": 16, "text": "二十五年，秦虏灭韩王安，置颍川郡。", "len": 17}
{"sid": "034_燕召公世家.21.1.s17", "chapter": "034_燕召公世家", "para": "21.1", "seq": 17, "text": "二十七年，秦虏赵王迁，灭赵。", "len": 14}
{"sid": "034_燕召公世家.21.1.s18", "chapter": "034_燕召公世家", "para": "21.1", "seq": 18, "text": "赵公子嘉自立为代王。", "len": 10}
{"sid": "034_燕召公世家.22.1.s1", "chapter": "034_燕召公世家", "para": "22.1", "seq": 1, "text": "燕见秦且灭六国，秦兵临易水，祸且至燕。", "len": 19}
{"sid": "034_燕召公世家.22.1.s2", "chapter": "034_燕召公世家", "para": "22.1", "seq": 2, "text": "太子丹阴养壮士二十人，使荆轲献督亢地图於秦，因袭刺秦王。", "len": 28}
{"sid": "034_燕召公世家.22.1.s3", "chapter": "034_燕召公世家", "para": "22.1", "seq": 3, "text": "秦王觉，杀轲，使将军王翦击燕。", "len": 15}
{"sid": "034_燕召公世家.22.1.s4", "chapter": "034_燕召公世家", "para": "22.1", "seq": 4, "text": "二十九年，秦攻拔我蓟，燕王亡，徙居辽东，斩丹以献秦。", "len": 26}
{"sid": "034_燕召公世家.22.1.s5", "chapter": "034_燕召公世家", "para": "22.1", "seq": 5, "text": "三十年，秦灭魏。", "len": 8}
{"sid": "034_燕召公世家.22.2.s1", "chapter": "034_燕召公世家", "para": "22.2", "seq": 1, "text": "三十三年，秦拔辽东，虏燕王喜，卒灭燕。", "len": 19}
{"sid": "034_燕召公世家.22.2.s2", "chapter": "034_燕召公世家", "para": "22.2", "seq": 2, "text": "是岁，秦将王贲亦虏代王嘉。", "len": 13}
{"sid": "034_燕召公世家.22.2.s3", "chapter": "034_燕召公世家", "para": "22.2", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "034_燕召公世家.23.1.s1", "chapter": "034_燕召公世家", "para": "23.1", "seq": 1, "text": "太史公曰：召公奭可谓仁矣！", "len": 13}
{"sid": "034_燕召公世家.23.1.s2", "chapter": "034_燕召公世家", "para": "23.1", "seq": 2, "text": "甘棠且思之，况其人乎？", "len": 11}
{"sid": "034_燕召公世家.23.1.s3", "chapter": "034_燕召公世家", "para": "23.1", "seq": 3, "text": "燕迫蛮貉，内措齐、晋，崎岖彊国之间，最为弱小，几灭者数矣。", "len": 29}
{"sid": "034_燕召公世家.23.1.s4", "chapter": "034_燕召公世家", "para": "23.1", "seq": 4, "text": "然社稷血食者八九百岁，於姬姓独後亡，岂非召公之烈邪！", "len": 26}
{"sid": "034_燕召公世家.23.1.s5", "chapter": "034_燕召公世家", "para": "23.1", "seq": 5, "text": "::: ::: 赞", "len": 9}
{"sid": "034_燕召公世家.24.s1", "chapter": "034_燕召公世家", "para": "24", "seq": 1, "text": "召伯作相，分陕而治。", "len": 10}
{"sid": "034_燕召公世家.24.s2", "chapter": "034_燕召公世家", "para": "24", "seq": 2, "text": "人惠其德，甘棠是思。", "len": 10}
{"sid": "034_燕召公世家.24.s3", "chapter": "034_燕召公世家", "para": "24", "seq": 3, "text": "庄送霸主，惠罗宠姬。", "len": 10}
{"sid": "034_燕召公世家.24.s4", "chapter": "034_燕召公世家", "para": "24", "seq": 4, "text": "文公从赵，苏秦骋辞。", "len": 10}
{"sid": "034_燕召公世家.24.s5", "chapter": "034_燕召公世家", "para": "24", "seq": 5, "text": "易王初立，齐宣我欺。", "len": 10}
{"sid": "034_燕召公世家.24.s6", "chapter": "034_燕召公世家", "para": "24", "seq": 6, "text": "燕哙无道，禅位子之。", "len": 10}
{"sid": "034_燕召公世家.24.s7", "chapter": "034_燕召公世家", "para": "24", "seq": 7, "text": "昭王待士，思报临淄。", "len": 10}
{"sid": "034_燕召公世家.24.s8", "chapter": "034_燕召公世家", "para": "24", "seq": 8, "text": "督亢不就，卒见芟夷。", "len": 10}
{"sid": "034_燕召公世家.24.s9", "chapter": "034_燕召公世家", "para": "24", "seq": 9, "text": ":::", "len": 3}
