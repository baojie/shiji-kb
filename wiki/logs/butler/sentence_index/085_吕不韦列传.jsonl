{"sid": "085_吕不韦列传.1.1.s1", "chapter": "085_吕不韦列传", "para": "1.1", "seq": 1, "text": "吕不韦者，阳翟大贾人也。", "len": 12}
{"sid": "085_吕不韦列传.1.1.s2", "chapter": "085_吕不韦列传", "para": "1.1", "seq": 2, "text": "往来贩贱卖贵，家累千金。", "len": 12}
{"sid": "085_吕不韦列传.2.1.s1", "chapter": "085_吕不韦列传", "para": "2.1", "seq": 1, "text": "秦昭王四十年，太子死。", "len": 11}
{"sid": "085_吕不韦列传.2.1.s2", "chapter": "085_吕不韦列传", "para": "2.1", "seq": 2, "text": "其四十二年，以其次子安国君为太子。", "len": 17}
{"sid": "085_吕不韦列传.2.1.s3", "chapter": "085_吕不韦列传", "para": "2.1", "seq": 3, "text": "安国君有子二十馀人。", "len": 10}
{"sid": "085_吕不韦列传.2.1.s4", "chapter": "085_吕不韦列传", "para": "2.1", "seq": 4, "text": "安国君有所甚爱姬，立以为正夫人，号曰华阳夫人。", "len": 23}
{"sid": "085_吕不韦列传.2.1.s5", "chapter": "085_吕不韦列传", "para": "2.1", "seq": 5, "text": "华阳夫人无子。", "len": 7}
{"sid": "085_吕不韦列传.2.1.s6", "chapter": "085_吕不韦列传", "para": "2.1", "seq": 6, "text": "安国君中男名子楚，子楚母曰夏姬，毋爱。", "len": 19}
{"sid": "085_吕不韦列传.2.1.s7", "chapter": "085_吕不韦列传", "para": "2.1", "seq": 7, "text": "子楚为秦质子於赵。", "len": 9}
{"sid": "085_吕不韦列传.2.1.s8", "chapter": "085_吕不韦列传", "para": "2.1", "seq": 8, "text": "秦数攻赵，赵不甚礼子楚。", "len": 12}
{"sid": "085_吕不韦列传.2.2.s1", "chapter": "085_吕不韦列传", "para": "2.2", "seq": 1, "text": "子楚，秦诸庶孽孙，质於诸侯，车乘进用不饶，居处困，不得意。", "len": 29}
{"sid": "085_吕不韦列传.2.2.s2", "chapter": "085_吕不韦列传", "para": "2.2", "seq": 2, "text": "吕不韦贾邯郸，见而怜之，曰“此奇货可居”。", "len": 21}
{"sid": "085_吕不韦列传.3.1.s1", "chapter": "085_吕不韦列传", "para": "3.1", "seq": 1, "text": "乃往见子楚，说曰：“吾能大子之门。", "len": 17}
{"sid": "085_吕不韦列传.3.1.s2", "chapter": "085_吕不韦列传", "para": "3.1", "seq": 2, "text": "” 子楚笑曰：“且自大君之门，而乃大吾门！", "len": 21}
{"sid": "085_吕不韦列传.3.1.s3", "chapter": "085_吕不韦列传", "para": "3.1", "seq": 3, "text": "” 吕不韦曰：“子不知也，吾门待子门而大。", "len": 21}
{"sid": "085_吕不韦列传.3.1.s4", "chapter": "085_吕不韦列传", "para": "3.1", "seq": 4, "text": "” 子楚心知所谓，乃引与坐，深语。", "len": 17}
{"sid": "085_吕不韦列传.3.2.s1", "chapter": "085_吕不韦列传", "para": "3.2", "seq": 1, "text": "吕不韦曰：”秦王老矣，安国君得为太子。", "len": 19}
{"sid": "085_吕不韦列传.3.2.s2", "chapter": "085_吕不韦列传", "para": "3.2", "seq": 2, "text": "窃闻安国君爱幸华阳夫人，华阳夫人无子，能立適嗣者独华阳夫人耳。", "len": 31}
{"sid": "085_吕不韦列传.3.2.s3", "chapter": "085_吕不韦列传", "para": "3.2", "seq": 3, "text": "今子兄弟二十馀人，子又居中，不甚见幸，久质诸侯。", "len": 24}
{"sid": "085_吕不韦列传.3.2.s4", "chapter": "085_吕不韦列传", "para": "3.2", "seq": 4, "text": "即大王薨，安国君立为王，则子毋几得与长子及诸子旦暮在前者争为太子矣。", "len": 34}
{"sid": "085_吕不韦列传.3.2.s5", "chapter": "085_吕不韦列传", "para": "3.2", "seq": 5, "text": "” 子楚曰：“然。", "len": 9}
{"sid": "085_吕不韦列传.3.2.s6", "chapter": "085_吕不韦列传", "para": "3.2", "seq": 6, "text": "为之柰何？", "len": 5}
{"sid": "085_吕不韦列传.3.2.s7", "chapter": "085_吕不韦列传", "para": "3.2", "seq": 7, "text": "” 吕不韦曰：“子贫，客於此，非有以奉献於亲及结宾客也。", "len": 28}
{"sid": "085_吕不韦列传.3.2.s8", "chapter": "085_吕不韦列传", "para": "3.2", "seq": 8, "text": "不韦虽贫，请以千金为子西游，事安国君及华阳夫人，立子为適嗣。", "len": 30}
{"sid": "085_吕不韦列传.3.2.s9", "chapter": "085_吕不韦列传", "para": "3.2", "seq": 9, "text": "” 子楚乃顿首曰：“必如君策，请得分秦国与君共之。”", "len": 26}
{"sid": "085_吕不韦列传.4.1.s1", "chapter": "085_吕不韦列传", "para": "4.1", "seq": 1, "text": "吕不韦乃以五百金与子楚，为进用，结宾客；而复以五百金买奇物玩好，自奉而西游秦，求见华阳夫人姊，而皆以其物献华阳夫人。", "len": 58}
{"sid": "085_吕不韦列传.4.1.s2", "chapter": "085_吕不韦列传", "para": "4.1", "seq": 2, "text": "因言子楚贤智，结诸侯宾客遍天下，常曰“楚也以夫人为天，日夜泣思太子及夫人”。", "len": 38}
{"sid": "085_吕不韦列传.4.1.s3", "chapter": "085_吕不韦列传", "para": "4.1", "seq": 3, "text": "夫人大喜。", "len": 5}
{"sid": "085_吕不韦列传.4.2.s1", "chapter": "085_吕不韦列传", "para": "4.2", "seq": 1, "text": "不韦因使其姊说夫人曰：“吾闻之，以色事人者，色衰而爱弛。", "len": 28}
{"sid": "085_吕不韦列传.4.2.s2", "chapter": "085_吕不韦列传", "para": "4.2", "seq": 2, "text": "今夫人事太子，甚爱而无子，不以此时蚤自结於诸子中贤孝者，举立以为適而子之，夫在则重尊，夫百岁之後，所子者为王，终不失势，此所谓一言而万世之利也。", "len": 72}
{"sid": "085_吕不韦列传.4.2.s3", "chapter": "085_吕不韦列传", "para": "4.2", "seq": 3, "text": "不以繁华时树本，即色衰爱弛後，虽欲开一语，尚可得乎？", "len": 26}
{"sid": "085_吕不韦列传.4.2.s4", "chapter": "085_吕不韦列传", "para": "4.2", "seq": 4, "text": "今子楚贤，而自知中男也，次不得为適，其母又不得幸，自附夫人，夫人诚以此时拔以为適，夫人则竟世有宠於秦矣。”", "len": 53}
{"sid": "085_吕不韦列传.4.3.s1", "chapter": "085_吕不韦列传", "para": "4.3", "seq": 1, "text": "华阳夫人以为然，承太子间，从容言子楚质於赵者绝贤，来往者皆称誉之。", "len": 33}
{"sid": "085_吕不韦列传.4.3.s2", "chapter": "085_吕不韦列传", "para": "4.3", "seq": 2, "text": "乃因涕泣曰：“妾幸得充後宫，不幸无子，原得子楚立以为適嗣，以讬妾身。", "len": 34}
{"sid": "085_吕不韦列传.4.3.s3", "chapter": "085_吕不韦列传", "para": "4.3", "seq": 3, "text": "” 安国君许之，乃与夫人刻玉符，约以为適嗣。", "len": 22}
{"sid": "085_吕不韦列传.4.3.s4", "chapter": "085_吕不韦列传", "para": "4.3", "seq": 4, "text": "安国君及夫人因厚餽遗子楚，而请吕不韦傅之，子楚以此名誉益盛於诸侯。", "len": 33}
{"sid": "085_吕不韦列传.5.1.s1", "chapter": "085_吕不韦列传", "para": "5.1", "seq": 1, "text": "吕不韦取邯郸诸姬绝好善舞者与居，知有身。", "len": 20}
{"sid": "085_吕不韦列传.5.1.s2", "chapter": "085_吕不韦列传", "para": "5.1", "seq": 2, "text": "子楚从不韦饮，见而说之，因起为寿，请之。", "len": 20}
{"sid": "085_吕不韦列传.5.1.s3", "chapter": "085_吕不韦列传", "para": "5.1", "seq": 3, "text": "吕不韦怒，念业已破家为子楚，欲以钓奇，乃遂献其姬。", "len": 25}
{"sid": "085_吕不韦列传.5.1.s4", "chapter": "085_吕不韦列传", "para": "5.1", "seq": 4, "text": "姬自匿有身，至大期时，生子政。", "len": 15}
{"sid": "085_吕不韦列传.5.1.s5", "chapter": "085_吕不韦列传", "para": "5.1", "seq": 5, "text": "子楚遂立姬为夫人。", "len": 9}
{"sid": "085_吕不韦列传.6.1.s1", "chapter": "085_吕不韦列传", "para": "6.1", "seq": 1, "text": "秦昭王五十年，使王齮围邯郸，急，赵欲杀子楚。", "len": 22}
{"sid": "085_吕不韦列传.6.1.s2", "chapter": "085_吕不韦列传", "para": "6.1", "seq": 2, "text": "子楚与吕不韦谋，行金六百斤予守者吏，得脱，亡赴秦军，遂以得归。", "len": 31}
{"sid": "085_吕不韦列传.6.1.s3", "chapter": "085_吕不韦列传", "para": "6.1", "seq": 3, "text": "赵欲杀子楚妻子，子楚夫人赵豪家女也，得匿，以故母子竟得活。", "len": 29}
{"sid": "085_吕不韦列传.6.2.s1", "chapter": "085_吕不韦列传", "para": "6.2", "seq": 1, "text": "秦昭王五十六年，薨，太子安国君立为王，华阳夫人为王后，子楚为太子。", "len": 33}
{"sid": "085_吕不韦列传.6.2.s2", "chapter": "085_吕不韦列传", "para": "6.2", "seq": 2, "text": "赵亦奉子楚夫人及子政归秦。", "len": 13}
{"sid": "085_吕不韦列传.7.1.s1", "chapter": "085_吕不韦列传", "para": "7.1", "seq": 1, "text": "秦王立一年，薨，谥为孝文王。", "len": 14}
{"sid": "085_吕不韦列传.7.1.s2", "chapter": "085_吕不韦列传", "para": "7.1", "seq": 2, "text": "太子子楚代立，是为庄襄王。", "len": 13}
{"sid": "085_吕不韦列传.7.1.s3", "chapter": "085_吕不韦列传", "para": "7.1", "seq": 3, "text": "庄襄王所母华阳后为华阳太后，真母夏姬尊以为夏太后。", "len": 25}
{"sid": "085_吕不韦列传.7.2.s1", "chapter": "085_吕不韦列传", "para": "7.2", "seq": 1, "text": "庄襄王元年，以吕不韦为丞相，封为文信侯，食河南雒阳十万户。", "len": 29}
{"sid": "085_吕不韦列传.8.1.s1", "chapter": "085_吕不韦列传", "para": "8.1", "seq": 1, "text": "庄襄王即位三年，薨，太子政立为王，尊吕不韦为相国，号称“仲父”。", "len": 32}
{"sid": "085_吕不韦列传.8.1.s2", "chapter": "085_吕不韦列传", "para": "8.1", "seq": 2, "text": "秦王年少，太后时时窃私通吕不韦。", "len": 16}
{"sid": "085_吕不韦列传.8.1.s3", "chapter": "085_吕不韦列传", "para": "8.1", "seq": 3, "text": "不韦家僮万人。", "len": 7}
{"sid": "085_吕不韦列传.9.1.s1", "chapter": "085_吕不韦列传", "para": "9.1", "seq": 1, "text": "当是时，魏有信陵君，楚有春申君，赵有平原君，齐有孟尝君，皆下士喜宾客以相倾。", "len": 38}
{"sid": "085_吕不韦列传.9.1.s2", "chapter": "085_吕不韦列传", "para": "9.1", "seq": 2, "text": "吕不韦以秦之彊，羞不如，亦招致士，厚遇之，至食客三千人。", "len": 28}
{"sid": "085_吕不韦列传.9.2.s1", "chapter": "085_吕不韦列传", "para": "9.2", "seq": 1, "text": "是时诸侯多辩士，如荀卿之徒，著书布天下。", "len": 20}
{"sid": "085_吕不韦列传.9.2.s2", "chapter": "085_吕不韦列传", "para": "9.2", "seq": 2, "text": "吕不韦乃使其客人人著所闻，集论以为八览、六论、十二纪，二十馀万言。", "len": 33}
{"sid": "085_吕不韦列传.9.2.s3", "chapter": "085_吕不韦列传", "para": "9.2", "seq": 3, "text": "以为备天地万物古今之事，号曰吕氏春秋。", "len": 19}
{"sid": "085_吕不韦列传.9.2.s4", "chapter": "085_吕不韦列传", "para": "9.2", "seq": 4, "text": "布咸阳市门，悬千金其上，延诸侯游士宾客有能增损一字者予千金。", "len": 30}
{"sid": "085_吕不韦列传.10.1.s1", "chapter": "085_吕不韦列传", "para": "10.1", "seq": 1, "text": "始皇帝益壮，太后淫不止。", "len": 12}
{"sid": "085_吕不韦列传.10.1.s2", "chapter": "085_吕不韦列传", "para": "10.1", "seq": 2, "text": "吕不韦恐觉祸及己，乃私求大阴人嫪毐以为舍人，时纵倡乐，使毐以其阴关桐轮而行，令太后闻之，以啗太后。", "len": 49}
{"sid": "085_吕不韦列传.10.1.s3", "chapter": "085_吕不韦列传", "para": "10.1", "seq": 3, "text": "太后闻，果欲私得之。", "len": 10}
{"sid": "085_吕不韦列传.10.2.s1", "chapter": "085_吕不韦列传", "para": "10.2", "seq": 1, "text": "吕不韦乃进嫪毐，诈令人以腐罪告之。", "len": 17}
{"sid": "085_吕不韦列传.10.2.s2", "chapter": "085_吕不韦列传", "para": "10.2", "seq": 2, "text": "不韦又阴谓太后曰：“可事诈腐，则得给事中。", "len": 21}
{"sid": "085_吕不韦列传.10.2.s3", "chapter": "085_吕不韦列传", "para": "10.2", "seq": 3, "text": "” 太后乃阴厚赐主腐者吏，诈论之，拔其须眉为宦者，遂得侍太后。", "len": 31}
{"sid": "085_吕不韦列传.10.2.s4", "chapter": "085_吕不韦列传", "para": "10.2", "seq": 4, "text": "太后私与通，绝爱之。", "len": 10}
{"sid": "085_吕不韦列传.10.2.s5", "chapter": "085_吕不韦列传", "para": "10.2", "seq": 5, "text": "有身，太后恐人知之，诈卜当避时，徙宫居雍。", "len": 21}
{"sid": "085_吕不韦列传.10.2.s6", "chapter": "085_吕不韦列传", "para": "10.2", "seq": 6, "text": "嫪毐常从，赏赐甚厚，事皆决於嫪毐。", "len": 17}
{"sid": "085_吕不韦列传.10.2.s7", "chapter": "085_吕不韦列传", "para": "10.2", "seq": 7, "text": "嫪毐家僮数千人，诸客求宦为嫪毐舍人千馀人。", "len": 21}
{"sid": "085_吕不韦列传.11.1.s1", "chapter": "085_吕不韦列传", "para": "11.1", "seq": 1, "text": "始皇七年，庄襄王母夏太后薨。", "len": 14}
{"sid": "085_吕不韦列传.11.1.s2", "chapter": "085_吕不韦列传", "para": "11.1", "seq": 2, "text": "孝文王后曰华阳太后，与孝文王会葬寿陵。", "len": 19}
{"sid": "085_吕不韦列传.11.1.s3", "chapter": "085_吕不韦列传", "para": "11.1", "seq": 3, "text": "夏太后子庄襄王葬芷阳，故夏太后独别葬杜东，曰“东望吾子，西望吾夫。", "len": 33}
{"sid": "085_吕不韦列传.11.1.s4", "chapter": "085_吕不韦列传", "para": "11.1", "seq": 4, "text": "後百年，旁当有万家邑”。", "len": 12}
{"sid": "085_吕不韦列传.12.1.s1", "chapter": "085_吕不韦列传", "para": "12.1", "seq": 1, "text": "始皇九年，有告嫪毐实非宦者，常与太后私乱，生子二人，皆匿之。", "len": 30}
{"sid": "085_吕不韦列传.12.1.s2", "chapter": "085_吕不韦列传", "para": "12.1", "seq": 2, "text": "与太后谋曰“王即薨，以子为後”。", "len": 16}
{"sid": "085_吕不韦列传.12.1.s3", "chapter": "085_吕不韦列传", "para": "12.1", "seq": 3, "text": "於是秦王下吏治，具得情实，事连相国吕不韦。", "len": 21}
{"sid": "085_吕不韦列传.12.2.s1", "chapter": "085_吕不韦列传", "para": "12.2", "seq": 1, "text": "九月，夷嫪毐三族，杀太后所生两子，而遂迁太后於雍。", "len": 25}
{"sid": "085_吕不韦列传.12.2.s2", "chapter": "085_吕不韦列传", "para": "12.2", "seq": 2, "text": "诸嫪毐舍人皆没其家而迁之蜀。", "len": 14}
{"sid": "085_吕不韦列传.12.2.s3", "chapter": "085_吕不韦列传", "para": "12.2", "seq": 3, "text": "王欲诛相国，为其奉先王功大，及宾客辩士为游说者众，王不忍致法。", "len": 31}
{"sid": "085_吕不韦列传.13.1.s1", "chapter": "085_吕不韦列传", "para": "13.1", "seq": 1, "text": "秦王十年十月，免相国吕不韦。", "len": 14}
{"sid": "085_吕不韦列传.13.1.s2", "chapter": "085_吕不韦列传", "para": "13.1", "seq": 2, "text": "及齐人茅焦说秦王，秦王乃迎太后於雍，归复咸阳，而出文信侯就国河南。", "len": 33}
{"sid": "085_吕不韦列传.14.1.s1", "chapter": "085_吕不韦列传", "para": "14.1", "seq": 1, "text": "岁馀，诸侯宾客使者相望於道，请文信侯。", "len": 19}
{"sid": "085_吕不韦列传.14.1.s2", "chapter": "085_吕不韦列传", "para": "14.1", "seq": 2, "text": "秦王恐其为变，乃赐文信侯书曰：“君何功於秦？", "len": 22}
{"sid": "085_吕不韦列传.14.1.s3", "chapter": "085_吕不韦列传", "para": "14.1", "seq": 3, "text": "秦封君河南，食十万户。", "len": 11}
{"sid": "085_吕不韦列传.14.1.s4", "chapter": "085_吕不韦列传", "para": "14.1", "seq": 4, "text": "君何亲於秦？", "len": 6}
{"sid": "085_吕不韦列传.14.1.s5", "chapter": "085_吕不韦列传", "para": "14.1", "seq": 5, "text": "号称仲父。", "len": 5}
{"sid": "085_吕不韦列传.14.1.s6", "chapter": "085_吕不韦列传", "para": "14.1", "seq": 6, "text": "其与家属徙处蜀！", "len": 8}
{"sid": "085_吕不韦列传.14.1.s7", "chapter": "085_吕不韦列传", "para": "14.1", "seq": 7, "text": "” 吕不韦自度稍侵，恐诛，乃饮酖而死。", "len": 19}
{"sid": "085_吕不韦列传.14.1.s8", "chapter": "085_吕不韦列传", "para": "14.1", "seq": 8, "text": "秦王所加怒吕不韦、嫪毐皆已死，乃皆复归嫪毐舍人迁蜀者。", "len": 27}
{"sid": "085_吕不韦列传.15.s1", "chapter": "085_吕不韦列传", "para": "15", "seq": 1, "text": "始皇十九年，太后薨，谥为帝太后，与庄襄王会葬茝阳。", "len": 25}
{"sid": "085_吕不韦列传.16.s1", "chapter": "085_吕不韦列传", "para": "16", "seq": 1, "text": "太史公曰：不韦及嫪毐贵，封号文信侯。", "len": 18}
{"sid": "085_吕不韦列传.16.s2", "chapter": "085_吕不韦列传", "para": "16", "seq": 2, "text": "人之告嫪毐，毐闻之。", "len": 10}
{"sid": "085_吕不韦列传.16.s3", "chapter": "085_吕不韦列传", "para": "16", "seq": 3, "text": "秦王验左右，未发。", "len": 9}
{"sid": "085_吕不韦列传.16.s4", "chapter": "085_吕不韦列传", "para": "16", "seq": 4, "text": "上之雍郊，毐恐祸起，乃与党谋，矫太后玺发卒以反蕲年宫。", "len": 27}
{"sid": "085_吕不韦列传.16.s5", "chapter": "085_吕不韦列传", "para": "16", "seq": 5, "text": "发吏攻毐，毐败亡走，追斩之好畤，遂灭其宗。", "len": 21}
{"sid": "085_吕不韦列传.16.s6", "chapter": "085_吕不韦列传", "para": "16", "seq": 6, "text": "而吕不韦由此绌矣。", "len": 9}
{"sid": "085_吕不韦列传.16.s7", "chapter": "085_吕不韦列传", "para": "16", "seq": 7, "text": "孔子之所谓“闻” 者，其吕子乎？", "len": 16}
{"sid": "085_吕不韦列传.16.s8", "chapter": "085_吕不韦列传", "para": "16", "seq": 8, "text": "::: 赞", "len": 5}
{"sid": "085_吕不韦列传.17.s1", "chapter": "085_吕不韦列传", "para": "17", "seq": 1, "text": "不韦钓奇，委质子楚。", "len": 10}
{"sid": "085_吕不韦列传.17.s2", "chapter": "085_吕不韦列传", "para": "17", "seq": 2, "text": "华阳立嗣，邯郸献女。", "len": 10}
{"sid": "085_吕不韦列传.17.s3", "chapter": "085_吕不韦列传", "para": "17", "seq": 3, "text": "及封河南，乃号仲父。", "len": 10}
{"sid": "085_吕不韦列传.17.s4", "chapter": "085_吕不韦列传", "para": "17", "seq": 4, "text": "徙蜀惩谤，悬金作语。", "len": 10}
{"sid": "085_吕不韦列传.17.s5", "chapter": "085_吕不韦列传", "para": "17", "seq": 5, "text": "筹策既成，富贵斯取。", "len": 10}
{"sid": "085_吕不韦列传.17.s6", "chapter": "085_吕不韦列传", "para": "17", "seq": 6, "text": ":::", "len": 3}
