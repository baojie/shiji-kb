{"sid": "103_万石张叔列传.1.s1", "chapter": "103_万石张叔列传", "para": "1", "seq": 1, "text": "万石君名奋，其父赵人也，姓石氏。", "len": 16}
{"sid": "103_万石张叔列传.1.s2", "chapter": "103_万石张叔列传", "para": "1", "seq": 2, "text": "赵亡，徙居温。", "len": 7}
{"sid": "103_万石张叔列传.1.s3", "chapter": "103_万石张叔列传", "para": "1", "seq": 3, "text": "高祖东击项籍，过河内，时奋年十五，为小吏，侍高祖。", "len": 25}
{"sid": "103_万石张叔列传.1.s4", "chapter": "103_万石张叔列传", "para": "1", "seq": 4, "text": "高祖与语，爱其恭敬，问曰：“若何有？", "len": 18}
{"sid": "103_万石张叔列传.1.s5", "chapter": "103_万石张叔列传", "para": "1", "seq": 5, "text": "” 对曰：“奋独有母，不幸失明。", "len": 16}
{"sid": "103_万石张叔列传.1.s6", "chapter": "103_万石张叔列传", "para": "1", "seq": 6, "text": "家贫。", "len": 3}
{"sid": "103_万石张叔列传.1.s7", "chapter": "103_万石张叔列传", "para": "1", "seq": 7, "text": "有姊，能鼓琴。", "len": 7}
{"sid": "103_万石张叔列传.1.s8", "chapter": "103_万石张叔列传", "para": "1", "seq": 8, "text": "” 高祖曰：“若能从我乎？", "len": 13}
{"sid": "103_万石张叔列传.1.s9", "chapter": "103_万石张叔列传", "para": "1", "seq": 9, "text": "” 曰：“原尽力。", "len": 9}
{"sid": "103_万石张叔列传.1.s10", "chapter": "103_万石张叔列传", "para": "1", "seq": 10, "text": "” 於是高祖召其姊为美人，以奋为中涓，受书谒，徙其家长安中戚里，以姊为美人故也。", "len": 40}
{"sid": "103_万石张叔列传.1.s11", "chapter": "103_万石张叔列传", "para": "1", "seq": 11, "text": "其官至孝文时，积功劳至大中大夫。", "len": 16}
{"sid": "103_万石张叔列传.1.s12", "chapter": "103_万石张叔列传", "para": "1", "seq": 12, "text": "无文学，恭谨无与比。", "len": 10}
{"sid": "103_万石张叔列传.2.s1", "chapter": "103_万石张叔列传", "para": "2", "seq": 1, "text": "文帝时，东阳侯张相如为太子太傅，免。", "len": 18}
{"sid": "103_万石张叔列传.2.s2", "chapter": "103_万石张叔列传", "para": "2", "seq": 2, "text": "选可为傅者，皆推奋，奋为太子太傅。", "len": 17}
{"sid": "103_万石张叔列传.2.s3", "chapter": "103_万石张叔列传", "para": "2", "seq": 3, "text": "及孝景即位，以为九卿；迫近，惮之，徙奋为诸侯相。", "len": 24}
{"sid": "103_万石张叔列传.2.s4", "chapter": "103_万石张叔列传", "para": "2", "seq": 4, "text": "奋长子建，次子甲，次子乙，次子庆，皆以驯行孝谨，官皆至二千石。", "len": 31}
{"sid": "103_万石张叔列传.2.s5", "chapter": "103_万石张叔列传", "para": "2", "seq": 5, "text": "於是景帝曰：“石君及四子皆二千石，人臣尊宠乃集其门。", "len": 26}
{"sid": "103_万石张叔列传.2.s6", "chapter": "103_万石张叔列传", "para": "2", "seq": 6, "text": "” 号奋为万石君。", "len": 9}
{"sid": "103_万石张叔列传.3.s1", "chapter": "103_万石张叔列传", "para": "3", "seq": 1, "text": "孝景帝季年，万石君以上大夫禄归老于家，以岁时为朝臣。", "len": 26}
{"sid": "103_万石张叔列传.3.s2", "chapter": "103_万石张叔列传", "para": "3", "seq": 2, "text": "过宫门阙，万石君必下车趋，见路马必式焉。", "len": 20}
{"sid": "103_万石张叔列传.3.s3", "chapter": "103_万石张叔列传", "para": "3", "seq": 3, "text": "子孙为小吏，来归谒，万石君必朝服见之，不名。", "len": 22}
{"sid": "103_万石张叔列传.3.s4", "chapter": "103_万石张叔列传", "para": "3", "seq": 4, "text": "子孙有过失，不谯让，为便坐，对案不食。", "len": 19}
{"sid": "103_万石张叔列传.3.s5", "chapter": "103_万石张叔列传", "para": "3", "seq": 5, "text": "然后诸子相责，因长老肉袒固谢罪，改之，乃许。", "len": 22}
{"sid": "103_万石张叔列传.3.s6", "chapter": "103_万石张叔列传", "para": "3", "seq": 6, "text": "子孙胜冠者在侧，虽燕居必冠，申申如也。", "len": 19}
{"sid": "103_万石张叔列传.3.s7", "chapter": "103_万石张叔列传", "para": "3", "seq": 7, "text": "僮仆如也，唯谨。", "len": 8}
{"sid": "103_万石张叔列传.3.s8", "chapter": "103_万石张叔列传", "para": "3", "seq": 8, "text": "上时赐食於家，必稽首俯伏而食之，如在上前。", "len": 21}
{"sid": "103_万石张叔列传.3.s9", "chapter": "103_万石张叔列传", "para": "3", "seq": 9, "text": "其执丧，哀戚甚悼。", "len": 9}
{"sid": "103_万石张叔列传.3.s10", "chapter": "103_万石张叔列传", "para": "3", "seq": 10, "text": "子孙遵教，亦如之。", "len": 9}
{"sid": "103_万石张叔列传.3.s11", "chapter": "103_万石张叔列传", "para": "3", "seq": 11, "text": "万石君家以孝谨闻乎郡国，虽齐鲁诸儒质行，皆自以为不及也。", "len": 28}
{"sid": "103_万石张叔列传.4.s1", "chapter": "103_万石张叔列传", "para": "4", "seq": 1, "text": "建元二年，郎中令王臧以文学获罪。", "len": 16}
{"sid": "103_万石张叔列传.4.s2", "chapter": "103_万石张叔列传", "para": "4", "seq": 2, "text": "皇太后以为儒者文多质少，今万石君家不言而躬行，乃以长子建为郎中令，少子庆为内史。", "len": 40}
{"sid": "103_万石张叔列传.5.s1", "chapter": "103_万石张叔列传", "para": "5", "seq": 1, "text": "建老白首，万石君尚无恙。", "len": 12}
{"sid": "103_万石张叔列传.5.s2", "chapter": "103_万石张叔列传", "para": "5", "seq": 2, "text": "建为郎中令，每五日洗沐归谒亲，入子舍，窃问侍者，取亲中稖厕窬，身自浣涤，复与侍者，不敢令万石君知，以为常。", "len": 53}
{"sid": "103_万石张叔列传.5.s3", "chapter": "103_万石张叔列传", "para": "5", "seq": 3, "text": "建为郎中令，事有可言，屏人恣言，极切；至廷见，如不能言者。", "len": 29}
{"sid": "103_万石张叔列传.5.s4", "chapter": "103_万石张叔列传", "para": "5", "seq": 4, "text": "是以上乃亲尊礼之。", "len": 9}
{"sid": "103_万石张叔列传.6.s1", "chapter": "103_万石张叔列传", "para": "6", "seq": 1, "text": "万石君徙居陵里。", "len": 8}
{"sid": "103_万石张叔列传.6.s2", "chapter": "103_万石张叔列传", "para": "6", "seq": 2, "text": "内史庆醉归，入外门不下车。", "len": 13}
{"sid": "103_万石张叔列传.6.s3", "chapter": "103_万石张叔列传", "para": "6", "seq": 3, "text": "万石君闻之，不食。", "len": 9}
{"sid": "103_万石张叔列传.6.s4", "chapter": "103_万石张叔列传", "para": "6", "seq": 4, "text": "庆恐，肉袒请罪，不许。", "len": 11}
{"sid": "103_万石张叔列传.6.s5", "chapter": "103_万石张叔列传", "para": "6", "seq": 5, "text": "举宗及兄建肉袒，万石君让曰：“内史贵人，入闾里，里中长老皆走匿，而内史坐车中自如，固当！", "len": 44}
{"sid": "103_万石张叔列传.6.s6", "chapter": "103_万石张叔列传", "para": "6", "seq": 6, "text": "” 乃谢罢庆。", "len": 7}
{"sid": "103_万石张叔列传.6.s7", "chapter": "103_万石张叔列传", "para": "6", "seq": 7, "text": "庆及诸子弟入里门，趋至家。", "len": 13}
{"sid": "103_万石张叔列传.7.s1", "chapter": "103_万石张叔列传", "para": "7", "seq": 1, "text": "万石君以元朔五年中卒。", "len": 11}
{"sid": "103_万石张叔列传.7.s2", "chapter": "103_万石张叔列传", "para": "7", "seq": 2, "text": "长子郎中令建哭泣哀思，扶杖乃能行。", "len": 17}
{"sid": "103_万石张叔列传.7.s3", "chapter": "103_万石张叔列传", "para": "7", "seq": 3, "text": "岁馀，建亦死。", "len": 7}
{"sid": "103_万石张叔列传.7.s4", "chapter": "103_万石张叔列传", "para": "7", "seq": 4, "text": "诸子孙咸孝，然建最甚，甚於万石君。", "len": 17}
{"sid": "103_万石张叔列传.8.s1", "chapter": "103_万石张叔列传", "para": "8", "seq": 1, "text": "建为郎中令，书奏事，事下，建读之，曰：“误书！", "len": 23}
{"sid": "103_万石张叔列传.8.s2", "chapter": "103_万石张叔列传", "para": "8", "seq": 2, "text": "‘马’者与尾当五，今乃四，不足一。", "len": 17}
{"sid": "103_万石张叔列传.8.s3", "chapter": "103_万石张叔列传", "para": "8", "seq": 3, "text": "上谴死矣！", "len": 5}
{"sid": "103_万石张叔列传.8.s4", "chapter": "103_万石张叔列传", "para": "8", "seq": 4, "text": "” 甚惶恐。", "len": 6}
{"sid": "103_万石张叔列传.8.s5", "chapter": "103_万石张叔列传", "para": "8", "seq": 5, "text": "其为谨慎，虽他皆如是。", "len": 11}
{"sid": "103_万石张叔列传.9.s1", "chapter": "103_万石张叔列传", "para": "9", "seq": 1, "text": "万石君少子庆为太仆，御出，上问车中几马，庆以策数马毕，举手曰：“六马。", "len": 35}
{"sid": "103_万石张叔列传.9.s2", "chapter": "103_万石张叔列传", "para": "9", "seq": 2, "text": "” 庆於诸子中最为简易矣，然犹如此。", "len": 18}
{"sid": "103_万石张叔列传.9.s3", "chapter": "103_万石张叔列传", "para": "9", "seq": 3, "text": "为齐相，举齐国皆慕其家行，不言而齐国大治，为立石相祠。", "len": 27}
{"sid": "103_万石张叔列传.10.s1", "chapter": "103_万石张叔列传", "para": "10", "seq": 1, "text": "元狩元年，上立太子，选群臣可为傅者，庆自沛守为太子太傅，七岁迁为御史大夫。", "len": 37}
{"sid": "103_万石张叔列传.11.s1", "chapter": "103_万石张叔列传", "para": "11", "seq": 1, "text": "元鼎五年秋，丞相有罪，罢。", "len": 13}
{"sid": "103_万石张叔列传.11.s2", "chapter": "103_万石张叔列传", "para": "11", "seq": 2, "text": "制诏御史：“万石君先帝尊之，子孙孝，其以御史大夫庆为丞相，封为牧丘侯。", "len": 35}
{"sid": "103_万石张叔列传.11.s3", "chapter": "103_万石张叔列传", "para": "11", "seq": 3, "text": "” 是时汉方南诛两越，东击朝鲜，北逐匈奴，西伐大宛，中国多事。", "len": 31}
{"sid": "103_万石张叔列传.11.s4", "chapter": "103_万石张叔列传", "para": "11", "seq": 4, "text": "天子巡狩海内，修上古神祠，封禅，兴礼乐。", "len": 20}
{"sid": "103_万石张叔列传.11.s5", "chapter": "103_万石张叔列传", "para": "11", "seq": 5, "text": "公家用少，桑弘羊等致利，王温舒之属峻法，兒宽等推文学至九卿，更进用事，事不关决於丞相，丞相醇谨而已。", "len": 50}
{"sid": "103_万石张叔列传.11.s6", "chapter": "103_万石张叔列传", "para": "11", "seq": 6, "text": "在位九岁，无能有所匡言。", "len": 12}
{"sid": "103_万石张叔列传.11.s7", "chapter": "103_万石张叔列传", "para": "11", "seq": 7, "text": "尝欲请治上近臣所忠、九卿咸宣罪，不能服，反受其过，赎罪。", "len": 28}
{"sid": "103_万石张叔列传.12.s1", "chapter": "103_万石张叔列传", "para": "12", "seq": 1, "text": "元封四年中，关东流民二百万口，无名数者四十万，公卿议欲请徙流民於边以適之。", "len": 37}
{"sid": "103_万石张叔列传.12.s2", "chapter": "103_万石张叔列传", "para": "12", "seq": 2, "text": "上以为丞相老谨，不能与其议，乃赐丞相告归，而案御史大夫以下议为请者。", "len": 34}
{"sid": "103_万石张叔列传.12.s3", "chapter": "103_万石张叔列传", "para": "12", "seq": 3, "text": "丞相惭不任职，乃上书曰：“庆幸得待罪丞相，罢驽无以辅治，城郭仓库空虚，民多流亡，罪当伏斧质，上不忍致法。", "len": 52}
{"sid": "103_万石张叔列传.12.s4", "chapter": "103_万石张叔列传", "para": "12", "seq": 4, "text": "原归丞相侯印，乞骸骨归，避贤者路。", "len": 17}
{"sid": "103_万石张叔列传.12.s5", "chapter": "103_万石张叔列传", "para": "12", "seq": 5, "text": "” 天子曰：“仓廪既空，民贫流亡，而君欲请徙之，摇荡不安，动危之，而辞位，君欲安归难乎？", "len": 44}
{"sid": "103_万石张叔列传.12.s6", "chapter": "103_万石张叔列传", "para": "12", "seq": 6, "text": "” 以书让庆，庆甚惭，遂复视事。", "len": 16}
{"sid": "103_万石张叔列传.13.s1", "chapter": "103_万石张叔列传", "para": "13", "seq": 1, "text": "庆文深审谨，然无他大略，为百姓言。", "len": 17}
{"sid": "103_万石张叔列传.13.s2", "chapter": "103_万石张叔列传", "para": "13", "seq": 2, "text": "後三岁馀，太初二年中，丞相庆卒，谥为恬侯。", "len": 21}
{"sid": "103_万石张叔列传.13.s3", "chapter": "103_万石张叔列传", "para": "13", "seq": 3, "text": "庆中子德，庆爱用之，上以德为嗣，代侯。", "len": 19}
{"sid": "103_万石张叔列传.13.s4", "chapter": "103_万石张叔列传", "para": "13", "seq": 4, "text": "後为太常，坐法当死，赎免为庶人。", "len": 16}
{"sid": "103_万石张叔列传.13.s5", "chapter": "103_万石张叔列传", "para": "13", "seq": 5, "text": "庆方为丞相，诸子孙为吏更至二千石者十三人。", "len": 21}
{"sid": "103_万石张叔列传.13.s6", "chapter": "103_万石张叔列传", "para": "13", "seq": 6, "text": "及庆死後，稍以罪去，孝谨益衰矣。", "len": 16}
{"sid": "103_万石张叔列传.14.s1", "chapter": "103_万石张叔列传", "para": "14", "seq": 1, "text": "建陵侯卫绾者，代大陵人也。", "len": 13}
{"sid": "103_万石张叔列传.14.s2", "chapter": "103_万石张叔列传", "para": "14", "seq": 2, "text": "绾以戏车为郎，事文帝，功次迁为中郎将，醇谨无他。", "len": 24}
{"sid": "103_万石张叔列传.14.s3", "chapter": "103_万石张叔列传", "para": "14", "seq": 3, "text": "孝景为太子时，召上左右饮，而绾称病不行。", "len": 20}
{"sid": "103_万石张叔列传.14.s4", "chapter": "103_万石张叔列传", "para": "14", "seq": 4, "text": "文帝且崩时，属孝景曰：“绾长者，善遇之。", "len": 20}
{"sid": "103_万石张叔列传.14.s5", "chapter": "103_万石张叔列传", "para": "14", "seq": 5, "text": "” 及文帝崩，景帝立，岁馀不噍呵绾，绾日以谨力。", "len": 24}
{"sid": "103_万石张叔列传.15.s1", "chapter": "103_万石张叔列传", "para": "15", "seq": 1, "text": "景帝幸上林，诏中郎将参乘，还而问曰：“君知所以得参乘乎？", "len": 28}
{"sid": "103_万石张叔列传.15.s2", "chapter": "103_万石张叔列传", "para": "15", "seq": 2, "text": "” 绾曰：“臣从车士幸得以功次迁为中郎将，不自知也。", "len": 26}
{"sid": "103_万石张叔列传.15.s3", "chapter": "103_万石张叔列传", "para": "15", "seq": 3, "text": "” 上问曰：“吾为太子时召君，君不肯来，何也？", "len": 23}
{"sid": "103_万石张叔列传.15.s4", "chapter": "103_万石张叔列传", "para": "15", "seq": 4, "text": "” 对曰：“死罪，实病！", "len": 12}
{"sid": "103_万石张叔列传.15.s5", "chapter": "103_万石张叔列传", "para": "15", "seq": 5, "text": "” 上赐之剑。", "len": 7}
{"sid": "103_万石张叔列传.15.s6", "chapter": "103_万石张叔列传", "para": "15", "seq": 6, "text": "绾曰：“先帝赐臣剑凡六，剑不敢奉诏。", "len": 18}
{"sid": "103_万石张叔列传.15.s7", "chapter": "103_万石张叔列传", "para": "15", "seq": 7, "text": "” 上曰：“剑，人之所施易，独至今乎？", "len": 19}
{"sid": "103_万石张叔列传.15.s8", "chapter": "103_万石张叔列传", "para": "15", "seq": 8, "text": "” 绾曰：“具在。", "len": 9}
{"sid": "103_万石张叔列传.15.s9", "chapter": "103_万石张叔列传", "para": "15", "seq": 9, "text": "” 上使取六剑，剑尚盛，未尝服也。", "len": 17}
{"sid": "103_万石张叔列传.15.s10", "chapter": "103_万石张叔列传", "para": "15", "seq": 10, "text": "郎官有谴，常蒙其罪，不与他将争；有功，常让他将。", "len": 24}
{"sid": "103_万石张叔列传.15.s11", "chapter": "103_万石张叔列传", "para": "15", "seq": 11, "text": "上以为廉，忠实无他肠，乃拜绾为河间王太傅。", "len": 21}
{"sid": "103_万石张叔列传.15.s12", "chapter": "103_万石张叔列传", "para": "15", "seq": 12, "text": "吴楚反，诏绾为将，将河间兵击吴楚有功，拜为中尉。", "len": 24}
{"sid": "103_万石张叔列传.15.s13", "chapter": "103_万石张叔列传", "para": "15", "seq": 13, "text": "三岁，以军功，孝景前六年中封绾为建陵侯。", "len": 20}
{"sid": "103_万石张叔列传.16.s1", "chapter": "103_万石张叔列传", "para": "16", "seq": 1, "text": "其明年，上废太子，诛栗卿之属。", "len": 15}
{"sid": "103_万石张叔列传.16.s2", "chapter": "103_万石张叔列传", "para": "16", "seq": 2, "text": "上以为绾长者，不忍，乃赐绾告归，而使郅都治捕栗氏。", "len": 25}
{"sid": "103_万石张叔列传.16.s3", "chapter": "103_万石张叔列传", "para": "16", "seq": 3, "text": "既已，上立胶东王为太子，召绾，拜为太子太傅。", "len": 22}
{"sid": "103_万石张叔列传.16.s4", "chapter": "103_万石张叔列传", "para": "16", "seq": 4, "text": "久之，迁为御史大夫。", "len": 10}
{"sid": "103_万石张叔列传.16.s5", "chapter": "103_万石张叔列传", "para": "16", "seq": 5, "text": "五岁，代桃侯舍为丞相，朝奏事如职所奏。", "len": 19}
{"sid": "103_万石张叔列传.16.s6", "chapter": "103_万石张叔列传", "para": "16", "seq": 6, "text": "然自初官以至丞相，终无可言。", "len": 14}
{"sid": "103_万石张叔列传.16.s7", "chapter": "103_万石张叔列传", "para": "16", "seq": 7, "text": "天子以为敦厚，可相少主，尊宠之，赏赐甚多。", "len": 21}
{"sid": "103_万石张叔列传.17.s1", "chapter": "103_万石张叔列传", "para": "17", "seq": 1, "text": "为丞相三岁，景帝崩，武帝立。", "len": 14}
{"sid": "103_万石张叔列传.17.s2", "chapter": "103_万石张叔列传", "para": "17", "seq": 2, "text": "建元年中，丞相以景帝疾时诸官囚多坐不辜者，而君不任职，免之。", "len": 30}
{"sid": "103_万石张叔列传.17.s3", "chapter": "103_万石张叔列传", "para": "17", "seq": 3, "text": "其後绾卒，子信代。", "len": 9}
{"sid": "103_万石张叔列传.17.s4", "chapter": "103_万石张叔列传", "para": "17", "seq": 4, "text": "坐酎金失侯。", "len": 6}
{"sid": "103_万石张叔列传.18.s1", "chapter": "103_万石张叔列传", "para": "18", "seq": 1, "text": "塞侯直不疑者，南阳人也。", "len": 12}
{"sid": "103_万石张叔列传.18.s2", "chapter": "103_万石张叔列传", "para": "18", "seq": 2, "text": "为郎，事文帝。", "len": 7}
{"sid": "103_万石张叔列传.18.s3", "chapter": "103_万石张叔列传", "para": "18", "seq": 3, "text": "其同舍有告归，误持同舍郎金去，已而金主觉，妄意不疑，不疑谢有之，买金偿。", "len": 36}
{"sid": "103_万石张叔列传.18.s4", "chapter": "103_万石张叔列传", "para": "18", "seq": 4, "text": "而告归者来而归金，而前郎亡金者大惭，以此称为长者。", "len": 25}
{"sid": "103_万石张叔列传.18.s5", "chapter": "103_万石张叔列传", "para": "18", "seq": 5, "text": "文帝称举，稍迁至太中大夫。", "len": 13}
{"sid": "103_万石张叔列传.18.s6", "chapter": "103_万石张叔列传", "para": "18", "seq": 6, "text": "朝廷见，人或毁曰：“不疑状貌甚美，然独无柰其善盗嫂何也！", "len": 28}
{"sid": "103_万石张叔列传.18.s7", "chapter": "103_万石张叔列传", "para": "18", "seq": 7, "text": "” 不疑闻，曰：“我乃无兄。", "len": 14}
{"sid": "103_万石张叔列传.18.s8", "chapter": "103_万石张叔列传", "para": "18", "seq": 8, "text": "” 然终不自明也。", "len": 9}
{"sid": "103_万石张叔列传.19.s1", "chapter": "103_万石张叔列传", "para": "19", "seq": 1, "text": "吴楚反时，不疑以二千石将兵击之。", "len": 16}
{"sid": "103_万石张叔列传.19.s2", "chapter": "103_万石张叔列传", "para": "19", "seq": 2, "text": "景帝後元年，拜为御史大夫。", "len": 13}
{"sid": "103_万石张叔列传.19.s3", "chapter": "103_万石张叔列传", "para": "19", "seq": 3, "text": "天子修吴楚时功，乃封不疑为塞侯。", "len": 16}
{"sid": "103_万石张叔列传.19.s4", "chapter": "103_万石张叔列传", "para": "19", "seq": 4, "text": "武帝建元年中，与丞相绾俱以过免。", "len": 16}
{"sid": "103_万石张叔列传.20.s1", "chapter": "103_万石张叔列传", "para": "20", "seq": 1, "text": "不疑学老子言。", "len": 7}
{"sid": "103_万石张叔列传.20.s2", "chapter": "103_万石张叔列传", "para": "20", "seq": 2, "text": "其所临，为官如故，唯恐人知其为吏迹也。", "len": 19}
{"sid": "103_万石张叔列传.20.s3", "chapter": "103_万石张叔列传", "para": "20", "seq": 3, "text": "不好立名称，称为长者。", "len": 11}
{"sid": "103_万石张叔列传.20.s4", "chapter": "103_万石张叔列传", "para": "20", "seq": 4, "text": "不疑卒，子相如代。", "len": 9}
{"sid": "103_万石张叔列传.20.s5", "chapter": "103_万石张叔列传", "para": "20", "seq": 5, "text": "孙望，坐酎金失侯。", "len": 9}
{"sid": "103_万石张叔列传.21.s1", "chapter": "103_万石张叔列传", "para": "21", "seq": 1, "text": "郎中令周文者，名仁，其先故任城人也。", "len": 18}
{"sid": "103_万石张叔列传.21.s2", "chapter": "103_万石张叔列传", "para": "21", "seq": 2, "text": "以医见。", "len": 4}
{"sid": "103_万石张叔列传.21.s3", "chapter": "103_万石张叔列传", "para": "21", "seq": 3, "text": "景帝为太子时，拜为舍人，积功稍迁，孝文帝时至太中大夫。", "len": 27}
{"sid": "103_万石张叔列传.21.s4", "chapter": "103_万石张叔列传", "para": "21", "seq": 4, "text": "景帝初即位，拜仁为郎中令。", "len": 13}
{"sid": "103_万石张叔列传.22.s1", "chapter": "103_万石张叔列传", "para": "22", "seq": 1, "text": "仁为人阴重不泄，常衣敝补衣溺袴，期为不絜清，以是得幸。", "len": 27}
{"sid": "103_万石张叔列传.22.s2", "chapter": "103_万石张叔列传", "para": "22", "seq": 2, "text": "景帝入卧内，於後宫祕戏，仁常在旁。", "len": 17}
{"sid": "103_万石张叔列传.22.s3", "chapter": "103_万石张叔列传", "para": "22", "seq": 3, "text": "至景帝崩，仁尚为郎中令，终无所言。", "len": 17}
{"sid": "103_万石张叔列传.22.s4", "chapter": "103_万石张叔列传", "para": "22", "seq": 4, "text": "上时问人，仁曰：“上自察之。", "len": 14}
{"sid": "103_万石张叔列传.22.s5", "chapter": "103_万石张叔列传", "para": "22", "seq": 5, "text": "” 然亦无所毁。", "len": 8}
{"sid": "103_万石张叔列传.22.s6", "chapter": "103_万石张叔列传", "para": "22", "seq": 6, "text": "以此景帝再自幸其家。", "len": 10}
{"sid": "103_万石张叔列传.22.s7", "chapter": "103_万石张叔列传", "para": "22", "seq": 7, "text": "家徙阳陵。", "len": 5}
{"sid": "103_万石张叔列传.22.s8", "chapter": "103_万石张叔列传", "para": "22", "seq": 8, "text": "上所赐甚多，然常让，不敢受也。", "len": 15}
{"sid": "103_万石张叔列传.22.s9", "chapter": "103_万石张叔列传", "para": "22", "seq": 9, "text": "诸侯群臣赂遗，终无所受。", "len": 12}
{"sid": "103_万石张叔列传.23.s1", "chapter": "103_万石张叔列传", "para": "23", "seq": 1, "text": "武帝立，以为先帝臣，重之。", "len": 13}
{"sid": "103_万石张叔列传.23.s2", "chapter": "103_万石张叔列传", "para": "23", "seq": 2, "text": "仁乃病免，以二千石禄归老，子孙咸至大官矣。", "len": 21}
{"sid": "103_万石张叔列传.24.s1", "chapter": "103_万石张叔列传", "para": "24", "seq": 1, "text": "御史大夫张叔者，名欧，安丘侯说之庶子也。", "len": 20}
{"sid": "103_万石张叔列传.24.s2", "chapter": "103_万石张叔列传", "para": "24", "seq": 2, "text": "孝文时以治刑名言事太子。", "len": 12}
{"sid": "103_万石张叔列传.24.s3", "chapter": "103_万石张叔列传", "para": "24", "seq": 3, "text": "然欧虽治刑名家，其人长者。", "len": 13}
{"sid": "103_万石张叔列传.24.s4", "chapter": "103_万石张叔列传", "para": "24", "seq": 4, "text": "景帝时尊重，常为九卿。", "len": 11}
{"sid": "103_万石张叔列传.24.s5", "chapter": "103_万石张叔列传", "para": "24", "seq": 5, "text": "至武帝元朔四年，韩安国免，诏拜欧为御史大夫。", "len": 22}
{"sid": "103_万石张叔列传.24.s6", "chapter": "103_万石张叔列传", "para": "24", "seq": 6, "text": "自欧为吏，未尝言案人，专以诚长者处官。", "len": 19}
{"sid": "103_万石张叔列传.24.s7", "chapter": "103_万石张叔列传", "para": "24", "seq": 7, "text": "官属以为长者，亦不敢大欺。", "len": 13}
{"sid": "103_万石张叔列传.24.s8", "chapter": "103_万石张叔列传", "para": "24", "seq": 8, "text": "上具狱事，有可卻，卻之；不可者，不得已，为涕泣面对而封之。", "len": 29}
{"sid": "103_万石张叔列传.24.s9", "chapter": "103_万石张叔列传", "para": "24", "seq": 9, "text": "其爱人如此。", "len": 6}
{"sid": "103_万石张叔列传.25.s1", "chapter": "103_万石张叔列传", "para": "25", "seq": 1, "text": "老病笃，请免。", "len": 7}
{"sid": "103_万石张叔列传.25.s2", "chapter": "103_万石张叔列传", "para": "25", "seq": 2, "text": "於是天子亦策罢，以上大夫禄归老于家。", "len": 18}
{"sid": "103_万石张叔列传.25.s3", "chapter": "103_万石张叔列传", "para": "25", "seq": 3, "text": "家於阳陵。", "len": 5}
{"sid": "103_万石张叔列传.25.s4", "chapter": "103_万石张叔列传", "para": "25", "seq": 4, "text": "子孙咸至大官矣。", "len": 8}
{"sid": "103_万石张叔列传.25.s5", "chapter": "103_万石张叔列传", "para": "25", "seq": 5, "text": "::: 太史公曰", "len": 8}
{"sid": "103_万石张叔列传.26.s1", "chapter": "103_万石张叔列传", "para": "26", "seq": 1, "text": "太史公曰：仲尼有言曰“君子欲讷於言而敏於行”，其万石、建陵、张叔之谓邪？", "len": 36}
{"sid": "103_万石张叔列传.26.s2", "chapter": "103_万石张叔列传", "para": "26", "seq": 2, "text": "是以其教不肃而成，不严而治。", "len": 14}
{"sid": "103_万石张叔列传.26.s3", "chapter": "103_万石张叔列传", "para": "26", "seq": 3, "text": "塞侯微巧，而周文处讇，君子讥之，为其近於佞也。", "len": 23}
{"sid": "103_万石张叔列传.26.s4", "chapter": "103_万石张叔列传", "para": "26", "seq": 4, "text": "然斯可谓笃行君子矣！", "len": 10}
{"sid": "103_万石张叔列传.26.s5", "chapter": "103_万石张叔列传", "para": "26", "seq": 5, "text": "::: ::: 赞", "len": 9}
{"sid": "103_万石张叔列传.27.s1", "chapter": "103_万石张叔列传", "para": "27", "seq": 1, "text": "万石孝谨，自家形国。", "len": 10}
{"sid": "103_万石张叔列传.27.s2", "chapter": "103_万石张叔列传", "para": "27", "seq": 2, "text": "郎中数马，内史匍匐。", "len": 10}
{"sid": "103_万石张叔列传.27.s3", "chapter": "103_万石张叔列传", "para": "27", "seq": 3, "text": "绾无他肠，塞有阴德。", "len": 10}
{"sid": "103_万石张叔列传.27.s4", "chapter": "103_万石张叔列传", "para": "27", "seq": 4, "text": "刑名张欧，垂涕恤狱。", "len": 10}
{"sid": "103_万石张叔列传.27.s5", "chapter": "103_万石张叔列传", "para": "27", "seq": 5, "text": "敏行讷言，俱嗣芳躅。", "len": 10}
{"sid": "103_万石张叔列传.27.s6", "chapter": "103_万石张叔列传", "para": "27", "seq": 6, "text": ":::", "len": 3}
