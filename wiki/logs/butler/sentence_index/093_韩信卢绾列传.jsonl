{"sid": "093_韩信卢绾列传.1.s1", "chapter": "093_韩信卢绾列传", "para": "1", "seq": 1, "text": "韩王信者，故韩襄王孽孙也，长八尺五寸。", "len": 19}
{"sid": "093_韩信卢绾列传.1.s2", "chapter": "093_韩信卢绾列传", "para": "1", "seq": 2, "text": "及项梁之立楚後怀王也，燕、齐、赵、魏皆已前王，唯韩无有後，故立韩诸公子横阳君成为韩王，欲以抚定韩故地。", "len": 51}
{"sid": "093_韩信卢绾列传.1.s3", "chapter": "093_韩信卢绾列传", "para": "1", "seq": 3, "text": "项梁败死定陶，成奔怀王。", "len": 12}
{"sid": "093_韩信卢绾列传.1.s4", "chapter": "093_韩信卢绾列传", "para": "1", "seq": 4, "text": "沛公引兵击阳城，使张良以韩司徒降下韩故地，得信，以为韩将，将其兵从沛公入武关。", "len": 39}
{"sid": "093_韩信卢绾列传.2.s1", "chapter": "093_韩信卢绾列传", "para": "2", "seq": 1, "text": "沛公立为汉王，韩信从入汉中，乃说汉王曰：“项王王诸将近地，而王独远居此，此左迁也。", "len": 41}
{"sid": "093_韩信卢绾列传.2.s2", "chapter": "093_韩信卢绾列传", "para": "2", "seq": 2, "text": "士卒皆山东人，跂而望归，及其锋东乡，可以争天下。", "len": 24}
{"sid": "093_韩信卢绾列传.2.s3", "chapter": "093_韩信卢绾列传", "para": "2", "seq": 3, "text": "” 汉王还定三秦，乃许信为韩王，先拜信为韩太尉，将兵略韩地。", "len": 30}
{"sid": "093_韩信卢绾列传.3.s1", "chapter": "093_韩信卢绾列传", "para": "3", "seq": 1, "text": "项籍之封诸王皆就国，韩王成以不从无功，不遣就国，更以为列侯。", "len": 30}
{"sid": "093_韩信卢绾列传.3.s2", "chapter": "093_韩信卢绾列传", "para": "3", "seq": 2, "text": "及闻汉遣韩信略韩地，乃令故项籍游吴时吴令郑昌为韩王以距汉。", "len": 29}
{"sid": "093_韩信卢绾列传.3.s3", "chapter": "093_韩信卢绾列传", "para": "3", "seq": 3, "text": "汉二年，韩信略定韩十馀城。", "len": 13}
{"sid": "093_韩信卢绾列传.3.s4", "chapter": "093_韩信卢绾列传", "para": "3", "seq": 4, "text": "汉王至河南，韩信急击韩王昌阳城。", "len": 16}
{"sid": "093_韩信卢绾列传.3.s5", "chapter": "093_韩信卢绾列传", "para": "3", "seq": 5, "text": "昌降，汉王乃立韩信为韩王，常将韩兵从。", "len": 19}
{"sid": "093_韩信卢绾列传.3.s6", "chapter": "093_韩信卢绾列传", "para": "3", "seq": 6, "text": "三年，汉王出荥阳，韩王信、周苛等守荥阳。", "len": 20}
{"sid": "093_韩信卢绾列传.3.s7", "chapter": "093_韩信卢绾列传", "para": "3", "seq": 7, "text": "及楚败荥阳，信降楚，已而得亡，复归汉，汉复立以为韩王，竟从击破项籍，天下定。", "len": 38}
{"sid": "093_韩信卢绾列传.3.s8", "chapter": "093_韩信卢绾列传", "para": "3", "seq": 8, "text": "五年春，遂与剖符为韩王，王颍川。", "len": 16}
{"sid": "093_韩信卢绾列传.4.s1", "chapter": "093_韩信卢绾列传", "para": "4", "seq": 1, "text": "明年春，上以韩信材武，所王北近巩、洛，南迫宛、叶，东有淮阳，皆天下劲兵处，乃诏徙韩王信王太原以北，备御胡，都晋阳。", "len": 57}
{"sid": "093_韩信卢绾列传.4.s2", "chapter": "093_韩信卢绾列传", "para": "4", "seq": 2, "text": "信上书曰：“国被边，匈奴数入，晋阳去塞远，请治马邑。", "len": 26}
{"sid": "093_韩信卢绾列传.4.s3", "chapter": "093_韩信卢绾列传", "para": "4", "seq": 3, "text": "” 上许之，信乃徙治马邑。", "len": 13}
{"sid": "093_韩信卢绾列传.4.s4", "chapter": "093_韩信卢绾列传", "para": "4", "seq": 4, "text": "秋，匈奴冒顿大围信，信数使使胡求和解。", "len": 19}
{"sid": "093_韩信卢绾列传.4.s5", "chapter": "093_韩信卢绾列传", "para": "4", "seq": 5, "text": "汉发兵救之，疑信数间使，有二心，使人责让信。", "len": 22}
{"sid": "093_韩信卢绾列传.4.s6", "chapter": "093_韩信卢绾列传", "para": "4", "seq": 6, "text": "信恐诛，因与匈奴约共攻汉，反，以马邑降胡，击太原。", "len": 25}
{"sid": "093_韩信卢绾列传.5.s1", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 1, "text": "七年冬，上自往击，破信军铜鞮，斩其将王喜。", "len": 21}
{"sid": "093_韩信卢绾列传.5.s2", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 2, "text": "信亡走匈奴。", "len": 6}
{"sid": "093_韩信卢绾列传.5.s3", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 3, "text": "其与白土人曼丘臣、王黄等立赵苗裔赵利为王，复收信败散兵，而与信及冒顿谋攻汉。", "len": 38}
{"sid": "093_韩信卢绾列传.5.s4", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 4, "text": "匈奴仗左右贤王将万馀骑与王黄等屯广武以南，至晋阳，与汉兵战，汉大破之，追至于离石，破之。", "len": 44}
{"sid": "093_韩信卢绾列传.5.s5", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 5, "text": "匈奴复聚兵楼烦西北，汉令车骑击破匈奴。", "len": 19}
{"sid": "093_韩信卢绾列传.5.s6", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 6, "text": "匈奴常败走，汉乘胜追北，闻冒顿居代谷，高皇帝居晋阳，使人视冒顿，还报曰“可击”。", "len": 40}
{"sid": "093_韩信卢绾列传.5.s7", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 7, "text": "上遂至平城。", "len": 6}
{"sid": "093_韩信卢绾列传.5.s8", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 8, "text": "上出白登，匈奴骑围上，上乃使人厚遗阏氏。", "len": 20}
{"sid": "093_韩信卢绾列传.5.s9", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 9, "text": "阏氏乃说冒顿曰：“今得汉地，犹不能居；且两主不相戹。", "len": 26}
{"sid": "093_韩信卢绾列传.5.s10", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 10, "text": "” 居七日，胡骑稍引去。", "len": 12}
{"sid": "093_韩信卢绾列传.5.s11", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 11, "text": "时天大雾，汉使人往来，胡不觉。", "len": 15}
{"sid": "093_韩信卢绾列传.5.s12", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 12, "text": "护军中尉陈平言上曰：“胡者全兵，请令彊弩傅两矢外乡，徐行出围。", "len": 31}
{"sid": "093_韩信卢绾列传.5.s13", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 13, "text": "” 入平城，汉救兵亦到，胡骑遂解去。", "len": 18}
{"sid": "093_韩信卢绾列传.5.s14", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 14, "text": "汉亦罢兵归。", "len": 6}
{"sid": "093_韩信卢绾列传.5.s15", "chapter": "093_韩信卢绾列传", "para": "5", "seq": 15, "text": "韩信为匈奴将兵往来击边。", "len": 12}
{"sid": "093_韩信卢绾列传.6.s1", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 1, "text": "汉十年，信令王黄等说误陈豨。", "len": 14}
{"sid": "093_韩信卢绾列传.6.s2", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 2, "text": "十一年春，故韩王信复与胡骑入居参合，距汉。", "len": 21}
{"sid": "093_韩信卢绾列传.6.s3", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 3, "text": "汉使柴将军击之，遗信书曰：“陛下宽仁，诸侯虽有畔亡，而复归，辄复故位号，不诛也。", "len": 40}
{"sid": "093_韩信卢绾列传.6.s4", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 4, "text": "大王所知。", "len": 5}
{"sid": "093_韩信卢绾列传.6.s5", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 5, "text": "今王以败亡走胡，非有大罪，急自归！", "len": 17}
{"sid": "093_韩信卢绾列传.6.s6", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 6, "text": "” 韩王信报曰：“陛下擢仆起闾巷，南面称孤，此仆之幸也。", "len": 28}
{"sid": "093_韩信卢绾列传.6.s7", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 7, "text": "荥阳之事，仆不能死，囚於项籍，此一罪也。", "len": 20}
{"sid": "093_韩信卢绾列传.6.s8", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 8, "text": "及寇攻马邑，仆不能坚守，以城降之，此二罪也。", "len": 22}
{"sid": "093_韩信卢绾列传.6.s9", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 9, "text": "今反为寇将兵，与将军争一旦之命，此三罪也。", "len": 21}
{"sid": "093_韩信卢绾列传.6.s10", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 10, "text": "夫种、蠡无一罪，身死亡；今仆有三罪於陛下，而欲求活於世，此伍子胥所以偾於吴也。", "len": 39}
{"sid": "093_韩信卢绾列传.6.s11", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 11, "text": "今仆亡匿山谷间，旦暮乞贷蛮夷，仆之思归，如痿人不忘起，盲者不忘视也，势不可耳。", "len": 39}
{"sid": "093_韩信卢绾列传.6.s12", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 12, "text": "” 遂战。", "len": 5}
{"sid": "093_韩信卢绾列传.6.s13", "chapter": "093_韩信卢绾列传", "para": "6", "seq": 13, "text": "柴将军屠参合，斩韩王信。", "len": 12}
{"sid": "093_韩信卢绾列传.7.s1", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 1, "text": "信之入匈奴，与太子俱；及至穨当城，生子，因名曰穨当。", "len": 26}
{"sid": "093_韩信卢绾列传.7.s2", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 2, "text": "韩太子亦生子，命曰婴。", "len": 11}
{"sid": "093_韩信卢绾列传.7.s3", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 3, "text": "至孝文十四年，穨当及婴率其众降汉。", "len": 17}
{"sid": "093_韩信卢绾列传.7.s4", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 4, "text": "汉封穨当为弓高侯，婴为襄城侯。", "len": 15}
{"sid": "093_韩信卢绾列传.7.s5", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 5, "text": "吴楚军时，弓高侯功冠诸将。", "len": 13}
{"sid": "093_韩信卢绾列传.7.s6", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 6, "text": "传子至孙，孙无子，失侯。", "len": 12}
{"sid": "093_韩信卢绾列传.7.s7", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 7, "text": "婴孙以不敬失侯。", "len": 8}
{"sid": "093_韩信卢绾列传.7.s8", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 8, "text": "穨当孽孙韩嫣，贵幸，名富显於当世。", "len": 17}
{"sid": "093_韩信卢绾列传.7.s9", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 9, "text": "其弟说，再封，数称将军，卒为案道侯。", "len": 18}
{"sid": "093_韩信卢绾列传.7.s10", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 10, "text": "子代，岁馀坐法死。", "len": 9}
{"sid": "093_韩信卢绾列传.7.s11", "chapter": "093_韩信卢绾列传", "para": "7", "seq": 11, "text": "後岁馀，说孙曾拜为龙嵒侯，续说後。", "len": 17}
{"sid": "093_韩信卢绾列传.8.s1", "chapter": "093_韩信卢绾列传", "para": "8", "seq": 1, "text": "卢绾者，丰人也，与高祖同里。", "len": 14}
{"sid": "093_韩信卢绾列传.8.s2", "chapter": "093_韩信卢绾列传", "para": "8", "seq": 2, "text": "卢绾亲与高祖太上皇相爱，及生男，高祖、卢绾同日生，里中持羊酒贺两家。", "len": 34}
{"sid": "093_韩信卢绾列传.8.s3", "chapter": "093_韩信卢绾列传", "para": "8", "seq": 3, "text": "及高祖、卢绾壮，俱学书，又相爱也。", "len": 17}
{"sid": "093_韩信卢绾列传.8.s4", "chapter": "093_韩信卢绾列传", "para": "8", "seq": 4, "text": "里中嘉两家亲相爱，生子同日，壮又相爱，复贺两家羊酒。", "len": 26}
{"sid": "093_韩信卢绾列传.8.s5", "chapter": "093_韩信卢绾列传", "para": "8", "seq": 5, "text": "高祖为布衣时，有吏事辟匿，卢绾常随出入上下。", "len": 22}
{"sid": "093_韩信卢绾列传.8.s6", "chapter": "093_韩信卢绾列传", "para": "8", "seq": 6, "text": "及高祖初起沛，卢绾以客从，入汉中为将军，常侍中。", "len": 24}
{"sid": "093_韩信卢绾列传.8.s7", "chapter": "093_韩信卢绾列传", "para": "8", "seq": 7, "text": "从东击项籍，以太尉常从，出入卧内，衣被饮食赏赐，群臣莫敢望，虽萧曹等，特以事见礼，至其亲幸，莫及卢绾。", "len": 51}
{"sid": "093_韩信卢绾列传.8.s8", "chapter": "093_韩信卢绾列传", "para": "8", "seq": 8, "text": "绾封为长安侯。", "len": 7}
{"sid": "093_韩信卢绾列传.8.s9", "chapter": "093_韩信卢绾列传", "para": "8", "seq": 9, "text": "长安，故咸阳也。", "len": 8}
{"sid": "093_韩信卢绾列传.9.s1", "chapter": "093_韩信卢绾列传", "para": "9", "seq": 1, "text": "汉五年冬，以破项籍，乃使卢绾别将，与刘贾击临江王共尉，破之。", "len": 30}
{"sid": "093_韩信卢绾列传.9.s2", "chapter": "093_韩信卢绾列传", "para": "9", "seq": 2, "text": "七月还，从击燕王臧荼，臧荼降。", "len": 15}
{"sid": "093_韩信卢绾列传.9.s3", "chapter": "093_韩信卢绾列传", "para": "9", "seq": 3, "text": "高祖已定天下，诸侯非刘氏而王者七人。", "len": 18}
{"sid": "093_韩信卢绾列传.9.s4", "chapter": "093_韩信卢绾列传", "para": "9", "seq": 4, "text": "欲王卢绾，为群臣觖望。", "len": 11}
{"sid": "093_韩信卢绾列传.9.s5", "chapter": "093_韩信卢绾列传", "para": "9", "seq": 5, "text": "及虏臧荼，乃下诏诸将相列侯，择群臣有功者以为燕王。", "len": 25}
{"sid": "093_韩信卢绾列传.9.s6", "chapter": "093_韩信卢绾列传", "para": "9", "seq": 6, "text": "群臣知上欲王卢绾，皆言曰：“太尉长安侯卢绾常从平定天下，功最多，可王燕。", "len": 36}
{"sid": "093_韩信卢绾列传.9.s7", "chapter": "093_韩信卢绾列传", "para": "9", "seq": 7, "text": "” 诏许之。", "len": 6}
{"sid": "093_韩信卢绾列传.9.s8", "chapter": "093_韩信卢绾列传", "para": "9", "seq": 8, "text": "汉五年八月，乃立虏绾为燕王。", "len": 14}
{"sid": "093_韩信卢绾列传.9.s9", "chapter": "093_韩信卢绾列传", "para": "9", "seq": 9, "text": "诸侯王得幸莫如燕王。", "len": 10}
{"sid": "093_韩信卢绾列传.10.s1", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 1, "text": "汉十一年秋，陈豨反代地，高祖如邯郸击豨兵，燕王绾亦击其东北。", "len": 30}
{"sid": "093_韩信卢绾列传.10.s2", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 2, "text": "当是时，陈豨使王黄求救匈奴。", "len": 14}
{"sid": "093_韩信卢绾列传.10.s3", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 3, "text": "燕王绾亦使其臣张胜於匈奴，言豨等军破。", "len": 19}
{"sid": "093_韩信卢绾列传.10.s4", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 4, "text": "张胜至胡，故燕王臧荼子衍出亡在胡，见张胜曰：“公所以重於燕者，以习胡事也。", "len": 37}
{"sid": "093_韩信卢绾列传.10.s5", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 5, "text": "燕所以久存者，以诸侯数反，兵连不决也。", "len": 19}
{"sid": "093_韩信卢绾列传.10.s6", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 6, "text": "今公为燕欲急灭豨等，豨等已尽，次亦至燕，公等亦且为虏矣。", "len": 28}
{"sid": "093_韩信卢绾列传.10.s7", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 7, "text": "公何不令燕且缓陈豨而与胡和？", "len": 14}
{"sid": "093_韩信卢绾列传.10.s8", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 8, "text": "事宽，得长王燕；即有汉急，可以安国。", "len": 18}
{"sid": "093_韩信卢绾列传.10.s9", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 9, "text": "” 张胜以为然，乃私令匈奴助豨等击燕。", "len": 19}
{"sid": "093_韩信卢绾列传.10.s10", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 10, "text": "燕王绾疑张胜与胡反，上书请族张胜。", "len": 17}
{"sid": "093_韩信卢绾列传.10.s11", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 11, "text": "胜还，具道所以为者。", "len": 10}
{"sid": "093_韩信卢绾列传.10.s12", "chapter": "093_韩信卢绾列传", "para": "10", "seq": 12, "text": "燕王寤，乃诈论它人，脱胜家属，使得为匈奴间，而阴使范齐之陈豨所，欲令久亡，连兵勿决。", "len": 42}
{"sid": "093_韩信卢绾列传.11.s1", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 1, "text": "汉十二年，东击黥布，豨常将兵居代，汉使樊哙击斩豨。", "len": 25}
{"sid": "093_韩信卢绾列传.11.s2", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 2, "text": "其裨将降，言燕王绾使范齐通计谋於豨所。", "len": 19}
{"sid": "093_韩信卢绾列传.11.s3", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 3, "text": "高祖使使召卢绾，绾称病。", "len": 12}
{"sid": "093_韩信卢绾列传.11.s4", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 4, "text": "上又使辟阳侯审食其、御史大夫赵尧往迎燕王，因验问左右。", "len": 27}
{"sid": "093_韩信卢绾列传.11.s5", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 5, "text": "绾愈恐，闭匿，谓其幸臣曰：“非刘氏而王，独我与长沙耳。", "len": 27}
{"sid": "093_韩信卢绾列传.11.s6", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 6, "text": "往年春，汉族淮阴，夏，诛彭越，皆吕后计。", "len": 20}
{"sid": "093_韩信卢绾列传.11.s7", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 7, "text": "今上病，属任吕后。", "len": 9}
{"sid": "093_韩信卢绾列传.11.s8", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 8, "text": "吕后妇人，专欲以事诛异姓王者及大功臣。", "len": 19}
{"sid": "093_韩信卢绾列传.11.s9", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 9, "text": "” 乃遂称病不行。", "len": 9}
{"sid": "093_韩信卢绾列传.11.s10", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 10, "text": "其左右皆亡匿。", "len": 7}
{"sid": "093_韩信卢绾列传.11.s11", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 11, "text": "语颇泄，辟阳侯闻之，归具报上，上益怒。", "len": 19}
{"sid": "093_韩信卢绾列传.11.s12", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 12, "text": "又得匈奴降者，降者言张胜亡在匈奴，为燕使。", "len": 21}
{"sid": "093_韩信卢绾列传.11.s13", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 13, "text": "於是上曰：“卢绾果反矣！", "len": 12}
{"sid": "093_韩信卢绾列传.11.s14", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 14, "text": "” 使樊哙击燕。", "len": 8}
{"sid": "093_韩信卢绾列传.11.s15", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 15, "text": "燕王绾悉将其宫人家属骑数千居长城下，侯伺，幸上病愈，自入谢。", "len": 30}
{"sid": "093_韩信卢绾列传.11.s16", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 16, "text": "四月，高祖崩，卢绾遂将其众亡入匈奴，匈奴以为东胡卢王。", "len": 27}
{"sid": "093_韩信卢绾列传.11.s17", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 17, "text": "绾为蛮夷所侵夺，常思复归。", "len": 13}
{"sid": "093_韩信卢绾列传.11.s18", "chapter": "093_韩信卢绾列传", "para": "11", "seq": 18, "text": "居岁馀，死胡中。", "len": 8}
{"sid": "093_韩信卢绾列传.12.s1", "chapter": "093_韩信卢绾列传", "para": "12", "seq": 1, "text": "高后时，卢绾妻子亡降汉，会高后病，不能见，舍燕邸，为欲置酒见之。", "len": 32}
{"sid": "093_韩信卢绾列传.12.s2", "chapter": "093_韩信卢绾列传", "para": "12", "seq": 2, "text": "高祖竟崩，不得见。", "len": 9}
{"sid": "093_韩信卢绾列传.12.s3", "chapter": "093_韩信卢绾列传", "para": "12", "seq": 3, "text": "卢绾妻亦病死。", "len": 7}
{"sid": "093_韩信卢绾列传.13.s1", "chapter": "093_韩信卢绾列传", "para": "13", "seq": 1, "text": "孝景中六年，卢绾孙他之，以东胡王降，封为亚谷侯。", "len": 24}
{"sid": "093_韩信卢绾列传.14.s1", "chapter": "093_韩信卢绾列传", "para": "14", "seq": 1, "text": "陈豨者，宛朐人也，不知始所以得从。", "len": 17}
{"sid": "093_韩信卢绾列传.14.s2", "chapter": "093_韩信卢绾列传", "para": "14", "seq": 2, "text": "及高祖七年冬，韩王信反，入匈奴，上至平城还，乃封豨为列侯，以赵相国将监赵、代边兵，边兵皆属焉。", "len": 47}
{"sid": "093_韩信卢绾列传.15.s1", "chapter": "093_韩信卢绾列传", "para": "15", "seq": 1, "text": "豨常告归过赵，赵相周昌见豨宾客随之者千馀乘，邯郸官舍皆满。", "len": 29}
{"sid": "093_韩信卢绾列传.15.s2", "chapter": "093_韩信卢绾列传", "para": "15", "seq": 2, "text": "豨所以待宾客布衣交，皆出客下。", "len": 15}
{"sid": "093_韩信卢绾列传.15.s3", "chapter": "093_韩信卢绾列传", "para": "15", "seq": 3, "text": "豨还之代，周昌乃求入见。", "len": 12}
{"sid": "093_韩信卢绾列传.15.s4", "chapter": "093_韩信卢绾列传", "para": "15", "seq": 4, "text": "见上，具言豨宾客盛甚，擅兵於外数岁，恐有变。", "len": 22}
{"sid": "093_韩信卢绾列传.15.s5", "chapter": "093_韩信卢绾列传", "para": "15", "seq": 5, "text": "上乃令人覆案豨客居代者财物诸不法事，多连引豨。", "len": 23}
{"sid": "093_韩信卢绾列传.15.s6", "chapter": "093_韩信卢绾列传", "para": "15", "seq": 6, "text": "豨恐，阴令客通使王黄、曼丘臣所。", "len": 16}
{"sid": "093_韩信卢绾列传.15.s7", "chapter": "093_韩信卢绾列传", "para": "15", "seq": 7, "text": "及高祖十年七月，太上皇崩，使人召豨，豨称病甚。", "len": 23}
{"sid": "093_韩信卢绾列传.15.s8", "chapter": "093_韩信卢绾列传", "para": "15", "seq": 8, "text": "九月，遂与王黄等反，自立为代王，劫略赵、代。", "len": 22}
{"sid": "093_韩信卢绾列传.16.s1", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 1, "text": "上闻，乃赦赵、代吏人为豨所诖误劫略者，皆赦之。", "len": 23}
{"sid": "093_韩信卢绾列传.16.s2", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 2, "text": "上自往，至邯郸，喜曰：“豨不南据漳水，北守邯郸，知其无能为也。", "len": 31}
{"sid": "093_韩信卢绾列传.16.s3", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 3, "text": "” 赵相奏斩常山守、尉，曰：“常山二十五城，豨反，亡其二十城。", "len": 31}
{"sid": "093_韩信卢绾列传.16.s4", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 4, "text": "” 上问曰：“守、尉反乎？", "len": 13}
{"sid": "093_韩信卢绾列传.16.s5", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 5, "text": "” 对曰：“不反。", "len": 9}
{"sid": "093_韩信卢绾列传.16.s6", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 6, "text": "” 上曰：“是力不足也。", "len": 12}
{"sid": "093_韩信卢绾列传.16.s7", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 7, "text": "” 赦之，复以为常山守、尉。", "len": 14}
{"sid": "093_韩信卢绾列传.16.s8", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 8, "text": "上问周昌曰：“赵亦有壮士可令将者乎？", "len": 18}
{"sid": "093_韩信卢绾列传.16.s9", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 9, "text": "” 对曰：“有四人。", "len": 10}
{"sid": "093_韩信卢绾列传.16.s10", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 10, "text": "” 四人谒，上谩骂曰：“竖子能为将乎？", "len": 19}
{"sid": "093_韩信卢绾列传.16.s11", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 11, "text": "” 四人惭伏。", "len": 7}
{"sid": "093_韩信卢绾列传.16.s12", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 12, "text": "上封之各千户，以为将。", "len": 11}
{"sid": "093_韩信卢绾列传.16.s13", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 13, "text": "左右谏曰：“从入蜀、汉，伐楚，功未遍行，今此何功而封？", "len": 27}
{"sid": "093_韩信卢绾列传.16.s14", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 14, "text": "” 上曰：“非若所知！", "len": 11}
{"sid": "093_韩信卢绾列传.16.s15", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 15, "text": "陈豨反，邯郸以北皆豨有，吾以羽檄徵天下兵，未有至者，今唯独邯郸中兵耳。", "len": 35}
{"sid": "093_韩信卢绾列传.16.s16", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 16, "text": "吾胡爱四千户封四人，不以慰赵子弟！", "len": 17}
{"sid": "093_韩信卢绾列传.16.s17", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 17, "text": "” 皆曰：“善。", "len": 8}
{"sid": "093_韩信卢绾列传.16.s18", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 18, "text": "” 於是上曰：“陈豨将谁？", "len": 13}
{"sid": "093_韩信卢绾列传.16.s19", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 19, "text": "” 曰：“王黄、曼丘臣，皆故贾人。", "len": 17}
{"sid": "093_韩信卢绾列传.16.s20", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 20, "text": "” 上曰：“吾知之矣。", "len": 11}
{"sid": "093_韩信卢绾列传.16.s21", "chapter": "093_韩信卢绾列传", "para": "16", "seq": 21, "text": "” 乃各以千金购黄、臣等。", "len": 13}
{"sid": "093_韩信卢绾列传.17.s1", "chapter": "093_韩信卢绾列传", "para": "17", "seq": 1, "text": "十一年冬，汉兵击斩陈豨将侯敞、王黄於曲逆下，破豨将张春於聊城，斩首万馀。", "len": 36}
{"sid": "093_韩信卢绾列传.17.s2", "chapter": "093_韩信卢绾列传", "para": "17", "seq": 2, "text": "太尉勃入定太原、代地。", "len": 11}
{"sid": "093_韩信卢绾列传.17.s3", "chapter": "093_韩信卢绾列传", "para": "17", "seq": 3, "text": "十二月，上自击东垣，东垣不下，卒骂上；东垣降，卒骂者斩之，不骂者黥之。", "len": 35}
{"sid": "093_韩信卢绾列传.17.s4", "chapter": "093_韩信卢绾列传", "para": "17", "seq": 4, "text": "更命东垣为真定。", "len": 8}
{"sid": "093_韩信卢绾列传.17.s5", "chapter": "093_韩信卢绾列传", "para": "17", "seq": 5, "text": "王黄、曼丘臣其麾下受购赏之，皆生得，以故陈豨军遂败。", "len": 26}
{"sid": "093_韩信卢绾列传.18.s1", "chapter": "093_韩信卢绾列传", "para": "18", "seq": 1, "text": "上还至洛阳。", "len": 6}
{"sid": "093_韩信卢绾列传.18.s2", "chapter": "093_韩信卢绾列传", "para": "18", "seq": 2, "text": "上曰：“代居常山北，赵乃从山南有之，远。", "len": 20}
{"sid": "093_韩信卢绾列传.18.s3", "chapter": "093_韩信卢绾列传", "para": "18", "seq": 3, "text": "” 乃立子恆为代王，都中都，代、雁门皆属代。", "len": 22}
{"sid": "093_韩信卢绾列传.19.s1", "chapter": "093_韩信卢绾列传", "para": "19", "seq": 1, "text": "高祖十二年冬，樊哙军卒追斩豨於灵丘。", "len": 18}
{"sid": "093_韩信卢绾列传.19.s2", "chapter": "093_韩信卢绾列传", "para": "19", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "093_韩信卢绾列传.20.s1", "chapter": "093_韩信卢绾列传", "para": "20", "seq": 1, "text": "太史公曰：韩信、卢绾非素积德累善之世，徼一时权变，以诈力成功，遭汉初定，故得列地，南面称孤。", "len": 46}
{"sid": "093_韩信卢绾列传.20.s2", "chapter": "093_韩信卢绾列传", "para": "20", "seq": 2, "text": "内见疑彊大，外倚蛮貊以为援，是以日疏自危，事穷智困，卒赴匈奴，岂不哀哉！", "len": 36}
{"sid": "093_韩信卢绾列传.20.s3", "chapter": "093_韩信卢绾列传", "para": "20", "seq": 3, "text": "陈豨，梁人，其少时数称慕魏公子；及将军守边，招致宾客而下士，名声过实。", "len": 35}
{"sid": "093_韩信卢绾列传.20.s4", "chapter": "093_韩信卢绾列传", "para": "20", "seq": 4, "text": "周昌疑之，疵瑕颇起，惧祸及身，邪人进说，遂陷无道。", "len": 25}
{"sid": "093_韩信卢绾列传.20.s5", "chapter": "093_韩信卢绾列传", "para": "20", "seq": 5, "text": "於戏悲夫！", "len": 5}
{"sid": "093_韩信卢绾列传.20.s6", "chapter": "093_韩信卢绾列传", "para": "20", "seq": 6, "text": "夫计之生孰成败於人也深矣！", "len": 13}
{"sid": "093_韩信卢绾列传.20.s7", "chapter": "093_韩信卢绾列传", "para": "20", "seq": 7, "text": "::: ::: 赞", "len": 9}
{"sid": "093_韩信卢绾列传.21.s1", "chapter": "093_韩信卢绾列传", "para": "21", "seq": 1, "text": "韩襄遗孽，始从汉中。", "len": 10}
{"sid": "093_韩信卢绾列传.21.s2", "chapter": "093_韩信卢绾列传", "para": "21", "seq": 2, "text": "剖符南面，徙邑北通。", "len": 10}
{"sid": "093_韩信卢绾列传.21.s3", "chapter": "093_韩信卢绾列传", "para": "21", "seq": 3, "text": "穨当归国，龙雒有功。", "len": 10}
{"sid": "093_韩信卢绾列传.21.s4", "chapter": "093_韩信卢绾列传", "para": "21", "seq": 4, "text": "卢绾亲爱，群臣莫同。", "len": 10}
{"sid": "093_韩信卢绾列传.21.s5", "chapter": "093_韩信卢绾列传", "para": "21", "seq": 5, "text": "旧燕是王，东胡计穷。", "len": 10}
{"sid": "093_韩信卢绾列传.21.s6", "chapter": "093_韩信卢绾列传", "para": "21", "seq": 6, "text": ":::", "len": 3}
