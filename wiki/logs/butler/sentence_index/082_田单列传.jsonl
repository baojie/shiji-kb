{"sid": "082_田单列传.1.1.s1", "chapter": "082_田单列传", "para": "1.1", "seq": 1, "text": "田单者，齐诸田疏属也。", "len": 11}
{"sid": "082_田单列传.1.2.s1", "chapter": "082_田单列传", "para": "1.2", "seq": 1, "text": "湣王时，单为临菑市掾，不见知。", "len": 15}
{"sid": "082_田单列传.2.1.s1", "chapter": "082_田单列传", "para": "2.1", "seq": 1, "text": "及燕使乐毅伐破齐，齐湣王出奔，已而保莒城。", "len": 21}
{"sid": "082_田单列传.2.2.s1", "chapter": "082_田单列传", "para": "2.2", "seq": 1, "text": "燕师长驱平齐，而田单走安平，令其宗人尽断其车轴末而傅铁笼。", "len": 29}
{"sid": "082_田单列传.2.3.s1", "chapter": "082_田单列传", "para": "2.3", "seq": 1, "text": "已而燕军攻安平，城坏，齐人走，争涂，以轊折车败，为燕所虏，唯田单宗人以铁笼故得脱，东保即墨。", "len": 46}
{"sid": "082_田单列传.2.4.s1", "chapter": "082_田单列传", "para": "2.4", "seq": 1, "text": "燕既尽降齐城，唯独莒、即墨不下。", "len": 16}
{"sid": "082_田单列传.2.5.s1", "chapter": "082_田单列传", "para": "2.5", "seq": 1, "text": "燕军闻齐王在莒，并兵攻之。", "len": 13}
{"sid": "082_田单列传.2.6.s1", "chapter": "082_田单列传", "para": "2.6", "seq": 1, "text": "淖齿既杀湣王於莒，因坚守，距燕军，数年不下。", "len": 22}
{"sid": "082_田单列传.2.7.s1", "chapter": "082_田单列传", "para": "2.7", "seq": 1, "text": "燕引兵东围即墨，即墨大夫出与战，败死。", "len": 19}
{"sid": "082_田单列传.2.8.s1", "chapter": "082_田单列传", "para": "2.8", "seq": 1, "text": "城中相与推田单，曰： “安平之战，田单宗人以铁笼得全，习兵。”", "len": 31}
{"sid": "082_田单列传.2.9.s1", "chapter": "082_田单列传", "para": "2.9", "seq": 1, "text": "立以为将军，以即墨距燕。", "len": 12}
{"sid": "082_田单列传.3.1.s1", "chapter": "082_田单列传", "para": "3.1", "seq": 1, "text": "顷之，燕昭王卒，惠王立，与乐毅有隙。", "len": 18}
{"sid": "082_田单列传.3.2.s1", "chapter": "082_田单列传", "para": "3.2", "seq": 1, "text": "田单闻之，乃纵反间於燕，宣言曰： ::: 反间之言 “齐王已死，城之不拔者二耳。", "len": 40}
{"sid": "082_田单列传.3.2.s2", "chapter": "082_田单列传", "para": "3.2", "seq": 2, "text": "乐毅畏诛而不敢归，以伐齐为名，实欲连兵南面而王齐。", "len": 25}
{"sid": "082_田单列传.3.2.s3", "chapter": "082_田单列传", "para": "3.2", "seq": 3, "text": "齐人未附，故且缓攻即墨以待其事。", "len": 16}
{"sid": "082_田单列传.3.2.s4", "chapter": "082_田单列传", "para": "3.2", "seq": 4, "text": "齐人所惧，唯恐他将之来，即墨残矣。", "len": 17}
{"sid": "082_田单列传.3.2.s5", "chapter": "082_田单列传", "para": "3.2", "seq": 5, "text": "” :::", "len": 5}
{"sid": "082_田单列传.3.3.s1", "chapter": "082_田单列传", "para": "3.3", "seq": 1, "text": "燕王以为然，使骑劫代乐毅。", "len": 13}
{"sid": "082_田单列传.4.1.s1", "chapter": "082_田单列传", "para": "4.1", "seq": 1, "text": "乐毅因归赵，燕人士卒忿。", "len": 12}
{"sid": "082_田单列传.4.2.s1", "chapter": "082_田单列传", "para": "4.2", "seq": 1, "text": "而田单乃令城中人食必祭其先祖於庭，飞鸟悉翔舞城中下食。", "len": 27}
{"sid": "082_田单列传.4.3.s1", "chapter": "082_田单列传", "para": "4.3", "seq": 1, "text": "燕人怪之。", "len": 5}
{"sid": "082_田单列传.4.4.s1", "chapter": "082_田单列传", "para": "4.4", "seq": 1, "text": "田单因宣言曰： “神来下教我。”", "len": 16}
{"sid": "082_田单列传.4.5.s1", "chapter": "082_田单列传", "para": "4.5", "seq": 1, "text": "乃令城中人曰： “当有神人为我师。”", "len": 18}
{"sid": "082_田单列传.4.6.s1", "chapter": "082_田单列传", "para": "4.6", "seq": 1, "text": "有一卒曰： “臣可以为师乎？”", "len": 15}
{"sid": "082_田单列传.4.7.s1", "chapter": "082_田单列传", "para": "4.7", "seq": 1, "text": "因反走。", "len": 4}
{"sid": "082_田单列传.4.8.s1", "chapter": "082_田单列传", "para": "4.8", "seq": 1, "text": "田单乃起，引还，东乡坐，师事之。", "len": 16}
{"sid": "082_田单列传.4.9.s1", "chapter": "082_田单列传", "para": "4.9", "seq": 1, "text": "卒曰： “臣欺君，诚无能也。”", "len": 15}
{"sid": "082_田单列传.4.10.s1", "chapter": "082_田单列传", "para": "4.10", "seq": 1, "text": "田单曰： “子勿言也！”", "len": 12}
{"sid": "082_田单列传.4.11.s1", "chapter": "082_田单列传", "para": "4.11", "seq": 1, "text": "因师之。", "len": 4}
{"sid": "082_田单列传.4.11.s2", "chapter": "082_田单列传", "para": "4.11", "seq": 2, "text": "每出约束，必称神师。", "len": 10}
{"sid": "082_田单列传.4.12.s1", "chapter": "082_田单列传", "para": "4.12", "seq": 1, "text": "乃宣言曰： “吾唯惧燕军之劓所得齐卒，置之前行，与我战，即墨败矣。”", "len": 34}
{"sid": "082_田单列传.4.13.s1", "chapter": "082_田单列传", "para": "4.13", "seq": 1, "text": "燕人闻之，如其言。", "len": 9}
{"sid": "082_田单列传.4.14.s1", "chapter": "082_田单列传", "para": "4.14", "seq": 1, "text": "城中人见齐诸降者尽劓，皆怒，坚守，唯恐见得。", "len": 22}
{"sid": "082_田单列传.4.15.s1", "chapter": "082_田单列传", "para": "4.15", "seq": 1, "text": "单又纵反间曰： “吾惧燕人掘吾城外冢墓，僇先人，可为寒心。”", "len": 30}
{"sid": "082_田单列传.4.16.s1", "chapter": "082_田单列传", "para": "4.16", "seq": 1, "text": "燕军尽掘垄墓，烧死人。", "len": 11}
{"sid": "082_田单列传.4.17.s1", "chapter": "082_田单列传", "para": "4.17", "seq": 1, "text": "即墨人从城上望见，皆涕泣，俱欲出战，怒自十倍。", "len": 23}
{"sid": "082_田单列传.5.1.s1", "chapter": "082_田单列传", "para": "5.1", "seq": 1, "text": "田单知士卒之可用，乃身操版插，与士卒分功，妻妾编於行伍之间，尽散饮食飨士。", "len": 37}
{"sid": "082_田单列传.5.2.s1", "chapter": "082_田单列传", "para": "5.2", "seq": 1, "text": "令甲卒皆伏，使老弱女子乘城，遣使约降於燕，燕军皆呼万岁。", "len": 28}
{"sid": "082_田单列传.5.3.s1", "chapter": "082_田单列传", "para": "5.3", "seq": 1, "text": "田单又收民金，得千溢，令即墨富豪遗燕将，曰： “即墨即降，原无虏掠吾族家妻妾，令安堵。”", "len": 44}
{"sid": "082_田单列传.5.4.s1", "chapter": "082_田单列传", "para": "5.4", "seq": 1, "text": "燕将大喜，许之。", "len": 8}
{"sid": "082_田单列传.5.5.s1", "chapter": "082_田单列传", "para": "5.5", "seq": 1, "text": "燕军由此益懈。", "len": 7}
{"sid": "082_田单列传.6.1.s1", "chapter": "082_田单列传", "para": "6.1", "seq": 1, "text": "田单乃收城中得千馀牛，为绛缯衣，画以五彩龙文，束兵刃於其角，而灌脂束苇於尾，烧其端。", "len": 42}
{"sid": "082_田单列传.6.2.s1", "chapter": "082_田单列传", "para": "6.2", "seq": 1, "text": "凿城数十穴，夜纵牛，壮士五千人随其後。", "len": 19}
{"sid": "082_田单列传.6.3.s1", "chapter": "082_田单列传", "para": "6.3", "seq": 1, "text": "牛尾热，怒而奔燕军，燕军夜大惊。", "len": 16}
{"sid": "082_田单列传.6.4.s1", "chapter": "082_田单列传", "para": "6.4", "seq": 1, "text": "牛尾炬火光明炫燿，燕军视之皆龙文，所触尽死伤。", "len": 23}
{"sid": "082_田单列传.6.5.s1", "chapter": "082_田单列传", "para": "6.5", "seq": 1, "text": "五千人因衔枚击之，而城中鼓譟从之，老弱皆击铜器为声，声动天地。", "len": 31}
{"sid": "082_田单列传.6.6.s1", "chapter": "082_田单列传", "para": "6.6", "seq": 1, "text": "燕军大骇，败走。", "len": 8}
{"sid": "082_田单列传.6.7.s1", "chapter": "082_田单列传", "para": "6.7", "seq": 1, "text": "齐人遂夷杀其将骑劫。", "len": 10}
{"sid": "082_田单列传.6.8.s1", "chapter": "082_田单列传", "para": "6.8", "seq": 1, "text": "燕军扰乱奔走，齐人追亡逐北，所过城邑皆畔燕而归田单，兵日益多，乘胜，燕日败亡，卒至河上，而齐七十馀城皆复为齐。", "len": 55}
{"sid": "082_田单列传.6.9.s1", "chapter": "082_田单列传", "para": "6.9", "seq": 1, "text": "乃迎襄王於莒，入临菑而听政。", "len": 14}
{"sid": "082_田单列传.7.1.s1", "chapter": "082_田单列传", "para": "7.1", "seq": 1, "text": "襄王封田单，号曰安平君。", "len": 12}
{"sid": "082_田单列传.7.1.s2", "chapter": "082_田单列传", "para": "7.1", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "082_田单列传.8.s1", "chapter": "082_田单列传", "para": "8", "seq": 1, "text": "太史公曰：兵以正合，以奇胜。", "len": 14}
{"sid": "082_田单列传.8.s2", "chapter": "082_田单列传", "para": "8", "seq": 2, "text": "善之者，出奇无穷。", "len": 9}
{"sid": "082_田单列传.8.s3", "chapter": "082_田单列传", "para": "8", "seq": 3, "text": "奇正还相生，如环之无端。", "len": 12}
{"sid": "082_田单列传.8.s4", "chapter": "082_田单列传", "para": "8", "seq": 4, "text": "夫始如处女，適人开户；後如脱兔，適不及距：其田单之谓邪！", "len": 28}
{"sid": "082_田单列传.8.s5", "chapter": "082_田单列传", "para": "8", "seq": 5, "text": ":::", "len": 3}
{"sid": "082_田单列传.9.1.s1", "chapter": "082_田单列传", "para": "9.1", "seq": 1, "text": "初，淖齿之杀湣王也，莒人求湣王子法章，得之太史嬓之家，为人灌园。", "len": 32}
{"sid": "082_田单列传.9.2.s1", "chapter": "082_田单列传", "para": "9.2", "seq": 1, "text": "嬓女怜而善遇之。", "len": 8}
{"sid": "082_田单列传.9.3.s1", "chapter": "082_田单列传", "para": "9.3", "seq": 1, "text": "後法章私以情告女，女遂与通。", "len": 14}
{"sid": "082_田单列传.9.4.s1", "chapter": "082_田单列传", "para": "9.4", "seq": 1, "text": "及莒人共立法章为齐王，以莒距燕，而太史氏女遂为后，所谓“君王后” 也。", "len": 35}
{"sid": "082_田单列传.10.1.s1", "chapter": "082_田单列传", "para": "10.1", "seq": 1, "text": "燕之初入齐，闻画邑人王蠋贤，令军中曰“环画邑三十里无入”，以王蠋之故。", "len": 35}
{"sid": "082_田单列传.10.2.s1", "chapter": "082_田单列传", "para": "10.2", "seq": 1, "text": "已而使人谓蠋曰： “齐人多高子之义，吾以子为将，封子万家。”", "len": 30}
{"sid": "082_田单列传.10.3.s1", "chapter": "082_田单列传", "para": "10.3", "seq": 1, "text": "蠋固谢。", "len": 4}
{"sid": "082_田单列传.10.4.s1", "chapter": "082_田单列传", "para": "10.4", "seq": 1, "text": "燕人曰： “子不听，吾引三军而屠画邑。”", "len": 20}
{"sid": "082_田单列传.10.5.s1", "chapter": "082_田单列传", "para": "10.5", "seq": 1, "text": "王蠋曰： ::: 王蠋遗言 “忠臣不事二君，贞女不更二夫。", "len": 29}
{"sid": "082_田单列传.10.5.s2", "chapter": "082_田单列传", "para": "10.5", "seq": 2, "text": "齐王不听吾谏，故退而耕於野。", "len": 14}
{"sid": "082_田单列传.10.5.s3", "chapter": "082_田单列传", "para": "10.5", "seq": 3, "text": "国既破亡，吾不能存；今又劫之以兵为君将，是助桀为暴也。", "len": 27}
{"sid": "082_田单列传.10.5.s4", "chapter": "082_田单列传", "para": "10.5", "seq": 4, "text": "与其生而无义，固不如烹！", "len": 12}
{"sid": "082_田单列传.10.5.s5", "chapter": "082_田单列传", "para": "10.5", "seq": 5, "text": "” :::", "len": 5}
{"sid": "082_田单列传.10.6.s1", "chapter": "082_田单列传", "para": "10.6", "seq": 1, "text": "遂经其颈於树枝，自奋绝脰而死。", "len": 15}
{"sid": "082_田单列传.10.7.s1", "chapter": "082_田单列传", "para": "10.7", "seq": 1, "text": "齐亡大夫闻之，曰： “王蠋，布衣也，义不北面於燕，况在位食禄者乎！”", "len": 34}
{"sid": "082_田单列传.10.8.s1", "chapter": "082_田单列传", "para": "10.8", "seq": 1, "text": "乃相聚如莒，求诸子，立为襄王。", "len": 15}
{"sid": "082_田单列传.10.8.s2", "chapter": "082_田单列传", "para": "10.8", "seq": 2, "text": "::: 赞", "len": 5}
{"sid": "082_田单列传.11.s1", "chapter": "082_田单列传", "para": "11", "seq": 1, "text": "军法以正，实尚奇兵。", "len": 10}
{"sid": "082_田单列传.11.s2", "chapter": "082_田单列传", "para": "11", "seq": 2, "text": "断轴自免，反间先行。", "len": 10}
{"sid": "082_田单列传.11.s3", "chapter": "082_田单列传", "para": "11", "seq": 3, "text": "群鸟或众，五牛扬旌。", "len": 10}
{"sid": "082_田单列传.11.s4", "chapter": "082_田单列传", "para": "11", "seq": 4, "text": "卒破骑劫，皆复齐城。", "len": 10}
{"sid": "082_田单列传.11.s5", "chapter": "082_田单列传", "para": "11", "seq": 5, "text": "襄王嗣位，乃封安平。", "len": 10}
{"sid": "082_田单列传.11.s6", "chapter": "082_田单列传", "para": "11", "seq": 6, "text": ":::", "len": 3}
