{"sid": "025_律书.1.1.s1", "chapter": "025_律书", "para": "1.1", "seq": 1, "text": "王者制事立法，物度轨则，壹禀於六律，六律为万事根本焉。", "len": 27}
{"sid": "025_律书.1.2.s1", "chapter": "025_律书", "para": "1.2", "seq": 1, "text": "其於兵械尤所重，故云“望敌知吉凶，闻声效胜负”，百王不易之道也。", "len": 32}
{"sid": "025_律书.1.3.s1", "chapter": "025_律书", "para": "1.3", "seq": 1, "text": "武王伐纣，吹律听声，推孟春以至于季冬，杀气相并，而音尚宫。", "len": 29}
{"sid": "025_律书.1.4.s1", "chapter": "025_律书", "para": "1.4", "seq": 1, "text": "同声相从，物之自然，何足怪哉？", "len": 15}
{"sid": "025_律书.2.1.s1", "chapter": "025_律书", "para": "2.1", "seq": 1, "text": "兵者，圣人所以讨彊暴，平乱世，夷险阻，救危殆。", "len": 23}
{"sid": "025_律书.2.2.s1", "chapter": "025_律书", "para": "2.2", "seq": 1, "text": "自含戴角之兽见犯则校，而况於人怀好恶喜怒之气？", "len": 23}
{"sid": "025_律书.2.3.s1", "chapter": "025_律书", "para": "2.3", "seq": 1, "text": "喜则爱心生，怒则毒螫加，情性之理也。", "len": 18}
{"sid": "025_律书.3.1.s1", "chapter": "025_律书", "para": "3.1", "seq": 1, "text": "昔黄帝有涿鹿之战，以定火灾；", "len": 14}
{"sid": "025_律书.3.2.s1", "chapter": "025_律书", "para": "3.2", "seq": 1, "text": "颛顼有共工之陈，以平水害；", "len": 13}
{"sid": "025_律书.3.3.s1", "chapter": "025_律书", "para": "3.3", "seq": 1, "text": "成汤有南巢之伐，以殄夏乱。", "len": 13}
{"sid": "025_律书.3.4.s1", "chapter": "025_律书", "para": "3.4", "seq": 1, "text": "递兴递废，胜者用事，所受於天也。", "len": 16}
{"sid": "025_律书.4.1.s1", "chapter": "025_律书", "para": "4.1", "seq": 1, "text": "自是之後，名士迭兴，", "len": 10}
{"sid": "025_律书.4.2.s1", "chapter": "025_律书", "para": "4.2", "seq": 1, "text": "晋用咎犯，而齐用王子，吴用孙武，申明军约，赏罚必信，卒伯诸侯，兼列邦土，", "len": 36}
{"sid": "025_律书.4.3.s1", "chapter": "025_律书", "para": "4.3", "seq": 1, "text": "虽不及三代之诰誓，然身宠君尊，当世显扬，可不谓荣焉？", "len": 26}
{"sid": "025_律书.4.4.s1", "chapter": "025_律书", "para": "4.4", "seq": 1, "text": "岂与世儒闇於大较，不权轻重，猥云德化，不当用兵，大至君辱失守，小乃侵犯削弱，遂执不移等哉！", "len": 45}
{"sid": "025_律书.4.5.s1", "chapter": "025_律书", "para": "4.5", "seq": 1, "text": "故教笞不可废於家，刑罚不可捐於国，诛伐不可偃於天下，用之有巧拙，行之有逆顺耳。", "len": 39}
{"sid": "025_律书.5.1.s1", "chapter": "025_律书", "para": "5.1", "seq": 1, "text": "夏桀、殷纣手搏豺狼，足追四马，勇非微也；", "len": 20}
{"sid": "025_律书.5.2.s1", "chapter": "025_律书", "para": "5.2", "seq": 1, "text": "百战克胜，诸侯慑服，权非轻也。", "len": 15}
{"sid": "025_律书.5.3.s1", "chapter": "025_律书", "para": "5.3", "seq": 1, "text": "秦二世宿军无用之地，连兵於边陲，力非弱也；", "len": 21}
{"sid": "025_律书.5.4.s1", "chapter": "025_律书", "para": "5.4", "seq": 1, "text": "结怨匈奴，絓祸於越，势非寡也。", "len": 15}
{"sid": "025_律书.5.5.s1", "chapter": "025_律书", "para": "5.5", "seq": 1, "text": "及其威尽势极，闾巷之人为敌国，咎生穷武之不知足，甘得之心不息也。", "len": 32}
{"sid": "025_律书.6.1.s1", "chapter": "025_律书", "para": "6.1", "seq": 1, "text": "高祖有天下，三边外畔；", "len": 11}
{"sid": "025_律书.6.2.s1", "chapter": "025_律书", "para": "6.2", "seq": 1, "text": "大国之王虽称蕃辅，臣节未尽。", "len": 14}
{"sid": "025_律书.6.3.s1", "chapter": "025_律书", "para": "6.3", "seq": 1, "text": "会高祖厌苦军事，亦有萧、张之谋，故偃武一休息，羁縻不备。", "len": 28}
{"sid": "025_律书.7.1.s1", "chapter": "025_律书", "para": "7.1", "seq": 1, "text": "历至孝文即位，将军陈武等议曰： ::: 陈武等建议征讨 “南越、朝鲜自全秦时内属为臣子，後且拥兵阻阸戹，选蠕观望。", "len": 57}
{"sid": "025_律书.7.1.s2", "chapter": "025_律书", "para": "7.1", "seq": 2, "text": "高祖时天下新定，人民小安，未可复兴兵。", "len": 19}
{"sid": "025_律书.7.1.s3", "chapter": "025_律书", "para": "7.1", "seq": 3, "text": "今陛下仁惠抚百姓，恩泽加海内，宜及士民乐用，征讨逆党，以一封疆。", "len": 32}
{"sid": "025_律书.7.1.s4", "chapter": "025_律书", "para": "7.1", "seq": 4, "text": "” :::", "len": 5}
{"sid": "025_律书.7.2.s1", "chapter": "025_律书", "para": "7.2", "seq": 1, "text": "孝文曰： ::: 文帝答复 “朕能任衣冠，念不到此。", "len": 26}
{"sid": "025_律书.7.2.s2", "chapter": "025_律书", "para": "7.2", "seq": 2, "text": "会吕氏之乱，功臣宗室共不羞耻，误居正位，常战战栗栗，恐事之不终。", "len": 32}
{"sid": "025_律书.7.2.s3", "chapter": "025_律书", "para": "7.2", "seq": 3, "text": "且兵凶器，虽克所原，动亦秏病，谓百姓远方何？", "len": 22}
{"sid": "025_律书.7.2.s4", "chapter": "025_律书", "para": "7.2", "seq": 4, "text": "又先帝知劳民不可烦，故不以为意。", "len": 16}
{"sid": "025_律书.7.2.s5", "chapter": "025_律书", "para": "7.2", "seq": 5, "text": "朕岂自谓能？", "len": 6}
{"sid": "025_律书.7.2.s6", "chapter": "025_律书", "para": "7.2", "seq": 6, "text": "今匈奴内侵，军吏无功，边民父子荷兵日久，朕常为动心伤痛，无日忘之。", "len": 33}
{"sid": "025_律书.7.2.s7", "chapter": "025_律书", "para": "7.2", "seq": 7, "text": "今未能销距，原且坚边设候，结和通使，休宁北陲，为功多矣。", "len": 28}
{"sid": "025_律书.7.2.s8", "chapter": "025_律书", "para": "7.2", "seq": 8, "text": "且无议军。", "len": 5}
{"sid": "025_律书.7.2.s9", "chapter": "025_律书", "para": "7.2", "seq": 9, "text": "” :::", "len": 5}
{"sid": "025_律书.7.3.s1", "chapter": "025_律书", "para": "7.3", "seq": 1, "text": "故百姓无内外之繇，得息肩於田亩，天下殷富，粟至十馀钱，鸣鸡吠狗，烟火万里，可谓和乐者乎！", "len": 44}
{"sid": "025_律书.8.s1", "chapter": "025_律书", "para": "8", "seq": 1, "text": "太史公曰： ::: 太史公评文帝 文帝时，会天下新去汤火，人民乐业，因其欲然，能不扰乱，故百姓遂安。", "len": 50}
{"sid": "025_律书.8.s2", "chapter": "025_律书", "para": "8", "seq": 2, "text": "自年六七十翁亦未尝至市井，游敖嬉戏如小兒状。", "len": 22}
{"sid": "025_律书.8.s3", "chapter": "025_律书", "para": "8", "seq": 3, "text": "孔子所称有德君子者邪！", "len": 11}
{"sid": "025_律书.8.s4", "chapter": "025_律书", "para": "8", "seq": 4, "text": ":::", "len": 3}
{"sid": "025_律书.9.1.s1", "chapter": "025_律书", "para": "9.1", "seq": 1, "text": "书曰“七正”，二十八舍。", "len": 12}
{"sid": "025_律书.9.2.s1", "chapter": "025_律书", "para": "9.2", "seq": 1, "text": "律历，天所以通五行八正之气，天所以成孰万物也。", "len": 23}
{"sid": "025_律书.9.3.s1", "chapter": "025_律书", "para": "9.3", "seq": 1, "text": "舍者，日月所舍。", "len": 8}
{"sid": "025_律书.9.3.s2", "chapter": "025_律书", "para": "9.3", "seq": 2, "text": "舍者，舒气也。", "len": 7}
{"sid": "025_律书.10.1.s1", "chapter": "025_律书", "para": "10.1", "seq": 1, "text": "不周风居西北，主杀生。", "len": 11}
{"sid": "025_律书.10.2.s1", "chapter": "025_律书", "para": "10.2", "seq": 1, "text": "东壁居不周风东，主辟生气而东之。", "len": 16}
{"sid": "025_律书.10.2.s2", "chapter": "025_律书", "para": "10.2", "seq": 2, "text": "至於营室。", "len": 5}
{"sid": "025_律书.10.3.s1", "chapter": "025_律书", "para": "10.3", "seq": 1, "text": "营室者，主营胎阳气而产之。", "len": 13}
{"sid": "025_律书.10.4.s1", "chapter": "025_律书", "para": "10.4", "seq": 1, "text": "东至于危。", "len": 5}
{"sid": "025_律书.10.4.s2", "chapter": "025_律书", "para": "10.4", "seq": 2, "text": "危，垝也。", "len": 5}
{"sid": "025_律书.10.4.s3", "chapter": "025_律书", "para": "10.4", "seq": 3, "text": "言阳气之垝，故曰危。", "len": 10}
{"sid": "025_律书.10.5.s1", "chapter": "025_律书", "para": "10.5", "seq": 1, "text": "十月也，律中应锺。", "len": 9}
{"sid": "025_律书.10.6.s1", "chapter": "025_律书", "para": "10.6", "seq": 1, "text": "应锺者，阳气之应，不用事也。", "len": 14}
{"sid": "025_律书.10.7.s1", "chapter": "025_律书", "para": "10.7", "seq": 1, "text": "其於十二子为亥。", "len": 8}
{"sid": "025_律书.10.7.s2", "chapter": "025_律书", "para": "10.7", "seq": 2, "text": "亥者，该也。", "len": 6}
{"sid": "025_律书.10.7.s3", "chapter": "025_律书", "para": "10.7", "seq": 3, "text": "言阳气藏於下，故该也。", "len": 11}
{"sid": "025_律书.11.1.s1", "chapter": "025_律书", "para": "11.1", "seq": 1, "text": "广莫风居北方。", "len": 7}
{"sid": "025_律书.11.2.s1", "chapter": "025_律书", "para": "11.2", "seq": 1, "text": "广莫者，言阳气在下，阴莫阳广大也，故曰广莫。", "len": 22}
{"sid": "025_律书.11.3.s1", "chapter": "025_律书", "para": "11.3", "seq": 1, "text": "东至於虚。", "len": 5}
{"sid": "025_律书.11.3.s2", "chapter": "025_律书", "para": "11.3", "seq": 2, "text": "虚者，能实能虚，言阳气冬则宛藏於虚，日冬至则一阴下藏，一阳上舒，故曰虚。", "len": 36}
{"sid": "025_律书.11.4.s1", "chapter": "025_律书", "para": "11.4", "seq": 1, "text": "东至于须女。", "len": 6}
{"sid": "025_律书.11.4.s2", "chapter": "025_律书", "para": "11.4", "seq": 2, "text": "言万物变动其所，阴阳气未相离，尚相胥也，故曰须女。", "len": 25}
{"sid": "025_律书.11.5.s1", "chapter": "025_律书", "para": "11.5", "seq": 1, "text": "十一月也，律中黄锺。", "len": 10}
{"sid": "025_律书.11.6.s1", "chapter": "025_律书", "para": "11.6", "seq": 1, "text": "黄锺者，阳气踵黄泉而出也。", "len": 13}
{"sid": "025_律书.11.7.s1", "chapter": "025_律书", "para": "11.7", "seq": 1, "text": "其於十二子为子。", "len": 8}
{"sid": "025_律书.11.7.s2", "chapter": "025_律书", "para": "11.7", "seq": 2, "text": "子者，滋也；滋者，言万物滋於下也。", "len": 17}
{"sid": "025_律书.11.8.s1", "chapter": "025_律书", "para": "11.8", "seq": 1, "text": "其於十母为壬癸。", "len": 8}
{"sid": "025_律书.11.8.s2", "chapter": "025_律书", "para": "11.8", "seq": 2, "text": "壬之为言任也，言阳气任养万物於下也。", "len": 18}
{"sid": "025_律书.11.8.s3", "chapter": "025_律书", "para": "11.8", "seq": 3, "text": "癸之为言揆也，言万物可揆度，故曰癸。", "len": 18}
{"sid": "025_律书.11.9.s1", "chapter": "025_律书", "para": "11.9", "seq": 1, "text": "东至牵牛。", "len": 5}
{"sid": "025_律书.11.9.s2", "chapter": "025_律书", "para": "11.9", "seq": 2, "text": "牵牛者，言阳气牵引万物出之也。", "len": 15}
{"sid": "025_律书.11.9.s3", "chapter": "025_律书", "para": "11.9", "seq": 3, "text": "牛者，冒也，言地虽冻，能冒而生也。", "len": 17}
{"sid": "025_律书.11.9.s4", "chapter": "025_律书", "para": "11.9", "seq": 4, "text": "牛者，耕植种万物也。", "len": 10}
{"sid": "025_律书.11.10.s1", "chapter": "025_律书", "para": "11.10", "seq": 1, "text": "东至於建星。", "len": 6}
{"sid": "025_律书.11.10.s2", "chapter": "025_律书", "para": "11.10", "seq": 2, "text": "建星者，建诸生也。", "len": 9}
{"sid": "025_律书.11.11.s1", "chapter": "025_律书", "para": "11.11", "seq": 1, "text": "十二月也，律中大吕。", "len": 10}
{"sid": "025_律书.11.11.s2", "chapter": "025_律书", "para": "11.11", "seq": 2, "text": "大吕者。", "len": 4}
{"sid": "025_律书.11.11.s3", "chapter": "025_律书", "para": "11.11", "seq": 3, "text": "其於十二子为丑。", "len": 8}
{"sid": "025_律书.12.1.s1", "chapter": "025_律书", "para": "12.1", "seq": 1, "text": "条风居东北，主出万物。", "len": 11}
{"sid": "025_律书.12.2.s1", "chapter": "025_律书", "para": "12.2", "seq": 1, "text": "条之言条治万物而出之，故曰条风。", "len": 16}
{"sid": "025_律书.12.3.s1", "chapter": "025_律书", "para": "12.3", "seq": 1, "text": "南至於箕。", "len": 5}
{"sid": "025_律书.12.3.s2", "chapter": "025_律书", "para": "12.3", "seq": 2, "text": "箕者，言万物根棋，故曰箕。", "len": 13}
{"sid": "025_律书.12.4.s1", "chapter": "025_律书", "para": "12.4", "seq": 1, "text": "正月也，律中泰蔟。", "len": 9}
{"sid": "025_律书.12.5.s1", "chapter": "025_律书", "para": "12.5", "seq": 1, "text": "泰蔟者，言万物蔟生也，故曰泰蔟。", "len": 16}
{"sid": "025_律书.12.6.s1", "chapter": "025_律书", "para": "12.6", "seq": 1, "text": "其於十二子为寅。", "len": 8}
{"sid": "025_律书.12.6.s2", "chapter": "025_律书", "para": "12.6", "seq": 2, "text": "寅言万物始生螾然也，故曰寅。", "len": 14}
{"sid": "025_律书.12.7.s1", "chapter": "025_律书", "para": "12.7", "seq": 1, "text": "南至於尾，言万物始生如尾也。", "len": 14}
{"sid": "025_律书.12.8.s1", "chapter": "025_律书", "para": "12.8", "seq": 1, "text": "南至於心，言万物始生有华心也。", "len": 15}
{"sid": "025_律书.12.9.s1", "chapter": "025_律书", "para": "12.9", "seq": 1, "text": "南至於房。", "len": 5}
{"sid": "025_律书.12.9.s2", "chapter": "025_律书", "para": "12.9", "seq": 2, "text": "房者，言万物门户也，至于门则出矣。", "len": 17}
{"sid": "025_律书.13.1.s1", "chapter": "025_律书", "para": "13.1", "seq": 1, "text": "明庶风居东方。", "len": 7}
{"sid": "025_律书.13.2.s1", "chapter": "025_律书", "para": "13.2", "seq": 1, "text": "明庶者，明众物尽出也。", "len": 11}
{"sid": "025_律书.13.3.s1", "chapter": "025_律书", "para": "13.3", "seq": 1, "text": "二月也，律中夹锺。", "len": 9}
{"sid": "025_律书.13.4.s1", "chapter": "025_律书", "para": "13.4", "seq": 1, "text": "夹锺者，言阴阳相夹厕也。", "len": 12}
{"sid": "025_律书.13.5.s1", "chapter": "025_律书", "para": "13.5", "seq": 1, "text": "其於十二子为卯。", "len": 8}
{"sid": "025_律书.13.5.s2", "chapter": "025_律书", "para": "13.5", "seq": 2, "text": "卯之为言茂也，言万物茂也。", "len": 13}
{"sid": "025_律书.13.6.s1", "chapter": "025_律书", "para": "13.6", "seq": 1, "text": "其於十母为甲乙。", "len": 8}
{"sid": "025_律书.13.6.s2", "chapter": "025_律书", "para": "13.6", "seq": 2, "text": "甲者，言万物剖符甲而出也；乙者，言万物生轧轧也。", "len": 24}
{"sid": "025_律书.13.7.s1", "chapter": "025_律书", "para": "13.7", "seq": 1, "text": "南至于氐者。", "len": 6}
{"sid": "025_律书.13.7.s2", "chapter": "025_律书", "para": "13.7", "seq": 2, "text": "氐者，言万物皆至也。", "len": 10}
{"sid": "025_律书.13.8.s1", "chapter": "025_律书", "para": "13.8", "seq": 1, "text": "南至於亢。", "len": 5}
{"sid": "025_律书.13.8.s2", "chapter": "025_律书", "para": "13.8", "seq": 2, "text": "亢者，言万物亢见也。", "len": 10}
{"sid": "025_律书.13.9.s1", "chapter": "025_律书", "para": "13.9", "seq": 1, "text": "南至于角。", "len": 5}
{"sid": "025_律书.13.9.s2", "chapter": "025_律书", "para": "13.9", "seq": 2, "text": "角者，言万物皆有枝格如角也。", "len": 14}
{"sid": "025_律书.13.10.s1", "chapter": "025_律书", "para": "13.10", "seq": 1, "text": "三月也，律中姑洗。", "len": 9}
{"sid": "025_律书.13.11.s1", "chapter": "025_律书", "para": "13.11", "seq": 1, "text": "姑洗者，言万物洗生。", "len": 10}
{"sid": "025_律书.13.11.s2", "chapter": "025_律书", "para": "13.11", "seq": 2, "text": "其於十二子为辰。", "len": 8}
{"sid": "025_律书.13.11.s3", "chapter": "025_律书", "para": "13.11", "seq": 3, "text": "辰者，言万物之蜄也。", "len": 10}
{"sid": "025_律书.14.1.s1", "chapter": "025_律书", "para": "14.1", "seq": 1, "text": "清明风居东南维，主风吹万物而西之。", "len": 17}
{"sid": "025_律书.14.2.s1", "chapter": "025_律书", "para": "14.2", "seq": 1, "text": "轸者，言万物益大而轸轸然。", "len": 13}
{"sid": "025_律书.14.3.s1", "chapter": "025_律书", "para": "14.3", "seq": 1, "text": "西至於翼。", "len": 5}
{"sid": "025_律书.14.3.s2", "chapter": "025_律书", "para": "14.3", "seq": 2, "text": "翼者，言万物皆有羽翼也。", "len": 12}
{"sid": "025_律书.14.4.s1", "chapter": "025_律书", "para": "14.4", "seq": 1, "text": "四月也，律中中吕。", "len": 9}
{"sid": "025_律书.14.5.s1", "chapter": "025_律书", "para": "14.5", "seq": 1, "text": "中吕者，言万物尽旅而西行也。", "len": 14}
{"sid": "025_律书.14.6.s1", "chapter": "025_律书", "para": "14.6", "seq": 1, "text": "其於十二子为巳。", "len": 8}
{"sid": "025_律书.14.6.s2", "chapter": "025_律书", "para": "14.6", "seq": 2, "text": "巳者，言阳气之已尽也。", "len": 11}
{"sid": "025_律书.14.7.s1", "chapter": "025_律书", "para": "14.7", "seq": 1, "text": "西至于七星。", "len": 6}
{"sid": "025_律书.14.7.s2", "chapter": "025_律书", "para": "14.7", "seq": 2, "text": "七星者，阳数成於七，故曰七星。", "len": 15}
{"sid": "025_律书.14.8.s1", "chapter": "025_律书", "para": "14.8", "seq": 1, "text": "西至于张。", "len": 5}
{"sid": "025_律书.14.8.s2", "chapter": "025_律书", "para": "14.8", "seq": 2, "text": "张者，言万物皆张也。", "len": 10}
{"sid": "025_律书.14.9.s1", "chapter": "025_律书", "para": "14.9", "seq": 1, "text": "西至于注。", "len": 5}
{"sid": "025_律书.14.9.s2", "chapter": "025_律书", "para": "14.9", "seq": 2, "text": "注者，言万物之始衰，阳气下注，故曰注。", "len": 19}
{"sid": "025_律书.14.10.s1", "chapter": "025_律书", "para": "14.10", "seq": 1, "text": "五月也，律中蕤宾。", "len": 9}
{"sid": "025_律书.14.11.s1", "chapter": "025_律书", "para": "14.11", "seq": 1, "text": "蕤宾者，言阴气幼少，故曰蕤；痿阳不用事，故曰宾。", "len": 24}
{"sid": "025_律书.15.1.s1", "chapter": "025_律书", "para": "15.1", "seq": 1, "text": "景风居南方。", "len": 6}
{"sid": "025_律书.15.2.s1", "chapter": "025_律书", "para": "15.2", "seq": 1, "text": "景者，言阳气道竟，故曰景风。", "len": 14}
{"sid": "025_律书.15.3.s1", "chapter": "025_律书", "para": "15.3", "seq": 1, "text": "其於十二子为午。", "len": 8}
{"sid": "025_律书.15.3.s2", "chapter": "025_律书", "para": "15.3", "seq": 2, "text": "午者，阴阳交，故曰午。", "len": 11}
{"sid": "025_律书.15.4.s1", "chapter": "025_律书", "para": "15.4", "seq": 1, "text": "其於十母为丙丁。", "len": 8}
{"sid": "025_律书.15.4.s2", "chapter": "025_律书", "para": "15.4", "seq": 2, "text": "丙者，言阳道著明，故曰丙；丁者，言万物之丁壮也，故曰丁。", "len": 28}
{"sid": "025_律书.15.5.s1", "chapter": "025_律书", "para": "15.5", "seq": 1, "text": "西至于弧。", "len": 5}
{"sid": "025_律书.15.5.s2", "chapter": "025_律书", "para": "15.5", "seq": 2, "text": "弧者，言万物之吴落且就死也。", "len": 14}
{"sid": "025_律书.15.6.s1", "chapter": "025_律书", "para": "15.6", "seq": 1, "text": "西至于狼。", "len": 5}
{"sid": "025_律书.15.6.s2", "chapter": "025_律书", "para": "15.6", "seq": 2, "text": "狼者，言万物可度量，断万物，故曰狼。", "len": 18}
{"sid": "025_律书.16.1.s1", "chapter": "025_律书", "para": "16.1", "seq": 1, "text": "凉风居西南维，主地。", "len": 10}
{"sid": "025_律书.16.2.s1", "chapter": "025_律书", "para": "16.2", "seq": 1, "text": "地者，沈夺万物气也。", "len": 10}
{"sid": "025_律书.16.3.s1", "chapter": "025_律书", "para": "16.3", "seq": 1, "text": "六月也，律中林锺。", "len": 9}
{"sid": "025_律书.16.4.s1", "chapter": "025_律书", "para": "16.4", "seq": 1, "text": "林锺者，言万物就死气林林然。", "len": 14}
{"sid": "025_律书.16.5.s1", "chapter": "025_律书", "para": "16.5", "seq": 1, "text": "其於十二子为未。", "len": 8}
{"sid": "025_律书.16.5.s2", "chapter": "025_律书", "para": "16.5", "seq": 2, "text": "未者，言万物皆成，有滋味也。", "len": 14}
{"sid": "025_律书.16.6.s1", "chapter": "025_律书", "para": "16.6", "seq": 1, "text": "北至於罚。", "len": 5}
{"sid": "025_律书.16.6.s2", "chapter": "025_律书", "para": "16.6", "seq": 2, "text": "罚者，言万物气夺可伐也。", "len": 12}
{"sid": "025_律书.16.7.s1", "chapter": "025_律书", "para": "16.7", "seq": 1, "text": "北至於参。", "len": 5}
{"sid": "025_律书.16.7.s2", "chapter": "025_律书", "para": "16.7", "seq": 2, "text": "参言万物可参也，故曰参。", "len": 12}
{"sid": "025_律书.16.8.s1", "chapter": "025_律书", "para": "16.8", "seq": 1, "text": "七月也，律中夷则。", "len": 9}
{"sid": "025_律书.16.9.s1", "chapter": "025_律书", "para": "16.9", "seq": 1, "text": "夷则，言阴气之贼万物也。", "len": 12}
{"sid": "025_律书.16.10.s1", "chapter": "025_律书", "para": "16.10", "seq": 1, "text": "其於十二子为申。", "len": 8}
{"sid": "025_律书.16.10.s2", "chapter": "025_律书", "para": "16.10", "seq": 2, "text": "申者，言阴用事，申贼万物，故曰申。", "len": 17}
{"sid": "025_律书.16.11.s1", "chapter": "025_律书", "para": "16.11", "seq": 1, "text": "北至於浊。", "len": 5}
{"sid": "025_律书.16.11.s2", "chapter": "025_律书", "para": "16.11", "seq": 2, "text": "浊者，触也，言万物皆触死也，故曰浊。", "len": 18}
{"sid": "025_律书.16.12.s1", "chapter": "025_律书", "para": "16.12", "seq": 1, "text": "北至於留。", "len": 5}
{"sid": "025_律书.16.12.s2", "chapter": "025_律书", "para": "16.12", "seq": 2, "text": "留者，言阳气之稽留也，故曰留。", "len": 15}
{"sid": "025_律书.16.13.s1", "chapter": "025_律书", "para": "16.13", "seq": 1, "text": "八月也，律中南吕。", "len": 9}
{"sid": "025_律书.16.14.s1", "chapter": "025_律书", "para": "16.14", "seq": 1, "text": "南吕者，言阳气之旅入藏也。", "len": 13}
{"sid": "025_律书.16.15.s1", "chapter": "025_律书", "para": "16.15", "seq": 1, "text": "其於十二子为酉。", "len": 8}
{"sid": "025_律书.16.15.s2", "chapter": "025_律书", "para": "16.15", "seq": 2, "text": "酉者，万物之老也，故曰酉。", "len": 13}
{"sid": "025_律书.17.1.s1", "chapter": "025_律书", "para": "17.1", "seq": 1, "text": "阊阖风居西方。", "len": 7}
{"sid": "025_律书.17.2.s1", "chapter": "025_律书", "para": "17.2", "seq": 1, "text": "阊者，倡也；阖者，藏也。", "len": 12}
{"sid": "025_律书.17.2.s2", "chapter": "025_律书", "para": "17.2", "seq": 2, "text": "言阳气道万物，阖黄泉也。", "len": 12}
{"sid": "025_律书.17.3.s1", "chapter": "025_律书", "para": "17.3", "seq": 1, "text": "其於十母为庚辛。", "len": 8}
{"sid": "025_律书.17.3.s2", "chapter": "025_律书", "para": "17.3", "seq": 2, "text": "庚者，言阴气庚万物，故曰庚；辛者，言万物之辛生，故曰辛。", "len": 28}
{"sid": "025_律书.17.4.s1", "chapter": "025_律书", "para": "17.4", "seq": 1, "text": "北至於胃。", "len": 5}
{"sid": "025_律书.17.4.s2", "chapter": "025_律书", "para": "17.4", "seq": 2, "text": "胃者，言阳气就藏，皆胃胃也。", "len": 14}
{"sid": "025_律书.17.5.s1", "chapter": "025_律书", "para": "17.5", "seq": 1, "text": "北至於娄。", "len": 5}
{"sid": "025_律书.17.5.s2", "chapter": "025_律书", "para": "17.5", "seq": 2, "text": "娄者，呼万物且内之也。", "len": 11}
{"sid": "025_律书.17.6.s1", "chapter": "025_律书", "para": "17.6", "seq": 1, "text": "北至於奎。", "len": 5}
{"sid": "025_律书.17.6.s2", "chapter": "025_律书", "para": "17.6", "seq": 2, "text": "奎者，主毒螫杀万物也，奎而藏之。", "len": 16}
{"sid": "025_律书.17.7.s1", "chapter": "025_律书", "para": "17.7", "seq": 1, "text": "九月也，律中无射。", "len": 9}
{"sid": "025_律书.17.8.s1", "chapter": "025_律书", "para": "17.8", "seq": 1, "text": "无射者，阴气盛用事，阳气无馀也，故曰无射。", "len": 21}
{"sid": "025_律书.17.9.s1", "chapter": "025_律书", "para": "17.9", "seq": 1, "text": "其於十二子为戌。", "len": 8}
{"sid": "025_律书.17.9.s2", "chapter": "025_律书", "para": "17.9", "seq": 2, "text": "戌者，言万物尽灭，故曰戌。", "len": 13}
{"sid": "025_律书.18.1.s1", "chapter": "025_律书", "para": "18.1", "seq": 1, "text": "律数：九九八十一以为宫。", "len": 12}
{"sid": "025_律书.18.2.s1", "chapter": "025_律书", "para": "18.2", "seq": 1, "text": "三分去一，五十四以为徵。", "len": 12}
{"sid": "025_律书.18.3.s1", "chapter": "025_律书", "para": "18.3", "seq": 1, "text": "三分益一，七十二以为商。", "len": 12}
{"sid": "025_律书.18.4.s1", "chapter": "025_律书", "para": "18.4", "seq": 1, "text": "三分去一，四十八以为羽。", "len": 12}
{"sid": "025_律书.18.5.s1", "chapter": "025_律书", "para": "18.5", "seq": 1, "text": "三分益一，六十四以为角。", "len": 12}
{"sid": "025_律书.19.1.s1", "chapter": "025_律书", "para": "19.1", "seq": 1, "text": "黄锺长八寸七分一，宫。", "len": 11}
{"sid": "025_律书.19.2.s1", "chapter": "025_律书", "para": "19.2", "seq": 1, "text": "大吕长七寸五分三分。", "len": 10}
{"sid": "025_律书.19.3.s1", "chapter": "025_律书", "para": "19.3", "seq": 1, "text": "太蔟长七寸分二，角。", "len": 10}
{"sid": "025_律书.19.4.s1", "chapter": "025_律书", "para": "19.4", "seq": 1, "text": "夹锺长六寸分三分一。", "len": 10}
{"sid": "025_律书.19.5.s1", "chapter": "025_律书", "para": "19.5", "seq": 1, "text": "姑洗长六寸分四，羽。", "len": 10}
{"sid": "025_律书.19.6.s1", "chapter": "025_律书", "para": "19.6", "seq": 1, "text": "仲吕长五寸九分三分二，徵。", "len": 13}
{"sid": "025_律书.19.7.s1", "chapter": "025_律书", "para": "19.7", "seq": 1, "text": "蕤宾长五寸六分三分。", "len": 10}
{"sid": "025_律书.19.8.s1", "chapter": "025_律书", "para": "19.8", "seq": 1, "text": "林锺长五寸分四，角。", "len": 10}
{"sid": "025_律书.19.9.s1", "chapter": "025_律书", "para": "19.9", "seq": 1, "text": "夷则长五寸三分二，商。", "len": 11}
{"sid": "025_律书.19.10.s1", "chapter": "025_律书", "para": "19.10", "seq": 1, "text": "南吕长四寸分八，徵。", "len": 10}
{"sid": "025_律书.19.11.s1", "chapter": "025_律书", "para": "19.11", "seq": 1, "text": "无射长四寸四分三分二。", "len": 11}
{"sid": "025_律书.19.12.s1", "chapter": "025_律书", "para": "19.12", "seq": 1, "text": "应锺长四寸二分三分二，羽。", "len": 13}
{"sid": "025_律书.20.1.s1", "chapter": "025_律书", "para": "20.1", "seq": 1, "text": "生锺分：", "len": 4}
{"sid": "025_律书.20.2.s1", "chapter": "025_律书", "para": "20.2", "seq": 1, "text": "子一分。", "len": 4}
{"sid": "025_律书.20.3.s1", "chapter": "025_律书", "para": "20.3", "seq": 1, "text": "丑三分二。", "len": 5}
{"sid": "025_律书.20.4.s1", "chapter": "025_律书", "para": "20.4", "seq": 1, "text": "寅九分八。", "len": 5}
{"sid": "025_律书.20.5.s1", "chapter": "025_律书", "para": "20.5", "seq": 1, "text": "卯二十七分十六。", "len": 8}
{"sid": "025_律书.20.6.s1", "chapter": "025_律书", "para": "20.6", "seq": 1, "text": "辰八十一分六十四。", "len": 9}
{"sid": "025_律书.20.7.s1", "chapter": "025_律书", "para": "20.7", "seq": 1, "text": "巳二百四十三分一百二十八。", "len": 13}
{"sid": "025_律书.20.8.s1", "chapter": "025_律书", "para": "20.8", "seq": 1, "text": "午七百二十九分五百一十二。", "len": 13}
{"sid": "025_律书.20.9.s1", "chapter": "025_律书", "para": "20.9", "seq": 1, "text": "未二千一百八十七分一千二十四。", "len": 15}
{"sid": "025_律书.20.10.s1", "chapter": "025_律书", "para": "20.10", "seq": 1, "text": "申六千五百六十一分四千九十六。", "len": 15}
{"sid": "025_律书.20.11.s1", "chapter": "025_律书", "para": "20.11", "seq": 1, "text": "酉一万九千六百八十三分八千一百九十二。", "len": 19}
{"sid": "025_律书.20.12.s1", "chapter": "025_律书", "para": "20.12", "seq": 1, "text": "戌五万九千四十九分三万二千七百六十八。", "len": 19}
{"sid": "025_律书.20.13.s1", "chapter": "025_律书", "para": "20.13", "seq": 1, "text": "亥十七万七千一百四十七分六万五千五百三十六。", "len": 22}
{"sid": "025_律书.21.1.s1", "chapter": "025_律书", "para": "21.1", "seq": 1, "text": "生黄锺术曰：", "len": 6}
{"sid": "025_律书.21.2.s1", "chapter": "025_律书", "para": "21.2", "seq": 1, "text": "以下生者，倍其实，三其法。", "len": 13}
{"sid": "025_律书.21.3.s1", "chapter": "025_律书", "para": "21.3", "seq": 1, "text": "以上生者，四其实，三其法。", "len": 13}
{"sid": "025_律书.21.4.s1", "chapter": "025_律书", "para": "21.4", "seq": 1, "text": "上九，商八，羽七，角六，宫五，徵九。", "len": 18}
{"sid": "025_律书.21.5.s1", "chapter": "025_律书", "para": "21.5", "seq": 1, "text": "置一而九三之以为法。", "len": 10}
{"sid": "025_律书.21.5.s2", "chapter": "025_律书", "para": "21.5", "seq": 2, "text": "实如法，得长一寸。", "len": 9}
{"sid": "025_律书.21.6.s1", "chapter": "025_律书", "para": "21.6", "seq": 1, "text": "凡得九寸，命曰“黄锺之宫”。", "len": 14}
{"sid": "025_律书.21.7.s1", "chapter": "025_律书", "para": "21.7", "seq": 1, "text": "故曰音始於宫，穷於角；数始於一，终於十，成於三；气始於冬至，周而复生。", "len": 35}
{"sid": "025_律书.22.1.s1", "chapter": "025_律书", "para": "22.1", "seq": 1, "text": "神生於无，形成於有，形然後数，形而成声，故曰神使气，气就形。", "len": 30}
{"sid": "025_律书.22.2.s1", "chapter": "025_律书", "para": "22.2", "seq": 1, "text": "形理如类有可类。", "len": 8}
{"sid": "025_律书.22.2.s2", "chapter": "025_律书", "para": "22.2", "seq": 2, "text": "或未形而未类，或同形而同类，类而可班，类而可识。", "len": 24}
{"sid": "025_律书.22.3.s1", "chapter": "025_律书", "para": "22.3", "seq": 1, "text": "圣人知天地识之别，故从有以至未有，以得细若气，微若声。", "len": 27}
{"sid": "025_律书.22.4.s1", "chapter": "025_律书", "para": "22.4", "seq": 1, "text": "然圣人因神而存之，虽妙必效情，核其华道者明矣。", "len": 23}
{"sid": "025_律书.22.5.s1", "chapter": "025_律书", "para": "22.5", "seq": 1, "text": "非有圣心以乘聪明，孰能存天地之神而成形之情哉？", "len": 23}
{"sid": "025_律书.22.6.s1", "chapter": "025_律书", "para": "22.6", "seq": 1, "text": "神者，物受之而不能知其去来，故圣人畏而欲存之。", "len": 23}
{"sid": "025_律书.22.7.s1", "chapter": "025_律书", "para": "22.7", "seq": 1, "text": "唯欲存之，神之亦存。", "len": 10}
{"sid": "025_律书.22.7.s2", "chapter": "025_律书", "para": "22.7", "seq": 2, "text": "其欲存之者，故莫贵焉。", "len": 11}
{"sid": "025_律书.22.7.s3", "chapter": "025_律书", "para": "22.7", "seq": 3, "text": "::: 太史公曰", "len": 8}
{"sid": "025_律书.23.s1", "chapter": "025_律书", "para": "23", "seq": 1, "text": "太史公曰：旋玑玉衡以齐七政，即天地二十八宿。", "len": 22}
{"sid": "025_律书.23.s2", "chapter": "025_律书", "para": "23", "seq": 2, "text": "十母，十二子，锺律调自上古。", "len": 14}
{"sid": "025_律书.23.s3", "chapter": "025_律书", "para": "23", "seq": 3, "text": "建律运历造日度，可据而度也。", "len": 14}
{"sid": "025_律书.23.s4", "chapter": "025_律书", "para": "23", "seq": 4, "text": "合符节，通道德，即从斯之谓也。", "len": 15}
{"sid": "025_律书.23.s5", "chapter": "025_律书", "para": "23", "seq": 5, "text": "::: ::: 赞", "len": 9}
{"sid": "025_律书.24.s1", "chapter": "025_律书", "para": "24", "seq": 1, "text": "自昔轩后，爰命伶纶。", "len": 10}
{"sid": "025_律书.24.s2", "chapter": "025_律书", "para": "24", "seq": 2, "text": "雄雌是听，厚薄伊均。", "len": 10}
{"sid": "025_律书.24.s3", "chapter": "025_律书", "para": "24", "seq": 3, "text": "以调气候，以轨星辰。", "len": 10}
{"sid": "025_律书.24.s4", "chapter": "025_律书", "para": "24", "seq": 4, "text": "军容取节，乐器斯因。", "len": 10}
{"sid": "025_律书.24.s5", "chapter": "025_律书", "para": "24", "seq": 5, "text": "自微知著，测化穷神。", "len": 10}
{"sid": "025_律书.24.s6", "chapter": "025_律书", "para": "24", "seq": 6, "text": "大哉虚受，含养生人。", "len": 10}
{"sid": "025_律书.24.s7", "chapter": "025_律书", "para": "24", "seq": 7, "text": ":::", "len": 3}
