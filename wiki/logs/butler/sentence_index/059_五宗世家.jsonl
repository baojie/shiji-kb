{"sid": "059_五宗世家.1.s1", "chapter": "059_五宗世家", "para": "1", "seq": 1, "text": "孝景皇帝子凡十三人为王，而母五人，同母者为宗亲。", "len": 24}
{"sid": "059_五宗世家.1.s2", "chapter": "059_五宗世家", "para": "1", "seq": 2, "text": "栗姬子曰荣、德、阏于。", "len": 11}
{"sid": "059_五宗世家.1.s3", "chapter": "059_五宗世家", "para": "1", "seq": 3, "text": "程姬子曰馀、非、端。", "len": 10}
{"sid": "059_五宗世家.1.s4", "chapter": "059_五宗世家", "para": "1", "seq": 4, "text": "贾夫人子曰彭祖、胜。", "len": 10}
{"sid": "059_五宗世家.1.s5", "chapter": "059_五宗世家", "para": "1", "seq": 5, "text": "唐姬子曰发。", "len": 6}
{"sid": "059_五宗世家.1.s6", "chapter": "059_五宗世家", "para": "1", "seq": 6, "text": "王夫人兒姁子曰越、寄、乘、舜。", "len": 15}
{"sid": "059_五宗世家.2.s1", "chapter": "059_五宗世家", "para": "2", "seq": 1, "text": "河间献王德，以孝景帝前二年用皇子为河间王。", "len": 21}
{"sid": "059_五宗世家.2.s2", "chapter": "059_五宗世家", "para": "2", "seq": 2, "text": "好儒学，被服造次必於儒者。", "len": 13}
{"sid": "059_五宗世家.2.s3", "chapter": "059_五宗世家", "para": "2", "seq": 3, "text": "山东诸儒多从之游。", "len": 9}
{"sid": "059_五宗世家.3.s1", "chapter": "059_五宗世家", "para": "3", "seq": 1, "text": "二十六年卒，子共王不害立。", "len": 13}
{"sid": "059_五宗世家.3.s2", "chapter": "059_五宗世家", "para": "3", "seq": 2, "text": "四年卒，子刚王基代立。", "len": 11}
{"sid": "059_五宗世家.3.s3", "chapter": "059_五宗世家", "para": "3", "seq": 3, "text": "十二年卒，子顷王授代立。", "len": 12}
{"sid": "059_五宗世家.4.s1", "chapter": "059_五宗世家", "para": "4", "seq": 1, "text": "临江哀王阏于，以孝景帝前二年用皇子为临江王。", "len": 22}
{"sid": "059_五宗世家.4.s2", "chapter": "059_五宗世家", "para": "4", "seq": 2, "text": "三年卒，无後，国除为郡。", "len": 12}
{"sid": "059_五宗世家.5.s1", "chapter": "059_五宗世家", "para": "5", "seq": 1, "text": "临江闵王荣，以孝景前四年为皇太子，四岁废，用故太子为临江王。", "len": 30}
{"sid": "059_五宗世家.6.s1", "chapter": "059_五宗世家", "para": "6", "seq": 1, "text": "四年，坐侵庙壖垣为宫，上徵荣。", "len": 15}
{"sid": "059_五宗世家.6.s2", "chapter": "059_五宗世家", "para": "6", "seq": 2, "text": "荣行，祖於江陵北门。", "len": 10}
{"sid": "059_五宗世家.6.s3", "chapter": "059_五宗世家", "para": "6", "seq": 3, "text": "既已上车，轴折车废。", "len": 10}
{"sid": "059_五宗世家.6.s4", "chapter": "059_五宗世家", "para": "6", "seq": 4, "text": "江陵父老流涕窃言曰：“吾王不反矣！", "len": 17}
{"sid": "059_五宗世家.6.s5", "chapter": "059_五宗世家", "para": "6", "seq": 5, "text": "” 荣至，诣中尉府簿。", "len": 11}
{"sid": "059_五宗世家.6.s6", "chapter": "059_五宗世家", "para": "6", "seq": 6, "text": "中尉郅都责讯王，王恐，自杀。", "len": 14}
{"sid": "059_五宗世家.6.s7", "chapter": "059_五宗世家", "para": "6", "seq": 7, "text": "葬蓝田。", "len": 4}
{"sid": "059_五宗世家.6.s8", "chapter": "059_五宗世家", "para": "6", "seq": 8, "text": "燕数万衔土置冢上，百姓怜之。", "len": 14}
{"sid": "059_五宗世家.7.s1", "chapter": "059_五宗世家", "para": "7", "seq": 1, "text": "荣最长，死无後，国除，地入于汉，为南郡。", "len": 20}
{"sid": "059_五宗世家.8.s1", "chapter": "059_五宗世家", "para": "8", "seq": 1, "text": "右三国本王皆栗姬之子也。", "len": 12}
{"sid": "059_五宗世家.9.s1", "chapter": "059_五宗世家", "para": "9", "seq": 1, "text": "鲁共王馀，以孝景前二年用皇子为淮阳王。", "len": 19}
{"sid": "059_五宗世家.9.s2", "chapter": "059_五宗世家", "para": "9", "seq": 2, "text": "二年，吴楚反破後，以孝景前三年徙为鲁王。", "len": 20}
{"sid": "059_五宗世家.9.s3", "chapter": "059_五宗世家", "para": "9", "seq": 3, "text": "好治宫室苑囿狗马。", "len": 9}
{"sid": "059_五宗世家.9.s4", "chapter": "059_五宗世家", "para": "9", "seq": 4, "text": "季年好音，不喜辞辩。", "len": 10}
{"sid": "059_五宗世家.9.s5", "chapter": "059_五宗世家", "para": "9", "seq": 5, "text": "为人吃。", "len": 4}
{"sid": "059_五宗世家.10.s1", "chapter": "059_五宗世家", "para": "10", "seq": 1, "text": "二十六年卒，子光代为王。", "len": 12}
{"sid": "059_五宗世家.10.s2", "chapter": "059_五宗世家", "para": "10", "seq": 2, "text": "初好音舆马；晚节啬，惟恐不足於财。", "len": 17}
{"sid": "059_五宗世家.11.s1", "chapter": "059_五宗世家", "para": "11", "seq": 1, "text": "江都易王非，以孝景前二年用皇子为汝南王。", "len": 20}
{"sid": "059_五宗世家.11.s2", "chapter": "059_五宗世家", "para": "11", "seq": 2, "text": "吴楚反时，非年十五，有材力，上书原击吴。", "len": 20}
{"sid": "059_五宗世家.11.s3", "chapter": "059_五宗世家", "para": "11", "seq": 3, "text": "景帝赐非将军印，击吴。", "len": 11}
{"sid": "059_五宗世家.11.s4", "chapter": "059_五宗世家", "para": "11", "seq": 4, "text": "吴已破，二岁，徙为江都王，治吴故国，以军功赐天子旌旗。", "len": 27}
{"sid": "059_五宗世家.11.s5", "chapter": "059_五宗世家", "para": "11", "seq": 5, "text": "元光五年，匈奴大入汉为贼，非上书原击匈奴，上不许。", "len": 25}
{"sid": "059_五宗世家.11.s6", "chapter": "059_五宗世家", "para": "11", "seq": 6, "text": "非好气力，治宫观，招四方豪桀，骄奢甚。", "len": 19}
{"sid": "059_五宗世家.12.s1", "chapter": "059_五宗世家", "para": "12", "seq": 1, "text": "立二十六年卒，子建立为王。", "len": 13}
{"sid": "059_五宗世家.12.s2", "chapter": "059_五宗世家", "para": "12", "seq": 2, "text": "七年自杀。", "len": 5}
{"sid": "059_五宗世家.12.s3", "chapter": "059_五宗世家", "para": "12", "seq": 3, "text": "淮南、衡山谋反时，建颇闻其谋。", "len": 15}
{"sid": "059_五宗世家.12.s4", "chapter": "059_五宗世家", "para": "12", "seq": 4, "text": "自以为国近淮南，恐一日发，为所并，即阴作兵器，而时佩其父所赐将军印，载天子旗以出。", "len": 41}
{"sid": "059_五宗世家.12.s5", "chapter": "059_五宗世家", "para": "12", "seq": 5, "text": "易王死未葬，建有所说易王宠美人淖姬，夜使人迎与奸服舍中。", "len": 28}
{"sid": "059_五宗世家.12.s6", "chapter": "059_五宗世家", "para": "12", "seq": 6, "text": "及淮南事发，治党与颇及江都王建。", "len": 16}
{"sid": "059_五宗世家.12.s7", "chapter": "059_五宗世家", "para": "12", "seq": 7, "text": "建恐，因使人多持金钱，事绝其狱。", "len": 16}
{"sid": "059_五宗世家.12.s8", "chapter": "059_五宗世家", "para": "12", "seq": 8, "text": "而又信巫祝，使人祷祠妄言。", "len": 13}
{"sid": "059_五宗世家.12.s9", "chapter": "059_五宗世家", "para": "12", "seq": 9, "text": "建又尽与其姊弟奸。", "len": 9}
{"sid": "059_五宗世家.12.s10", "chapter": "059_五宗世家", "para": "12", "seq": 10, "text": "事既闻，汉公卿请捕治建。", "len": 12}
{"sid": "059_五宗世家.12.s11", "chapter": "059_五宗世家", "para": "12", "seq": 11, "text": "天子不忍，使大臣即讯王。", "len": 12}
{"sid": "059_五宗世家.12.s12", "chapter": "059_五宗世家", "para": "12", "seq": 12, "text": "王服所犯，遂自杀。", "len": 9}
{"sid": "059_五宗世家.12.s13", "chapter": "059_五宗世家", "para": "12", "seq": 13, "text": "国除，地入于汉，为广陵郡。", "len": 13}
{"sid": "059_五宗世家.13.s1", "chapter": "059_五宗世家", "para": "13", "seq": 1, "text": "胶西于王端，以孝景前三年吴楚七国反破後，端用皇子为胶西王。", "len": 29}
{"sid": "059_五宗世家.13.s2", "chapter": "059_五宗世家", "para": "13", "seq": 2, "text": "端为人贼戾，又阴痿，一近妇人，病之数月。", "len": 20}
{"sid": "059_五宗世家.13.s3", "chapter": "059_五宗世家", "para": "13", "seq": 3, "text": "而有爱幸少年为郎。", "len": 9}
{"sid": "059_五宗世家.13.s4", "chapter": "059_五宗世家", "para": "13", "seq": 4, "text": "为郎者顷之与後宫乱，端禽灭之，及杀其子母。", "len": 21}
{"sid": "059_五宗世家.13.s5", "chapter": "059_五宗世家", "para": "13", "seq": 5, "text": "数犯上法，汉公卿数请诛端，天子为兄弟之故不忍，而端所为滋甚。", "len": 30}
{"sid": "059_五宗世家.13.s6", "chapter": "059_五宗世家", "para": "13", "seq": 6, "text": "有司再请削其国，去太半。", "len": 12}
{"sid": "059_五宗世家.13.s7", "chapter": "059_五宗世家", "para": "13", "seq": 7, "text": "端心愠，遂为无訾省。", "len": 10}
{"sid": "059_五宗世家.13.s8", "chapter": "059_五宗世家", "para": "13", "seq": 8, "text": "府库坏漏尽，腐财物以巨万计，终不得收徙。", "len": 20}
{"sid": "059_五宗世家.13.s9", "chapter": "059_五宗世家", "para": "13", "seq": 9, "text": "令吏毋得收租赋。", "len": 8}
{"sid": "059_五宗世家.13.s10", "chapter": "059_五宗世家", "para": "13", "seq": 10, "text": "端皆去卫，封其宫门，从一门出游。", "len": 16}
{"sid": "059_五宗世家.13.s11", "chapter": "059_五宗世家", "para": "13", "seq": 11, "text": "数变名姓，为布衣，之他郡国。", "len": 14}
{"sid": "059_五宗世家.14.s1", "chapter": "059_五宗世家", "para": "14", "seq": 1, "text": "相、二千石往者，奉汉法以治，端辄求其罪告之，无罪者诈药杀之。", "len": 30}
{"sid": "059_五宗世家.14.s2", "chapter": "059_五宗世家", "para": "14", "seq": 2, "text": "所以设诈究变，彊足以距谏，智足以饰非。", "len": 19}
{"sid": "059_五宗世家.14.s3", "chapter": "059_五宗世家", "para": "14", "seq": 3, "text": "相、二千石从王治，则汉绳以法。", "len": 15}
{"sid": "059_五宗世家.14.s4", "chapter": "059_五宗世家", "para": "14", "seq": 4, "text": "故胶西小国，而所杀伤二千石甚众。", "len": 16}
{"sid": "059_五宗世家.15.s1", "chapter": "059_五宗世家", "para": "15", "seq": 1, "text": "立四十七年，卒，竟无男代後，国除，地入于汉，为胶西郡。", "len": 27}
{"sid": "059_五宗世家.16.s1", "chapter": "059_五宗世家", "para": "16", "seq": 1, "text": "右三国本王皆程姬之子也。", "len": 12}
{"sid": "059_五宗世家.17.s1", "chapter": "059_五宗世家", "para": "17", "seq": 1, "text": "赵王彭祖，以孝景前二年用皇子为广川王。", "len": 19}
{"sid": "059_五宗世家.17.s2", "chapter": "059_五宗世家", "para": "17", "seq": 2, "text": "赵王遂反破後，彭祖王广川。", "len": 13}
{"sid": "059_五宗世家.17.s3", "chapter": "059_五宗世家", "para": "17", "seq": 3, "text": "四年，徙为赵王。", "len": 8}
{"sid": "059_五宗世家.17.s4", "chapter": "059_五宗世家", "para": "17", "seq": 4, "text": "十五年，孝景帝崩。", "len": 9}
{"sid": "059_五宗世家.17.s5", "chapter": "059_五宗世家", "para": "17", "seq": 5, "text": "彭祖为人巧佞卑谄，足恭而心刻深。", "len": 16}
{"sid": "059_五宗世家.17.s6", "chapter": "059_五宗世家", "para": "17", "seq": 6, "text": "好法律，持诡辩以中人。", "len": 11}
{"sid": "059_五宗世家.17.s7", "chapter": "059_五宗世家", "para": "17", "seq": 7, "text": "彭祖多内宠姬及子孙。", "len": 10}
{"sid": "059_五宗世家.17.s8", "chapter": "059_五宗世家", "para": "17", "seq": 8, "text": "相、二千石欲奉汉法以治，则害於王家。", "len": 18}
{"sid": "059_五宗世家.17.s9", "chapter": "059_五宗世家", "para": "17", "seq": 9, "text": "是以每相、二千石至，彭祖衣皁布衣，自行迎，除二千石舍，多设疑事以作动之，得二千石失言，中忌讳，辄书之。", "len": 51}
{"sid": "059_五宗世家.17.s10", "chapter": "059_五宗世家", "para": "17", "seq": 10, "text": "二千石欲治者，则以此迫劫；不听，乃上书告，及汙以奸利事。", "len": 28}
{"sid": "059_五宗世家.17.s11", "chapter": "059_五宗世家", "para": "17", "seq": 11, "text": "彭祖立五十馀年，相、二千石无能满二岁，辄以罪去，大者死，小者刑，以故二千石莫敢治。", "len": 41}
{"sid": "059_五宗世家.17.s12", "chapter": "059_五宗世家", "para": "17", "seq": 12, "text": "而赵王擅权，使使即县为贾人榷会，入多於国经租税。", "len": 24}
{"sid": "059_五宗世家.17.s13", "chapter": "059_五宗世家", "para": "17", "seq": 13, "text": "以是赵王家多金钱，然所赐姬诸子，亦尽之矣。", "len": 21}
{"sid": "059_五宗世家.17.s14", "chapter": "059_五宗世家", "para": "17", "seq": 14, "text": "彭祖取故江都易王宠姬王建所盗与奸淖姬者为姬，甚爱之。", "len": 26}
{"sid": "059_五宗世家.18.s1", "chapter": "059_五宗世家", "para": "18", "seq": 1, "text": "彭祖不好治宫室、禨祥，好为吏事。", "len": 16}
{"sid": "059_五宗世家.18.s2", "chapter": "059_五宗世家", "para": "18", "seq": 2, "text": "上书原督国中盗贼。", "len": 9}
{"sid": "059_五宗世家.18.s3", "chapter": "059_五宗世家", "para": "18", "seq": 3, "text": "常夜从走卒行徼邯郸中。", "len": 11}
{"sid": "059_五宗世家.18.s4", "chapter": "059_五宗世家", "para": "18", "seq": 4, "text": "诸使过客以彭祖险陂，莫敢留邯郸。", "len": 16}
{"sid": "059_五宗世家.19.s1", "chapter": "059_五宗世家", "para": "19", "seq": 1, "text": "其太子丹与其女及同产姊奸，与其客江充有卻。", "len": 21}
{"sid": "059_五宗世家.19.s2", "chapter": "059_五宗世家", "para": "19", "seq": 2, "text": "充告丹，丹以故废。", "len": 9}
{"sid": "059_五宗世家.19.s3", "chapter": "059_五宗世家", "para": "19", "seq": 3, "text": "赵更立太子。", "len": 6}
{"sid": "059_五宗世家.20.s1", "chapter": "059_五宗世家", "para": "20", "seq": 1, "text": "中山靖王胜，以孝景前三年用皇子为中山王。", "len": 20}
{"sid": "059_五宗世家.20.s2", "chapter": "059_五宗世家", "para": "20", "seq": 2, "text": "十四年，孝景帝崩。", "len": 9}
{"sid": "059_五宗世家.20.s3", "chapter": "059_五宗世家", "para": "20", "seq": 3, "text": "胜为人乐酒好内，有子枝属百二十馀人。", "len": 18}
{"sid": "059_五宗世家.20.s4", "chapter": "059_五宗世家", "para": "20", "seq": 4, "text": "常与兄赵王相非，曰：“兄为王，专代吏治事。", "len": 21}
{"sid": "059_五宗世家.20.s5", "chapter": "059_五宗世家", "para": "20", "seq": 5, "text": "王者当日听音乐声色。", "len": 10}
{"sid": "059_五宗世家.20.s6", "chapter": "059_五宗世家", "para": "20", "seq": 6, "text": "” 赵王亦非之，曰：“中山王徒日淫，不佐天子拊循百姓，何以称为籓臣！”", "len": 35}
{"sid": "059_五宗世家.21.s1", "chapter": "059_五宗世家", "para": "21", "seq": 1, "text": "立四十二年卒，子哀王昌立。", "len": 13}
{"sid": "059_五宗世家.21.s2", "chapter": "059_五宗世家", "para": "21", "seq": 2, "text": "一年卒，子昆侈代为中山王。", "len": 13}
{"sid": "059_五宗世家.22.s1", "chapter": "059_五宗世家", "para": "22", "seq": 1, "text": "右二国本王皆贾夫人之子也。", "len": 13}
{"sid": "059_五宗世家.23.s1", "chapter": "059_五宗世家", "para": "23", "seq": 1, "text": "长沙定王发，发之母唐姬，故程姬侍者。", "len": 18}
{"sid": "059_五宗世家.23.s2", "chapter": "059_五宗世家", "para": "23", "seq": 2, "text": "景帝召程姬，程姬有所辟，不原进，而饰侍者唐兒使夜进。", "len": 26}
{"sid": "059_五宗世家.23.s3", "chapter": "059_五宗世家", "para": "23", "seq": 3, "text": "上醉不知，以为程姬而幸之，遂有身。", "len": 17}
{"sid": "059_五宗世家.23.s4", "chapter": "059_五宗世家", "para": "23", "seq": 4, "text": "已乃觉非程姬也。", "len": 8}
{"sid": "059_五宗世家.23.s5", "chapter": "059_五宗世家", "para": "23", "seq": 5, "text": "及生子，因命曰发。", "len": 9}
{"sid": "059_五宗世家.23.s6", "chapter": "059_五宗世家", "para": "23", "seq": 6, "text": "以孝景前二年用皇子为长沙王。", "len": 14}
{"sid": "059_五宗世家.23.s7", "chapter": "059_五宗世家", "para": "23", "seq": 7, "text": "以其母微，无宠，故王卑湿贫国。", "len": 15}
{"sid": "059_五宗世家.24.s1", "chapter": "059_五宗世家", "para": "24", "seq": 1, "text": "立二十七年卒，子康王庸立。", "len": 13}
{"sid": "059_五宗世家.24.s2", "chapter": "059_五宗世家", "para": "24", "seq": 2, "text": "二十八年，卒，子鲋鮈立为长沙王。", "len": 16}
{"sid": "059_五宗世家.25.s1", "chapter": "059_五宗世家", "para": "25", "seq": 1, "text": "右一国本王唐姬之子也。", "len": 11}
{"sid": "059_五宗世家.26.s1", "chapter": "059_五宗世家", "para": "26", "seq": 1, "text": "广川惠王越，以孝景中二年用皇子为广川王。", "len": 20}
{"sid": "059_五宗世家.27.s1", "chapter": "059_五宗世家", "para": "27", "seq": 1, "text": "十二年卒，子齐立为王。", "len": 11}
{"sid": "059_五宗世家.27.s2", "chapter": "059_五宗世家", "para": "27", "seq": 2, "text": "齐有幸臣桑距。", "len": 7}
{"sid": "059_五宗世家.27.s3", "chapter": "059_五宗世家", "para": "27", "seq": 3, "text": "已而有罪，欲诛距，距亡，王因禽其宗族。", "len": 19}
{"sid": "059_五宗世家.27.s4", "chapter": "059_五宗世家", "para": "27", "seq": 4, "text": "距怨王，乃上书告王齐与同产奸。", "len": 15}
{"sid": "059_五宗世家.27.s5", "chapter": "059_五宗世家", "para": "27", "seq": 5, "text": "自是之後，王齐数上书告言汉公卿及幸臣所忠等。", "len": 22}
{"sid": "059_五宗世家.28.s1", "chapter": "059_五宗世家", "para": "28", "seq": 1, "text": "胶东康王寄，以孝景中二年用皇子为胶东王。", "len": 20}
{"sid": "059_五宗世家.28.s2", "chapter": "059_五宗世家", "para": "28", "seq": 2, "text": "二十八年卒。", "len": 6}
{"sid": "059_五宗世家.28.s3", "chapter": "059_五宗世家", "para": "28", "seq": 3, "text": "淮南王谋反时，寄微闻其事，私作楼车镞矢战守备，候淮南之起。", "len": 29}
{"sid": "059_五宗世家.28.s4", "chapter": "059_五宗世家", "para": "28", "seq": 4, "text": "及吏治淮南之事，辞出之。", "len": 12}
{"sid": "059_五宗世家.28.s5", "chapter": "059_五宗世家", "para": "28", "seq": 5, "text": "寄於上最亲，意伤之，发病而死，不敢置後，於是上。", "len": 24}
{"sid": "059_五宗世家.28.s6", "chapter": "059_五宗世家", "para": "28", "seq": 6, "text": "寄有长子者名贤，母无宠；少子名庆，母爱幸，寄常欲立之，为不次，因有过，遂无言。", "len": 39}
{"sid": "059_五宗世家.28.s7", "chapter": "059_五宗世家", "para": "28", "seq": 7, "text": "上怜之，乃以贤为胶东王奉康王嗣，而封庆於故衡山地，为六安王。", "len": 30}
{"sid": "059_五宗世家.29.s1", "chapter": "059_五宗世家", "para": "29", "seq": 1, "text": "胶东王贤立十四年卒，谥为哀王。", "len": 15}
{"sid": "059_五宗世家.29.s2", "chapter": "059_五宗世家", "para": "29", "seq": 2, "text": "子庆为王。", "len": 5}
{"sid": "059_五宗世家.30.s1", "chapter": "059_五宗世家", "para": "30", "seq": 1, "text": "六安王庆，以元狩二年用胶东康王子为六安王。", "len": 21}
{"sid": "059_五宗世家.31.s1", "chapter": "059_五宗世家", "para": "31", "seq": 1, "text": "清河哀王乘，以孝景中三年用皇子为清河王。", "len": 20}
{"sid": "059_五宗世家.31.s2", "chapter": "059_五宗世家", "para": "31", "seq": 2, "text": "十二年卒，无後，国除，地入于汉，为清河郡。", "len": 21}
{"sid": "059_五宗世家.32.s1", "chapter": "059_五宗世家", "para": "32", "seq": 1, "text": "常山宪王舜，以孝景中五年用皇子为常山王。", "len": 20}
{"sid": "059_五宗世家.32.s2", "chapter": "059_五宗世家", "para": "32", "seq": 2, "text": "舜最亲，景帝少子，骄怠多淫，数犯禁，上常宽释之。", "len": 24}
{"sid": "059_五宗世家.32.s3", "chapter": "059_五宗世家", "para": "32", "seq": 3, "text": "立三十二年卒，太子勃代立为王。", "len": 15}
{"sid": "059_五宗世家.33.s1", "chapter": "059_五宗世家", "para": "33", "seq": 1, "text": "初，宪王舜有所不爱姬生长男棁。", "len": 15}
{"sid": "059_五宗世家.33.s2", "chapter": "059_五宗世家", "para": "33", "seq": 2, "text": "棁以母无宠故，亦不得幸於王。", "len": 14}
{"sid": "059_五宗世家.33.s3", "chapter": "059_五宗世家", "para": "33", "seq": 3, "text": "王后脩生太子勃。", "len": 8}
{"sid": "059_五宗世家.33.s4", "chapter": "059_五宗世家", "para": "33", "seq": 4, "text": "王内多，所幸姬生子平、子商，王后希得幸。", "len": 20}
{"sid": "059_五宗世家.33.s5", "chapter": "059_五宗世家", "para": "33", "seq": 5, "text": "及宪王病甚，诸幸姬常侍病，故王后亦以妒媢不常侍病，辄归舍。", "len": 29}
{"sid": "059_五宗世家.33.s6", "chapter": "059_五宗世家", "para": "33", "seq": 6, "text": "医进药，太子勃不自尝药，又不宿留侍病。", "len": 19}
{"sid": "059_五宗世家.33.s7", "chapter": "059_五宗世家", "para": "33", "seq": 7, "text": "及王薨，王后、太子乃至。", "len": 12}
{"sid": "059_五宗世家.33.s8", "chapter": "059_五宗世家", "para": "33", "seq": 8, "text": "宪王雅不以长子棁为人数，及薨，又不分与财物。", "len": 22}
{"sid": "059_五宗世家.33.s9", "chapter": "059_五宗世家", "para": "33", "seq": 9, "text": "郎或说太子、王后，令诸子与长子棁共分财物，太子、王后不听。", "len": 29}
{"sid": "059_五宗世家.33.s10", "chapter": "059_五宗世家", "para": "33", "seq": 10, "text": "太子代立，又不收恤棁。", "len": 11}
{"sid": "059_五宗世家.33.s11", "chapter": "059_五宗世家", "para": "33", "seq": 11, "text": "棁怨王后、太子。", "len": 8}
{"sid": "059_五宗世家.33.s12", "chapter": "059_五宗世家", "para": "33", "seq": 12, "text": "汉使者视宪王丧，棁自言宪王病时，王后、太子不侍，及薨，六日出舍，太子勃私奸，饮酒，博戏，击筑，与女子载驰，环城过市，入牢视囚。", "len": 63}
{"sid": "059_五宗世家.33.s13", "chapter": "059_五宗世家", "para": "33", "seq": 13, "text": "天子遣大行骞验王后及问王勃，请逮勃所与奸诸证左，王又匿之。", "len": 29}
{"sid": "059_五宗世家.33.s14", "chapter": "059_五宗世家", "para": "33", "seq": 14, "text": "吏求捕勃大急，使人致击笞掠，擅出汉所疑囚者。", "len": 22}
{"sid": "059_五宗世家.33.s15", "chapter": "059_五宗世家", "para": "33", "seq": 15, "text": "有司请诛宪王后脩及王勃。", "len": 12}
{"sid": "059_五宗世家.33.s16", "chapter": "059_五宗世家", "para": "33", "seq": 16, "text": "上以脩素无行，使棁陷之罪，勃无良师傅，不忍诛。", "len": 23}
{"sid": "059_五宗世家.33.s17", "chapter": "059_五宗世家", "para": "33", "seq": 17, "text": "有司请废王后脩，徙王勃以家属处房陵，上许之。", "len": 22}
{"sid": "059_五宗世家.34.s1", "chapter": "059_五宗世家", "para": "34", "seq": 1, "text": "勃王数月，迁于房陵，国绝。", "len": 13}
{"sid": "059_五宗世家.34.s2", "chapter": "059_五宗世家", "para": "34", "seq": 2, "text": "月馀，天子为最亲，乃诏有司曰：“常山宪王蚤夭，后妾不和，適孽诬争，陷于不义以灭国，朕甚闵焉。", "len": 46}
{"sid": "059_五宗世家.34.s3", "chapter": "059_五宗世家", "para": "34", "seq": 3, "text": "其封宪王子平三万户，为真定王；封子商三万户，为泗水王。”", "len": 28}
{"sid": "059_五宗世家.35.s1", "chapter": "059_五宗世家", "para": "35", "seq": 1, "text": "真定王平，元鼎四年用常山宪王子为真定王。", "len": 20}
{"sid": "059_五宗世家.36.s1", "chapter": "059_五宗世家", "para": "36", "seq": 1, "text": "泗水思王商，以元鼎四年用常山宪王子为泗水王。", "len": 22}
{"sid": "059_五宗世家.36.s2", "chapter": "059_五宗世家", "para": "36", "seq": 2, "text": "十一年卒，子哀王安世立。", "len": 12}
{"sid": "059_五宗世家.36.s3", "chapter": "059_五宗世家", "para": "36", "seq": 3, "text": "十一年卒，无子。", "len": 8}
{"sid": "059_五宗世家.36.s4", "chapter": "059_五宗世家", "para": "36", "seq": 4, "text": "於是上怜泗水王绝，乃立安世弟贺为泗水王。", "len": 20}
{"sid": "059_五宗世家.37.s1", "chapter": "059_五宗世家", "para": "37", "seq": 1, "text": "右四国本王皆王夫人兒姁子也。", "len": 14}
{"sid": "059_五宗世家.37.s2", "chapter": "059_五宗世家", "para": "37", "seq": 2, "text": "其後汉益封其支子为六安王、泗水王二国。", "len": 19}
{"sid": "059_五宗世家.37.s3", "chapter": "059_五宗世家", "para": "37", "seq": 3, "text": "凡兒姁子孙，於今为六王。", "len": 12}
{"sid": "059_五宗世家.37.s4", "chapter": "059_五宗世家", "para": "37", "seq": 4, "text": "::: 太史公曰", "len": 8}
{"sid": "059_五宗世家.38.s1", "chapter": "059_五宗世家", "para": "38", "seq": 1, "text": "太史公曰：高祖时诸侯皆赋，得自除内史以下，汉独为置丞相，黄金印。", "len": 32}
{"sid": "059_五宗世家.38.s2", "chapter": "059_五宗世家", "para": "38", "seq": 2, "text": "诸侯自除御史、廷尉正、博士，拟於天子。", "len": 19}
{"sid": "059_五宗世家.38.s3", "chapter": "059_五宗世家", "para": "38", "seq": 3, "text": "自吴楚反後，五宗王世，汉为置二千石，去“丞相” 曰“相”，银印。", "len": 32}
{"sid": "059_五宗世家.38.s4", "chapter": "059_五宗世家", "para": "38", "seq": 4, "text": "诸侯独得食租税，夺之权。", "len": 12}
{"sid": "059_五宗世家.38.s5", "chapter": "059_五宗世家", "para": "38", "seq": 5, "text": "其後诸侯贫者或乘牛车也。", "len": 12}
{"sid": "059_五宗世家.38.s6", "chapter": "059_五宗世家", "para": "38", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "059_五宗世家.39.s1", "chapter": "059_五宗世家", "para": "39", "seq": 1, "text": "景十三子，五宗亲睦。", "len": 10}
{"sid": "059_五宗世家.39.s2", "chapter": "059_五宗世家", "para": "39", "seq": 2, "text": "栗姬既废，临江折轴。", "len": 10}
{"sid": "059_五宗世家.39.s3", "chapter": "059_五宗世家", "para": "39", "seq": 3, "text": "阏于早薨，河间儒服。", "len": 10}
{"sid": "059_五宗世家.39.s4", "chapter": "059_五宗世家", "para": "39", "seq": 4, "text": "馀好宫苑，端事驰逐。", "len": 10}
{"sid": "059_五宗世家.39.s5", "chapter": "059_五宗世家", "para": "39", "seq": 5, "text": "江都有才，中山禔福。", "len": 10}
{"sid": "059_五宗世家.39.s6", "chapter": "059_五宗世家", "para": "39", "seq": 6, "text": "长沙地小，胶东造镞。", "len": 10}
{"sid": "059_五宗世家.39.s7", "chapter": "059_五宗世家", "para": "39", "seq": 7, "text": "仁贤者代，浡乱者族。", "len": 10}
{"sid": "059_五宗世家.39.s8", "chapter": "059_五宗世家", "para": "39", "seq": 8, "text": "兒姁四王，分封为六。", "len": 10}
{"sid": "059_五宗世家.39.s9", "chapter": "059_五宗世家", "para": "39", "seq": 9, "text": ":::", "len": 3}
