{"sid": "045_韩世家.1.s1", "chapter": "045_韩世家", "para": "1", "seq": 1, "text": "韩之先与周同姓，姓姬氏。", "len": 12}
{"sid": "045_韩世家.1.s2", "chapter": "045_韩世家", "para": "1", "seq": 2, "text": "其後苗裔事晋，得封於韩原，曰韩武子。", "len": 18}
{"sid": "045_韩世家.1.s3", "chapter": "045_韩世家", "para": "1", "seq": 3, "text": "武子後三世有韩厥，从封姓为韩氏。", "len": 16}
{"sid": "045_韩世家.2.s1", "chapter": "045_韩世家", "para": "2", "seq": 1, "text": "韩厥，晋景公之三年，晋司寇屠岸贾将作乱，诛灵公之贼赵盾。", "len": 28}
{"sid": "045_韩世家.2.s2", "chapter": "045_韩世家", "para": "2", "seq": 2, "text": "赵盾已死矣，欲诛其子赵朔。", "len": 13}
{"sid": "045_韩世家.2.s3", "chapter": "045_韩世家", "para": "2", "seq": 3, "text": "韩厥止贾，贾不听。", "len": 9}
{"sid": "045_韩世家.2.s4", "chapter": "045_韩世家", "para": "2", "seq": 4, "text": "厥告赵朔令亡。", "len": 7}
{"sid": "045_韩世家.2.s5", "chapter": "045_韩世家", "para": "2", "seq": 5, "text": "朔曰：“子必能不绝赵祀，死不恨矣。", "len": 17}
{"sid": "045_韩世家.2.s6", "chapter": "045_韩世家", "para": "2", "seq": 6, "text": "” 韩厥许之。", "len": 7}
{"sid": "045_韩世家.2.s7", "chapter": "045_韩世家", "para": "2", "seq": 7, "text": "及贾诛赵氏，厥称疾不出。", "len": 12}
{"sid": "045_韩世家.2.s8", "chapter": "045_韩世家", "para": "2", "seq": 8, "text": "程婴、公孙杵臼之藏赵孤赵武也，厥知之。", "len": 19}
{"sid": "045_韩世家.3.s1", "chapter": "045_韩世家", "para": "3", "seq": 1, "text": "景公十一年，厥与郤克将兵八百乘伐齐，败齐顷公于鞍，获逢丑父。", "len": 30}
{"sid": "045_韩世家.3.s2", "chapter": "045_韩世家", "para": "3", "seq": 2, "text": "於是晋作六卿，而韩厥在一卿之位，号为献子。", "len": 21}
{"sid": "045_韩世家.4.s1", "chapter": "045_韩世家", "para": "4", "seq": 1, "text": "晋景公十七年，病，卜大业之不遂者为祟。", "len": 19}
{"sid": "045_韩世家.4.s2", "chapter": "045_韩世家", "para": "4", "seq": 2, "text": "韩厥称赵成季之功，今後无祀，以感景公。", "len": 19}
{"sid": "045_韩世家.4.s3", "chapter": "045_韩世家", "para": "4", "seq": 3, "text": "景公问曰：“尚有世乎？", "len": 11}
{"sid": "045_韩世家.4.s4", "chapter": "045_韩世家", "para": "4", "seq": 4, "text": "” 厥於是言赵武，而复与故赵氏田邑，续赵氏祀。", "len": 23}
{"sid": "045_韩世家.5.s1", "chapter": "045_韩世家", "para": "5", "seq": 1, "text": "晋悼公之七年，韩献子老。", "len": 12}
{"sid": "045_韩世家.5.s2", "chapter": "045_韩世家", "para": "5", "seq": 2, "text": "献子卒，子宣子代。", "len": 9}
{"sid": "045_韩世家.5.s3", "chapter": "045_韩世家", "para": "5", "seq": 3, "text": "宣字徙居州。", "len": 6}
{"sid": "045_韩世家.6.s1", "chapter": "045_韩世家", "para": "6", "seq": 1, "text": "晋平公十四年，吴季札使晋，曰：“晋国之政卒归於韩、魏、赵矣。", "len": 30}
{"sid": "045_韩世家.6.s2", "chapter": "045_韩世家", "para": "6", "seq": 2, "text": "” 晋顷公十二年，韩宣子与赵、魏共分祁氏、羊舌氏十县。", "len": 27}
{"sid": "045_韩世家.6.s3", "chapter": "045_韩世家", "para": "6", "seq": 3, "text": "晋定公十五年，宣子与赵简子侵伐范、中行氏。", "len": 21}
{"sid": "045_韩世家.6.s4", "chapter": "045_韩世家", "para": "6", "seq": 4, "text": "宣子卒，子贞子代立。", "len": 10}
{"sid": "045_韩世家.6.s5", "chapter": "045_韩世家", "para": "6", "seq": 5, "text": "贞子徙居平阳。", "len": 7}
{"sid": "045_韩世家.7.s1", "chapter": "045_韩世家", "para": "7", "seq": 1, "text": "贞子卒，子简子代。", "len": 9}
{"sid": "045_韩世家.7.s2", "chapter": "045_韩世家", "para": "7", "seq": 2, "text": "简子卒，子庄子代。", "len": 9}
{"sid": "045_韩世家.7.s3", "chapter": "045_韩世家", "para": "7", "seq": 3, "text": "庄子卒，子康子代。", "len": 9}
{"sid": "045_韩世家.7.s4", "chapter": "045_韩世家", "para": "7", "seq": 4, "text": "康子与赵襄子、魏桓子共败知伯，分其地，地益大，大於诸侯。", "len": 28}
{"sid": "045_韩世家.8.s1", "chapter": "045_韩世家", "para": "8", "seq": 1, "text": "康子卒，子武子代。", "len": 9}
{"sid": "045_韩世家.8.s2", "chapter": "045_韩世家", "para": "8", "seq": 2, "text": "武子二年，伐郑，杀其君幽公。", "len": 14}
{"sid": "045_韩世家.8.s3", "chapter": "045_韩世家", "para": "8", "seq": 3, "text": "十六年，武子卒，子景侯立。", "len": 13}
{"sid": "045_韩世家.9.s1", "chapter": "045_韩世家", "para": "9", "seq": 1, "text": "景侯虔元年，伐郑，取雍丘。", "len": 13}
{"sid": "045_韩世家.9.s2", "chapter": "045_韩世家", "para": "9", "seq": 2, "text": "二年，郑败我负黍。", "len": 9}
{"sid": "045_韩世家.10.s1", "chapter": "045_韩世家", "para": "10", "seq": 1, "text": "六年，与赵、魏俱得列为诸侯。", "len": 14}
{"sid": "045_韩世家.11.s1", "chapter": "045_韩世家", "para": "11", "seq": 1, "text": "九年，郑围我阳翟。", "len": 9}
{"sid": "045_韩世家.11.s2", "chapter": "045_韩世家", "para": "11", "seq": 2, "text": "景侯卒，子列侯取立。", "len": 10}
{"sid": "045_韩世家.12.s1", "chapter": "045_韩世家", "para": "12", "seq": 1, "text": "列侯三年，聂政杀韩相侠累。", "len": 13}
{"sid": "045_韩世家.12.s2", "chapter": "045_韩世家", "para": "12", "seq": 2, "text": "九年，秦伐我宜阳，取六邑。", "len": 13}
{"sid": "045_韩世家.12.s3", "chapter": "045_韩世家", "para": "12", "seq": 3, "text": "十三年，列侯卒，子文侯立。", "len": 13}
{"sid": "045_韩世家.12.s4", "chapter": "045_韩世家", "para": "12", "seq": 4, "text": "是岁魏文侯卒。", "len": 7}
{"sid": "045_韩世家.13.s1", "chapter": "045_韩世家", "para": "13", "seq": 1, "text": "文侯二年，伐郑，取阳城。", "len": 12}
{"sid": "045_韩世家.13.s2", "chapter": "045_韩世家", "para": "13", "seq": 2, "text": "伐宋，到彭城，执宋君。", "len": 11}
{"sid": "045_韩世家.13.s3", "chapter": "045_韩世家", "para": "13", "seq": 3, "text": "七年，伐齐，至桑丘。", "len": 10}
{"sid": "045_韩世家.13.s4", "chapter": "045_韩世家", "para": "13", "seq": 4, "text": "郑反晋。", "len": 4}
{"sid": "045_韩世家.13.s5", "chapter": "045_韩世家", "para": "13", "seq": 5, "text": "九年，伐齐，至灵丘。", "len": 10}
{"sid": "045_韩世家.13.s6", "chapter": "045_韩世家", "para": "13", "seq": 6, "text": "十年，文侯卒，子哀侯立。", "len": 12}
{"sid": "045_韩世家.14.s1", "chapter": "045_韩世家", "para": "14", "seq": 1, "text": "哀侯元年，与赵、魏分晋国。", "len": 13}
{"sid": "045_韩世家.14.s2", "chapter": "045_韩世家", "para": "14", "seq": 2, "text": "二年，灭郑，因徙都郑。", "len": 11}
{"sid": "045_韩世家.15.s1", "chapter": "045_韩世家", "para": "15", "seq": 1, "text": "六年，韩严弑其君哀侯。", "len": 11}
{"sid": "045_韩世家.15.s2", "chapter": "045_韩世家", "para": "15", "seq": 2, "text": "而子懿侯立。", "len": 6}
{"sid": "045_韩世家.16.s1", "chapter": "045_韩世家", "para": "16", "seq": 1, "text": "懿侯二年，魏败我马陵。", "len": 11}
{"sid": "045_韩世家.16.s2", "chapter": "045_韩世家", "para": "16", "seq": 2, "text": "五年，与魏惠王会宅阳。", "len": 11}
{"sid": "045_韩世家.16.s3", "chapter": "045_韩世家", "para": "16", "seq": 3, "text": "九年，魏败我澮。", "len": 8}
{"sid": "045_韩世家.16.s4", "chapter": "045_韩世家", "para": "16", "seq": 4, "text": "十二年，懿侯卒，子昭侯立。", "len": 13}
{"sid": "045_韩世家.17.s1", "chapter": "045_韩世家", "para": "17", "seq": 1, "text": "昭侯元年，秦败我西山。", "len": 11}
{"sid": "045_韩世家.17.s2", "chapter": "045_韩世家", "para": "17", "seq": 2, "text": "二年，宋取我黄池。", "len": 9}
{"sid": "045_韩世家.17.s3", "chapter": "045_韩世家", "para": "17", "seq": 3, "text": "魏取硃。", "len": 4}
{"sid": "045_韩世家.17.s4", "chapter": "045_韩世家", "para": "17", "seq": 4, "text": "六年，伐东周，取陵观、邢丘。", "len": 14}
{"sid": "045_韩世家.18.s1", "chapter": "045_韩世家", "para": "18", "seq": 1, "text": "八年，申不害相韩，脩术行道，国内以治，诸侯不来侵伐。", "len": 26}
{"sid": "045_韩世家.19.s1", "chapter": "045_韩世家", "para": "19", "seq": 1, "text": "十年，韩姬弑其君悼公。", "len": 11}
{"sid": "045_韩世家.19.s2", "chapter": "045_韩世家", "para": "19", "seq": 2, "text": "十一年，昭侯如秦。", "len": 9}
{"sid": "045_韩世家.19.s3", "chapter": "045_韩世家", "para": "19", "seq": 3, "text": "二十二年，申不害死。", "len": 10}
{"sid": "045_韩世家.19.s4", "chapter": "045_韩世家", "para": "19", "seq": 4, "text": "二十四年，秦来拔我宜阳。", "len": 12}
{"sid": "045_韩世家.20.s1", "chapter": "045_韩世家", "para": "20", "seq": 1, "text": "二十五年，旱，作高门。", "len": 11}
{"sid": "045_韩世家.20.s2", "chapter": "045_韩世家", "para": "20", "seq": 2, "text": "屈宜臼曰：“昭侯不出此门。", "len": 13}
{"sid": "045_韩世家.20.s3", "chapter": "045_韩世家", "para": "20", "seq": 3, "text": "何也？", "len": 3}
{"sid": "045_韩世家.20.s4", "chapter": "045_韩世家", "para": "20", "seq": 4, "text": "不时。", "len": 3}
{"sid": "045_韩世家.20.s5", "chapter": "045_韩世家", "para": "20", "seq": 5, "text": "吾所谓时者，非时日也，人固有利不利时。", "len": 19}
{"sid": "045_韩世家.20.s6", "chapter": "045_韩世家", "para": "20", "seq": 6, "text": "昭侯尝利矣，不作高门。", "len": 11}
{"sid": "045_韩世家.20.s7", "chapter": "045_韩世家", "para": "20", "seq": 7, "text": "往年秦拔宜阳，今年旱，昭侯不以此时恤民之急，而顾益奢，此谓’时绌举赢’。", "len": 36}
{"sid": "045_韩世家.20.s8", "chapter": "045_韩世家", "para": "20", "seq": 8, "text": "” 二十六年，高门成，昭侯卒，果不出此门。", "len": 21}
{"sid": "045_韩世家.20.s9", "chapter": "045_韩世家", "para": "20", "seq": 9, "text": "子宣惠王立。", "len": 6}
{"sid": "045_韩世家.21.s1", "chapter": "045_韩世家", "para": "21", "seq": 1, "text": "宣惠王五年，张仪相秦。", "len": 11}
{"sid": "045_韩世家.21.s2", "chapter": "045_韩世家", "para": "21", "seq": 2, "text": "八年，魏败我将韩举。", "len": 10}
{"sid": "045_韩世家.21.s3", "chapter": "045_韩世家", "para": "21", "seq": 3, "text": "十一年，君号为王。", "len": 9}
{"sid": "045_韩世家.21.s4", "chapter": "045_韩世家", "para": "21", "seq": 4, "text": "与赵会区鼠。", "len": 6}
{"sid": "045_韩世家.21.s5", "chapter": "045_韩世家", "para": "21", "seq": 5, "text": "十四年，秦伐败我鄢。", "len": 10}
{"sid": "045_韩世家.22.s1", "chapter": "045_韩世家", "para": "22", "seq": 1, "text": "十六年，秦败我脩鱼，虏得韩将宧、申差於浊泽。", "len": 22}
{"sid": "045_韩世家.22.s2", "chapter": "045_韩世家", "para": "22", "seq": 2, "text": "韩氏急，公仲谓韩王曰：“与国非可恃也。", "len": 19}
{"sid": "045_韩世家.22.s3", "chapter": "045_韩世家", "para": "22", "seq": 3, "text": "今秦之欲伐楚久矣，王不如因张仪为和於秦，赂以一名都，具甲，与之南伐楚，此以一易二之计也。", "len": 44}
{"sid": "045_韩世家.22.s4", "chapter": "045_韩世家", "para": "22", "seq": 4, "text": "” 韩王曰：“善。", "len": 9}
{"sid": "045_韩世家.22.s5", "chapter": "045_韩世家", "para": "22", "seq": 5, "text": "” 乃警公仲之行，将西购於秦。", "len": 15}
{"sid": "045_韩世家.22.s6", "chapter": "045_韩世家", "para": "22", "seq": 6, "text": "楚王闻之大恐，召陈轸告之。", "len": 13}
{"sid": "045_韩世家.22.s7", "chapter": "045_韩世家", "para": "22", "seq": 7, "text": "陈轸曰：“秦之欲伐楚久矣，今又得韩之名都一而具甲，秦韩并兵而伐楚，此秦所祷祀而求也。", "len": 42}
{"sid": "045_韩世家.22.s8", "chapter": "045_韩世家", "para": "22", "seq": 8, "text": "今已得之矣，楚国必伐矣。", "len": 12}
{"sid": "045_韩世家.22.s9", "chapter": "045_韩世家", "para": "22", "seq": 9, "text": "王听臣为之警四境之内，起师言救韩，命战车满道路，发信臣，多其车，重其币，使信王之救己也。", "len": 44}
{"sid": "045_韩世家.22.s10", "chapter": "045_韩世家", "para": "22", "seq": 10, "text": "纵韩不能听我，韩必德王也，必不为雁行以来，是秦韩不和也，兵虽至，楚不大病也。", "len": 38}
{"sid": "045_韩世家.22.s11", "chapter": "045_韩世家", "para": "22", "seq": 11, "text": "为能听我绝和於秦，秦必大怒，以厚怨韩。", "len": 19}
{"sid": "045_韩世家.22.s12", "chapter": "045_韩世家", "para": "22", "seq": 12, "text": "韩之南交楚，必轻秦；轻秦，其应秦必不敬：是因秦、韩之兵而免楚国之患也。", "len": 35}
{"sid": "045_韩世家.22.s13", "chapter": "045_韩世家", "para": "22", "seq": 13, "text": "” 楚王曰：“善。", "len": 9}
{"sid": "045_韩世家.22.s14", "chapter": "045_韩世家", "para": "22", "seq": 14, "text": "” 乃警四境之内，兴师言救韩。", "len": 15}
{"sid": "045_韩世家.22.s15", "chapter": "045_韩世家", "para": "22", "seq": 15, "text": "命战车满道路，发信臣，多其车，重其币。", "len": 19}
{"sid": "045_韩世家.22.s16", "chapter": "045_韩世家", "para": "22", "seq": 16, "text": "谓韩王曰：”不穀国虽小，已悉发之矣。", "len": 18}
{"sid": "045_韩世家.22.s17", "chapter": "045_韩世家", "para": "22", "seq": 17, "text": "原大国遂肆志於秦，不穀将以楚殉韩。", "len": 17}
{"sid": "045_韩世家.22.s18", "chapter": "045_韩世家", "para": "22", "seq": 18, "text": "” 韩王闻之大说，乃止公仲之行。", "len": 16}
{"sid": "045_韩世家.22.s19", "chapter": "045_韩世家", "para": "22", "seq": 19, "text": "公仲曰：“不可。", "len": 8}
{"sid": "045_韩世家.22.s20", "chapter": "045_韩世家", "para": "22", "seq": 20, "text": "夫以实伐我者秦也，以虚名救我者楚也。", "len": 18}
{"sid": "045_韩世家.22.s21", "chapter": "045_韩世家", "para": "22", "seq": 21, "text": "王恃楚之虚名，而轻绝彊秦之敌，王必为天下大笑。", "len": 23}
{"sid": "045_韩世家.22.s22", "chapter": "045_韩世家", "para": "22", "seq": 22, "text": "且楚韩非兄弟之国也，又非素约而谋伐秦也。", "len": 20}
{"sid": "045_韩世家.22.s23", "chapter": "045_韩世家", "para": "22", "seq": 23, "text": "已有伐形，因发兵言救韩，此必陈轸之谋也。", "len": 20}
{"sid": "045_韩世家.22.s24", "chapter": "045_韩世家", "para": "22", "seq": 24, "text": "且王已使人报於秦矣，今不行，是欺秦也。", "len": 19}
{"sid": "045_韩世家.22.s25", "chapter": "045_韩世家", "para": "22", "seq": 25, "text": "夫轻欺彊秦而信楚之谋臣，恐王必悔之。", "len": 18}
{"sid": "045_韩世家.22.s26", "chapter": "045_韩世家", "para": "22", "seq": 26, "text": "” 韩王不听，遂绝於秦。", "len": 12}
{"sid": "045_韩世家.22.s27", "chapter": "045_韩世家", "para": "22", "seq": 27, "text": "秦因大怒，益甲伐韩，大战，楚救不至韩。", "len": 19}
{"sid": "045_韩世家.22.s28", "chapter": "045_韩世家", "para": "22", "seq": 28, "text": "十九年，大破我岸门。", "len": 10}
{"sid": "045_韩世家.22.s29", "chapter": "045_韩世家", "para": "22", "seq": 29, "text": "太子仓质於秦以和。", "len": 9}
{"sid": "045_韩世家.23.s1", "chapter": "045_韩世家", "para": "23", "seq": 1, "text": "二十一年，与秦共攻楚，败楚将屈丐，斩首八万於丹阳。", "len": 25}
{"sid": "045_韩世家.23.s2", "chapter": "045_韩世家", "para": "23", "seq": 2, "text": "” 是岁，宣惠王卒，太子仓立，是为襄王。", "len": 20}
{"sid": "045_韩世家.24.s1", "chapter": "045_韩世家", "para": "24", "seq": 1, "text": "襄王四年，与秦武王会临晋。", "len": 13}
{"sid": "045_韩世家.24.s2", "chapter": "045_韩世家", "para": "24", "seq": 2, "text": "其秋，秦使甘茂攻我宜阳。", "len": 12}
{"sid": "045_韩世家.24.s3", "chapter": "045_韩世家", "para": "24", "seq": 3, "text": "五年，秦拔我宜阳，斩首六万。", "len": 14}
{"sid": "045_韩世家.24.s4", "chapter": "045_韩世家", "para": "24", "seq": 4, "text": "秦武王卒。", "len": 5}
{"sid": "045_韩世家.24.s5", "chapter": "045_韩世家", "para": "24", "seq": 5, "text": "六年，秦复与我武遂。", "len": 10}
{"sid": "045_韩世家.24.s6", "chapter": "045_韩世家", "para": "24", "seq": 6, "text": "九年，秦复取我武遂。", "len": 10}
{"sid": "045_韩世家.24.s7", "chapter": "045_韩世家", "para": "24", "seq": 7, "text": "十年，太子婴朝秦而归。", "len": 11}
{"sid": "045_韩世家.24.s8", "chapter": "045_韩世家", "para": "24", "seq": 8, "text": "十一年，秦伐我，取穰。", "len": 11}
{"sid": "045_韩世家.24.s9", "chapter": "045_韩世家", "para": "24", "seq": 9, "text": "与秦伐楚，败楚将唐眛。", "len": 11}
{"sid": "045_韩世家.25.s1", "chapter": "045_韩世家", "para": "25", "seq": 1, "text": "十二年，太子婴死。", "len": 9}
{"sid": "045_韩世家.25.s2", "chapter": "045_韩世家", "para": "25", "seq": 2, "text": "公子咎、公子虮虱争为太子。", "len": 13}
{"sid": "045_韩世家.25.s3", "chapter": "045_韩世家", "para": "25", "seq": 3, "text": "时虮虱质於楚。", "len": 7}
{"sid": "045_韩世家.25.s4", "chapter": "045_韩世家", "para": "25", "seq": 4, "text": "苏代谓韩咎曰：“虮虱亡在楚，楚王欲内之甚。", "len": 21}
{"sid": "045_韩世家.25.s5", "chapter": "045_韩世家", "para": "25", "seq": 5, "text": "今楚兵十馀万在方城之外，公何不令楚王筑万室之都雍氏之旁，韩必起兵以救之，公必将矣。", "len": 41}
{"sid": "045_韩世家.25.s6", "chapter": "045_韩世家", "para": "25", "seq": 6, "text": "公因以韩楚之兵奉虮虱而内之，其听公必矣，必以楚韩封公也。", "len": 28}
{"sid": "045_韩世家.25.s7", "chapter": "045_韩世家", "para": "25", "seq": 7, "text": "” 韩咎从其计。", "len": 8}
{"sid": "045_韩世家.26.s1", "chapter": "045_韩世家", "para": "26", "seq": 1, "text": "楚围雍氏，韩求救於秦。", "len": 11}
{"sid": "045_韩世家.26.s2", "chapter": "045_韩世家", "para": "26", "seq": 2, "text": "秦未为发，使公孙昧入韩。", "len": 12}
{"sid": "045_韩世家.26.s3", "chapter": "045_韩世家", "para": "26", "seq": 3, "text": "公仲曰：“子以秦为且救韩乎？", "len": 14}
{"sid": "045_韩世家.26.s4", "chapter": "045_韩世家", "para": "26", "seq": 4, "text": "” 对曰：“秦王之言曰’请道南郑、蓝田，出兵於楚以待公’，殆不合矣。", "len": 34}
{"sid": "045_韩世家.26.s5", "chapter": "045_韩世家", "para": "26", "seq": 5, "text": "” 公仲曰：“子以为果乎？", "len": 13}
{"sid": "045_韩世家.26.s6", "chapter": "045_韩世家", "para": "26", "seq": 6, "text": "” 对曰：“秦王必祖张仪之故智。", "len": 16}
{"sid": "045_韩世家.26.s7", "chapter": "045_韩世家", "para": "26", "seq": 7, "text": "” 楚威王攻梁也，张仪谓秦王曰：‘与楚攻魏，魏折而入於楚，韩固其与国也，是秦孤也。", "len": 41}
{"sid": "045_韩世家.26.s8", "chapter": "045_韩世家", "para": "26", "seq": 8, "text": "不如出兵以到之，魏楚大战，秦取西河之外以归。", "len": 22}
{"sid": "045_韩世家.26.s9", "chapter": "045_韩世家", "para": "26", "seq": 9, "text": "‘今其状阳言与韩，其实阴善楚。", "len": 15}
{"sid": "045_韩世家.26.s10", "chapter": "045_韩世家", "para": "26", "seq": 10, "text": "公待秦而到，必轻与楚战。", "len": 12}
{"sid": "045_韩世家.26.s11", "chapter": "045_韩世家", "para": "26", "seq": 11, "text": "楚阴得秦之不用也，必易与公相支也。", "len": 17}
{"sid": "045_韩世家.26.s12", "chapter": "045_韩世家", "para": "26", "seq": 12, "text": "公战而胜楚，遂与公乘楚，施三川而归。", "len": 18}
{"sid": "045_韩世家.26.s13", "chapter": "045_韩世家", "para": "26", "seq": 13, "text": "公战不胜楚，楚塞三川守之，公不能救也。", "len": 19}
{"sid": "045_韩世家.26.s14", "chapter": "045_韩世家", "para": "26", "seq": 14, "text": "窃为公患之。", "len": 6}
{"sid": "045_韩世家.26.s15", "chapter": "045_韩世家", "para": "26", "seq": 15, "text": "司马庚三反於郢，甘茂与昭鱼遇於商於，其言收玺，实类有约也。", "len": 29}
{"sid": "045_韩世家.26.s16", "chapter": "045_韩世家", "para": "26", "seq": 16, "text": "“公仲恐，曰：“然则柰何？", "len": 13}
{"sid": "045_韩世家.26.s17", "chapter": "045_韩世家", "para": "26", "seq": 17, "text": "“曰：“公必先韩而後秦，先身而後张仪。", "len": 19}
{"sid": "045_韩世家.26.s18", "chapter": "045_韩世家", "para": "26", "seq": 18, "text": "公不如亟以国合於齐楚，齐楚必委国於公。", "len": 19}
{"sid": "045_韩世家.26.s19", "chapter": "045_韩世家", "para": "26", "seq": 19, "text": "公之所恶者张仪也，其实犹不无秦也。", "len": 17}
{"sid": "045_韩世家.26.s20", "chapter": "045_韩世家", "para": "26", "seq": 20, "text": "“於是楚解雍氏围。", "len": 9}
{"sid": "045_韩世家.27.s1", "chapter": "045_韩世家", "para": "27", "seq": 1, "text": "苏代又谓秦太后弟琇戎曰：“公叔伯婴恐秦楚之内虮虱也，公何不为韩求质子於楚？", "len": 37}
{"sid": "045_韩世家.27.s2", "chapter": "045_韩世家", "para": "27", "seq": 2, "text": "楚王听入质子於韩，则公叔伯婴知秦楚之不以虮虱为事，必以韩合於秦楚。", "len": 33}
{"sid": "045_韩世家.27.s3", "chapter": "045_韩世家", "para": "27", "seq": 3, "text": "秦楚挟韩以窘魏，魏氏不敢合於齐，是齐孤也。", "len": 21}
{"sid": "045_韩世家.27.s4", "chapter": "045_韩世家", "para": "27", "seq": 4, "text": "公又为秦求质子於楚，楚不听，怨结於韩。", "len": 19}
{"sid": "045_韩世家.27.s5", "chapter": "045_韩世家", "para": "27", "seq": 5, "text": "韩挟齐魏以围楚，楚必重公。", "len": 13}
{"sid": "045_韩世家.27.s6", "chapter": "045_韩世家", "para": "27", "seq": 6, "text": "公挟秦楚之重以积德於韩，公叔伯婴必以国待公。", "len": 22}
{"sid": "045_韩世家.27.s7", "chapter": "045_韩世家", "para": "27", "seq": 7, "text": "” 於是虮虱竟不得归韩。", "len": 12}
{"sid": "045_韩世家.27.s8", "chapter": "045_韩世家", "para": "27", "seq": 8, "text": "韩立咎为太子。", "len": 7}
{"sid": "045_韩世家.27.s9", "chapter": "045_韩世家", "para": "27", "seq": 9, "text": "齐、魏王来。", "len": 6}
{"sid": "045_韩世家.28.s1", "chapter": "045_韩世家", "para": "28", "seq": 1, "text": "十四年，与齐、魏王共击秦，至函谷而军焉。", "len": 20}
{"sid": "045_韩世家.28.s2", "chapter": "045_韩世家", "para": "28", "seq": 2, "text": "十六年，秦与我河外及武遂。", "len": 13}
{"sid": "045_韩世家.28.s3", "chapter": "045_韩世家", "para": "28", "seq": 3, "text": "襄王卒，太子咎立，是为釐王。", "len": 14}
{"sid": "045_韩世家.29.s1", "chapter": "045_韩世家", "para": "29", "seq": 1, "text": "釐王三年，使公孙喜率周、魏攻秦。", "len": 16}
{"sid": "045_韩世家.29.s2", "chapter": "045_韩世家", "para": "29", "seq": 2, "text": "秦败我二十四万，虏喜伊阙。", "len": 13}
{"sid": "045_韩世家.29.s3", "chapter": "045_韩世家", "para": "29", "seq": 3, "text": "五年，秦拔我宛。", "len": 8}
{"sid": "045_韩世家.29.s4", "chapter": "045_韩世家", "para": "29", "seq": 4, "text": "六年，与秦武遂地二百里。", "len": 12}
{"sid": "045_韩世家.29.s5", "chapter": "045_韩世家", "para": "29", "seq": 5, "text": "十年，秦败我师于夏山。", "len": 11}
{"sid": "045_韩世家.29.s6", "chapter": "045_韩世家", "para": "29", "seq": 6, "text": "十二年，与秦昭王会西周而佐秦攻齐。", "len": 17}
{"sid": "045_韩世家.29.s7", "chapter": "045_韩世家", "para": "29", "seq": 7, "text": "齐败，湣王出亡。", "len": 8}
{"sid": "045_韩世家.29.s8", "chapter": "045_韩世家", "para": "29", "seq": 8, "text": "十四年，与秦会两周间。", "len": 11}
{"sid": "045_韩世家.29.s9", "chapter": "045_韩世家", "para": "29", "seq": 9, "text": "二十一年，使暴烝救魏，为秦所败，烝走开封。", "len": 21}
{"sid": "045_韩世家.30.s1", "chapter": "045_韩世家", "para": "30", "seq": 1, "text": "二十三年，赵、魏攻我华阳。", "len": 13}
{"sid": "045_韩世家.30.s2", "chapter": "045_韩世家", "para": "30", "seq": 2, "text": "韩告急於秦，秦不救。", "len": 10}
{"sid": "045_韩世家.30.s3", "chapter": "045_韩世家", "para": "30", "seq": 3, "text": "韩相国谓陈筮曰：“事急，原公虽病，为一宿之行。", "len": 23}
{"sid": "045_韩世家.30.s4", "chapter": "045_韩世家", "para": "30", "seq": 4, "text": "” 陈筮见穰侯。", "len": 8}
{"sid": "045_韩世家.30.s5", "chapter": "045_韩世家", "para": "30", "seq": 5, "text": "穰侯曰：“事急乎？", "len": 9}
{"sid": "045_韩世家.30.s6", "chapter": "045_韩世家", "para": "30", "seq": 6, "text": "故使公来。", "len": 5}
{"sid": "045_韩世家.30.s7", "chapter": "045_韩世家", "para": "30", "seq": 7, "text": "” 陈筮曰：“未急也。", "len": 11}
{"sid": "045_韩世家.30.s8", "chapter": "045_韩世家", "para": "30", "seq": 8, "text": "” 穰侯怒曰：“是可以为公之主使乎？", "len": 18}
{"sid": "045_韩世家.30.s9", "chapter": "045_韩世家", "para": "30", "seq": 9, "text": "夫冠盖相望，告敝邑甚急，公来言未急，何也？", "len": 21}
{"sid": "045_韩世家.30.s10", "chapter": "045_韩世家", "para": "30", "seq": 10, "text": "” 陈筮曰：“彼韩急则将变而佗从，以未急，故复来耳。", "len": 26}
{"sid": "045_韩世家.30.s11", "chapter": "045_韩世家", "para": "30", "seq": 11, "text": "” 穰侯曰：“公无见王，请今发兵救韩。", "len": 19}
{"sid": "045_韩世家.30.s12", "chapter": "045_韩世家", "para": "30", "seq": 12, "text": "” 八日而至，败赵、魏於华阳之下。", "len": 17}
{"sid": "045_韩世家.30.s13", "chapter": "045_韩世家", "para": "30", "seq": 13, "text": "是岁，釐王卒，子桓惠王立。", "len": 13}
{"sid": "045_韩世家.31.s1", "chapter": "045_韩世家", "para": "31", "seq": 1, "text": "桓惠王元年，伐燕。", "len": 9}
{"sid": "045_韩世家.31.s2", "chapter": "045_韩世家", "para": "31", "seq": 2, "text": "九年，秦拔我陉，城汾旁。", "len": 12}
{"sid": "045_韩世家.31.s3", "chapter": "045_韩世家", "para": "31", "seq": 3, "text": "十年，秦击我於太行，我上党郡守以上党郡降赵。", "len": 22}
{"sid": "045_韩世家.31.s4", "chapter": "045_韩世家", "para": "31", "seq": 4, "text": "十四年，秦拔赵上党，杀马服子卒四十馀万於长平。", "len": 23}
{"sid": "045_韩世家.31.s5", "chapter": "045_韩世家", "para": "31", "seq": 5, "text": "十七年，秦拔我阳城、负黍。", "len": 13}
{"sid": "045_韩世家.31.s6", "chapter": "045_韩世家", "para": "31", "seq": 6, "text": "二十二年，秦昭王卒。", "len": 10}
{"sid": "045_韩世家.31.s7", "chapter": "045_韩世家", "para": "31", "seq": 7, "text": "二十四年，秦拔我城皋、荥阳。", "len": 14}
{"sid": "045_韩世家.31.s8", "chapter": "045_韩世家", "para": "31", "seq": 8, "text": "二十六年，秦悉拔我上党。", "len": 12}
{"sid": "045_韩世家.31.s9", "chapter": "045_韩世家", "para": "31", "seq": 9, "text": "二十九年，秦拔我十三城。", "len": 12}
{"sid": "045_韩世家.32.s1", "chapter": "045_韩世家", "para": "32", "seq": 1, "text": "三十四年，桓惠王卒，子王安立。", "len": 15}
{"sid": "045_韩世家.33.s1", "chapter": "045_韩世家", "para": "33", "seq": 1, "text": "王安五年，秦攻韩，韩急，使韩非使秦，秦留非，因杀之。", "len": 26}
{"sid": "045_韩世家.34.s1", "chapter": "045_韩世家", "para": "34", "seq": 1, "text": "九年，秦虏王安，尽入其地，为颍州郡。", "len": 18}
{"sid": "045_韩世家.34.s2", "chapter": "045_韩世家", "para": "34", "seq": 2, "text": "韩遂亡。", "len": 4}
{"sid": "045_韩世家.35.s1", "chapter": "045_韩世家", "para": "35", "seq": 1, "text": "太史公曰：韩厥之感晋景公，绍赵孤之子武，以成程婴、公孙杵臼之义，此天下之阴德也。", "len": 40}
{"sid": "045_韩世家.35.s2", "chapter": "045_韩世家", "para": "35", "seq": 2, "text": "韩氏之功，於晋未睹其大者也。", "len": 14}
{"sid": "045_韩世家.35.s3", "chapter": "045_韩世家", "para": "35", "seq": 3, "text": "然与赵、魏终为诸侯十馀世，宜乎哉！", "len": 17}
{"sid": "045_韩世家.35.s4", "chapter": "045_韩世家", "para": "35", "seq": 4, "text": "::: 赞", "len": 5}
{"sid": "045_韩世家.36.s1", "chapter": "045_韩世家", "para": "36", "seq": 1, "text": "韩氏之先，实宗周武。", "len": 10}
{"sid": "045_韩世家.36.s2", "chapter": "045_韩世家", "para": "36", "seq": 2, "text": "事微国小，春秋无语。", "len": 10}
{"sid": "045_韩世家.36.s3", "chapter": "045_韩世家", "para": "36", "seq": 3, "text": "後裔事晋，韩原是处。", "len": 10}
{"sid": "045_韩世家.36.s4", "chapter": "045_韩世家", "para": "36", "seq": 4, "text": "赵孤克立，智伯可取。", "len": 10}
{"sid": "045_韩世家.36.s5", "chapter": "045_韩世家", "para": "36", "seq": 5, "text": "既徙平阳，又侵负黍。", "len": 10}
{"sid": "045_韩世家.36.s6", "chapter": "045_韩世家", "para": "36", "seq": 6, "text": "景赵俱侯，惠又僭主。", "len": 10}
{"sid": "045_韩世家.36.s7", "chapter": "045_韩世家", "para": "36", "seq": 7, "text": "秦败脩鱼，魏会区鼠。", "len": 10}
{"sid": "045_韩世家.36.s8", "chapter": "045_韩世家", "para": "36", "seq": 8, "text": "韩非虽使，不禁狼虎。", "len": 10}
{"sid": "045_韩世家.36.s9", "chapter": "045_韩世家", "para": "36", "seq": 9, "text": ":::", "len": 3}
