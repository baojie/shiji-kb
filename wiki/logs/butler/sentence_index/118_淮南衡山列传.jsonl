{"sid": "118_淮南衡山列传.0.s1", "chapter": "118_淮南衡山列传", "para": "0", "seq": 1, "text": "淮南厉王长者，高祖少子也，其母故赵王张敖美人。", "len": 23}
{"sid": "118_淮南衡山列传.0.s2", "chapter": "118_淮南衡山列传", "para": "0", "seq": 2, "text": "高祖八年，从东垣过赵，赵王献之美人。", "len": 18}
{"sid": "118_淮南衡山列传.0.s3", "chapter": "118_淮南衡山列传", "para": "0", "seq": 3, "text": "厉王母得幸焉，有身。", "len": 10}
{"sid": "118_淮南衡山列传.0.s4", "chapter": "118_淮南衡山列传", "para": "0", "seq": 4, "text": "赵王敖弗敢内宫，为筑外宫而舍之。", "len": 16}
{"sid": "118_淮南衡山列传.0.s5", "chapter": "118_淮南衡山列传", "para": "0", "seq": 5, "text": "及贯高等谋反柏人事发觉，并逮治王，尽收捕王母兄弟美人，系之河内。", "len": 32}
{"sid": "118_淮南衡山列传.0.s6", "chapter": "118_淮南衡山列传", "para": "0", "seq": 6, "text": "厉王母亦系，告吏曰：“得幸上，有身。", "len": 18}
{"sid": "118_淮南衡山列传.0.s7", "chapter": "118_淮南衡山列传", "para": "0", "seq": 7, "text": "” 吏以闻上，上方怒赵王，未理厉王母。", "len": 19}
{"sid": "118_淮南衡山列传.0.s8", "chapter": "118_淮南衡山列传", "para": "0", "seq": 8, "text": "厉王母弟赵兼因辟阳侯言吕后，吕后妒，弗肯白，辟阳侯不彊争。", "len": 29}
{"sid": "118_淮南衡山列传.0.s9", "chapter": "118_淮南衡山列传", "para": "0", "seq": 9, "text": "及厉王母已生厉王，恚，即自杀。", "len": 15}
{"sid": "118_淮南衡山列传.0.s10", "chapter": "118_淮南衡山列传", "para": "0", "seq": 10, "text": "吏奉厉王诣上，上悔，令吕后母之，而葬厉王母真定。", "len": 24}
{"sid": "118_淮南衡山列传.0.s11", "chapter": "118_淮南衡山列传", "para": "0", "seq": 11, "text": "真定，厉王母之家在焉，父世县也。", "len": 16}
{"sid": "118_淮南衡山列传.1.s1", "chapter": "118_淮南衡山列传", "para": "1", "seq": 1, "text": "高祖十一年月，淮南王黥布反，立子长为淮南王，王黥布故地，凡四郡。", "len": 32}
{"sid": "118_淮南衡山列传.1.s2", "chapter": "118_淮南衡山列传", "para": "1", "seq": 2, "text": "上自将兵击灭布，厉王遂即位。", "len": 14}
{"sid": "118_淮南衡山列传.1.s3", "chapter": "118_淮南衡山列传", "para": "1", "seq": 3, "text": "厉王蚤失母，常附吕后，孝惠、吕后时以故得幸无患害，而常心怨辟阳侯，弗敢发。", "len": 37}
{"sid": "118_淮南衡山列传.1.s4", "chapter": "118_淮南衡山列传", "para": "1", "seq": 4, "text": "及孝文帝初即位，淮南王自以为最亲，骄蹇，数不奉法。", "len": 25}
{"sid": "118_淮南衡山列传.1.s5", "chapter": "118_淮南衡山列传", "para": "1", "seq": 5, "text": "上以亲故，常宽赦之。", "len": 10}
{"sid": "118_淮南衡山列传.1.s6", "chapter": "118_淮南衡山列传", "para": "1", "seq": 6, "text": "三年，入朝。", "len": 6}
{"sid": "118_淮南衡山列传.1.s7", "chapter": "118_淮南衡山列传", "para": "1", "seq": 7, "text": "甚横。", "len": 3}
{"sid": "118_淮南衡山列传.1.s8", "chapter": "118_淮南衡山列传", "para": "1", "seq": 8, "text": "从上入苑囿猎，与上同车，常谓上”大兄”。", "len": 20}
{"sid": "118_淮南衡山列传.1.s9", "chapter": "118_淮南衡山列传", "para": "1", "seq": 9, "text": "厉王有材力，力能扛鼎，乃往请辟阳侯。", "len": 18}
{"sid": "118_淮南衡山列传.1.s10", "chapter": "118_淮南衡山列传", "para": "1", "seq": 10, "text": "辟阳侯出见之，即自袖铁椎椎辟阳侯，令从者魏敬刭之。", "len": 25}
{"sid": "118_淮南衡山列传.1.s11", "chapter": "118_淮南衡山列传", "para": "1", "seq": 11, "text": "厉王乃驰走阙下，肉袒谢曰：”臣母不当坐赵事，其时辟阳侯力能得之吕后，弗争，罪一也。", "len": 41}
{"sid": "118_淮南衡山列传.1.s12", "chapter": "118_淮南衡山列传", "para": "1", "seq": 12, "text": "赵王如意子母无罪，吕后杀之，辟阳侯弗争，罪二也。", "len": 24}
{"sid": "118_淮南衡山列传.1.s13", "chapter": "118_淮南衡山列传", "para": "1", "seq": 13, "text": "吕后王诸吕，欲以危刘氏，辟阳侯弗争，罪三也。", "len": 22}
{"sid": "118_淮南衡山列传.1.s14", "chapter": "118_淮南衡山列传", "para": "1", "seq": 14, "text": "臣谨为天下诛贼臣辟阳侯，报母之仇，谨伏阙下请罪。", "len": 24}
{"sid": "118_淮南衡山列传.1.s15", "chapter": "118_淮南衡山列传", "para": "1", "seq": 15, "text": "” 孝文伤其志，为亲故，弗治，赦厉王。", "len": 19}
{"sid": "118_淮南衡山列传.1.s16", "chapter": "118_淮南衡山列传", "para": "1", "seq": 16, "text": "当是时，薄太后及太子诸大臣皆惮厉王，厉王以此归国益骄恣，不用汉法，出入称警跸，称制，自为法令，拟於天子。", "len": 52}
{"sid": "118_淮南衡山列传.2.s1", "chapter": "118_淮南衡山列传", "para": "2", "seq": 1, "text": "六年，令男子但等七十人与棘蒲侯柴武太子奇谋，以輂车四十乘反谷口，令人使闽越、匈奴。", "len": 41}
{"sid": "118_淮南衡山列传.2.s2", "chapter": "118_淮南衡山列传", "para": "2", "seq": 2, "text": "事觉，治之，使使召淮南王。", "len": 13}
{"sid": "118_淮南衡山列传.2.s3", "chapter": "118_淮南衡山列传", "para": "2", "seq": 3, "text": "淮南王至长安。", "len": 7}
{"sid": "118_淮南衡山列传.3.s1", "chapter": "118_淮南衡山列传", "para": "3", "seq": 1, "text": "“丞相臣张仓、典客臣冯敬、行御史大夫事宗正臣逸、廷尉臣贺、备盗贼中尉臣福昧死言：淮南王长废先帝法，不听天子诏，居处无度，为黄屋盖乘舆，出入拟於天子，擅为法令，不用汉法。", "len": 84}
{"sid": "118_淮南衡山列传.3.s2", "chapter": "118_淮南衡山列传", "para": "3", "seq": 2, "text": "及所置吏，以其郎中春为丞相，聚收汉诸侯人及有罪亡者，匿与居，为治家室，赐其财物爵禄田宅，爵或至关内侯，奉以二千石，所不当得，欲以有为。", "len": 67}
{"sid": "118_淮南衡山列传.3.s3", "chapter": "118_淮南衡山列传", "para": "3", "seq": 3, "text": "大夫但、士五开章等七十人与棘蒲侯太子奇谋反，欲以危宗庙社稷。", "len": 30}
{"sid": "118_淮南衡山列传.3.s4", "chapter": "118_淮南衡山列传", "para": "3", "seq": 4, "text": "使开章阴告长，与谋使闽越及匈奴发其兵。", "len": 19}
{"sid": "118_淮南衡山列传.3.s5", "chapter": "118_淮南衡山列传", "para": "3", "seq": 5, "text": "开章之淮南见长，长数与坐语饮食，为家室娶妇，以二千石俸奉之。", "len": 30}
{"sid": "118_淮南衡山列传.3.s6", "chapter": "118_淮南衡山列传", "para": "3", "seq": 6, "text": "开章使人告但，已言之王。", "len": 12}
{"sid": "118_淮南衡山列传.3.s7", "chapter": "118_淮南衡山列传", "para": "3", "seq": 7, "text": "春使使报但等。", "len": 7}
{"sid": "118_淮南衡山列传.3.s8", "chapter": "118_淮南衡山列传", "para": "3", "seq": 8, "text": "吏觉知，使长安尉奇等往捕开章。", "len": 15}
{"sid": "118_淮南衡山列传.3.s9", "chapter": "118_淮南衡山列传", "para": "3", "seq": 9, "text": "长匿不予，与故中尉蕑忌谋，杀以闭口。", "len": 18}
{"sid": "118_淮南衡山列传.3.s10", "chapter": "118_淮南衡山列传", "para": "3", "seq": 10, "text": "为棺椁衣衾，葬之肥陵邑，谩吏曰’不知安在‘。", "len": 22}
{"sid": "118_淮南衡山列传.3.1.s1", "chapter": "118_淮南衡山列传", "para": "3.1", "seq": 1, "text": "又详聚土，树表其上，曰‘开章死，埋此下’。", "len": 21}
{"sid": "118_淮南衡山列传.3.2.s1", "chapter": "118_淮南衡山列传", "para": "3.2", "seq": 1, "text": "及长身自贼杀无罪者一人；令吏论杀无罪者六人；为亡命弃市罪诈捕命者以除罪；擅罪人，罪人无告劾，系治城旦舂以上十四人；赦免罪人，死罪十八人，城旦舂以下五十八人；赐人爵关内侯以下九十四人。", "len": 91}
{"sid": "118_淮南衡山列传.3.2.s2", "chapter": "118_淮南衡山列传", "para": "3.2", "seq": 2, "text": "前日长病，陛下忧苦之，使使者赐书、枣脯。", "len": 20}
{"sid": "118_淮南衡山列传.3.2.s3", "chapter": "118_淮南衡山列传", "para": "3.2", "seq": 3, "text": "长不欲受赐，不肯见拜使者。", "len": 13}
{"sid": "118_淮南衡山列传.3.2.s4", "chapter": "118_淮南衡山列传", "para": "3.2", "seq": 4, "text": "南海民处庐江界中者反，淮南吏卒击之。", "len": 18}
{"sid": "118_淮南衡山列传.3.2.s5", "chapter": "118_淮南衡山列传", "para": "3.2", "seq": 5, "text": "陛下以淮南民贫苦，遣使者赐长帛五千匹，以赐吏卒劳苦者。", "len": 27}
{"sid": "118_淮南衡山列传.3.2.s6", "chapter": "118_淮南衡山列传", "para": "3.2", "seq": 6, "text": "长不欲受赐，谩言曰‘无劳苦者’。", "len": 16}
{"sid": "118_淮南衡山列传.3.3.s1", "chapter": "118_淮南衡山列传", "para": "3.3", "seq": 1, "text": "南海民王织上书献璧皇帝，忌擅燔其书，不以闻。", "len": 22}
{"sid": "118_淮南衡山列传.3.3.s2", "chapter": "118_淮南衡山列传", "para": "3.3", "seq": 2, "text": "吏请召治忌，长不遣，谩言曰‘忌病’。", "len": 18}
{"sid": "118_淮南衡山列传.4.s1", "chapter": "118_淮南衡山列传", "para": "4", "seq": 1, "text": "春又请长，原入见，长怒曰‘女欲离我自附汉’。", "len": 22}
{"sid": "118_淮南衡山列传.3.5.s1", "chapter": "118_淮南衡山列传", "para": "3.5", "seq": 1, "text": "长当弃市，臣请论如法。”", "len": 12}
{"sid": "118_淮南衡山列传.4.s1", "chapter": "118_淮南衡山列传", "para": "4", "seq": 1, "text": "制曰：“朕不忍致法於王，其与列侯二千石议。”", "len": 22}
{"sid": "118_淮南衡山列传.5.s1", "chapter": "118_淮南衡山列传", "para": "5", "seq": 1, "text": "“臣仓、臣敬、臣逸、臣福、臣贺昧死言：臣谨与列侯吏二千石臣婴等四十三人议，皆曰‘长不奉法度，不听天子诏，乃阴聚徒党及谋反者，厚养亡命，欲以有为’。", "len": 73}
{"sid": "118_淮南衡山列传.5.1.s1", "chapter": "118_淮南衡山列传", "para": "5.1", "seq": 1, "text": "臣等议论如法。”", "len": 8}
{"sid": "118_淮南衡山列传.6.s1", "chapter": "118_淮南衡山列传", "para": "6", "seq": 1, "text": "制曰：“朕不忍致法於王，其赦长死罪，废勿王。”", "len": 23}
{"sid": "118_淮南衡山列传.7.s1", "chapter": "118_淮南衡山列传", "para": "7", "seq": 1, "text": "“臣仓等昧死言：长有大死罪，陛下不忍致法，幸赦，废勿王。", "len": 28}
{"sid": "118_淮南衡山列传.7.s2", "chapter": "118_淮南衡山列传", "para": "7", "seq": 2, "text": "臣请处蜀郡严道邛邮，遣其子母从居，县为筑盖家室，皆廪食给薪菜盐豉炊食器席蓐。", "len": 38}
{"sid": "118_淮南衡山列传.7.s3", "chapter": "118_淮南衡山列传", "para": "7", "seq": 3, "text": "臣等昧死请，请布告天下。”", "len": 13}
{"sid": "118_淮南衡山列传.8.s1", "chapter": "118_淮南衡山列传", "para": "8", "seq": 1, "text": "制曰：“计食长给肉日五斤，酒二斗。", "len": 17}
{"sid": "118_淮南衡山列传.8.s2", "chapter": "118_淮南衡山列传", "para": "8", "seq": 2, "text": "令故美人才人得幸者十人从居。", "len": 14}
{"sid": "118_淮南衡山列传.8.s3", "chapter": "118_淮南衡山列传", "para": "8", "seq": 3, "text": "他可。”", "len": 4}
{"sid": "118_淮南衡山列传.9.s1", "chapter": "118_淮南衡山列传", "para": "9", "seq": 1, "text": "尽诛所与谋者。", "len": 7}
{"sid": "118_淮南衡山列传.9.s2", "chapter": "118_淮南衡山列传", "para": "9", "seq": 2, "text": "於是乃遣淮南王，载以辎车，令县以次传。", "len": 19}
{"sid": "118_淮南衡山列传.9.s3", "chapter": "118_淮南衡山列传", "para": "9", "seq": 3, "text": "是时袁盎谏上曰：“上素骄淮南王，弗为置严傅相，以故至此。", "len": 28}
{"sid": "118_淮南衡山列传.9.s4", "chapter": "118_淮南衡山列传", "para": "9", "seq": 4, "text": "且淮南王为人刚，今暴摧折之。", "len": 14}
{"sid": "118_淮南衡山列传.9.s5", "chapter": "118_淮南衡山列传", "para": "9", "seq": 5, "text": "臣恐卒逢雾露病死。", "len": 9}
{"sid": "118_淮南衡山列传.9.s6", "chapter": "118_淮南衡山列传", "para": "9", "seq": 6, "text": "陛下为有杀弟之名，柰何！", "len": 12}
{"sid": "118_淮南衡山列传.9.s7", "chapter": "118_淮南衡山列传", "para": "9", "seq": 7, "text": "” 上曰：“吾特苦之耳，今复之。", "len": 16}
{"sid": "118_淮南衡山列传.9.s8", "chapter": "118_淮南衡山列传", "para": "9", "seq": 8, "text": "” 县传淮南王者皆不敢发车封。", "len": 15}
{"sid": "118_淮南衡山列传.9.s9", "chapter": "118_淮南衡山列传", "para": "9", "seq": 9, "text": "淮南王乃谓侍者曰：“谁谓乃公勇者？", "len": 17}
{"sid": "118_淮南衡山列传.9.s10", "chapter": "118_淮南衡山列传", "para": "9", "seq": 10, "text": "吾安能勇！", "len": 5}
{"sid": "118_淮南衡山列传.9.s11", "chapter": "118_淮南衡山列传", "para": "9", "seq": 11, "text": "吾以骄故不闻吾过至此。", "len": 11}
{"sid": "118_淮南衡山列传.9.s12", "chapter": "118_淮南衡山列传", "para": "9", "seq": 12, "text": "人生一世间，安能邑邑如此！", "len": 13}
{"sid": "118_淮南衡山列传.9.s13", "chapter": "118_淮南衡山列传", "para": "9", "seq": 13, "text": "” 乃不食死。", "len": 7}
{"sid": "118_淮南衡山列传.9.s14", "chapter": "118_淮南衡山列传", "para": "9", "seq": 14, "text": "至雍，雍令发封，以死闻。", "len": 12}
{"sid": "118_淮南衡山列传.9.s15", "chapter": "118_淮南衡山列传", "para": "9", "seq": 15, "text": "上哭甚悲，谓袁盎曰：“吾不听公言，卒亡淮南王。", "len": 23}
{"sid": "118_淮南衡山列传.9.s16", "chapter": "118_淮南衡山列传", "para": "9", "seq": 16, "text": "” 盎曰：“不可柰何，原陛下自宽。", "len": 17}
{"sid": "118_淮南衡山列传.9.s17", "chapter": "118_淮南衡山列传", "para": "9", "seq": 17, "text": "” 上曰：“为之柰何？", "len": 11}
{"sid": "118_淮南衡山列传.9.s18", "chapter": "118_淮南衡山列传", "para": "9", "seq": 18, "text": "” 盎曰：“独斩丞相、御史以谢天下乃可。", "len": 20}
{"sid": "118_淮南衡山列传.9.s19", "chapter": "118_淮南衡山列传", "para": "9", "seq": 19, "text": "” 上即令丞相、御史逮考诸县传送淮南王不发封餽侍者，皆弃市。", "len": 30}
{"sid": "118_淮南衡山列传.9.s20", "chapter": "118_淮南衡山列传", "para": "9", "seq": 20, "text": "乃以列侯葬淮南王於雍，守冢三十户。", "len": 17}
{"sid": "118_淮南衡山列传.10.s1", "chapter": "118_淮南衡山列传", "para": "10", "seq": 1, "text": "孝文八年，上怜淮南王，淮南王有子四人，皆七八岁，乃封子安为阜陵侯，子勃为安阳侯，子赐为阳周侯，子良为东成侯。", "len": 54}
{"sid": "118_淮南衡山列传.11.s1", "chapter": "118_淮南衡山列传", "para": "11", "seq": 1, "text": "孝文十二年，民有作歌歌淮南厉王曰：“一尺布，尚可缝；一斗粟，尚可舂。", "len": 34}
{"sid": "118_淮南衡山列传.11.s2", "chapter": "118_淮南衡山列传", "para": "11", "seq": 2, "text": "兄弟二人不能相容。", "len": 9}
{"sid": "118_淮南衡山列传.11.s3", "chapter": "118_淮南衡山列传", "para": "11", "seq": 3, "text": "” 上闻之，乃叹曰：“尧舜放逐骨肉，周公杀管蔡，天下称圣。", "len": 29}
{"sid": "118_淮南衡山列传.11.s4", "chapter": "118_淮南衡山列传", "para": "11", "seq": 4, "text": "何者？", "len": 3}
{"sid": "118_淮南衡山列传.11.s5", "chapter": "118_淮南衡山列传", "para": "11", "seq": 5, "text": "不以私害公。", "len": 6}
{"sid": "118_淮南衡山列传.11.s6", "chapter": "118_淮南衡山列传", "para": "11", "seq": 6, "text": "天下岂以我为贪淮南王地邪？", "len": 13}
{"sid": "118_淮南衡山列传.11.s7", "chapter": "118_淮南衡山列传", "para": "11", "seq": 7, "text": "” 乃徙城阳王王淮南故地，而追尊谥淮南王为厉王，置园复如诸侯仪。", "len": 32}
{"sid": "118_淮南衡山列传.12.s1", "chapter": "118_淮南衡山列传", "para": "12", "seq": 1, "text": "孝文十六年，徙淮南王喜复故城阳。", "len": 16}
{"sid": "118_淮南衡山列传.12.s2", "chapter": "118_淮南衡山列传", "para": "12", "seq": 2, "text": "上怜淮南厉王废法不轨，自使失国蚤死，乃立其三子：阜陵侯安为淮南王，安阳侯勃为衡山王，阳周侯赐为庐江王，皆复得厉王时地，参分之。", "len": 63}
{"sid": "118_淮南衡山列传.12.s3", "chapter": "118_淮南衡山列传", "para": "12", "seq": 3, "text": "东城侯良前薨，无後也。", "len": 11}
{"sid": "118_淮南衡山列传.13.s1", "chapter": "118_淮南衡山列传", "para": "13", "seq": 1, "text": "孝景三年，吴楚七国反，吴使者至淮南，淮南王欲发兵应之。", "len": 27}
{"sid": "118_淮南衡山列传.13.s2", "chapter": "118_淮南衡山列传", "para": "13", "seq": 2, "text": "其相曰：“大王必欲发兵应吴，臣原为将。", "len": 19}
{"sid": "118_淮南衡山列传.13.s3", "chapter": "118_淮南衡山列传", "para": "13", "seq": 3, "text": "” 王乃属相兵。", "len": 8}
{"sid": "118_淮南衡山列传.13.s4", "chapter": "118_淮南衡山列传", "para": "13", "seq": 4, "text": "淮南相已将兵，因城守，不听王而为汉；汉亦使曲城侯将兵救淮南：淮南以故得完。", "len": 37}
{"sid": "118_淮南衡山列传.13.s5", "chapter": "118_淮南衡山列传", "para": "13", "seq": 5, "text": "吴使者至庐江，庐江王弗应，而往来使越。", "len": 19}
{"sid": "118_淮南衡山列传.13.s6", "chapter": "118_淮南衡山列传", "para": "13", "seq": 6, "text": "吴使者至衡山，衡山王坚守无二心。", "len": 16}
{"sid": "118_淮南衡山列传.13.s7", "chapter": "118_淮南衡山列传", "para": "13", "seq": 7, "text": "孝景四年，吴楚已破，衡山王朝，上以为贞信，乃劳苦之曰：“南方卑湿。", "len": 33}
{"sid": "118_淮南衡山列传.13.s8", "chapter": "118_淮南衡山列传", "para": "13", "seq": 8, "text": "” 徙衡山王王济北，所以襃之。", "len": 15}
{"sid": "118_淮南衡山列传.13.s9", "chapter": "118_淮南衡山列传", "para": "13", "seq": 9, "text": "及薨，遂赐谥为贞王。", "len": 10}
{"sid": "118_淮南衡山列传.13.s10", "chapter": "118_淮南衡山列传", "para": "13", "seq": 10, "text": "庐江王边越，数使使相交，故徙为衡山王，王江北。", "len": 23}
{"sid": "118_淮南衡山列传.13.s11", "chapter": "118_淮南衡山列传", "para": "13", "seq": 11, "text": "淮南王如故。", "len": 6}
{"sid": "118_淮南衡山列传.14.s1", "chapter": "118_淮南衡山列传", "para": "14", "seq": 1, "text": "淮南王安为人好读书鼓琴，不喜弋猎狗马驰骋，亦欲以行阴德拊循百姓，流誉天下。", "len": 37}
{"sid": "118_淮南衡山列传.14.s2", "chapter": "118_淮南衡山列传", "para": "14", "seq": 2, "text": "时时怨望厉王死，时欲畔逆，未有因也。", "len": 18}
{"sid": "118_淮南衡山列传.14.s3", "chapter": "118_淮南衡山列传", "para": "14", "seq": 3, "text": "及建元二年，淮南王入朝。", "len": 12}
{"sid": "118_淮南衡山列传.14.s4", "chapter": "118_淮南衡山列传", "para": "14", "seq": 4, "text": "素善武安侯，武安侯时为太尉，乃逆王霸上，与王语曰：“方今上无太子，大王亲高皇帝孙，行仁义，天下莫不闻。", "len": 51}
{"sid": "118_淮南衡山列传.14.s5", "chapter": "118_淮南衡山列传", "para": "14", "seq": 5, "text": "即宫车一日晏驾，非大王当谁立者！", "len": 16}
{"sid": "118_淮南衡山列传.14.s6", "chapter": "118_淮南衡山列传", "para": "14", "seq": 6, "text": "” 淮南王大喜，厚遗武安侯金财物。", "len": 17}
{"sid": "118_淮南衡山列传.14.s7", "chapter": "118_淮南衡山列传", "para": "14", "seq": 7, "text": "阴结宾客，拊循百姓，为畔逆事。", "len": 15}
{"sid": "118_淮南衡山列传.14.s8", "chapter": "118_淮南衡山列传", "para": "14", "seq": 8, "text": "建元六年，彗星见，淮南王心怪之。", "len": 16}
{"sid": "118_淮南衡山列传.14.s9", "chapter": "118_淮南衡山列传", "para": "14", "seq": 9, "text": "或说王曰：“先吴军起时，彗星出长数尺，然尚流血千里。", "len": 26}
{"sid": "118_淮南衡山列传.14.s10", "chapter": "118_淮南衡山列传", "para": "14", "seq": 10, "text": "今彗星长竟天，天下兵当大起。", "len": 14}
{"sid": "118_淮南衡山列传.14.s11", "chapter": "118_淮南衡山列传", "para": "14", "seq": 11, "text": "” 王心以为上无太子，天下有变，诸侯并争，愈益治器械攻战具，积金钱赂遗郡国诸侯游士奇材。", "len": 44}
{"sid": "118_淮南衡山列传.14.s12", "chapter": "118_淮南衡山列传", "para": "14", "seq": 12, "text": "诸辨士为方略者，妄作妖言，谄谀王，王喜，多赐金钱，而谋反滋甚。", "len": 31}
{"sid": "118_淮南衡山列传.15.s1", "chapter": "118_淮南衡山列传", "para": "15", "seq": 1, "text": "淮南王有女陵，慧，有口辩。", "len": 13}
{"sid": "118_淮南衡山列传.15.s2", "chapter": "118_淮南衡山列传", "para": "15", "seq": 2, "text": "王爱陵，常多予金钱，为中诇长安，约结上左右。", "len": 22}
{"sid": "118_淮南衡山列传.15.s3", "chapter": "118_淮南衡山列传", "para": "15", "seq": 3, "text": "元朔三年，上赐淮南王几杖，不朝。", "len": 16}
{"sid": "118_淮南衡山列传.15.s4", "chapter": "118_淮南衡山列传", "para": "15", "seq": 4, "text": "淮南王王后荼，王爱幸之。", "len": 12}
{"sid": "118_淮南衡山列传.15.s5", "chapter": "118_淮南衡山列传", "para": "15", "seq": 5, "text": "王后生太子迁，迁取王皇太后外孙修成君女为妃。", "len": 22}
{"sid": "118_淮南衡山列传.15.s6", "chapter": "118_淮南衡山列传", "para": "15", "seq": 6, "text": "王谋为反具，畏太子妃知而内泄事，乃与太子谋，令诈弗爱，三月不同席。", "len": 33}
{"sid": "118_淮南衡山列传.15.s7", "chapter": "118_淮南衡山列传", "para": "15", "seq": 7, "text": "王乃详为怒太子，闭太子使与妃同内三月，太子终不近妃。", "len": 26}
{"sid": "118_淮南衡山列传.15.s8", "chapter": "118_淮南衡山列传", "para": "15", "seq": 8, "text": "妃求去，王乃上书谢归去之。", "len": 13}
{"sid": "118_淮南衡山列传.15.s9", "chapter": "118_淮南衡山列传", "para": "15", "seq": 9, "text": "王后荼、太子迁及女陵得爱幸王，擅国权，侵夺民田宅，妄致系人。", "len": 30}
{"sid": "118_淮南衡山列传.16.s1", "chapter": "118_淮南衡山列传", "para": "16", "seq": 1, "text": "元朔五年，太子学用剑，自以为人莫及，闻郎中雷被巧，乃召与戏。", "len": 30}
{"sid": "118_淮南衡山列传.16.s2", "chapter": "118_淮南衡山列传", "para": "16", "seq": 2, "text": "被一再辞让，误中太子。", "len": 11}
{"sid": "118_淮南衡山列传.16.s3", "chapter": "118_淮南衡山列传", "para": "16", "seq": 3, "text": "太子怒，被恐。", "len": 7}
{"sid": "118_淮南衡山列传.16.s4", "chapter": "118_淮南衡山列传", "para": "16", "seq": 4, "text": "此时有欲从军者辄诣京师，被即原奋击匈奴。", "len": 20}
{"sid": "118_淮南衡山列传.16.s5", "chapter": "118_淮南衡山列传", "para": "16", "seq": 5, "text": "太子迁数恶被於王，王使郎中令斥免，欲以禁後，被遂亡至长安，上书自明。", "len": 34}
{"sid": "118_淮南衡山列传.16.s6", "chapter": "118_淮南衡山列传", "para": "16", "seq": 6, "text": "诏下其事廷尉、河南。", "len": 10}
{"sid": "118_淮南衡山列传.16.s7", "chapter": "118_淮南衡山列传", "para": "16", "seq": 7, "text": "河南治，逮淮南太子，王、王后计欲无遣太子，遂发兵反，计犹豫，十馀日未定。", "len": 36}
{"sid": "118_淮南衡山列传.16.s8", "chapter": "118_淮南衡山列传", "para": "16", "seq": 8, "text": "会有诏，即讯太子。", "len": 9}
{"sid": "118_淮南衡山列传.16.s9", "chapter": "118_淮南衡山列传", "para": "16", "seq": 9, "text": "当是时，淮南相怒寿春丞留太子逮不遣，劾不敬。", "len": 22}
{"sid": "118_淮南衡山列传.16.s10", "chapter": "118_淮南衡山列传", "para": "16", "seq": 10, "text": "王以请相，相弗听。", "len": 9}
{"sid": "118_淮南衡山列传.16.s11", "chapter": "118_淮南衡山列传", "para": "16", "seq": 11, "text": "王使人上书告相，事下廷尉治。", "len": 14}
{"sid": "118_淮南衡山列传.16.s12", "chapter": "118_淮南衡山列传", "para": "16", "seq": 12, "text": "踪迹连王，王使人候伺汉公卿，公卿请逮捕治王。", "len": 22}
{"sid": "118_淮南衡山列传.16.s13", "chapter": "118_淮南衡山列传", "para": "16", "seq": 13, "text": "王恐事发，太子迁谋曰：“汉使即逮王，王令人衣卫士衣，持戟居庭中，王旁有非是，则刺杀之，臣亦使人刺杀淮南中尉，乃举兵，未晚。", "len": 61}
{"sid": "118_淮南衡山列传.16.s14", "chapter": "118_淮南衡山列传", "para": "16", "seq": 14, "text": "” 是时上不许公卿请，而遣汉中尉宏即讯验王。", "len": 22}
{"sid": "118_淮南衡山列传.16.s15", "chapter": "118_淮南衡山列传", "para": "16", "seq": 15, "text": "王闻汉使来，即如太子谋计。", "len": 13}
{"sid": "118_淮南衡山列传.16.s16", "chapter": "118_淮南衡山列传", "para": "16", "seq": 16, "text": "汉中尉至，王视其颜色和，讯王以斥雷被事耳，王自度无何，不发。", "len": 30}
{"sid": "118_淮南衡山列传.16.s17", "chapter": "118_淮南衡山列传", "para": "16", "seq": 17, "text": "中尉还，以闻。", "len": 7}
{"sid": "118_淮南衡山列传.16.s18", "chapter": "118_淮南衡山列传", "para": "16", "seq": 18, "text": "公卿治者曰：“淮南王安拥阏奋击匈奴者雷被等，废格明诏，当弃市。", "len": 31}
{"sid": "118_淮南衡山列传.16.s19", "chapter": "118_淮南衡山列传", "para": "16", "seq": 19, "text": "” 诏弗许。", "len": 6}
{"sid": "118_淮南衡山列传.16.s20", "chapter": "118_淮南衡山列传", "para": "16", "seq": 20, "text": "公卿请废勿王，诏弗许。", "len": 11}
{"sid": "118_淮南衡山列传.16.s21", "chapter": "118_淮南衡山列传", "para": "16", "seq": 21, "text": "公卿请削五县，诏削二县。", "len": 12}
{"sid": "118_淮南衡山列传.16.s22", "chapter": "118_淮南衡山列传", "para": "16", "seq": 22, "text": "使中尉宏赦淮南王罪，罚以削地。", "len": 15}
{"sid": "118_淮南衡山列传.16.s23", "chapter": "118_淮南衡山列传", "para": "16", "seq": 23, "text": "中尉入淮南界，宣言赦王。", "len": 12}
{"sid": "118_淮南衡山列传.16.s24", "chapter": "118_淮南衡山列传", "para": "16", "seq": 24, "text": "王初闻汉公卿请诛之，未知得削地，闻汉使来，恐其捕之，乃与太子谋刺之如前计。", "len": 37}
{"sid": "118_淮南衡山列传.16.s25", "chapter": "118_淮南衡山列传", "para": "16", "seq": 25, "text": "及中尉至，即贺王，王以故不发。", "len": 15}
{"sid": "118_淮南衡山列传.16.s26", "chapter": "118_淮南衡山列传", "para": "16", "seq": 26, "text": "其後自伤曰：“吾行仁义见削，甚耻之。", "len": 18}
{"sid": "118_淮南衡山列传.16.s27", "chapter": "118_淮南衡山列传", "para": "16", "seq": 27, "text": "” 然淮南王削地之後，其为反谋益甚。", "len": 18}
{"sid": "118_淮南衡山列传.16.s28", "chapter": "118_淮南衡山列传", "para": "16", "seq": 28, "text": "诸使道从长安来，为妄妖言，言上无男，汉不治，即喜；即言汉廷治，有男，王怒，以为妄言，非也。", "len": 45}
{"sid": "118_淮南衡山列传.17.s1", "chapter": "118_淮南衡山列传", "para": "17", "seq": 1, "text": "王日夜与伍被、左吴等案舆地图，部署兵所从入。", "len": 22}
{"sid": "118_淮南衡山列传.17.s2", "chapter": "118_淮南衡山列传", "para": "17", "seq": 2, "text": "王曰：“上无太子，宫车即晏驾，廷臣必徵胶东王，不即常山王，诸侯并争，吾可以无备乎！", "len": 41}
{"sid": "118_淮南衡山列传.17.s3", "chapter": "118_淮南衡山列传", "para": "17", "seq": 3, "text": "且吾高祖孙，亲行仁义，陛下遇我厚，吾能忍之；万世之後，吾宁能北面臣事竖子乎！”", "len": 39}
{"sid": "118_淮南衡山列传.18.s1", "chapter": "118_淮南衡山列传", "para": "18", "seq": 1, "text": "王坐东宫，召伍被与谋，曰：“将军上。", "len": 18}
{"sid": "118_淮南衡山列传.18.s2", "chapter": "118_淮南衡山列传", "para": "18", "seq": 2, "text": "” 被怅然曰：“上宽赦大王，王复安得此亡国之语乎！", "len": 25}
{"sid": "118_淮南衡山列传.18.s3", "chapter": "118_淮南衡山列传", "para": "18", "seq": 3, "text": "臣闻子胥谏吴王，吴王不用，乃曰‘臣今见麋鹿游姑苏之台也’。", "len": 29}
{"sid": "118_淮南衡山列传.18.1.s1", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 1, "text": "今臣亦见宫中生荆棘，露霑衣也。", "len": 15}
{"sid": "118_淮南衡山列传.18.1.s2", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 2, "text": "“王怒，系伍被父母，囚之三月。", "len": 15}
{"sid": "118_淮南衡山列传.18.1.s3", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 3, "text": "复召曰：“将军许寡人乎？", "len": 12}
{"sid": "118_淮南衡山列传.18.1.s4", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 4, "text": "“被曰：“不，直来为大王画耳。", "len": 15}
{"sid": "118_淮南衡山列传.18.1.s5", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 5, "text": "臣闻聪者听於无声，明者见於未形，故圣人万举万全。", "len": 24}
{"sid": "118_淮南衡山列传.18.1.s6", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 6, "text": "昔文王一动而功显于千世，列为三代，此所谓因天心以动作者也，故海内不期而随。", "len": 37}
{"sid": "118_淮南衡山列传.18.1.s7", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 7, "text": "此千岁之可见者。", "len": 8}
{"sid": "118_淮南衡山列传.18.1.s8", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 8, "text": "夫百年之秦，近世之吴楚，亦足以喻国家之存亡矣。", "len": 23}
{"sid": "118_淮南衡山列传.18.1.s9", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 9, "text": "臣不敢避子胥之诛，原大王毋为吴王之听。", "len": 19}
{"sid": "118_淮南衡山列传.18.1.s10", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 10, "text": "昔秦绝圣人之道，杀术士，燔诗书，弃礼义，尚诈力，任刑罚，转负海之粟致之西河。", "len": 38}
{"sid": "118_淮南衡山列传.18.1.s11", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 11, "text": "当是之时，男子疾耕不足於糟糠，女子纺绩不足於盖形。", "len": 25}
{"sid": "118_淮南衡山列传.18.1.s12", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 12, "text": "遣蒙恬筑长城，东西数千里，暴兵露师常数十万，死者不可胜数，僵尸千里，流血顷亩，百姓力竭，欲为乱者十家而五。", "len": 53}
{"sid": "118_淮南衡山列传.18.1.s13", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 13, "text": "又使徐福入海求神异物，还为伪辞曰：‘臣见海中大神，言曰：“汝西皇之使邪？", "len": 36}
{"sid": "118_淮南衡山列传.18.1.s14", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 14, "text": "” 臣答曰：“然。", "len": 9}
{"sid": "118_淮南衡山列传.18.1.s15", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 15, "text": "” ” 汝何求？", "len": 8}
{"sid": "118_淮南衡山列传.18.1.s16", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 16, "text": "“曰：“原请延年益寿药。", "len": 12}
{"sid": "118_淮南衡山列传.18.1.s17", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 17, "text": "“神曰：“汝秦王之礼薄，得观而不得取。", "len": 19}
{"sid": "118_淮南衡山列传.18.1.s18", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 18, "text": "“即从臣东南至蓬莱山，见芝成宫阙，有使者铜色而龙形，光上照天。", "len": 31}
{"sid": "118_淮南衡山列传.18.1.s19", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 19, "text": "於是臣再拜问曰：“宜何资以献？", "len": 15}
{"sid": "118_淮南衡山列传.18.1.s20", "chapter": "118_淮南衡山列传", "para": "18.1", "seq": 20, "text": "“海神曰：“以令名男子若振女与百工之事，即得之矣。“‘", "len": 27}
{"sid": "118_淮南衡山列传.18.2.s1", "chapter": "118_淮南衡山列传", "para": "18.2", "seq": 1, "text": "秦皇帝大说，遣振男女三千人，资之五穀种种百工而行。", "len": 25}
{"sid": "118_淮南衡山列传.18.2.s2", "chapter": "118_淮南衡山列传", "para": "18.2", "seq": 2, "text": "徐福得平原广泽，止王不来。", "len": 13}
{"sid": "118_淮南衡山列传.18.2.s3", "chapter": "118_淮南衡山列传", "para": "18.2", "seq": 3, "text": "於是百姓悲痛相思，欲为乱者十家而六。", "len": 18}
{"sid": "118_淮南衡山列传.18.2.s4", "chapter": "118_淮南衡山列传", "para": "18.2", "seq": 4, "text": "又使尉佗逾五岭攻百越。", "len": 11}
{"sid": "118_淮南衡山列传.18.2.s5", "chapter": "118_淮南衡山列传", "para": "18.2", "seq": 5, "text": "尉佗知中国劳极，止王不来，使人上书，求女无夫家者三万人，以为士卒衣补。", "len": 35}
{"sid": "118_淮南衡山列传.18.2.s6", "chapter": "118_淮南衡山列传", "para": "18.2", "seq": 6, "text": "秦皇帝可其万五千人。", "len": 10}
{"sid": "118_淮南衡山列传.18.2.s7", "chapter": "118_淮南衡山列传", "para": "18.2", "seq": 7, "text": "於是百姓离心瓦解，欲为乱者十家而七。", "len": 18}
{"sid": "118_淮南衡山列传.18.2.s8", "chapter": "118_淮南衡山列传", "para": "18.2", "seq": 8, "text": "客谓高皇帝曰：‘时可矣。‘", "len": 13}
{"sid": "118_淮南衡山列传.18.3.s1", "chapter": "118_淮南衡山列传", "para": "18.3", "seq": 1, "text": "高皇帝曰：‘待之，圣人当起东南间。‘", "len": 18}
{"sid": "118_淮南衡山列传.18.4.s1", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 1, "text": "不一年，陈胜吴广发矣。", "len": 11}
{"sid": "118_淮南衡山列传.18.4.s2", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 2, "text": "高皇始於丰沛，一倡天下不期而响应者不可胜数也。", "len": 23}
{"sid": "118_淮南衡山列传.18.4.s3", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 3, "text": "此所谓蹈瑕候间，因秦之亡而动者也。", "len": 17}
{"sid": "118_淮南衡山列传.18.4.s4", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 4, "text": "百姓原之，若旱之望雨，故起於行陈之中而立为天子，功高三王，德传无穷。", "len": 34}
{"sid": "118_淮南衡山列传.18.4.s5", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 5, "text": "今大王见高皇帝得天下之易也，独不观近世之吴楚乎？", "len": 24}
{"sid": "118_淮南衡山列传.18.4.s6", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 6, "text": "夫吴王赐号为刘氏祭酒，复不朝，王四郡之众，地方数千里，内铸消铜以为钱，东煮海水以为盐，上取江陵木以为船，一船之载当中国数十两车，国富民众。", "len": 69}
{"sid": "118_淮南衡山列传.18.4.s7", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 7, "text": "行珠玉金帛赂诸侯宗室大臣，独窦氏不与。", "len": 19}
{"sid": "118_淮南衡山列传.18.4.s8", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 8, "text": "计定谋成，举兵而西。", "len": 10}
{"sid": "118_淮南衡山列传.18.4.s9", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 9, "text": "破於大梁，败於狐父，奔走而东，至於丹徒，越人禽之，身死绝祀，为天下笑。", "len": 35}
{"sid": "118_淮南衡山列传.18.4.s10", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 10, "text": "夫以吴越之众不能成功者何？", "len": 13}
{"sid": "118_淮南衡山列传.18.4.s11", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 11, "text": "诚逆天道而不知时也。", "len": 10}
{"sid": "118_淮南衡山列传.18.4.s12", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 12, "text": "方今大王之兵众不能十分吴楚之一，天下安宁有万倍於秦之时，原大王从臣之计。", "len": 36}
{"sid": "118_淮南衡山列传.18.4.s13", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 13, "text": "大王不从臣之计，今见大王事必不成而语先泄也。", "len": 22}
{"sid": "118_淮南衡山列传.18.4.s14", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 14, "text": "臣闻微子过故国而悲，於是作麦秀之歌，是痛纣之不用王子比干也。", "len": 30}
{"sid": "118_淮南衡山列传.18.4.s15", "chapter": "118_淮南衡山列传", "para": "18.4", "seq": 15, "text": "故孟子曰’纣贵为天子，死曾不若匹夫‘。", "len": 19}
{"sid": "118_淮南衡山列传.18.5.s1", "chapter": "118_淮南衡山列传", "para": "18.5", "seq": 1, "text": "是纣先自绝於天下久矣，非死之日而天下去之。", "len": 21}
{"sid": "118_淮南衡山列传.18.5.s2", "chapter": "118_淮南衡山列传", "para": "18.5", "seq": 2, "text": "今臣亦窃悲大王弃千乘之君，必且赐绝命之书，为群臣先，死於东宫也。", "len": 32}
{"sid": "118_淮南衡山列传.18.5.s3", "chapter": "118_淮南衡山列传", "para": "18.5", "seq": 3, "text": "“於是气怨结而不扬，涕满匡而横流，即起，历阶而去。", "len": 25}
{"sid": "118_淮南衡山列传.19.s1", "chapter": "118_淮南衡山列传", "para": "19", "seq": 1, "text": "王有孽子不害，最长，王弗爱，王、王后、太子皆不以为子兄数。", "len": 29}
{"sid": "118_淮南衡山列传.19.s2", "chapter": "118_淮南衡山列传", "para": "19", "seq": 2, "text": "不害有子建，材高有气，常怨望太子不省其父；又怨时诸侯皆得分子弟为侯，而淮南独二子，一为太子，建父独不得为侯。", "len": 54}
{"sid": "118_淮南衡山列传.19.s3", "chapter": "118_淮南衡山列传", "para": "19", "seq": 3, "text": "建阴结交，欲告败太子，以其父代之。", "len": 17}
{"sid": "118_淮南衡山列传.19.s4", "chapter": "118_淮南衡山列传", "para": "19", "seq": 4, "text": "太子知之，数捕系而榜笞建。", "len": 13}
{"sid": "118_淮南衡山列传.19.s5", "chapter": "118_淮南衡山列传", "para": "19", "seq": 5, "text": "建具知太子之谋欲杀汉中尉，即使所善寿春庄芷以元朔六年上书於天子曰：“毒药苦於口利於病，忠言逆於耳利於行。", "len": 52}
{"sid": "118_淮南衡山列传.19.s6", "chapter": "118_淮南衡山列传", "para": "19", "seq": 6, "text": "今淮南王孙建，材能高，淮南王王后荼、荼子太子迁常疾害建。", "len": 28}
{"sid": "118_淮南衡山列传.19.s7", "chapter": "118_淮南衡山列传", "para": "19", "seq": 7, "text": "建父不害无罪，擅数捕系，欲杀之。", "len": 16}
{"sid": "118_淮南衡山列传.19.s8", "chapter": "118_淮南衡山列传", "para": "19", "seq": 8, "text": "今建在，可徵问，具知淮南阴事。", "len": 15}
{"sid": "118_淮南衡山列传.19.s9", "chapter": "118_淮南衡山列传", "para": "19", "seq": 9, "text": "” 书闻，上以其事下廷尉，廷尉下河南治。", "len": 20}
{"sid": "118_淮南衡山列传.19.s10", "chapter": "118_淮南衡山列传", "para": "19", "seq": 10, "text": "是时故辟阳侯孙审卿善丞相公孙弘，怨淮南厉王杀其大父，乃深购淮南事於弘，弘乃疑淮南有畔逆计谋，深穷治其狱。", "len": 52}
{"sid": "118_淮南衡山列传.19.s11", "chapter": "118_淮南衡山列传", "para": "19", "seq": 11, "text": "河南治建，辞引淮南太子及党与。", "len": 15}
{"sid": "118_淮南衡山列传.19.s12", "chapter": "118_淮南衡山列传", "para": "19", "seq": 12, "text": "淮南王患之，欲发，问伍被曰：“汉廷治乱？", "len": 20}
{"sid": "118_淮南衡山列传.19.s13", "chapter": "118_淮南衡山列传", "para": "19", "seq": 13, "text": "” 伍被曰：“天下治。", "len": 11}
{"sid": "118_淮南衡山列传.19.s14", "chapter": "118_淮南衡山列传", "para": "19", "seq": 14, "text": "” 王意不说，谓伍被曰：“公何以言天下治也？", "len": 22}
{"sid": "118_淮南衡山列传.19.s15", "chapter": "118_淮南衡山列传", "para": "19", "seq": 15, "text": "” 被曰：“被窃观朝廷之政，君臣之义，父子之亲，夫妇之别，长幼之序，皆得其理，上之举错遵古之道，风俗纪纲未有所缺也。", "len": 58}
{"sid": "118_淮南衡山列传.19.s16", "chapter": "118_淮南衡山列传", "para": "19", "seq": 16, "text": "重装富贾，周流天下，道无不通，故交易之道行。", "len": 22}
{"sid": "118_淮南衡山列传.19.s17", "chapter": "118_淮南衡山列传", "para": "19", "seq": 17, "text": "南越宾服，羌僰入献，东瓯入降，广长榆，开朔方，匈奴折翅伤翼，失援不振。", "len": 35}
{"sid": "118_淮南衡山列传.19.s18", "chapter": "118_淮南衡山列传", "para": "19", "seq": 18, "text": "虽未及古太平之时，然犹为治也。", "len": 15}
{"sid": "118_淮南衡山列传.19.s19", "chapter": "118_淮南衡山列传", "para": "19", "seq": 19, "text": "” 王怒，被谢死罪。", "len": 10}
{"sid": "118_淮南衡山列传.19.s20", "chapter": "118_淮南衡山列传", "para": "19", "seq": 20, "text": "王又谓被曰：“山东即有兵，汉必使大将军将而制山东，公以为大将军何如人也？", "len": 36}
{"sid": "118_淮南衡山列传.19.s21", "chapter": "118_淮南衡山列传", "para": "19", "seq": 21, "text": "” 被曰：“被所善者黄义，从大将军击匈奴，还，告被曰：‘大将军遇士大夫有礼，於士卒有恩，众皆乐为之用。", "len": 51}
{"sid": "118_淮南衡山列传.19.s22", "chapter": "118_淮南衡山列传", "para": "19", "seq": 22, "text": "骑上下山若蜚，材幹绝人。‘", "len": 13}
{"sid": "118_淮南衡山列传.19.1.s1", "chapter": "118_淮南衡山列传", "para": "19.1", "seq": 1, "text": "被以为材能如此，数将习兵，未易当也。", "len": 18}
{"sid": "118_淮南衡山列传.19.1.s2", "chapter": "118_淮南衡山列传", "para": "19.1", "seq": 2, "text": "及谒者曹梁使长安来，言大将军号令明，当敌勇敢，常为士卒先。", "len": 29}
{"sid": "118_淮南衡山列传.19.1.s3", "chapter": "118_淮南衡山列传", "para": "19.1", "seq": 3, "text": "休舍，穿井未通，须士卒尽得水，乃敢饮。", "len": 19}
{"sid": "118_淮南衡山列传.19.1.s4", "chapter": "118_淮南衡山列传", "para": "19.1", "seq": 4, "text": "军罢，卒尽已度河，乃度。", "len": 12}
{"sid": "118_淮南衡山列传.19.1.s5", "chapter": "118_淮南衡山列传", "para": "19.1", "seq": 5, "text": "皇太后所赐金帛，尽以赐军吏。", "len": 14}
{"sid": "118_淮南衡山列传.19.1.s6", "chapter": "118_淮南衡山列传", "para": "19.1", "seq": 6, "text": "虽古名将弗过也。", "len": 8}
{"sid": "118_淮南衡山列传.19.1.s7", "chapter": "118_淮南衡山列传", "para": "19.1", "seq": 7, "text": "“王默然。", "len": 5}
{"sid": "118_淮南衡山列传.20.s1", "chapter": "118_淮南衡山列传", "para": "20", "seq": 1, "text": "淮南王见建已徵治，恐国阴事且觉，欲发，被又以为难，乃复问被曰：“公以为吴兴兵是邪非也？", "len": 43}
{"sid": "118_淮南衡山列传.20.s2", "chapter": "118_淮南衡山列传", "para": "20", "seq": 2, "text": "” 被曰：“以为非也。", "len": 11}
{"sid": "118_淮南衡山列传.20.s3", "chapter": "118_淮南衡山列传", "para": "20", "seq": 3, "text": "吴王至富贵也，举事不当，身死丹徒，头足异处，子孙无遗类。", "len": 28}
{"sid": "118_淮南衡山列传.20.s4", "chapter": "118_淮南衡山列传", "para": "20", "seq": 4, "text": "臣闻吴王悔之甚。", "len": 8}
{"sid": "118_淮南衡山列传.20.s5", "chapter": "118_淮南衡山列传", "para": "20", "seq": 5, "text": "原王孰虑之，无为吴王之所悔。", "len": 14}
{"sid": "118_淮南衡山列传.20.s6", "chapter": "118_淮南衡山列传", "para": "20", "seq": 6, "text": "” 王曰：“男子之所死者一言耳。", "len": 16}
{"sid": "118_淮南衡山列传.20.s7", "chapter": "118_淮南衡山列传", "para": "20", "seq": 7, "text": "且吴何知反，汉将一日过成皋者四十馀人。", "len": 19}
{"sid": "118_淮南衡山列传.20.s8", "chapter": "118_淮南衡山列传", "para": "20", "seq": 8, "text": "今我令楼缓先要成皋之口，周被下颍川兵塞轘辕、伊阙之道，陈定发南阳兵守武关。", "len": 37}
{"sid": "118_淮南衡山列传.20.s9", "chapter": "118_淮南衡山列传", "para": "20", "seq": 9, "text": "河南太守独有雒阳耳，何足忧。", "len": 14}
{"sid": "118_淮南衡山列传.20.s10", "chapter": "118_淮南衡山列传", "para": "20", "seq": 10, "text": "然此北尚有临晋关、河东、上党与河内、赵国。", "len": 21}
{"sid": "118_淮南衡山列传.20.s11", "chapter": "118_淮南衡山列传", "para": "20", "seq": 11, "text": "人言曰’绝成皋之口，天下不通‘。", "len": 16}
{"sid": "118_淮南衡山列传.20.1.s1", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 1, "text": "据三川之险，招山东之兵，举事如此，公以为何如？", "len": 23}
{"sid": "118_淮南衡山列传.20.1.s2", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 2, "text": "“被曰：“臣见其祸，未见其福也。", "len": 16}
{"sid": "118_淮南衡山列传.20.1.s3", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 3, "text": "“王曰：“左吴、赵贤、硃骄如皆以为有福，什事九成，公独以为有祸无福，何也？", "len": 37}
{"sid": "118_淮南衡山列传.20.1.s4", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 4, "text": "“被曰：“大王之群臣近幸素能使众者，皆前系诏狱，馀无可用者。", "len": 30}
{"sid": "118_淮南衡山列传.20.1.s5", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 5, "text": "“王曰：“陈胜、吴广无立锥之地，千人之聚，起於大泽，奋臂大呼而天下响应，西至於戏而兵百二十万。", "len": 47}
{"sid": "118_淮南衡山列传.20.1.s6", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 6, "text": "今吾国虽小，然而胜兵者可得十馀万，非直適戍之众，釠凿棘矜也，公何以言有祸无福？", "len": 39}
{"sid": "118_淮南衡山列传.20.1.s7", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 7, "text": "“被曰：“往者秦为无道，残贼天下。", "len": 17}
{"sid": "118_淮南衡山列传.20.1.s8", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 8, "text": "兴万乘之驾，作阿房之宫，收太半之赋，发闾左之戍，父不宁子，兄不便弟，政苛刑峻，天下熬然若焦，民皆引领而望，倾耳而听，悲号仰天，叩心而怨上，故陈胜大呼，天下响应。", "len": 80}
{"sid": "118_淮南衡山列传.20.1.s9", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 9, "text": "当今陛下临制天下，一齐海内，汎爱蒸庶，布德施惠。", "len": 24}
{"sid": "118_淮南衡山列传.20.1.s10", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 10, "text": "口虽未言，声疾雷霆，令虽未出，化驰如神，心有所怀，威动万里，下之应上，犹影响也。", "len": 40}
{"sid": "118_淮南衡山列传.20.1.s11", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 11, "text": "而大将军材能不特章邯、杨熊也。", "len": 15}
{"sid": "118_淮南衡山列传.20.1.s12", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 12, "text": "大王以陈胜、吴广谕之，被以为过矣。", "len": 17}
{"sid": "118_淮南衡山列传.20.1.s13", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 13, "text": "“王曰：“苟如公言，不可徼幸邪？", "len": 16}
{"sid": "118_淮南衡山列传.20.1.s14", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 14, "text": "“被曰：“被有愚计。", "len": 10}
{"sid": "118_淮南衡山列传.20.1.s15", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 15, "text": "“王曰：“柰何？", "len": 8}
{"sid": "118_淮南衡山列传.20.1.s16", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 16, "text": "“被曰：“当今诸侯无异心，百姓无怨气。", "len": 19}
{"sid": "118_淮南衡山列传.20.1.s17", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 17, "text": "朔方之郡田地广，水草美，民徙者不足以实其地。", "len": 22}
{"sid": "118_淮南衡山列传.20.1.s18", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 18, "text": "臣之愚计，可伪为丞相御史请书，徙郡国豪桀任侠及有耐罪以上，赦令除其罪，产五十万以上者，皆徙其家属朔方之郡，益发甲卒，急其会日。", "len": 63}
{"sid": "118_淮南衡山列传.20.1.s19", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 19, "text": "又伪为左右都司空上林中都官诏狱书，诸侯太子幸臣。", "len": 24}
{"sid": "118_淮南衡山列传.20.1.s20", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 20, "text": "如此则民怨，诸侯惧，即使辩武随而说之，傥可徼幸什得一乎？", "len": 28}
{"sid": "118_淮南衡山列传.20.1.s21", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 21, "text": "“王曰：“此可也。", "len": 9}
{"sid": "118_淮南衡山列传.20.1.s22", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 22, "text": "虽然，吾以为不至若此。", "len": 11}
{"sid": "118_淮南衡山列传.20.1.s23", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 23, "text": "“於是王乃令官奴入宫，作皇帝玺，丞相、御史、大将军、军吏、中二千石、都官令、丞印，及旁近郡太守、都尉印，汉使节法冠，欲如伍被计。", "len": 64}
{"sid": "118_淮南衡山列传.20.1.s24", "chapter": "118_淮南衡山列传", "para": "20.1", "seq": 24, "text": "使人伪得罪而西，事大将军、丞相；一日发兵，使人即刺杀大将军青，而说丞相下之，如发蒙耳。", "len": 43}
{"sid": "118_淮南衡山列传.21.s1", "chapter": "118_淮南衡山列传", "para": "21", "seq": 1, "text": "王欲发国中兵，恐其相、二千石不听。", "len": 17}
{"sid": "118_淮南衡山列传.21.s2", "chapter": "118_淮南衡山列传", "para": "21", "seq": 2, "text": "王乃与伍被谋，先杀相、二千石；伪失火宫中，相、二千石救火，至即杀之。", "len": 34}
{"sid": "118_淮南衡山列传.21.s3", "chapter": "118_淮南衡山列传", "para": "21", "seq": 3, "text": "计未决，又欲令人衣求盗衣，持羽檄，从东方来，呼曰“南越兵入界”，欲因以发兵。", "len": 38}
{"sid": "118_淮南衡山列传.21.s4", "chapter": "118_淮南衡山列传", "para": "21", "seq": 4, "text": "乃使人至庐江、会稽为求盗，未发。", "len": 16}
{"sid": "118_淮南衡山列传.21.s5", "chapter": "118_淮南衡山列传", "para": "21", "seq": 5, "text": "王问伍被曰：“吾举兵西乡，诸侯必有应我者；即无应，柰何？", "len": 28}
{"sid": "118_淮南衡山列传.21.s6", "chapter": "118_淮南衡山列传", "para": "21", "seq": 6, "text": "” 被曰：“南收衡山以击庐江，有寻阳之船，守下雉之城，结九江之浦，绝豫章之口，彊弩临江而守，以禁南郡之下，东收江都、会稽，南通劲越，屈彊江淮间，犹可得延岁月之寿。", "len": 81}
{"sid": "118_淮南衡山列传.21.s7", "chapter": "118_淮南衡山列传", "para": "21", "seq": 7, "text": "” 王曰：“善，无以易此。", "len": 13}
{"sid": "118_淮南衡山列传.21.s8", "chapter": "118_淮南衡山列传", "para": "21", "seq": 8, "text": "急则走越耳。”", "len": 7}
{"sid": "118_淮南衡山列传.22.s1", "chapter": "118_淮南衡山列传", "para": "22", "seq": 1, "text": "於是廷尉以王孙建辞连淮南王太子迁闻。", "len": 18}
{"sid": "118_淮南衡山列传.22.s2", "chapter": "118_淮南衡山列传", "para": "22", "seq": 2, "text": "上遣廷尉监因拜淮南中尉，逮捕太子。", "len": 17}
{"sid": "118_淮南衡山列传.22.s3", "chapter": "118_淮南衡山列传", "para": "22", "seq": 3, "text": "至淮南，淮南王闻，与太子谋召相、二千石，欲杀而发兵。", "len": 26}
{"sid": "118_淮南衡山列传.22.s4", "chapter": "118_淮南衡山列传", "para": "22", "seq": 4, "text": "召相，相至；内史以出为解。", "len": 13}
{"sid": "118_淮南衡山列传.22.s5", "chapter": "118_淮南衡山列传", "para": "22", "seq": 5, "text": "中尉曰：“臣受诏使，不得见王。", "len": 15}
{"sid": "118_淮南衡山列传.22.s6", "chapter": "118_淮南衡山列传", "para": "22", "seq": 6, "text": "” 王念独杀相而内史中尉不来，无益也，即罢相。", "len": 23}
{"sid": "118_淮南衡山列传.22.s7", "chapter": "118_淮南衡山列传", "para": "22", "seq": 7, "text": "王犹豫，计未决。", "len": 8}
{"sid": "118_淮南衡山列传.22.s8", "chapter": "118_淮南衡山列传", "para": "22", "seq": 8, "text": "太子念所坐者谋刺汉中尉，所与谋者已死，以为口绝，乃谓王曰：“群臣可用者皆前系，今无足与举事者。", "len": 47}
{"sid": "118_淮南衡山列传.22.s9", "chapter": "118_淮南衡山列传", "para": "22", "seq": 9, "text": "王以非时发，恐无功，臣原会逮。", "len": 15}
{"sid": "118_淮南衡山列传.22.s10", "chapter": "118_淮南衡山列传", "para": "22", "seq": 10, "text": "” 王亦偷欲休，即许太子。", "len": 13}
{"sid": "118_淮南衡山列传.22.s11", "chapter": "118_淮南衡山列传", "para": "22", "seq": 11, "text": "太子即自刭，不殊。", "len": 9}
{"sid": "118_淮南衡山列传.22.s12", "chapter": "118_淮南衡山列传", "para": "22", "seq": 12, "text": "伍被自诣吏，因告与淮南王谋反，反踪迹具如此。", "len": 22}
{"sid": "118_淮南衡山列传.23.s1", "chapter": "118_淮南衡山列传", "para": "23", "seq": 1, "text": "吏因捕太子、王后，围王宫，尽求捕王所与谋反宾客在国中者，索得反具以闻。", "len": 35}
{"sid": "118_淮南衡山列传.23.s2", "chapter": "118_淮南衡山列传", "para": "23", "seq": 2, "text": "上下公卿治，所连引与淮南王谋反列侯二千石豪杰数千人，皆以罪轻重受诛。", "len": 34}
{"sid": "118_淮南衡山列传.23.s3", "chapter": "118_淮南衡山列传", "para": "23", "seq": 3, "text": "衡山王赐，淮南王弟也，当坐收，有司请逮捕衡山王。", "len": 24}
{"sid": "118_淮南衡山列传.23.s4", "chapter": "118_淮南衡山列传", "para": "23", "seq": 4, "text": "天子曰：“诸侯各以其国为本，不当相坐。", "len": 19}
{"sid": "118_淮南衡山列传.23.s5", "chapter": "118_淮南衡山列传", "para": "23", "seq": 5, "text": "与诸侯王列侯会肄丞相诸侯议。", "len": 14}
{"sid": "118_淮南衡山列传.23.s6", "chapter": "118_淮南衡山列传", "para": "23", "seq": 6, "text": "” 赵王彭祖、列侯臣让等四十三人议，皆曰：“淮南王安甚大逆无道，谋反明白，当伏诛。", "len": 41}
{"sid": "118_淮南衡山列传.23.s7", "chapter": "118_淮南衡山列传", "para": "23", "seq": 7, "text": "” 胶西王臣端议曰：“淮南王安废法行邪，怀诈伪心，以乱天下，荧惑百姓，倍畔宗庙，妄作妖言。", "len": 45}
{"sid": "118_淮南衡山列传.23.s8", "chapter": "118_淮南衡山列传", "para": "23", "seq": 8, "text": "春秋曰‘臣无将，将而诛’。", "len": 13}
{"sid": "118_淮南衡山列传.23.1.s1", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 1, "text": "安罪重於将，谋反形已定。", "len": 12}
{"sid": "118_淮南衡山列传.23.1.s2", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 2, "text": "臣端所见其书节印图及他逆无道事验明白，甚大逆无道，当伏其法。", "len": 30}
{"sid": "118_淮南衡山列传.23.1.s3", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 3, "text": "而论国吏二百石以上及比者，宗室近幸臣不在法中者，不能相教，当皆免官削爵为士伍，毋得宦为吏。", "len": 45}
{"sid": "118_淮南衡山列传.23.1.s4", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 4, "text": "其非吏，他赎死金二斤八两。", "len": 13}
{"sid": "118_淮南衡山列传.23.1.s5", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 5, "text": "以章臣安之罪，使天下明知臣子之道，毋敢复有邪僻倍畔之意。", "len": 28}
{"sid": "118_淮南衡山列传.23.1.s6", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 6, "text": "“丞相弘、廷尉汤等以闻，天子使宗正以符节治王。", "len": 23}
{"sid": "118_淮南衡山列传.23.1.s7", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 7, "text": "未至，淮南王安自刭杀。", "len": 11}
{"sid": "118_淮南衡山列传.23.1.s8", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 8, "text": "王后荼、太子迁诸所与谋反者皆族。", "len": 16}
{"sid": "118_淮南衡山列传.23.1.s9", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 9, "text": "天子以伍被雅辞多引汉之美，欲勿诛。", "len": 17}
{"sid": "118_淮南衡山列传.23.1.s10", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 10, "text": "廷尉汤曰：“被首为王画反谋，被罪无赦。", "len": 19}
{"sid": "118_淮南衡山列传.23.1.s11", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 11, "text": "“遂诛被。", "len": 5}
{"sid": "118_淮南衡山列传.23.1.s12", "chapter": "118_淮南衡山列传", "para": "23.1", "seq": 12, "text": "国除为九江郡。", "len": 7}
{"sid": "118_淮南衡山列传.24.s1", "chapter": "118_淮南衡山列传", "para": "24", "seq": 1, "text": "衡山王赐，王后乘舒生子三人，长男爽为太子，次男孝，次女无采。", "len": 30}
{"sid": "118_淮南衡山列传.24.s2", "chapter": "118_淮南衡山列传", "para": "24", "seq": 2, "text": "又姬徐来生子男女四人，美人厥姬生子二人。", "len": 20}
{"sid": "118_淮南衡山列传.24.s3", "chapter": "118_淮南衡山列传", "para": "24", "seq": 3, "text": "衡山王、淮南王兄弟相责望礼节，间不相能。", "len": 20}
{"sid": "118_淮南衡山列传.24.s4", "chapter": "118_淮南衡山列传", "para": "24", "seq": 4, "text": "衡山王闻淮南王作为畔逆反具，亦心结宾客以应之，恐为所并。", "len": 28}
{"sid": "118_淮南衡山列传.25.s1", "chapter": "118_淮南衡山列传", "para": "25", "seq": 1, "text": "元光六年，衡山王入朝，其谒者卫庆有方术，欲上书事天子，王怒，故劾庆死罪，彊榜服之。", "len": 41}
{"sid": "118_淮南衡山列传.25.s2", "chapter": "118_淮南衡山列传", "para": "25", "seq": 2, "text": "衡山内史以为非是，卻其狱。", "len": 13}
{"sid": "118_淮南衡山列传.25.s3", "chapter": "118_淮南衡山列传", "para": "25", "seq": 3, "text": "王使人上书告内史，内史治，言王不直。", "len": 18}
{"sid": "118_淮南衡山列传.25.s4", "chapter": "118_淮南衡山列传", "para": "25", "seq": 4, "text": "王又数侵夺人田，坏人冢以为田。", "len": 15}
{"sid": "118_淮南衡山列传.25.s5", "chapter": "118_淮南衡山列传", "para": "25", "seq": 5, "text": "有司请逮治衡山王。", "len": 9}
{"sid": "118_淮南衡山列传.25.s6", "chapter": "118_淮南衡山列传", "para": "25", "seq": 6, "text": "天子不许，为置吏二百石以上。", "len": 14}
{"sid": "118_淮南衡山列传.25.s7", "chapter": "118_淮南衡山列传", "para": "25", "seq": 7, "text": "衡山王以此恚，与奚慈、张广昌谋，求能为兵法候星气者，日夜从容王密谋反事。", "len": 36}
{"sid": "118_淮南衡山列传.26.s1", "chapter": "118_淮南衡山列传", "para": "26", "seq": 1, "text": "王后乘舒死，立徐来为王后。", "len": 13}
{"sid": "118_淮南衡山列传.26.s2", "chapter": "118_淮南衡山列传", "para": "26", "seq": 2, "text": "厥姬俱幸。", "len": 5}
{"sid": "118_淮南衡山列传.26.s3", "chapter": "118_淮南衡山列传", "para": "26", "seq": 3, "text": "两人相妒，厥姬乃恶王后徐来於太子曰：“徐来使婢蛊道杀太子母。", "len": 30}
{"sid": "118_淮南衡山列传.26.s4", "chapter": "118_淮南衡山列传", "para": "26", "seq": 4, "text": "” 太子心怨徐来。", "len": 9}
{"sid": "118_淮南衡山列传.26.s5", "chapter": "118_淮南衡山列传", "para": "26", "seq": 5, "text": "徐来兄至衡山，太子与饮，以刃刺伤王后兄。", "len": 20}
{"sid": "118_淮南衡山列传.26.s6", "chapter": "118_淮南衡山列传", "para": "26", "seq": 6, "text": "王后怨怒，数毁恶太子於王。", "len": 13}
{"sid": "118_淮南衡山列传.26.s7", "chapter": "118_淮南衡山列传", "para": "26", "seq": 7, "text": "太子女弟无采，嫁弃归，与奴奸，又与客奸。", "len": 20}
{"sid": "118_淮南衡山列传.26.s8", "chapter": "118_淮南衡山列传", "para": "26", "seq": 8, "text": "太子数让无采，无采怒，不与太子通。", "len": 17}
{"sid": "118_淮南衡山列传.26.s9", "chapter": "118_淮南衡山列传", "para": "26", "seq": 9, "text": "王后闻之，即善遇无采。", "len": 11}
{"sid": "118_淮南衡山列传.26.s10", "chapter": "118_淮南衡山列传", "para": "26", "seq": 10, "text": "无采及中兄孝少失母，附王后，王后以计爱之，与共毁太子，王以故数击笞太子。", "len": 36}
{"sid": "118_淮南衡山列传.26.s11", "chapter": "118_淮南衡山列传", "para": "26", "seq": 11, "text": "元朔四年中，人有贼伤王后假母者，王疑太子使人伤之，笞太子。", "len": 29}
{"sid": "118_淮南衡山列传.26.s12", "chapter": "118_淮南衡山列传", "para": "26", "seq": 12, "text": "後王病，太子时称病不侍。", "len": 12}
{"sid": "118_淮南衡山列传.26.s13", "chapter": "118_淮南衡山列传", "para": "26", "seq": 13, "text": "孝、王后、无采恶太子：“太子实不病，自言病，有喜色。", "len": 26}
{"sid": "118_淮南衡山列传.26.s14", "chapter": "118_淮南衡山列传", "para": "26", "seq": 14, "text": "” 王大怒，欲废太子，立其弟孝。", "len": 16}
{"sid": "118_淮南衡山列传.26.s15", "chapter": "118_淮南衡山列传", "para": "26", "seq": 15, "text": "王后知王决废太子，又欲并废孝。", "len": 15}
{"sid": "118_淮南衡山列传.26.s16", "chapter": "118_淮南衡山列传", "para": "26", "seq": 16, "text": "王后有侍者，善舞，王幸之，王后欲令侍者与孝乱以汙之，欲并废兄弟而立其子广代太子。", "len": 40}
{"sid": "118_淮南衡山列传.26.s17", "chapter": "118_淮南衡山列传", "para": "26", "seq": 17, "text": "太子爽知之，念后数恶己无已时，欲与乱以止其口。", "len": 23}
{"sid": "118_淮南衡山列传.26.s18", "chapter": "118_淮南衡山列传", "para": "26", "seq": 18, "text": "王后饮，太子前为寿，因据王后股，求与王后卧。", "len": 22}
{"sid": "118_淮南衡山列传.26.s19", "chapter": "118_淮南衡山列传", "para": "26", "seq": 19, "text": "王后怒，以告王。", "len": 8}
{"sid": "118_淮南衡山列传.26.s20", "chapter": "118_淮南衡山列传", "para": "26", "seq": 20, "text": "王乃召，欲缚而笞之。", "len": 10}
{"sid": "118_淮南衡山列传.26.s21", "chapter": "118_淮南衡山列传", "para": "26", "seq": 21, "text": "太子知王常欲废己立其弟孝，乃谓王曰：“孝与王御者奸，无采与奴奸，王彊食，请上书。", "len": 40}
{"sid": "118_淮南衡山列传.26.s22", "chapter": "118_淮南衡山列传", "para": "26", "seq": 22, "text": "” 即倍王去。", "len": 7}
{"sid": "118_淮南衡山列传.26.s23", "chapter": "118_淮南衡山列传", "para": "26", "seq": 23, "text": "王使人止之，莫能禁，乃自驾追捕太子。", "len": 18}
{"sid": "118_淮南衡山列传.26.s24", "chapter": "118_淮南衡山列传", "para": "26", "seq": 24, "text": "太子妄恶言，王械系太子宫中。", "len": 14}
{"sid": "118_淮南衡山列传.26.s25", "chapter": "118_淮南衡山列传", "para": "26", "seq": 25, "text": "孝日益亲幸。", "len": 6}
{"sid": "118_淮南衡山列传.26.s26", "chapter": "118_淮南衡山列传", "para": "26", "seq": 26, "text": "王奇孝材能，乃佩之王印，号曰将军，令居外宅，多给金钱，招致宾客。", "len": 32}
{"sid": "118_淮南衡山列传.26.s27", "chapter": "118_淮南衡山列传", "para": "26", "seq": 27, "text": "宾客来者，微知淮南、衡山有逆计，日夜从容劝之。", "len": 23}
{"sid": "118_淮南衡山列传.26.s28", "chapter": "118_淮南衡山列传", "para": "26", "seq": 28, "text": "王乃使孝客江都人救赫、陈喜作輣车镞矢，刻天子玺，将相军吏印。", "len": 30}
{"sid": "118_淮南衡山列传.26.s29", "chapter": "118_淮南衡山列传", "para": "26", "seq": 29, "text": "王日夜求壮士如周丘等，数称引吴楚反时计画，以约束。", "len": 25}
{"sid": "118_淮南衡山列传.26.s30", "chapter": "118_淮南衡山列传", "para": "26", "seq": 30, "text": "衡山王非敢效淮南王求即天子位，畏淮南起并其国，以为淮南已西，发兵定江淮之间而有之，望如是。", "len": 45}
{"sid": "118_淮南衡山列传.27.s1", "chapter": "118_淮南衡山列传", "para": "27", "seq": 1, "text": "元朔五年秋，衡山王当朝，过淮南，淮南王乃昆弟语，除前卻，约束反具。", "len": 33}
{"sid": "118_淮南衡山列传.27.s2", "chapter": "118_淮南衡山列传", "para": "27", "seq": 2, "text": "衡山王即上书谢病，上赐书不朝。", "len": 15}
{"sid": "118_淮南衡山列传.28.s1", "chapter": "118_淮南衡山列传", "para": "28", "seq": 1, "text": "元朔六年中，衡山王使人上书请废太子爽，立孝为太子。", "len": 25}
{"sid": "118_淮南衡山列传.28.s2", "chapter": "118_淮南衡山列传", "para": "28", "seq": 2, "text": "爽闻，即使所善白嬴之长安上书，言孝作輣车镞矢，与王御者奸，欲以败孝。", "len": 34}
{"sid": "118_淮南衡山列传.28.s3", "chapter": "118_淮南衡山列传", "para": "28", "seq": 3, "text": "白嬴至长安，未及上书，吏捕嬴，以淮南事系。", "len": 21}
{"sid": "118_淮南衡山列传.28.s4", "chapter": "118_淮南衡山列传", "para": "28", "seq": 4, "text": "王闻爽使白嬴上书，恐言国阴事，即上书反告太子爽所为不道弃市罪事。", "len": 32}
{"sid": "118_淮南衡山列传.28.s5", "chapter": "118_淮南衡山列传", "para": "28", "seq": 5, "text": "事下沛郡治。", "len": 6}
{"sid": "118_淮南衡山列传.28.s6", "chapter": "118_淮南衡山列传", "para": "28", "seq": 6, "text": "元年冬，有司公卿下沛郡求捕所与淮南谋反者未得，得陈喜於衡山王子孝家。", "len": 34}
{"sid": "118_淮南衡山列传.28.s7", "chapter": "118_淮南衡山列传", "para": "28", "seq": 7, "text": "吏劾孝首匿喜。", "len": 7}
{"sid": "118_淮南衡山列传.28.s8", "chapter": "118_淮南衡山列传", "para": "28", "seq": 8, "text": "孝以为陈喜雅数与王计谋反，恐其发之，闻律先自告除其罪，又疑太子使白嬴上书发其事，即先自告，告所与谋反者救赫、陈喜等。", "len": 58}
{"sid": "118_淮南衡山列传.28.s9", "chapter": "118_淮南衡山列传", "para": "28", "seq": 9, "text": "廷尉治验，公卿请逮捕衡山王治之。", "len": 16}
{"sid": "118_淮南衡山列传.28.s10", "chapter": "118_淮南衡山列传", "para": "28", "seq": 10, "text": "天子曰：“勿捕。", "len": 8}
{"sid": "118_淮南衡山列传.28.s11", "chapter": "118_淮南衡山列传", "para": "28", "seq": 11, "text": "” 遣中尉安、大行息即问王，王具以情实对。", "len": 21}
{"sid": "118_淮南衡山列传.28.s12", "chapter": "118_淮南衡山列传", "para": "28", "seq": 12, "text": "吏皆围王宫而守之。", "len": 9}
{"sid": "118_淮南衡山列传.28.s13", "chapter": "118_淮南衡山列传", "para": "28", "seq": 13, "text": "中尉大行还，以闻，公卿请遣宗正、大行与沛郡杂治王。", "len": 25}
{"sid": "118_淮南衡山列传.28.s14", "chapter": "118_淮南衡山列传", "para": "28", "seq": 14, "text": "王闻，即自刭杀。", "len": 8}
{"sid": "118_淮南衡山列传.28.s15", "chapter": "118_淮南衡山列传", "para": "28", "seq": 15, "text": "孝先自告反，除其罪；坐与王御婢奸，弃市。", "len": 20}
{"sid": "118_淮南衡山列传.28.s16", "chapter": "118_淮南衡山列传", "para": "28", "seq": 16, "text": "王后徐来亦坐蛊杀前王后乘舒，及太子爽坐王告不孝，皆弃市。", "len": 28}
{"sid": "118_淮南衡山列传.28.s17", "chapter": "118_淮南衡山列传", "para": "28", "seq": 17, "text": "诸与衡山王谋反者皆族。", "len": 11}
{"sid": "118_淮南衡山列传.28.s18", "chapter": "118_淮南衡山列传", "para": "28", "seq": 18, "text": "国除为衡山郡。", "len": 7}
{"sid": "118_淮南衡山列传.28.s19", "chapter": "118_淮南衡山列传", "para": "28", "seq": 19, "text": "::: 太史公曰", "len": 8}
{"sid": "118_淮南衡山列传.29.s1", "chapter": "118_淮南衡山列传", "para": "29", "seq": 1, "text": "太史公曰：诗之所谓“戎狄是膺，荆舒是惩”，信哉是言也。", "len": 27}
{"sid": "118_淮南衡山列传.29.s2", "chapter": "118_淮南衡山列传", "para": "29", "seq": 2, "text": "淮南、衡山亲为骨肉，疆土千里，列为诸侯，不务遵蕃臣职以承辅天子，而专挟邪僻之计，谋为畔逆，仍父子再亡国，各不终其身，为天下笑。", "len": 63}
{"sid": "118_淮南衡山列传.29.s3", "chapter": "118_淮南衡山列传", "para": "29", "seq": 3, "text": "此非独王过也，亦其俗薄，臣下渐靡使然也。", "len": 20}
{"sid": "118_淮南衡山列传.29.s4", "chapter": "118_淮南衡山列传", "para": "29", "seq": 4, "text": "夫荆楚僄勇轻悍，好作乱，乃自古记之矣。", "len": 19}
{"sid": "118_淮南衡山列传.29.s5", "chapter": "118_淮南衡山列传", "para": "29", "seq": 5, "text": "::: ::: 赞", "len": 9}
{"sid": "118_淮南衡山列传.30.s1", "chapter": "118_淮南衡山列传", "para": "30", "seq": 1, "text": "淮南多横，举事非正。", "len": 10}
{"sid": "118_淮南衡山列传.30.s2", "chapter": "118_淮南衡山列传", "para": "30", "seq": 2, "text": "天子宽仁，其过不更。", "len": 10}
{"sid": "118_淮南衡山列传.30.s3", "chapter": "118_淮南衡山列传", "para": "30", "seq": 3, "text": "轞车致祸，斗粟成咏。", "len": 10}
{"sid": "118_淮南衡山列传.30.s4", "chapter": "118_淮南衡山列传", "para": "30", "seq": 4, "text": "王安好学，女陵作诇。", "len": 10}
{"sid": "118_淮南衡山列传.30.s5", "chapter": "118_淮南衡山列传", "para": "30", "seq": 5, "text": "兄弟不和，倾国殒命。", "len": 10}
{"sid": "118_淮南衡山列传.30.s6", "chapter": "118_淮南衡山列传", "para": "30", "seq": 6, "text": ":::", "len": 3}
