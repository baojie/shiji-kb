{"sid": "122_酷吏列传.1.s1", "chapter": "122_酷吏列传", "para": "1", "seq": 1, "text": "孔子曰：“导之以政，齐之以刑，民免而无耻。", "len": 21}
{"sid": "122_酷吏列传.1.s2", "chapter": "122_酷吏列传", "para": "1", "seq": 2, "text": "导之以德，齐之以礼，有耻且格。", "len": 15}
{"sid": "122_酷吏列传.1.s3", "chapter": "122_酷吏列传", "para": "1", "seq": 3, "text": "” 老氏称：“上德不德，是以有德；下德不失德，是以无德。", "len": 28}
{"sid": "122_酷吏列传.1.s4", "chapter": "122_酷吏列传", "para": "1", "seq": 4, "text": "法令滋章，盗贼多有。", "len": 10}
{"sid": "122_酷吏列传.1.s5", "chapter": "122_酷吏列传", "para": "1", "seq": 5, "text": "” 太史公曰：信哉是言也！", "len": 13}
{"sid": "122_酷吏列传.1.s6", "chapter": "122_酷吏列传", "para": "1", "seq": 6, "text": "法令者治之具，而非制治清浊之源也。", "len": 17}
{"sid": "122_酷吏列传.1.s7", "chapter": "122_酷吏列传", "para": "1", "seq": 7, "text": "昔天下之网尝密矣，然奸伪萌起，其极也，上下相遁，至於不振。", "len": 29}
{"sid": "122_酷吏列传.1.s8", "chapter": "122_酷吏列传", "para": "1", "seq": 8, "text": "当是之时，吏治若救火扬沸，非武健严酷，恶能胜其任而愉快乎！", "len": 29}
{"sid": "122_酷吏列传.1.s9", "chapter": "122_酷吏列传", "para": "1", "seq": 9, "text": "言道德者，溺其职矣。", "len": 10}
{"sid": "122_酷吏列传.1.s10", "chapter": "122_酷吏列传", "para": "1", "seq": 10, "text": "故曰“听讼，吾犹人也，必也使无讼乎”。", "len": 19}
{"sid": "122_酷吏列传.1.s11", "chapter": "122_酷吏列传", "para": "1", "seq": 11, "text": "“下士闻道大笑之”。", "len": 10}
{"sid": "122_酷吏列传.1.s12", "chapter": "122_酷吏列传", "para": "1", "seq": 12, "text": "非虚言也。", "len": 5}
{"sid": "122_酷吏列传.1.s13", "chapter": "122_酷吏列传", "para": "1", "seq": 13, "text": "汉兴，破觚而为圜，斫雕而为朴，网漏於吞舟之鱼，而吏治烝烝，不至於奸，黎民艾安。", "len": 39}
{"sid": "122_酷吏列传.1.s14", "chapter": "122_酷吏列传", "para": "1", "seq": 14, "text": "由是观之，在彼不在此。", "len": 11}
{"sid": "122_酷吏列传.2.s1", "chapter": "122_酷吏列传", "para": "2", "seq": 1, "text": "高后时，酷吏独有侯封，刻轹宗室，侵辱功臣。", "len": 21}
{"sid": "122_酷吏列传.2.s2", "chapter": "122_酷吏列传", "para": "2", "seq": 2, "text": "吕氏已败，遂侯封之家。", "len": 11}
{"sid": "122_酷吏列传.2.s3", "chapter": "122_酷吏列传", "para": "2", "seq": 3, "text": "孝景时，晁错以刻深颇用术辅其资，而七国之乱，发怒於错，错卒以被戮。", "len": 33}
{"sid": "122_酷吏列传.2.s4", "chapter": "122_酷吏列传", "para": "2", "seq": 4, "text": "其後有郅都、宁成之属。", "len": 11}
{"sid": "122_酷吏列传.3.s1", "chapter": "122_酷吏列传", "para": "3", "seq": 1, "text": "郅都者，杨人也。", "len": 8}
{"sid": "122_酷吏列传.3.s2", "chapter": "122_酷吏列传", "para": "3", "seq": 2, "text": "以郎事孝文帝。", "len": 7}
{"sid": "122_酷吏列传.3.s3", "chapter": "122_酷吏列传", "para": "3", "seq": 3, "text": "孝景时，都为中郎将，敢直谏，面折大臣於朝。", "len": 21}
{"sid": "122_酷吏列传.3.s4", "chapter": "122_酷吏列传", "para": "3", "seq": 4, "text": "尝从入上林，贾姬如厕，野彘卒入厕。", "len": 17}
{"sid": "122_酷吏列传.3.s5", "chapter": "122_酷吏列传", "para": "3", "seq": 5, "text": "上目都，都不行。", "len": 8}
{"sid": "122_酷吏列传.3.s6", "chapter": "122_酷吏列传", "para": "3", "seq": 6, "text": "上欲自持兵救贾姬，都伏上前曰：“亡一姬复一姬进，天下所少宁贾姬等乎？", "len": 34}
{"sid": "122_酷吏列传.3.s7", "chapter": "122_酷吏列传", "para": "3", "seq": 7, "text": "陛下纵自轻，柰宗庙太后何！", "len": 13}
{"sid": "122_酷吏列传.3.s8", "chapter": "122_酷吏列传", "para": "3", "seq": 8, "text": "” 上还，彘亦去。", "len": 9}
{"sid": "122_酷吏列传.3.s9", "chapter": "122_酷吏列传", "para": "3", "seq": 9, "text": "太后闻之，赐都金百斤，由此重郅都。", "len": 17}
{"sid": "122_酷吏列传.4.s1", "chapter": "122_酷吏列传", "para": "4", "seq": 1, "text": "济南瞷氏宗人三百馀家，豪猾，二千石莫能制，於是景帝乃拜都为济南太守。", "len": 34}
{"sid": "122_酷吏列传.4.s2", "chapter": "122_酷吏列传", "para": "4", "seq": 2, "text": "至则族灭瞷氏首恶，馀皆股栗。", "len": 14}
{"sid": "122_酷吏列传.4.s3", "chapter": "122_酷吏列传", "para": "4", "seq": 3, "text": "居岁馀，郡中不拾遗。", "len": 10}
{"sid": "122_酷吏列传.4.s4", "chapter": "122_酷吏列传", "para": "4", "seq": 4, "text": "旁十馀郡守畏都如大府。", "len": 11}
{"sid": "122_酷吏列传.5.s1", "chapter": "122_酷吏列传", "para": "5", "seq": 1, "text": "都为人勇，有气力，公廉，不发私书，问遗无所受，请寄无所听。", "len": 29}
{"sid": "122_酷吏列传.5.s2", "chapter": "122_酷吏列传", "para": "5", "seq": 2, "text": "常自称曰：“已倍亲而仕，身固当奉职死节官下，终不顾妻子矣。”", "len": 30}
{"sid": "122_酷吏列传.6.s1", "chapter": "122_酷吏列传", "para": "6", "seq": 1, "text": "郅都迁为中尉。", "len": 7}
{"sid": "122_酷吏列传.6.s2", "chapter": "122_酷吏列传", "para": "6", "seq": 2, "text": "丞相条侯至贵倨也，而都揖丞相。", "len": 15}
{"sid": "122_酷吏列传.6.s3", "chapter": "122_酷吏列传", "para": "6", "seq": 3, "text": "是时民朴，畏罪自重，而都独先严酷，致行法不避贵戚，列侯宗室见都侧目而视，号曰“苍鹰”。", "len": 43}
{"sid": "122_酷吏列传.7.s1", "chapter": "122_酷吏列传", "para": "7", "seq": 1, "text": "临江王徵诣中尉府对簿，临江王欲得刀笔为书谢上，而都禁吏不予。", "len": 30}
{"sid": "122_酷吏列传.7.s2", "chapter": "122_酷吏列传", "para": "7", "seq": 2, "text": "魏其侯使人以间与临江王。", "len": 12}
{"sid": "122_酷吏列传.7.s3", "chapter": "122_酷吏列传", "para": "7", "seq": 3, "text": "临江王既为书谢上，因自杀。", "len": 13}
{"sid": "122_酷吏列传.7.s4", "chapter": "122_酷吏列传", "para": "7", "seq": 4, "text": "窦太后闻之，怒，以危法中都，都免归家。", "len": 19}
{"sid": "122_酷吏列传.7.s5", "chapter": "122_酷吏列传", "para": "7", "seq": 5, "text": "孝景帝乃使使持节拜都为雁门太守，而便道之官，得以便宜从事。", "len": 29}
{"sid": "122_酷吏列传.7.s6", "chapter": "122_酷吏列传", "para": "7", "seq": 6, "text": "匈奴素闻郅都节，居边，为引兵去，竟郅都死不近雁门。", "len": 25}
{"sid": "122_酷吏列传.7.s7", "chapter": "122_酷吏列传", "para": "7", "seq": 7, "text": "匈奴至为偶人象郅都，令骑驰射莫能中，见惮如此。", "len": 23}
{"sid": "122_酷吏列传.7.s8", "chapter": "122_酷吏列传", "para": "7", "seq": 8, "text": "匈奴患之。", "len": 5}
{"sid": "122_酷吏列传.7.s9", "chapter": "122_酷吏列传", "para": "7", "seq": 9, "text": "窦太后乃竟中都以汉法。", "len": 11}
{"sid": "122_酷吏列传.7.s10", "chapter": "122_酷吏列传", "para": "7", "seq": 10, "text": "景帝曰：“都忠臣。", "len": 9}
{"sid": "122_酷吏列传.7.s11", "chapter": "122_酷吏列传", "para": "7", "seq": 11, "text": "” 欲释之。", "len": 6}
{"sid": "122_酷吏列传.7.s12", "chapter": "122_酷吏列传", "para": "7", "seq": 12, "text": "窦太后曰：”临江王独非忠臣邪？", "len": 15}
{"sid": "122_酷吏列传.7.s13", "chapter": "122_酷吏列传", "para": "7", "seq": 13, "text": "” 於是遂斩郅都。", "len": 9}
{"sid": "122_酷吏列传.8.s1", "chapter": "122_酷吏列传", "para": "8", "seq": 1, "text": "宁成者，穰人也。", "len": 8}
{"sid": "122_酷吏列传.8.s2", "chapter": "122_酷吏列传", "para": "8", "seq": 2, "text": "以郎谒者事景帝。", "len": 8}
{"sid": "122_酷吏列传.8.s3", "chapter": "122_酷吏列传", "para": "8", "seq": 3, "text": "好气，为人小吏，必陵其长吏；为人上，操下如束湿薪。", "len": 25}
{"sid": "122_酷吏列传.8.s4", "chapter": "122_酷吏列传", "para": "8", "seq": 4, "text": "滑贼任威。", "len": 5}
{"sid": "122_酷吏列传.8.s5", "chapter": "122_酷吏列传", "para": "8", "seq": 5, "text": "稍迁至济南都尉，而郅都为守。", "len": 14}
{"sid": "122_酷吏列传.8.s6", "chapter": "122_酷吏列传", "para": "8", "seq": 6, "text": "始前数都尉皆步入府，因吏谒守如县令，其畏郅都如此。", "len": 25}
{"sid": "122_酷吏列传.8.s7", "chapter": "122_酷吏列传", "para": "8", "seq": 7, "text": "及成往，直陵都出其上。", "len": 11}
{"sid": "122_酷吏列传.8.s8", "chapter": "122_酷吏列传", "para": "8", "seq": 8, "text": "都素闻其声，於是善遇，与结驩。", "len": 15}
{"sid": "122_酷吏列传.8.s9", "chapter": "122_酷吏列传", "para": "8", "seq": 9, "text": "久之，郅都死，後长安左右宗室多暴犯法，於是上召宁成为中尉。", "len": 29}
{"sid": "122_酷吏列传.8.s10", "chapter": "122_酷吏列传", "para": "8", "seq": 10, "text": "其治效郅都，其廉弗如，然宗室豪桀皆人人惴恐。", "len": 22}
{"sid": "122_酷吏列传.9.s1", "chapter": "122_酷吏列传", "para": "9", "seq": 1, "text": "武帝即位，徙为内史。", "len": 10}
{"sid": "122_酷吏列传.9.s2", "chapter": "122_酷吏列传", "para": "9", "seq": 2, "text": "外戚多毁成之短，抵罪髡钳。", "len": 13}
{"sid": "122_酷吏列传.9.s3", "chapter": "122_酷吏列传", "para": "9", "seq": 3, "text": "是时九卿罪死即死，少被刑，而成极刑，自以为不复收，於是解脱，诈刻传出关归家。", "len": 38}
{"sid": "122_酷吏列传.9.s4", "chapter": "122_酷吏列传", "para": "9", "seq": 4, "text": "称曰：“仕不至二千石，贾不至千万，安可比人乎！", "len": 23}
{"sid": "122_酷吏列传.9.s5", "chapter": "122_酷吏列传", "para": "9", "seq": 5, "text": "” 乃贳贷买陂田千馀顷，假贫民，役使数千家。", "len": 22}
{"sid": "122_酷吏列传.9.s6", "chapter": "122_酷吏列传", "para": "9", "seq": 6, "text": "数年，会赦。", "len": 6}
{"sid": "122_酷吏列传.9.s7", "chapter": "122_酷吏列传", "para": "9", "seq": 7, "text": "致产数千金，为任侠，持吏长短，出从数十骑。", "len": 21}
{"sid": "122_酷吏列传.9.s8", "chapter": "122_酷吏列传", "para": "9", "seq": 8, "text": "其使民威重於郡守。", "len": 9}
{"sid": "122_酷吏列传.10.s1", "chapter": "122_酷吏列传", "para": "10", "seq": 1, "text": "周阳由者，其父赵兼以淮南王舅父侯周阳，故因姓周阳氏。", "len": 26}
{"sid": "122_酷吏列传.10.s2", "chapter": "122_酷吏列传", "para": "10", "seq": 2, "text": "由以宗家任为郎，事孝文及景帝。", "len": 15}
{"sid": "122_酷吏列传.10.s3", "chapter": "122_酷吏列传", "para": "10", "seq": 3, "text": "景帝时，由为郡守。", "len": 9}
{"sid": "122_酷吏列传.10.s4", "chapter": "122_酷吏列传", "para": "10", "seq": 4, "text": "武帝即位，吏治尚循谨甚，然由居二千石中，最为暴酷骄恣。", "len": 27}
{"sid": "122_酷吏列传.10.s5", "chapter": "122_酷吏列传", "para": "10", "seq": 5, "text": "所爱者，挠法活之；所憎者，曲法诛灭之。", "len": 19}
{"sid": "122_酷吏列传.10.s6", "chapter": "122_酷吏列传", "para": "10", "seq": 6, "text": "所居郡，必夷其豪。", "len": 9}
{"sid": "122_酷吏列传.10.s7", "chapter": "122_酷吏列传", "para": "10", "seq": 7, "text": "为守，视都尉如令。", "len": 9}
{"sid": "122_酷吏列传.10.s8", "chapter": "122_酷吏列传", "para": "10", "seq": 8, "text": "为都尉，必陵太守，夺之治。", "len": 13}
{"sid": "122_酷吏列传.10.s9", "chapter": "122_酷吏列传", "para": "10", "seq": 9, "text": "与汲黯俱为忮，司马安之文恶，俱在二千石列，同车未尝敢均茵伏。", "len": 30}
{"sid": "122_酷吏列传.11.s1", "chapter": "122_酷吏列传", "para": "11", "seq": 1, "text": "由後为河东都尉，时与其守胜屠公争权，相告言罪。", "len": 23}
{"sid": "122_酷吏列传.11.s2", "chapter": "122_酷吏列传", "para": "11", "seq": 2, "text": "胜屠公当抵罪，义不受刑，自杀，而由弃市。", "len": 20}
{"sid": "122_酷吏列传.12.s1", "chapter": "122_酷吏列传", "para": "12", "seq": 1, "text": "自宁成、周阳由之後，事益多，民巧法，大抵吏之治类多成、由等矣。", "len": 31}
{"sid": "122_酷吏列传.13.s1", "chapter": "122_酷吏列传", "para": "13", "seq": 1, "text": "赵禹者，斄人。", "len": 7}
{"sid": "122_酷吏列传.13.s2", "chapter": "122_酷吏列传", "para": "13", "seq": 2, "text": "以佐史补中都官，用廉为令史，事太尉亚夫。", "len": 20}
{"sid": "122_酷吏列传.13.s3", "chapter": "122_酷吏列传", "para": "13", "seq": 3, "text": "亚夫为丞相，禹为丞相史，府中皆称其廉平。", "len": 20}
{"sid": "122_酷吏列传.13.s4", "chapter": "122_酷吏列传", "para": "13", "seq": 4, "text": "然亚夫弗任，曰：“极知禹无害，然文深，不可以居大府。", "len": 26}
{"sid": "122_酷吏列传.13.s5", "chapter": "122_酷吏列传", "para": "13", "seq": 5, "text": "” 今上时，禹以刀笔吏积劳，稍迁为御史。", "len": 20}
{"sid": "122_酷吏列传.13.s6", "chapter": "122_酷吏列传", "para": "13", "seq": 6, "text": "上以为能，至太中大夫。", "len": 11}
{"sid": "122_酷吏列传.13.s7", "chapter": "122_酷吏列传", "para": "13", "seq": 7, "text": "与张汤论定诸律令，作见知，吏传得相监司。", "len": 20}
{"sid": "122_酷吏列传.13.s8", "chapter": "122_酷吏列传", "para": "13", "seq": 8, "text": "用法益刻，盖自此始。", "len": 10}
{"sid": "122_酷吏列传.14.s1", "chapter": "122_酷吏列传", "para": "14", "seq": 1, "text": "张汤者，杜人也。", "len": 8}
{"sid": "122_酷吏列传.14.s2", "chapter": "122_酷吏列传", "para": "14", "seq": 2, "text": "其父为长安丞，出，汤为兒守舍。", "len": 15}
{"sid": "122_酷吏列传.14.s3", "chapter": "122_酷吏列传", "para": "14", "seq": 3, "text": "还而鼠盗肉，其父怒，笞汤。", "len": 13}
{"sid": "122_酷吏列传.14.s4", "chapter": "122_酷吏列传", "para": "14", "seq": 4, "text": "汤掘窟得盗鼠及馀肉，劾鼠掠治，传爰书，讯鞫论报，并取鼠与肉，具狱磔堂下。", "len": 36}
{"sid": "122_酷吏列传.14.s5", "chapter": "122_酷吏列传", "para": "14", "seq": 5, "text": "其父见之，视其文辞如老狱吏，大惊，遂使书狱。", "len": 22}
{"sid": "122_酷吏列传.14.s6", "chapter": "122_酷吏列传", "para": "14", "seq": 6, "text": "父死後，汤为长安吏，久之。", "len": 13}
{"sid": "122_酷吏列传.15.s1", "chapter": "122_酷吏列传", "para": "15", "seq": 1, "text": "周阳侯始为诸卿时，尝系长安，汤倾身为之。", "len": 20}
{"sid": "122_酷吏列传.15.s2", "chapter": "122_酷吏列传", "para": "15", "seq": 2, "text": "及出为侯，大与汤交，遍见汤贵人。", "len": 16}
{"sid": "122_酷吏列传.15.s3", "chapter": "122_酷吏列传", "para": "15", "seq": 3, "text": "汤给事内史，为宁成掾，以汤为无害，言大府，调为茂陵尉，治方中。", "len": 31}
{"sid": "122_酷吏列传.16.s1", "chapter": "122_酷吏列传", "para": "16", "seq": 1, "text": "武安侯为丞相，徵汤为史，时荐言之天子，补御史，使案事。", "len": 27}
{"sid": "122_酷吏列传.16.s2", "chapter": "122_酷吏列传", "para": "16", "seq": 2, "text": "治陈皇后蛊狱，深竟党与。", "len": 12}
{"sid": "122_酷吏列传.16.s3", "chapter": "122_酷吏列传", "para": "16", "seq": 3, "text": "於是上以为能，稍迁至太中大夫。", "len": 15}
{"sid": "122_酷吏列传.16.s4", "chapter": "122_酷吏列传", "para": "16", "seq": 4, "text": "与赵禹共定诸律令，务在深文，拘守职之吏。", "len": 20}
{"sid": "122_酷吏列传.16.s5", "chapter": "122_酷吏列传", "para": "16", "seq": 5, "text": "已而赵禹迁为中尉，徙为少府，而张汤为廷尉，两人交驩，而兄事禹。", "len": 31}
{"sid": "122_酷吏列传.16.s6", "chapter": "122_酷吏列传", "para": "16", "seq": 6, "text": "禹为人廉倨。", "len": 6}
{"sid": "122_酷吏列传.16.s7", "chapter": "122_酷吏列传", "para": "16", "seq": 7, "text": "为吏以来，舍毋食客。", "len": 10}
{"sid": "122_酷吏列传.16.s8", "chapter": "122_酷吏列传", "para": "16", "seq": 8, "text": "公卿相造请禹，禹终不报谢，务在绝知友宾客之请，孤立行一意而已。", "len": 31}
{"sid": "122_酷吏列传.16.s9", "chapter": "122_酷吏列传", "para": "16", "seq": 9, "text": "见文法辄取，亦不覆案，求官属阴罪。", "len": 17}
{"sid": "122_酷吏列传.16.s10", "chapter": "122_酷吏列传", "para": "16", "seq": 10, "text": "汤为人多诈，舞智以御人。", "len": 12}
{"sid": "122_酷吏列传.16.s11", "chapter": "122_酷吏列传", "para": "16", "seq": 11, "text": "始为小吏，乾没，与长安富贾田甲、鱼翁叔之属交私。", "len": 24}
{"sid": "122_酷吏列传.16.s12", "chapter": "122_酷吏列传", "para": "16", "seq": 12, "text": "及列九卿，收接天下名士大夫，己心内虽不合，然阳浮慕之。", "len": 27}
{"sid": "122_酷吏列传.17.s1", "chapter": "122_酷吏列传", "para": "17", "seq": 1, "text": "是时上方乡文学，汤决大狱，欲傅古义，乃请博士弟子治尚书、春秋补廷尉史，亭疑法。", "len": 39}
{"sid": "122_酷吏列传.17.s2", "chapter": "122_酷吏列传", "para": "17", "seq": 2, "text": "奏谳疑事，必豫先为上分别其原，上所是，受而著谳决法廷尉，絜令扬主之明。", "len": 35}
{"sid": "122_酷吏列传.17.s3", "chapter": "122_酷吏列传", "para": "17", "seq": 3, "text": "奏事即谴，汤应谢，乡上意所便，必引正、监、掾史贤者，曰：“固为臣议，如上责臣，臣弗用，愚抵於此。", "len": 48}
{"sid": "122_酷吏列传.17.s4", "chapter": "122_酷吏列传", "para": "17", "seq": 4, "text": "” 罪常释。", "len": 6}
{"sid": "122_酷吏列传.17.s5", "chapter": "122_酷吏列传", "para": "17", "seq": 5, "text": "即奏事，上善之，曰：“臣非知为此奏，乃正、监、掾史某为之。", "len": 29}
{"sid": "122_酷吏列传.17.s6", "chapter": "122_酷吏列传", "para": "17", "seq": 6, "text": "” 其欲荐吏，扬人之善蔽人之过如此。", "len": 18}
{"sid": "122_酷吏列传.17.s7", "chapter": "122_酷吏列传", "para": "17", "seq": 7, "text": "所治即上意所欲罪，予监史深祸者；即上意所欲释，与监史轻平者。", "len": 30}
{"sid": "122_酷吏列传.17.s8", "chapter": "122_酷吏列传", "para": "17", "seq": 8, "text": "所治即豪，必舞文巧诋；即下户羸弱，时口言，虽文致法，上财察。", "len": 30}
{"sid": "122_酷吏列传.17.s9", "chapter": "122_酷吏列传", "para": "17", "seq": 9, "text": "於是往往释汤所言。", "len": 9}
{"sid": "122_酷吏列传.17.s10", "chapter": "122_酷吏列传", "para": "17", "seq": 10, "text": "汤至於大吏，内行脩也。", "len": 11}
{"sid": "122_酷吏列传.17.s11", "chapter": "122_酷吏列传", "para": "17", "seq": 11, "text": "通宾客饮食。", "len": 6}
{"sid": "122_酷吏列传.17.s12", "chapter": "122_酷吏列传", "para": "17", "seq": 12, "text": "於故人子弟为吏及贫昆弟，调护之尤厚。", "len": 18}
{"sid": "122_酷吏列传.17.s13", "chapter": "122_酷吏列传", "para": "17", "seq": 13, "text": "其造请诸公，不避寒暑。", "len": 11}
{"sid": "122_酷吏列传.17.s14", "chapter": "122_酷吏列传", "para": "17", "seq": 14, "text": "是以汤虽文深意忌不专平，然得此声誉。", "len": 18}
{"sid": "122_酷吏列传.17.s15", "chapter": "122_酷吏列传", "para": "17", "seq": 15, "text": "而刻深吏多为爪牙用者，依於文学之士。", "len": 18}
{"sid": "122_酷吏列传.17.s16", "chapter": "122_酷吏列传", "para": "17", "seq": 16, "text": "丞相弘数称其美。", "len": 8}
{"sid": "122_酷吏列传.17.s17", "chapter": "122_酷吏列传", "para": "17", "seq": 17, "text": "及治淮南、衡山、江都反狱，皆穷根本。", "len": 18}
{"sid": "122_酷吏列传.17.s18", "chapter": "122_酷吏列传", "para": "17", "seq": 18, "text": "严助及伍被，上欲释之。", "len": 11}
{"sid": "122_酷吏列传.17.s19", "chapter": "122_酷吏列传", "para": "17", "seq": 19, "text": "汤争曰：”伍被本画反谋，而助亲幸出入禁闼爪牙臣，乃交私诸侯如此，弗诛，後不可治。", "len": 40}
{"sid": "122_酷吏列传.17.s20", "chapter": "122_酷吏列传", "para": "17", "seq": 20, "text": "” 於是上可论之。", "len": 9}
{"sid": "122_酷吏列传.17.s21", "chapter": "122_酷吏列传", "para": "17", "seq": 21, "text": "其治狱所排大臣自为功，多此类。", "len": 15}
{"sid": "122_酷吏列传.17.s22", "chapter": "122_酷吏列传", "para": "17", "seq": 22, "text": "於是汤益尊任，迁为御史大夫。", "len": 14}
{"sid": "122_酷吏列传.18.s1", "chapter": "122_酷吏列传", "para": "18", "seq": 1, "text": "会浑邪等降，汉大兴兵伐匈奴，山东水旱，贫民流徙，皆仰给县官，县官空虚。", "len": 35}
{"sid": "122_酷吏列传.18.s2", "chapter": "122_酷吏列传", "para": "18", "seq": 2, "text": "於是丞上指，请造白金及五铢钱，笼天下盐铁，排富商大贾，出告缗令，鉏豪彊并兼之家，舞文巧诋以辅法。", "len": 48}
{"sid": "122_酷吏列传.18.s3", "chapter": "122_酷吏列传", "para": "18", "seq": 3, "text": "汤每朝奏事，语国家用，日晏，天子忘食。", "len": 19}
{"sid": "122_酷吏列传.18.s4", "chapter": "122_酷吏列传", "para": "18", "seq": 4, "text": "丞相取充位，天下事皆决於汤。", "len": 14}
{"sid": "122_酷吏列传.18.s5", "chapter": "122_酷吏列传", "para": "18", "seq": 5, "text": "百姓不安其生，骚动，县官所兴，未获其利，奸吏并侵渔，於是痛绳以罪。", "len": 33}
{"sid": "122_酷吏列传.18.s6", "chapter": "122_酷吏列传", "para": "18", "seq": 6, "text": "则自公卿以下，至於庶人，咸指汤。", "len": 16}
{"sid": "122_酷吏列传.18.s7", "chapter": "122_酷吏列传", "para": "18", "seq": 7, "text": "汤尝病，天子至自视病，其隆贵如此。", "len": 17}
{"sid": "122_酷吏列传.19.s1", "chapter": "122_酷吏列传", "para": "19", "seq": 1, "text": "匈奴来请和亲，群臣议上前。", "len": 13}
{"sid": "122_酷吏列传.19.s2", "chapter": "122_酷吏列传", "para": "19", "seq": 2, "text": "博士狄山曰：“和亲便。", "len": 11}
{"sid": "122_酷吏列传.19.s3", "chapter": "122_酷吏列传", "para": "19", "seq": 3, "text": "” 上问其便，山曰：“兵者凶器，未易数动。", "len": 21}
{"sid": "122_酷吏列传.19.s4", "chapter": "122_酷吏列传", "para": "19", "seq": 4, "text": "高帝欲伐匈奴，大困平城，乃遂结和亲。", "len": 18}
{"sid": "122_酷吏列传.19.s5", "chapter": "122_酷吏列传", "para": "19", "seq": 5, "text": "孝惠、高后时，天下安乐。", "len": 12}
{"sid": "122_酷吏列传.19.s6", "chapter": "122_酷吏列传", "para": "19", "seq": 6, "text": "及孝文帝欲事匈奴，北边萧然苦兵矣。", "len": 17}
{"sid": "122_酷吏列传.19.s7", "chapter": "122_酷吏列传", "para": "19", "seq": 7, "text": "孝景时，吴楚七国反，景帝往来两宫间，寒心者数月。", "len": 24}
{"sid": "122_酷吏列传.19.s8", "chapter": "122_酷吏列传", "para": "19", "seq": 8, "text": "吴楚已破，竟景帝不言兵，天下富实。", "len": 17}
{"sid": "122_酷吏列传.19.s9", "chapter": "122_酷吏列传", "para": "19", "seq": 9, "text": "今自陛下举兵击匈奴，中国以空虚，边民大困贫。", "len": 22}
{"sid": "122_酷吏列传.19.s10", "chapter": "122_酷吏列传", "para": "19", "seq": 10, "text": "由此观之，不如和亲。", "len": 10}
{"sid": "122_酷吏列传.19.s11", "chapter": "122_酷吏列传", "para": "19", "seq": 11, "text": "” 上问汤，汤曰：“此愚儒，无知。", "len": 17}
{"sid": "122_酷吏列传.19.s12", "chapter": "122_酷吏列传", "para": "19", "seq": 12, "text": "” 狄山曰：“臣固愚忠，若御史大夫汤乃诈忠。", "len": 22}
{"sid": "122_酷吏列传.19.s13", "chapter": "122_酷吏列传", "para": "19", "seq": 13, "text": "若汤之治淮南、江都，以深文痛诋诸侯，别疏骨肉，使蕃臣不自安。", "len": 30}
{"sid": "122_酷吏列传.19.s14", "chapter": "122_酷吏列传", "para": "19", "seq": 14, "text": "臣固知汤之为诈忠。", "len": 9}
{"sid": "122_酷吏列传.19.s15", "chapter": "122_酷吏列传", "para": "19", "seq": 15, "text": "” 於是上作色曰：“吾使生居一郡，能无使虏入盗乎？", "len": 25}
{"sid": "122_酷吏列传.19.s16", "chapter": "122_酷吏列传", "para": "19", "seq": 16, "text": "” 曰：“不能。", "len": 8}
{"sid": "122_酷吏列传.19.s17", "chapter": "122_酷吏列传", "para": "19", "seq": 17, "text": "” 曰：“居一县？", "len": 9}
{"sid": "122_酷吏列传.19.s18", "chapter": "122_酷吏列传", "para": "19", "seq": 18, "text": "” 对曰：“不能。", "len": 9}
{"sid": "122_酷吏列传.19.s19", "chapter": "122_酷吏列传", "para": "19", "seq": 19, "text": "” 复曰：“居一障间？", "len": 11}
{"sid": "122_酷吏列传.19.s20", "chapter": "122_酷吏列传", "para": "19", "seq": 20, "text": "” 山自度辩穷且下吏，曰：“能。", "len": 16}
{"sid": "122_酷吏列传.19.s21", "chapter": "122_酷吏列传", "para": "19", "seq": 21, "text": "” 於是上遣山乘鄣。", "len": 10}
{"sid": "122_酷吏列传.19.s22", "chapter": "122_酷吏列传", "para": "19", "seq": 22, "text": "至月馀，匈奴斩山头而去。", "len": 12}
{"sid": "122_酷吏列传.19.s23", "chapter": "122_酷吏列传", "para": "19", "seq": 23, "text": "自是以後，群臣震慴。", "len": 10}
{"sid": "122_酷吏列传.20.s1", "chapter": "122_酷吏列传", "para": "20", "seq": 1, "text": "汤之客田甲，虽贾人，有贤操。", "len": 14}
{"sid": "122_酷吏列传.20.s2", "chapter": "122_酷吏列传", "para": "20", "seq": 2, "text": "始汤为小吏时，与钱通，及汤为大吏，甲所以责汤行义过失，亦有烈士风。", "len": 33}
{"sid": "122_酷吏列传.21.s1", "chapter": "122_酷吏列传", "para": "21", "seq": 1, "text": "汤为御史大夫七岁，败。", "len": 11}
{"sid": "122_酷吏列传.22.s1", "chapter": "122_酷吏列传", "para": "22", "seq": 1, "text": "河东人李文尝与汤有卻，已而为御史中丞，恚，数从中文书事有可以伤汤者，不能为地。", "len": 39}
{"sid": "122_酷吏列传.22.s2", "chapter": "122_酷吏列传", "para": "22", "seq": 2, "text": "汤有所爱史鲁谒居，知汤不平，使人上蜚变告文奸事，事下汤，汤治论杀文，而汤心知谒居为之。", "len": 43}
{"sid": "122_酷吏列传.22.s3", "chapter": "122_酷吏列传", "para": "22", "seq": 3, "text": "上问曰：”言变事纵迹安起？", "len": 13}
{"sid": "122_酷吏列传.22.s4", "chapter": "122_酷吏列传", "para": "22", "seq": 4, "text": "” 汤详惊曰：”此殆文故人怨之。", "len": 16}
{"sid": "122_酷吏列传.22.s5", "chapter": "122_酷吏列传", "para": "22", "seq": 5, "text": "” 谒居病卧闾里主人，汤自往视疾，为谒居摩足。", "len": 23}
{"sid": "122_酷吏列传.22.s6", "chapter": "122_酷吏列传", "para": "22", "seq": 6, "text": "赵国以冶铸为业，王数讼铁官事，汤常排赵王。", "len": 21}
{"sid": "122_酷吏列传.22.s7", "chapter": "122_酷吏列传", "para": "22", "seq": 7, "text": "赵王求汤阴事。", "len": 7}
{"sid": "122_酷吏列传.22.s8", "chapter": "122_酷吏列传", "para": "22", "seq": 8, "text": "谒居尝案赵王，赵王怨之，并上书告：“汤，大臣也，史谒居有病，汤至为摩足，疑与为大奸。", "len": 42}
{"sid": "122_酷吏列传.22.s9", "chapter": "122_酷吏列传", "para": "22", "seq": 9, "text": "” 事下廷尉。", "len": 7}
{"sid": "122_酷吏列传.22.s10", "chapter": "122_酷吏列传", "para": "22", "seq": 10, "text": "谒居病死，事连其弟，弟系导官。", "len": 15}
{"sid": "122_酷吏列传.22.s11", "chapter": "122_酷吏列传", "para": "22", "seq": 11, "text": "汤亦治他囚导官，见谒居弟，欲阴为之，而详不省。", "len": 23}
{"sid": "122_酷吏列传.22.s12", "chapter": "122_酷吏列传", "para": "22", "seq": 12, "text": "谒居弟弗知，怨汤，使人上书告汤与谒居谋，共变告李文。", "len": 26}
{"sid": "122_酷吏列传.22.s13", "chapter": "122_酷吏列传", "para": "22", "seq": 13, "text": "事下减宣。", "len": 5}
{"sid": "122_酷吏列传.22.s14", "chapter": "122_酷吏列传", "para": "22", "seq": 14, "text": "宣尝与汤有卻，及得此事，穷竟其事，未奏也。", "len": 21}
{"sid": "122_酷吏列传.22.s15", "chapter": "122_酷吏列传", "para": "22", "seq": 15, "text": "会人有盗发孝文园瘗钱，丞相青翟朝，与汤约俱谢，至前，汤念独丞相以四时行园，当谢，汤无与也，不谢。", "len": 48}
{"sid": "122_酷吏列传.22.s16", "chapter": "122_酷吏列传", "para": "22", "seq": 16, "text": "丞相谢，上使御史案其事。", "len": 12}
{"sid": "122_酷吏列传.22.s17", "chapter": "122_酷吏列传", "para": "22", "seq": 17, "text": "汤欲致其文丞相见知，丞相患之。", "len": 15}
{"sid": "122_酷吏列传.22.s18", "chapter": "122_酷吏列传", "para": "22", "seq": 18, "text": "三长史皆害汤，欲陷之。", "len": 11}
{"sid": "122_酷吏列传.23.s1", "chapter": "122_酷吏列传", "para": "23", "seq": 1, "text": "始长史硃买臣，会稽人也。", "len": 12}
{"sid": "122_酷吏列传.23.s2", "chapter": "122_酷吏列传", "para": "23", "seq": 2, "text": "读春秋。", "len": 4}
{"sid": "122_酷吏列传.23.s3", "chapter": "122_酷吏列传", "para": "23", "seq": 3, "text": "庄助使人言买臣，买臣以楚辞与助俱幸，侍中，为太中大夫，用事；而汤乃为小吏，跪伏使买臣等前。", "len": 45}
{"sid": "122_酷吏列传.23.s4", "chapter": "122_酷吏列传", "para": "23", "seq": 4, "text": "已而汤为廷尉，治淮南狱，排挤庄助，买臣固心望。", "len": 23}
{"sid": "122_酷吏列传.23.s5", "chapter": "122_酷吏列传", "para": "23", "seq": 5, "text": "及汤为御史大夫，买臣以会稽守为主爵都尉，列於九卿。", "len": 25}
{"sid": "122_酷吏列传.23.s6", "chapter": "122_酷吏列传", "para": "23", "seq": 6, "text": "数年，坐法废，守长史，见汤，汤坐床上，丞史遇买臣弗为礼。", "len": 28}
{"sid": "122_酷吏列传.23.s7", "chapter": "122_酷吏列传", "para": "23", "seq": 7, "text": "买臣楚士，深怨，常欲死之。", "len": 13}
{"sid": "122_酷吏列传.23.s8", "chapter": "122_酷吏列传", "para": "23", "seq": 8, "text": "王朝，齐人也。", "len": 7}
{"sid": "122_酷吏列传.23.s9", "chapter": "122_酷吏列传", "para": "23", "seq": 9, "text": "以术至右内史。", "len": 7}
{"sid": "122_酷吏列传.23.s10", "chapter": "122_酷吏列传", "para": "23", "seq": 10, "text": "边通，学长短，刚暴彊人也，官再至济南相。", "len": 20}
{"sid": "122_酷吏列传.23.s11", "chapter": "122_酷吏列传", "para": "23", "seq": 11, "text": "故皆居汤右，已而失官，守长史，诎体於汤。", "len": 20}
{"sid": "122_酷吏列传.23.s12", "chapter": "122_酷吏列传", "para": "23", "seq": 12, "text": "汤数行丞相事，知此三长史素贵，常凌折之。", "len": 20}
{"sid": "122_酷吏列传.23.s13", "chapter": "122_酷吏列传", "para": "23", "seq": 13, "text": "以故三长史合谋曰：“始汤约与君谢，已而卖君；今欲劾君以宗庙事，此欲代君耳。", "len": 37}
{"sid": "122_酷吏列传.23.s14", "chapter": "122_酷吏列传", "para": "23", "seq": 14, "text": "吾知汤阴事。", "len": 6}
{"sid": "122_酷吏列传.23.s15", "chapter": "122_酷吏列传", "para": "23", "seq": 15, "text": "” 使吏捕案汤左田信等，曰汤且欲奏请，信辄先知之，居物致富，与汤分之，及他奸事。", "len": 40}
{"sid": "122_酷吏列传.23.s16", "chapter": "122_酷吏列传", "para": "23", "seq": 16, "text": "事辞颇闻。", "len": 5}
{"sid": "122_酷吏列传.23.s17", "chapter": "122_酷吏列传", "para": "23", "seq": 17, "text": "上问汤曰：“吾所为，贾人辄先知之，益居其物，是类有以吾谋告之者。", "len": 32}
{"sid": "122_酷吏列传.23.s18", "chapter": "122_酷吏列传", "para": "23", "seq": 18, "text": "” 汤不谢。", "len": 6}
{"sid": "122_酷吏列传.23.s19", "chapter": "122_酷吏列传", "para": "23", "seq": 19, "text": "汤又详惊曰：“固宜有。", "len": 11}
{"sid": "122_酷吏列传.23.s20", "chapter": "122_酷吏列传", "para": "23", "seq": 20, "text": "” 减宣亦奏谒居等事。", "len": 11}
{"sid": "122_酷吏列传.23.s21", "chapter": "122_酷吏列传", "para": "23", "seq": 21, "text": "天子果以汤怀诈面欺，使使八辈簿责汤。", "len": 18}
{"sid": "122_酷吏列传.23.s22", "chapter": "122_酷吏列传", "para": "23", "seq": 22, "text": "汤具自道无此，不服。", "len": 10}
{"sid": "122_酷吏列传.23.s23", "chapter": "122_酷吏列传", "para": "23", "seq": 23, "text": "於是上使赵禹责汤。", "len": 9}
{"sid": "122_酷吏列传.23.s24", "chapter": "122_酷吏列传", "para": "23", "seq": 24, "text": "禹至，让汤曰：“君何不知分也。", "len": 15}
{"sid": "122_酷吏列传.23.s25", "chapter": "122_酷吏列传", "para": "23", "seq": 25, "text": "君所治夷灭者几何人矣？", "len": 11}
{"sid": "122_酷吏列传.23.s26", "chapter": "122_酷吏列传", "para": "23", "seq": 26, "text": "今人言君皆有状，天子重致君狱，欲令君自为计，何多以对簿为？", "len": 29}
{"sid": "122_酷吏列传.23.s27", "chapter": "122_酷吏列传", "para": "23", "seq": 27, "text": "” 汤乃为书谢曰：“汤无尺寸功，起刀笔吏，陛下幸致为三公，无以塞责。", "len": 34}
{"sid": "122_酷吏列传.23.s28", "chapter": "122_酷吏列传", "para": "23", "seq": 28, "text": "然谋陷汤罪者，三长史也。", "len": 12}
{"sid": "122_酷吏列传.23.s29", "chapter": "122_酷吏列传", "para": "23", "seq": 29, "text": "” 遂自杀。", "len": 6}
{"sid": "122_酷吏列传.24.s1", "chapter": "122_酷吏列传", "para": "24", "seq": 1, "text": "汤死，家产直不过五百金，皆所得奉赐，无他业。", "len": 22}
{"sid": "122_酷吏列传.24.s2", "chapter": "122_酷吏列传", "para": "24", "seq": 2, "text": "昆弟诸子欲厚葬汤，汤母曰：”汤为天子大臣，被汙恶言而死，何厚葬乎！", "len": 33}
{"sid": "122_酷吏列传.24.s3", "chapter": "122_酷吏列传", "para": "24", "seq": 3, "text": "” 载以牛车，有棺无椁。", "len": 12}
{"sid": "122_酷吏列传.24.s4", "chapter": "122_酷吏列传", "para": "24", "seq": 4, "text": "天子闻之，曰：”非此母不能生此子。", "len": 17}
{"sid": "122_酷吏列传.24.s5", "chapter": "122_酷吏列传", "para": "24", "seq": 5, "text": "” 乃尽案诛三长史。", "len": 10}
{"sid": "122_酷吏列传.24.s6", "chapter": "122_酷吏列传", "para": "24", "seq": 6, "text": "丞相青翟自杀。", "len": 7}
{"sid": "122_酷吏列传.24.s7", "chapter": "122_酷吏列传", "para": "24", "seq": 7, "text": "出田信。", "len": 4}
{"sid": "122_酷吏列传.24.s8", "chapter": "122_酷吏列传", "para": "24", "seq": 8, "text": "上惜汤。", "len": 4}
{"sid": "122_酷吏列传.24.s9", "chapter": "122_酷吏列传", "para": "24", "seq": 9, "text": "稍迁其子安世。", "len": 7}
{"sid": "122_酷吏列传.25.s1", "chapter": "122_酷吏列传", "para": "25", "seq": 1, "text": "赵禹中废，已而为廷尉。", "len": 11}
{"sid": "122_酷吏列传.25.s2", "chapter": "122_酷吏列传", "para": "25", "seq": 2, "text": "始条侯以为禹贼深，弗任。", "len": 12}
{"sid": "122_酷吏列传.25.s3", "chapter": "122_酷吏列传", "para": "25", "seq": 3, "text": "及禹为少府，比九卿。", "len": 10}
{"sid": "122_酷吏列传.25.s4", "chapter": "122_酷吏列传", "para": "25", "seq": 4, "text": "禹酷急，至晚节，事益多，吏务为严峻，而禹治加缓，而名为平。", "len": 29}
{"sid": "122_酷吏列传.25.s5", "chapter": "122_酷吏列传", "para": "25", "seq": 5, "text": "王温舒等後起，治酷於禹。", "len": 12}
{"sid": "122_酷吏列传.25.s6", "chapter": "122_酷吏列传", "para": "25", "seq": 6, "text": "禹以老，徙为燕相。", "len": 9}
{"sid": "122_酷吏列传.25.s7", "chapter": "122_酷吏列传", "para": "25", "seq": 7, "text": "数岁，乱悖有罪，免归。", "len": 11}
{"sid": "122_酷吏列传.25.s8", "chapter": "122_酷吏列传", "para": "25", "seq": 8, "text": "後汤十馀年，以寿卒于家。", "len": 12}
{"sid": "122_酷吏列传.26.s1", "chapter": "122_酷吏列传", "para": "26", "seq": 1, "text": "义纵者，河东人也。", "len": 9}
{"sid": "122_酷吏列传.26.s2", "chapter": "122_酷吏列传", "para": "26", "seq": 2, "text": "为少年时，尝与张次公俱攻剽为群盗。", "len": 17}
{"sid": "122_酷吏列传.26.s3", "chapter": "122_酷吏列传", "para": "26", "seq": 3, "text": "纵有姊姁，以医幸王太后。", "len": 12}
{"sid": "122_酷吏列传.26.s4", "chapter": "122_酷吏列传", "para": "26", "seq": 4, "text": "王太后问：”有子兄弟为官者乎？", "len": 15}
{"sid": "122_酷吏列传.26.s5", "chapter": "122_酷吏列传", "para": "26", "seq": 5, "text": "” 姊曰：”有弟无行，不可。", "len": 14}
{"sid": "122_酷吏列传.26.s6", "chapter": "122_酷吏列传", "para": "26", "seq": 6, "text": "” 太后乃告上，拜义姁弟纵为中郎，补上党郡中令。", "len": 24}
{"sid": "122_酷吏列传.26.s7", "chapter": "122_酷吏列传", "para": "26", "seq": 7, "text": "治敢行，少蕴藉，县无逋事，举为第一。", "len": 18}
{"sid": "122_酷吏列传.26.s8", "chapter": "122_酷吏列传", "para": "26", "seq": 8, "text": "迁为长陵及长安令，直法行治，不避贵戚。", "len": 19}
{"sid": "122_酷吏列传.26.s9", "chapter": "122_酷吏列传", "para": "26", "seq": 9, "text": "以捕案太后外孙脩成君子仲，上以为能，迁为河内都尉。", "len": 25}
{"sid": "122_酷吏列传.26.s10", "chapter": "122_酷吏列传", "para": "26", "seq": 10, "text": "至则族灭其豪穰氏之属，河内道不拾遗。", "len": 18}
{"sid": "122_酷吏列传.26.s11", "chapter": "122_酷吏列传", "para": "26", "seq": 11, "text": "而张次公亦为郎，以勇悍从军，敢深入，有功，为岸头侯。", "len": 26}
{"sid": "122_酷吏列传.27.s1", "chapter": "122_酷吏列传", "para": "27", "seq": 1, "text": "宁成家居，上欲以为郡守。", "len": 12}
{"sid": "122_酷吏列传.27.s2", "chapter": "122_酷吏列传", "para": "27", "seq": 2, "text": "御史大夫弘曰：”臣居山东为小吏时，宁成为济南都尉，其治如狼牧羊。", "len": 32}
{"sid": "122_酷吏列传.27.s3", "chapter": "122_酷吏列传", "para": "27", "seq": 3, "text": "成不可使治民。", "len": 7}
{"sid": "122_酷吏列传.27.s4", "chapter": "122_酷吏列传", "para": "27", "seq": 4, "text": "” 上乃拜成为关都尉。", "len": 11}
{"sid": "122_酷吏列传.27.s5", "chapter": "122_酷吏列传", "para": "27", "seq": 5, "text": "岁馀，关东吏隶郡国出入关者，号曰“宁见乳虎，无值宁成之怒”。", "len": 30}
{"sid": "122_酷吏列传.27.s6", "chapter": "122_酷吏列传", "para": "27", "seq": 6, "text": "义纵自河内迁为南阳太守，闻宁成家居南阳，及纵至关，宁成侧行送迎，然纵气盛，弗为礼。", "len": 41}
{"sid": "122_酷吏列传.27.s7", "chapter": "122_酷吏列传", "para": "27", "seq": 7, "text": "至郡，遂案宁氏，尽破碎其家。", "len": 14}
{"sid": "122_酷吏列传.27.s8", "chapter": "122_酷吏列传", "para": "27", "seq": 8, "text": "成坐有罪，及孔、暴之属皆奔亡，南阳吏民重足一迹。", "len": 24}
{"sid": "122_酷吏列传.27.s9", "chapter": "122_酷吏列传", "para": "27", "seq": 9, "text": "而平氏硃彊、杜衍、杜周为纵牙爪之吏，任用，迁为廷史。", "len": 26}
{"sid": "122_酷吏列传.27.s10", "chapter": "122_酷吏列传", "para": "27", "seq": 10, "text": "军数出定襄，定襄吏民乱败，於是徙纵为定襄太守。", "len": 23}
{"sid": "122_酷吏列传.27.s11", "chapter": "122_酷吏列传", "para": "27", "seq": 11, "text": "纵至，掩定襄狱中重罪轻系二百馀人，及宾客昆弟私入相视亦二百馀人。", "len": 32}
{"sid": "122_酷吏列传.27.s12", "chapter": "122_酷吏列传", "para": "27", "seq": 12, "text": "纵一捕鞠，曰“为死罪解脱”。", "len": 14}
{"sid": "122_酷吏列传.27.s13", "chapter": "122_酷吏列传", "para": "27", "seq": 13, "text": "是日皆报杀四百馀人。", "len": 10}
{"sid": "122_酷吏列传.27.s14", "chapter": "122_酷吏列传", "para": "27", "seq": 14, "text": "其後郡中不寒而栗，猾民佐吏为治。", "len": 16}
{"sid": "122_酷吏列传.28.s1", "chapter": "122_酷吏列传", "para": "28", "seq": 1, "text": "是时赵禹、张汤以深刻为九卿矣，然其治尚宽，辅法而行，而纵以鹰击毛挚为治。", "len": 36}
{"sid": "122_酷吏列传.28.s2", "chapter": "122_酷吏列传", "para": "28", "seq": 2, "text": "後会五铢钱白金起，民为奸，京师尤甚，乃以纵为右内史，王温舒为中尉。", "len": 33}
{"sid": "122_酷吏列传.28.s3", "chapter": "122_酷吏列传", "para": "28", "seq": 3, "text": "温舒至恶，其所为不先言纵，纵必以气凌之，败坏其功。", "len": 25}
{"sid": "122_酷吏列传.28.s4", "chapter": "122_酷吏列传", "para": "28", "seq": 4, "text": "其治，所诛杀甚多，然取为小治，奸益不胜，直指始出矣。", "len": 26}
{"sid": "122_酷吏列传.28.s5", "chapter": "122_酷吏列传", "para": "28", "seq": 5, "text": "吏之治以斩杀缚束为务，阎奉以恶用矣。", "len": 18}
{"sid": "122_酷吏列传.28.s6", "chapter": "122_酷吏列传", "para": "28", "seq": 6, "text": "纵廉，其治放郅都。", "len": 9}
{"sid": "122_酷吏列传.28.s7", "chapter": "122_酷吏列传", "para": "28", "seq": 7, "text": "上幸鼎湖，病久，已而卒起幸甘泉，道多不治。", "len": 21}
{"sid": "122_酷吏列传.28.s8", "chapter": "122_酷吏列传", "para": "28", "seq": 8, "text": "上怒曰：“纵以我为不复行此道乎？", "len": 16}
{"sid": "122_酷吏列传.28.s9", "chapter": "122_酷吏列传", "para": "28", "seq": 9, "text": "” 嗛之。", "len": 5}
{"sid": "122_酷吏列传.28.s10", "chapter": "122_酷吏列传", "para": "28", "seq": 10, "text": "至冬，杨可方受告缗，纵以为此乱民，部吏捕其为可使者。", "len": 26}
{"sid": "122_酷吏列传.28.s11", "chapter": "122_酷吏列传", "para": "28", "seq": 11, "text": "天子闻，使杜式治，以为废格沮事，弃纵市。", "len": 20}
{"sid": "122_酷吏列传.28.s12", "chapter": "122_酷吏列传", "para": "28", "seq": 12, "text": "後一岁，张汤亦死。", "len": 9}
{"sid": "122_酷吏列传.29.s1", "chapter": "122_酷吏列传", "para": "29", "seq": 1, "text": "王温舒者，阳陵人也。", "len": 10}
{"sid": "122_酷吏列传.29.s2", "chapter": "122_酷吏列传", "para": "29", "seq": 2, "text": "少时椎埋为奸。", "len": 7}
{"sid": "122_酷吏列传.29.s3", "chapter": "122_酷吏列传", "para": "29", "seq": 3, "text": "已而试补县亭长，数废。", "len": 11}
{"sid": "122_酷吏列传.29.s4", "chapter": "122_酷吏列传", "para": "29", "seq": 4, "text": "为吏，以治狱至廷史。", "len": 10}
{"sid": "122_酷吏列传.29.s5", "chapter": "122_酷吏列传", "para": "29", "seq": 5, "text": "事张汤，迁为御史。", "len": 9}
{"sid": "122_酷吏列传.29.s6", "chapter": "122_酷吏列传", "para": "29", "seq": 6, "text": "督盗贼，杀伤甚多，稍迁至广平都尉。", "len": 17}
{"sid": "122_酷吏列传.29.s7", "chapter": "122_酷吏列传", "para": "29", "seq": 7, "text": "择郡中豪敢任吏十馀人，以为爪牙，皆把其阴重罪，而纵使督盗贼，快其意所欲得。", "len": 37}
{"sid": "122_酷吏列传.29.s8", "chapter": "122_酷吏列传", "para": "29", "seq": 8, "text": "此人虽有百罪，弗法；即有避，因其事夷之，亦灭宗。", "len": 24}
{"sid": "122_酷吏列传.29.s9", "chapter": "122_酷吏列传", "para": "29", "seq": 9, "text": "以其故齐赵之郊盗贼不敢近广平，广平声为道不拾遗。", "len": 24}
{"sid": "122_酷吏列传.29.s10", "chapter": "122_酷吏列传", "para": "29", "seq": 10, "text": "上闻，迁为河内太守。", "len": 10}
{"sid": "122_酷吏列传.30.s1", "chapter": "122_酷吏列传", "para": "30", "seq": 1, "text": "素居广平时，皆知河内豪奸之家，及往，九月而至。", "len": 23}
{"sid": "122_酷吏列传.30.s2", "chapter": "122_酷吏列传", "para": "30", "seq": 2, "text": "令郡具私马五十匹，为驿自河内至长安，部吏如居广平时方略，捕郡中豪猾，郡中豪猾相连坐千馀家。", "len": 45}
{"sid": "122_酷吏列传.30.s3", "chapter": "122_酷吏列传", "para": "30", "seq": 3, "text": "上书请，大者至族，小者乃死，家尽没入偿臧。", "len": 21}
{"sid": "122_酷吏列传.30.s4", "chapter": "122_酷吏列传", "para": "30", "seq": 4, "text": "奏行不过二三日，得可事。", "len": 12}
{"sid": "122_酷吏列传.30.s5", "chapter": "122_酷吏列传", "para": "30", "seq": 5, "text": "论报，至流血十馀里。", "len": 10}
{"sid": "122_酷吏列传.30.s6", "chapter": "122_酷吏列传", "para": "30", "seq": 6, "text": "河内皆怪其奏，以为神速。", "len": 12}
{"sid": "122_酷吏列传.30.s7", "chapter": "122_酷吏列传", "para": "30", "seq": 7, "text": "尽十二月，郡中毋声，毋敢夜行，野无犬吠之盗。", "len": 22}
{"sid": "122_酷吏列传.30.s8", "chapter": "122_酷吏列传", "para": "30", "seq": 8, "text": "其颇不得，失之旁郡国，黎来，会春，温舒顿足叹曰：“嗟乎，令冬月益展一月，足吾事矣！", "len": 41}
{"sid": "122_酷吏列传.30.s9", "chapter": "122_酷吏列传", "para": "30", "seq": 9, "text": "” 其好杀伐行威不爱人如此。", "len": 14}
{"sid": "122_酷吏列传.30.s10", "chapter": "122_酷吏列传", "para": "30", "seq": 10, "text": "天子闻之，以为能，迁为中尉。", "len": 14}
{"sid": "122_酷吏列传.30.s11", "chapter": "122_酷吏列传", "para": "30", "seq": 11, "text": "其治复放河内，徙诸名祸猾吏与从事，河内则杨皆、麻戊，关中杨赣、成信等。", "len": 35}
{"sid": "122_酷吏列传.30.s12", "chapter": "122_酷吏列传", "para": "30", "seq": 12, "text": "义纵为内史，惮未敢恣治。", "len": 12}
{"sid": "122_酷吏列传.30.s13", "chapter": "122_酷吏列传", "para": "30", "seq": 13, "text": "及纵死，张汤败後，徙为廷尉，而尹齐为中尉。", "len": 21}
{"sid": "122_酷吏列传.31.s1", "chapter": "122_酷吏列传", "para": "31", "seq": 1, "text": "尹齐者，东郡茌平人。", "len": 10}
{"sid": "122_酷吏列传.31.s2", "chapter": "122_酷吏列传", "para": "31", "seq": 2, "text": "以刀笔稍迁至御史。", "len": 9}
{"sid": "122_酷吏列传.31.s3", "chapter": "122_酷吏列传", "para": "31", "seq": 3, "text": "事张汤，张汤数称以为廉武，使督盗贼，所斩伐不避贵戚。", "len": 26}
{"sid": "122_酷吏列传.31.s4", "chapter": "122_酷吏列传", "para": "31", "seq": 4, "text": "迁为关内都尉，声甚於宁成。", "len": 13}
{"sid": "122_酷吏列传.31.s5", "chapter": "122_酷吏列传", "para": "31", "seq": 5, "text": "上以为能，迁为中尉，吏民益凋敝。", "len": 16}
{"sid": "122_酷吏列传.31.s6", "chapter": "122_酷吏列传", "para": "31", "seq": 6, "text": "尹齐木彊少文，豪恶吏伏匿而善吏不能为治，以故事多废，抵罪。", "len": 29}
{"sid": "122_酷吏列传.31.s7", "chapter": "122_酷吏列传", "para": "31", "seq": 7, "text": "上复徙温舒为中尉，而杨仆以严酷为主爵都尉。", "len": 21}
{"sid": "122_酷吏列传.32.s1", "chapter": "122_酷吏列传", "para": "32", "seq": 1, "text": "杨仆者，宜阳人也。", "len": 9}
{"sid": "122_酷吏列传.32.s2", "chapter": "122_酷吏列传", "para": "32", "seq": 2, "text": "以千夫为吏。", "len": 6}
{"sid": "122_酷吏列传.32.s3", "chapter": "122_酷吏列传", "para": "32", "seq": 3, "text": "河南守案举以为能，迁为御史，使督盗贼关东。", "len": 21}
{"sid": "122_酷吏列传.32.s4", "chapter": "122_酷吏列传", "para": "32", "seq": 4, "text": "治放尹齐，以为敢挚行。", "len": 11}
{"sid": "122_酷吏列传.32.s5", "chapter": "122_酷吏列传", "para": "32", "seq": 5, "text": "稍迁至主爵都尉，列九卿。", "len": 12}
{"sid": "122_酷吏列传.32.s6", "chapter": "122_酷吏列传", "para": "32", "seq": 6, "text": "天子以为能。", "len": 6}
{"sid": "122_酷吏列传.32.s7", "chapter": "122_酷吏列传", "para": "32", "seq": 7, "text": "南越反，拜为楼船将军，有功，封将梁侯。", "len": 19}
{"sid": "122_酷吏列传.32.s8", "chapter": "122_酷吏列传", "para": "32", "seq": 8, "text": "为荀彘所缚。", "len": 6}
{"sid": "122_酷吏列传.32.s9", "chapter": "122_酷吏列传", "para": "32", "seq": 9, "text": "居久之，病死。", "len": 7}
{"sid": "122_酷吏列传.33.s1", "chapter": "122_酷吏列传", "para": "33", "seq": 1, "text": "而温舒复为中尉。", "len": 8}
{"sid": "122_酷吏列传.33.s2", "chapter": "122_酷吏列传", "para": "33", "seq": 2, "text": "为人少文，居廷惛惛不辩，至於中尉则心开。", "len": 20}
{"sid": "122_酷吏列传.33.s3", "chapter": "122_酷吏列传", "para": "33", "seq": 3, "text": "督盗贼，素习关中俗，知豪恶吏，豪恶吏尽复为用，为方略。", "len": 27}
{"sid": "122_酷吏列传.33.s4", "chapter": "122_酷吏列传", "para": "33", "seq": 4, "text": "吏苛察，盗贼恶少年投缿购告言奸，置伯格长以牧司奸盗贼。", "len": 27}
{"sid": "122_酷吏列传.33.s5", "chapter": "122_酷吏列传", "para": "33", "seq": 5, "text": "温舒为人，善事有埶者；即无埶者，视之如奴。", "len": 21}
{"sid": "122_酷吏列传.33.s6", "chapter": "122_酷吏列传", "para": "33", "seq": 6, "text": "有埶家，虽有奸如山，弗犯；无埶者，贵戚必侵辱。", "len": 23}
{"sid": "122_酷吏列传.33.s7", "chapter": "122_酷吏列传", "para": "33", "seq": 7, "text": "舞文巧诋下户之猾，以焄大豪。", "len": 14}
{"sid": "122_酷吏列传.33.s8", "chapter": "122_酷吏列传", "para": "33", "seq": 8, "text": "其治中尉如此。", "len": 7}
{"sid": "122_酷吏列传.33.s9", "chapter": "122_酷吏列传", "para": "33", "seq": 9, "text": "奸猾穷治，大抵尽靡烂狱中，行论无出者。", "len": 19}
{"sid": "122_酷吏列传.33.s10", "chapter": "122_酷吏列传", "para": "33", "seq": 10, "text": "其爪牙吏虎而冠。", "len": 8}
{"sid": "122_酷吏列传.33.s11", "chapter": "122_酷吏列传", "para": "33", "seq": 11, "text": "於是中尉部中中猾以下皆伏，有势者为游声誉，称治。", "len": 24}
{"sid": "122_酷吏列传.33.s12", "chapter": "122_酷吏列传", "para": "33", "seq": 12, "text": "治数岁，其吏多以权富。", "len": 11}
{"sid": "122_酷吏列传.34.s1", "chapter": "122_酷吏列传", "para": "34", "seq": 1, "text": "温舒击东越还，议有不中意者，坐小法抵罪免。", "len": 21}
{"sid": "122_酷吏列传.34.s2", "chapter": "122_酷吏列传", "para": "34", "seq": 2, "text": "是时天子方欲作通天台而未有人，温舒请覆中尉脱卒，得数万人作。", "len": 30}
{"sid": "122_酷吏列传.34.s3", "chapter": "122_酷吏列传", "para": "34", "seq": 3, "text": "上说，拜为少府。", "len": 8}
{"sid": "122_酷吏列传.34.s4", "chapter": "122_酷吏列传", "para": "34", "seq": 4, "text": "徙为右内史，治如其故，奸邪少禁。", "len": 16}
{"sid": "122_酷吏列传.34.s5", "chapter": "122_酷吏列传", "para": "34", "seq": 5, "text": "坐法失官。", "len": 5}
{"sid": "122_酷吏列传.34.s6", "chapter": "122_酷吏列传", "para": "34", "seq": 6, "text": "复为右辅，行中尉事。", "len": 10}
{"sid": "122_酷吏列传.34.s7", "chapter": "122_酷吏列传", "para": "34", "seq": 7, "text": "如故操。", "len": 4}
{"sid": "122_酷吏列传.35.s1", "chapter": "122_酷吏列传", "para": "35", "seq": 1, "text": "岁馀，会宛军发，诏徵豪吏，温舒匿其吏华成，及人有变告温舒受员骑钱，他奸利事，罪至族，自杀。", "len": 45}
{"sid": "122_酷吏列传.35.s2", "chapter": "122_酷吏列传", "para": "35", "seq": 2, "text": "其时两弟及两婚家亦各自坐他罪而族。", "len": 17}
{"sid": "122_酷吏列传.35.s3", "chapter": "122_酷吏列传", "para": "35", "seq": 3, "text": "光禄徐自为曰：“悲夫，夫古有三族，而王温舒罪至同时而五族乎！”", "len": 31}
{"sid": "122_酷吏列传.36.s1", "chapter": "122_酷吏列传", "para": "36", "seq": 1, "text": "温舒死，家直累千金。", "len": 10}
{"sid": "122_酷吏列传.36.s2", "chapter": "122_酷吏列传", "para": "36", "seq": 2, "text": "後数岁，尹齐亦以淮阳都尉病死，家直不满五十金。", "len": 23}
{"sid": "122_酷吏列传.36.s3", "chapter": "122_酷吏列传", "para": "36", "seq": 3, "text": "所诛灭淮阳甚多，及死，仇家欲烧其尸，尸亡去归葬。", "len": 24}
{"sid": "122_酷吏列传.37.s1", "chapter": "122_酷吏列传", "para": "37", "seq": 1, "text": "自温舒等以恶为治，而郡守、都尉、诸侯二千石欲为治者，其治大抵尽放温舒，而吏民益轻犯法，盗贼滋起。", "len": 48}
{"sid": "122_酷吏列传.37.s2", "chapter": "122_酷吏列传", "para": "37", "seq": 2, "text": "南阳有梅免、白政，楚有殷中、杜少，齐有徐勃，燕赵之间有坚卢、范生之属。", "len": 35}
{"sid": "122_酷吏列传.37.s3", "chapter": "122_酷吏列传", "para": "37", "seq": 3, "text": "大群至数千人，擅自号，攻城邑，取库兵，释死罪，缚辱郡太守、都尉，杀二千石，为檄告县趣具食；小群以百数，掠卤乡里者，不可胜数也。", "len": 63}
{"sid": "122_酷吏列传.37.s4", "chapter": "122_酷吏列传", "para": "37", "seq": 4, "text": "於是天子始使御史中丞、丞相长史督之。", "len": 18}
{"sid": "122_酷吏列传.37.s5", "chapter": "122_酷吏列传", "para": "37", "seq": 5, "text": "犹弗能禁也，乃使光禄大夫范昆、诸辅都尉及故九卿张德等衣绣衣，持节，虎符发兵以兴击，斩首大部或至万馀级，及以法诛通饮食，坐连诸郡，甚者数千人。", "len": 70}
{"sid": "122_酷吏列传.37.s6", "chapter": "122_酷吏列传", "para": "37", "seq": 6, "text": "数岁，乃颇得其渠率。", "len": 10}
{"sid": "122_酷吏列传.37.s7", "chapter": "122_酷吏列传", "para": "37", "seq": 7, "text": "散卒失亡，复聚党阻山川者，往往而群居，无可柰何。", "len": 24}
{"sid": "122_酷吏列传.37.s8", "chapter": "122_酷吏列传", "para": "37", "seq": 8, "text": "於是作\"沈命法\"，曰群盗起不发觉，发觉而捕弗满品者，二千石以下至小吏主者皆死。其後小吏畏诛，虽有盗不敢发，恐不能得，坐课累府，府亦使其不言。故盗贼浸多，上下相为匿，以文辞避法焉。", "len": 89}
{"sid": "122_酷吏列传.38.s1", "chapter": "122_酷吏列传", "para": "38", "seq": 1, "text": "减宣者，杨人也。", "len": 8}
{"sid": "122_酷吏列传.38.s2", "chapter": "122_酷吏列传", "para": "38", "seq": 2, "text": "以佐史无害给事河东守府。", "len": 12}
{"sid": "122_酷吏列传.38.s3", "chapter": "122_酷吏列传", "para": "38", "seq": 3, "text": "卫将军青使买马河东，见宣无害，言上，徵为大厩丞。", "len": 24}
{"sid": "122_酷吏列传.38.s4", "chapter": "122_酷吏列传", "para": "38", "seq": 4, "text": "官事辨，稍迁至御史及中丞。", "len": 13}
{"sid": "122_酷吏列传.38.s5", "chapter": "122_酷吏列传", "para": "38", "seq": 5, "text": "使治主父偃及治淮南反狱，所以微文深诋，杀者甚众，称为敢决疑。", "len": 30}
{"sid": "122_酷吏列传.38.s6", "chapter": "122_酷吏列传", "para": "38", "seq": 6, "text": "数废数起，为御史及中丞者几二十岁。", "len": 17}
{"sid": "122_酷吏列传.38.s7", "chapter": "122_酷吏列传", "para": "38", "seq": 7, "text": "王温舒免中尉，而宣为左内史。", "len": 14}
{"sid": "122_酷吏列传.38.s8", "chapter": "122_酷吏列传", "para": "38", "seq": 8, "text": "其治米盐，事大小皆关其手，自部署县名曹实物，官吏令丞不得擅摇，痛以重法绳之。", "len": 38}
{"sid": "122_酷吏列传.38.s9", "chapter": "122_酷吏列传", "para": "38", "seq": 9, "text": "居官数年，一切郡中为小治辨，然独宣以小致大，能因力行之，难以为经。", "len": 33}
{"sid": "122_酷吏列传.38.s10", "chapter": "122_酷吏列传", "para": "38", "seq": 10, "text": "中废。", "len": 3}
{"sid": "122_酷吏列传.38.s11", "chapter": "122_酷吏列传", "para": "38", "seq": 11, "text": "为右扶风，坐怨成信，信亡藏上林中，宣使郿令格杀信，吏卒格信时，射中上林苑门，宣下吏诋罪，以为大逆，当族，自杀。", "len": 55}
{"sid": "122_酷吏列传.38.s12", "chapter": "122_酷吏列传", "para": "38", "seq": 12, "text": "而杜周任用。", "len": 6}
{"sid": "122_酷吏列传.39.s1", "chapter": "122_酷吏列传", "para": "39", "seq": 1, "text": "杜周者，南阳杜衍人。", "len": 10}
{"sid": "122_酷吏列传.39.s2", "chapter": "122_酷吏列传", "para": "39", "seq": 2, "text": "义纵为南阳守，以为爪牙，举为廷尉史。", "len": 18}
{"sid": "122_酷吏列传.39.s3", "chapter": "122_酷吏列传", "para": "39", "seq": 3, "text": "事张汤，汤数言其无害，至御史。", "len": 15}
{"sid": "122_酷吏列传.39.s4", "chapter": "122_酷吏列传", "para": "39", "seq": 4, "text": "使案边失亡，所论杀甚众。", "len": 12}
{"sid": "122_酷吏列传.39.s5", "chapter": "122_酷吏列传", "para": "39", "seq": 5, "text": "奏事中上意，任用，与减宣相编，更为中丞十馀岁。", "len": 23}
{"sid": "122_酷吏列传.40.s1", "chapter": "122_酷吏列传", "para": "40", "seq": 1, "text": "其治与宣相放，然重迟，外宽，内深次骨。", "len": 19}
{"sid": "122_酷吏列传.40.s2", "chapter": "122_酷吏列传", "para": "40", "seq": 2, "text": "宣为左内史，周为廷尉，其治大放张汤而善候伺。", "len": 22}
{"sid": "122_酷吏列传.40.s3", "chapter": "122_酷吏列传", "para": "40", "seq": 3, "text": "上所欲挤者，因而陷之；上所欲释者，久系待问而微见其冤状。", "len": 28}
{"sid": "122_酷吏列传.40.s4", "chapter": "122_酷吏列传", "para": "40", "seq": 4, "text": "客有让周曰：“君为天子决平，不循三尺法，专以人主意指为狱。", "len": 29}
{"sid": "122_酷吏列传.40.s5", "chapter": "122_酷吏列传", "para": "40", "seq": 5, "text": "狱者固如是乎？", "len": 7}
{"sid": "122_酷吏列传.40.s6", "chapter": "122_酷吏列传", "para": "40", "seq": 6, "text": "” 周曰：“三尺安出哉？", "len": 12}
{"sid": "122_酷吏列传.40.s7", "chapter": "122_酷吏列传", "para": "40", "seq": 7, "text": "前主所是著为律，後主所是疏为令，当时为是，何古之法乎！”", "len": 28}
{"sid": "122_酷吏列传.41.s1", "chapter": "122_酷吏列传", "para": "41", "seq": 1, "text": "至周为廷尉，诏狱亦益多矣。", "len": 13}
{"sid": "122_酷吏列传.41.s2", "chapter": "122_酷吏列传", "para": "41", "seq": 2, "text": "二千石系者新故相因，不减百馀人。", "len": 16}
{"sid": "122_酷吏列传.41.s3", "chapter": "122_酷吏列传", "para": "41", "seq": 3, "text": "郡吏大府举之廷尉，一岁至千馀章。", "len": 16}
{"sid": "122_酷吏列传.41.s4", "chapter": "122_酷吏列传", "para": "41", "seq": 4, "text": "章大者连逮证案数百，小者数十人；远者数千，近者数百里。", "len": 27}
{"sid": "122_酷吏列传.41.s5", "chapter": "122_酷吏列传", "para": "41", "seq": 5, "text": "会狱，吏因责如章告劾，不服，以笞掠定之。", "len": 20}
{"sid": "122_酷吏列传.41.s6", "chapter": "122_酷吏列传", "para": "41", "seq": 6, "text": "於是闻有逮皆亡匿。", "len": 9}
{"sid": "122_酷吏列传.41.s7", "chapter": "122_酷吏列传", "para": "41", "seq": 7, "text": "狱久者至更数赦十有馀岁而相告言，大抵尽诋以不道以上。", "len": 26}
{"sid": "122_酷吏列传.41.s8", "chapter": "122_酷吏列传", "para": "41", "seq": 8, "text": "廷尉及中都官诏狱逮至六七万人，吏所增加十万馀人。", "len": 24}
{"sid": "122_酷吏列传.42.s1", "chapter": "122_酷吏列传", "para": "42", "seq": 1, "text": "周中废，後为执金吾，逐盗，捕治桑弘羊、卫皇后昆弟子刻深，天子以为尽力无私，迁为御史大夫。", "len": 44}
{"sid": "122_酷吏列传.42.s2", "chapter": "122_酷吏列传", "para": "42", "seq": 2, "text": "家两子，夹河为守。", "len": 9}
{"sid": "122_酷吏列传.42.s3", "chapter": "122_酷吏列传", "para": "42", "seq": 3, "text": "其治暴酷皆甚於王温舒等矣。", "len": 13}
{"sid": "122_酷吏列传.42.s4", "chapter": "122_酷吏列传", "para": "42", "seq": 4, "text": "杜周初徵为廷史，有一马，且不全；及身久任事，至三公列，子孙尊官，家訾累数巨万矣。", "len": 40}
{"sid": "122_酷吏列传.42.s5", "chapter": "122_酷吏列传", "para": "42", "seq": 5, "text": "::: 太史公曰", "len": 8}
{"sid": "122_酷吏列传.43.s1", "chapter": "122_酷吏列传", "para": "43", "seq": 1, "text": "太史公曰：自郅都、杜周十人者，此皆以酷烈为声。", "len": 23}
{"sid": "122_酷吏列传.43.s2", "chapter": "122_酷吏列传", "para": "43", "seq": 2, "text": "然郅都伉直，引是非，争天下大体。", "len": 16}
{"sid": "122_酷吏列传.43.s3", "chapter": "122_酷吏列传", "para": "43", "seq": 3, "text": "张汤以知阴阳，人主与俱上下，时数辩当否，国家赖其便。", "len": 26}
{"sid": "122_酷吏列传.43.s4", "chapter": "122_酷吏列传", "para": "43", "seq": 4, "text": "赵禹时据法守正。", "len": 8}
{"sid": "122_酷吏列传.43.s5", "chapter": "122_酷吏列传", "para": "43", "seq": 5, "text": "杜周从谀，以少言为重。", "len": 11}
{"sid": "122_酷吏列传.43.s6", "chapter": "122_酷吏列传", "para": "43", "seq": 6, "text": "自张汤死後，网密，多诋严，官事浸以秏废。", "len": 20}
{"sid": "122_酷吏列传.43.s7", "chapter": "122_酷吏列传", "para": "43", "seq": 7, "text": "九卿碌碌奉其官，救过不赡，何暇论绳墨之外乎！", "len": 22}
{"sid": "122_酷吏列传.43.s8", "chapter": "122_酷吏列传", "para": "43", "seq": 8, "text": "然此十人中，其廉者足以为仪表，其污者足以为戒，方略教导，禁奸止邪，一切亦皆彬彬质有其文武焉。", "len": 46}
{"sid": "122_酷吏列传.43.s9", "chapter": "122_酷吏列传", "para": "43", "seq": 9, "text": "虽惨酷，斯称其位矣。", "len": 10}
{"sid": "122_酷吏列传.43.s10", "chapter": "122_酷吏列传", "para": "43", "seq": 10, "text": "至若蜀守冯当暴挫，广汉李贞擅磔人，东郡弥仆锯项，天水骆璧推咸，河东褚广妄杀，京兆无忌、冯翊殷周蝮鸷，水衡阎奉朴击卖请，何足数哉！", "len": 64}
{"sid": "122_酷吏列传.43.s11", "chapter": "122_酷吏列传", "para": "43", "seq": 11, "text": "何足数哉！", "len": 5}
{"sid": "122_酷吏列传.43.s12", "chapter": "122_酷吏列传", "para": "43", "seq": 12, "text": "::: ::: 赞", "len": 9}
{"sid": "122_酷吏列传.44.s1", "chapter": "122_酷吏列传", "para": "44", "seq": 1, "text": "太上失德，法令滋起。", "len": 10}
{"sid": "122_酷吏列传.44.s2", "chapter": "122_酷吏列传", "para": "44", "seq": 2, "text": "破觚为圆，禁暴不止。", "len": 10}
{"sid": "122_酷吏列传.44.s3", "chapter": "122_酷吏列传", "para": "44", "seq": 3, "text": "奸伪斯炽，惨酷爰始。", "len": 10}
{"sid": "122_酷吏列传.44.s4", "chapter": "122_酷吏列传", "para": "44", "seq": 4, "text": "乳兽扬威，苍鹰侧视。", "len": 10}
{"sid": "122_酷吏列传.44.s5", "chapter": "122_酷吏列传", "para": "44", "seq": 5, "text": "舞文巧诋，怀生何恃！", "len": 10}
{"sid": "122_酷吏列传.44.s6", "chapter": "122_酷吏列传", "para": "44", "seq": 6, "text": ":::", "len": 3}
