{"sid": "050_楚元王世家.1.1.s1", "chapter": "050_楚元王世家", "para": "1.1", "seq": 1, "text": "楚元王刘交者，高祖之同母少弟也，字游。", "len": 19}
{"sid": "050_楚元王世家.2.s1", "chapter": "050_楚元王世家", "para": "2", "seq": 1, "text": "高祖兄弟四人，长兄伯，伯蚤卒。", "len": 15}
{"sid": "050_楚元王世家.2.s2", "chapter": "050_楚元王世家", "para": "2", "seq": 2, "text": "始高祖微时，尝辟事，时时与宾客过巨嫂食。", "len": 20}
{"sid": "050_楚元王世家.2.s3", "chapter": "050_楚元王世家", "para": "2", "seq": 3, "text": "嫂厌叔，叔与客来，嫂详为羹尽，栎釜，宾客以故去。", "len": 24}
{"sid": "050_楚元王世家.2.s4", "chapter": "050_楚元王世家", "para": "2", "seq": 4, "text": "已而视釜中尚有羹，高祖由此怨其嫂。", "len": 17}
{"sid": "050_楚元王世家.2.s5", "chapter": "050_楚元王世家", "para": "2", "seq": 5, "text": "及高祖为帝，封昆弟，而伯子独不得封。", "len": 18}
{"sid": "050_楚元王世家.2.s6", "chapter": "050_楚元王世家", "para": "2", "seq": 6, "text": "太上皇以为言，高祖曰：”某非忘封之也，为其母不长者耳。", "len": 27}
{"sid": "050_楚元王世家.2.s7", "chapter": "050_楚元王世家", "para": "2", "seq": 7, "text": "” 於是乃封其子信为羹颉侯。", "len": 14}
{"sid": "050_楚元王世家.2.s8", "chapter": "050_楚元王世家", "para": "2", "seq": 8, "text": "而王次兄仲於代。", "len": 8}
{"sid": "050_楚元王世家.1.3.s1", "chapter": "050_楚元王世家", "para": "1.3", "seq": 1, "text": "高祖六年，已禽楚王韩信於陈，乃以弟交为楚王，都彭城。", "len": 26}
{"sid": "050_楚元王世家.1.3.s2", "chapter": "050_楚元王世家", "para": "1.3", "seq": 2, "text": "即位二十三年卒，子夷王郢立。", "len": 14}
{"sid": "050_楚元王世家.2.1.s1", "chapter": "050_楚元王世家", "para": "2.1", "seq": 1, "text": "王戊立二十年，冬，坐为薄太后服私奸，削东海郡。", "len": 23}
{"sid": "050_楚元王世家.2.1.s2", "chapter": "050_楚元王世家", "para": "2.1", "seq": 2, "text": "春，戊与吴王合谋反，其相张尚、太傅赵夷吾谏，不听。", "len": 25}
{"sid": "050_楚元王世家.2.1.s3", "chapter": "050_楚元王世家", "para": "2.1", "seq": 3, "text": "戊则杀尚、夷吾，起兵与吴西攻梁，破棘壁。", "len": 20}
{"sid": "050_楚元王世家.2.1.s4", "chapter": "050_楚元王世家", "para": "2.1", "seq": 4, "text": "至昌邑南，与汉将周亚夫战。", "len": 13}
{"sid": "050_楚元王世家.2.1.s5", "chapter": "050_楚元王世家", "para": "2.1", "seq": 5, "text": "汉绝吴楚粮道，士卒饥，吴王走，楚王戊自杀，军遂降汉。", "len": 26}
{"sid": "050_楚元王世家.3.1.s1", "chapter": "050_楚元王世家", "para": "3.1", "seq": 1, "text": "汉已平吴楚，孝景帝欲以德侯子续吴，以元王子礼续楚。", "len": 25}
{"sid": "050_楚元王世家.3.1.s2", "chapter": "050_楚元王世家", "para": "3.1", "seq": 2, "text": "窦太后曰：“吴王，老人也，宜为宗室顺善。", "len": 20}
{"sid": "050_楚元王世家.3.1.s3", "chapter": "050_楚元王世家", "para": "3.1", "seq": 3, "text": "今乃首率七国，纷乱天下，柰何续其後！", "len": 18}
{"sid": "050_楚元王世家.3.1.s4", "chapter": "050_楚元王世家", "para": "3.1", "seq": 4, "text": "” 不许吴，许立楚後。", "len": 11}
{"sid": "050_楚元王世家.3.1.s5", "chapter": "050_楚元王世家", "para": "3.1", "seq": 5, "text": "是时礼为汉宗正。", "len": 8}
{"sid": "050_楚元王世家.3.1.s6", "chapter": "050_楚元王世家", "para": "3.1", "seq": 6, "text": "乃拜礼为楚王，奉元王宗庙，是为楚文王。", "len": 19}
{"sid": "050_楚元王世家.4.1.s1", "chapter": "050_楚元王世家", "para": "4.1", "seq": 1, "text": "文王立三年卒，子安王道立。", "len": 13}
{"sid": "050_楚元王世家.4.1.s2", "chapter": "050_楚元王世家", "para": "4.1", "seq": 2, "text": "安王二十二年卒，子襄王注立。", "len": 14}
{"sid": "050_楚元王世家.4.1.s3", "chapter": "050_楚元王世家", "para": "4.1", "seq": 3, "text": "襄王立十四年卒，子王纯代立。", "len": 14}
{"sid": "050_楚元王世家.4.1.s4", "chapter": "050_楚元王世家", "para": "4.1", "seq": 4, "text": "王纯立，地节二年，中人上书告楚王谋反，王自杀，国除，入汉为彭城郡。", "len": 33}
{"sid": "050_楚元王世家.5.1.s1", "chapter": "050_楚元王世家", "para": "5.1", "seq": 1, "text": "赵王刘遂者，其父高祖中子，名友，谥曰”幽”。", "len": 22}
{"sid": "050_楚元王世家.5.1.s2", "chapter": "050_楚元王世家", "para": "5.1", "seq": 2, "text": "幽王以忧死，故为”幽”。", "len": 12}
{"sid": "050_楚元王世家.5.1.s3", "chapter": "050_楚元王世家", "para": "5.1", "seq": 3, "text": "高后王吕禄於赵，一岁而高后崩。", "len": 15}
{"sid": "050_楚元王世家.5.1.s4", "chapter": "050_楚元王世家", "para": "5.1", "seq": 4, "text": "大臣诛诸吕吕禄等，乃立幽王子遂为赵王。", "len": 19}
{"sid": "050_楚元王世家.6.1.s1", "chapter": "050_楚元王世家", "para": "6.1", "seq": 1, "text": "孝文帝即位二年，立遂弟辟彊，取赵之河间郡为河间王，为文王。", "len": 29}
{"sid": "050_楚元王世家.6.1.s2", "chapter": "050_楚元王世家", "para": "6.1", "seq": 2, "text": "立十三年卒，子哀王福立。", "len": 12}
{"sid": "050_楚元王世家.6.1.s3", "chapter": "050_楚元王世家", "para": "6.1", "seq": 3, "text": "一年卒，无子，绝後，国除，入于汉。", "len": 17}
{"sid": "050_楚元王世家.7.1.s1", "chapter": "050_楚元王世家", "para": "7.1", "seq": 1, "text": "遂既王赵二十六年，孝景帝时坐晁错以適削赵王常山之郡。", "len": 26}
{"sid": "050_楚元王世家.7.1.s2", "chapter": "050_楚元王世家", "para": "7.1", "seq": 2, "text": "吴楚反，赵王遂与合谋起兵。", "len": 13}
{"sid": "050_楚元王世家.7.1.s3", "chapter": "050_楚元王世家", "para": "7.1", "seq": 3, "text": "其相建德、内史王悍谏，不听。", "len": 14}
{"sid": "050_楚元王世家.7.1.s4", "chapter": "050_楚元王世家", "para": "7.1", "seq": 4, "text": "遂烧杀建德、王悍，发兵屯其西界，欲待吴与俱西。", "len": 23}
{"sid": "050_楚元王世家.7.1.s5", "chapter": "050_楚元王世家", "para": "7.1", "seq": 5, "text": "北使匈奴，与连和攻汉。", "len": 11}
{"sid": "050_楚元王世家.7.1.s6", "chapter": "050_楚元王世家", "para": "7.1", "seq": 6, "text": "汉使曲周侯郦寄击之。", "len": 10}
{"sid": "050_楚元王世家.7.1.s7", "chapter": "050_楚元王世家", "para": "7.1", "seq": 7, "text": "赵王遂还，城守邯郸，相距七月。", "len": 15}
{"sid": "050_楚元王世家.7.1.s8", "chapter": "050_楚元王世家", "para": "7.1", "seq": 8, "text": "吴楚败於梁，不能西。", "len": 10}
{"sid": "050_楚元王世家.7.1.s9", "chapter": "050_楚元王世家", "para": "7.1", "seq": 9, "text": "匈奴闻之，亦止，不肯入汉边。", "len": 14}
{"sid": "050_楚元王世家.7.1.s10", "chapter": "050_楚元王世家", "para": "7.1", "seq": 10, "text": "栾布自破齐还，乃并兵引水灌赵城。", "len": 16}
{"sid": "050_楚元王世家.7.1.s11", "chapter": "050_楚元王世家", "para": "7.1", "seq": 11, "text": "赵城坏，赵王自杀，邯郸遂降。", "len": 14}
{"sid": "050_楚元王世家.7.1.s12", "chapter": "050_楚元王世家", "para": "7.1", "seq": 12, "text": "赵幽王绝後。", "len": 6}
{"sid": "050_楚元王世家.8.1.s1", "chapter": "050_楚元王世家", "para": "8.1", "seq": 1, "text": "太史公曰：国之将兴，必有祯祥，君子用而小人退。", "len": 23}
{"sid": "050_楚元王世家.8.1.s2", "chapter": "050_楚元王世家", "para": "8.1", "seq": 2, "text": "国之将亡，贤人隐，乱臣贵。", "len": 13}
{"sid": "050_楚元王世家.8.1.s3", "chapter": "050_楚元王世家", "para": "8.1", "seq": 3, "text": "使楚王戊毋刑申公，遵其言，赵任防与先生，岂有篡杀之谋，为天下僇哉？", "len": 33}
{"sid": "050_楚元王世家.8.1.s4", "chapter": "050_楚元王世家", "para": "8.1", "seq": 4, "text": "贤人乎，贤人乎！", "len": 8}
{"sid": "050_楚元王世家.8.1.s5", "chapter": "050_楚元王世家", "para": "8.1", "seq": 5, "text": "非质有其内，恶能用之哉？", "len": 12}
{"sid": "050_楚元王世家.8.1.s6", "chapter": "050_楚元王世家", "para": "8.1", "seq": 6, "text": "甚矣，“安危在出令，存亡在所任”，诚哉是言也！", "len": 23}
{"sid": "050_楚元王世家.8.1.s7", "chapter": "050_楚元王世家", "para": "8.1", "seq": 7, "text": "::: 赞", "len": 5}
{"sid": "050_楚元王世家.9.s1", "chapter": "050_楚元王世家", "para": "9", "seq": 1, "text": "汉封同姓，楚有令名。", "len": 10}
{"sid": "050_楚元王世家.9.s2", "chapter": "050_楚元王世家", "para": "9", "seq": 2, "text": "既灭韩信，王於彭城。", "len": 10}
{"sid": "050_楚元王世家.9.s3", "chapter": "050_楚元王世家", "para": "9", "seq": 3, "text": "穆生置醴，韦孟作程。", "len": 10}
{"sid": "050_楚元王世家.9.s4", "chapter": "050_楚元王世家", "para": "9", "seq": 4, "text": "王戊弃德，与吴连兵。", "len": 10}
{"sid": "050_楚元王世家.9.s5", "chapter": "050_楚元王世家", "para": "9", "seq": 5, "text": "太后命礼，为楚罪轻。", "len": 10}
{"sid": "050_楚元王世家.9.s6", "chapter": "050_楚元王世家", "para": "9", "seq": 6, "text": "文襄继立，世挺才英。", "len": 10}
{"sid": "050_楚元王世家.9.s7", "chapter": "050_楚元王世家", "para": "9", "seq": 7, "text": "如何赵遂，代殒厥声！", "len": 10}
{"sid": "050_楚元王世家.9.s8", "chapter": "050_楚元王世家", "para": "9", "seq": 8, "text": "兴亡之兆，所任宜明。", "len": 10}
{"sid": "050_楚元王世家.9.s9", "chapter": "050_楚元王世家", "para": "9", "seq": 9, "text": ":::", "len": 3}
