{"sid": "036_陈杞世家.1.s1", "chapter": "036_陈杞世家", "para": "1", "seq": 1, "text": "陈胡公满者，虞帝舜之後也。", "len": 13}
{"sid": "036_陈杞世家.1.s2", "chapter": "036_陈杞世家", "para": "1", "seq": 2, "text": "昔舜为庶人时，尧妻之二女，居于妫汭，其後因为氏姓，姓妫氏。", "len": 29}
{"sid": "036_陈杞世家.1.s3", "chapter": "036_陈杞世家", "para": "1", "seq": 3, "text": "舜已崩，传禹天下，而舜子商均为封国。", "len": 18}
{"sid": "036_陈杞世家.1.s4", "chapter": "036_陈杞世家", "para": "1", "seq": 4, "text": "夏后之时，或失或续。", "len": 10}
{"sid": "036_陈杞世家.1.s5", "chapter": "036_陈杞世家", "para": "1", "seq": 5, "text": "至于周武王克殷纣，乃复求舜後，得妫满，封之於陈，以奉帝舜祀，是为胡公。", "len": 35}
{"sid": "036_陈杞世家.2.s1", "chapter": "036_陈杞世家", "para": "2", "seq": 1, "text": "胡公卒，子申公犀侯立。", "len": 11}
{"sid": "036_陈杞世家.2.s2", "chapter": "036_陈杞世家", "para": "2", "seq": 2, "text": "申公卒，弟相公皋羊立。", "len": 11}
{"sid": "036_陈杞世家.2.s3", "chapter": "036_陈杞世家", "para": "2", "seq": 3, "text": "相公卒，立申公子突，是为孝公。", "len": 15}
{"sid": "036_陈杞世家.2.s4", "chapter": "036_陈杞世家", "para": "2", "seq": 4, "text": "孝公卒，子慎公圉戎立。", "len": 11}
{"sid": "036_陈杞世家.2.s5", "chapter": "036_陈杞世家", "para": "2", "seq": 5, "text": "慎公当周厉王时。", "len": 8}
{"sid": "036_陈杞世家.2.s6", "chapter": "036_陈杞世家", "para": "2", "seq": 6, "text": "慎公卒，子幽公宁立。", "len": 10}
{"sid": "036_陈杞世家.3.s1", "chapter": "036_陈杞世家", "para": "3", "seq": 1, "text": "幽公十二年，周厉王奔于彘。", "len": 13}
{"sid": "036_陈杞世家.4.s1", "chapter": "036_陈杞世家", "para": "4", "seq": 1, "text": "二十三年，幽公卒，子釐公孝立。", "len": 15}
{"sid": "036_陈杞世家.4.s2", "chapter": "036_陈杞世家", "para": "4", "seq": 2, "text": "釐公六年，周宣王即位。", "len": 11}
{"sid": "036_陈杞世家.4.s3", "chapter": "036_陈杞世家", "para": "4", "seq": 3, "text": "三十六年，釐公卒，子武公灵立。", "len": 15}
{"sid": "036_陈杞世家.4.s4", "chapter": "036_陈杞世家", "para": "4", "seq": 4, "text": "武公十五年卒，子夷公说立。", "len": 13}
{"sid": "036_陈杞世家.4.s5", "chapter": "036_陈杞世家", "para": "4", "seq": 5, "text": "是岁，周幽王即位。", "len": 9}
{"sid": "036_陈杞世家.4.s6", "chapter": "036_陈杞世家", "para": "4", "seq": 6, "text": "夷公三年卒，弟平公燮立。", "len": 12}
{"sid": "036_陈杞世家.4.s7", "chapter": "036_陈杞世家", "para": "4", "seq": 7, "text": "平公七年，周幽王为犬戎所杀，周东徙。", "len": 18}
{"sid": "036_陈杞世家.4.s8", "chapter": "036_陈杞世家", "para": "4", "seq": 8, "text": "秦始列为诸侯。", "len": 7}
{"sid": "036_陈杞世家.5.s1", "chapter": "036_陈杞世家", "para": "5", "seq": 1, "text": "二十三年，平公卒，子文公圉立。", "len": 15}
{"sid": "036_陈杞世家.6.s1", "chapter": "036_陈杞世家", "para": "6", "seq": 1, "text": "文公元年，取蔡女，生子佗。", "len": 13}
{"sid": "036_陈杞世家.6.s2", "chapter": "036_陈杞世家", "para": "6", "seq": 2, "text": "十年，文公卒，长子桓公鲍立。", "len": 14}
{"sid": "036_陈杞世家.7.s1", "chapter": "036_陈杞世家", "para": "7", "seq": 1, "text": "桓公二十三年，鲁隐公初立。", "len": 13}
{"sid": "036_陈杞世家.7.s2", "chapter": "036_陈杞世家", "para": "7", "seq": 2, "text": "二十六年，卫杀其君州吁。", "len": 12}
{"sid": "036_陈杞世家.7.s3", "chapter": "036_陈杞世家", "para": "7", "seq": 3, "text": "三十三年，鲁弑其君隐公。", "len": 12}
{"sid": "036_陈杞世家.8.s1", "chapter": "036_陈杞世家", "para": "8", "seq": 1, "text": "三十八年正月甲戌己丑，桓公鲍卒。", "len": 16}
{"sid": "036_陈杞世家.8.s2", "chapter": "036_陈杞世家", "para": "8", "seq": 2, "text": "桓公弟佗，其母蔡女，故蔡人为佗杀五父及桓公太子免而立佗，是为厉公。", "len": 33}
{"sid": "036_陈杞世家.8.s3", "chapter": "036_陈杞世家", "para": "8", "seq": 3, "text": "桓公病而乱作，国人分散，故再赴。", "len": 16}
{"sid": "036_陈杞世家.9.s1", "chapter": "036_陈杞世家", "para": "9", "seq": 1, "text": "厉公二年，生子敬仲完。", "len": 11}
{"sid": "036_陈杞世家.9.s2", "chapter": "036_陈杞世家", "para": "9", "seq": 2, "text": "周太史过陈，陈厉公使以周易筮之，卦得观之否：“是为观国之光，利用宾于王。", "len": 36}
{"sid": "036_陈杞世家.9.s3", "chapter": "036_陈杞世家", "para": "9", "seq": 3, "text": "此其代陈有国乎？", "len": 8}
{"sid": "036_陈杞世家.9.s4", "chapter": "036_陈杞世家", "para": "9", "seq": 4, "text": "不在此，其在异国？", "len": 9}
{"sid": "036_陈杞世家.9.s5", "chapter": "036_陈杞世家", "para": "9", "seq": 5, "text": "非此其身，在其子孙。", "len": 10}
{"sid": "036_陈杞世家.9.s6", "chapter": "036_陈杞世家", "para": "9", "seq": 6, "text": "若在异国，必姜姓。", "len": 9}
{"sid": "036_陈杞世家.9.s7", "chapter": "036_陈杞世家", "para": "9", "seq": 7, "text": "姜姓，太岳之後。", "len": 8}
{"sid": "036_陈杞世家.9.s8", "chapter": "036_陈杞世家", "para": "9", "seq": 8, "text": "物莫能两大，陈衰，此其昌乎？”", "len": 15}
{"sid": "036_陈杞世家.10.s1", "chapter": "036_陈杞世家", "para": "10", "seq": 1, "text": "厉公取蔡女，蔡女与蔡人乱，厉公数如蔡淫。", "len": 20}
{"sid": "036_陈杞世家.10.s2", "chapter": "036_陈杞世家", "para": "10", "seq": 2, "text": "七年，厉公所杀桓公太子免之三弟，长曰跃，中曰林，少曰杵臼，共令蔡人诱厉公以好女，与蔡人共杀厉公而立跃，是为利公。", "len": 56}
{"sid": "036_陈杞世家.10.s3", "chapter": "036_陈杞世家", "para": "10", "seq": 3, "text": "利公者，桓公子也。", "len": 9}
{"sid": "036_陈杞世家.10.s4", "chapter": "036_陈杞世家", "para": "10", "seq": 4, "text": "利公立五月卒，立中弟林，是为庄公。", "len": 17}
{"sid": "036_陈杞世家.10.s5", "chapter": "036_陈杞世家", "para": "10", "seq": 5, "text": "庄公七年卒，少弟杵臼立，是为宣公。", "len": 17}
{"sid": "036_陈杞世家.11.s1", "chapter": "036_陈杞世家", "para": "11", "seq": 1, "text": "宣公三年，楚武王卒，楚始彊。", "len": 14}
{"sid": "036_陈杞世家.11.s2", "chapter": "036_陈杞世家", "para": "11", "seq": 2, "text": "十七年，周惠王娶陈女为后。", "len": 13}
{"sid": "036_陈杞世家.12.s1", "chapter": "036_陈杞世家", "para": "12", "seq": 1, "text": "二十一年，宣公後有嬖姬生子款，欲立之，乃杀其太子御寇。", "len": 27}
{"sid": "036_陈杞世家.12.s2", "chapter": "036_陈杞世家", "para": "12", "seq": 2, "text": "御寇素爱厉公子完，完惧祸及己，乃奔齐。", "len": 19}
{"sid": "036_陈杞世家.12.s3", "chapter": "036_陈杞世家", "para": "12", "seq": 3, "text": "齐桓公欲使陈完为卿，完曰：“羁旅之臣，幸得免负檐，君之惠也，不敢当高位。", "len": 36}
{"sid": "036_陈杞世家.12.s4", "chapter": "036_陈杞世家", "para": "12", "seq": 4, "text": "” 桓公使为工正。", "len": 9}
{"sid": "036_陈杞世家.12.s5", "chapter": "036_陈杞世家", "para": "12", "seq": 5, "text": "齐懿仲欲妻陈敬仲，卜之，占曰：“是谓凤皇于飞，和鸣锵锵。", "len": 28}
{"sid": "036_陈杞世家.12.s6", "chapter": "036_陈杞世家", "para": "12", "seq": 6, "text": "有妫之後，将育于姜。", "len": 10}
{"sid": "036_陈杞世家.12.s7", "chapter": "036_陈杞世家", "para": "12", "seq": 7, "text": "五世其昌，并于正卿。", "len": 10}
{"sid": "036_陈杞世家.12.s8", "chapter": "036_陈杞世家", "para": "12", "seq": 8, "text": "八世之後，莫之与京。”", "len": 11}
{"sid": "036_陈杞世家.13.s1", "chapter": "036_陈杞世家", "para": "13", "seq": 1, "text": "三十七年，齐桓公伐蔡，蔡败；南侵楚，至召陵，还过陈。", "len": 26}
{"sid": "036_陈杞世家.13.s2", "chapter": "036_陈杞世家", "para": "13", "seq": 2, "text": "陈大夫辕涛涂恶其过陈，诈齐令出东道。", "len": 18}
{"sid": "036_陈杞世家.13.s3", "chapter": "036_陈杞世家", "para": "13", "seq": 3, "text": "东道恶，桓公怒，执陈辕涛涂。", "len": 14}
{"sid": "036_陈杞世家.13.s4", "chapter": "036_陈杞世家", "para": "13", "seq": 4, "text": "是岁，晋献公杀其太子申生。", "len": 13}
{"sid": "036_陈杞世家.14.s1", "chapter": "036_陈杞世家", "para": "14", "seq": 1, "text": "四十五年，宣公卒，子款立，是为穆公。", "len": 18}
{"sid": "036_陈杞世家.14.s2", "chapter": "036_陈杞世家", "para": "14", "seq": 2, "text": "穆公五年，齐桓公卒。", "len": 10}
{"sid": "036_陈杞世家.14.s3", "chapter": "036_陈杞世家", "para": "14", "seq": 3, "text": "十六年，晋文公败楚师于城濮。", "len": 14}
{"sid": "036_陈杞世家.14.s4", "chapter": "036_陈杞世家", "para": "14", "seq": 4, "text": "是岁，穆公卒，子共公朔立。", "len": 13}
{"sid": "036_陈杞世家.14.s5", "chapter": "036_陈杞世家", "para": "14", "seq": 5, "text": "共公六年，楚太子商臣弑其父成王代立，是为穆王。", "len": 23}
{"sid": "036_陈杞世家.14.s6", "chapter": "036_陈杞世家", "para": "14", "seq": 6, "text": "十一年，秦穆公卒。", "len": 9}
{"sid": "036_陈杞世家.14.s7", "chapter": "036_陈杞世家", "para": "14", "seq": 7, "text": "十八年，共公卒，子灵公平国立。", "len": 15}
{"sid": "036_陈杞世家.15.s1", "chapter": "036_陈杞世家", "para": "15", "seq": 1, "text": "灵公元年，楚庄王即位。", "len": 11}
{"sid": "036_陈杞世家.15.s2", "chapter": "036_陈杞世家", "para": "15", "seq": 2, "text": "六年，楚伐陈。", "len": 7}
{"sid": "036_陈杞世家.15.s3", "chapter": "036_陈杞世家", "para": "15", "seq": 3, "text": "十年，陈及楚平。", "len": 8}
{"sid": "036_陈杞世家.16.s1", "chapter": "036_陈杞世家", "para": "16", "seq": 1, "text": "十四年，灵公与其大夫孔宁、仪行父皆通於夏姬，衷其衣以戏於朝。", "len": 30}
{"sid": "036_陈杞世家.16.s2", "chapter": "036_陈杞世家", "para": "16", "seq": 2, "text": "泄冶谏曰：“君臣淫乱，民何效焉？", "len": 16}
{"sid": "036_陈杞世家.16.s3", "chapter": "036_陈杞世家", "para": "16", "seq": 3, "text": "” 灵公以告二子，二子请杀泄冶，公弗禁，遂杀泄冶。", "len": 25}
{"sid": "036_陈杞世家.16.s4", "chapter": "036_陈杞世家", "para": "16", "seq": 4, "text": "十五年，灵公与二子饮於夏氏。", "len": 14}
{"sid": "036_陈杞世家.16.s5", "chapter": "036_陈杞世家", "para": "16", "seq": 5, "text": "公戏二子曰：“徵舒似汝。", "len": 12}
{"sid": "036_陈杞世家.16.s6", "chapter": "036_陈杞世家", "para": "16", "seq": 6, "text": "” 二子曰：“亦似公。", "len": 11}
{"sid": "036_陈杞世家.16.s7", "chapter": "036_陈杞世家", "para": "16", "seq": 7, "text": "” 徵舒怒。", "len": 6}
{"sid": "036_陈杞世家.16.s8", "chapter": "036_陈杞世家", "para": "16", "seq": 8, "text": "灵公罢酒出，徵舒伏弩厩门射杀灵公。", "len": 17}
{"sid": "036_陈杞世家.16.s9", "chapter": "036_陈杞世家", "para": "16", "seq": 9, "text": "孔宁、仪行父皆奔楚，灵公太子午奔晋。", "len": 18}
{"sid": "036_陈杞世家.16.s10", "chapter": "036_陈杞世家", "para": "16", "seq": 10, "text": "徵舒自立为陈侯。", "len": 8}
{"sid": "036_陈杞世家.16.s11", "chapter": "036_陈杞世家", "para": "16", "seq": 11, "text": "徵舒，故陈大夫也。", "len": 9}
{"sid": "036_陈杞世家.16.s12", "chapter": "036_陈杞世家", "para": "16", "seq": 12, "text": "夏姬，御叔之妻，舒之母也。", "len": 13}
{"sid": "036_陈杞世家.17.s1", "chapter": "036_陈杞世家", "para": "17", "seq": 1, "text": "成公元年冬，楚庄王为夏徵舒杀灵公，率诸侯伐陈。", "len": 23}
{"sid": "036_陈杞世家.17.s2", "chapter": "036_陈杞世家", "para": "17", "seq": 2, "text": "谓陈曰：“无惊，吾诛徵舒而已。", "len": 15}
{"sid": "036_陈杞世家.17.s3", "chapter": "036_陈杞世家", "para": "17", "seq": 3, "text": "” 已诛徵舒，因县陈而有之，群臣毕贺。", "len": 19}
{"sid": "036_陈杞世家.17.s4", "chapter": "036_陈杞世家", "para": "17", "seq": 4, "text": "申叔时使於齐来还，独不贺。", "len": 13}
{"sid": "036_陈杞世家.17.s5", "chapter": "036_陈杞世家", "para": "17", "seq": 5, "text": "庄王问其故，对曰：“鄙语有之，牵牛径人田，田主夺之牛。", "len": 27}
{"sid": "036_陈杞世家.17.s6", "chapter": "036_陈杞世家", "para": "17", "seq": 6, "text": "径则有罪矣，夺之牛，不亦甚乎？", "len": 15}
{"sid": "036_陈杞世家.17.s7", "chapter": "036_陈杞世家", "para": "17", "seq": 7, "text": "今王以徵舒为贼弑君，故徵兵诸侯，以义伐之，已而取之，以利其地，则後何以令於天下！", "len": 40}
{"sid": "036_陈杞世家.17.s8", "chapter": "036_陈杞世家", "para": "17", "seq": 8, "text": "是以不贺。", "len": 5}
{"sid": "036_陈杞世家.17.s9", "chapter": "036_陈杞世家", "para": "17", "seq": 9, "text": "” 庄王曰：“善。", "len": 9}
{"sid": "036_陈杞世家.17.s10", "chapter": "036_陈杞世家", "para": "17", "seq": 10, "text": "” 乃迎陈灵公太子午於晋而立之，复君陈如故，是为成公。", "len": 27}
{"sid": "036_陈杞世家.17.s11", "chapter": "036_陈杞世家", "para": "17", "seq": 11, "text": "孔子读史记至楚复陈，曰：“贤哉楚庄王！", "len": 19}
{"sid": "036_陈杞世家.17.s12", "chapter": "036_陈杞世家", "para": "17", "seq": 12, "text": "轻千乘之国而重一言。”", "len": 11}
{"sid": "036_陈杞世家.18.s1", "chapter": "036_陈杞世家", "para": "18", "seq": 1, "text": "八年，楚庄王卒。", "len": 8}
{"sid": "036_陈杞世家.18.s2", "chapter": "036_陈杞世家", "para": "18", "seq": 2, "text": "二十九年，陈倍楚盟。", "len": 10}
{"sid": "036_陈杞世家.18.s3", "chapter": "036_陈杞世家", "para": "18", "seq": 3, "text": "三十年，楚共王伐陈。", "len": 10}
{"sid": "036_陈杞世家.18.s4", "chapter": "036_陈杞世家", "para": "18", "seq": 4, "text": "是岁，成公卒，子哀公弱立。", "len": 13}
{"sid": "036_陈杞世家.18.s5", "chapter": "036_陈杞世家", "para": "18", "seq": 5, "text": "楚以陈丧，罢兵去。", "len": 9}
{"sid": "036_陈杞世家.19.s1", "chapter": "036_陈杞世家", "para": "19", "seq": 1, "text": "哀公三年，楚围陈，复释之。", "len": 13}
{"sid": "036_陈杞世家.19.s2", "chapter": "036_陈杞世家", "para": "19", "seq": 2, "text": "二十八年，楚公子围弑其君郏敖自立，为灵王。", "len": 21}
{"sid": "036_陈杞世家.20.s1", "chapter": "036_陈杞世家", "para": "20", "seq": 1, "text": "三十四年，初，哀公娶郑，长姬生悼太子师，少姬生偃。", "len": 25}
{"sid": "036_陈杞世家.20.s2", "chapter": "036_陈杞世家", "para": "20", "seq": 2, "text": "二嬖妾，长妾生留，少妾生胜。", "len": 14}
{"sid": "036_陈杞世家.20.s3", "chapter": "036_陈杞世家", "para": "20", "seq": 3, "text": "留有宠哀公，哀公属之其弟司徒招。", "len": 16}
{"sid": "036_陈杞世家.20.s4", "chapter": "036_陈杞世家", "para": "20", "seq": 4, "text": "哀公病，三月，招杀悼太子，立留为太子。", "len": 19}
{"sid": "036_陈杞世家.20.s5", "chapter": "036_陈杞世家", "para": "20", "seq": 5, "text": "哀公怒，欲诛招，招发兵围守哀公，哀公自经杀。", "len": 22}
{"sid": "036_陈杞世家.20.s6", "chapter": "036_陈杞世家", "para": "20", "seq": 6, "text": "招卒立留为陈君。", "len": 8}
{"sid": "036_陈杞世家.20.s7", "chapter": "036_陈杞世家", "para": "20", "seq": 7, "text": "四月，陈使使赴楚。", "len": 9}
{"sid": "036_陈杞世家.20.s8", "chapter": "036_陈杞世家", "para": "20", "seq": 8, "text": "楚灵王闻陈乱，乃杀陈使者，使公子弃疾发兵伐陈，陈君留奔郑。", "len": 29}
{"sid": "036_陈杞世家.20.s9", "chapter": "036_陈杞世家", "para": "20", "seq": 9, "text": "九月，楚围陈。", "len": 7}
{"sid": "036_陈杞世家.20.s10", "chapter": "036_陈杞世家", "para": "20", "seq": 10, "text": "十一月，灭陈。", "len": 7}
{"sid": "036_陈杞世家.20.s11", "chapter": "036_陈杞世家", "para": "20", "seq": 11, "text": "使弃疾为陈公。", "len": 7}
{"sid": "036_陈杞世家.21.s1", "chapter": "036_陈杞世家", "para": "21", "seq": 1, "text": "招之杀悼太子也，太子之子名吴，出奔晋。", "len": 19}
{"sid": "036_陈杞世家.21.s2", "chapter": "036_陈杞世家", "para": "21", "seq": 2, "text": "晋平公问太史赵曰：“陈遂亡乎？", "len": 15}
{"sid": "036_陈杞世家.21.s3", "chapter": "036_陈杞世家", "para": "21", "seq": 3, "text": "” 对曰：“陈，颛顼之族。", "len": 13}
{"sid": "036_陈杞世家.21.s4", "chapter": "036_陈杞世家", "para": "21", "seq": 4, "text": "陈氏得政於齐，乃卒亡。", "len": 11}
{"sid": "036_陈杞世家.21.s5", "chapter": "036_陈杞世家", "para": "21", "seq": 5, "text": "自幕至于瞽瞍，无违命。", "len": 11}
{"sid": "036_陈杞世家.21.s6", "chapter": "036_陈杞世家", "para": "21", "seq": 6, "text": "舜重之以明德。", "len": 7}
{"sid": "036_陈杞世家.21.s7", "chapter": "036_陈杞世家", "para": "21", "seq": 7, "text": "至於遂，世世守之。", "len": 9}
{"sid": "036_陈杞世家.21.s8", "chapter": "036_陈杞世家", "para": "21", "seq": 8, "text": "及胡公，周赐之姓，使祀虞帝。", "len": 14}
{"sid": "036_陈杞世家.21.s9", "chapter": "036_陈杞世家", "para": "21", "seq": 9, "text": "且盛德之後，必百世祀。", "len": 11}
{"sid": "036_陈杞世家.21.s10", "chapter": "036_陈杞世家", "para": "21", "seq": 10, "text": "虞之世未也，其在齐乎？”", "len": 12}
{"sid": "036_陈杞世家.22.s1", "chapter": "036_陈杞世家", "para": "22", "seq": 1, "text": "楚灵王灭陈五岁，楚公子弃疾弑灵王代立，是为平王。", "len": 24}
{"sid": "036_陈杞世家.22.s2", "chapter": "036_陈杞世家", "para": "22", "seq": 2, "text": "平王初立，欲得和诸侯，乃求故陈悼太子师之子吴，立为陈侯，是为惠公。", "len": 33}
{"sid": "036_陈杞世家.22.s3", "chapter": "036_陈杞世家", "para": "22", "seq": 3, "text": "惠公立，探续哀公卒时年而为元，空籍五岁矣。", "len": 21}
{"sid": "036_陈杞世家.23.s1", "chapter": "036_陈杞世家", "para": "23", "seq": 1, "text": "十年，陈火。", "len": 6}
{"sid": "036_陈杞世家.23.s2", "chapter": "036_陈杞世家", "para": "23", "seq": 2, "text": "十五年，吴王僚使公子光伐陈，取胡、沈而去。", "len": 21}
{"sid": "036_陈杞世家.23.s3", "chapter": "036_陈杞世家", "para": "23", "seq": 3, "text": "二十八年，吴王阖闾与子胥败楚入郢。", "len": 17}
{"sid": "036_陈杞世家.23.s4", "chapter": "036_陈杞世家", "para": "23", "seq": 4, "text": "是年，惠公卒，子怀公柳立。", "len": 13}
{"sid": "036_陈杞世家.24.s1", "chapter": "036_陈杞世家", "para": "24", "seq": 1, "text": "怀公元年，吴破楚，在郢，召陈侯。", "len": 16}
{"sid": "036_陈杞世家.24.s2", "chapter": "036_陈杞世家", "para": "24", "seq": 2, "text": "陈侯欲往，大夫曰：“吴新得意；楚王虽亡，与陈有故，不可倍。", "len": 29}
{"sid": "036_陈杞世家.24.s3", "chapter": "036_陈杞世家", "para": "24", "seq": 3, "text": "” 怀公乃以疾谢吴。", "len": 10}
{"sid": "036_陈杞世家.24.s4", "chapter": "036_陈杞世家", "para": "24", "seq": 4, "text": "四年，吴复召怀公。", "len": 9}
{"sid": "036_陈杞世家.24.s5", "chapter": "036_陈杞世家", "para": "24", "seq": 5, "text": "怀公恐，如吴。", "len": 7}
{"sid": "036_陈杞世家.24.s6", "chapter": "036_陈杞世家", "para": "24", "seq": 6, "text": "吴怒其前不往，留之，因卒吴。", "len": 14}
{"sid": "036_陈杞世家.24.s7", "chapter": "036_陈杞世家", "para": "24", "seq": 7, "text": "陈乃立怀公之子越，是为湣公。", "len": 14}
{"sid": "036_陈杞世家.25.s1", "chapter": "036_陈杞世家", "para": "25", "seq": 1, "text": "湣公六年，孔子適陈。", "len": 10}
{"sid": "036_陈杞世家.25.s2", "chapter": "036_陈杞世家", "para": "25", "seq": 2, "text": "吴王夫差伐陈，取三邑而去。", "len": 13}
{"sid": "036_陈杞世家.25.s3", "chapter": "036_陈杞世家", "para": "25", "seq": 3, "text": "十三年，吴复来伐陈，陈告急楚，楚昭王来救，军於城父，吴师去。", "len": 30}
{"sid": "036_陈杞世家.25.s4", "chapter": "036_陈杞世家", "para": "25", "seq": 4, "text": "是年，楚昭王卒於城父。", "len": 11}
{"sid": "036_陈杞世家.25.s5", "chapter": "036_陈杞世家", "para": "25", "seq": 5, "text": "时孔子在陈。", "len": 6}
{"sid": "036_陈杞世家.25.s6", "chapter": "036_陈杞世家", "para": "25", "seq": 6, "text": "十五年，宋灭曹。", "len": 8}
{"sid": "036_陈杞世家.25.s7", "chapter": "036_陈杞世家", "para": "25", "seq": 7, "text": "十六年，吴王夫差伐齐，败之艾陵，使人召陈侯。", "len": 22}
{"sid": "036_陈杞世家.25.s8", "chapter": "036_陈杞世家", "para": "25", "seq": 8, "text": "陈侯恐，如吴。", "len": 7}
{"sid": "036_陈杞世家.25.s9", "chapter": "036_陈杞世家", "para": "25", "seq": 9, "text": "楚伐陈。", "len": 4}
{"sid": "036_陈杞世家.25.s10", "chapter": "036_陈杞世家", "para": "25", "seq": 10, "text": "二十一年，齐田常弑其君简公。", "len": 14}
{"sid": "036_陈杞世家.25.s11", "chapter": "036_陈杞世家", "para": "25", "seq": 11, "text": "二十三年，楚之白公胜杀令尹子西、子綦，袭惠王。", "len": 23}
{"sid": "036_陈杞世家.25.s12", "chapter": "036_陈杞世家", "para": "25", "seq": 12, "text": "叶公攻败白公，白公自杀。", "len": 12}
{"sid": "036_陈杞世家.26.s1", "chapter": "036_陈杞世家", "para": "26", "seq": 1, "text": "二十四年，楚惠王复国，以兵北伐，杀陈湣公，遂灭陈而有之。", "len": 28}
{"sid": "036_陈杞世家.26.s2", "chapter": "036_陈杞世家", "para": "26", "seq": 2, "text": "是岁，孔子卒。", "len": 7}
{"sid": "036_陈杞世家.27.s1", "chapter": "036_陈杞世家", "para": "27", "seq": 1, "text": "杞东楼公者，夏后禹之後苗裔也。", "len": 15}
{"sid": "036_陈杞世家.27.s2", "chapter": "036_陈杞世家", "para": "27", "seq": 2, "text": "殷时或封或绝。", "len": 7}
{"sid": "036_陈杞世家.27.s3", "chapter": "036_陈杞世家", "para": "27", "seq": 3, "text": "周武王克殷纣，求禹之後，得东楼公，封之於杞，以奉夏后氏祀。", "len": 29}
{"sid": "036_陈杞世家.28.s1", "chapter": "036_陈杞世家", "para": "28", "seq": 1, "text": "东楼公生西楼公，西楼公生题公，题公生谋娶公。", "len": 22}
{"sid": "036_陈杞世家.28.s2", "chapter": "036_陈杞世家", "para": "28", "seq": 2, "text": "谋娶公当周厉王时。", "len": 9}
{"sid": "036_陈杞世家.28.s3", "chapter": "036_陈杞世家", "para": "28", "seq": 3, "text": "谋娶公生武公。", "len": 7}
{"sid": "036_陈杞世家.28.s4", "chapter": "036_陈杞世家", "para": "28", "seq": 4, "text": "武公立四十七年卒，子靖公立。", "len": 14}
{"sid": "036_陈杞世家.28.s5", "chapter": "036_陈杞世家", "para": "28", "seq": 5, "text": "靖公二十三年卒，子共公立。", "len": 13}
{"sid": "036_陈杞世家.28.s6", "chapter": "036_陈杞世家", "para": "28", "seq": 6, "text": "共公八年卒，子德公立。", "len": 11}
{"sid": "036_陈杞世家.28.s7", "chapter": "036_陈杞世家", "para": "28", "seq": 7, "text": "德公十八年卒，弟桓公姑容立。", "len": 14}
{"sid": "036_陈杞世家.28.s8", "chapter": "036_陈杞世家", "para": "28", "seq": 8, "text": "桓公十七年卒，子孝公匄立。", "len": 13}
{"sid": "036_陈杞世家.28.s9", "chapter": "036_陈杞世家", "para": "28", "seq": 9, "text": "孝公十七年卒，弟文公益姑立。", "len": 14}
{"sid": "036_陈杞世家.28.s10", "chapter": "036_陈杞世家", "para": "28", "seq": 10, "text": "文公十四年卒，弟平公郁立。", "len": 13}
{"sid": "036_陈杞世家.28.s11", "chapter": "036_陈杞世家", "para": "28", "seq": 11, "text": "平公十八年卒，子悼公成立。", "len": 13}
{"sid": "036_陈杞世家.28.s12", "chapter": "036_陈杞世家", "para": "28", "seq": 12, "text": "悼公十二年卒，子隐公乞立。", "len": 13}
{"sid": "036_陈杞世家.28.s13", "chapter": "036_陈杞世家", "para": "28", "seq": 13, "text": "七月，隐公弟遂弑隐公自立，是为釐公。", "len": 18}
{"sid": "036_陈杞世家.28.s14", "chapter": "036_陈杞世家", "para": "28", "seq": 14, "text": "釐公十九年卒，子湣公维立。", "len": 13}
{"sid": "036_陈杞世家.28.s15", "chapter": "036_陈杞世家", "para": "28", "seq": 15, "text": "湣公十五年，楚惠王灭陈。", "len": 12}
{"sid": "036_陈杞世家.28.s16", "chapter": "036_陈杞世家", "para": "28", "seq": 16, "text": "十六年，湣公弟阏路弑湣公代立，是为哀公。", "len": 20}
{"sid": "036_陈杞世家.28.s17", "chapter": "036_陈杞世家", "para": "28", "seq": 17, "text": "哀公立十年卒，湣公子敕立，是为出公。", "len": 18}
{"sid": "036_陈杞世家.28.s18", "chapter": "036_陈杞世家", "para": "28", "seq": 18, "text": "出公十二年卒，子简公春立。", "len": 13}
{"sid": "036_陈杞世家.28.s19", "chapter": "036_陈杞世家", "para": "28", "seq": 19, "text": "立一年，楚惠王之四十四年，灭杞。", "len": 16}
{"sid": "036_陈杞世家.28.s20", "chapter": "036_陈杞世家", "para": "28", "seq": 20, "text": "杞後陈亡三十四年。", "len": 9}
{"sid": "036_陈杞世家.28.s21", "chapter": "036_陈杞世家", "para": "28", "seq": 21, "text": "杞小微，其事不足称述。", "len": 11}
{"sid": "036_陈杞世家.29.s1", "chapter": "036_陈杞世家", "para": "29", "seq": 1, "text": "舜之後，周武王封之陈，至楚惠王灭之，有世家言。", "len": 23}
{"sid": "036_陈杞世家.29.s2", "chapter": "036_陈杞世家", "para": "29", "seq": 2, "text": "禹之後，周武王封之杞，楚惠王灭之，有世家言。", "len": 22}
{"sid": "036_陈杞世家.29.s3", "chapter": "036_陈杞世家", "para": "29", "seq": 3, "text": "契之後为殷，殷有本纪言。", "len": 12}
{"sid": "036_陈杞世家.29.s4", "chapter": "036_陈杞世家", "para": "29", "seq": 4, "text": "殷破，周封其後於宋，齐湣王灭之，有世家言。", "len": 21}
{"sid": "036_陈杞世家.29.s5", "chapter": "036_陈杞世家", "para": "29", "seq": 5, "text": "后稷之後为周，秦昭王灭之，有本纪言。", "len": 18}
{"sid": "036_陈杞世家.29.s6", "chapter": "036_陈杞世家", "para": "29", "seq": 6, "text": "皋陶之後，或封英、六，楚穆王灭之，无谱。", "len": 20}
{"sid": "036_陈杞世家.29.s7", "chapter": "036_陈杞世家", "para": "29", "seq": 7, "text": "伯夷之後，至周武王复封於齐，曰太公望，陈氏灭之，有世家言。", "len": 29}
{"sid": "036_陈杞世家.29.s8", "chapter": "036_陈杞世家", "para": "29", "seq": 8, "text": "伯翳之後，至周平王时封为秦，项羽灭之，有本纪言。", "len": 24}
{"sid": "036_陈杞世家.29.s9", "chapter": "036_陈杞世家", "para": "29", "seq": 9, "text": "垂、益、夔、龙，其後不知所封，不见也。", "len": 19}
{"sid": "036_陈杞世家.29.s10", "chapter": "036_陈杞世家", "para": "29", "seq": 10, "text": "右十一人者，皆唐虞之际名有功德臣也；其五人之後皆至帝王，馀乃为显诸侯。", "len": 35}
{"sid": "036_陈杞世家.29.s11", "chapter": "036_陈杞世家", "para": "29", "seq": 11, "text": "滕、薛、驺，夏、殷、周之间封也，小，不足齿列，弗论也。", "len": 27}
{"sid": "036_陈杞世家.30.s1", "chapter": "036_陈杞世家", "para": "30", "seq": 1, "text": "周武王时，侯伯尚千馀人。", "len": 12}
{"sid": "036_陈杞世家.30.s2", "chapter": "036_陈杞世家", "para": "30", "seq": 2, "text": "及幽、厉之後，诸侯力攻相并。", "len": 14}
{"sid": "036_陈杞世家.30.s3", "chapter": "036_陈杞世家", "para": "30", "seq": 3, "text": "江、黄、胡、沈之属，不可胜数，故弗采著于传。", "len": 22}
{"sid": "036_陈杞世家.30.s4", "chapter": "036_陈杞世家", "para": "30", "seq": 4, "text": "::: 太史公曰", "len": 8}
{"sid": "036_陈杞世家.31.s1", "chapter": "036_陈杞世家", "para": "31", "seq": 1, "text": "太史公曰：舜之德可谓至矣！", "len": 13}
{"sid": "036_陈杞世家.31.s2", "chapter": "036_陈杞世家", "para": "31", "seq": 2, "text": "禅位於夏，而後世血食者历三代。", "len": 15}
{"sid": "036_陈杞世家.31.s3", "chapter": "036_陈杞世家", "para": "31", "seq": 3, "text": "及楚灭陈，而田常得政於齐，卒为建国，百世不绝，苗裔兹兹，有土者不乏焉。", "len": 35}
{"sid": "036_陈杞世家.31.s4", "chapter": "036_陈杞世家", "para": "31", "seq": 4, "text": "至禹，於周则杞，微甚，不足数也。", "len": 16}
{"sid": "036_陈杞世家.31.s5", "chapter": "036_陈杞世家", "para": "31", "seq": 5, "text": "楚惠王灭杞，其後越王句践兴。", "len": 14}
{"sid": "036_陈杞世家.31.s6", "chapter": "036_陈杞世家", "para": "31", "seq": 6, "text": "::: ::: 赞", "len": 9}
{"sid": "036_陈杞世家.32.s1", "chapter": "036_陈杞世家", "para": "32", "seq": 1, "text": "盛德之祀，必及百世。", "len": 10}
{"sid": "036_陈杞世家.32.s2", "chapter": "036_陈杞世家", "para": "32", "seq": 2, "text": "舜、禹馀烈，陈、杞是继。", "len": 12}
{"sid": "036_陈杞世家.32.s3", "chapter": "036_陈杞世家", "para": "32", "seq": 3, "text": "妫满受封，东楼纂系。", "len": 10}
{"sid": "036_陈杞世家.32.s4", "chapter": "036_陈杞世家", "para": "32", "seq": 4, "text": "阏路篡逆，夏姬淫嬖。", "len": 10}
{"sid": "036_陈杞世家.32.s5", "chapter": "036_陈杞世家", "para": "32", "seq": 5, "text": "二国衰微，或兴或替。", "len": 10}
{"sid": "036_陈杞世家.32.s6", "chapter": "036_陈杞世家", "para": "32", "seq": 6, "text": "前并後虏，皆亡楚惠。", "len": 10}
{"sid": "036_陈杞世家.32.s7", "chapter": "036_陈杞世家", "para": "32", "seq": 7, "text": "句践勃兴，田和吞噬。", "len": 10}
{"sid": "036_陈杞世家.32.s8", "chapter": "036_陈杞世家", "para": "32", "seq": 8, "text": "蝉联血食，岂其苗裔？", "len": 10}
{"sid": "036_陈杞世家.32.s9", "chapter": "036_陈杞世家", "para": "32", "seq": 9, "text": ":::", "len": 3}
