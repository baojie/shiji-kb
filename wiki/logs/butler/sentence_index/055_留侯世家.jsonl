{"sid": "055_留侯世家.1.s1", "chapter": "055_留侯世家", "para": "1", "seq": 1, "text": "留侯张良者，其先韩人也。", "len": 12}
{"sid": "055_留侯世家.1.s2", "chapter": "055_留侯世家", "para": "1", "seq": 2, "text": "大父开地，相韩昭侯、宣惠王、襄哀王。", "len": 18}
{"sid": "055_留侯世家.1.s3", "chapter": "055_留侯世家", "para": "1", "seq": 3, "text": "父平，相釐王、悼惠王。", "len": 11}
{"sid": "055_留侯世家.1.s4", "chapter": "055_留侯世家", "para": "1", "seq": 4, "text": "悼惠王二十三年，平卒。", "len": 11}
{"sid": "055_留侯世家.1.s5", "chapter": "055_留侯世家", "para": "1", "seq": 5, "text": "卒二十岁，秦灭韩。", "len": 9}
{"sid": "055_留侯世家.1.s6", "chapter": "055_留侯世家", "para": "1", "seq": 6, "text": "良年少，未宦事韩。", "len": 9}
{"sid": "055_留侯世家.1.s7", "chapter": "055_留侯世家", "para": "1", "seq": 7, "text": "韩破，良家僮三百人，弟死不葬，悉以家财求客刺秦王，为韩报仇，以大父、父五世相韩故。", "len": 41}
{"sid": "055_留侯世家.2.s1", "chapter": "055_留侯世家", "para": "2", "seq": 1, "text": "良尝学礼淮阳。", "len": 7}
{"sid": "055_留侯世家.2.s2", "chapter": "055_留侯世家", "para": "2", "seq": 2, "text": "东见仓海君。", "len": 6}
{"sid": "055_留侯世家.2.s3", "chapter": "055_留侯世家", "para": "2", "seq": 3, "text": "得力士，为铁椎重百二十斤。", "len": 13}
{"sid": "055_留侯世家.2.s4", "chapter": "055_留侯世家", "para": "2", "seq": 4, "text": "秦皇帝东游，良与客狙击秦皇帝博浪沙中，误中副车。", "len": 24}
{"sid": "055_留侯世家.2.s5", "chapter": "055_留侯世家", "para": "2", "seq": 5, "text": "秦皇帝大怒，大索天下，求贼甚急，为张良故也。", "len": 22}
{"sid": "055_留侯世家.2.s6", "chapter": "055_留侯世家", "para": "2", "seq": 6, "text": "良乃更名姓，亡匿下邳。", "len": 11}
{"sid": "055_留侯世家.3.s1", "chapter": "055_留侯世家", "para": "3", "seq": 1, "text": "良尝间从容步游下邳圯上，有一老父，衣褐，至良所，直堕其履圯下，顾谓良曰：“孺子，下取履！", "len": 44}
{"sid": "055_留侯世家.3.s2", "chapter": "055_留侯世家", "para": "3", "seq": 2, "text": "” 良鄂然，欲殴之。", "len": 10}
{"sid": "055_留侯世家.3.s3", "chapter": "055_留侯世家", "para": "3", "seq": 3, "text": "为其老，彊忍，下取履。", "len": 11}
{"sid": "055_留侯世家.3.s4", "chapter": "055_留侯世家", "para": "3", "seq": 4, "text": "父曰：“履我！", "len": 7}
{"sid": "055_留侯世家.3.s5", "chapter": "055_留侯世家", "para": "3", "seq": 5, "text": "” 良业为取履，因长跪履之。", "len": 14}
{"sid": "055_留侯世家.3.s6", "chapter": "055_留侯世家", "para": "3", "seq": 6, "text": "父以足受，笑而去。", "len": 9}
{"sid": "055_留侯世家.3.s7", "chapter": "055_留侯世家", "para": "3", "seq": 7, "text": "良殊大惊，随目之。", "len": 9}
{"sid": "055_留侯世家.3.s8", "chapter": "055_留侯世家", "para": "3", "seq": 8, "text": "父去里所，复还，曰：“孺子可教矣。", "len": 17}
{"sid": "055_留侯世家.3.s9", "chapter": "055_留侯世家", "para": "3", "seq": 9, "text": "後五日平明，与我会此。", "len": 11}
{"sid": "055_留侯世家.3.s10", "chapter": "055_留侯世家", "para": "3", "seq": 10, "text": "” 良因怪之，跪曰：“诺。", "len": 13}
{"sid": "055_留侯世家.3.s11", "chapter": "055_留侯世家", "para": "3", "seq": 11, "text": "” 五日平明，良往。", "len": 10}
{"sid": "055_留侯世家.3.s12", "chapter": "055_留侯世家", "para": "3", "seq": 12, "text": "父已先在，怒曰：“与老人期，後，何也？", "len": 19}
{"sid": "055_留侯世家.3.s13", "chapter": "055_留侯世家", "para": "3", "seq": 13, "text": "” 去，曰：“後五日早会。", "len": 13}
{"sid": "055_留侯世家.3.s14", "chapter": "055_留侯世家", "para": "3", "seq": 14, "text": "” 五日鸡鸣，良往。", "len": 10}
{"sid": "055_留侯世家.3.s15", "chapter": "055_留侯世家", "para": "3", "seq": 15, "text": "父又先在，复怒曰：“後，何也？", "len": 15}
{"sid": "055_留侯世家.3.s16", "chapter": "055_留侯世家", "para": "3", "seq": 16, "text": "” 去，曰：“後五日复早来。", "len": 14}
{"sid": "055_留侯世家.3.s17", "chapter": "055_留侯世家", "para": "3", "seq": 17, "text": "” 五日，良夜未半往。", "len": 11}
{"sid": "055_留侯世家.3.s18", "chapter": "055_留侯世家", "para": "3", "seq": 18, "text": "有顷，父亦来，喜曰：“当如是。", "len": 15}
{"sid": "055_留侯世家.3.s19", "chapter": "055_留侯世家", "para": "3", "seq": 19, "text": "” 出一编书，曰：“读此则为王者师矣。", "len": 19}
{"sid": "055_留侯世家.3.s20", "chapter": "055_留侯世家", "para": "3", "seq": 20, "text": "後十年兴。", "len": 5}
{"sid": "055_留侯世家.3.s21", "chapter": "055_留侯世家", "para": "3", "seq": 21, "text": "十三年孺子见我济北，穀城山下黄石即我矣。", "len": 20}
{"sid": "055_留侯世家.3.s22", "chapter": "055_留侯世家", "para": "3", "seq": 22, "text": "” 遂去，无他言，不复见。", "len": 13}
{"sid": "055_留侯世家.3.s23", "chapter": "055_留侯世家", "para": "3", "seq": 23, "text": "旦日视其书，乃太公兵法也。", "len": 13}
{"sid": "055_留侯世家.3.s24", "chapter": "055_留侯世家", "para": "3", "seq": 24, "text": "良因异之，常习诵读之。", "len": 11}
{"sid": "055_留侯世家.4.s1", "chapter": "055_留侯世家", "para": "4", "seq": 1, "text": "居下邳，为任侠。", "len": 8}
{"sid": "055_留侯世家.4.s2", "chapter": "055_留侯世家", "para": "4", "seq": 2, "text": "项伯常杀人，从良匿。", "len": 10}
{"sid": "055_留侯世家.5.s1", "chapter": "055_留侯世家", "para": "5", "seq": 1, "text": "後十年，陈涉等起兵，良亦聚少年百馀人。", "len": 19}
{"sid": "055_留侯世家.5.s2", "chapter": "055_留侯世家", "para": "5", "seq": 2, "text": "景驹自立为楚假王，在留。", "len": 12}
{"sid": "055_留侯世家.5.s3", "chapter": "055_留侯世家", "para": "5", "seq": 3, "text": "良欲往从之，道还沛公。", "len": 11}
{"sid": "055_留侯世家.5.s4", "chapter": "055_留侯世家", "para": "5", "seq": 4, "text": "沛公将数千人，略地下邳西，遂属焉。", "len": 17}
{"sid": "055_留侯世家.5.s5", "chapter": "055_留侯世家", "para": "5", "seq": 5, "text": "沛公拜良为厩将。", "len": 8}
{"sid": "055_留侯世家.5.s6", "chapter": "055_留侯世家", "para": "5", "seq": 6, "text": "良数以太公兵法说沛公，沛公善之，常用其策。", "len": 21}
{"sid": "055_留侯世家.5.s7", "chapter": "055_留侯世家", "para": "5", "seq": 7, "text": "良为他人者，皆不省。", "len": 10}
{"sid": "055_留侯世家.5.s8", "chapter": "055_留侯世家", "para": "5", "seq": 8, "text": "良曰：“沛公殆天授。", "len": 10}
{"sid": "055_留侯世家.5.s9", "chapter": "055_留侯世家", "para": "5", "seq": 9, "text": "” 故遂从之，不去见景驹。", "len": 13}
{"sid": "055_留侯世家.6.s1", "chapter": "055_留侯世家", "para": "6", "seq": 1, "text": "及沛公之薛，见项梁。", "len": 10}
{"sid": "055_留侯世家.6.s2", "chapter": "055_留侯世家", "para": "6", "seq": 2, "text": "项梁立楚怀王。", "len": 7}
{"sid": "055_留侯世家.6.s3", "chapter": "055_留侯世家", "para": "6", "seq": 3, "text": "良乃说项梁曰：“君已立楚後，而韩诸公子横阳君成贤，可立为王，益树党。", "len": 34}
{"sid": "055_留侯世家.6.s4", "chapter": "055_留侯世家", "para": "6", "seq": 4, "text": "” 项梁使良求韩成，立以为韩王。", "len": 16}
{"sid": "055_留侯世家.6.s5", "chapter": "055_留侯世家", "para": "6", "seq": 5, "text": "以良为韩申徒，与韩王将千馀人西略韩地，得数城，秦辄复取之，往来为游兵颍川。", "len": 37}
{"sid": "055_留侯世家.7.s1", "chapter": "055_留侯世家", "para": "7", "seq": 1, "text": "沛公之从雒阳南出轘辕，良引兵从沛公，下韩十馀城，击破杨熊军。", "len": 30}
{"sid": "055_留侯世家.7.s2", "chapter": "055_留侯世家", "para": "7", "seq": 2, "text": "沛公乃令韩王成留守阳翟，与良俱南，攻下宛，西入武关。", "len": 26}
{"sid": "055_留侯世家.7.s3", "chapter": "055_留侯世家", "para": "7", "seq": 3, "text": "沛公欲以兵二万人击秦峣下军，良说曰：“秦兵尚彊，未可轻。", "len": 28}
{"sid": "055_留侯世家.7.s4", "chapter": "055_留侯世家", "para": "7", "seq": 4, "text": "臣闻其将屠者子，贾竖易动以利。", "len": 15}
{"sid": "055_留侯世家.7.s5", "chapter": "055_留侯世家", "para": "7", "seq": 5, "text": "原沛公且留壁，使人先行，为五万人具食，益为张旗帜诸山上，为疑兵，令郦食其持重宝啗秦将。", "len": 43}
{"sid": "055_留侯世家.7.s6", "chapter": "055_留侯世家", "para": "7", "seq": 6, "text": "” 秦将果畔，欲连和俱西袭咸阳，沛公欲听之。", "len": 22}
{"sid": "055_留侯世家.7.s7", "chapter": "055_留侯世家", "para": "7", "seq": 7, "text": "良曰：“此独其将欲叛耳，恐士卒不从。", "len": 18}
{"sid": "055_留侯世家.7.s8", "chapter": "055_留侯世家", "para": "7", "seq": 8, "text": "不从必危，不如因其解击之。", "len": 13}
{"sid": "055_留侯世家.7.s9", "chapter": "055_留侯世家", "para": "7", "seq": 9, "text": "” 沛公乃引兵击秦军，大破之。", "len": 15}
{"sid": "055_留侯世家.7.s10", "chapter": "055_留侯世家", "para": "7", "seq": 10, "text": "北至蓝田，再战，秦兵竟败。", "len": 13}
{"sid": "055_留侯世家.7.s11", "chapter": "055_留侯世家", "para": "7", "seq": 11, "text": "遂至咸阳，秦王子婴降沛公。", "len": 13}
{"sid": "055_留侯世家.8.s1", "chapter": "055_留侯世家", "para": "8", "seq": 1, "text": "沛公入秦宫，宫室帷帐狗马重宝妇女以千数，意欲留居之。", "len": 26}
{"sid": "055_留侯世家.8.s2", "chapter": "055_留侯世家", "para": "8", "seq": 2, "text": "樊哙谏沛公出舍，沛公不听。", "len": 13}
{"sid": "055_留侯世家.8.s3", "chapter": "055_留侯世家", "para": "8", "seq": 3, "text": "良曰：“夫秦为无道，故沛公得至此。", "len": 17}
{"sid": "055_留侯世家.8.s4", "chapter": "055_留侯世家", "para": "8", "seq": 4, "text": "夫为天下除残贼，宜缟素为资。", "len": 14}
{"sid": "055_留侯世家.8.s5", "chapter": "055_留侯世家", "para": "8", "seq": 5, "text": "今始入秦，即安其乐，此所谓‘助桀为虐’。", "len": 20}
{"sid": "055_留侯世家.8.s6", "chapter": "055_留侯世家", "para": "8", "seq": 6, "text": "且‘忠言逆耳利於行，毒药苦口利於病’，原沛公听樊哙言。", "len": 27}
{"sid": "055_留侯世家.8.s7", "chapter": "055_留侯世家", "para": "8", "seq": 7, "text": "” 沛公乃还军霸上。", "len": 10}
{"sid": "055_留侯世家.9.s1", "chapter": "055_留侯世家", "para": "9", "seq": 1, "text": "项羽至鸿门下，欲击沛公，项伯乃夜驰入沛公军，私见张良，欲与俱去。", "len": 32}
{"sid": "055_留侯世家.9.s2", "chapter": "055_留侯世家", "para": "9", "seq": 2, "text": "良曰：“臣为韩王送沛公，今事有急，亡去不义。", "len": 22}
{"sid": "055_留侯世家.9.s3", "chapter": "055_留侯世家", "para": "9", "seq": 3, "text": "” 乃具以语沛公。", "len": 9}
{"sid": "055_留侯世家.9.s4", "chapter": "055_留侯世家", "para": "9", "seq": 4, "text": "沛公大惊，曰：“为将柰何？", "len": 13}
{"sid": "055_留侯世家.9.s5", "chapter": "055_留侯世家", "para": "9", "seq": 5, "text": "” 良曰：“沛公诚欲倍项羽邪？", "len": 15}
{"sid": "055_留侯世家.9.s6", "chapter": "055_留侯世家", "para": "9", "seq": 6, "text": "” 沛公曰：“鲰生教我距关无内诸侯，秦地可尽王，故听之。", "len": 28}
{"sid": "055_留侯世家.9.s7", "chapter": "055_留侯世家", "para": "9", "seq": 7, "text": "” 良曰：“沛公自度能卻项羽乎？", "len": 16}
{"sid": "055_留侯世家.9.s8", "chapter": "055_留侯世家", "para": "9", "seq": 8, "text": "” 沛公默然良久，曰：“固不能也。", "len": 17}
{"sid": "055_留侯世家.9.s9", "chapter": "055_留侯世家", "para": "9", "seq": 9, "text": "今为柰何？", "len": 5}
{"sid": "055_留侯世家.9.s10", "chapter": "055_留侯世家", "para": "9", "seq": 10, "text": "” 良乃固要项伯。", "len": 9}
{"sid": "055_留侯世家.9.s11", "chapter": "055_留侯世家", "para": "9", "seq": 11, "text": "项伯见沛公。", "len": 6}
{"sid": "055_留侯世家.9.s12", "chapter": "055_留侯世家", "para": "9", "seq": 12, "text": "沛公与饮为寿，结宾婚。", "len": 11}
{"sid": "055_留侯世家.9.s13", "chapter": "055_留侯世家", "para": "9", "seq": 13, "text": "令项伯具言沛公不敢倍项羽，所以距关者，备他盗也。", "len": 24}
{"sid": "055_留侯世家.9.s14", "chapter": "055_留侯世家", "para": "9", "seq": 14, "text": "及见项羽後解，语在项羽事中。", "len": 14}
{"sid": "055_留侯世家.10.s1", "chapter": "055_留侯世家", "para": "10", "seq": 1, "text": "汉元年正月，沛公为汉王，王巴蜀。", "len": 16}
{"sid": "055_留侯世家.10.s2", "chapter": "055_留侯世家", "para": "10", "seq": 2, "text": "汉王赐良金百溢，珠二斗，良具以献项伯。", "len": 19}
{"sid": "055_留侯世家.10.s3", "chapter": "055_留侯世家", "para": "10", "seq": 3, "text": "汉王亦因令良厚遗项伯，使请汉中地。", "len": 17}
{"sid": "055_留侯世家.10.s4", "chapter": "055_留侯世家", "para": "10", "seq": 4, "text": "项王乃许之，遂得汉中地。", "len": 12}
{"sid": "055_留侯世家.10.s5", "chapter": "055_留侯世家", "para": "10", "seq": 5, "text": "汉王之国，良送至襃中，遣良归韩。", "len": 16}
{"sid": "055_留侯世家.10.s6", "chapter": "055_留侯世家", "para": "10", "seq": 6, "text": "良因说汉王曰：“王何不烧绝所过栈道，示天下无还心，以固项王意。", "len": 31}
{"sid": "055_留侯世家.10.s7", "chapter": "055_留侯世家", "para": "10", "seq": 7, "text": "” 乃使良还。", "len": 7}
{"sid": "055_留侯世家.10.s8", "chapter": "055_留侯世家", "para": "10", "seq": 8, "text": "行，烧绝栈道。", "len": 7}
{"sid": "055_留侯世家.11.s1", "chapter": "055_留侯世家", "para": "11", "seq": 1, "text": "良至韩，韩王成以良从汉王故，项王不遣成之国，从与俱东。", "len": 27}
{"sid": "055_留侯世家.11.s2", "chapter": "055_留侯世家", "para": "11", "seq": 2, "text": "良说项王曰：“汉王烧绝栈道，无还心矣。", "len": 19}
{"sid": "055_留侯世家.11.s3", "chapter": "055_留侯世家", "para": "11", "seq": 3, "text": "” 乃以齐王田荣反，书告项王。", "len": 15}
{"sid": "055_留侯世家.11.s4", "chapter": "055_留侯世家", "para": "11", "seq": 4, "text": "项王以此无西忧汉心，而发兵北击齐。", "len": 17}
{"sid": "055_留侯世家.12.s1", "chapter": "055_留侯世家", "para": "12", "seq": 1, "text": "项王竟不肯遣韩王，乃以为侯，又杀之彭城。", "len": 20}
{"sid": "055_留侯世家.12.s2", "chapter": "055_留侯世家", "para": "12", "seq": 2, "text": "良亡，间行归汉王，汉王亦已还定三秦矣。", "len": 19}
{"sid": "055_留侯世家.12.s3", "chapter": "055_留侯世家", "para": "12", "seq": 3, "text": "复以良为成信侯，从东击楚。", "len": 13}
{"sid": "055_留侯世家.12.s4", "chapter": "055_留侯世家", "para": "12", "seq": 4, "text": "至彭城，汉败而还。", "len": 9}
{"sid": "055_留侯世家.12.s5", "chapter": "055_留侯世家", "para": "12", "seq": 5, "text": "至下邑，汉王下马踞鞍而问曰：“吾欲捐关以东等弃之，谁可与共功者？", "len": 32}
{"sid": "055_留侯世家.12.s6", "chapter": "055_留侯世家", "para": "12", "seq": 6, "text": "” 良进曰：“九江王黥布，楚枭将，与项王有郄；彭越与齐王田荣反梁地：此两人可急使。", "len": 41}
{"sid": "055_留侯世家.12.s7", "chapter": "055_留侯世家", "para": "12", "seq": 7, "text": "而汉王之将独韩信可属大事，当一面。", "len": 17}
{"sid": "055_留侯世家.12.s8", "chapter": "055_留侯世家", "para": "12", "seq": 8, "text": "即欲捐之，捐之此三人，则楚可破也。", "len": 17}
{"sid": "055_留侯世家.12.s9", "chapter": "055_留侯世家", "para": "12", "seq": 9, "text": "” 汉王乃遣随何说九江王布，而使人连彭越。", "len": 21}
{"sid": "055_留侯世家.12.s10", "chapter": "055_留侯世家", "para": "12", "seq": 10, "text": "及魏王豹反，使韩信将兵击之，因举燕、代、齐、赵。", "len": 24}
{"sid": "055_留侯世家.12.s11", "chapter": "055_留侯世家", "para": "12", "seq": 11, "text": "然卒破楚者，此三人力也。", "len": 12}
{"sid": "055_留侯世家.13.s1", "chapter": "055_留侯世家", "para": "13", "seq": 1, "text": "张良多病，未尝特将也，常为画策，时时从汉王。", "len": 22}
{"sid": "055_留侯世家.14.s1", "chapter": "055_留侯世家", "para": "14", "seq": 1, "text": "汉三年，项羽急围汉王荥阳，汉王恐忧，与郦食其谋桡楚权。", "len": 27}
{"sid": "055_留侯世家.14.s2", "chapter": "055_留侯世家", "para": "14", "seq": 2, "text": "食其曰：“昔汤伐桀，封其後於杞。", "len": 16}
{"sid": "055_留侯世家.14.s3", "chapter": "055_留侯世家", "para": "14", "seq": 3, "text": "武王伐纣，封其後於宋。", "len": 11}
{"sid": "055_留侯世家.14.s4", "chapter": "055_留侯世家", "para": "14", "seq": 4, "text": "今秦失德弃义，侵伐诸侯社稷，灭六国之後，使无立锥之地。", "len": 27}
{"sid": "055_留侯世家.14.s5", "chapter": "055_留侯世家", "para": "14", "seq": 5, "text": "陛下诚能复立六国後世，毕已受印，此其君臣百姓必皆戴陛下之德，莫不乡风慕义，原为臣妾。", "len": 42}
{"sid": "055_留侯世家.14.s6", "chapter": "055_留侯世家", "para": "14", "seq": 6, "text": "德义已行，陛下南乡称霸，楚必敛衽而朝。", "len": 19}
{"sid": "055_留侯世家.14.s7", "chapter": "055_留侯世家", "para": "14", "seq": 7, "text": "” 汉王曰：“善。", "len": 9}
{"sid": "055_留侯世家.14.s8", "chapter": "055_留侯世家", "para": "14", "seq": 8, "text": "趣刻印，先生因行佩之矣。”", "len": 13}
{"sid": "055_留侯世家.15.s1", "chapter": "055_留侯世家", "para": "15", "seq": 1, "text": "食其未行，张良从外来谒。", "len": 12}
{"sid": "055_留侯世家.15.s2", "chapter": "055_留侯世家", "para": "15", "seq": 2, "text": "汉王方食，曰：“子房前！", "len": 12}
{"sid": "055_留侯世家.15.s3", "chapter": "055_留侯世家", "para": "15", "seq": 3, "text": "客有为我计桡楚权者。", "len": 10}
{"sid": "055_留侯世家.15.s4", "chapter": "055_留侯世家", "para": "15", "seq": 4, "text": "” 其以郦生语告，曰：“於子房何如？", "len": 18}
{"sid": "055_留侯世家.15.s5", "chapter": "055_留侯世家", "para": "15", "seq": 5, "text": "” 良曰：“谁为陛下画此计者？", "len": 15}
{"sid": "055_留侯世家.15.s6", "chapter": "055_留侯世家", "para": "15", "seq": 6, "text": "陛下事去矣。", "len": 6}
{"sid": "055_留侯世家.15.s7", "chapter": "055_留侯世家", "para": "15", "seq": 7, "text": "” 汉王曰：“何哉？", "len": 10}
{"sid": "055_留侯世家.15.s8", "chapter": "055_留侯世家", "para": "15", "seq": 8, "text": "” 张良对曰：“臣请藉前箸为大王筹之。", "len": 19}
{"sid": "055_留侯世家.15.s9", "chapter": "055_留侯世家", "para": "15", "seq": 9, "text": "” 曰：“昔者汤伐桀而封其後於杞者，度能制桀之死命也。", "len": 27}
{"sid": "055_留侯世家.15.s10", "chapter": "055_留侯世家", "para": "15", "seq": 10, "text": "今陛下能制项籍之死命乎？", "len": 12}
{"sid": "055_留侯世家.15.s11", "chapter": "055_留侯世家", "para": "15", "seq": 11, "text": "” 曰：“未能也。", "len": 9}
{"sid": "055_留侯世家.15.s12", "chapter": "055_留侯世家", "para": "15", "seq": 12, "text": "” “其不可一也。", "len": 9}
{"sid": "055_留侯世家.15.s13", "chapter": "055_留侯世家", "para": "15", "seq": 13, "text": "武王伐纣封其後於宋者，度能得纣之头也。", "len": 19}
{"sid": "055_留侯世家.15.s14", "chapter": "055_留侯世家", "para": "15", "seq": 14, "text": "今陛下能得项籍之头乎？", "len": 11}
{"sid": "055_留侯世家.15.s15", "chapter": "055_留侯世家", "para": "15", "seq": 15, "text": "” 曰：“未能也。", "len": 9}
{"sid": "055_留侯世家.15.s16", "chapter": "055_留侯世家", "para": "15", "seq": 16, "text": "” “其不可二也。", "len": 9}
{"sid": "055_留侯世家.15.s17", "chapter": "055_留侯世家", "para": "15", "seq": 17, "text": "武王入殷，表商容之闾，释箕子之拘，封比干之墓。", "len": 23}
{"sid": "055_留侯世家.15.s18", "chapter": "055_留侯世家", "para": "15", "seq": 18, "text": "今陛下能封圣人之墓，表贤者之闾，式智者之门乎？", "len": 23}
{"sid": "055_留侯世家.15.s19", "chapter": "055_留侯世家", "para": "15", "seq": 19, "text": "” 曰：“未能也。", "len": 9}
{"sid": "055_留侯世家.15.s20", "chapter": "055_留侯世家", "para": "15", "seq": 20, "text": "” “其不可三也。", "len": 9}
{"sid": "055_留侯世家.15.s21", "chapter": "055_留侯世家", "para": "15", "seq": 21, "text": "发钜桥之粟，散鹿台之钱，以赐贫穷。", "len": 17}
{"sid": "055_留侯世家.15.s22", "chapter": "055_留侯世家", "para": "15", "seq": 22, "text": "今陛下能散府库以赐贫穷乎？", "len": 13}
{"sid": "055_留侯世家.15.s23", "chapter": "055_留侯世家", "para": "15", "seq": 23, "text": "” 曰：“未能也。", "len": 9}
{"sid": "055_留侯世家.15.s24", "chapter": "055_留侯世家", "para": "15", "seq": 24, "text": "” “其不可四矣。", "len": 9}
{"sid": "055_留侯世家.15.s25", "chapter": "055_留侯世家", "para": "15", "seq": 25, "text": "殷事已毕，偃革为轩，倒置干戈，覆以虎皮，以示天下不复用兵。", "len": 29}
{"sid": "055_留侯世家.15.s26", "chapter": "055_留侯世家", "para": "15", "seq": 26, "text": "今陛下能偃武行文，不复用兵乎？", "len": 15}
{"sid": "055_留侯世家.15.s27", "chapter": "055_留侯世家", "para": "15", "seq": 27, "text": "” 曰：“未能也。", "len": 9}
{"sid": "055_留侯世家.15.s28", "chapter": "055_留侯世家", "para": "15", "seq": 28, "text": "” “其不可五矣。", "len": 9}
{"sid": "055_留侯世家.15.s29", "chapter": "055_留侯世家", "para": "15", "seq": 29, "text": "休马华山之阳，示以无所为。", "len": 13}
{"sid": "055_留侯世家.15.s30", "chapter": "055_留侯世家", "para": "15", "seq": 30, "text": "今陛下能休马无所用乎？", "len": 11}
{"sid": "055_留侯世家.15.s31", "chapter": "055_留侯世家", "para": "15", "seq": 31, "text": "” 曰：“未能也。", "len": 9}
{"sid": "055_留侯世家.15.s32", "chapter": "055_留侯世家", "para": "15", "seq": 32, "text": "” “其不可六矣。", "len": 9}
{"sid": "055_留侯世家.15.s33", "chapter": "055_留侯世家", "para": "15", "seq": 33, "text": "放牛桃林之阴，以示不复输积。", "len": 14}
{"sid": "055_留侯世家.15.s34", "chapter": "055_留侯世家", "para": "15", "seq": 34, "text": "今陛下能放牛不复输积乎？", "len": 12}
{"sid": "055_留侯世家.15.s35", "chapter": "055_留侯世家", "para": "15", "seq": 35, "text": "” 曰：“未能也。", "len": 9}
{"sid": "055_留侯世家.15.s36", "chapter": "055_留侯世家", "para": "15", "seq": 36, "text": "” “其不可七矣。", "len": 9}
{"sid": "055_留侯世家.15.s37", "chapter": "055_留侯世家", "para": "15", "seq": 37, "text": "且天下游士离其亲戚，弃坟墓，去故旧，从陛下游者，徒欲日夜望咫尺之地。", "len": 34}
{"sid": "055_留侯世家.15.s38", "chapter": "055_留侯世家", "para": "15", "seq": 38, "text": "今复六国，立韩、魏、燕、赵、齐、楚之後，天下游士各归事其主，从其亲戚，反其故旧坟墓，陛下与谁取天下乎？", "len": 51}
{"sid": "055_留侯世家.15.s39", "chapter": "055_留侯世家", "para": "15", "seq": 39, "text": "其不可八矣。", "len": 6}
{"sid": "055_留侯世家.15.s40", "chapter": "055_留侯世家", "para": "15", "seq": 40, "text": "且夫楚唯无彊，六国立者复桡而从之，陛下焉得而臣之？", "len": 25}
{"sid": "055_留侯世家.15.s41", "chapter": "055_留侯世家", "para": "15", "seq": 41, "text": "诚用客之谋，陛下事去矣。", "len": 12}
{"sid": "055_留侯世家.15.s42", "chapter": "055_留侯世家", "para": "15", "seq": 42, "text": "” 汉王辍食吐哺，骂曰：“竖儒，几败而公事！", "len": 22}
{"sid": "055_留侯世家.15.s43", "chapter": "055_留侯世家", "para": "15", "seq": 43, "text": "” 令趣销印。", "len": 7}
{"sid": "055_留侯世家.16.s1", "chapter": "055_留侯世家", "para": "16", "seq": 1, "text": "汉四年，韩信破齐而欲自立为齐王，汉王怒。", "len": 20}
{"sid": "055_留侯世家.16.s2", "chapter": "055_留侯世家", "para": "16", "seq": 2, "text": "张良说汉王，汉王使良授齐王信印，语在淮阴事中。", "len": 23}
{"sid": "055_留侯世家.17.s1", "chapter": "055_留侯世家", "para": "17", "seq": 1, "text": "其秋，汉王追楚至阳夏南，战不利而壁固陵，诸侯期不至。", "len": 26}
{"sid": "055_留侯世家.17.s2", "chapter": "055_留侯世家", "para": "17", "seq": 2, "text": "良说汉王，汉王用其计，诸侯皆至。", "len": 16}
{"sid": "055_留侯世家.17.s3", "chapter": "055_留侯世家", "para": "17", "seq": 3, "text": "语在项籍事中。", "len": 7}
{"sid": "055_留侯世家.18.s1", "chapter": "055_留侯世家", "para": "18", "seq": 1, "text": "汉六年正月，封功臣。", "len": 10}
{"sid": "055_留侯世家.18.s2", "chapter": "055_留侯世家", "para": "18", "seq": 2, "text": "良未尝有战斗功，高帝曰：“运筹策帷帐中|运筹帷幄，决胜千里外，子房功也。", "len": 36}
{"sid": "055_留侯世家.18.s3", "chapter": "055_留侯世家", "para": "18", "seq": 3, "text": "自择齐三万户。", "len": 7}
{"sid": "055_留侯世家.18.s4", "chapter": "055_留侯世家", "para": "18", "seq": 4, "text": "” 良曰：“始臣起下邳，与上会留，此天以臣授陛下。", "len": 25}
{"sid": "055_留侯世家.18.s5", "chapter": "055_留侯世家", "para": "18", "seq": 5, "text": "陛下用臣计，幸而时中，臣原封留足矣，不敢当三万户。", "len": 25}
{"sid": "055_留侯世家.18.s6", "chapter": "055_留侯世家", "para": "18", "seq": 6, "text": "” 乃封张良为留侯，与萧何等俱封。", "len": 17}
{"sid": "055_留侯世家.19.s1", "chapter": "055_留侯世家", "para": "19", "seq": 1, "text": "上已封大功臣二十馀人，其馀日夜争功不决，未得行封。", "len": 25}
{"sid": "055_留侯世家.19.s2", "chapter": "055_留侯世家", "para": "19", "seq": 2, "text": "上在雒阳南宫，从复道望见诸将往往相与坐沙中语。", "len": 23}
{"sid": "055_留侯世家.19.s3", "chapter": "055_留侯世家", "para": "19", "seq": 3, "text": "上曰：“此何语？", "len": 8}
{"sid": "055_留侯世家.19.s4", "chapter": "055_留侯世家", "para": "19", "seq": 4, "text": "” 留侯曰：“陛下不知乎？", "len": 13}
{"sid": "055_留侯世家.19.s5", "chapter": "055_留侯世家", "para": "19", "seq": 5, "text": "此谋反耳。", "len": 5}
{"sid": "055_留侯世家.19.s6", "chapter": "055_留侯世家", "para": "19", "seq": 6, "text": "” 上曰：“天下属安定，何故反乎？", "len": 17}
{"sid": "055_留侯世家.19.s7", "chapter": "055_留侯世家", "para": "19", "seq": 7, "text": "” 留侯曰：“陛下起布衣，以此属取天下，今陛下为天子，而所封皆萧、曹故人所亲爱，而所诛者皆生平所仇怨。", "len": 51}
{"sid": "055_留侯世家.19.s8", "chapter": "055_留侯世家", "para": "19", "seq": 8, "text": "今军吏计功，以天下不足遍封，此属畏陛下不能尽封，恐又见疑平生过失及诛，故即相聚谋反耳。", "len": 43}
{"sid": "055_留侯世家.19.s9", "chapter": "055_留侯世家", "para": "19", "seq": 9, "text": "” 上乃忧曰：“为之柰何？", "len": 13}
{"sid": "055_留侯世家.19.s10", "chapter": "055_留侯世家", "para": "19", "seq": 10, "text": "” 留侯曰：“上平生所憎，群臣所共知，谁最甚者？", "len": 24}
{"sid": "055_留侯世家.19.s11", "chapter": "055_留侯世家", "para": "19", "seq": 11, "text": "” 上曰：“雍齿与我故，数尝窘辱我。", "len": 18}
{"sid": "055_留侯世家.19.s12", "chapter": "055_留侯世家", "para": "19", "seq": 12, "text": "我欲杀之，为其功多，故不忍。", "len": 14}
{"sid": "055_留侯世家.19.s13", "chapter": "055_留侯世家", "para": "19", "seq": 13, "text": "” 留侯曰：“今急先封雍齿以示群臣，群臣见雍齿封，则人人自坚矣。", "len": 32}
{"sid": "055_留侯世家.19.s14", "chapter": "055_留侯世家", "para": "19", "seq": 14, "text": "” 於是上乃置酒，封雍齿为什方侯，而急趣丞相、御史定功行封。", "len": 30}
{"sid": "055_留侯世家.19.s15", "chapter": "055_留侯世家", "para": "19", "seq": 15, "text": "群臣罢酒，皆喜曰：“雍齿尚为侯，我属无患矣。”", "len": 23}
{"sid": "055_留侯世家.20.s1", "chapter": "055_留侯世家", "para": "20", "seq": 1, "text": "刘敬说高帝曰：“都关中。", "len": 12}
{"sid": "055_留侯世家.20.s2", "chapter": "055_留侯世家", "para": "20", "seq": 2, "text": "” 上疑之。", "len": 6}
{"sid": "055_留侯世家.20.s3", "chapter": "055_留侯世家", "para": "20", "seq": 3, "text": "左右大臣皆山东人，多劝上都雒阳：“雒阳东有成皋，西有殽黾，倍河，向伊雒，其固亦足恃。", "len": 42}
{"sid": "055_留侯世家.20.s4", "chapter": "055_留侯世家", "para": "20", "seq": 4, "text": "” 留侯曰：“雒阳虽有此固，其中小，不过数百里，田地薄，四面受敌，此非用武之国也。", "len": 41}
{"sid": "055_留侯世家.20.s5", "chapter": "055_留侯世家", "para": "20", "seq": 5, "text": "夫关中左殽函，右陇蜀，沃野千里，南有巴蜀之饶，北有胡苑之利，阻三面而守，独以一面东制诸侯。", "len": 45}
{"sid": "055_留侯世家.20.s6", "chapter": "055_留侯世家", "para": "20", "seq": 6, "text": "诸侯安定，河渭漕輓天下，西给京师；诸侯有变，顺流而下，足以委输。", "len": 32}
{"sid": "055_留侯世家.20.s7", "chapter": "055_留侯世家", "para": "20", "seq": 7, "text": "此所谓金城千里，天府之国也，刘敬说是也。", "len": 20}
{"sid": "055_留侯世家.20.s8", "chapter": "055_留侯世家", "para": "20", "seq": 8, "text": "” 於是高帝即日驾，西都关中。", "len": 15}
{"sid": "055_留侯世家.21.s1", "chapter": "055_留侯世家", "para": "21", "seq": 1, "text": "留侯从入关。", "len": 6}
{"sid": "055_留侯世家.21.s2", "chapter": "055_留侯世家", "para": "21", "seq": 2, "text": "留侯性多病，即道引不食穀，杜门不出岁馀。", "len": 20}
{"sid": "055_留侯世家.22.s1", "chapter": "055_留侯世家", "para": "22", "seq": 1, "text": "上欲废太子，立戚夫人子赵王如意。", "len": 16}
{"sid": "055_留侯世家.22.s2", "chapter": "055_留侯世家", "para": "22", "seq": 2, "text": "大臣多谏争，未能得坚决者也。", "len": 14}
{"sid": "055_留侯世家.22.s3", "chapter": "055_留侯世家", "para": "22", "seq": 3, "text": "吕后恐，不知所为。", "len": 9}
{"sid": "055_留侯世家.22.s4", "chapter": "055_留侯世家", "para": "22", "seq": 4, "text": "人或谓吕后曰：“留侯善画计筴，上信用之。", "len": 20}
{"sid": "055_留侯世家.22.s5", "chapter": "055_留侯世家", "para": "22", "seq": 5, "text": "” 吕后乃使建成侯吕泽劫留侯，曰：“君常为上谋臣，今上欲易太子，君安得高枕而卧乎？", "len": 41}
{"sid": "055_留侯世家.22.s6", "chapter": "055_留侯世家", "para": "22", "seq": 6, "text": "” 留侯曰：“始上数在困急之中，幸用臣筴。", "len": 21}
{"sid": "055_留侯世家.22.s7", "chapter": "055_留侯世家", "para": "22", "seq": 7, "text": "今天下安定，以爱欲易太子，骨肉之间，虽臣等百馀人何益。", "len": 27}
{"sid": "055_留侯世家.22.s8", "chapter": "055_留侯世家", "para": "22", "seq": 8, "text": "” 吕泽彊要曰：“为我画计。", "len": 14}
{"sid": "055_留侯世家.22.s9", "chapter": "055_留侯世家", "para": "22", "seq": 9, "text": "” 留侯曰：“此难以口舌争也。", "len": 15}
{"sid": "055_留侯世家.22.s10", "chapter": "055_留侯世家", "para": "22", "seq": 10, "text": "顾上有不能致者，天下有四人。", "len": 14}
{"sid": "055_留侯世家.22.s11", "chapter": "055_留侯世家", "para": "22", "seq": 11, "text": "四人者年老矣，皆以为上慢侮人，故逃匿山中，义不为汉臣。", "len": 27}
{"sid": "055_留侯世家.22.s12", "chapter": "055_留侯世家", "para": "22", "seq": 12, "text": "然上高此四人。", "len": 7}
{"sid": "055_留侯世家.22.s13", "chapter": "055_留侯世家", "para": "22", "seq": 13, "text": "今公诚能无爱金玉璧帛，令太子为书，卑辞安车，因使辩士固请，宜来。", "len": 32}
{"sid": "055_留侯世家.22.s14", "chapter": "055_留侯世家", "para": "22", "seq": 14, "text": "来，以为客，时时从入朝，令上见之，则必异而问之。", "len": 24}
{"sid": "055_留侯世家.22.s15", "chapter": "055_留侯世家", "para": "22", "seq": 15, "text": "问之，上知此四人贤，则一助也。", "len": 15}
{"sid": "055_留侯世家.22.s16", "chapter": "055_留侯世家", "para": "22", "seq": 16, "text": "” 於是吕后令吕泽使人奉太子书，卑辞厚礼，迎此四人。", "len": 26}
{"sid": "055_留侯世家.22.s17", "chapter": "055_留侯世家", "para": "22", "seq": 17, "text": "四人至，客建成侯所。", "len": 10}
{"sid": "055_留侯世家.23.s1", "chapter": "055_留侯世家", "para": "23", "seq": 1, "text": "汉十一年，黥布反，上病，欲使太子将，往击之。", "len": 22}
{"sid": "055_留侯世家.23.s2", "chapter": "055_留侯世家", "para": "23", "seq": 2, "text": "四人相谓曰：“凡来者，将以存太子。", "len": 17}
{"sid": "055_留侯世家.23.s3", "chapter": "055_留侯世家", "para": "23", "seq": 3, "text": "太子将兵，事危矣。", "len": 9}
{"sid": "055_留侯世家.23.s4", "chapter": "055_留侯世家", "para": "23", "seq": 4, "text": "” 乃说建成侯曰：“太子将兵，有功则位不益太子；无功还，则从此受祸矣。", "len": 35}
{"sid": "055_留侯世家.23.s5", "chapter": "055_留侯世家", "para": "23", "seq": 5, "text": "且太子所与俱诸将，皆尝与上定天下枭将也，今使太子将之，此无异使羊将狼也，皆不肯为尽力，其无功必矣。", "len": 49}
{"sid": "055_留侯世家.23.s6", "chapter": "055_留侯世家", "para": "23", "seq": 6, "text": "臣闻‘母爱者子抱’，今戚夫人日夜待御，赵王如意常抱居前，上曰‘终不使不肖子居爱子之上’，明乎其代太子位必矣。", "len": 54}
{"sid": "055_留侯世家.23.s7", "chapter": "055_留侯世家", "para": "23", "seq": 7, "text": "君何不急请吕后承间为上泣言：‘黥布，天下猛将也，善用兵，今诸将皆陛下故等夷，乃令太子将此属，无异使羊将狼，莫肯为用，且使布闻之，则鼓行而西耳。", "len": 71}
{"sid": "055_留侯世家.23.s8", "chapter": "055_留侯世家", "para": "23", "seq": 8, "text": "上虽病，彊载辎车，卧而护之，诸将不敢不尽力。", "len": 22}
{"sid": "055_留侯世家.23.s9", "chapter": "055_留侯世家", "para": "23", "seq": 9, "text": "上虽苦，为妻子自彊。", "len": 10}
{"sid": "055_留侯世家.23.s10", "chapter": "055_留侯世家", "para": "23", "seq": 10, "text": "’” 於是吕泽立夜见吕后，吕后承间为上泣涕而言，如四人意。", "len": 29}
{"sid": "055_留侯世家.23.s11", "chapter": "055_留侯世家", "para": "23", "seq": 11, "text": "上曰：“吾惟竖子固不足遣，而公自行耳。", "len": 19}
{"sid": "055_留侯世家.23.s12", "chapter": "055_留侯世家", "para": "23", "seq": 12, "text": "” 於是上自将兵而东，群臣居守，皆送至灞上。", "len": 22}
{"sid": "055_留侯世家.23.s13", "chapter": "055_留侯世家", "para": "23", "seq": 13, "text": "留侯病，自彊起，至曲邮，见上曰：“臣宜从，病甚。", "len": 24}
{"sid": "055_留侯世家.23.s14", "chapter": "055_留侯世家", "para": "23", "seq": 14, "text": "楚人剽疾，原上无与楚人争锋。", "len": 14}
{"sid": "055_留侯世家.23.s15", "chapter": "055_留侯世家", "para": "23", "seq": 15, "text": "” 因说上曰：“令太子为将军，监关中兵。", "len": 20}
{"sid": "055_留侯世家.23.s16", "chapter": "055_留侯世家", "para": "23", "seq": 16, "text": "” 上曰：“子房虽病，彊卧而傅太子。", "len": 18}
{"sid": "055_留侯世家.23.s17", "chapter": "055_留侯世家", "para": "23", "seq": 17, "text": "” 是时叔孙通为太傅，留侯行少傅事。", "len": 18}
{"sid": "055_留侯世家.24.s1", "chapter": "055_留侯世家", "para": "24", "seq": 1, "text": "汉十二年，上从击破布军归，疾益甚，愈欲易太子。", "len": 23}
{"sid": "055_留侯世家.24.s2", "chapter": "055_留侯世家", "para": "24", "seq": 2, "text": "留侯谏，不听，因疾不视事。", "len": 13}
{"sid": "055_留侯世家.24.s3", "chapter": "055_留侯世家", "para": "24", "seq": 3, "text": "叔孙太傅称说引古今，以死争太子。", "len": 16}
{"sid": "055_留侯世家.24.s4", "chapter": "055_留侯世家", "para": "24", "seq": 4, "text": "上详许之，犹欲易之。", "len": 10}
{"sid": "055_留侯世家.24.s5", "chapter": "055_留侯世家", "para": "24", "seq": 5, "text": "及燕，置酒，太子侍。", "len": 10}
{"sid": "055_留侯世家.24.s6", "chapter": "055_留侯世家", "para": "24", "seq": 6, "text": "四人从太子，年皆八十有馀，须眉皓白，衣冠甚伟。", "len": 23}
{"sid": "055_留侯世家.24.s7", "chapter": "055_留侯世家", "para": "24", "seq": 7, "text": "上怪之，问曰：“彼何为者？", "len": 13}
{"sid": "055_留侯世家.24.s8", "chapter": "055_留侯世家", "para": "24", "seq": 8, "text": "” 四人前对，各言名姓，曰东园公，角里先生，绮里季，夏黄公。", "len": 30}
{"sid": "055_留侯世家.24.s9", "chapter": "055_留侯世家", "para": "24", "seq": 9, "text": "上乃大惊，曰：“吾求公数岁，公辟逃我，今公何自从吾兒游乎？", "len": 29}
{"sid": "055_留侯世家.24.s10", "chapter": "055_留侯世家", "para": "24", "seq": 10, "text": "” 四人皆曰：“陛下轻士善骂，臣等义不受辱，故恐而亡匿。", "len": 28}
{"sid": "055_留侯世家.24.s11", "chapter": "055_留侯世家", "para": "24", "seq": 11, "text": "窃闻太子为人仁孝，恭敬爱士，天下莫不延颈欲为太子死者，故臣等来耳。", "len": 33}
{"sid": "055_留侯世家.24.s12", "chapter": "055_留侯世家", "para": "24", "seq": 12, "text": "” 上曰：“烦公幸卒调护太子。”", "len": 16}
{"sid": "055_留侯世家.25.s1", "chapter": "055_留侯世家", "para": "25", "seq": 1, "text": "四人为寿已毕，趋去。", "len": 10}
{"sid": "055_留侯世家.25.s2", "chapter": "055_留侯世家", "para": "25", "seq": 2, "text": "上目送之，召戚夫人指示四人者曰：“我欲易之，彼四人辅之，羽翼已成，难动矣。", "len": 37}
{"sid": "055_留侯世家.25.s3", "chapter": "055_留侯世家", "para": "25", "seq": 3, "text": "吕后真而主矣。", "len": 7}
{"sid": "055_留侯世家.25.s4", "chapter": "055_留侯世家", "para": "25", "seq": 4, "text": "” 戚夫人泣，上曰：“为我楚舞，吾为若楚歌。", "len": 22}
{"sid": "055_留侯世家.25.s5", "chapter": "055_留侯世家", "para": "25", "seq": 5, "text": "” 歌曰： ::: 歌 “鸿鹄高飞，一举千里。", "len": 23}
{"sid": "055_留侯世家.25.s6", "chapter": "055_留侯世家", "para": "25", "seq": 6, "text": "羽翮已就，横绝四海。", "len": 10}
{"sid": "055_留侯世家.25.s7", "chapter": "055_留侯世家", "para": "25", "seq": 7, "text": "横绝四海，当可柰何！", "len": 10}
{"sid": "055_留侯世家.25.s8", "chapter": "055_留侯世家", "para": "25", "seq": 8, "text": "虽有矰缴，尚安所施！", "len": 10}
{"sid": "055_留侯世家.25.s9", "chapter": "055_留侯世家", "para": "25", "seq": 9, "text": "” ::: 歌数阕，戚夫人嘘唏流涕，上起去，罢酒。", "len": 25}
{"sid": "055_留侯世家.25.s10", "chapter": "055_留侯世家", "para": "25", "seq": 10, "text": "竟不易太子者，留侯本招此四人之力也。", "len": 18}
{"sid": "055_留侯世家.26.s1", "chapter": "055_留侯世家", "para": "26", "seq": 1, "text": "留侯从上击代，出奇计马邑下，及立萧何相国，所与上从容言天下事甚众，非天下所以存亡，故不著。", "len": 45}
{"sid": "055_留侯世家.26.s2", "chapter": "055_留侯世家", "para": "26", "seq": 2, "text": "留侯乃称曰：“家世相韩，及韩灭，不爱万金之资，为韩报雠彊秦，天下振动。", "len": 35}
{"sid": "055_留侯世家.26.s3", "chapter": "055_留侯世家", "para": "26", "seq": 3, "text": "今以三寸舌为帝者师，封万户，位列侯，此布衣之极，於良足矣。", "len": 29}
{"sid": "055_留侯世家.26.s4", "chapter": "055_留侯世家", "para": "26", "seq": 4, "text": "原弃人间事，欲从赤松子游耳。", "len": 14}
{"sid": "055_留侯世家.26.s5", "chapter": "055_留侯世家", "para": "26", "seq": 5, "text": "” 乃学辟穀，道引轻身。", "len": 12}
{"sid": "055_留侯世家.26.s6", "chapter": "055_留侯世家", "para": "26", "seq": 6, "text": "会高帝崩，吕后德留侯，乃彊食之，曰：“人生一世间，如白驹过隙，何至自苦如此乎！", "len": 39}
{"sid": "055_留侯世家.26.s7", "chapter": "055_留侯世家", "para": "26", "seq": 7, "text": "” 留侯不得已，彊听而食。", "len": 13}
{"sid": "055_留侯世家.27.s1", "chapter": "055_留侯世家", "para": "27", "seq": 1, "text": "後八年卒，谥为文成侯。", "len": 11}
{"sid": "055_留侯世家.27.s2", "chapter": "055_留侯世家", "para": "27", "seq": 2, "text": "子不疑代侯。", "len": 6}
{"sid": "055_留侯世家.28.s1", "chapter": "055_留侯世家", "para": "28", "seq": 1, "text": "子房始所见下邳圯上老父与太公书者，後十三年从高帝过济北，果见穀城山下黄石，取而葆祠之。", "len": 43}
{"sid": "055_留侯世家.28.s2", "chapter": "055_留侯世家", "para": "28", "seq": 2, "text": "留侯死，并葬黄石。", "len": 9}
{"sid": "055_留侯世家.28.s3", "chapter": "055_留侯世家", "para": "28", "seq": 3, "text": "每上冢伏腊，祠黄石。", "len": 10}
{"sid": "055_留侯世家.29.s1", "chapter": "055_留侯世家", "para": "29", "seq": 1, "text": "留侯不疑，孝文帝五年坐不敬，国除。", "len": 17}
{"sid": "055_留侯世家.29.s2", "chapter": "055_留侯世家", "para": "29", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "055_留侯世家.30.s1", "chapter": "055_留侯世家", "para": "30", "seq": 1, "text": "太史公曰：学者多言无鬼神，然言有物。", "len": 18}
{"sid": "055_留侯世家.30.s2", "chapter": "055_留侯世家", "para": "30", "seq": 2, "text": "至如留侯所见老父予书，亦可怪矣。", "len": 16}
{"sid": "055_留侯世家.30.s3", "chapter": "055_留侯世家", "para": "30", "seq": 3, "text": "高祖离困者数矣，而留侯常有功力焉，岂可谓非天乎？", "len": 24}
{"sid": "055_留侯世家.30.s4", "chapter": "055_留侯世家", "para": "30", "seq": 4, "text": "上曰：“夫运筹筴帷帐之中，决胜千里外，吾不如子房。", "len": 25}
{"sid": "055_留侯世家.30.s5", "chapter": "055_留侯世家", "para": "30", "seq": 5, "text": "” 余以为其人计魁梧奇伟，至见其图，状貌如妇人好女。", "len": 26}
{"sid": "055_留侯世家.30.s6", "chapter": "055_留侯世家", "para": "30", "seq": 6, "text": "盖孔子曰：“以貌取人，失之子羽。", "len": 16}
{"sid": "055_留侯世家.30.s7", "chapter": "055_留侯世家", "para": "30", "seq": 7, "text": "” 留侯亦云。", "len": 7}
{"sid": "055_留侯世家.30.s8", "chapter": "055_留侯世家", "para": "30", "seq": 8, "text": "::: ::: 赞", "len": 9}
{"sid": "055_留侯世家.31.s1", "chapter": "055_留侯世家", "para": "31", "seq": 1, "text": "留侯倜傥，志怀愤惋。", "len": 10}
{"sid": "055_留侯世家.31.s2", "chapter": "055_留侯世家", "para": "31", "seq": 2, "text": "五代相韩，一朝归汉。", "len": 10}
{"sid": "055_留侯世家.31.s3", "chapter": "055_留侯世家", "para": "31", "seq": 3, "text": "进履宜假，运筹神算。", "len": 10}
{"sid": "055_留侯世家.31.s4", "chapter": "055_留侯世家", "para": "31", "seq": 4, "text": "横阳既立，申徒作扞。", "len": 10}
{"sid": "055_留侯世家.31.s5", "chapter": "055_留侯世家", "para": "31", "seq": 5, "text": "灞上扶危，固陵静乱。", "len": 10}
{"sid": "055_留侯世家.31.s6", "chapter": "055_留侯世家", "para": "31", "seq": 6, "text": "人称三杰，辩推八难。", "len": 10}
{"sid": "055_留侯世家.31.s7", "chapter": "055_留侯世家", "para": "31", "seq": 7, "text": "赤松原游，白驹难绊。", "len": 10}
{"sid": "055_留侯世家.31.s8", "chapter": "055_留侯世家", "para": "31", "seq": 8, "text": "嗟彼雄略，曾非魁岸。", "len": 10}
{"sid": "055_留侯世家.31.s9", "chapter": "055_留侯世家", "para": "31", "seq": 9, "text": ":::", "len": 3}
