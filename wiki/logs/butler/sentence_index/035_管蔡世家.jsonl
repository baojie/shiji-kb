{"sid": "035_管蔡世家.1.s1", "chapter": "035_管蔡世家", "para": "1", "seq": 1, "text": "管叔鲜、蔡叔度者，周文王子而武王弟也。", "len": 19}
{"sid": "035_管蔡世家.1.s2", "chapter": "035_管蔡世家", "para": "1", "seq": 2, "text": "武王同母兄弟十人。", "len": 9}
{"sid": "035_管蔡世家.1.s3", "chapter": "035_管蔡世家", "para": "1", "seq": 3, "text": "母曰太姒，文王正妃也。", "len": 11}
{"sid": "035_管蔡世家.1.s4", "chapter": "035_管蔡世家", "para": "1", "seq": 4, "text": "其长子曰伯邑考，次曰武王发，次曰管叔鲜，次曰周公旦，次曰蔡叔度，次曰曹叔振铎，次曰成叔武，次曰霍叔处，次曰康叔封，次曰厓季载。", "len": 63}
{"sid": "035_管蔡世家.1.s5", "chapter": "035_管蔡世家", "para": "1", "seq": 5, "text": "厓季载最少。", "len": 6}
{"sid": "035_管蔡世家.1.s6", "chapter": "035_管蔡世家", "para": "1", "seq": 6, "text": "同母昆弟十人，唯发、旦贤，左右辅文王，故文王舍伯邑考而以发为太子。", "len": 33}
{"sid": "035_管蔡世家.1.s7", "chapter": "035_管蔡世家", "para": "1", "seq": 7, "text": "及文王崩而发立，是为武王。", "len": 13}
{"sid": "035_管蔡世家.1.s8", "chapter": "035_管蔡世家", "para": "1", "seq": 8, "text": "伯邑考既已前卒矣。", "len": 9}
{"sid": "035_管蔡世家.2.s1", "chapter": "035_管蔡世家", "para": "2", "seq": 1, "text": "武王已克殷纣，平天下，封功臣昆弟。", "len": 17}
{"sid": "035_管蔡世家.2.s2", "chapter": "035_管蔡世家", "para": "2", "seq": 2, "text": "於是封叔鲜於管，封叔度於蔡：二人相纣子武庚禄父，治殷遗民。", "len": 29}
{"sid": "035_管蔡世家.2.s3", "chapter": "035_管蔡世家", "para": "2", "seq": 3, "text": "封叔旦於鲁而相周，为周公。", "len": 13}
{"sid": "035_管蔡世家.2.s4", "chapter": "035_管蔡世家", "para": "2", "seq": 4, "text": "封叔振铎於曹，封叔武於成，封叔处於霍。", "len": 19}
{"sid": "035_管蔡世家.2.s5", "chapter": "035_管蔡世家", "para": "2", "seq": 5, "text": "康叔封、厓季载皆少，未得封。", "len": 14}
{"sid": "035_管蔡世家.3.s1", "chapter": "035_管蔡世家", "para": "3", "seq": 1, "text": "武王既崩，成王少，周公旦专王室。", "len": 16}
{"sid": "035_管蔡世家.3.s2", "chapter": "035_管蔡世家", "para": "3", "seq": 2, "text": "管叔、蔡叔疑周公之为不利於成王，乃挟武庚以作乱。", "len": 24}
{"sid": "035_管蔡世家.3.s3", "chapter": "035_管蔡世家", "para": "3", "seq": 3, "text": "周公旦承成王命伐诛武庚，杀管叔，而放蔡叔，迁之，与车十乘，徒七十人从。", "len": 35}
{"sid": "035_管蔡世家.3.s4", "chapter": "035_管蔡世家", "para": "3", "seq": 4, "text": "而分殷馀民为二：其一封微子启於宋，以续殷祀；其一封康叔为卫君，是为卫康叔。", "len": 37}
{"sid": "035_管蔡世家.3.s5", "chapter": "035_管蔡世家", "para": "3", "seq": 5, "text": "封季载於厓。", "len": 6}
{"sid": "035_管蔡世家.3.s6", "chapter": "035_管蔡世家", "para": "3", "seq": 6, "text": "厓季、康叔皆有驯行，於是周公举康叔为周司寇，厓季为周司空，以佐成王治，皆有令名於天下。", "len": 43}
{"sid": "035_管蔡世家.4.s1", "chapter": "035_管蔡世家", "para": "4", "seq": 1, "text": "蔡叔度既迁而死。", "len": 8}
{"sid": "035_管蔡世家.4.s2", "chapter": "035_管蔡世家", "para": "4", "seq": 2, "text": "其子曰胡，胡乃改行，率德驯善。", "len": 15}
{"sid": "035_管蔡世家.4.s3", "chapter": "035_管蔡世家", "para": "4", "seq": 3, "text": "周公闻之，而举胡以为鲁卿士，鲁国治。", "len": 18}
{"sid": "035_管蔡世家.4.s4", "chapter": "035_管蔡世家", "para": "4", "seq": 4, "text": "於是周公言於成王，复封胡於蔡，以奉蔡叔之祀，是为蔡仲。", "len": 27}
{"sid": "035_管蔡世家.4.s5", "chapter": "035_管蔡世家", "para": "4", "seq": 5, "text": "馀五叔皆就国，无为天子吏者。", "len": 14}
{"sid": "035_管蔡世家.5.s1", "chapter": "035_管蔡世家", "para": "5", "seq": 1, "text": "蔡仲卒，子蔡伯荒立。", "len": 10}
{"sid": "035_管蔡世家.5.s2", "chapter": "035_管蔡世家", "para": "5", "seq": 2, "text": "蔡伯荒卒，子宫侯立。", "len": 10}
{"sid": "035_管蔡世家.5.s3", "chapter": "035_管蔡世家", "para": "5", "seq": 3, "text": "宫侯卒，子厉侯立。", "len": 9}
{"sid": "035_管蔡世家.5.s4", "chapter": "035_管蔡世家", "para": "5", "seq": 4, "text": "厉侯卒，子武侯立。", "len": 9}
{"sid": "035_管蔡世家.5.s5", "chapter": "035_管蔡世家", "para": "5", "seq": 5, "text": "武侯之时，周厉王失国，奔彘，共和行政，诸侯多叛周。", "len": 25}
{"sid": "035_管蔡世家.6.s1", "chapter": "035_管蔡世家", "para": "6", "seq": 1, "text": "武侯卒，子夷侯立。", "len": 9}
{"sid": "035_管蔡世家.6.s2", "chapter": "035_管蔡世家", "para": "6", "seq": 2, "text": "夷侯十一年，周宣王即位。", "len": 12}
{"sid": "035_管蔡世家.6.s3", "chapter": "035_管蔡世家", "para": "6", "seq": 3, "text": "二十八年，夷侯卒，子釐侯所事立。", "len": 16}
{"sid": "035_管蔡世家.7.s1", "chapter": "035_管蔡世家", "para": "7", "seq": 1, "text": "釐侯三十九年，周幽王为犬戎所杀，周室卑而东徙。", "len": 23}
{"sid": "035_管蔡世家.7.s2", "chapter": "035_管蔡世家", "para": "7", "seq": 2, "text": "秦始得列为诸侯。", "len": 8}
{"sid": "035_管蔡世家.8.s1", "chapter": "035_管蔡世家", "para": "8", "seq": 1, "text": "四十八年，釐侯卒，子共侯兴立。", "len": 15}
{"sid": "035_管蔡世家.8.s2", "chapter": "035_管蔡世家", "para": "8", "seq": 2, "text": "共侯二年卒，子戴侯立。", "len": 11}
{"sid": "035_管蔡世家.8.s3", "chapter": "035_管蔡世家", "para": "8", "seq": 3, "text": "戴侯十年卒，子宣侯措父立。", "len": 13}
{"sid": "035_管蔡世家.9.s1", "chapter": "035_管蔡世家", "para": "9", "seq": 1, "text": "宣侯二十八年，鲁隐公初立。", "len": 13}
{"sid": "035_管蔡世家.9.s2", "chapter": "035_管蔡世家", "para": "9", "seq": 2, "text": "三十五年，宣侯卒，子桓侯封人立。", "len": 16}
{"sid": "035_管蔡世家.9.s3", "chapter": "035_管蔡世家", "para": "9", "seq": 3, "text": "桓侯三年，鲁弑其君隐公。", "len": 12}
{"sid": "035_管蔡世家.9.s4", "chapter": "035_管蔡世家", "para": "9", "seq": 4, "text": "二十年，桓侯卒，弟哀侯献舞立。", "len": 15}
{"sid": "035_管蔡世家.10.s1", "chapter": "035_管蔡世家", "para": "10", "seq": 1, "text": "哀侯十一年，初，哀侯娶陈，息侯亦娶陈。", "len": 19}
{"sid": "035_管蔡世家.10.s2", "chapter": "035_管蔡世家", "para": "10", "seq": 2, "text": "息夫人将归，过蔡，蔡侯不敬。", "len": 14}
{"sid": "035_管蔡世家.10.s3", "chapter": "035_管蔡世家", "para": "10", "seq": 3, "text": "息侯怒，请楚文王：”来伐我，我求救於蔡，蔡必来，楚因击之，可以有功。", "len": 34}
{"sid": "035_管蔡世家.10.s4", "chapter": "035_管蔡世家", "para": "10", "seq": 4, "text": "” 楚文王从之，虏蔡哀侯以归。", "len": 15}
{"sid": "035_管蔡世家.10.s5", "chapter": "035_管蔡世家", "para": "10", "seq": 5, "text": "哀侯留九岁，死於楚。", "len": 10}
{"sid": "035_管蔡世家.10.s6", "chapter": "035_管蔡世家", "para": "10", "seq": 6, "text": "凡立二十年卒。", "len": 7}
{"sid": "035_管蔡世家.10.s7", "chapter": "035_管蔡世家", "para": "10", "seq": 7, "text": "蔡人立其子肸，是为缪侯。", "len": 12}
{"sid": "035_管蔡世家.11.s1", "chapter": "035_管蔡世家", "para": "11", "seq": 1, "text": "缪侯以其女弟为齐桓公夫人。", "len": 13}
{"sid": "035_管蔡世家.11.s2", "chapter": "035_管蔡世家", "para": "11", "seq": 2, "text": "十八年，齐桓公与蔡女戏船中，夫人荡舟，桓公止之，不止，公怒，归蔡女而不绝也。", "len": 38}
{"sid": "035_管蔡世家.11.s3", "chapter": "035_管蔡世家", "para": "11", "seq": 3, "text": "蔡侯怒，嫁其弟。", "len": 8}
{"sid": "035_管蔡世家.11.s4", "chapter": "035_管蔡世家", "para": "11", "seq": 4, "text": "齐桓公怒，伐蔡；蔡溃，遂虏缪侯，南至楚邵陵。", "len": 22}
{"sid": "035_管蔡世家.11.s5", "chapter": "035_管蔡世家", "para": "11", "seq": 5, "text": "已而诸侯为蔡谢齐，齐侯归蔡侯。", "len": 15}
{"sid": "035_管蔡世家.11.s6", "chapter": "035_管蔡世家", "para": "11", "seq": 6, "text": "二十九年，缪侯卒，子庄侯甲午立。", "len": 16}
{"sid": "035_管蔡世家.12.s1", "chapter": "035_管蔡世家", "para": "12", "seq": 1, "text": "庄侯三年，齐桓公卒。", "len": 10}
{"sid": "035_管蔡世家.12.s2", "chapter": "035_管蔡世家", "para": "12", "seq": 2, "text": "十四年，晋文公败楚於城濮。", "len": 13}
{"sid": "035_管蔡世家.12.s3", "chapter": "035_管蔡世家", "para": "12", "seq": 3, "text": "二十年，楚太子商臣弑其父成王代立。", "len": 17}
{"sid": "035_管蔡世家.12.s4", "chapter": "035_管蔡世家", "para": "12", "seq": 4, "text": "二十五年，秦穆公卒。", "len": 10}
{"sid": "035_管蔡世家.12.s5", "chapter": "035_管蔡世家", "para": "12", "seq": 5, "text": "三十三年，楚庄王即位。", "len": 11}
{"sid": "035_管蔡世家.12.s6", "chapter": "035_管蔡世家", "para": "12", "seq": 6, "text": "三十四年，庄侯卒，子文侯申立。", "len": 15}
{"sid": "035_管蔡世家.13.s1", "chapter": "035_管蔡世家", "para": "13", "seq": 1, "text": "文侯十四年，楚庄王伐陈，杀夏徵舒。", "len": 17}
{"sid": "035_管蔡世家.13.s2", "chapter": "035_管蔡世家", "para": "13", "seq": 2, "text": "十五年，楚围郑，郑降楚，楚复醳之。", "len": 17}
{"sid": "035_管蔡世家.13.s3", "chapter": "035_管蔡世家", "para": "13", "seq": 3, "text": "二十年，文侯卒，子景侯固立。", "len": 14}
{"sid": "035_管蔡世家.14.s1", "chapter": "035_管蔡世家", "para": "14", "seq": 1, "text": "景侯元年，楚庄王卒。", "len": 10}
{"sid": "035_管蔡世家.14.s2", "chapter": "035_管蔡世家", "para": "14", "seq": 2, "text": "四十九年，景侯为太子般娶妇於楚，而景侯通焉。", "len": 22}
{"sid": "035_管蔡世家.14.s3", "chapter": "035_管蔡世家", "para": "14", "seq": 3, "text": "太子弑景侯而自立，是为灵侯。", "len": 14}
{"sid": "035_管蔡世家.15.s1", "chapter": "035_管蔡世家", "para": "15", "seq": 1, "text": "灵侯二年，楚公子围弑其王郏敖而自立，为灵王。", "len": 22}
{"sid": "035_管蔡世家.15.s2", "chapter": "035_管蔡世家", "para": "15", "seq": 2, "text": "九年，陈司徒招弑其君哀公。", "len": 13}
{"sid": "035_管蔡世家.15.s3", "chapter": "035_管蔡世家", "para": "15", "seq": 3, "text": "楚使公子弃疾灭陈而有之。", "len": 12}
{"sid": "035_管蔡世家.15.s4", "chapter": "035_管蔡世家", "para": "15", "seq": 4, "text": "十二年，楚灵王以灵侯弑其父，诱蔡灵侯于申，伏甲饮之，醉而杀之，刑其士卒七十人。", "len": 39}
{"sid": "035_管蔡世家.15.s5", "chapter": "035_管蔡世家", "para": "15", "seq": 5, "text": "令公子弃疾围蔡。", "len": 8}
{"sid": "035_管蔡世家.15.s6", "chapter": "035_管蔡世家", "para": "15", "seq": 6, "text": "十一月，灭蔡，使弃疾为蔡公。", "len": 14}
{"sid": "035_管蔡世家.16.s1", "chapter": "035_管蔡世家", "para": "16", "seq": 1, "text": "楚灭蔡三岁，楚公子弃疾弑其君灵王代立，为平王。", "len": 23}
{"sid": "035_管蔡世家.16.s2", "chapter": "035_管蔡世家", "para": "16", "seq": 2, "text": "平王乃求蔡景侯少子庐，立之，是为平侯。", "len": 19}
{"sid": "035_管蔡世家.16.s3", "chapter": "035_管蔡世家", "para": "16", "seq": 3, "text": "是年，楚亦复立陈。", "len": 9}
{"sid": "035_管蔡世家.16.s4", "chapter": "035_管蔡世家", "para": "16", "seq": 4, "text": "楚平王初立，欲亲诸侯，故复立陈、蔡後。", "len": 19}
{"sid": "035_管蔡世家.17.s1", "chapter": "035_管蔡世家", "para": "17", "seq": 1, "text": "平侯九年卒，灵侯般之孙东国攻平侯子而自立，是为悼侯。", "len": 26}
{"sid": "035_管蔡世家.17.s2", "chapter": "035_管蔡世家", "para": "17", "seq": 2, "text": "悼侯父曰隐太子友。", "len": 9}
{"sid": "035_管蔡世家.17.s3", "chapter": "035_管蔡世家", "para": "17", "seq": 3, "text": "隐太子友者，灵侯之太子，平侯立而杀隐太子，故平侯卒而隐太子之子东国攻平侯子而代立，是为悼侯。", "len": 46}
{"sid": "035_管蔡世家.17.s4", "chapter": "035_管蔡世家", "para": "17", "seq": 4, "text": "悼侯三年卒，弟昭侯申立。", "len": 12}
{"sid": "035_管蔡世家.18.s1", "chapter": "035_管蔡世家", "para": "18", "seq": 1, "text": "昭侯十年，朝楚昭王，持美裘二，献其一於昭王而自衣其一。", "len": 27}
{"sid": "035_管蔡世家.18.s2", "chapter": "035_管蔡世家", "para": "18", "seq": 2, "text": "楚相子常欲之，不与。", "len": 10}
{"sid": "035_管蔡世家.18.s3", "chapter": "035_管蔡世家", "para": "18", "seq": 3, "text": "子常谗蔡侯，留之楚三年。", "len": 12}
{"sid": "035_管蔡世家.18.s4", "chapter": "035_管蔡世家", "para": "18", "seq": 4, "text": "蔡侯知之，乃献其裘於子常；子常受之，乃言归蔡侯。", "len": 24}
{"sid": "035_管蔡世家.18.s5", "chapter": "035_管蔡世家", "para": "18", "seq": 5, "text": "蔡侯归而之晋，请与晋伐楚。", "len": 13}
{"sid": "035_管蔡世家.19.s1", "chapter": "035_管蔡世家", "para": "19", "seq": 1, "text": "十三年春，与卫灵公会邵陵。", "len": 13}
{"sid": "035_管蔡世家.19.s2", "chapter": "035_管蔡世家", "para": "19", "seq": 2, "text": "蔡侯私於周苌弘以求长於卫；卫使史言康叔之功德，乃长卫。", "len": 27}
{"sid": "035_管蔡世家.19.s3", "chapter": "035_管蔡世家", "para": "19", "seq": 3, "text": "夏，为晋灭沈，楚怒，攻蔡。", "len": 13}
{"sid": "035_管蔡世家.19.s4", "chapter": "035_管蔡世家", "para": "19", "seq": 4, "text": "蔡昭侯使其子为质於吴，以共伐楚。", "len": 16}
{"sid": "035_管蔡世家.19.s5", "chapter": "035_管蔡世家", "para": "19", "seq": 5, "text": "冬，与吴王阖闾遂破楚入郢。", "len": 13}
{"sid": "035_管蔡世家.19.s6", "chapter": "035_管蔡世家", "para": "19", "seq": 6, "text": "蔡怨子常，子常恐，奔郑。", "len": 12}
{"sid": "035_管蔡世家.19.s7", "chapter": "035_管蔡世家", "para": "19", "seq": 7, "text": "十四年，吴去而楚昭王复国。", "len": 13}
{"sid": "035_管蔡世家.19.s8", "chapter": "035_管蔡世家", "para": "19", "seq": 8, "text": "十六年，楚令尹为其民泣以谋蔡，蔡昭侯惧。", "len": 20}
{"sid": "035_管蔡世家.19.s9", "chapter": "035_管蔡世家", "para": "19", "seq": 9, "text": "二十六年，孔子如蔡。", "len": 10}
{"sid": "035_管蔡世家.19.s10", "chapter": "035_管蔡世家", "para": "19", "seq": 10, "text": "楚昭王伐蔡，蔡恐，告急於吴。", "len": 14}
{"sid": "035_管蔡世家.19.s11", "chapter": "035_管蔡世家", "para": "19", "seq": 11, "text": "吴为蔡远，约迁以自近，易以相救；昭侯私许，不与大夫计。", "len": 27}
{"sid": "035_管蔡世家.19.s12", "chapter": "035_管蔡世家", "para": "19", "seq": 12, "text": "吴人来救蔡，因迁蔡于州来。", "len": 13}
{"sid": "035_管蔡世家.19.s13", "chapter": "035_管蔡世家", "para": "19", "seq": 13, "text": "二十八年，昭侯将朝于吴，大夫恐其复迁，乃令贼利杀昭侯；已而诛贼利以解过，而立昭侯子朔，是为成侯。", "len": 48}
{"sid": "035_管蔡世家.20.s1", "chapter": "035_管蔡世家", "para": "20", "seq": 1, "text": "成侯四年，宋灭曹。", "len": 9}
{"sid": "035_管蔡世家.20.s2", "chapter": "035_管蔡世家", "para": "20", "seq": 2, "text": "十年，齐田常弑其君简公。", "len": 12}
{"sid": "035_管蔡世家.20.s3", "chapter": "035_管蔡世家", "para": "20", "seq": 3, "text": "十三年，楚灭陈。", "len": 8}
{"sid": "035_管蔡世家.20.s4", "chapter": "035_管蔡世家", "para": "20", "seq": 4, "text": "十九年，成侯卒，子声侯产立。", "len": 14}
{"sid": "035_管蔡世家.20.s5", "chapter": "035_管蔡世家", "para": "20", "seq": 5, "text": "声侯十五年卒，子元侯立。", "len": 12}
{"sid": "035_管蔡世家.20.s6", "chapter": "035_管蔡世家", "para": "20", "seq": 6, "text": "元侯六年卒，子侯齐立。", "len": 11}
{"sid": "035_管蔡世家.21.s1", "chapter": "035_管蔡世家", "para": "21", "seq": 1, "text": "侯齐四年，楚惠王灭蔡，蔡侯齐亡，蔡遂绝祀。", "len": 21}
{"sid": "035_管蔡世家.21.s2", "chapter": "035_管蔡世家", "para": "21", "seq": 2, "text": "後陈灭三十三年。", "len": 8}
{"sid": "035_管蔡世家.22.s1", "chapter": "035_管蔡世家", "para": "22", "seq": 1, "text": "伯邑考，其後不知所封。", "len": 11}
{"sid": "035_管蔡世家.22.s2", "chapter": "035_管蔡世家", "para": "22", "seq": 2, "text": "武王发，其後为周，有本纪言。", "len": 14}
{"sid": "035_管蔡世家.22.s3", "chapter": "035_管蔡世家", "para": "22", "seq": 3, "text": "管叔鲜作乱诛死，无後。", "len": 11}
{"sid": "035_管蔡世家.22.s4", "chapter": "035_管蔡世家", "para": "22", "seq": 4, "text": "周公旦，其後为鲁，有世家言。", "len": 14}
{"sid": "035_管蔡世家.22.s5", "chapter": "035_管蔡世家", "para": "22", "seq": 5, "text": "蔡叔度，其後为蔡，有世家言。", "len": 14}
{"sid": "035_管蔡世家.22.s6", "chapter": "035_管蔡世家", "para": "22", "seq": 6, "text": "曹叔振铎，有後为曹，有世家言。", "len": 15}
{"sid": "035_管蔡世家.22.s7", "chapter": "035_管蔡世家", "para": "22", "seq": 7, "text": "成叔武，其後世无所见。", "len": 11}
{"sid": "035_管蔡世家.22.s8", "chapter": "035_管蔡世家", "para": "22", "seq": 8, "text": "霍叔处，其後晋献公时灭霍。", "len": 13}
{"sid": "035_管蔡世家.22.s9", "chapter": "035_管蔡世家", "para": "22", "seq": 9, "text": "康叔封，其後为卫，有世家言。", "len": 14}
{"sid": "035_管蔡世家.22.s10", "chapter": "035_管蔡世家", "para": "22", "seq": 10, "text": "厓季载，其後世无所见。", "len": 11}
{"sid": "035_管蔡世家.23.s1", "chapter": "035_管蔡世家", "para": "23", "seq": 1, "text": "太史公曰：管蔡作乱，无足载者。", "len": 15}
{"sid": "035_管蔡世家.23.s2", "chapter": "035_管蔡世家", "para": "23", "seq": 2, "text": "然周武王崩，成王少，天下既疑，赖同母之弟成叔、厓季之属十人为辅拂，是以诸侯卒宗周，故附之世家言。", "len": 48}
{"sid": "035_管蔡世家.24.s1", "chapter": "035_管蔡世家", "para": "24", "seq": 1, "text": "曹叔振铎者，周武王弟也。", "len": 12}
{"sid": "035_管蔡世家.24.s2", "chapter": "035_管蔡世家", "para": "24", "seq": 2, "text": "武王已克殷纣，封叔振铎於曹。", "len": 14}
{"sid": "035_管蔡世家.25.s1", "chapter": "035_管蔡世家", "para": "25", "seq": 1, "text": "叔振铎卒，子太伯脾立。", "len": 11}
{"sid": "035_管蔡世家.25.s2", "chapter": "035_管蔡世家", "para": "25", "seq": 2, "text": "太伯卒，子仲君平立。", "len": 10}
{"sid": "035_管蔡世家.25.s3", "chapter": "035_管蔡世家", "para": "25", "seq": 3, "text": "仲君平卒，子宫伯侯立。", "len": 11}
{"sid": "035_管蔡世家.25.s4", "chapter": "035_管蔡世家", "para": "25", "seq": 4, "text": "宫伯侯卒，子孝伯云立。", "len": 11}
{"sid": "035_管蔡世家.25.s5", "chapter": "035_管蔡世家", "para": "25", "seq": 5, "text": "孝伯云卒，子夷伯喜立。", "len": 11}
{"sid": "035_管蔡世家.26.s1", "chapter": "035_管蔡世家", "para": "26", "seq": 1, "text": "夷伯二十三年，周厉王奔于彘。", "len": 14}
{"sid": "035_管蔡世家.27.s1", "chapter": "035_管蔡世家", "para": "27", "seq": 1, "text": "三十年卒，弟幽伯彊立。", "len": 11}
{"sid": "035_管蔡世家.27.s2", "chapter": "035_管蔡世家", "para": "27", "seq": 2, "text": "幽伯九年，弟苏杀幽伯代立，是为戴伯。", "len": 18}
{"sid": "035_管蔡世家.27.s3", "chapter": "035_管蔡世家", "para": "27", "seq": 3, "text": "戴伯元年，周宣王已立三岁。", "len": 13}
{"sid": "035_管蔡世家.27.s4", "chapter": "035_管蔡世家", "para": "27", "seq": 4, "text": "三十年，戴伯卒，子惠伯兕立。", "len": 14}
{"sid": "035_管蔡世家.28.s1", "chapter": "035_管蔡世家", "para": "28", "seq": 1, "text": "惠伯二十五年，周幽王为犬戎所杀，因东徙，益卑，诸侯畔之。", "len": 28}
{"sid": "035_管蔡世家.28.s2", "chapter": "035_管蔡世家", "para": "28", "seq": 2, "text": "秦始列为诸侯。", "len": 7}
{"sid": "035_管蔡世家.29.s1", "chapter": "035_管蔡世家", "para": "29", "seq": 1, "text": "三十六，惠伯卒，子石甫立，其弟武杀之代立，是为缪公。", "len": 26}
{"sid": "035_管蔡世家.29.s2", "chapter": "035_管蔡世家", "para": "29", "seq": 2, "text": "缪公三年卒，子桓公终生立。", "len": 13}
{"sid": "035_管蔡世家.30.s1", "chapter": "035_管蔡世家", "para": "30", "seq": 1, "text": "桓公三十五年，鲁隐公立。", "len": 12}
{"sid": "035_管蔡世家.30.s2", "chapter": "035_管蔡世家", "para": "30", "seq": 2, "text": "四十五年，鲁弑其君隐公。", "len": 12}
{"sid": "035_管蔡世家.30.s3", "chapter": "035_管蔡世家", "para": "30", "seq": 3, "text": "四十六年，宋华父督弑其君殇公，及孔父。", "len": 19}
{"sid": "035_管蔡世家.30.s4", "chapter": "035_管蔡世家", "para": "30", "seq": 4, "text": "五十五年，桓公卒，子庄公夕姑立。", "len": 16}
{"sid": "035_管蔡世家.31.s1", "chapter": "035_管蔡世家", "para": "31", "seq": 1, "text": "庄公二十三年，齐桓公始霸。", "len": 13}
{"sid": "035_管蔡世家.32.s1", "chapter": "035_管蔡世家", "para": "32", "seq": 1, "text": "三十一年，庄公卒，子釐公夷立。", "len": 15}
{"sid": "035_管蔡世家.32.s2", "chapter": "035_管蔡世家", "para": "32", "seq": 2, "text": "釐公九年卒，子昭公班立。", "len": 12}
{"sid": "035_管蔡世家.32.s3", "chapter": "035_管蔡世家", "para": "32", "seq": 3, "text": "昭公六年，齐桓公败蔡，遂至楚召陵。", "len": 17}
{"sid": "035_管蔡世家.32.s4", "chapter": "035_管蔡世家", "para": "32", "seq": 4, "text": "九年，昭公卒，子共公襄立。", "len": 13}
{"sid": "035_管蔡世家.33.s1", "chapter": "035_管蔡世家", "para": "33", "seq": 1, "text": "共公十六年，初，晋公子重耳其亡过曹，曹君无礼，欲观其骈胁。", "len": 29}
{"sid": "035_管蔡世家.33.s2", "chapter": "035_管蔡世家", "para": "33", "seq": 2, "text": "釐负羁谏，不听，私善於重耳。", "len": 14}
{"sid": "035_管蔡世家.33.s3", "chapter": "035_管蔡世家", "para": "33", "seq": 3, "text": "二十一年，晋文公重耳伐曹，虏共公以归，令军毋入釐负羁之宗族闾。", "len": 31}
{"sid": "035_管蔡世家.33.s4", "chapter": "035_管蔡世家", "para": "33", "seq": 4, "text": "或说晋文公曰：“昔齐桓公会诸侯，复异姓；今君囚曹君，灭同姓，何以令於诸侯？", "len": 37}
{"sid": "035_管蔡世家.33.s5", "chapter": "035_管蔡世家", "para": "33", "seq": 5, "text": "” 晋乃复归共公。", "len": 9}
{"sid": "035_管蔡世家.34.s1", "chapter": "035_管蔡世家", "para": "34", "seq": 1, "text": "二十五年，晋文公卒。", "len": 10}
{"sid": "035_管蔡世家.34.s2", "chapter": "035_管蔡世家", "para": "34", "seq": 2, "text": "三十五年，共公卒，子文公寿立。", "len": 15}
{"sid": "035_管蔡世家.34.s3", "chapter": "035_管蔡世家", "para": "34", "seq": 3, "text": "文公二十三年卒，子宣公彊立。", "len": 14}
{"sid": "035_管蔡世家.34.s4", "chapter": "035_管蔡世家", "para": "34", "seq": 4, "text": "宣公十七年卒，弟成公负刍立。", "len": 14}
{"sid": "035_管蔡世家.35.s1", "chapter": "035_管蔡世家", "para": "35", "seq": 1, "text": "成公三年，晋厉公伐曹，虏成公以归，已复释之。", "len": 22}
{"sid": "035_管蔡世家.35.s2", "chapter": "035_管蔡世家", "para": "35", "seq": 2, "text": "五年，晋栾书、中行偃使程滑弑其君厉公。", "len": 19}
{"sid": "035_管蔡世家.35.s3", "chapter": "035_管蔡世家", "para": "35", "seq": 3, "text": "二十三年，成公卒，子武公胜立。", "len": 15}
{"sid": "035_管蔡世家.35.s4", "chapter": "035_管蔡世家", "para": "35", "seq": 4, "text": "武公二十六年，楚公子弃疾弑其君灵王代立。", "len": 20}
{"sid": "035_管蔡世家.35.s5", "chapter": "035_管蔡世家", "para": "35", "seq": 5, "text": "二十七年，武公卒，子平公立。", "len": 14}
{"sid": "035_管蔡世家.35.s6", "chapter": "035_管蔡世家", "para": "35", "seq": 6, "text": "平公四年卒，子悼公午立。", "len": 12}
{"sid": "035_管蔡世家.35.s7", "chapter": "035_管蔡世家", "para": "35", "seq": 7, "text": "是岁，宋、卫、陈、郑皆火。", "len": 13}
{"sid": "035_管蔡世家.36.s1", "chapter": "035_管蔡世家", "para": "36", "seq": 1, "text": "悼公八年，宋景公立。", "len": 10}
{"sid": "035_管蔡世家.36.s2", "chapter": "035_管蔡世家", "para": "36", "seq": 2, "text": "九年，悼公朝于宋，宋囚之；曹立其弟野，是为声公。", "len": 24}
{"sid": "035_管蔡世家.36.s3", "chapter": "035_管蔡世家", "para": "36", "seq": 3, "text": "悼公死於宋，归葬。", "len": 9}
{"sid": "035_管蔡世家.37.s1", "chapter": "035_管蔡世家", "para": "37", "seq": 1, "text": "声公五年，平公弟通弑声公代立，是为隐公。", "len": 20}
{"sid": "035_管蔡世家.37.s2", "chapter": "035_管蔡世家", "para": "37", "seq": 2, "text": "隐公四年，声公弟露弑隐公代立，是为靖公。", "len": 20}
{"sid": "035_管蔡世家.37.s3", "chapter": "035_管蔡世家", "para": "37", "seq": 3, "text": "靖公四年卒，子伯阳立。", "len": 11}
{"sid": "035_管蔡世家.38.s1", "chapter": "035_管蔡世家", "para": "38", "seq": 1, "text": "伯阳三年，国人有梦众君子立于社宫，谋欲亡曹；曹叔振铎止之，请待公孙彊，许之。", "len": 38}
{"sid": "035_管蔡世家.38.s2", "chapter": "035_管蔡世家", "para": "38", "seq": 2, "text": "旦，求之曹，无此人。", "len": 10}
{"sid": "035_管蔡世家.38.s3", "chapter": "035_管蔡世家", "para": "38", "seq": 3, "text": "梦者戒其子曰：“我亡，尔闻公孙彊为政，必去曹，无离曹祸。", "len": 28}
{"sid": "035_管蔡世家.38.s4", "chapter": "035_管蔡世家", "para": "38", "seq": 4, "text": "” 及伯阳即位，好田弋之事。", "len": 14}
{"sid": "035_管蔡世家.38.s5", "chapter": "035_管蔡世家", "para": "38", "seq": 5, "text": "六年，曹野人公孙彊亦好田弋，获白雁而献之，且言田弋之说，因访政事。", "len": 33}
{"sid": "035_管蔡世家.38.s6", "chapter": "035_管蔡世家", "para": "38", "seq": 6, "text": "伯阳大说之，有宠，使为司城以听政。", "len": 17}
{"sid": "035_管蔡世家.38.s7", "chapter": "035_管蔡世家", "para": "38", "seq": 7, "text": "梦者之子乃亡去。", "len": 8}
{"sid": "035_管蔡世家.39.s1", "chapter": "035_管蔡世家", "para": "39", "seq": 1, "text": "公孙彊言霸说於曹伯。", "len": 10}
{"sid": "035_管蔡世家.39.s2", "chapter": "035_管蔡世家", "para": "39", "seq": 2, "text": "十四年，曹伯从之，乃背晋干宋。", "len": 15}
{"sid": "035_管蔡世家.39.s3", "chapter": "035_管蔡世家", "para": "39", "seq": 3, "text": "宋景公伐之，晋人不救。", "len": 11}
{"sid": "035_管蔡世家.39.s4", "chapter": "035_管蔡世家", "para": "39", "seq": 4, "text": "十五年，宋灭曹，执曹伯阳及公孙彊以归而杀之。", "len": 22}
{"sid": "035_管蔡世家.39.s5", "chapter": "035_管蔡世家", "para": "39", "seq": 5, "text": "曹遂绝其祀。", "len": 6}
{"sid": "035_管蔡世家.39.s6", "chapter": "035_管蔡世家", "para": "39", "seq": 6, "text": "::: 太史公曰", "len": 8}
{"sid": "035_管蔡世家.40.s1", "chapter": "035_管蔡世家", "para": "40", "seq": 1, "text": "太史公曰：余寻曹共公之不用僖负羁，乃乘轩者三百人，知唯德之不建。", "len": 32}
{"sid": "035_管蔡世家.40.s2", "chapter": "035_管蔡世家", "para": "40", "seq": 2, "text": "及振铎之梦，岂不欲引曹之祀者哉？", "len": 16}
{"sid": "035_管蔡世家.40.s3", "chapter": "035_管蔡世家", "para": "40", "seq": 3, "text": "如公孙彊不脩厥政，叔铎之祀忽诸。", "len": 16}
{"sid": "035_管蔡世家.40.s4", "chapter": "035_管蔡世家", "para": "40", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "035_管蔡世家.41.s1", "chapter": "035_管蔡世家", "para": "41", "seq": 1, "text": "武王之弟，管、蔡及霍。", "len": 11}
{"sid": "035_管蔡世家.41.s2", "chapter": "035_管蔡世家", "para": "41", "seq": 2, "text": "周公居相，流言是作。", "len": 10}
{"sid": "035_管蔡世家.41.s3", "chapter": "035_管蔡世家", "para": "41", "seq": 3, "text": "狼跋致艰，鸱鸮讨恶。", "len": 10}
{"sid": "035_管蔡世家.41.s4", "chapter": "035_管蔡世家", "para": "41", "seq": 4, "text": "胡能改行，克复其爵。", "len": 10}
{"sid": "035_管蔡世家.41.s5", "chapter": "035_管蔡世家", "para": "41", "seq": 5, "text": "献舞执楚，遇息礼薄。", "len": 10}
{"sid": "035_管蔡世家.41.s6", "chapter": "035_管蔡世家", "para": "41", "seq": 6, "text": "穆侯虏齐，荡舟乖谑。", "len": 10}
{"sid": "035_管蔡世家.41.s7", "chapter": "035_管蔡世家", "para": "41", "seq": 7, "text": "曹共轻晋，负羁先觉。", "len": 10}
{"sid": "035_管蔡世家.41.s8", "chapter": "035_管蔡世家", "para": "41", "seq": 8, "text": "伯阳梦社，祚倾振铎。", "len": 10}
{"sid": "035_管蔡世家.41.s9", "chapter": "035_管蔡世家", "para": "41", "seq": 9, "text": ":::", "len": 3}
