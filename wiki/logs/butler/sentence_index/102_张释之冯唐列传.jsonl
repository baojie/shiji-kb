{"sid": "102_张释之冯唐列传.1.s1", "chapter": "102_张释之冯唐列传", "para": "1", "seq": 1, "text": "张廷尉释之者，堵阳人也，字季。", "len": 15}
{"sid": "102_张释之冯唐列传.1.s2", "chapter": "102_张释之冯唐列传", "para": "1", "seq": 2, "text": "有兄仲同居。", "len": 6}
{"sid": "102_张释之冯唐列传.1.s3", "chapter": "102_张释之冯唐列传", "para": "1", "seq": 3, "text": "以訾为骑郎，事孝文帝，十岁不得调，无所知名。", "len": 22}
{"sid": "102_张释之冯唐列传.1.s4", "chapter": "102_张释之冯唐列传", "para": "1", "seq": 4, "text": "释之曰：“久宦减仲之产，不遂。", "len": 15}
{"sid": "102_张释之冯唐列传.1.s5", "chapter": "102_张释之冯唐列传", "para": "1", "seq": 5, "text": "” 欲自免归。", "len": 7}
{"sid": "102_张释之冯唐列传.1.s6", "chapter": "102_张释之冯唐列传", "para": "1", "seq": 6, "text": "中郎将袁盎知其贤，惜其去，乃请徙释之补谒者。", "len": 22}
{"sid": "102_张释之冯唐列传.1.s7", "chapter": "102_张释之冯唐列传", "para": "1", "seq": 7, "text": "释之既朝毕，因前言便宜事。", "len": 13}
{"sid": "102_张释之冯唐列传.1.s8", "chapter": "102_张释之冯唐列传", "para": "1", "seq": 8, "text": "文帝曰：“卑之，毋甚高论|卑之毋甚高论，令今可施行也。", "len": 27}
{"sid": "102_张释之冯唐列传.1.s9", "chapter": "102_张释之冯唐列传", "para": "1", "seq": 9, "text": "” 於是释之言秦汉之间事，秦所以失而汉所以兴者久之。", "len": 26}
{"sid": "102_张释之冯唐列传.1.s10", "chapter": "102_张释之冯唐列传", "para": "1", "seq": 10, "text": "文帝称善，乃拜释之为谒者仆射。", "len": 15}
{"sid": "102_张释之冯唐列传.2.s1", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 1, "text": "释之从行，登虎圈。", "len": 9}
{"sid": "102_张释之冯唐列传.2.s2", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 2, "text": "上问上林尉诸禽兽簿，十馀问，尉左右视，尽不能对。", "len": 24}
{"sid": "102_张释之冯唐列传.2.s3", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 3, "text": "虎圈啬夫从旁代尉对上所问禽兽簿甚悉，欲以观其能口对响应无穷者。", "len": 31}
{"sid": "102_张释之冯唐列传.2.s4", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 4, "text": "文帝曰：“吏不当若是邪？", "len": 12}
{"sid": "102_张释之冯唐列传.2.s5", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 5, "text": "尉无赖！", "len": 4}
{"sid": "102_张释之冯唐列传.2.s6", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 6, "text": "” 乃诏释之拜啬夫为上林令。", "len": 14}
{"sid": "102_张释之冯唐列传.2.s7", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 7, "text": "释之久之前曰：“陛下以绛侯周勃何如人也？", "len": 20}
{"sid": "102_张释之冯唐列传.2.s8", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 8, "text": "” 上曰：“长者也。", "len": 10}
{"sid": "102_张释之冯唐列传.2.s9", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 9, "text": "” 又复问：“东阳侯张相如何如人也？", "len": 18}
{"sid": "102_张释之冯唐列传.2.s10", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 10, "text": "” 上复曰：“长者。", "len": 10}
{"sid": "102_张释之冯唐列传.2.s11", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 11, "text": "” 释之曰：“夫绛侯、东阳侯称为长者，此两人言事曾不能出口，岂斅此啬夫谍谍利口捷给哉！", "len": 43}
{"sid": "102_张释之冯唐列传.2.s12", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 12, "text": "且秦以任刀笔之吏，吏争以亟疾苛察相高，然其敝徒文具耳，无恻隐之实。", "len": 33}
{"sid": "102_张释之冯唐列传.2.s13", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 13, "text": "以故不闻其过，陵迟而至於二世，天下土崩。", "len": 20}
{"sid": "102_张释之冯唐列传.2.s14", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 14, "text": "今陛下以啬夫口辩而超迁之，臣恐天下随风靡靡，争为口辩而无其实。", "len": 31}
{"sid": "102_张释之冯唐列传.2.s15", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 15, "text": "且下之化上疾於景响，举错不可不审也。", "len": 18}
{"sid": "102_张释之冯唐列传.2.s16", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 16, "text": "” 文帝曰：“善。", "len": 9}
{"sid": "102_张释之冯唐列传.2.s17", "chapter": "102_张释之冯唐列传", "para": "2", "seq": 17, "text": "” 乃止不拜啬夫。", "len": 9}
{"sid": "102_张释之冯唐列传.3.s1", "chapter": "102_张释之冯唐列传", "para": "3", "seq": 1, "text": "上就车，召释之参乘，徐行，问释之秦之敝。", "len": 20}
{"sid": "102_张释之冯唐列传.3.s2", "chapter": "102_张释之冯唐列传", "para": "3", "seq": 2, "text": "具以质言。", "len": 5}
{"sid": "102_张释之冯唐列传.3.s3", "chapter": "102_张释之冯唐列传", "para": "3", "seq": 3, "text": "至宫，上拜释之为公车令。", "len": 12}
{"sid": "102_张释之冯唐列传.4.s1", "chapter": "102_张释之冯唐列传", "para": "4", "seq": 1, "text": "顷之，太子与梁王共车入朝，不下司马门，於是释之追止太子、梁王无得入殿门。", "len": 36}
{"sid": "102_张释之冯唐列传.4.s2", "chapter": "102_张释之冯唐列传", "para": "4", "seq": 2, "text": "遂劾不下公门不敬，奏之。", "len": 12}
{"sid": "102_张释之冯唐列传.4.s3", "chapter": "102_张释之冯唐列传", "para": "4", "seq": 3, "text": "薄太后闻之，文帝免冠谢曰：“教兒子不谨。", "len": 20}
{"sid": "102_张释之冯唐列传.4.s4", "chapter": "102_张释之冯唐列传", "para": "4", "seq": 4, "text": "” 薄太后乃使使承诏赦太子、梁王，然后得入。", "len": 22}
{"sid": "102_张释之冯唐列传.4.s5", "chapter": "102_张释之冯唐列传", "para": "4", "seq": 5, "text": "文帝由是奇释之，拜为中大夫。", "len": 14}
{"sid": "102_张释之冯唐列传.5.s1", "chapter": "102_张释之冯唐列传", "para": "5", "seq": 1, "text": "顷之，至中郎将。", "len": 8}
{"sid": "102_张释之冯唐列传.5.s2", "chapter": "102_张释之冯唐列传", "para": "5", "seq": 2, "text": "从行至霸陵，居北临厕。", "len": 11}
{"sid": "102_张释之冯唐列传.5.s3", "chapter": "102_张释之冯唐列传", "para": "5", "seq": 3, "text": "是时慎夫人从，上指示慎夫人新丰道，曰：“此走邯郸道也。", "len": 27}
{"sid": "102_张释之冯唐列传.5.s4", "chapter": "102_张释之冯唐列传", "para": "5", "seq": 4, "text": "” 使慎夫人鼓瑟，上自倚瑟而歌，意惨凄悲怀，顾谓群臣曰：“嗟乎！", "len": 32}
{"sid": "102_张释之冯唐列传.5.s5", "chapter": "102_张释之冯唐列传", "para": "5", "seq": 5, "text": "以北山石为椁，用纻絮斫陈，蕠漆其间，岂可动哉！", "len": 23}
{"sid": "102_张释之冯唐列传.5.s6", "chapter": "102_张释之冯唐列传", "para": "5", "seq": 6, "text": "” 左右皆曰：“善。", "len": 10}
{"sid": "102_张释之冯唐列传.5.s7", "chapter": "102_张释之冯唐列传", "para": "5", "seq": 7, "text": "” 释之前进曰：“使其中有可欲者，虽锢南山犹有郄；使其中无可欲者，虽无石椁，又何戚焉！", "len": 43}
{"sid": "102_张释之冯唐列传.5.s8", "chapter": "102_张释之冯唐列传", "para": "5", "seq": 8, "text": "” 文帝称善。", "len": 7}
{"sid": "102_张释之冯唐列传.5.s9", "chapter": "102_张释之冯唐列传", "para": "5", "seq": 9, "text": "其後拜释之为廷尉。", "len": 9}
{"sid": "102_张释之冯唐列传.6.s1", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 1, "text": "顷之，上行出中渭桥，有一人从穚下走出，乘舆马惊。", "len": 24}
{"sid": "102_张释之冯唐列传.6.s2", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 2, "text": "於是使骑捕，属之廷尉。", "len": 11}
{"sid": "102_张释之冯唐列传.6.s3", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 3, "text": "释之治问。", "len": 5}
{"sid": "102_张释之冯唐列传.6.s4", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 4, "text": "曰：“县人来，闻跸，匿桥下。", "len": 14}
{"sid": "102_张释之冯唐列传.6.s5", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 5, "text": "久之，以为行已过，即出，见乘舆车骑，即走耳。", "len": 22}
{"sid": "102_张释之冯唐列传.6.s6", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 6, "text": "” 廷尉秦当，一人犯跸，当罚金。", "len": 16}
{"sid": "102_张释之冯唐列传.6.s7", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 7, "text": "文帝怒曰：“此人亲惊吾马，吾马赖柔和，令他马，固不败伤我乎？", "len": 30}
{"sid": "102_张释之冯唐列传.6.s8", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 8, "text": "而廷尉乃当之罚金！", "len": 9}
{"sid": "102_张释之冯唐列传.6.s9", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 9, "text": "” 释之曰：“法者天子所与天下公共也。", "len": 19}
{"sid": "102_张释之冯唐列传.6.s10", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 10, "text": "今法如此而更重之，是法不信於民也。", "len": 17}
{"sid": "102_张释之冯唐列传.6.s11", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 11, "text": "且方其时，上使立诛之则已。", "len": 13}
{"sid": "102_张释之冯唐列传.6.s12", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 12, "text": "今既下廷尉，廷尉，天下之平也，一倾而天下用法皆为轻重，民安所措其手足？", "len": 35}
{"sid": "102_张释之冯唐列传.6.s13", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 13, "text": "唯陛下察之。", "len": 6}
{"sid": "102_张释之冯唐列传.6.s14", "chapter": "102_张释之冯唐列传", "para": "6", "seq": 14, "text": "” 良久，上曰：“廷尉当是也。”", "len": 16}
{"sid": "102_张释之冯唐列传.7.s1", "chapter": "102_张释之冯唐列传", "para": "7", "seq": 1, "text": "其後有人盗高庙坐前玉环，捕得，文帝怒，下廷尉治。", "len": 24}
{"sid": "102_张释之冯唐列传.7.s2", "chapter": "102_张释之冯唐列传", "para": "7", "seq": 2, "text": "释之案律盗宗庙服御物者为奏，奏当弃市。", "len": 19}
{"sid": "102_张释之冯唐列传.7.s3", "chapter": "102_张释之冯唐列传", "para": "7", "seq": 3, "text": "上大怒曰：“人之无道，乃盗先帝庙器，吾属廷尉者，欲致之族，而君以法奏之，非吾所以共承宗庙意也。", "len": 47}
{"sid": "102_张释之冯唐列传.7.s4", "chapter": "102_张释之冯唐列传", "para": "7", "seq": 4, "text": "” 释之免冠顿首谢曰：“法如是足也。", "len": 18}
{"sid": "102_张释之冯唐列传.7.s5", "chapter": "102_张释之冯唐列传", "para": "7", "seq": 5, "text": "且罪等，然以逆顺为差。", "len": 11}
{"sid": "102_张释之冯唐列传.7.s6", "chapter": "102_张释之冯唐列传", "para": "7", "seq": 6, "text": "今盗宗庙器而族之，有如万分之一，假令愚民取长陵一抔土，陛下何以加其法乎？", "len": 36}
{"sid": "102_张释之冯唐列传.7.s7", "chapter": "102_张释之冯唐列传", "para": "7", "seq": 7, "text": "” 久之，文帝与太后言之，乃许廷尉当。", "len": 19}
{"sid": "102_张释之冯唐列传.7.s8", "chapter": "102_张释之冯唐列传", "para": "7", "seq": 8, "text": "是时，中尉条侯周亚夫与梁相山都侯王恬开见释之持议平，乃结为亲友。", "len": 32}
{"sid": "102_张释之冯唐列传.7.s9", "chapter": "102_张释之冯唐列传", "para": "7", "seq": 9, "text": "张廷尉由此天下称之。", "len": 10}
{"sid": "102_张释之冯唐列传.8.s1", "chapter": "102_张释之冯唐列传", "para": "8", "seq": 1, "text": "後文帝崩，景帝立，释之恐，称病。", "len": 16}
{"sid": "102_张释之冯唐列传.8.s2", "chapter": "102_张释之冯唐列传", "para": "8", "seq": 2, "text": "欲免去，惧大诛至；欲见谢，则未知何如。", "len": 19}
{"sid": "102_张释之冯唐列传.8.s3", "chapter": "102_张释之冯唐列传", "para": "8", "seq": 3, "text": "用王生计，卒见谢，景帝不过也。", "len": 15}
{"sid": "102_张释之冯唐列传.9.s1", "chapter": "102_张释之冯唐列传", "para": "9", "seq": 1, "text": "王生者，善为黄老言，处士也。", "len": 14}
{"sid": "102_张释之冯唐列传.9.s2", "chapter": "102_张释之冯唐列传", "para": "9", "seq": 2, "text": "尝召居廷中，三公九卿尽会立，王生老人，曰“吾穇解”，顾谓张廷尉：“为我结穇！", "len": 38}
{"sid": "102_张释之冯唐列传.9.s3", "chapter": "102_张释之冯唐列传", "para": "9", "seq": 3, "text": "” 释之跪而结之。", "len": 9}
{"sid": "102_张释之冯唐列传.9.s4", "chapter": "102_张释之冯唐列传", "para": "9", "seq": 4, "text": "既已，人或谓王生曰：“独柰何廷辱张廷尉，使跪结穇？", "len": 25}
{"sid": "102_张释之冯唐列传.9.s5", "chapter": "102_张释之冯唐列传", "para": "9", "seq": 5, "text": "” 王生曰：“吾老且贱，自度终无益於张廷尉。", "len": 22}
{"sid": "102_张释之冯唐列传.9.s6", "chapter": "102_张释之冯唐列传", "para": "9", "seq": 6, "text": "张廷尉方今天下名臣，吾故聊辱廷尉，使跪结穇，欲以重之。", "len": 27}
{"sid": "102_张释之冯唐列传.9.s7", "chapter": "102_张释之冯唐列传", "para": "9", "seq": 7, "text": "” 诸公闻之，贤王生而重张廷尉。", "len": 16}
{"sid": "102_张释之冯唐列传.10.s1", "chapter": "102_张释之冯唐列传", "para": "10", "seq": 1, "text": "张廷尉事景帝岁馀，为淮南王相，犹尚以前过也。", "len": 22}
{"sid": "102_张释之冯唐列传.10.s2", "chapter": "102_张释之冯唐列传", "para": "10", "seq": 2, "text": "久之，释之卒。", "len": 7}
{"sid": "102_张释之冯唐列传.10.s3", "chapter": "102_张释之冯唐列传", "para": "10", "seq": 3, "text": "其子曰张挚，字长公，官至大夫，免。", "len": 17}
{"sid": "102_张释之冯唐列传.10.s4", "chapter": "102_张释之冯唐列传", "para": "10", "seq": 4, "text": "以不能取容当世，故终身不仕。", "len": 14}
{"sid": "102_张释之冯唐列传.11.s1", "chapter": "102_张释之冯唐列传", "para": "11", "seq": 1, "text": "冯唐者，其大父赵人。", "len": 10}
{"sid": "102_张释之冯唐列传.11.s2", "chapter": "102_张释之冯唐列传", "para": "11", "seq": 2, "text": "父徙代。", "len": 4}
{"sid": "102_张释之冯唐列传.11.s3", "chapter": "102_张释之冯唐列传", "para": "11", "seq": 3, "text": "汉兴徙安陵。", "len": 6}
{"sid": "102_张释之冯唐列传.11.s4", "chapter": "102_张释之冯唐列传", "para": "11", "seq": 4, "text": "唐以孝著，为中郎署长，事文帝。", "len": 15}
{"sid": "102_张释之冯唐列传.12.s1", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 1, "text": "文帝辇过，问唐曰：”父老何自为郎？", "len": 17}
{"sid": "102_张释之冯唐列传.12.s2", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 2, "text": "家安在？", "len": 4}
{"sid": "102_张释之冯唐列传.12.s3", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 3, "text": "” 唐具以实对。", "len": 8}
{"sid": "102_张释之冯唐列传.12.s4", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 4, "text": "文帝曰：“吾居代时，吾尚食监高袪数为我言赵将李齐之贤，战於钜鹿下。", "len": 33}
{"sid": "102_张释之冯唐列传.12.s5", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 5, "text": "今吾每饭，意未尝不在钜鹿也。", "len": 14}
{"sid": "102_张释之冯唐列传.12.s6", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 6, "text": "父知之乎？", "len": 5}
{"sid": "102_张释之冯唐列传.12.s7", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 7, "text": "” 唐对曰：“尚不如廉颇、李牧之为将也。", "len": 20}
{"sid": "102_张释之冯唐列传.12.s8", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 8, "text": "” 上曰：“何以？", "len": 9}
{"sid": "102_张释之冯唐列传.12.s9", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 9, "text": "” 唐曰：“臣大父在赵时，为官将，善李牧。", "len": 21}
{"sid": "102_张释之冯唐列传.12.s10", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 10, "text": "臣父故为代相，善赵将李齐，知其为人也。", "len": 19}
{"sid": "102_张释之冯唐列传.12.s11", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 11, "text": "” 上既闻廉颇、李牧为人，良说，而搏髀曰：“嗟乎！", "len": 25}
{"sid": "102_张释之冯唐列传.12.s12", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 12, "text": "吾独不得廉颇、李牧时为吾将，吾岂忧匈奴哉！", "len": 21}
{"sid": "102_张释之冯唐列传.12.s13", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 13, "text": "” 唐曰：“主臣！", "len": 9}
{"sid": "102_张释之冯唐列传.12.s14", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 14, "text": "陛下虽得廉颇、李牧，弗能用也。", "len": 15}
{"sid": "102_张释之冯唐列传.12.s15", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 15, "text": "” 上怒，起入禁中。", "len": 10}
{"sid": "102_张释之冯唐列传.12.s16", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 16, "text": "良久，召唐让曰：“公柰何众辱我，独无间处乎？", "len": 22}
{"sid": "102_张释之冯唐列传.12.s17", "chapter": "102_张释之冯唐列传", "para": "12", "seq": 17, "text": "” 唐谢曰：“鄙人不知忌讳。”", "len": 15}
{"sid": "102_张释之冯唐列传.13.s1", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 1, "text": "当是之时，匈奴新大入朝，杀北地都尉卬。", "len": 19}
{"sid": "102_张释之冯唐列传.13.s2", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 2, "text": "上以胡寇为意，乃卒复问唐曰：“公何以知吾不能用廉颇、李牧也？", "len": 30}
{"sid": "102_张释之冯唐列传.13.s3", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 3, "text": "” 唐对曰：“臣闻上古王者之遣将也，跪而推毂，曰阃以内者，寡人制之；阃以外者，将军制之。", "len": 44}
{"sid": "102_张释之冯唐列传.13.s4", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 4, "text": "军功爵赏皆决於外，归而奏之。", "len": 14}
{"sid": "102_张释之冯唐列传.13.s5", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 5, "text": "此非虚言也。", "len": 6}
{"sid": "102_张释之冯唐列传.13.s6", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 6, "text": "臣大父言，李牧为赵将居边，军市之租皆自用飨士，赏赐决於外，不从中扰也。", "len": 35}
{"sid": "102_张释之冯唐列传.13.s7", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 7, "text": "委任而责成功，故李牧乃得尽其智能，遣选车千三百乘，彀骑万三千，百金之士十万，是以北逐单于，破东胡，灭澹林，西抑彊秦，南支韩、魏。", "len": 64}
{"sid": "102_张释之冯唐列传.13.s8", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 8, "text": "当是之时，赵几霸。", "len": 9}
{"sid": "102_张释之冯唐列传.13.s9", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 9, "text": "其後会赵王迁立，其母倡也。", "len": 13}
{"sid": "102_张释之冯唐列传.13.s10", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 10, "text": "王迁立，乃用郭开谗，卒诛李牧，令颜聚代之。", "len": 21}
{"sid": "102_张释之冯唐列传.13.s11", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 11, "text": "是以兵破士北，为秦所禽灭。", "len": 13}
{"sid": "102_张释之冯唐列传.13.s12", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 12, "text": "今臣窃闻魏尚为云中守，其军市租尽以飨士卒，私养钱，五日一椎牛，飨宾客军吏舍人，是以匈奴远避，不近云中之塞。", "len": 53}
{"sid": "102_张释之冯唐列传.13.s13", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 13, "text": "虏曾一入，尚率车骑击之，所杀其众。", "len": 17}
{"sid": "102_张释之冯唐列传.13.s14", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 14, "text": "夫士卒尽家人子，起田中从军，安知尺籍伍符。", "len": 21}
{"sid": "102_张释之冯唐列传.13.s15", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 15, "text": "终日力战，斩首捕虏，上功莫府，一言不相应，文吏以法绳之。", "len": 28}
{"sid": "102_张释之冯唐列传.13.s16", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 16, "text": "其赏不行而吏奉法必用。", "len": 11}
{"sid": "102_张释之冯唐列传.13.s17", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 17, "text": "臣愚，以为陛下法太明，赏太轻，罚太重。", "len": 19}
{"sid": "102_张释之冯唐列传.13.s18", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 18, "text": "且云中守魏尚坐上功首虏差六级，陛下下之吏，削其爵，罚作之。", "len": 29}
{"sid": "102_张释之冯唐列传.13.s19", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 19, "text": "由此言之，陛下虽得廉颇、李牧，弗能用也。", "len": 20}
{"sid": "102_张释之冯唐列传.13.s20", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 20, "text": "臣诚愚，触忌讳，死罪死罪！", "len": 13}
{"sid": "102_张释之冯唐列传.13.s21", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 21, "text": "” 文帝说。", "len": 6}
{"sid": "102_张释之冯唐列传.13.s22", "chapter": "102_张释之冯唐列传", "para": "13", "seq": 22, "text": "是日令冯唐持节赦魏尚，复以为云中守，而拜唐为车骑都尉，主中尉及郡国车士。", "len": 36}
{"sid": "102_张释之冯唐列传.14.s1", "chapter": "102_张释之冯唐列传", "para": "14", "seq": 1, "text": "七年，景帝立，以唐为楚相，免。", "len": 15}
{"sid": "102_张释之冯唐列传.14.s2", "chapter": "102_张释之冯唐列传", "para": "14", "seq": 2, "text": "武帝立，求贤良，举冯唐。", "len": 12}
{"sid": "102_张释之冯唐列传.14.s3", "chapter": "102_张释之冯唐列传", "para": "14", "seq": 3, "text": "唐时年九十馀，不能复为官，乃以唐子冯遂为郎。", "len": 22}
{"sid": "102_张释之冯唐列传.14.s4", "chapter": "102_张释之冯唐列传", "para": "14", "seq": 4, "text": "遂字王孙，亦奇士，与余善。", "len": 13}
{"sid": "102_张释之冯唐列传.14.s5", "chapter": "102_张释之冯唐列传", "para": "14", "seq": 5, "text": "::: 太史公曰", "len": 8}
{"sid": "102_张释之冯唐列传.15.s1", "chapter": "102_张释之冯唐列传", "para": "15", "seq": 1, "text": "太史公曰：张季之言长者，守法不阿意；冯公之论将率，有味哉！", "len": 29}
{"sid": "102_张释之冯唐列传.15.s2", "chapter": "102_张释之冯唐列传", "para": "15", "seq": 2, "text": "有味哉！", "len": 4}
{"sid": "102_张释之冯唐列传.15.s3", "chapter": "102_张释之冯唐列传", "para": "15", "seq": 3, "text": "语曰“不知其人，视其友”。", "len": 13}
{"sid": "102_张释之冯唐列传.15.s4", "chapter": "102_张释之冯唐列传", "para": "15", "seq": 4, "text": "二君之所称诵，可著廊庙。", "len": 12}
{"sid": "102_张释之冯唐列传.15.s5", "chapter": "102_张释之冯唐列传", "para": "15", "seq": 5, "text": "书曰“不偏不党，王道荡荡；不党不偏，王道便便”。", "len": 24}
{"sid": "102_张释之冯唐列传.15.s6", "chapter": "102_张释之冯唐列传", "para": "15", "seq": 6, "text": "张季、冯公近之矣。", "len": 9}
{"sid": "102_张释之冯唐列传.15.s7", "chapter": "102_张释之冯唐列传", "para": "15", "seq": 7, "text": "::: ::: 赞", "len": 9}
{"sid": "102_张释之冯唐列传.16.s1", "chapter": "102_张释之冯唐列传", "para": "16", "seq": 1, "text": "张季未偶，见识袁盎。", "len": 10}
{"sid": "102_张释之冯唐列传.16.s2", "chapter": "102_张释之冯唐列传", "para": "16", "seq": 2, "text": "太子惧法，啬夫无状。", "len": 10}
{"sid": "102_张释之冯唐列传.16.s3", "chapter": "102_张释之冯唐列传", "para": "16", "seq": 3, "text": "惊马罚金，盗环悟上。", "len": 10}
{"sid": "102_张释之冯唐列传.16.s4", "chapter": "102_张释之冯唐列传", "para": "16", "seq": 4, "text": "冯公白首，味哉论将。", "len": 10}
{"sid": "102_张释之冯唐列传.16.s5", "chapter": "102_张释之冯唐列传", "para": "16", "seq": 5, "text": "因对李齐，收功魏尚。", "len": 10}
{"sid": "102_张释之冯唐列传.16.s6", "chapter": "102_张释之冯唐列传", "para": "16", "seq": 6, "text": ":::", "len": 3}
