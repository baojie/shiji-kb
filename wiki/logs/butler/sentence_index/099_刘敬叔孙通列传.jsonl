{"sid": "099_刘敬叔孙通列传.1.s1", "chapter": "099_刘敬叔孙通列传", "para": "1", "seq": 1, "text": "刘敬者，齐人也。", "len": 8}
{"sid": "099_刘敬叔孙通列传.1.s2", "chapter": "099_刘敬叔孙通列传", "para": "1", "seq": 2, "text": "汉五年，戍陇西，过洛阳，高帝在焉。", "len": 17}
{"sid": "099_刘敬叔孙通列传.1.s3", "chapter": "099_刘敬叔孙通列传", "para": "1", "seq": 3, "text": "娄敬脱輓辂，衣其羊裘，见齐人虞将军曰：“臣原见上言便事。", "len": 28}
{"sid": "099_刘敬叔孙通列传.1.s4", "chapter": "099_刘敬叔孙通列传", "para": "1", "seq": 4, "text": "” 虞将军欲与之鲜衣，娄敬曰：“臣衣帛，衣帛见；衣褐，衣褐见：终不敢易衣。", "len": 37}
{"sid": "099_刘敬叔孙通列传.1.s5", "chapter": "099_刘敬叔孙通列传", "para": "1", "seq": 5, "text": "” 於是虞将军入言上。", "len": 11}
{"sid": "099_刘敬叔孙通列传.1.s6", "chapter": "099_刘敬叔孙通列传", "para": "1", "seq": 6, "text": "上召入见，赐食。", "len": 8}
{"sid": "099_刘敬叔孙通列传.2.s1", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 1, "text": "已而问娄敬，娄敬说曰：“陛下都洛阳，岂欲与周室比隆哉？", "len": 27}
{"sid": "099_刘敬叔孙通列传.2.s2", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 2, "text": "” 上曰：“然。", "len": 8}
{"sid": "099_刘敬叔孙通列传.2.s3", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 3, "text": "” 娄敬曰：“陛下取天下与周室异。", "len": 17}
{"sid": "099_刘敬叔孙通列传.2.s4", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 4, "text": "周之先自后稷，尧封之邰，积德累善十有馀世。", "len": 21}
{"sid": "099_刘敬叔孙通列传.2.s5", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 5, "text": "公刘避桀居豳。", "len": 7}
{"sid": "099_刘敬叔孙通列传.2.s6", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 6, "text": "太王以狄伐故，去豳，杖马箠居岐，国人争随之。", "len": 22}
{"sid": "099_刘敬叔孙通列传.2.s7", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 7, "text": "及文王为西伯，断虞芮之讼，始受命，吕望、伯夷自海滨来归之。", "len": 29}
{"sid": "099_刘敬叔孙通列传.2.s8", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 8, "text": "武王伐纣，不期而会孟津之上八百诸侯，皆曰纣可伐矣，遂灭殷。", "len": 29}
{"sid": "099_刘敬叔孙通列传.2.s9", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 9, "text": "成王即位，周公之属傅相焉，乃营成周洛邑，以此为天下之中也，诸侯四方纳贡职，道里均矣，有德则易以王，无德则易以亡。", "len": 56}
{"sid": "099_刘敬叔孙通列传.2.s10", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 10, "text": "凡居此者，欲令周务以德致人，不欲依阻险，令後世骄奢以虐民也。", "len": 30}
{"sid": "099_刘敬叔孙通列传.2.s11", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 11, "text": "及周之盛时，天下和洽，四夷乡风，慕义怀德，附离而并事天子，不屯一卒，不战一士，八夷大国之民莫不宾服，效其贡职。", "len": 55}
{"sid": "099_刘敬叔孙通列传.2.s12", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 12, "text": "及周之衰也，分而为两，天下莫朝，周不能制也。", "len": 22}
{"sid": "099_刘敬叔孙通列传.2.s13", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 13, "text": "非其德薄也，而形势弱也。", "len": 12}
{"sid": "099_刘敬叔孙通列传.2.s14", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 14, "text": "今陛下起丰沛，收卒三千人，以之径往而卷蜀汉，定三秦，与项羽战荥阳，争成皋之口，大战七十，小战四十，使天下之民肝脑涂地，父子暴骨中野，不可胜数，哭泣之声未绝，伤痍者未起，而欲比隆於成康之时，臣窃以为不侔也。", "len": 102}
{"sid": "099_刘敬叔孙通列传.2.s15", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 15, "text": "且夫秦地被山带河，四塞以为固，卒然有急，百万之众可具也。", "len": 28}
{"sid": "099_刘敬叔孙通列传.2.s16", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 16, "text": "因秦之故，资甚美膏腴之地，此所谓天府者也。", "len": 21}
{"sid": "099_刘敬叔孙通列传.2.s17", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 17, "text": "陛下入关而都之，山东虽乱，秦之故地可全而有也。", "len": 23}
{"sid": "099_刘敬叔孙通列传.2.s18", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 18, "text": "夫与人斗，不搤其亢，拊其背，未能全其胜也。", "len": 21}
{"sid": "099_刘敬叔孙通列传.2.s19", "chapter": "099_刘敬叔孙通列传", "para": "2", "seq": 19, "text": "今陛下入关而都，案秦之故地，此亦搤天下之亢而拊其背也。”", "len": 28}
{"sid": "099_刘敬叔孙通列传.3.s1", "chapter": "099_刘敬叔孙通列传", "para": "3", "seq": 1, "text": "高帝问群臣，群臣皆山东人，争言周王数百年，秦二世即亡，不如都周。", "len": 32}
{"sid": "099_刘敬叔孙通列传.3.s2", "chapter": "099_刘敬叔孙通列传", "para": "3", "seq": 2, "text": "上疑未能决。", "len": 6}
{"sid": "099_刘敬叔孙通列传.3.s3", "chapter": "099_刘敬叔孙通列传", "para": "3", "seq": 3, "text": "及留侯明言入关便，即日车驾西都关中。", "len": 18}
{"sid": "099_刘敬叔孙通列传.4.s1", "chapter": "099_刘敬叔孙通列传", "para": "4", "seq": 1, "text": "於是上曰：“本言都秦地者娄敬，‘娄’者乃‘刘’也。", "len": 25}
{"sid": "099_刘敬叔孙通列传.4.s2", "chapter": "099_刘敬叔孙通列传", "para": "4", "seq": 2, "text": "” 赐姓刘氏，拜为郎中，号为奉春君。", "len": 18}
{"sid": "099_刘敬叔孙通列传.5.s1", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 1, "text": "汉七年，韩王信反，高帝自往击之。", "len": 16}
{"sid": "099_刘敬叔孙通列传.5.s2", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 2, "text": "至晋阳，闻信与匈奴欲共击汉，上大怒，使人使匈奴。", "len": 24}
{"sid": "099_刘敬叔孙通列传.5.s3", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 3, "text": "匈奴匿其壮士肥牛马，但见老弱及羸畜。", "len": 18}
{"sid": "099_刘敬叔孙通列传.5.s4", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 4, "text": "使者十辈来，皆言匈奴可击。", "len": 13}
{"sid": "099_刘敬叔孙通列传.5.s5", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 5, "text": "上使刘敬复往使匈奴，还报曰：“两国相击，此宜夸矜见所长。", "len": 28}
{"sid": "099_刘敬叔孙通列传.5.s6", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 6, "text": "今臣往，徒见羸瘠老弱，此必欲见短，伏奇兵以争利。", "len": 24}
{"sid": "099_刘敬叔孙通列传.5.s7", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 7, "text": "愚以为匈奴不可击也。", "len": 10}
{"sid": "099_刘敬叔孙通列传.5.s8", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 8, "text": "” 是时汉兵已逾句注，二十馀万兵已业行。", "len": 20}
{"sid": "099_刘敬叔孙通列传.5.s9", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 9, "text": "上怒，骂刘敬曰：“齐虏！", "len": 12}
{"sid": "099_刘敬叔孙通列传.5.s10", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 10, "text": "以口舌得官，今乃妄言沮吾军。", "len": 14}
{"sid": "099_刘敬叔孙通列传.5.s11", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 11, "text": "” 械系敬广武。", "len": 8}
{"sid": "099_刘敬叔孙通列传.5.s12", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 12, "text": "遂往，至平城，匈奴果出奇兵围高帝白登，七日然後得解。", "len": 26}
{"sid": "099_刘敬叔孙通列传.5.s13", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 13, "text": "高帝至广武，赦敬，曰：“吾不用公言，以困平城。", "len": 23}
{"sid": "099_刘敬叔孙通列传.5.s14", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 14, "text": "吾皆已斩前使十辈言可击者矣。", "len": 14}
{"sid": "099_刘敬叔孙通列传.5.s15", "chapter": "099_刘敬叔孙通列传", "para": "5", "seq": 15, "text": "” 乃封敬二千户，为关内侯，号为建信侯。", "len": 20}
{"sid": "099_刘敬叔孙通列传.6.s1", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 1, "text": "高帝罢平城归，韩王信亡入胡。", "len": 14}
{"sid": "099_刘敬叔孙通列传.6.s2", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 2, "text": "当是时，冒顿为单于，兵彊，控弦三十万，数苦北边。", "len": 24}
{"sid": "099_刘敬叔孙通列传.6.s3", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 3, "text": "上患之，问刘敬。", "len": 8}
{"sid": "099_刘敬叔孙通列传.6.s4", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 4, "text": "刘敬曰：“天下初定，士卒罢於兵，未可以武服也。", "len": 23}
{"sid": "099_刘敬叔孙通列传.6.s5", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 5, "text": "冒顿杀父代立，妻群母，以力为威，未可以仁义说也。", "len": 24}
{"sid": "099_刘敬叔孙通列传.6.s6", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 6, "text": "独可以计久远子孙为臣耳，然恐陛下不能为。", "len": 20}
{"sid": "099_刘敬叔孙通列传.6.s7", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 7, "text": "” 上曰：“诚可，何为不能！", "len": 14}
{"sid": "099_刘敬叔孙通列传.6.s8", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 8, "text": "顾为柰何？", "len": 5}
{"sid": "099_刘敬叔孙通列传.6.s9", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 9, "text": "” 刘敬对曰：“陛下诚能以適长公主妻之，厚奉遗之，彼知汉適女送厚，蛮夷必慕以为阏氏，生子必为太子。", "len": 49}
{"sid": "099_刘敬叔孙通列传.6.s10", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 10, "text": "代单于。", "len": 4}
{"sid": "099_刘敬叔孙通列传.6.s11", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 11, "text": "何者？", "len": 3}
{"sid": "099_刘敬叔孙通列传.6.s12", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 12, "text": "贪汉重币。", "len": 5}
{"sid": "099_刘敬叔孙通列传.6.s13", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 13, "text": "陛下以岁时汉所馀彼所鲜数问遗，因使辩士风谕以礼节。", "len": 25}
{"sid": "099_刘敬叔孙通列传.6.s14", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 14, "text": "冒顿在，固为子婿；死，则外孙为单于。", "len": 18}
{"sid": "099_刘敬叔孙通列传.6.s15", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 15, "text": "岂尝闻外孙敢与大父抗礼者哉？", "len": 14}
{"sid": "099_刘敬叔孙通列传.6.s16", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 16, "text": "兵可无战以渐臣也。", "len": 9}
{"sid": "099_刘敬叔孙通列传.6.s17", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 17, "text": "若陛下不能遣长公主，而令宗室及後宫诈称公主，彼亦知，不肯贵近，无益也。", "len": 35}
{"sid": "099_刘敬叔孙通列传.6.s18", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 18, "text": "” 高帝曰：“善。", "len": 9}
{"sid": "099_刘敬叔孙通列传.6.s19", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 19, "text": "” 欲遣长公主。", "len": 8}
{"sid": "099_刘敬叔孙通列传.6.s20", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 20, "text": "吕后日夜泣，曰：“妾唯太子、一女，柰何弃之匈奴！", "len": 24}
{"sid": "099_刘敬叔孙通列传.6.s21", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 21, "text": "” 上竟不能遣长公主，而取家人子名为长公主，妻单于。", "len": 26}
{"sid": "099_刘敬叔孙通列传.6.s22", "chapter": "099_刘敬叔孙通列传", "para": "6", "seq": 22, "text": "使刘敬往结和亲约。", "len": 9}
{"sid": "099_刘敬叔孙通列传.7.s1", "chapter": "099_刘敬叔孙通列传", "para": "7", "seq": 1, "text": "刘敬从匈奴来，因言“匈奴河南白羊、楼烦王，去长安近者七百里，轻骑一日一夜可以至秦中。", "len": 42}
{"sid": "099_刘敬叔孙通列传.7.s2", "chapter": "099_刘敬叔孙通列传", "para": "7", "seq": 2, "text": "秦中新破，少民，地肥饶，可益实。", "len": 16}
{"sid": "099_刘敬叔孙通列传.7.s3", "chapter": "099_刘敬叔孙通列传", "para": "7", "seq": 3, "text": "夫诸侯初起时，非齐诸田，楚昭、屈、景莫能兴。", "len": 22}
{"sid": "099_刘敬叔孙通列传.7.s4", "chapter": "099_刘敬叔孙通列传", "para": "7", "seq": 4, "text": "今陛下虽都关中，实少人。", "len": 12}
{"sid": "099_刘敬叔孙通列传.7.s5", "chapter": "099_刘敬叔孙通列传", "para": "7", "seq": 5, "text": "北近胡寇，东有六国之族，宗彊，一日有变，陛下亦未得高枕而卧也。", "len": 31}
{"sid": "099_刘敬叔孙通列传.7.s6", "chapter": "099_刘敬叔孙通列传", "para": "7", "seq": 6, "text": "臣原陛下徙齐诸田，楚昭、屈、景，燕、赵、韩、魏後，及豪桀名家居关中。", "len": 34}
{"sid": "099_刘敬叔孙通列传.7.s7", "chapter": "099_刘敬叔孙通列传", "para": "7", "seq": 7, "text": "无事，可以备胡；诸侯有变，亦足率以东伐。", "len": 20}
{"sid": "099_刘敬叔孙通列传.7.s8", "chapter": "099_刘敬叔孙通列传", "para": "7", "seq": 8, "text": "此彊本弱末之术也”。", "len": 10}
{"sid": "099_刘敬叔孙通列传.7.s9", "chapter": "099_刘敬叔孙通列传", "para": "7", "seq": 9, "text": "上曰：“善。", "len": 6}
{"sid": "099_刘敬叔孙通列传.7.s10", "chapter": "099_刘敬叔孙通列传", "para": "7", "seq": 10, "text": "” 乃使刘敬徙所言关中十馀万口。", "len": 16}
{"sid": "099_刘敬叔孙通列传.8.s1", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 1, "text": "叔孙通者，薛人也。", "len": 9}
{"sid": "099_刘敬叔孙通列传.8.s2", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 2, "text": "秦时以文学徵，待诏博士。", "len": 12}
{"sid": "099_刘敬叔孙通列传.8.s3", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 3, "text": "数岁，陈胜起山东，使者以闻，二世召博士诸儒生问曰：“楚戍卒攻蕲入陈，於公如何？", "len": 39}
{"sid": "099_刘敬叔孙通列传.8.s4", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 4, "text": "” 博士诸生三十馀人前曰：“人臣无将，将即反，罪死无赦。", "len": 28}
{"sid": "099_刘敬叔孙通列传.8.s5", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 5, "text": "原陛下急发兵击之。", "len": 9}
{"sid": "099_刘敬叔孙通列传.8.s6", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 6, "text": "” 二世怒，作色。", "len": 9}
{"sid": "099_刘敬叔孙通列传.8.s7", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 7, "text": "叔孙通前曰：“诸生言皆非也。", "len": 14}
{"sid": "099_刘敬叔孙通列传.8.s8", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 8, "text": "夫天下合为一家，毁郡县城，铄其兵，示天下不复用。", "len": 24}
{"sid": "099_刘敬叔孙通列传.8.s9", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 9, "text": "且明主在其上，法令具於下，使人人奉职，四方辐輳，安敢有反者！", "len": 30}
{"sid": "099_刘敬叔孙通列传.8.s10", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 10, "text": "此特群盗鼠窃狗盗耳，何足置之齿牙间。", "len": 18}
{"sid": "099_刘敬叔孙通列传.8.s11", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 11, "text": "郡守尉今捕论，何足忧。", "len": 11}
{"sid": "099_刘敬叔孙通列传.8.s12", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 12, "text": "” 二世喜曰：“善。", "len": 10}
{"sid": "099_刘敬叔孙通列传.8.s13", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 13, "text": "” 尽问诸生，诸生或言反，或言盗。", "len": 17}
{"sid": "099_刘敬叔孙通列传.8.s14", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 14, "text": "於是二世令御史案诸生言反者下吏，非所宜言。", "len": 21}
{"sid": "099_刘敬叔孙通列传.8.s15", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 15, "text": "诸言盗者皆罢之。", "len": 8}
{"sid": "099_刘敬叔孙通列传.8.s16", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 16, "text": "乃赐叔孙通帛二十匹，衣一袭，拜为博士。", "len": 19}
{"sid": "099_刘敬叔孙通列传.8.s17", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 17, "text": "叔孙通已出宫，反舍，诸生曰：“先生何言之谀也？", "len": 23}
{"sid": "099_刘敬叔孙通列传.8.s18", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 18, "text": "” 通曰：“公不知也，我几不脱於虎口！", "len": 19}
{"sid": "099_刘敬叔孙通列传.8.s19", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 19, "text": "” 乃亡去，之薛，薛已降楚矣。", "len": 15}
{"sid": "099_刘敬叔孙通列传.8.s20", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 20, "text": "及项梁之薛，叔孙通从之。", "len": 12}
{"sid": "099_刘敬叔孙通列传.8.s21", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 21, "text": "败於定陶，从怀王。", "len": 9}
{"sid": "099_刘敬叔孙通列传.8.s22", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 22, "text": "怀王为义帝，徙长沙，叔孙通留事项王。", "len": 18}
{"sid": "099_刘敬叔孙通列传.8.s23", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 23, "text": "汉二年，汉王从五诸侯入彭城，叔孙通降汉王。", "len": 21}
{"sid": "099_刘敬叔孙通列传.8.s24", "chapter": "099_刘敬叔孙通列传", "para": "8", "seq": 24, "text": "汉王败而西，因竟从汉。", "len": 11}
{"sid": "099_刘敬叔孙通列传.9.s1", "chapter": "099_刘敬叔孙通列传", "para": "9", "seq": 1, "text": "叔孙通儒服，汉王憎之；乃变其服，服短衣，楚制，汉王喜。", "len": 27}
{"sid": "099_刘敬叔孙通列传.10.s1", "chapter": "099_刘敬叔孙通列传", "para": "10", "seq": 1, "text": "叔孙通之降汉，从儒生弟子百馀人，然通无所言进，专言诸故群盗壮士进之。", "len": 34}
{"sid": "099_刘敬叔孙通列传.10.s2", "chapter": "099_刘敬叔孙通列传", "para": "10", "seq": 2, "text": "弟子皆窃骂曰：“事先生数岁，幸得从降汉，今不能进臣等，专言大猾，何也？", "len": 35}
{"sid": "099_刘敬叔孙通列传.10.s3", "chapter": "099_刘敬叔孙通列传", "para": "10", "seq": 3, "text": "” 叔孙通闻之，乃谓曰：“汉王方蒙矢石争天下，诸生宁能斗乎？", "len": 30}
{"sid": "099_刘敬叔孙通列传.10.s4", "chapter": "099_刘敬叔孙通列传", "para": "10", "seq": 4, "text": "故先言斩将搴旗之士。", "len": 10}
{"sid": "099_刘敬叔孙通列传.10.s5", "chapter": "099_刘敬叔孙通列传", "para": "10", "seq": 5, "text": "诸生且待我，我不忘矣。", "len": 11}
{"sid": "099_刘敬叔孙通列传.10.s6", "chapter": "099_刘敬叔孙通列传", "para": "10", "seq": 6, "text": "” 汉王拜叔孙通为博士，号稷嗣君。", "len": 17}
{"sid": "099_刘敬叔孙通列传.11.s1", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 1, "text": "汉五年，已并天下，诸侯共尊汉王为皇帝於定陶，叔孙通就其仪号。", "len": 30}
{"sid": "099_刘敬叔孙通列传.11.s2", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 2, "text": "高帝悉去秦苛仪法，为简易。", "len": 13}
{"sid": "099_刘敬叔孙通列传.11.s3", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 3, "text": "群臣饮酒争功，醉或妄呼，拔剑击柱，高帝患之。", "len": 22}
{"sid": "099_刘敬叔孙通列传.11.s4", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 4, "text": "叔孙通知上益厌之也，说上曰：“夫儒者难与进取，可与守成。", "len": 28}
{"sid": "099_刘敬叔孙通列传.11.s5", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 5, "text": "臣原徵鲁诸生，与臣弟子共起朝仪。", "len": 16}
{"sid": "099_刘敬叔孙通列传.11.s6", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 6, "text": "” 高帝曰：“得无难乎？", "len": 12}
{"sid": "099_刘敬叔孙通列传.11.s7", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 7, "text": "” 叔孙通曰：“五帝异乐，三王不同礼。", "len": 19}
{"sid": "099_刘敬叔孙通列传.11.s8", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 8, "text": "礼者，因时世人情为之节文者也。", "len": 15}
{"sid": "099_刘敬叔孙通列传.11.s9", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 9, "text": "故夏、殷、周之礼所因损益可知者，谓不相复也。", "len": 22}
{"sid": "099_刘敬叔孙通列传.11.s10", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 10, "text": "臣原颇采古礼与秦仪杂就之。", "len": 13}
{"sid": "099_刘敬叔孙通列传.11.s11", "chapter": "099_刘敬叔孙通列传", "para": "11", "seq": 11, "text": "” 上曰：“可试为之，令易知，度吾所能行为之。”", "len": 24}
{"sid": "099_刘敬叔孙通列传.12.s1", "chapter": "099_刘敬叔孙通列传", "para": "12", "seq": 1, "text": "於是叔孙通使徵鲁诸生三十馀人。", "len": 15}
{"sid": "099_刘敬叔孙通列传.12.s2", "chapter": "099_刘敬叔孙通列传", "para": "12", "seq": 2, "text": "鲁有两生不肯行，曰：“公所事者且十主，皆面谀以得亲贵。", "len": 27}
{"sid": "099_刘敬叔孙通列传.12.s3", "chapter": "099_刘敬叔孙通列传", "para": "12", "seq": 3, "text": "今天下初定，死者未葬，伤者未起，又欲起礼乐。", "len": 22}
{"sid": "099_刘敬叔孙通列传.12.s4", "chapter": "099_刘敬叔孙通列传", "para": "12", "seq": 4, "text": "礼乐所由起，积德百年而後可兴也。", "len": 16}
{"sid": "099_刘敬叔孙通列传.12.s5", "chapter": "099_刘敬叔孙通列传", "para": "12", "seq": 5, "text": "吾不忍为公所为。", "len": 8}
{"sid": "099_刘敬叔孙通列传.12.s6", "chapter": "099_刘敬叔孙通列传", "para": "12", "seq": 6, "text": "公所为不合古，吾不行。", "len": 11}
{"sid": "099_刘敬叔孙通列传.12.s7", "chapter": "099_刘敬叔孙通列传", "para": "12", "seq": 7, "text": "公往矣，无汙我！", "len": 8}
{"sid": "099_刘敬叔孙通列传.12.s8", "chapter": "099_刘敬叔孙通列传", "para": "12", "seq": 8, "text": "” 叔孙通笑曰：“若真鄙儒也，不知时变。”", "len": 21}
{"sid": "099_刘敬叔孙通列传.13.s1", "chapter": "099_刘敬叔孙通列传", "para": "13", "seq": 1, "text": "遂与所徵三十人西，及上左右为学者与其弟子百馀人为绵蕞野外。", "len": 29}
{"sid": "099_刘敬叔孙通列传.13.s2", "chapter": "099_刘敬叔孙通列传", "para": "13", "seq": 2, "text": "习之月馀，叔孙通曰：“上可试观。", "len": 16}
{"sid": "099_刘敬叔孙通列传.13.s3", "chapter": "099_刘敬叔孙通列传", "para": "13", "seq": 3, "text": "” 上既观，使行礼，曰：“吾能为此。", "len": 18}
{"sid": "099_刘敬叔孙通列传.13.s4", "chapter": "099_刘敬叔孙通列传", "para": "13", "seq": 4, "text": "” 乃令群臣习肄，会十月。", "len": 13}
{"sid": "099_刘敬叔孙通列传.14.s1", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 1, "text": "汉七年，长乐宫成，诸侯群臣皆朝十月。", "len": 18}
{"sid": "099_刘敬叔孙通列传.14.s2", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 2, "text": "仪：先平明，谒者治礼，引以次入殿门，廷中陈车骑步卒卫宫，设兵张旗志。", "len": 34}
{"sid": "099_刘敬叔孙通列传.14.s3", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 3, "text": "传言“趋”。", "len": 6}
{"sid": "099_刘敬叔孙通列传.14.s4", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 4, "text": "殿下郎中侠陛，陛数百人。", "len": 12}
{"sid": "099_刘敬叔孙通列传.14.s5", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 5, "text": "功臣列侯诸将军军吏以次陈西方，东乡；文官丞相以下陈东方，西乡。", "len": 31}
{"sid": "099_刘敬叔孙通列传.14.s6", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 6, "text": "大行设九宾，胪传。", "len": 9}
{"sid": "099_刘敬叔孙通列传.14.s7", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 7, "text": "於是皇帝辇出房，百官执职传警，引诸侯王以下至吏六百石以次奉贺。", "len": 31}
{"sid": "099_刘敬叔孙通列传.14.s8", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 8, "text": "自诸侯王以下莫不振恐肃敬。", "len": 13}
{"sid": "099_刘敬叔孙通列传.14.s9", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 9, "text": "至礼毕，复置法酒。", "len": 9}
{"sid": "099_刘敬叔孙通列传.14.s10", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 10, "text": "诸侍坐殿上皆伏抑首，以尊卑次起上寿。", "len": 18}
{"sid": "099_刘敬叔孙通列传.14.s11", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 11, "text": "觞九行，谒者言“罢酒”。", "len": 12}
{"sid": "099_刘敬叔孙通列传.14.s12", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 12, "text": "御史执法举不如仪者辄引去。", "len": 13}
{"sid": "099_刘敬叔孙通列传.14.s13", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 13, "text": "竟朝置酒，无敢讙譁失礼者。", "len": 13}
{"sid": "099_刘敬叔孙通列传.14.s14", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 14, "text": "於是高帝曰：“吾乃今日知为皇帝之贵也。", "len": 19}
{"sid": "099_刘敬叔孙通列传.14.s15", "chapter": "099_刘敬叔孙通列传", "para": "14", "seq": 15, "text": "” 乃拜叔孙通为太常，赐金五百斤。", "len": 17}
{"sid": "099_刘敬叔孙通列传.15.s1", "chapter": "099_刘敬叔孙通列传", "para": "15", "seq": 1, "text": "叔孙通因进曰：“诸弟子儒生随臣久矣，与臣共为仪，原陛下官之。", "len": 30}
{"sid": "099_刘敬叔孙通列传.15.s2", "chapter": "099_刘敬叔孙通列传", "para": "15", "seq": 2, "text": "” 高帝悉以为郎。", "len": 9}
{"sid": "099_刘敬叔孙通列传.15.s3", "chapter": "099_刘敬叔孙通列传", "para": "15", "seq": 3, "text": "叔孙通出，皆以五百斤金赐诸生。", "len": 15}
{"sid": "099_刘敬叔孙通列传.15.s4", "chapter": "099_刘敬叔孙通列传", "para": "15", "seq": 4, "text": "诸生乃皆喜曰：“叔孙生诚圣人也，知当世之要务。”", "len": 24}
{"sid": "099_刘敬叔孙通列传.16.s1", "chapter": "099_刘敬叔孙通列传", "para": "16", "seq": 1, "text": "汉九年，高帝徙叔孙通为太子太傅。", "len": 16}
{"sid": "099_刘敬叔孙通列传.16.s2", "chapter": "099_刘敬叔孙通列传", "para": "16", "seq": 2, "text": "汉十二年，高祖欲以赵王如意易太子，叔孙通谏上曰：“昔者晋献公以骊姬之故废太子，立奚齐，晋国乱者数十年，为天下笑。", "len": 56}
{"sid": "099_刘敬叔孙通列传.16.s3", "chapter": "099_刘敬叔孙通列传", "para": "16", "seq": 3, "text": "秦以不蚤定扶苏，令赵高得以诈立胡亥，自使灭祀，此陛下所亲见。", "len": 30}
{"sid": "099_刘敬叔孙通列传.16.s4", "chapter": "099_刘敬叔孙通列传", "para": "16", "seq": 4, "text": "今太子仁孝，天下皆闻之；吕后与陛下攻苦食啖，其可背哉！", "len": 27}
{"sid": "099_刘敬叔孙通列传.16.s5", "chapter": "099_刘敬叔孙通列传", "para": "16", "seq": 5, "text": "陛下必欲废適而立少，臣原先伏诛，以颈血汙地。", "len": 22}
{"sid": "099_刘敬叔孙通列传.16.s6", "chapter": "099_刘敬叔孙通列传", "para": "16", "seq": 6, "text": "” 高帝曰：“公罢矣，吾直戏耳。", "len": 16}
{"sid": "099_刘敬叔孙通列传.16.s7", "chapter": "099_刘敬叔孙通列传", "para": "16", "seq": 7, "text": "” 叔孙通曰：“太子天下本，本一摇天下振动，柰何以天下为戏！", "len": 30}
{"sid": "099_刘敬叔孙通列传.16.s8", "chapter": "099_刘敬叔孙通列传", "para": "16", "seq": 8, "text": "” 高帝曰：“吾听公言。", "len": 12}
{"sid": "099_刘敬叔孙通列传.16.s9", "chapter": "099_刘敬叔孙通列传", "para": "16", "seq": 9, "text": "” 及上置酒，见留侯所招客从太子入见，上乃遂无易太子志矣。", "len": 29}
{"sid": "099_刘敬叔孙通列传.17.s1", "chapter": "099_刘敬叔孙通列传", "para": "17", "seq": 1, "text": "高帝崩，孝惠即位，乃谓叔孙生曰：“先帝园陵寝庙，群臣莫习。", "len": 29}
{"sid": "099_刘敬叔孙通列传.17.s2", "chapter": "099_刘敬叔孙通列传", "para": "17", "seq": 2, "text": "” 徙为太常，定宗庙仪法。", "len": 13}
{"sid": "099_刘敬叔孙通列传.17.s3", "chapter": "099_刘敬叔孙通列传", "para": "17", "seq": 3, "text": "及稍定汉诸仪法，皆叔孙生为太常所论箸也。", "len": 20}
{"sid": "099_刘敬叔孙通列传.18.s1", "chapter": "099_刘敬叔孙通列传", "para": "18", "seq": 1, "text": "孝惠帝为东朝长乐宫，及间往，数跸烦人，乃作複道，方筑武库南。", "len": 30}
{"sid": "099_刘敬叔孙通列传.18.s2", "chapter": "099_刘敬叔孙通列传", "para": "18", "seq": 2, "text": "叔孙生奏事，因请间曰：“陛下何自筑複道高寝，衣冠月出游高庙？", "len": 30}
{"sid": "099_刘敬叔孙通列传.18.s3", "chapter": "099_刘敬叔孙通列传", "para": "18", "seq": 3, "text": "高庙，汉太祖，柰何令後世子孙乘宗庙道上行哉？", "len": 22}
{"sid": "099_刘敬叔孙通列传.18.s4", "chapter": "099_刘敬叔孙通列传", "para": "18", "seq": 4, "text": "” 孝惠帝大惧，曰：“急坏之。", "len": 15}
{"sid": "099_刘敬叔孙通列传.18.s5", "chapter": "099_刘敬叔孙通列传", "para": "18", "seq": 5, "text": "” 叔孙生曰：“人主无过举。", "len": 14}
{"sid": "099_刘敬叔孙通列传.18.s6", "chapter": "099_刘敬叔孙通列传", "para": "18", "seq": 6, "text": "今已作，百姓皆知之，今坏此，则示有过举。", "len": 20}
{"sid": "099_刘敬叔孙通列传.18.s7", "chapter": "099_刘敬叔孙通列传", "para": "18", "seq": 7, "text": "原陛下原庙渭北，衣冠月出游之，益广多宗庙，大孝之本也。", "len": 27}
{"sid": "099_刘敬叔孙通列传.18.s8", "chapter": "099_刘敬叔孙通列传", "para": "18", "seq": 8, "text": "” 上乃诏有司立原庙。", "len": 11}
{"sid": "099_刘敬叔孙通列传.18.s9", "chapter": "099_刘敬叔孙通列传", "para": "18", "seq": 9, "text": "原庙起，以複道故。", "len": 9}
{"sid": "099_刘敬叔孙通列传.19.s1", "chapter": "099_刘敬叔孙通列传", "para": "19", "seq": 1, "text": "孝惠帝曾春出游离宫，叔孙生曰：“古者有春尝果，方今樱桃孰，可献，原陛下出，因取樱桃献宗庙。", "len": 45}
{"sid": "099_刘敬叔孙通列传.19.s2", "chapter": "099_刘敬叔孙通列传", "para": "19", "seq": 2, "text": "” 上乃许之。", "len": 7}
{"sid": "099_刘敬叔孙通列传.19.s3", "chapter": "099_刘敬叔孙通列传", "para": "19", "seq": 3, "text": "诸果献由此兴。", "len": 7}
{"sid": "099_刘敬叔孙通列传.19.s4", "chapter": "099_刘敬叔孙通列传", "para": "19", "seq": 4, "text": "::: 太史公曰", "len": 8}
{"sid": "099_刘敬叔孙通列传.20.s1", "chapter": "099_刘敬叔孙通列传", "para": "20", "seq": 1, "text": "太史公曰：语曰“千金之裘，非一狐之腋也；台榭之榱，非一木之枝也；三代之际，非一士之智也”。", "len": 45}
{"sid": "099_刘敬叔孙通列传.20.s2", "chapter": "099_刘敬叔孙通列传", "para": "20", "seq": 2, "text": "信哉！", "len": 3}
{"sid": "099_刘敬叔孙通列传.20.s3", "chapter": "099_刘敬叔孙通列传", "para": "20", "seq": 3, "text": "夫高祖起微细，定海内，谋计用兵，可谓尽之矣。", "len": 22}
{"sid": "099_刘敬叔孙通列传.20.s4", "chapter": "099_刘敬叔孙通列传", "para": "20", "seq": 4, "text": "然而刘敬脱輓辂一说，建万世之安，智岂可专邪！", "len": 22}
{"sid": "099_刘敬叔孙通列传.20.s5", "chapter": "099_刘敬叔孙通列传", "para": "20", "seq": 5, "text": "叔孙通希世度务，制礼进退，与时变化，卒为汉家儒宗。", "len": 25}
{"sid": "099_刘敬叔孙通列传.20.s6", "chapter": "099_刘敬叔孙通列传", "para": "20", "seq": 6, "text": "“大直若诎，道固委蛇”，盖谓是乎？", "len": 17}
{"sid": "099_刘敬叔孙通列传.20.s7", "chapter": "099_刘敬叔孙通列传", "para": "20", "seq": 7, "text": "::: ::: 赞", "len": 9}
{"sid": "099_刘敬叔孙通列传.21.s1", "chapter": "099_刘敬叔孙通列传", "para": "21", "seq": 1, "text": "厦藉众幹，裘非一狐。", "len": 10}
{"sid": "099_刘敬叔孙通列传.21.s2", "chapter": "099_刘敬叔孙通列传", "para": "21", "seq": 2, "text": "委辂献说，釂蕝陈书。", "len": 10}
{"sid": "099_刘敬叔孙通列传.21.s3", "chapter": "099_刘敬叔孙通列传", "para": "21", "seq": 3, "text": "皇帝始贵，车驾西都。", "len": 10}
{"sid": "099_刘敬叔孙通列传.21.s4", "chapter": "099_刘敬叔孙通列传", "para": "21", "seq": 4, "text": "既安太子，又和匈奴。", "len": 10}
{"sid": "099_刘敬叔孙通列传.21.s5", "chapter": "099_刘敬叔孙通列传", "para": "21", "seq": 5, "text": "奉春、稷嗣，其功可图。", "len": 11}
{"sid": "099_刘敬叔孙通列传.21.s6", "chapter": "099_刘敬叔孙通列传", "para": "21", "seq": 6, "text": ":::", "len": 3}
