{"sid": "121_儒林列传.1.s1", "chapter": "121_儒林列传", "para": "1", "seq": 1, "text": "太史公曰：余读功令，至於广厉学官之路，未尝不废书而叹也。", "len": 28}
{"sid": "121_儒林列传.1.s2", "chapter": "121_儒林列传", "para": "1", "seq": 2, "text": "曰：嗟乎！", "len": 5}
{"sid": "121_儒林列传.1.s3", "chapter": "121_儒林列传", "para": "1", "seq": 3, "text": "夫周室衰而关雎作，幽厉微而礼乐坏，诸侯恣行，政由彊国。", "len": 27}
{"sid": "121_儒林列传.1.s4", "chapter": "121_儒林列传", "para": "1", "seq": 4, "text": "故孔子闵王路废而邪道兴，於是论次诗书，修起礼乐。", "len": 24}
{"sid": "121_儒林列传.1.s5", "chapter": "121_儒林列传", "para": "1", "seq": 5, "text": "適齐闻韶，三月不知肉味。", "len": 12}
{"sid": "121_儒林列传.1.s6", "chapter": "121_儒林列传", "para": "1", "seq": 6, "text": "自卫返鲁，然後乐正，雅颂各得其所。", "len": 17}
{"sid": "121_儒林列传.1.s7", "chapter": "121_儒林列传", "para": "1", "seq": 7, "text": "世以混浊莫能用，是以仲尼干七十馀君无所遇，曰“苟有用我者，期月而已矣”。", "len": 36}
{"sid": "121_儒林列传.1.s8", "chapter": "121_儒林列传", "para": "1", "seq": 8, "text": "西狩获麟，曰“吾道穷矣”。", "len": 13}
{"sid": "121_儒林列传.1.s9", "chapter": "121_儒林列传", "para": "1", "seq": 9, "text": "故因史记作春秋，以当王法，其辞微而指博，後世学者多录焉。", "len": 28}
{"sid": "121_儒林列传.2.s1", "chapter": "121_儒林列传", "para": "2", "seq": 1, "text": "自孔子卒後，七十子之徒散游诸侯，大者为师傅卿相，小者友教士大夫，或隐而不见。", "len": 38}
{"sid": "121_儒林列传.2.s2", "chapter": "121_儒林列传", "para": "2", "seq": 2, "text": "故子路居卫，子张居陈，澹台子羽居楚，子夏居西河，子贡终於齐。", "len": 30}
{"sid": "121_儒林列传.2.s3", "chapter": "121_儒林列传", "para": "2", "seq": 3, "text": "如田子方、段干木、吴起、禽滑釐之属，皆受业於子夏之伦，为王者师。", "len": 32}
{"sid": "121_儒林列传.2.s4", "chapter": "121_儒林列传", "para": "2", "seq": 4, "text": "是时独魏文侯好学。", "len": 9}
{"sid": "121_儒林列传.2.s5", "chapter": "121_儒林列传", "para": "2", "seq": 5, "text": "後陵迟以至于始皇，天下并争於战国，懦术既绌焉，然齐鲁之间，学者独不废也。", "len": 36}
{"sid": "121_儒林列传.2.s6", "chapter": "121_儒林列传", "para": "2", "seq": 6, "text": "於威、宣之际，孟子、荀卿之列，咸遵夫子之业而润色之，以学显於当世。", "len": 33}
{"sid": "121_儒林列传.3.s1", "chapter": "121_儒林列传", "para": "3", "seq": 1, "text": "及至秦之季世，焚诗书，阬术士，六从此缺焉。", "len": 21}
{"sid": "121_儒林列传.3.s2", "chapter": "121_儒林列传", "para": "3", "seq": 2, "text": "陈涉之王也，而鲁诸儒持孔氏之礼器往归陈王。", "len": 21}
{"sid": "121_儒林列传.3.s3", "chapter": "121_儒林列传", "para": "3", "seq": 3, "text": "於是孔甲为陈涉博士，卒与涉俱死。", "len": 16}
{"sid": "121_儒林列传.3.s4", "chapter": "121_儒林列传", "para": "3", "seq": 4, "text": "陈涉起匹夫，驱瓦合適戍，旬月以王楚，不满半岁竟灭亡，其事至微浅，然而缙绅先生之徒负孔子礼器往委质为臣者，何也？", "len": 55}
{"sid": "121_儒林列传.3.s5", "chapter": "121_儒林列传", "para": "3", "seq": 5, "text": "以秦焚其业，积怨而发愤于陈王也。", "len": 16}
{"sid": "121_儒林列传.4.s1", "chapter": "121_儒林列传", "para": "4", "seq": 1, "text": "及高皇帝诛项籍，举兵围鲁，鲁中诸儒尚讲诵习礼乐，弦歌之音不绝，岂非圣人之遗化，好礼乐之国哉？", "len": 46}
{"sid": "121_儒林列传.4.s2", "chapter": "121_儒林列传", "para": "4", "seq": 2, "text": "故孔子在陈，曰“归与归与！", "len": 13}
{"sid": "121_儒林列传.4.s3", "chapter": "121_儒林列传", "para": "4", "seq": 3, "text": "吾党之小子狂简，斐然成章，不知所以裁之”。", "len": 21}
{"sid": "121_儒林列传.4.s4", "chapter": "121_儒林列传", "para": "4", "seq": 4, "text": "夫齐鲁之间於文学，自古以来，其天性也。", "len": 19}
{"sid": "121_儒林列传.4.s5", "chapter": "121_儒林列传", "para": "4", "seq": 5, "text": "故汉兴，然後诸儒始得脩其经，讲习大射乡饮之礼。", "len": 23}
{"sid": "121_儒林列传.4.s6", "chapter": "121_儒林列传", "para": "4", "seq": 6, "text": "叔孙通作汉礼仪，因为太常，诸生弟子共定者，咸为选首，於是喟然叹兴於学。", "len": 35}
{"sid": "121_儒林列传.4.s7", "chapter": "121_儒林列传", "para": "4", "seq": 7, "text": "然尚有干戈，平定四海，亦未暇遑庠序之事也。", "len": 21}
{"sid": "121_儒林列传.4.s8", "chapter": "121_儒林列传", "para": "4", "seq": 8, "text": "孝惠、吕后时，公卿皆武力有功之臣。", "len": 17}
{"sid": "121_儒林列传.4.s9", "chapter": "121_儒林列传", "para": "4", "seq": 9, "text": "孝文时颇徵用，然孝文帝本好刑名之言。", "len": 18}
{"sid": "121_儒林列传.4.s10", "chapter": "121_儒林列传", "para": "4", "seq": 10, "text": "及至孝景，不任儒者，而窦太后又好黄老之术，故诸博士具官待问，未有进者。", "len": 35}
{"sid": "121_儒林列传.5.s1", "chapter": "121_儒林列传", "para": "5", "seq": 1, "text": "及今上即位，赵绾、王臧之属明儒学，而上亦乡之，於是招方正贤良文学之士。", "len": 35}
{"sid": "121_儒林列传.5.s2", "chapter": "121_儒林列传", "para": "5", "seq": 2, "text": "自是之後，言诗於鲁则申培公，於齐则辕固生，於燕则韩太傅。", "len": 28}
{"sid": "121_儒林列传.5.s3", "chapter": "121_儒林列传", "para": "5", "seq": 3, "text": "言尚书自济南伏生。", "len": 9}
{"sid": "121_儒林列传.5.s4", "chapter": "121_儒林列传", "para": "5", "seq": 4, "text": "言礼自鲁高堂生。", "len": 8}
{"sid": "121_儒林列传.5.s5", "chapter": "121_儒林列传", "para": "5", "seq": 5, "text": "言易自菑川田生。", "len": 8}
{"sid": "121_儒林列传.5.s6", "chapter": "121_儒林列传", "para": "5", "seq": 6, "text": "言春秋於齐鲁自胡毋生，於赵自董仲舒。", "len": 18}
{"sid": "121_儒林列传.5.s7", "chapter": "121_儒林列传", "para": "5", "seq": 7, "text": "及窦太后崩，武安侯田蚡为丞相，绌黄老、刑名百家之言，延文学儒者数百人，而公孙弘以春秋白衣为天子三公，封以平津侯。", "len": 56}
{"sid": "121_儒林列传.5.s8", "chapter": "121_儒林列传", "para": "5", "seq": 8, "text": "天下之学士靡然乡风矣。", "len": 11}
{"sid": "121_儒林列传.6.s1", "chapter": "121_儒林列传", "para": "6", "seq": 1, "text": "公孙弘为学官，悼道之郁滞，乃请曰：“丞相御史言：制曰‘盖闻导民以礼，风之以乐。", "len": 39}
{"sid": "121_儒林列传.6.s2", "chapter": "121_儒林列传", "para": "6", "seq": 2, "text": "婚姻者，居屋之大伦也。", "len": 11}
{"sid": "121_儒林列传.6.s3", "chapter": "121_儒林列传", "para": "6", "seq": 3, "text": "今礼废乐崩，朕甚愍焉。", "len": 11}
{"sid": "121_儒林列传.6.s4", "chapter": "121_儒林列传", "para": "6", "seq": 4, "text": "故详延天下方正博闻之士，咸登诸朝。", "len": 17}
{"sid": "121_儒林列传.6.s5", "chapter": "121_儒林列传", "para": "6", "seq": 5, "text": "其令礼官劝学，讲议洽闻兴礼，以为天下先。", "len": 20}
{"sid": "121_儒林列传.6.s6", "chapter": "121_儒林列传", "para": "6", "seq": 6, "text": "太常议，与博士弟子，崇乡里之化，以广贤材焉’。", "len": 23}
{"sid": "121_儒林列传.7.s1", "chapter": "121_儒林列传", "para": "7", "seq": 1, "text": "谨与太常臧、博士平等议曰：闻三代之道，乡里有教，夏曰校，殷曰序，周曰庠。", "len": 36}
{"sid": "121_儒林列传.7.s2", "chapter": "121_儒林列传", "para": "7", "seq": 2, "text": "其劝善也，显之朝廷；其惩恶也，加之刑罚。", "len": 20}
{"sid": "121_儒林列传.7.s3", "chapter": "121_儒林列传", "para": "7", "seq": 3, "text": "故教化之行也，建首善自京师始，由内及外。", "len": 20}
{"sid": "121_儒林列传.7.s4", "chapter": "121_儒林列传", "para": "7", "seq": 4, "text": "今陛下昭至德，开大明，配天地，本人伦，劝学脩礼，崇化厉贤，以风四方，太平之原也。", "len": 40}
{"sid": "121_儒林列传.7.s5", "chapter": "121_儒林列传", "para": "7", "seq": 5, "text": "古者政教未洽，不备其礼，请因旧官而兴焉。", "len": 20}
{"sid": "121_儒林列传.7.s6", "chapter": "121_儒林列传", "para": "7", "seq": 6, "text": "为博士官置弟子五十人，复其身。", "len": 15}
{"sid": "121_儒林列传.7.s7", "chapter": "121_儒林列传", "para": "7", "seq": 7, "text": "太常择民年十八已上，仪状端正者，补博士弟子。", "len": 22}
{"sid": "121_儒林列传.7.s8", "chapter": "121_儒林列传", "para": "7", "seq": 8, "text": "郡国县道邑有好文学，敬长上，肃政教，顺乡里，出入不悖所闻者，令相长丞上属所二千石，二千石谨察可者，当与计偕，诣太常，得受业如弟子。", "len": 65}
{"sid": "121_儒林列传.7.s9", "chapter": "121_儒林列传", "para": "7", "seq": 9, "text": "一岁皆辄试，能通一以上，补文学掌故缺；其高弟可以为郎中者，太常籍奏。", "len": 34}
{"sid": "121_儒林列传.7.s10", "chapter": "121_儒林列传", "para": "7", "seq": 10, "text": "即有秀才异等，辄以名闻。", "len": 12}
{"sid": "121_儒林列传.7.s11", "chapter": "121_儒林列传", "para": "7", "seq": 11, "text": "其不事学若下材及不能通一，辄罢之，而请诸不称者罚。", "len": 25}
{"sid": "121_儒林列传.7.s12", "chapter": "121_儒林列传", "para": "7", "seq": 12, "text": "臣谨案诏书律令下者，明天人分际，通古今之义，文章尔雅，训辞深厚，恩施甚美。", "len": 37}
{"sid": "121_儒林列传.7.s13", "chapter": "121_儒林列传", "para": "7", "seq": 13, "text": "小吏浅闻，不能究宣，无以明布谕下。", "len": 17}
{"sid": "121_儒林列传.7.s14", "chapter": "121_儒林列传", "para": "7", "seq": 14, "text": "治礼次治掌故，以文学礼义为官，迁留滞。", "len": 19}
{"sid": "121_儒林列传.7.s15", "chapter": "121_儒林列传", "para": "7", "seq": 15, "text": "请选择其秩比二百石以上，及吏百石通一以上，补左右内史、大行卒史；比百石已下，补郡太守卒史：皆各二人，边郡一人。", "len": 55}
{"sid": "121_儒林列传.7.s16", "chapter": "121_儒林列传", "para": "7", "seq": 16, "text": "先用诵多者，若不足，乃择掌故补中二千石属，文学掌故补郡属，备员。", "len": 32}
{"sid": "121_儒林列传.7.s17", "chapter": "121_儒林列传", "para": "7", "seq": 17, "text": "请著功令。", "len": 5}
{"sid": "121_儒林列传.7.s18", "chapter": "121_儒林列传", "para": "7", "seq": 18, "text": "佗如律令。", "len": 5}
{"sid": "121_儒林列传.7.s19", "chapter": "121_儒林列传", "para": "7", "seq": 19, "text": "“制曰：“可。", "len": 7}
{"sid": "121_儒林列传.7.s20", "chapter": "121_儒林列传", "para": "7", "seq": 20, "text": "“自此以来，则公卿大夫士吏斌斌多文学之士矣。", "len": 22}
{"sid": "121_儒林列传.8.s1", "chapter": "121_儒林列传", "para": "8", "seq": 1, "text": "申公者，鲁人也。", "len": 8}
{"sid": "121_儒林列传.8.s2", "chapter": "121_儒林列传", "para": "8", "seq": 2, "text": "高祖过鲁，申公以弟子从师入见高祖于鲁南宫。", "len": 21}
{"sid": "121_儒林列传.8.s3", "chapter": "121_儒林列传", "para": "8", "seq": 3, "text": "吕太后时，申公游学长安，与刘郢同师。", "len": 18}
{"sid": "121_儒林列传.8.s4", "chapter": "121_儒林列传", "para": "8", "seq": 4, "text": "已而郢为楚王，令申公傅其太子戊。", "len": 16}
{"sid": "121_儒林列传.8.s5", "chapter": "121_儒林列传", "para": "8", "seq": 5, "text": "戊不好学，疾申公。", "len": 9}
{"sid": "121_儒林列传.8.s6", "chapter": "121_儒林列传", "para": "8", "seq": 6, "text": "及王郢卒，戊立为楚王，胥靡申公。", "len": 16}
{"sid": "121_儒林列传.8.s7", "chapter": "121_儒林列传", "para": "8", "seq": 7, "text": "申公耻之，归鲁，退居家教，终身不出门，复谢绝宾客，独王命召之乃往。", "len": 33}
{"sid": "121_儒林列传.8.s8", "chapter": "121_儒林列传", "para": "8", "seq": 8, "text": "弟子自远方至受业者百馀人。", "len": 13}
{"sid": "121_儒林列传.8.s9", "chapter": "121_儒林列传", "para": "8", "seq": 9, "text": "申公独以诗经为训以教，无传，疑者则阙不传。", "len": 21}
{"sid": "121_儒林列传.9.s1", "chapter": "121_儒林列传", "para": "9", "seq": 1, "text": "兰陵王臧既受诗，以事孝景帝为太子少傅，免去。", "len": 22}
{"sid": "121_儒林列传.9.s2", "chapter": "121_儒林列传", "para": "9", "seq": 2, "text": "今上初即位，臧乃上书宿卫上，累迁，一岁中为郎中令。", "len": 25}
{"sid": "121_儒林列传.9.s3", "chapter": "121_儒林列传", "para": "9", "seq": 3, "text": "及代赵绾亦尝受诗申公，绾为御史大夫。", "len": 18}
{"sid": "121_儒林列传.9.s4", "chapter": "121_儒林列传", "para": "9", "seq": 4, "text": "绾、臧请天子，欲立明堂以朝诸侯，不能就其事，乃言师申公。", "len": 28}
{"sid": "121_儒林列传.9.s5", "chapter": "121_儒林列传", "para": "9", "seq": 5, "text": "於是天子使使束帛加璧安车驷马迎申公，弟子二人乘轺传从。", "len": 27}
{"sid": "121_儒林列传.9.s6", "chapter": "121_儒林列传", "para": "9", "seq": 6, "text": "至，见天子。", "len": 6}
{"sid": "121_儒林列传.9.s7", "chapter": "121_儒林列传", "para": "9", "seq": 7, "text": "天子问治乱之事，申公时已八十馀，老，对曰：“为治者不在多言，顾力行何如耳。", "len": 37}
{"sid": "121_儒林列传.9.s8", "chapter": "121_儒林列传", "para": "9", "seq": 8, "text": "” 是时天子方好文词，见申公对，默然。", "len": 19}
{"sid": "121_儒林列传.9.s9", "chapter": "121_儒林列传", "para": "9", "seq": 9, "text": "然已招致，则以为太中大夫，舍鲁邸，议明堂事。", "len": 22}
{"sid": "121_儒林列传.9.s10", "chapter": "121_儒林列传", "para": "9", "seq": 10, "text": "太皇窦太后好老子言，不说儒术，得赵绾、王臧之过以让上，上因废明堂事，尽下赵绾、王臧吏，後皆自杀。", "len": 48}
{"sid": "121_儒林列传.9.s11", "chapter": "121_儒林列传", "para": "9", "seq": 11, "text": "申公亦疾免以归，数年卒。", "len": 12}
{"sid": "121_儒林列传.10.s1", "chapter": "121_儒林列传", "para": "10", "seq": 1, "text": "弟子为博士者十馀人：孔安国至临淮太守，周霸至胶西内史，夏宽至城阳内史，砀鲁赐至东海太守，兰陵缪生至长沙内史，徐偃为胶西中尉，邹人阙门庆忌为胶东内史。", "len": 74}
{"sid": "121_儒林列传.10.s2", "chapter": "121_儒林列传", "para": "10", "seq": 2, "text": "其治官民皆有廉节，称其好学。", "len": 14}
{"sid": "121_儒林列传.10.s3", "chapter": "121_儒林列传", "para": "10", "seq": 3, "text": "学官弟子行虽不备，而至於大夫、郎中、掌故以百数。", "len": 24}
{"sid": "121_儒林列传.10.s4", "chapter": "121_儒林列传", "para": "10", "seq": 4, "text": "言诗虽殊，多本於申公。", "len": 11}
{"sid": "121_儒林列传.11.s1", "chapter": "121_儒林列传", "para": "11", "seq": 1, "text": "清河王太傅辕固生者，齐人也。", "len": 14}
{"sid": "121_儒林列传.11.s2", "chapter": "121_儒林列传", "para": "11", "seq": 2, "text": "以治诗，孝景时为博士。", "len": 11}
{"sid": "121_儒林列传.11.s3", "chapter": "121_儒林列传", "para": "11", "seq": 3, "text": "与黄生争论景帝前。", "len": 9}
{"sid": "121_儒林列传.11.s4", "chapter": "121_儒林列传", "para": "11", "seq": 4, "text": "黄生曰：“汤武非受命，乃弑也。", "len": 15}
{"sid": "121_儒林列传.11.s5", "chapter": "121_儒林列传", "para": "11", "seq": 5, "text": "” 辕固生曰：“不然。", "len": 11}
{"sid": "121_儒林列传.11.s6", "chapter": "121_儒林列传", "para": "11", "seq": 6, "text": "夫桀纣虐乱，天下之心皆归汤武，汤武与天下之心而诛桀纣，桀纣之民不为之使而归汤武，汤武不得已而立，非受命为何？", "len": 54}
{"sid": "121_儒林列传.11.s7", "chapter": "121_儒林列传", "para": "11", "seq": 7, "text": "” 黄生曰：“冠虽敝，必加於首；履虽新，必关於足。", "len": 25}
{"sid": "121_儒林列传.11.s8", "chapter": "121_儒林列传", "para": "11", "seq": 8, "text": "何者，上下之分也。", "len": 9}
{"sid": "121_儒林列传.11.s9", "chapter": "121_儒林列传", "para": "11", "seq": 9, "text": "今桀纣虽失道，然君上也；汤武虽圣，臣下也。", "len": 21}
{"sid": "121_儒林列传.11.s10", "chapter": "121_儒林列传", "para": "11", "seq": 10, "text": "夫主有失行，臣下不能正言匡过以尊天子，反因过而诛之，代立践南面，非弑而何也？", "len": 38}
{"sid": "121_儒林列传.11.s11", "chapter": "121_儒林列传", "para": "11", "seq": 11, "text": "” 辕固生曰：“必若所云，是高帝代秦即天子之位，非邪？", "len": 27}
{"sid": "121_儒林列传.11.s12", "chapter": "121_儒林列传", "para": "11", "seq": 12, "text": "” 於是景帝曰：“食肉不食马肝，不为不知味；言学者无言汤武受命，不为愚。", "len": 36}
{"sid": "121_儒林列传.11.s13", "chapter": "121_儒林列传", "para": "11", "seq": 13, "text": "” 遂罢。", "len": 5}
{"sid": "121_儒林列传.11.s14", "chapter": "121_儒林列传", "para": "11", "seq": 14, "text": "是後学者莫敢明受命放杀者。", "len": 13}
{"sid": "121_儒林列传.12.s1", "chapter": "121_儒林列传", "para": "12", "seq": 1, "text": "窦太后好老子书，召辕固生问老子书。", "len": 17}
{"sid": "121_儒林列传.12.s2", "chapter": "121_儒林列传", "para": "12", "seq": 2, "text": "固曰：“此是家人言耳。", "len": 11}
{"sid": "121_儒林列传.12.s3", "chapter": "121_儒林列传", "para": "12", "seq": 3, "text": "” 太后怒曰：“安得司空城旦书乎？", "len": 17}
{"sid": "121_儒林列传.12.s4", "chapter": "121_儒林列传", "para": "12", "seq": 4, "text": "” 乃使固入圈刺豕。", "len": 10}
{"sid": "121_儒林列传.12.s5", "chapter": "121_儒林列传", "para": "12", "seq": 5, "text": "景帝知太后怒而固直言无罪，乃假固利兵，下圈刺豕，正中其心，一刺，豕应手而倒。", "len": 38}
{"sid": "121_儒林列传.12.s6", "chapter": "121_儒林列传", "para": "12", "seq": 6, "text": "太后默然，无以复罪，罢之。", "len": 13}
{"sid": "121_儒林列传.12.s7", "chapter": "121_儒林列传", "para": "12", "seq": 7, "text": "居顷之，景帝以固为廉直，拜为清河王太傅。", "len": 20}
{"sid": "121_儒林列传.12.s8", "chapter": "121_儒林列传", "para": "12", "seq": 8, "text": "久之，病免。", "len": 6}
{"sid": "121_儒林列传.13.s1", "chapter": "121_儒林列传", "para": "13", "seq": 1, "text": "今上初即位，复以贤良徵固。", "len": 13}
{"sid": "121_儒林列传.13.s2", "chapter": "121_儒林列传", "para": "13", "seq": 2, "text": "诸谀儒多疾毁固，曰“固老”，罢归之。", "len": 18}
{"sid": "121_儒林列传.13.s3", "chapter": "121_儒林列传", "para": "13", "seq": 3, "text": "时固已九十馀矣。", "len": 8}
{"sid": "121_儒林列传.13.s4", "chapter": "121_儒林列传", "para": "13", "seq": 4, "text": "固之徵也，薛人公孙弘亦徵，侧目而视固。", "len": 19}
{"sid": "121_儒林列传.13.s5", "chapter": "121_儒林列传", "para": "13", "seq": 5, "text": "固曰：“公孙子，务正学以言，无曲学以阿世！", "len": 21}
{"sid": "121_儒林列传.13.s6", "chapter": "121_儒林列传", "para": "13", "seq": 6, "text": "” 自是之後，齐言诗皆本辕固生也。", "len": 17}
{"sid": "121_儒林列传.13.s7", "chapter": "121_儒林列传", "para": "13", "seq": 7, "text": "诸齐人以诗显贵，皆固之弟子也。", "len": 15}
{"sid": "121_儒林列传.14.s1", "chapter": "121_儒林列传", "para": "14", "seq": 1, "text": "韩生者，燕人也。", "len": 8}
{"sid": "121_儒林列传.14.s2", "chapter": "121_儒林列传", "para": "14", "seq": 2, "text": "孝文帝时为博士，景帝时为常山王太傅。", "len": 18}
{"sid": "121_儒林列传.14.s3", "chapter": "121_儒林列传", "para": "14", "seq": 3, "text": "韩生推诗之意而为内外传数万言，其语颇与齐鲁间殊，然其归一也。", "len": 30}
{"sid": "121_儒林列传.14.s4", "chapter": "121_儒林列传", "para": "14", "seq": 4, "text": "淮南贲生受之。", "len": 7}
{"sid": "121_儒林列传.14.s5", "chapter": "121_儒林列传", "para": "14", "seq": 5, "text": "自是之後，而燕赵间言诗者由韩生。", "len": 16}
{"sid": "121_儒林列传.14.s6", "chapter": "121_儒林列传", "para": "14", "seq": 6, "text": "韩生孙商为今上博士。", "len": 10}
{"sid": "121_儒林列传.15.s1", "chapter": "121_儒林列传", "para": "15", "seq": 1, "text": "伏生者，济南人也。", "len": 9}
{"sid": "121_儒林列传.15.s2", "chapter": "121_儒林列传", "para": "15", "seq": 2, "text": "故为秦博士。", "len": 6}
{"sid": "121_儒林列传.15.s3", "chapter": "121_儒林列传", "para": "15", "seq": 3, "text": "孝文帝时，欲求能治尚书者，天下无有，乃闻伏生能治，欲召之。", "len": 29}
{"sid": "121_儒林列传.15.s4", "chapter": "121_儒林列传", "para": "15", "seq": 4, "text": "是时伏生年九十馀，老，不能行，於是乃诏太常使掌故晁错往受之。", "len": 30}
{"sid": "121_儒林列传.15.s5", "chapter": "121_儒林列传", "para": "15", "seq": 5, "text": "秦时焚书，伏生壁藏之。", "len": 11}
{"sid": "121_儒林列传.15.s6", "chapter": "121_儒林列传", "para": "15", "seq": 6, "text": "其後兵大起，流亡，汉定，伏生求其书，亡数十篇，独得二十九篇，即以教于齐鲁之间。", "len": 39}
{"sid": "121_儒林列传.15.s7", "chapter": "121_儒林列传", "para": "15", "seq": 7, "text": "学者由是颇能言尚书，诸山东大师无不涉尚书以教矣。", "len": 24}
{"sid": "121_儒林列传.16.s1", "chapter": "121_儒林列传", "para": "16", "seq": 1, "text": "伏生教济南张生及欧阳生，欧阳生教千乘兒宽。", "len": 21}
{"sid": "121_儒林列传.16.s2", "chapter": "121_儒林列传", "para": "16", "seq": 2, "text": "兒宽既通尚书，以文学应郡举，诣博士受业，受业孔安国。", "len": 26}
{"sid": "121_儒林列传.16.s3", "chapter": "121_儒林列传", "para": "16", "seq": 3, "text": "兒宽贫无资用，常为弟子都养，及时时间行佣赁，以给衣食。", "len": 27}
{"sid": "121_儒林列传.16.s4", "chapter": "121_儒林列传", "para": "16", "seq": 4, "text": "行常带经，止息则诵习之。", "len": 12}
{"sid": "121_儒林列传.16.s5", "chapter": "121_儒林列传", "para": "16", "seq": 5, "text": "以试第次，补廷尉史。", "len": 10}
{"sid": "121_儒林列传.16.s6", "chapter": "121_儒林列传", "para": "16", "seq": 6, "text": "是时张汤方乡学，以为奏谳掾，以古法议决疑大狱，而爱幸宽。", "len": 28}
{"sid": "121_儒林列传.16.s7", "chapter": "121_儒林列传", "para": "16", "seq": 7, "text": "宽为人温良，有廉智，自持，而善著书、书奏，敏於文，口不能发明也。", "len": 32}
{"sid": "121_儒林列传.16.s8", "chapter": "121_儒林列传", "para": "16", "seq": 8, "text": "汤以为长者，数称誉之。", "len": 11}
{"sid": "121_儒林列传.16.s9", "chapter": "121_儒林列传", "para": "16", "seq": 9, "text": "及汤为御史大夫，以兒宽为掾，荐之天子。", "len": 19}
{"sid": "121_儒林列传.16.s10", "chapter": "121_儒林列传", "para": "16", "seq": 10, "text": "天子见问，说之。", "len": 8}
{"sid": "121_儒林列传.16.s11", "chapter": "121_儒林列传", "para": "16", "seq": 11, "text": "张汤死後六年，兒宽位至御史大夫。", "len": 16}
{"sid": "121_儒林列传.16.s12", "chapter": "121_儒林列传", "para": "16", "seq": 12, "text": "九年而以官卒。", "len": 7}
{"sid": "121_儒林列传.16.s13", "chapter": "121_儒林列传", "para": "16", "seq": 13, "text": "宽在三公位，以和良承意从容得久，然无有所匡谏；於官，官属易之，不为尽力。", "len": 36}
{"sid": "121_儒林列传.16.s14", "chapter": "121_儒林列传", "para": "16", "seq": 14, "text": "张生亦为博士。", "len": 7}
{"sid": "121_儒林列传.16.s15", "chapter": "121_儒林列传", "para": "16", "seq": 15, "text": "而伏生孙以治尚书徵，不能明也。", "len": 15}
{"sid": "121_儒林列传.17.s1", "chapter": "121_儒林列传", "para": "17", "seq": 1, "text": "自此之後，鲁周霸、孔安国，雒阳贾嘉，颇能言尚书事。", "len": 25}
{"sid": "121_儒林列传.17.s2", "chapter": "121_儒林列传", "para": "17", "seq": 2, "text": "孔氏有古文尚书，而安国以今文读之，因以起其家。", "len": 23}
{"sid": "121_儒林列传.17.s3", "chapter": "121_儒林列传", "para": "17", "seq": 3, "text": "逸书得十馀篇，盖尚书滋多於是矣。", "len": 16}
{"sid": "121_儒林列传.18.s1", "chapter": "121_儒林列传", "para": "18", "seq": 1, "text": "诸学者多言礼，而鲁高堂生最本。", "len": 15}
{"sid": "121_儒林列传.18.s2", "chapter": "121_儒林列传", "para": "18", "seq": 2, "text": "礼固自孔子时而其经不具，及至秦焚书，书散亡益多，於今独有士礼，高堂生能言之。", "len": 38}
{"sid": "121_儒林列传.19.s1", "chapter": "121_儒林列传", "para": "19", "seq": 1, "text": "而鲁徐生善为容。", "len": 8}
{"sid": "121_儒林列传.19.s2", "chapter": "121_儒林列传", "para": "19", "seq": 2, "text": "孝文帝时，徐生以容为礼官大夫。", "len": 15}
{"sid": "121_儒林列传.19.s3", "chapter": "121_儒林列传", "para": "19", "seq": 3, "text": "传子至孙延、徐襄。", "len": 9}
{"sid": "121_儒林列传.19.s4", "chapter": "121_儒林列传", "para": "19", "seq": 4, "text": "襄，其天姿善为容，不能通礼经；延颇能，未善也。", "len": 23}
{"sid": "121_儒林列传.19.s5", "chapter": "121_儒林列传", "para": "19", "seq": 5, "text": "襄以容为汉礼官大夫，至广陵内史。", "len": 16}
{"sid": "121_儒林列传.19.s6", "chapter": "121_儒林列传", "para": "19", "seq": 6, "text": "延及徐氏弟子公户满意、桓生、单次，皆尝为汉礼官大夫。", "len": 26}
{"sid": "121_儒林列传.19.s7", "chapter": "121_儒林列传", "para": "19", "seq": 7, "text": "而瑕丘萧奋以礼为淮阳太守。", "len": 13}
{"sid": "121_儒林列传.19.s8", "chapter": "121_儒林列传", "para": "19", "seq": 8, "text": "是後能言礼为容者，由徐氏焉。", "len": 14}
{"sid": "121_儒林列传.20.s1", "chapter": "121_儒林列传", "para": "20", "seq": 1, "text": "自鲁商瞿受易孔子，孔子卒，商瞿传易，六世至齐人田何，字子庄，而汉兴。", "len": 34}
{"sid": "121_儒林列传.20.s2", "chapter": "121_儒林列传", "para": "20", "seq": 2, "text": "田何传东武人王同子仲，子仲传菑川人杨何。", "len": 20}
{"sid": "121_儒林列传.20.s3", "chapter": "121_儒林列传", "para": "20", "seq": 3, "text": "何以易，元光元年徵，官至中大夫。", "len": 16}
{"sid": "121_儒林列传.20.s4", "chapter": "121_儒林列传", "para": "20", "seq": 4, "text": "齐人即墨成以易至城阳相。", "len": 12}
{"sid": "121_儒林列传.20.s5", "chapter": "121_儒林列传", "para": "20", "seq": 5, "text": "广川人孟但以易为太子门大夫。", "len": 14}
{"sid": "121_儒林列传.20.s6", "chapter": "121_儒林列传", "para": "20", "seq": 6, "text": "鲁人周霸，莒人衡胡，临菑人主父偃，皆以易至二千石。", "len": 25}
{"sid": "121_儒林列传.20.s7", "chapter": "121_儒林列传", "para": "20", "seq": 7, "text": "然要言易者本於杨何之家。", "len": 12}
{"sid": "121_儒林列传.21.s1", "chapter": "121_儒林列传", "para": "21", "seq": 1, "text": "董仲舒，广川人也。", "len": 9}
{"sid": "121_儒林列传.21.s2", "chapter": "121_儒林列传", "para": "21", "seq": 2, "text": "以治春秋，孝景时为博士。", "len": 12}
{"sid": "121_儒林列传.21.s3", "chapter": "121_儒林列传", "para": "21", "seq": 3, "text": "下帷讲诵，弟子传以久次相受业，或莫见其面，盖三年董仲舒不观於舍园，其精如此。", "len": 38}
{"sid": "121_儒林列传.21.s4", "chapter": "121_儒林列传", "para": "21", "seq": 4, "text": "进退容止，非礼不行，学士皆师尊之。", "len": 17}
{"sid": "121_儒林列传.21.s5", "chapter": "121_儒林列传", "para": "21", "seq": 5, "text": "今上即位，为江都相。", "len": 10}
{"sid": "121_儒林列传.21.s6", "chapter": "121_儒林列传", "para": "21", "seq": 6, "text": "以春秋灾异之变推阴阳所以错行，故求雨闭诸阳，纵诸阴，其止雨反是。", "len": 32}
{"sid": "121_儒林列传.21.s7", "chapter": "121_儒林列传", "para": "21", "seq": 7, "text": "行之一国，未尝不得所欲。", "len": 12}
{"sid": "121_儒林列传.21.s8", "chapter": "121_儒林列传", "para": "21", "seq": 8, "text": "中废为中大夫，居舍，著灾异之记。", "len": 16}
{"sid": "121_儒林列传.21.s9", "chapter": "121_儒林列传", "para": "21", "seq": 9, "text": "是时辽东高庙灾，主父偃疾之，取其书奏之天子。", "len": 22}
{"sid": "121_儒林列传.21.s10", "chapter": "121_儒林列传", "para": "21", "seq": 10, "text": "天子召诸生示其书，有刺讥。", "len": 13}
{"sid": "121_儒林列传.21.s11", "chapter": "121_儒林列传", "para": "21", "seq": 11, "text": "董仲舒弟子吕步舒不知其师书，以为下愚。", "len": 19}
{"sid": "121_儒林列传.21.s12", "chapter": "121_儒林列传", "para": "21", "seq": 12, "text": "於是下董仲舒吏，当死，诏赦之。", "len": 15}
{"sid": "121_儒林列传.21.s13", "chapter": "121_儒林列传", "para": "21", "seq": 13, "text": "於是董仲舒竟不敢复言灾异。", "len": 13}
{"sid": "121_儒林列传.22.s1", "chapter": "121_儒林列传", "para": "22", "seq": 1, "text": "董仲舒为人廉直。", "len": 8}
{"sid": "121_儒林列传.22.s2", "chapter": "121_儒林列传", "para": "22", "seq": 2, "text": "是时方外攘四夷，公孙弘治春秋不如董仲舒，而弘希世用事，位至公卿。", "len": 32}
{"sid": "121_儒林列传.22.s3", "chapter": "121_儒林列传", "para": "22", "seq": 3, "text": "董仲舒以弘为从谀。", "len": 9}
{"sid": "121_儒林列传.22.s4", "chapter": "121_儒林列传", "para": "22", "seq": 4, "text": "弘疾之，乃言上曰：“独董仲舒可使相缪西王。", "len": 21}
{"sid": "121_儒林列传.22.s5", "chapter": "121_儒林列传", "para": "22", "seq": 5, "text": "” 胶西王素闻董仲舒有行，亦善待之。", "len": 18}
{"sid": "121_儒林列传.22.s6", "chapter": "121_儒林列传", "para": "22", "seq": 6, "text": "董仲舒恐久获罪，疾免居家。", "len": 13}
{"sid": "121_儒林列传.22.s7", "chapter": "121_儒林列传", "para": "22", "seq": 7, "text": "至卒，终不治产业，以脩学著书为事。", "len": 17}
{"sid": "121_儒林列传.22.s8", "chapter": "121_儒林列传", "para": "22", "seq": 8, "text": "故汉兴至于五世之间，唯董仲舒名为明於春秋，其传公羊氏也。", "len": 28}
{"sid": "121_儒林列传.23.s1", "chapter": "121_儒林列传", "para": "23", "seq": 1, "text": "胡毋生，齐人也。", "len": 8}
{"sid": "121_儒林列传.23.s2", "chapter": "121_儒林列传", "para": "23", "seq": 2, "text": "孝景时为博士，以老归教授。", "len": 13}
{"sid": "121_儒林列传.23.s3", "chapter": "121_儒林列传", "para": "23", "seq": 3, "text": "齐之言春秋者多受胡毋生，公孙弘亦颇受焉。", "len": 20}
{"sid": "121_儒林列传.24.s1", "chapter": "121_儒林列传", "para": "24", "seq": 1, "text": "瑕丘江生为穀梁春秋。", "len": 10}
{"sid": "121_儒林列传.24.s2", "chapter": "121_儒林列传", "para": "24", "seq": 2, "text": "自公孙弘得用，尝集比其义，卒用董仲舒。", "len": 19}
{"sid": "121_儒林列传.25.s1", "chapter": "121_儒林列传", "para": "25", "seq": 1, "text": "仲舒弟子遂者：兰陵褚大，广川殷忠，温吕步舒。", "len": 22}
{"sid": "121_儒林列传.25.s2", "chapter": "121_儒林列传", "para": "25", "seq": 2, "text": "褚大至梁相。", "len": 6}
{"sid": "121_儒林列传.25.s3", "chapter": "121_儒林列传", "para": "25", "seq": 3, "text": "步舒至长史，持节使决淮南狱，於诸侯擅专断，不报，以春秋之义正之，天子皆以为是。", "len": 39}
{"sid": "121_儒林列传.25.s4", "chapter": "121_儒林列传", "para": "25", "seq": 4, "text": "弟子通者，至於命大夫；为郎、谒者、掌故者以百数。", "len": 24}
{"sid": "121_儒林列传.25.s5", "chapter": "121_儒林列传", "para": "25", "seq": 5, "text": "而董仲舒子及孙皆以学至大官。", "len": 14}
{"sid": "121_儒林列传.25.s6", "chapter": "121_儒林列传", "para": "25", "seq": 6, "text": "::: 赞", "len": 5}
{"sid": "121_儒林列传.26.s1", "chapter": "121_儒林列传", "para": "26", "seq": 1, "text": "孔氏之衰，经书绪乱。", "len": 10}
{"sid": "121_儒林列传.26.s2", "chapter": "121_儒林列传", "para": "26", "seq": 2, "text": "言诸六学，始自炎汉。", "len": 10}
{"sid": "121_儒林列传.26.s3", "chapter": "121_儒林列传", "para": "26", "seq": 3, "text": "著令立官，四方鸧腕。", "len": 10}
{"sid": "121_儒林列传.26.s4", "chapter": "121_儒林列传", "para": "26", "seq": 4, "text": "曲台坏壁，书礼之冠。", "len": 10}
{"sid": "121_儒林列传.26.s5", "chapter": "121_儒林列传", "para": "26", "seq": 5, "text": "传易言诗，云蒸雾散。", "len": 10}
{"sid": "121_儒林列传.26.s6", "chapter": "121_儒林列传", "para": "26", "seq": 6, "text": "兴化致理，鸿猷克赞。", "len": 10}
{"sid": "121_儒林列传.26.s7", "chapter": "121_儒林列传", "para": "26", "seq": 7, "text": ":::", "len": 3}
