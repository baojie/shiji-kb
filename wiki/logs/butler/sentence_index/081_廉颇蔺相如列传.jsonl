{"sid": "081_廉颇蔺相如列传.1.s1", "chapter": "081_廉颇蔺相如列传", "para": "1", "seq": 1, "text": "廉颇者，赵之良将也。", "len": 10}
{"sid": "081_廉颇蔺相如列传.1.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "1.2", "seq": 1, "text": "赵惠文王十六年，廉颇为赵将伐齐，大破之，取阳晋，拜为上卿，以勇气闻於诸侯。", "len": 37}
{"sid": "081_廉颇蔺相如列传.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "2", "seq": 1, "text": "蔺相如者，赵人也，为赵宦者令缪贤舍人。", "len": 19}
{"sid": "081_廉颇蔺相如列传.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "3", "seq": 1, "text": "赵惠文王时，得楚和氏璧。", "len": 12}
{"sid": "081_廉颇蔺相如列传.3.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "3.2", "seq": 1, "text": "秦昭王闻之，使人遗赵王书，原以十五城请易璧。", "len": 22}
{"sid": "081_廉颇蔺相如列传.3.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "3.3", "seq": 1, "text": "赵王与大将军廉颇诸大臣谋：欲予秦，秦城恐不可得，徒见欺；欲勿予，即患秦兵之来。", "len": 39}
{"sid": "081_廉颇蔺相如列传.3.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "3.4", "seq": 1, "text": "计未定，求人可使报秦者，未得。", "len": 15}
{"sid": "081_廉颇蔺相如列传.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "4", "seq": 1, "text": "宦者令缪贤曰：“臣舍人蔺相如可使。”", "len": 18}
{"sid": "081_廉颇蔺相如列传.4.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "4.2", "seq": 1, "text": "王问：“何以知之？”", "len": 10}
{"sid": "081_廉颇蔺相如列传.4.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "4.3", "seq": 1, "text": "对曰： ::: 缪贤说辞 “臣尝有罪，窃计欲亡走燕，臣舍人相如止臣，曰：‘君何以知燕王？", "len": 44}
{"sid": "081_廉颇蔺相如列传.4.3.s2", "chapter": "081_廉颇蔺相如列传", "para": "4.3", "seq": 2, "text": "’臣语曰：‘臣尝从大王与燕王会境上，燕王私握臣手，曰“原结友”。", "len": 32}
{"sid": "081_廉颇蔺相如列传.4.3.s3", "chapter": "081_廉颇蔺相如列传", "para": "4.3", "seq": 3, "text": "以此知之，故欲往。", "len": 9}
{"sid": "081_廉颇蔺相如列传.4.3.s4", "chapter": "081_廉颇蔺相如列传", "para": "4.3", "seq": 4, "text": "’相如谓臣曰：‘夫赵彊而燕弱，而君幸於赵王，故燕王欲结於君。", "len": 30}
{"sid": "081_廉颇蔺相如列传.4.3.s5", "chapter": "081_廉颇蔺相如列传", "para": "4.3", "seq": 5, "text": "今君乃亡赵走燕，燕畏赵，其势必不敢留君，而束君归赵矣。", "len": 27}
{"sid": "081_廉颇蔺相如列传.4.3.s6", "chapter": "081_廉颇蔺相如列传", "para": "4.3", "seq": 6, "text": "君不如肉袒伏斧质请罪，则幸得脱矣。", "len": 17}
{"sid": "081_廉颇蔺相如列传.4.3.s7", "chapter": "081_廉颇蔺相如列传", "para": "4.3", "seq": 7, "text": "’臣从其计，大王亦幸赦臣。", "len": 13}
{"sid": "081_廉颇蔺相如列传.4.3.s8", "chapter": "081_廉颇蔺相如列传", "para": "4.3", "seq": 8, "text": "臣窃以为其人勇士，有智谋，宜可使。", "len": 17}
{"sid": "081_廉颇蔺相如列传.4.3.s9", "chapter": "081_廉颇蔺相如列传", "para": "4.3", "seq": 9, "text": "” :::", "len": 5}
{"sid": "081_廉颇蔺相如列传.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "5", "seq": 1, "text": "於是王召见，问蔺相如曰：“秦王以十五城请易寡人之璧，可予不？”", "len": 31}
{"sid": "081_廉颇蔺相如列传.5.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "5.2", "seq": 1, "text": "相如曰：“秦彊而赵弱，不可不许。”", "len": 17}
{"sid": "081_廉颇蔺相如列传.5.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "5.3", "seq": 1, "text": "王曰：“取吾璧，不予我城，柰何？”", "len": 17}
{"sid": "081_廉颇蔺相如列传.5.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "5.4", "seq": 1, "text": "相如曰：“秦以城求璧而赵不许，曲在赵。", "len": 19}
{"sid": "081_廉颇蔺相如列传.5.4.s2", "chapter": "081_廉颇蔺相如列传", "para": "5.4", "seq": 2, "text": "赵予璧而秦不予赵城，曲在秦。", "len": 14}
{"sid": "081_廉颇蔺相如列传.5.4.s3", "chapter": "081_廉颇蔺相如列传", "para": "5.4", "seq": 3, "text": "均之二策，宁许以负秦曲。”", "len": 13}
{"sid": "081_廉颇蔺相如列传.5.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "5.5", "seq": 1, "text": "王曰：“谁可使者？”", "len": 10}
{"sid": "081_廉颇蔺相如列传.5.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "5.6", "seq": 1, "text": "相如曰：“王必无人，臣原奉璧往使。", "len": 17}
{"sid": "081_廉颇蔺相如列传.5.6.s2", "chapter": "081_廉颇蔺相如列传", "para": "5.6", "seq": 2, "text": "城入赵而璧留秦；城不入，臣请完璧归赵。”", "len": 20}
{"sid": "081_廉颇蔺相如列传.5.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "5.7", "seq": 1, "text": "赵王於是遂遣相如奉璧西入秦。", "len": 14}
{"sid": "081_廉颇蔺相如列传.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "6", "seq": 1, "text": "秦王坐章台见相如，相如奉璧奏秦王。", "len": 17}
{"sid": "081_廉颇蔺相如列传.6.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "6.2", "seq": 1, "text": "秦王大喜，传以示美人及左右，左右皆呼万岁。", "len": 21}
{"sid": "081_廉颇蔺相如列传.6.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "6.3", "seq": 1, "text": "相如视秦王无意偿赵城，乃前曰：“璧有瑕，请指示王。”", "len": 26}
{"sid": "081_廉颇蔺相如列传.6.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 1, "text": "王授璧，相如因持璧卻立，倚柱，怒发上冲冠|怒发冲冠，谓秦王曰： ::: 相如斥责秦王 “大王欲得璧，使人发书至赵王，赵王悉召群臣议，皆曰‘秦贪，负其彊，以空言求璧，偿城恐不可得’。", "len": 90}
{"sid": "081_廉颇蔺相如列传.6.4.s2", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 2, "text": "议不欲予秦璧。", "len": 7}
{"sid": "081_廉颇蔺相如列传.6.4.s3", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 3, "text": "臣以为布衣之交尚不相欺，况大国乎！", "len": 17}
{"sid": "081_廉颇蔺相如列传.6.4.s4", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 4, "text": "且以一璧之故逆彊秦之驩，不可。", "len": 15}
{"sid": "081_廉颇蔺相如列传.6.4.s5", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 5, "text": "於是赵王乃斋戒五日，使臣奉璧，拜送书於庭。", "len": 21}
{"sid": "081_廉颇蔺相如列传.6.4.s6", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 6, "text": "何者？", "len": 3}
{"sid": "081_廉颇蔺相如列传.6.4.s7", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 7, "text": "严大国之威以修敬也。", "len": 10}
{"sid": "081_廉颇蔺相如列传.6.4.s8", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 8, "text": "今臣至，大王见臣列观，礼节甚倨；得璧，传之美人，以戏弄臣。", "len": 29}
{"sid": "081_廉颇蔺相如列传.6.4.s9", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 9, "text": "臣观大王无意偿赵王城邑，故臣复取璧。", "len": 18}
{"sid": "081_廉颇蔺相如列传.6.4.s10", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 10, "text": "大王必欲急臣，臣头今与璧俱碎於柱矣！", "len": 18}
{"sid": "081_廉颇蔺相如列传.6.4.s11", "chapter": "081_廉颇蔺相如列传", "para": "6.4", "seq": 11, "text": "” :::", "len": 5}
{"sid": "081_廉颇蔺相如列传.6.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "6.5", "seq": 1, "text": "相如持其璧睨柱，欲以击柱。", "len": 13}
{"sid": "081_廉颇蔺相如列传.6.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "6.6", "seq": 1, "text": "秦王恐其破璧，乃辞谢固请，召有司案图，指从此以往十五都予赵。", "len": 30}
{"sid": "081_廉颇蔺相如列传.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "7", "seq": 1, "text": "相如度秦王特以诈详为予赵城，实不可得，乃谓秦王曰：“和氏璧，天下所共传宝也，赵王恐，不敢不献。", "len": 47}
{"sid": "081_廉颇蔺相如列传.7.s2", "chapter": "081_廉颇蔺相如列传", "para": "7", "seq": 2, "text": "赵王送璧时，斋戒五日，今大王亦宜斋戒五日，设九宾於廷，臣乃敢上璧。”", "len": 34}
{"sid": "081_廉颇蔺相如列传.7.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "7.2", "seq": 1, "text": "秦王度之，终不可彊夺，遂许斋五日，舍相如广成传。", "len": 24}
{"sid": "081_廉颇蔺相如列传.7.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "7.3", "seq": 1, "text": "相如度秦王虽斋，决负约不偿城，乃使其从者衣褐，怀其璧，从径道亡，归璧于赵。", "len": 37}
{"sid": "081_廉颇蔺相如列传.8.s1", "chapter": "081_廉颇蔺相如列传", "para": "8", "seq": 1, "text": "秦王斋五日後，乃设九宾礼於廷，引赵使者蔺相如。", "len": 23}
{"sid": "081_廉颇蔺相如列传.8.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "8.2", "seq": 1, "text": "相如至，谓秦王曰： ::: 相如抗辩 “秦自缪公以来二十馀君，未尝有坚明约束者也。", "len": 41}
{"sid": "081_廉颇蔺相如列传.8.2.s2", "chapter": "081_廉颇蔺相如列传", "para": "8.2", "seq": 2, "text": "臣诚恐见欺於王而负赵，故令人持璧归，间至赵矣。", "len": 23}
{"sid": "081_廉颇蔺相如列传.8.2.s3", "chapter": "081_廉颇蔺相如列传", "para": "8.2", "seq": 3, "text": "且秦彊而赵弱，大王遣一介之使至赵，赵立奉璧来。", "len": 23}
{"sid": "081_廉颇蔺相如列传.8.2.s4", "chapter": "081_廉颇蔺相如列传", "para": "8.2", "seq": 4, "text": "今以秦之彊而先割十五都予赵，赵岂敢留璧而得罪於大王乎？", "len": 27}
{"sid": "081_廉颇蔺相如列传.8.2.s5", "chapter": "081_廉颇蔺相如列传", "para": "8.2", "seq": 5, "text": "臣知欺大王之罪当诛，臣请就汤镬，唯大王与群臣孰计议之。", "len": 27}
{"sid": "081_廉颇蔺相如列传.8.2.s6", "chapter": "081_廉颇蔺相如列传", "para": "8.2", "seq": 6, "text": "” :::", "len": 5}
{"sid": "081_廉颇蔺相如列传.8.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "8.3", "seq": 1, "text": "秦王与群臣相视而嘻。", "len": 10}
{"sid": "081_廉颇蔺相如列传.8.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "8.4", "seq": 1, "text": "左右或欲引相如去，秦王因曰：“今杀相如，终不能得璧也，而绝秦赵之驩，不如因而厚遇之，使归赵，赵王岂以一璧之故欺秦邪！”", "len": 59}
{"sid": "081_廉颇蔺相如列传.8.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "8.5", "seq": 1, "text": "卒廷见相如，毕礼而归之。", "len": 12}
{"sid": "081_廉颇蔺相如列传.9.s1", "chapter": "081_廉颇蔺相如列传", "para": "9", "seq": 1, "text": "相如既归，赵王以为贤大夫使不辱於诸侯，拜相如为上大夫。", "len": 27}
{"sid": "081_廉颇蔺相如列传.9.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "9.2", "seq": 1, "text": "秦亦不以城予赵，赵亦终不予秦璧。", "len": 16}
{"sid": "081_廉颇蔺相如列传.10.s1", "chapter": "081_廉颇蔺相如列传", "para": "10", "seq": 1, "text": "其後秦伐赵，拔石城。", "len": 10}
{"sid": "081_廉颇蔺相如列传.10.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "10.2", "seq": 1, "text": "明年，复攻赵，杀二万人。", "len": 12}
{"sid": "081_廉颇蔺相如列传.11.s1", "chapter": "081_廉颇蔺相如列传", "para": "11", "seq": 1, "text": "秦王使使者告赵王，欲与王为好会於西河外渑池。", "len": 22}
{"sid": "081_廉颇蔺相如列传.11.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "11.2", "seq": 1, "text": "赵王畏秦，欲毋行。", "len": 9}
{"sid": "081_廉颇蔺相如列传.11.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "11.3", "seq": 1, "text": "廉颇、蔺相如计曰：“王不行，示赵弱且怯也。”", "len": 22}
{"sid": "081_廉颇蔺相如列传.11.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "11.4", "seq": 1, "text": "赵王遂行，相如从。", "len": 9}
{"sid": "081_廉颇蔺相如列传.11.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "11.5", "seq": 1, "text": "廉颇送至境，与王诀曰：“王行，度道里会遇之礼毕，还，不过三十日。", "len": 32}
{"sid": "081_廉颇蔺相如列传.11.5.s2", "chapter": "081_廉颇蔺相如列传", "para": "11.5", "seq": 2, "text": "三十日不还，则请立太子为王。", "len": 14}
{"sid": "081_廉颇蔺相如列传.11.5.s3", "chapter": "081_廉颇蔺相如列传", "para": "11.5", "seq": 3, "text": "以绝秦望。”", "len": 6}
{"sid": "081_廉颇蔺相如列传.11.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "11.6", "seq": 1, "text": "王许之，遂与秦王会渑池。", "len": 12}
{"sid": "081_廉颇蔺相如列传.12.s1", "chapter": "081_廉颇蔺相如列传", "para": "12", "seq": 1, "text": "秦王饮酒酣，曰：“寡人窃闻赵王好音，请奏瑟。”", "len": 23}
{"sid": "081_廉颇蔺相如列传.12.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.2", "seq": 1, "text": "赵王鼓瑟。", "len": 5}
{"sid": "081_廉颇蔺相如列传.12.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.3", "seq": 1, "text": "秦御史前书曰“某年月日，秦王与赵王会饮，令赵王鼓瑟”。", "len": 27}
{"sid": "081_廉颇蔺相如列传.12.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.4", "seq": 1, "text": "蔺相如前曰：“赵王窃闻秦王善为秦声，请奏盆鲊秦王，以相娱乐。”", "len": 31}
{"sid": "081_廉颇蔺相如列传.12.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.5", "seq": 1, "text": "秦王怒，不许。", "len": 7}
{"sid": "081_廉颇蔺相如列传.12.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.6", "seq": 1, "text": "於是相如前进鲊，因跪请秦王。", "len": 14}
{"sid": "081_廉颇蔺相如列传.12.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.7", "seq": 1, "text": "秦王不肯击鲊。", "len": 7}
{"sid": "081_廉颇蔺相如列传.12.8.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.8", "seq": 1, "text": "相如曰：“五步之内，相如请得以颈血溅大王矣！”", "len": 23}
{"sid": "081_廉颇蔺相如列传.12.9.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.9", "seq": 1, "text": "左右欲刃相如，相如张目叱之，左右皆靡。", "len": 19}
{"sid": "081_廉颇蔺相如列传.12.10.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.10", "seq": 1, "text": "於是秦王不怿，为一击鲊。", "len": 12}
{"sid": "081_廉颇蔺相如列传.12.11.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.11", "seq": 1, "text": "相如顾召赵御史书曰“某年月日，秦王为赵王击鲊”。", "len": 24}
{"sid": "081_廉颇蔺相如列传.12.12.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.12", "seq": 1, "text": "秦之群臣曰：“请以赵十五城为秦王寿”。", "len": 19}
{"sid": "081_廉颇蔺相如列传.12.13.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.13", "seq": 1, "text": "蔺相如亦曰：“请以秦之咸阳为赵王寿。”", "len": 19}
{"sid": "081_廉颇蔺相如列传.12.14.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.14", "seq": 1, "text": "秦王竟酒，终不能加胜於赵。", "len": 13}
{"sid": "081_廉颇蔺相如列传.12.15.s1", "chapter": "081_廉颇蔺相如列传", "para": "12.15", "seq": 1, "text": "赵亦盛设兵以待秦，秦不敢动。", "len": 14}
{"sid": "081_廉颇蔺相如列传.13.s1", "chapter": "081_廉颇蔺相如列传", "para": "13", "seq": 1, "text": "既罢归国，以相如功大，拜为上卿，位在廉颇之右。", "len": 23}
{"sid": "081_廉颇蔺相如列传.13.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "13.2", "seq": 1, "text": "廉颇曰：“我为赵将，有攻城野战之大功，而蔺相如徒以口舌为劳，而位居我上，且相如素贱人，吾羞，不忍为之下。”", "len": 53}
{"sid": "081_廉颇蔺相如列传.13.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "13.3", "seq": 1, "text": "宣言曰：“我见相如，必辱之。”", "len": 15}
{"sid": "081_廉颇蔺相如列传.14.s1", "chapter": "081_廉颇蔺相如列传", "para": "14", "seq": 1, "text": "相如闻，不肯与会。", "len": 9}
{"sid": "081_廉颇蔺相如列传.14.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "14.2", "seq": 1, "text": "相如每朝时，常称病，不欲与廉颇争列。", "len": 18}
{"sid": "081_廉颇蔺相如列传.14.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "14.3", "seq": 1, "text": "已而相如出，望见廉颇，相如引车避匿。", "len": 18}
{"sid": "081_廉颇蔺相如列传.15.s1", "chapter": "081_廉颇蔺相如列传", "para": "15", "seq": 1, "text": "於是舍人相与谏曰：“臣所以去亲戚而事君者，徒慕君之高义也。", "len": 29}
{"sid": "081_廉颇蔺相如列传.15.s2", "chapter": "081_廉颇蔺相如列传", "para": "15", "seq": 2, "text": "今君与廉颇同列，廉君宣恶言而君畏匿之，恐惧殊甚，且庸人尚羞之，况於将相乎！", "len": 37}
{"sid": "081_廉颇蔺相如列传.15.s3", "chapter": "081_廉颇蔺相如列传", "para": "15", "seq": 3, "text": "臣等不肖，请辞去。”", "len": 10}
{"sid": "081_廉颇蔺相如列传.16.s1", "chapter": "081_廉颇蔺相如列传", "para": "16", "seq": 1, "text": "蔺相如固止之，曰：“公之视廉将军孰与秦王？”", "len": 22}
{"sid": "081_廉颇蔺相如列传.16.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "16.2", "seq": 1, "text": "曰：“不若也。”", "len": 8}
{"sid": "081_廉颇蔺相如列传.16.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "16.3", "seq": 1, "text": "相如曰： ::: 相如释义 “夫以秦王之威，而相如廷叱之，辱其群臣，相如虽驽，独畏廉将军哉？", "len": 46}
{"sid": "081_廉颇蔺相如列传.16.3.s2", "chapter": "081_廉颇蔺相如列传", "para": "16.3", "seq": 2, "text": "顾吾念之，彊秦之所以不敢加兵於赵者，徒以吾两人在也。", "len": 26}
{"sid": "081_廉颇蔺相如列传.16.3.s3", "chapter": "081_廉颇蔺相如列传", "para": "16.3", "seq": 3, "text": "今两虎共斗，其势不俱生。", "len": 12}
{"sid": "081_廉颇蔺相如列传.16.3.s4", "chapter": "081_廉颇蔺相如列传", "para": "16.3", "seq": 4, "text": "吾所以为此者，以先国家之急而後私雠也。", "len": 19}
{"sid": "081_廉颇蔺相如列传.16.3.s5", "chapter": "081_廉颇蔺相如列传", "para": "16.3", "seq": 5, "text": "” :::", "len": 5}
{"sid": "081_廉颇蔺相如列传.17.s1", "chapter": "081_廉颇蔺相如列传", "para": "17", "seq": 1, "text": "廉颇闻之，肉袒负荆，因宾客至蔺相如门谢罪。", "len": 21}
{"sid": "081_廉颇蔺相如列传.17.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "17.2", "seq": 1, "text": "曰：“鄙贱之人，不知将军宽之至此也。”", "len": 19}
{"sid": "081_廉颇蔺相如列传.17.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "17.3", "seq": 1, "text": "卒相与驩，为刎颈之交。", "len": 11}
{"sid": "081_廉颇蔺相如列传.18.s1", "chapter": "081_廉颇蔺相如列传", "para": "18", "seq": 1, "text": "是岁，廉颇东攻齐，破其一军。", "len": 14}
{"sid": "081_廉颇蔺相如列传.18.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "18.2", "seq": 1, "text": "居二年，廉颇复伐齐几，拔之。", "len": 14}
{"sid": "081_廉颇蔺相如列传.18.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "18.3", "seq": 1, "text": "後三年，廉颇攻魏之防陵、安阳，拔之。", "len": 18}
{"sid": "081_廉颇蔺相如列传.18.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "18.4", "seq": 1, "text": "後四年，蔺相如将而攻齐，至平邑而罢。", "len": 18}
{"sid": "081_廉颇蔺相如列传.18.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "18.5", "seq": 1, "text": "其明年，赵奢破秦军阏与下。", "len": 13}
{"sid": "081_廉颇蔺相如列传.19.s1", "chapter": "081_廉颇蔺相如列传", "para": "19", "seq": 1, "text": "赵奢者，赵之田部吏也。", "len": 11}
{"sid": "081_廉颇蔺相如列传.19.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "19.2", "seq": 1, "text": "收租税而平原君家不肯出租，奢以法治之，杀平原君用事者九人。", "len": 29}
{"sid": "081_廉颇蔺相如列传.19.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "19.3", "seq": 1, "text": "平原君怒，将杀奢。", "len": 9}
{"sid": "081_廉颇蔺相如列传.19.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "19.4", "seq": 1, "text": "奢因说曰： ::: 赵奢说辞 “君於赵为贵公子，今纵君家而不奉公则法削，法削则国弱，国弱则诸侯加兵，诸侯加兵是无赵也，君安得有此富乎？", "len": 67}
{"sid": "081_廉颇蔺相如列传.19.4.s2", "chapter": "081_廉颇蔺相如列传", "para": "19.4", "seq": 2, "text": "以君之贵，奉公如法则上下平，上下平则国彊，国彊则赵固，而君为贵戚，岂轻於天下邪？", "len": 40}
{"sid": "081_廉颇蔺相如列传.19.4.s3", "chapter": "081_廉颇蔺相如列传", "para": "19.4", "seq": 3, "text": "” :::", "len": 5}
{"sid": "081_廉颇蔺相如列传.19.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "19.5", "seq": 1, "text": "平原君以为贤，言之於王。", "len": 12}
{"sid": "081_廉颇蔺相如列传.19.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "19.6", "seq": 1, "text": "王用之治国赋，国赋大平，民富而府库实。", "len": 19}
{"sid": "081_廉颇蔺相如列传.20.s1", "chapter": "081_廉颇蔺相如列传", "para": "20", "seq": 1, "text": "秦伐韩，军於阏与。", "len": 9}
{"sid": "081_廉颇蔺相如列传.20.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "20.2", "seq": 1, "text": "王召廉颇而问曰：“可救不？”", "len": 14}
{"sid": "081_廉颇蔺相如列传.20.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "20.3", "seq": 1, "text": "对曰：“道远险狭，难救。”", "len": 13}
{"sid": "081_廉颇蔺相如列传.20.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "20.4", "seq": 1, "text": "又召乐乘而问焉，乐乘对如廉颇言。", "len": 16}
{"sid": "081_廉颇蔺相如列传.20.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "20.5", "seq": 1, "text": "又召问赵奢，奢对曰：“其道远险狭，譬之犹两鼠斗於穴中，将勇者胜。”", "len": 33}
{"sid": "081_廉颇蔺相如列传.20.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "20.6", "seq": 1, "text": "王乃令赵奢将，救之。", "len": 10}
{"sid": "081_廉颇蔺相如列传.21.s1", "chapter": "081_廉颇蔺相如列传", "para": "21", "seq": 1, "text": "兵去邯郸三十里，而令军中曰：“有以军事谏者死。”", "len": 24}
{"sid": "081_廉颇蔺相如列传.21.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "21.2", "seq": 1, "text": "秦军军武安西，秦军鼓譟勒兵，武安屋瓦尽振。", "len": 21}
{"sid": "081_廉颇蔺相如列传.21.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "21.3", "seq": 1, "text": "军中候有一人言急救武安，赵奢立斩之。", "len": 18}
{"sid": "081_廉颇蔺相如列传.21.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "21.4", "seq": 1, "text": "坚壁，留二十八日不行，复益增垒。", "len": 16}
{"sid": "081_廉颇蔺相如列传.21.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "21.5", "seq": 1, "text": "秦间来入，赵奢善食而遣之。", "len": 13}
{"sid": "081_廉颇蔺相如列传.21.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "21.6", "seq": 1, "text": "间以报秦将，秦将大喜曰：“夫去国三十里而军不行，乃增垒，阏与非赵地也。”", "len": 36}
{"sid": "081_廉颇蔺相如列传.21.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "21.7", "seq": 1, "text": "赵奢既已遣秦间，卷甲而趋之，二日一夜至，今善射者去阏与五十里而军。", "len": 33}
{"sid": "081_廉颇蔺相如列传.21.8.s1", "chapter": "081_廉颇蔺相如列传", "para": "21.8", "seq": 1, "text": "军垒成，秦人闻之，悉甲而至。", "len": 14}
{"sid": "081_廉颇蔺相如列传.22.s1", "chapter": "081_廉颇蔺相如列传", "para": "22", "seq": 1, "text": "军士许历请以军事谏，赵奢曰：“内之。”", "len": 19}
{"sid": "081_廉颇蔺相如列传.22.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "22.2", "seq": 1, "text": "许历曰：“秦人不意赵师至此，其来气盛，将军必厚集其阵以待之。", "len": 30}
{"sid": "081_廉颇蔺相如列传.22.2.s2", "chapter": "081_廉颇蔺相如列传", "para": "22.2", "seq": 2, "text": "不然，必败。”", "len": 7}
{"sid": "081_廉颇蔺相如列传.22.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "22.3", "seq": 1, "text": "赵奢曰：“请受令。”", "len": 10}
{"sid": "081_廉颇蔺相如列传.22.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "22.4", "seq": 1, "text": "许历曰：“请就鈇质之诛。”", "len": 13}
{"sid": "081_廉颇蔺相如列传.22.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "22.5", "seq": 1, "text": "赵奢曰：“胥後令邯郸。”", "len": 12}
{"sid": "081_廉颇蔺相如列传.22.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "22.6", "seq": 1, "text": "许历复请谏，曰：“先据北山上者胜，後至者败。”", "len": 23}
{"sid": "081_廉颇蔺相如列传.22.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "22.7", "seq": 1, "text": "赵奢许诺，即发万人趋之。", "len": 12}
{"sid": "081_廉颇蔺相如列传.22.8.s1", "chapter": "081_廉颇蔺相如列传", "para": "22.8", "seq": 1, "text": "秦兵後至，争山不得上，赵奢纵兵击之，大破秦军。", "len": 23}
{"sid": "081_廉颇蔺相如列传.22.9.s1", "chapter": "081_廉颇蔺相如列传", "para": "22.9", "seq": 1, "text": "秦军解而走，遂解阏与之围而归。", "len": 15}
{"sid": "081_廉颇蔺相如列传.23.s1", "chapter": "081_廉颇蔺相如列传", "para": "23", "seq": 1, "text": "赵惠文王赐奢号为马服君，以许历为国尉。", "len": 19}
{"sid": "081_廉颇蔺相如列传.23.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "23.2", "seq": 1, "text": "赵奢於是与廉颇、蔺相如同位。", "len": 14}
{"sid": "081_廉颇蔺相如列传.24.s1", "chapter": "081_廉颇蔺相如列传", "para": "24", "seq": 1, "text": "後四年，赵惠文王卒，子孝成王立。", "len": 16}
{"sid": "081_廉颇蔺相如列传.24.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "24.2", "seq": 1, "text": "七年，秦与赵兵相距长平，时赵奢已死，而蔺相如病笃，赵使廉颇将攻秦，秦数败赵军，赵军固壁不战。", "len": 46}
{"sid": "081_廉颇蔺相如列传.24.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "24.3", "seq": 1, "text": "秦数挑战，廉颇不肯。", "len": 10}
{"sid": "081_廉颇蔺相如列传.24.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "24.4", "seq": 1, "text": "赵王信秦之间。", "len": 7}
{"sid": "081_廉颇蔺相如列传.24.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "24.5", "seq": 1, "text": "秦之间言曰：“秦之所恶，独畏马服君赵奢之子赵括为将耳。”", "len": 28}
{"sid": "081_廉颇蔺相如列传.24.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "24.6", "seq": 1, "text": "赵王因以括为将，代廉颇。", "len": 12}
{"sid": "081_廉颇蔺相如列传.24.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "24.7", "seq": 1, "text": "蔺相如曰：“王以名使括，若胶柱而鼓瑟耳。", "len": 20}
{"sid": "081_廉颇蔺相如列传.24.7.s2", "chapter": "081_廉颇蔺相如列传", "para": "24.7", "seq": 2, "text": "括徒能读其父书传，不知合变也。”", "len": 16}
{"sid": "081_廉颇蔺相如列传.24.8.s1", "chapter": "081_廉颇蔺相如列传", "para": "24.8", "seq": 1, "text": "赵王不听，遂将之。", "len": 9}
{"sid": "081_廉颇蔺相如列传.25.s1", "chapter": "081_廉颇蔺相如列传", "para": "25", "seq": 1, "text": "赵括自少时学兵法，言兵事，以天下莫能当。", "len": 20}
{"sid": "081_廉颇蔺相如列传.25.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "25.2", "seq": 1, "text": "尝与其父奢言兵事，奢不能难，然不谓善。", "len": 19}
{"sid": "081_廉颇蔺相如列传.25.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "25.3", "seq": 1, "text": "括母问奢其故，奢曰：“兵，死地也，而括易言之。", "len": 23}
{"sid": "081_廉颇蔺相如列传.25.3.s2", "chapter": "081_廉颇蔺相如列传", "para": "25.3", "seq": 2, "text": "使赵不将括即已，若必将之，破赵军者必括也。”", "len": 22}
{"sid": "081_廉颇蔺相如列传.26.s1", "chapter": "081_廉颇蔺相如列传", "para": "26", "seq": 1, "text": "及括将行，其母上书言於王曰：“括不可使将。”", "len": 22}
{"sid": "081_廉颇蔺相如列传.26.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "26.2", "seq": 1, "text": "王曰：“何以？”", "len": 8}
{"sid": "081_廉颇蔺相如列传.26.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "26.3", "seq": 1, "text": "对曰： ::: 括母进言 “始妾事其父，时为将，身所奉饭饮而进食者以十数，所友者以百数，大王及宗室所赏赐者尽以予军吏士大夫，受命之日，不问家事。", "len": 72}
{"sid": "081_廉颇蔺相如列传.26.3.s2", "chapter": "081_廉颇蔺相如列传", "para": "26.3", "seq": 2, "text": "今括一旦为将，东向而朝，军吏无敢仰视之者，王所赐金帛，归藏於家，而日视便利田宅可买者买之。", "len": 45}
{"sid": "081_廉颇蔺相如列传.26.3.s3", "chapter": "081_廉颇蔺相如列传", "para": "26.3", "seq": 3, "text": "王以为何如其父？", "len": 8}
{"sid": "081_廉颇蔺相如列传.26.3.s4", "chapter": "081_廉颇蔺相如列传", "para": "26.3", "seq": 4, "text": "父子异心，原王勿遣。", "len": 10}
{"sid": "081_廉颇蔺相如列传.26.3.s5", "chapter": "081_廉颇蔺相如列传", "para": "26.3", "seq": 5, "text": "” :::", "len": 5}
{"sid": "081_廉颇蔺相如列传.26.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "26.4", "seq": 1, "text": "王曰：“母置之，吾已决矣。”", "len": 14}
{"sid": "081_廉颇蔺相如列传.26.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "26.5", "seq": 1, "text": "括母因曰：“王终遣之，即有如不称，妾得无随坐乎？”", "len": 25}
{"sid": "081_廉颇蔺相如列传.26.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "26.6", "seq": 1, "text": "王许诺。", "len": 4}
{"sid": "081_廉颇蔺相如列传.27.s1", "chapter": "081_廉颇蔺相如列传", "para": "27", "seq": 1, "text": "赵括既代廉颇，悉更约束，易置军吏。", "len": 17}
{"sid": "081_廉颇蔺相如列传.27.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "27.2", "seq": 1, "text": "秦将白起闻之，纵奇兵，详败走，而绝其粮道，分断其军为二，士卒离心。", "len": 33}
{"sid": "081_廉颇蔺相如列传.27.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "27.3", "seq": 1, "text": "四十馀日，军饿，赵括出锐卒自博战，秦军射杀赵括。", "len": 24}
{"sid": "081_廉颇蔺相如列传.27.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "27.4", "seq": 1, "text": "括军败，数十万之众遂降秦，秦悉阬之。", "len": 18}
{"sid": "081_廉颇蔺相如列传.27.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "27.5", "seq": 1, "text": "赵前後所亡凡四十五万。", "len": 11}
{"sid": "081_廉颇蔺相如列传.27.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "27.6", "seq": 1, "text": "明年，秦兵遂围邯郸，岁馀，几不得脱。", "len": 18}
{"sid": "081_廉颇蔺相如列传.27.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "27.7", "seq": 1, "text": "赖楚、魏诸侯来救，乃得解邯郸之围。", "len": 17}
{"sid": "081_廉颇蔺相如列传.27.8.s1", "chapter": "081_廉颇蔺相如列传", "para": "27.8", "seq": 1, "text": "赵王亦以括母先言，竟不诛也。", "len": 14}
{"sid": "081_廉颇蔺相如列传.28.s1", "chapter": "081_廉颇蔺相如列传", "para": "28", "seq": 1, "text": "自邯郸围解五年，而燕用栗腹之谋，曰“赵壮者尽於长平，其孤未壮”，举兵击赵。", "len": 37}
{"sid": "081_廉颇蔺相如列传.28.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "28.2", "seq": 1, "text": "赵使廉颇将，击，大破燕军於鄗，杀栗腹，遂围燕。", "len": 23}
{"sid": "081_廉颇蔺相如列传.28.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "28.3", "seq": 1, "text": "燕割五城请和，乃听之。", "len": 11}
{"sid": "081_廉颇蔺相如列传.28.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "28.4", "seq": 1, "text": "赵以尉文封廉颇为信平君，为假相国。", "len": 17}
{"sid": "081_廉颇蔺相如列传.29.s1", "chapter": "081_廉颇蔺相如列传", "para": "29", "seq": 1, "text": "廉颇之免长平归也，失势之时，故客尽去。", "len": 19}
{"sid": "081_廉颇蔺相如列传.29.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "29.2", "seq": 1, "text": "及复用为将，客又复至。", "len": 11}
{"sid": "081_廉颇蔺相如列传.29.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "29.3", "seq": 1, "text": "廉颇曰：“客退矣！”", "len": 10}
{"sid": "081_廉颇蔺相如列传.29.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "29.4", "seq": 1, "text": "客曰：“吁！", "len": 6}
{"sid": "081_廉颇蔺相如列传.29.4.s2", "chapter": "081_廉颇蔺相如列传", "para": "29.4", "seq": 2, "text": "君何见之晚也？", "len": 7}
{"sid": "081_廉颇蔺相如列传.29.4.s3", "chapter": "081_廉颇蔺相如列传", "para": "29.4", "seq": 3, "text": "夫天下以市道交，君有势，我则从君，君无势则去，此固其理也，有何怨乎？”", "len": 35}
{"sid": "081_廉颇蔺相如列传.29.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "29.5", "seq": 1, "text": "居六年，赵使廉颇伐魏之繁阳，拔之。", "len": 17}
{"sid": "081_廉颇蔺相如列传.30.s1", "chapter": "081_廉颇蔺相如列传", "para": "30", "seq": 1, "text": "赵孝成王卒，子悼襄王立，使乐乘代廉颇。", "len": 19}
{"sid": "081_廉颇蔺相如列传.30.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "30.2", "seq": 1, "text": "廉颇怒，攻乐乘，乐乘走。", "len": 12}
{"sid": "081_廉颇蔺相如列传.30.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "30.3", "seq": 1, "text": "廉颇遂奔魏之大梁。", "len": 9}
{"sid": "081_廉颇蔺相如列传.30.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "30.4", "seq": 1, "text": "其明年，赵乃以李牧为将而攻燕，拔武遂、方城。", "len": 22}
{"sid": "081_廉颇蔺相如列传.31.s1", "chapter": "081_廉颇蔺相如列传", "para": "31", "seq": 1, "text": "廉颇居梁久之，魏不能信用。", "len": 13}
{"sid": "081_廉颇蔺相如列传.31.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "31.2", "seq": 1, "text": "赵以数困於秦兵，赵王思复得廉颇，廉颇亦思复用於赵。", "len": 25}
{"sid": "081_廉颇蔺相如列传.31.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "31.3", "seq": 1, "text": "赵王使使者视廉颇尚可用否。", "len": 13}
{"sid": "081_廉颇蔺相如列传.31.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "31.4", "seq": 1, "text": "廉颇之仇郭开多与使者金，令毁之。", "len": 16}
{"sid": "081_廉颇蔺相如列传.31.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "31.5", "seq": 1, "text": "赵使者既见廉颇，廉颇为之一饭斗米，肉十斤，被甲上马，以示尚可用。", "len": 32}
{"sid": "081_廉颇蔺相如列传.31.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "31.6", "seq": 1, "text": "赵使还报王曰：“廉将军虽老，尚善饭，然与臣坐，顷之三遗矢矣。”", "len": 31}
{"sid": "081_廉颇蔺相如列传.31.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "31.7", "seq": 1, "text": "赵王以为老，遂不召。", "len": 10}
{"sid": "081_廉颇蔺相如列传.32.s1", "chapter": "081_廉颇蔺相如列传", "para": "32", "seq": 1, "text": "楚闻廉颇在魏，阴使人迎之。", "len": 13}
{"sid": "081_廉颇蔺相如列传.32.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "32.2", "seq": 1, "text": "廉颇一为楚将，无功，曰：“我思用赵人。”", "len": 20}
{"sid": "081_廉颇蔺相如列传.32.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "32.3", "seq": 1, "text": "廉颇卒死于寿春。", "len": 8}
{"sid": "081_廉颇蔺相如列传.33.s1", "chapter": "081_廉颇蔺相如列传", "para": "33", "seq": 1, "text": "李牧者，赵之北边良将也。", "len": 12}
{"sid": "081_廉颇蔺相如列传.33.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "33.2", "seq": 1, "text": "常居代雁门，备匈奴。", "len": 10}
{"sid": "081_廉颇蔺相如列传.33.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "33.3", "seq": 1, "text": "以便宜置吏，市租皆输入莫府，为士卒费。", "len": 19}
{"sid": "081_廉颇蔺相如列传.33.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "33.4", "seq": 1, "text": "日击数牛飨士，习射骑，谨烽火，多间谍，厚遇战士。", "len": 24}
{"sid": "081_廉颇蔺相如列传.33.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "33.5", "seq": 1, "text": "为约曰：“匈奴即入盗，急入收保，有敢捕虏者斩。”", "len": 24}
{"sid": "081_廉颇蔺相如列传.33.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "33.6", "seq": 1, "text": "匈奴每入，烽火谨，辄入收保，不敢战。", "len": 18}
{"sid": "081_廉颇蔺相如列传.33.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "33.7", "seq": 1, "text": "如是数岁，亦不亡失。", "len": 10}
{"sid": "081_廉颇蔺相如列传.33.8.s1", "chapter": "081_廉颇蔺相如列传", "para": "33.8", "seq": 1, "text": "然匈奴以李牧为怯，虽赵边兵亦以为吾将怯。", "len": 20}
{"sid": "081_廉颇蔺相如列传.33.9.s1", "chapter": "081_廉颇蔺相如列传", "para": "33.9", "seq": 1, "text": "赵王让李牧，李牧如故。", "len": 11}
{"sid": "081_廉颇蔺相如列传.33.10.s1", "chapter": "081_廉颇蔺相如列传", "para": "33.10", "seq": 1, "text": "赵王怒，召之，使他人代将。", "len": 13}
{"sid": "081_廉颇蔺相如列传.34.s1", "chapter": "081_廉颇蔺相如列传", "para": "34", "seq": 1, "text": "岁馀，匈奴每来，出战。", "len": 11}
{"sid": "081_廉颇蔺相如列传.34.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "34.2", "seq": 1, "text": "出战，数不利，失亡多，边不得田畜。", "len": 17}
{"sid": "081_廉颇蔺相如列传.34.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "34.3", "seq": 1, "text": "复请李牧。", "len": 5}
{"sid": "081_廉颇蔺相如列传.34.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "34.4", "seq": 1, "text": "牧杜门不出，固称疾。", "len": 10}
{"sid": "081_廉颇蔺相如列传.34.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "34.5", "seq": 1, "text": "赵王乃复彊起使将兵。", "len": 10}
{"sid": "081_廉颇蔺相如列传.34.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "34.6", "seq": 1, "text": "牧曰：“王必用臣，臣如前，乃敢奉令。”", "len": 19}
{"sid": "081_廉颇蔺相如列传.34.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "34.7", "seq": 1, "text": "王许之。", "len": 4}
{"sid": "081_廉颇蔺相如列传.35.s1", "chapter": "081_廉颇蔺相如列传", "para": "35", "seq": 1, "text": "李牧至，如故约。", "len": 8}
{"sid": "081_廉颇蔺相如列传.35.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "35.2", "seq": 1, "text": "匈奴数岁无所得。", "len": 8}
{"sid": "081_廉颇蔺相如列传.35.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "35.3", "seq": 1, "text": "终以为怯。", "len": 5}
{"sid": "081_廉颇蔺相如列传.35.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "35.4", "seq": 1, "text": "边士日得赏赐而不用，皆原一战。", "len": 15}
{"sid": "081_廉颇蔺相如列传.35.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "35.5", "seq": 1, "text": "於是乃具选车得千三百乘，选骑得万三千匹，百金之士五万人，彀者十万人，悉勒习战。", "len": 39}
{"sid": "081_廉颇蔺相如列传.35.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "35.6", "seq": 1, "text": "大纵畜牧，人民满野。", "len": 10}
{"sid": "081_廉颇蔺相如列传.35.7.s1", "chapter": "081_廉颇蔺相如列传", "para": "35.7", "seq": 1, "text": "匈奴小入，详北不胜，以数千人委之。", "len": 17}
{"sid": "081_廉颇蔺相如列传.35.8.s1", "chapter": "081_廉颇蔺相如列传", "para": "35.8", "seq": 1, "text": "单于闻之，大率众来入。", "len": 11}
{"sid": "081_廉颇蔺相如列传.35.9.s1", "chapter": "081_廉颇蔺相如列传", "para": "35.9", "seq": 1, "text": "李牧多为奇陈，张左右翼击之，大破杀匈奴十馀万骑。", "len": 24}
{"sid": "081_廉颇蔺相如列传.35.10.s1", "chapter": "081_廉颇蔺相如列传", "para": "35.10", "seq": 1, "text": "灭襜褴，破东胡，降林胡，单于奔走。", "len": 17}
{"sid": "081_廉颇蔺相如列传.35.11.s1", "chapter": "081_廉颇蔺相如列传", "para": "35.11", "seq": 1, "text": "其後十馀岁，匈奴不敢近赵边城。", "len": 15}
{"sid": "081_廉颇蔺相如列传.36.s1", "chapter": "081_廉颇蔺相如列传", "para": "36", "seq": 1, "text": "赵悼襄王元年，廉颇既亡入魏，赵使李牧攻燕，拔武遂、方城。", "len": 28}
{"sid": "081_廉颇蔺相如列传.36.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "36.2", "seq": 1, "text": "居二年，庞暖破燕军，杀剧辛。", "len": 14}
{"sid": "081_廉颇蔺相如列传.36.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "36.3", "seq": 1, "text": "後七年，秦破杀赵将扈辄於武遂，斩首十万。", "len": 20}
{"sid": "081_廉颇蔺相如列传.36.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "36.4", "seq": 1, "text": "赵乃以李牧为大将军，击秦军於宜安，大破秦军，走秦将桓齮。", "len": 28}
{"sid": "081_廉颇蔺相如列传.36.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "36.5", "seq": 1, "text": "封李牧为武安君。", "len": 8}
{"sid": "081_廉颇蔺相如列传.36.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "36.6", "seq": 1, "text": "居三年，秦攻番吾，李牧击破秦军，南距韩、魏。", "len": 22}
{"sid": "081_廉颇蔺相如列传.37.s1", "chapter": "081_廉颇蔺相如列传", "para": "37", "seq": 1, "text": "赵王迁七年，秦使王翦攻赵，赵使李牧、司马尚御之。", "len": 24}
{"sid": "081_廉颇蔺相如列传.37.2.s1", "chapter": "081_廉颇蔺相如列传", "para": "37.2", "seq": 1, "text": "秦多与赵王宠臣郭开金，为反间，言李牧、司马尚欲反。", "len": 25}
{"sid": "081_廉颇蔺相如列传.37.3.s1", "chapter": "081_廉颇蔺相如列传", "para": "37.3", "seq": 1, "text": "赵王乃使赵葱及齐将颜聚代李牧。", "len": 15}
{"sid": "081_廉颇蔺相如列传.37.4.s1", "chapter": "081_廉颇蔺相如列传", "para": "37.4", "seq": 1, "text": "李牧不受命，赵使人微捕得李牧，斩之。", "len": 18}
{"sid": "081_廉颇蔺相如列传.37.5.s1", "chapter": "081_廉颇蔺相如列传", "para": "37.5", "seq": 1, "text": "废司马尚。", "len": 5}
{"sid": "081_廉颇蔺相如列传.37.6.s1", "chapter": "081_廉颇蔺相如列传", "para": "37.6", "seq": 1, "text": "後三月，王翦因急击赵，大破杀赵葱，虏赵王迁及其将颜聚，遂灭赵。", "len": 31}
{"sid": "081_廉颇蔺相如列传.37.6.s2", "chapter": "081_廉颇蔺相如列传", "para": "37.6", "seq": 2, "text": "::: 太史公曰", "len": 8}
{"sid": "081_廉颇蔺相如列传.38.s1", "chapter": "081_廉颇蔺相如列传", "para": "38", "seq": 1, "text": "太史公曰：知死必勇，非死者难也，处死者难。", "len": 21}
{"sid": "081_廉颇蔺相如列传.38.s2", "chapter": "081_廉颇蔺相如列传", "para": "38", "seq": 2, "text": "方蔺相如引璧睨柱，及叱秦王左右，势不过诛，然士或怯懦而不敢发。", "len": 31}
{"sid": "081_廉颇蔺相如列传.38.s3", "chapter": "081_廉颇蔺相如列传", "para": "38", "seq": 3, "text": "相如一奋其气，威信敌国，退而让颇，名重太山，其处智勇，可谓兼之矣！", "len": 33}
{"sid": "081_廉颇蔺相如列传.38.s4", "chapter": "081_廉颇蔺相如列传", "para": "38", "seq": 4, "text": "::: ::: 赞", "len": 9}
{"sid": "081_廉颇蔺相如列传.39.s1", "chapter": "081_廉颇蔺相如列传", "para": "39", "seq": 1, "text": "清梠凛凛，壮气熊熊。", "len": 10}
{"sid": "081_廉颇蔺相如列传.39.s2", "chapter": "081_廉颇蔺相如列传", "para": "39", "seq": 2, "text": "各竭诚义，递为雌雄。", "len": 10}
{"sid": "081_廉颇蔺相如列传.39.s3", "chapter": "081_廉颇蔺相如列传", "para": "39", "seq": 3, "text": "和璧聘返，渑池好通。", "len": 10}
{"sid": "081_廉颇蔺相如列传.39.s4", "chapter": "081_廉颇蔺相如列传", "para": "39", "seq": 4, "text": "负荆知惧，屈节推工。", "len": 10}
{"sid": "081_廉颇蔺相如列传.39.s5", "chapter": "081_廉颇蔺相如列传", "para": "39", "seq": 5, "text": "安边定策，颇、牧之功。", "len": 11}
{"sid": "081_廉颇蔺相如列传.39.s6", "chapter": "081_廉颇蔺相如列传", "para": "39", "seq": 6, "text": ":::", "len": 3}
