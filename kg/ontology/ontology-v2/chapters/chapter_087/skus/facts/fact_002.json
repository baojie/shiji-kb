      "category": "政治制度改革",
      "measures": [
        {
          "measure": "郡县制",
          "description": "夷郡县城，不立子弟为王，功臣为诸侯者，使后无战攻之患",
          "significance": "废除分封制，建立中央集权的郡县制度",
          "effect": "巩固中央集权，防止地方割据"
        },
        {
          "measure": "销兵刃",
          "description": "销其兵刃，示不复用",
          "significance": "收缴天下兵器，防止叛乱",
          "effect": "使秦无尺土之封"
        }
      ]
    },
    {
      "category": "思想文化控制",
      "measures": [
        {
          "measure": "焚书（始皇三十四年）",
          "background": "博士淳于越建议分封子弟功臣，李斯反对",
          "理论依据": "古者天下散乱，莫能相一，是以诸侯并作，语皆道古以害今，饰虚言以乱实",
          "具体措施": [
            "收去诗书百家之语以愚百姓",
            "使天下无以古非今",
            "保留：医药卜筮种树之书",
            "惩罚：令到满三十日弗去，黥为城旦",
            "教育：若有欲学者，以吏为师"
          ],
          "significance": "中国历史上最大规模的思想控制运动",
          "effect": "摧残文化，但也统一思想"
        }
      ]
    },
    {
      "category": "标准化改革",
      "measures": [
        {
          "measure": "同文书",
          "description": "统一文字",
          "significance": "消除各国文字差异，便于政令传达",
          "effect": "文化统一的基础"
        },
        {
          "measure": "明法度，定律令",
          "description": "皆以始皇起",
          "significance": "统一法律体系",
          "effect": "法律统一"
        }
      ]
    },
    {
      "category": "基础设施建设",
      "measures": [
