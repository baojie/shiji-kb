@prefix : <http://memect.cn/baojie/ontologies/2025/1/shiji/> .
@prefix bio: <http://memect.cn/baojie/ontologies/2025/1/shiji/biology/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Shiji Biology Taxonomy
# 388 species from Records of the Grand Historian
# Source: kg/biology/data/biology_wordlist.json
# Tag format: 〖+X〗

# -- Top level --

bio:生物 a owl:Class ;
    rdfs:label "生物"@zh, "Living Thing"@en .

# -- Level 1: Animal / Plant / Collective --

bio:动物 a owl:Class ;
    rdfs:subClassOf bio:生物 ;
    rdfs:label "动物"@zh, "Animal"@en .

bio:植物 a owl:Class ;
    rdfs:subClassOf bio:生物 ;
    rdfs:label "植物"@zh, "Plant"@en .

bio:生物集合 a owl:Class ;
    rdfs:subClassOf bio:生物 ;
    rdfs:label "生物集合"@zh, "Collective Term"@en ;
    rdfs:comment "Cross-category terms: 六畜, 五穀, 鸟兽"@en .

# -- Level 2: Animal subtypes --

bio:家畜 a owl:Class ;
    rdfs:subClassOf bio:动物 ;
    rdfs:label "家畜"@zh, "Domestic Animal"@en .

bio:野兽 a owl:Class ;
    rdfs:subClassOf bio:动物 ;
    rdfs:label "野兽"@zh, "Wild Beast"@en .

bio:鸟类 a owl:Class ;
    rdfs:subClassOf bio:动物 ;
    rdfs:label "鸟类"@zh, "Bird"@en .

bio:鱼类水族 a owl:Class ;
    rdfs:subClassOf bio:动物 ;
    rdfs:label "鱼类水族"@zh, "Fish and Aquatic"@en .

bio:虫类 a owl:Class ;
    rdfs:subClassOf bio:动物 ;
    rdfs:label "虫类"@zh, "Insect"@en .

bio:神话动物 a owl:Class ;
    rdfs:subClassOf bio:动物 ;
    rdfs:label "神话动物"@zh, "Mythical Animal"@en .

# -- Level 2: Plant subtypes --

bio:穀物 a owl:Class ;
    rdfs:subClassOf bio:植物 ;
    rdfs:label "穀物"@zh, "Grain"@en .

bio:树木 a owl:Class ;
    rdfs:subClassOf bio:植物 ;
    rdfs:label "树木"@zh, "Tree"@en .

bio:草本花卉 a owl:Class ;
    rdfs:subClassOf bio:植物 ;
    rdfs:label "草本花卉"@zh, "Herb and Flower"@en .

bio:果蔬 a owl:Class ;
    rdfs:subClassOf bio:植物 ;
    rdfs:label "果蔬"@zh, "Fruit and Vegetable"@en .

# -- Level 3: Domestic animal subtypes --

bio:马属 a owl:Class ;
    rdfs:subClassOf bio:家畜 ;
    rdfs:label "马属"@zh, "Equine"@en .

bio:牛属 a owl:Class ;
    rdfs:subClassOf bio:家畜 ;
    rdfs:label "牛属"@zh, "Bovine"@en .

bio:羊属 a owl:Class ;
    rdfs:subClassOf bio:家畜 ;
    rdfs:label "羊属"@zh, "Ovine"@en .

bio:犬属 a owl:Class ;
    rdfs:subClassOf bio:家畜 ;
    rdfs:label "犬属"@zh, "Canine"@en .

bio:禽属 a owl:Class ;
    rdfs:subClassOf bio:家畜 ;
    rdfs:label "禽属"@zh, "Poultry"@en .

bio:猪属 a owl:Class ;
    rdfs:subClassOf bio:家畜 ;
    rdfs:label "猪属"@zh, "Swine"@en .

# -- Instances: Domestic - Equine --

bio:马 a bio:马属 ; rdfs:label "马"@zh ; :count 102 .
bio:驹 a bio:马属 ; rdfs:label "驹"@zh ; :count 9 .
bio:骥 a bio:马属 ; rdfs:label "骥"@zh ; :count 5 .
bio:驴 a bio:马属 ; rdfs:label "驴"@zh ; :count 3 .
bio:骐骥 a bio:马属 ; rdfs:label "骐骥"@zh ; :count 3 .
bio:騊駼 a bio:马属 ; rdfs:label "騊駼"@zh ; :count 3 .
bio:騄耳 a bio:马属 ; rdfs:label "騄耳"@zh ; :count 3 .

# -- Instances: Domestic - Bovine / Ovine / Canine / Poultry / Swine --

bio:牛 a bio:牛属 ; rdfs:label "牛"@zh ; :count 36 .
