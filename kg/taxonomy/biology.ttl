bio:麋 a bio:野兽 ; rdfs:label "麋"@zh ; :count 4 .

# -- Instances: Bird --

bio:鸟 a bio:鸟类 ; rdfs:label "鸟"@zh ; :count 19 .
bio:雉 a bio:鸟类 ; rdfs:label "雉"@zh ; :count 6 .
bio:鸿鹄 a bio:鸟类 ; rdfs:label "鸿鹄"@zh ; :count 4 .

# -- Instances: Aquatic --

bio:鱼 a bio:鱼类水族 ; rdfs:label "鱼"@zh ; :count 33 .
bio:鳖 a bio:鱼类水族 ; rdfs:label "鳖"@zh ; :count 3 .
bio:鼋 a bio:鱼类水族 ; rdfs:label "鼋"@zh ; :count 2 .

# -- Instances: Insect --

bio:蝗 a bio:虫类 ; rdfs:label "蝗"@zh ; :count 3 .
