        {
          "公元前": "",
          "秦": "七月",
          "楚": "楚隐王陈涉起兵入秦。",
          "项": "",
          "赵": "",
          "齐": "",
          "汉": "",
          "燕": "",
          "魏": "",
          "韩": ""
        },
        {
          "公元前": "",
          "秦": "八月",
          "楚": "二。葛婴为涉徇九江，立襄彊为楚王。",
          "项": "",
          "赵": "武臣始至邯郸，自立为赵王，始。",
          "齐": "",
          "汉": "",
          "燕": "",
          "魏": "",
          "韩": ""
        },
        {
          "公元前": "",
          "秦": "九月。楚兵至戏。",
          "楚": "三。周文兵至戏，败。而葛婴闻涉王，即杀彊。",
          "项": "项梁号武信君。",
          "赵": "二",
          "齐": "齐王田儋始。儋，狄人。诸田宗彊。从弟荣，荣弟横。",
          "汉": "沛公初起。",
          "燕": "韩广为赵略地至蓟，自立为燕王始。",
          "魏": "魏王咎始。咎在陈，不得归国。",
          "韩": ""
        },
        {
          "公元前": "208",
          "秦": "二年十月",
          "楚": "四。诛葛婴。",
          "项": "二",
          "赵": "三",
          "齐": "二。儋之起，杀狄令自王。",
          "汉": "二。击胡陵、方与，破秦监军。",
          "燕": "二",
          "魏": "二",
          "韩": ""
        },
        {
          "公元前": "",
          "秦": "十一月",
          "楚": "五。周文死。",
          "项": "三",
          "赵": "四。李良杀武臣，张耳、陈余走。",
          "齐": "三",
          "汉": "三。杀泗水守。拔薛西。周市东略地丰沛闲。",
          "燕": "三",
          "魏": "三。齐、赵共立周市，市不肯，曰「必立魏咎」云。",
          "韩": ""
        },
        {
          "公元前": "",
          "秦": "十二月",
          "楚": "六。陈涉死。",
          "项": "四",
          "赵": "",
          "齐": "四",
          "汉": "四。雍齿叛沛公，以丰降魏。沛公还攻丰，不能下。",
          "燕": "四",
          "魏": "四。咎自陈归，立。",
          "韩": ""
        },
        {
          "公元前": "",
          "秦": "端月",
          "楚": "楚王景驹始，秦嘉立之。",
          "项": "五。涉将召平矫拜项梁为楚柱国，急西击秦。",
          "赵": "赵王歇始，张耳、陈余立之。",
          "齐": "五。让景驹以擅自王不请我。",
          "汉": "五。沛公闻景驹王在留，往从，与击秦军砀西。",
          "燕": "五",
          "魏": "五。章邯已破涉，围咎临济。",
          "韩": ""
        },
        {
          "公元前": "",
          "秦": "二月",
          "楚": "二。嘉为上将军。",
          "项": "六。梁渡江，陈婴、黥布皆属。",
          "赵": "二",
          "齐": "六。景驹使公孙庆让齐，诛庆。",
          "汉": "六。攻下砀，收得兵六千，与故凡九千人。",
          "燕": "六",
          "魏": "六",
          "韩": ""
        },
        {
          "公元前": "",
          "秦": "三月",
          "楚": "三",
          "项": "七",
          "赵": "三",
          "齐": "七",
          "汉": "七。攻拔下邑，遂击丰，丰不拔。闻项梁兵众，往请击丰。",
          "燕": "七",
          "魏": "七",
          "韩": ""
        },
        {
          "公元前": "",
          "秦": "四月",
          "楚": "四",
          "项": "八。梁击杀景驹、秦嘉，遂入薛，兵十余万众。",
          "赵": "四",
          "齐": "八",
          "汉": "八。沛公如薛见项梁，梁益沛公卒五千，击丰，拔之。雍齿奔魏。",
          "燕": "八",
          "魏": "八。临济急，周市如齐、楚请救。",
          "韩": ""
        },
        {
          "公元前": "",
          "秦": "五月",
          "楚": "",
          "项": "九",
          "赵": "五",
          "齐": "九",
          "汉": "九",
          "燕": "九",
          "魏": "九",
          "韩": ""
        },
        {
          "公元前": "",
          "秦": "六月",
          "楚": "楚怀王始，都盱台，故怀王孙，梁立之。",
          "项": "十。梁求楚怀王孙，得之民闲，立为楚王。",
          "赵": "六",
          "齐": "十。儋救临济，章邯杀田儋。荣走东阿。",
          "汉": "十。沛公如薛，共立楚怀王。",
          "燕": "十",
          "魏": "十。咎自杀，临济降秦。",
          "韩": "韩王成始。"
        },
        {
          "公元前": "",
          "秦": "七月",
          "楚": "二。陈婴为柱国。",
          "项": "十一。天大雨，三月不见星。",
          "赵": "七",
          "齐": "齐立田假为王，秦急围东阿。",
          "汉": "十一。沛公与项羽北救东阿，破秦军濮阳，东屠城阳。",
          "燕": "十一",
          "魏": "咎弟豹走东阿。",
          "韩": "二"
        },
        {
          "公元前": "",
          "秦": "八月",
          "楚": "三",
          "项": "十二。救东阿，破秦军，乘胜至定陶，项梁有骄色。",
          "赵": "八",
          "齐": "楚救荣，得解归，逐田假，立儋子市为齐王，始。",
          "汉": "十二。沛公与项羽西略地，斩三川守李由于雍丘。",
          "燕": "十二",
          "魏": "",
          "韩": "三"
        },
        {
          "公元前": "",
          "秦": "九月",
          "楚": "四。徙都彭城。",
          "项": "十三。章邯破杀项梁于定陶，项羽恐，还军彭城。",
          "赵": "九",
          "齐": "二。田假走楚，楚趋齐救赵。田荣以假故，不肯，谓「楚杀假乃出兵。」项羽怒田荣。",
          "汉": "十三。沛公闻项梁死，还军，从怀王，军于砀。",
          "燕": "十三",
          "魏": "魏豹自立为魏王，都平阳，始。",
          "韩": "四"
        },
        {
          "公元前": "",
          "秦": "后九月。",
          "楚": "五。拜宋义为上将军。",
          "项": "怀王封项羽于鲁，为次将，属宋义，北救赵。",
          "赵": "十。秦军围歇巨鹿，陈余出收兵。",
          "齐": "三",
          "汉": "十四。怀王封沛公为武安侯，将砀郡兵西，约先至咸阳王之。",
          "燕": "十四",
          "魏": "二",
          "韩": "五"
        },
        {
          "公元前": "207",
          "秦": "三年十月",
          "楚": "六",
          "项": "二",
          "赵": "十一。章邯破邯郸，徙其民于河内。",
          "齐": "四。齐将田都叛荣，往助项羽救赵。",
          "汉": "十五。攻破东郡尉及王离军于成武南。",
          "燕": "十五。使将臧荼救赵。",
          "魏": "三",
          "韩": "六"
        },
        {
          "公元前": "",
          "秦": "十一月",
          "楚": "七。拜籍上将军。",
          "项": "三。羽矫杀宋义，将其兵渡河救巨鹿。",
          "赵": "十二",
          "齐": "五",
          "汉": "十六",
          "燕": "十六",
          "魏": "四",
          "韩": "七"
        },
        {
          "公元前": "",
          "秦": "十二月",
          "楚": "八",
          "项": "四。大破秦军巨鹿下，诸侯将皆属项羽。",
          "赵": "十三。楚救至，秦围解。",
          "齐": "六。故齐王建孙田安下济北，从项羽救赵。",
          "汉": "十七。（救赵）至栗，得皇䜣、武蒲军。与秦军战，破之。",
          "燕": "十七",
          "魏": "五。豹救赵。",
          "韩": "八"
        },
        {
          "公元前": "",
          "秦": "端月",
          "楚": "九",
          "项": "五。虏秦将王离。",
          "赵": "十四。张耳怒陈余，弃将印去。",
          "齐": "七",
          "汉": "十八",
          "燕": "十八",
          "魏": "六",
          "韩": "九"
        },
        {
          "公元前": "",
          "秦": "二月",
          "楚": "十",
          "项": "六。攻破章邯，章邯军却。",
          "赵": "十五",
          "齐": "八",
          "汉": "十九。得彭越军昌邑，袭陈留。用郦食其策，军得积粟。",
          "燕": "十九",
          "魏": "七",
          "韩": "十"
        },
        {
          "公元前": "",
          "秦": "三月",
          "楚": "十一",
          "项": "七",
          "赵": "十六",
          "齐": "九",
          "汉": "二十。攻开封，破秦将杨熊，熊走荥阳，秦斩熊以徇。",
          "燕": "二十",
          "魏": "八",
          "韩": "十一"
        },
        {
          "公元前": "",
          "秦": "四月",
          "楚": "十二",
          "项": "八。楚急攻章邯，章邯恐，使长史欣归秦请兵，赵高让之。",
          "赵": "十七",
          "齐": "十",
          "汉": "二十一。攻颍阳，略韩地，北绝河津。",
          "燕": "二十一",
          "魏": "九",
          "韩": "十二"
        },
        {
          "公元前": "",
          "秦": "五月",
          "楚": "二年一月",
          "项": "九。赵高欲诛欣，欣恐，亡走，告章邯谋叛秦。",
          "赵": "十八",
          "齐": "十一",
          "汉": "二十二",
          "燕": "二十二",
          "魏": "十",
          "韩": "十三"
        },
        {
          "公元前": "",
          "秦": "六月",
          "楚": "二",
          "项": "十。章邯与楚约降，未定，项羽许而击之。",
          "赵": "十九",
          "齐": "十二",
          "汉": "二十三。攻南阳守𬺈，破之阳城郭东。",
          "燕": "二十三",
          "魏": "十一",
          "韩": "十四"
        },
        {
          "公元前": "",
          "秦": "七月",
          "楚": "三",
          "项": "十一。项羽与章邯期殷虚，章邯等已降，与盟，以邯为雍王。",
          "赵": "二十",
          "齐": "十三",
          "汉": "二十四。降下南阳，封其守𬺈。",
          "燕": "二十四",
          "魏": "十二",
          "韩": "十五。申阳下河南，降楚。"
        },
        {
          "公元前": "",
          "秦": "八月。赵高杀二世。",
          "楚": "四",
          "项": "十二。以秦降都尉翳、长史欣为上将，将秦降军。",
          "赵": "二十一。赵王歇留国。陈余亡居南皮。",
          "齐": "十四",
          "汉": "二十五。攻武关，破之。",
          "燕": "二十五",
          "魏": "十三",
          "韩": "十六"
        },
        {
          "公元前": "",
          "秦": "九月子婴为王。",
          "楚": "五",
          "项": "十三",
          "赵": "二十二",
          "齐": "十五",
          "汉": "二十六。攻下峣及蓝田。以留侯策，不战皆降。",
          "燕": "二十六",
          "魏": "十四",
          "韩": "十七"
        },
        {
          "公元前": "206",
          "秦": "十月",
          "楚": "六",
          "项": "十四。项羽将诸侯兵四十余万，行略地，西至于河南。",
          "赵": "二十三。张耳从楚西入秦。",
          "齐": "十六",
          "汉": "二十七。汉元年，秦王子婴降。沛公入破咸阳，平秦，还军霸上，待诸侯约。",
          "燕": "二十七",
          "魏": "十五。从项羽略地，遂入关",
          "韩": "十八"
        },
        {
          "公元前": "",
          "秦": "十一月",
          "楚": "七",
          "项": "十五。羽诈阬杀秦降卒二十万人于新安。",
          "赵": "二十四",
          "齐": "十七",
          "汉": "二十八。沛公出令三章，秦民大悦。",
          "燕": "二十八",
          "魏": "十六",
          "韩": "十九"
        },
        {
          "公元前": "",
          "秦": "十二月",
          "楚": "八。分楚为四。",
          "项": "十六。至关中，诛秦王子婴，屠烧咸阳。分天下，立诸侯。",
          "赵": "二十五。分赵为代国。",
          "齐": "十八。项羽怨荣，分齐为三国。",
          "汉": "二十九。与项羽有纳，见之戏下，讲解。羽倍约，分关中为四国。",
          "燕": "二十九。臧荼从入，分燕为二国。",
          "魏": "十七。分魏为殷国。",
          "韩": "二十。分韩为河南国。"
        }
      ]
    },
