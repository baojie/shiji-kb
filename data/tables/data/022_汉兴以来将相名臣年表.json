    },
    {
      "公元前": "133",
      "纪年": "二",
      "大事纪": "帝初之雍，郊见五畤。",
      "相位": "三",
      "将位": "夏，御史大夫韩安国为护军将军，卫尉李广为骁骑将军，太仆公孙贺为轻车将军，大行王恢为将屯将军，太中大夫李息为材官将军，篡单于马邑，不合，诛恢。",
      "御史大夫位": ""
    },
    {
      "公元前": "132",
      "纪年": "三",
      "大事纪": "五月丙子，河决于瓠子。",
      "相位": "四",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "131",
      "纪年": "四",
      "大事纪": "十二月丁亥，地动。蚡卒。",
      "相位": "五。平棘侯薛泽为丞相。",
      "将位": "",
      "御史大夫位": "御史大夫欧。"
    },
    {
      "公元前": "130",
      "纪年": "五",
      "大事纪": "十月，族灌夫家，弃魏其侯市。",
      "相位": "二",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "129",
      "纪年": "六",
      "大事纪": "南夷始置邮亭。",
      "相位": "三",
      "将位": "太中大夫卫青为车骑将军，出上谷；卫尉李广为骁骑将军，出鴈门；大中大夫公孙敖为骑将军，出代；太仆公孙贺为轻车将军，出云中：皆击匈奴。",
      "御史大夫位": ""
    },
    {
      "公元前": "128",
      "纪年": "元朔元年",
      "大事纪": "卫夫人立为皇后。",
      "相位": "四",
      "将位": "车骑将军青出雁门，击匈奴。卫尉韩安国为将屯将军，军代，明年，屯渔阳卒。",
      "御史大夫位": ""
    },
    {
      "公元前": "127",
      "纪年": "二",
      "大事纪": "",
      "相位": "五",
      "将位": "春，车骑将军卫青出云中，至高阙，取河南地。",
      "御史大夫位": ""
    },
    {
      "公元前": "126",
      "纪年": "三",
      "大事纪": "匈奴杀代太守友。",
      "相位": "六",
      "将位": "",
      "御史大夫位": "御史大夫弘。"
    },
    {
      "公元前": "125",
      "纪年": "四",
      "大事纪": "匈奴入定襄、代、上郡。",
      "相位": "七",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "124",
      "纪年": "五",
      "大事纪": "匈奴杀代都尉朱英。泽免相。",
      "相位": "八。十一月乙丑，御史大夫公孙弘为丞相，封平津侯。",
      "将位": "春，长平侯卫青为大将军，击右贤。卫尉苏建为游击将军，属青。左内史李沮为强弩将军，太仆贺为车骑将军，代相李蔡为轻车将军，岸头侯张次公为将军，大行息为将军：皆属大将军，击匈奴。",
      "御史大夫位": ""
    },
    {
      "公元前": "123",
      "纪年": "六",
      "大事纪": "",
      "相位": "二",
      "将位": "大将军青再出定襄击胡。合骑侯公孙敖为中将军，太仆贺为左将军，郎中令李广为后将军。翕侯赵信为前将军，败降匈奴。卫尉苏建为右将军，败，身脱。左内史沮为彊弩将军。皆属青。",
      "御史大夫位": ""
    },
    {
      "公元前": "122",
      "纪年": "元狩元年",
      "大事纪": "十月中，淮南王安、衡山王赐谋反，皆自杀，国除。",
