  },
  "rows": [
    {
      "公元前": "206",
      "纪年": "高皇帝元年",
      "大事纪": "春，沛公为汉王，之南郑。秋，还定雍。",
      "相位": "一。丞相萧何守汉中。",
      "将位": "",
      "御史大夫位": "御史大夫周苛守荥阳。"
    },
    {
      "公元前": "205",
      "纪年": "二",
      "大事纪": "春，定塞、翟、魏、河南、韩、殷国。夏，伐项籍，至彭城。立太子。还据荥阳。",
      "相位": "二。守关中。",
      "将位": "一。太尉长安侯卢绾。",
      "御史大夫位": ""
    },
    {
      "公元前": "204",
      "纪年": "三",
      "大事纪": "魏豹反。使韩信别定魏，伐赵。楚围我荥阳。",
      "相位": "三",
      "将位": "二",
      "御史大夫位": ""
    },
    {
      "公元前": "203",
      "纪年": "四",
      "大事纪": "使韩信别定齐及燕，太公自楚归，与楚界洪渠。",
      "相位": "四",
      "将位": "三。周苛守荥阳，死。",
      "御史大夫位": "御史大夫汾阴侯周昌。"
    },
    {
      "公元前": "202",
      "纪年": "五",
      "大事纪": "冬，破楚垓下，杀项籍。春，王践皇帝位定陶。。入都关中。",
      "相位": "五。罢太尉官。",
      "将位": "四。后九月，绾为燕王。",
      "御史大夫位": ""
    },
    {
      "公元前": "201",
      "纪年": "六",
      "大事纪": "尊太公为太上皇。刘仲为代王。立大市。更命咸阳曰长安。",
      "相位": "六。封为酂侯。。张苍为计相。",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "200",
      "纪年": "七",
      "大事纪": "长乐宫成，自栎阳徙长安。伐匈奴，匈奴围我平城。",
      "相位": "七",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "199",
      "纪年": "八",
      "大事纪": "击韩信反虏于赵城。贯高作乱，明年觉，诛之。匈奴攻代王，代王弃国亡，废为郃阳侯。",
      "相位": "八",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "198",
      "纪年": "九",
      "大事纪": "未央宫成，置酒前殿，太上皇辇上坐，帝奉玉卮上寿，曰：「始常以臣不如仲力，今臣功孰与仲多？」太上皇笑，殿上称万岁。徙齐田，楚昭、屈、景于关中。",
      "相位": "九。迁为相国。",
      "将位": "",
      "御史大夫位": "御史大夫昌为赵丞相。"
    },
    {
      "公元前": "197",
      "纪年": "十",
      "大事纪": "太上皇崩。陈豨反代地。",
      "相位": "十",
      "将位": "",
      "御史大夫位": "御史大夫江邑侯赵尧。"
    },
    {
      "公元前": "196",
      "纪年": "十一",
      "大事纪": "诛淮阴、彭越。黥布反。",
      "相位": "十一",
      "将位": "周勃为太尉。攻代。后官省。",
      "御史大夫位": ""
    },
    {
      "公元前": "195",
      "纪年": "十二",
      "大事纪": "冬，击布。还过沛。夏，上崩，葬长陵。",
      "相位": "十二",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "194",
      "纪年": "孝惠元年",
      "大事纪": "赵隐王如意死。始作长安城西北方。除诸侯丞相为相。",
      "相位": "十三",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "193",
      "纪年": "二",
      "大事纪": "楚元王、齐悼惠王来朝。七月辛未，何薨。",
      "相位": "十四。七月癸巳，齐相平阳侯曹参为相国。",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "192",
      "纪年": "三",
      "大事纪": "初作长安城。蜀湔氐反。击之。",
      "相位": "二",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "191",
      "纪年": "四",
      "大事纪": "三月甲子，赦，无所复作。",
      "相位": "三",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "190",
      "纪年": "五",
      "大事纪": "为高祖立庙于沛城成，置歌儿一百二十人。八月乙丑，参卒。",
      "相位": "四",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "189",
      "纪年": "六",
      "大事纪": "七月，齐悼惠王薨。立太仓、西市。",
      "相位": "一。十月己巳，安国侯王陵为右丞相。曲逆侯陈平为左丞相。",
      "将位": "尧抵罪。",
      "御史大夫位": "广阿侯任敖为御史大夫。"
    },
    {
      "公元前": "188",
      "纪年": "七",
      "大事纪": "上崩。大臣用张辟彊计，吕氏权重，以吕台为吕王。立少帝。九月辛巳，葬安陵。",
      "相位": "二",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "187",
      "纪年": "高后元年",
      "大事纪": "王孝惠诸子。置孝悌力田。",
      "相位": "三。十一月甲子，徙平为右丞相。辟阳侯审食其为左丞相。",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "186",
      "纪年": "二",
      "大事纪": "十二月，吕王台薨，子嘉代立为吕王。行八铢钱。",
      "相位": "四。平。二。食其。",
      "将位": "",
      "御史大夫位": "平阳侯曹窋为御史大夫。。"
    },
    {
      "公元前": "185",
      "纪年": "三",
      "大事纪": "",
      "相位": "五。三",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "184",
      "纪年": "四",
      "大事纪": "废少帝，更立常山王弘为帝。",
      "相位": "六。四。置太尉官。",
      "将位": "一。绛侯周勃为太尉。",
      "御史大夫位": ""
    },
    {
      "公元前": "183",
      "纪年": "五",
      "大事纪": "八月，淮阳王薨，以其弟壶关侯武为淮阳王。令戍卒岁更。",
      "相位": "七。五",
      "将位": "二",
      "御史大夫位": ""
    },
    {
      "公元前": "182",
      "纪年": "六",
      "大事纪": "以吕产为吕王。四月丁酉，赦天下。昼昏。",
      "相位": "八。六",
      "将位": "三",
      "御史大夫位": ""
    },
    {
      "公元前": "181",
      "纪年": "七",
      "大事纪": "赵王幽死，以吕禄为赵王。梁王徙赵，自杀。",
      "相位": "九。七",
      "将位": "四",
      "御史大夫位": ""
    },
    {
      "公元前": "180",
      "纪年": "八",
      "大事纪": "七月，高后崩。九月，诛诸吕。后九月，代王至，践皇帝位。后九月，食其免相。",
      "相位": "十。七月辛巳，为帝太傅。九月壬戌，复为丞相。八",
      "将位": "五。隆虑侯灶为将军，击南越。",
      "御史大夫位": "御史大夫苍。"
    },
    {
      "公元前": "179",
      "纪年": "孝文元年",
      "大事纪": "除收孥相坐律。立太子。赐民爵。",
      "相位": "十一。十一月辛巳，平徙为左丞相。太尉绛侯周勃为右丞相。",
      "将位": "六。勃为相，颍阴侯灌婴为太尉。",
      "御史大夫位": ""
    },
    {
      "公元前": "178",
      "纪年": "二",
      "大事纪": "除诽谤律。皇子武为代王，参为太原王，揖为梁王。十月，丞相平薨。",
      "相位": "一。十一月乙亥，绛侯勃复为丞相。",
      "将位": "一",
      "御史大夫位": ""
    },
    {
      "公元前": "177",
      "纪年": "三",
      "大事纪": "徙代王武为淮阳王。上幸太原。济北王反。匈奴大入上郡。以地尽与太原，太原更号代。十一月壬子，勃免相，之国。",
      "相位": "一。十二月乙亥，太尉颍阴侯灌婴为丞相。罢太尉官。",
      "将位": "二。棘蒲侯陈武为大将军，击济北。昌侯卢卿、共侯卢罢师、宁侯鸱、深泽侯将夜皆为将军，属武祁侯贺，将兵屯荥阳。",
      "御史大夫位": ""
    },
    {
      "公元前": "176",
      "纪年": "四",
      "大事纪": "十二月己巳，婴卒。",
      "相位": "一。正月甲午，御史大夫北平侯张苍为丞相。",
      "将位": "安丘侯张说为将军，击胡，出代。",
      "御史大夫位": "关中侯申屠嘉为御史大夫。"
    },
    {
      "公元前": "175",
      "纪年": "五",
      "大事纪": "除钱律，民得铸钱",
      "相位": "",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "174",
      "纪年": "六",
      "大事纪": "废淮南王，迁严道，道死雍。",
      "相位": "三",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "173",
      "纪年": "七",
      "大事纪": "四月丙子，初置南陵。",
      "相位": "四",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "172",
      "纪年": "八",
      "大事纪": "太仆汝阴侯滕公卒。",
      "相位": "五",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "171",
      "纪年": "九",
      "大事纪": "温室钟自鸣。以芷阳乡为霸陵。",
      "相位": "六",
      "将位": "",
      "御史大夫位": "御史大夫敬。"
    },
    {
      "公元前": "170",
      "纪年": "十",
      "大事纪": "诸侯王皆至长安。",
      "相位": "七",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "169",
      "纪年": "十一",
      "大事纪": "上幸代。地动。",
      "相位": "八",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "168",
      "纪年": "十二",
      "大事纪": "河决东郡金隄。徙淮阳王为梁王。",
      "相位": "九",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "167",
      "纪年": "十三",
      "大事纪": "除肉刑及田租税律、戍卒令。",
      "相位": "十",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "166",
      "纪年": "十四",
      "大事纪": "匈奴大入萧关，发兵击之，及屯长安旁。",
      "相位": "十一",
      "将位": "成侯董赤、内史栾布、昌侯卢卿、隆虑侯灶、宁侯鸱皆为将军，东阳侯张相如为大将军，皆击匈奴。中尉周舍、郎中令张武皆为将军，屯长安旁。",
      "御史大夫位": ""
    },
    {
      "公元前": "165",
      "纪年": "十五",
      "大事纪": "黄龙见成纪。上始郊见雍五帝。",
      "相位": "十二",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "164",
      "纪年": "十六",
      "大事纪": "上始郊见渭阳五帝。",
      "相位": "十三",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "163",
      "纪年": "后元年",
      "大事纪": "新垣平诈言方士，觉，诛之。",
      "相位": "十四",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "162",
      "纪年": "二",
      "大事纪": "匈奴和亲。地动。八月戊辰，苍免相。",
      "相位": "十五。八月庚午，御史大夫申屠嘉为丞相，封故安侯。",
      "将位": "",
      "御史大夫位": "御史大夫青。"
    },
    {
      "公元前": "161",
      "纪年": "三",
      "大事纪": "置谷口邑。",
      "相位": "二",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "160",
      "纪年": "四",
      "大事纪": "",
      "相位": "三",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "159",
      "纪年": "五",
      "大事纪": "上幸雍。",
      "相位": "四",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "158",
      "纪年": "六",
      "大事纪": "匈奴三万人入上郡，二万人入云中。",
      "相位": "五",
      "将位": "以中大夫令免为车骑将军，军飞狐，故楚相苏意为将军，军句注；。将军张武屯北地；河内守周亚夫为将军，军细柳；宗正刘礼军霸上；祝兹侯徐厉军棘门：以备胡。数月，胡去，亦罢。",
      "御史大夫位": ""
    },
    {
      "公元前": "157",
      "纪年": "七",
      "大事纪": "六月己亥，孝文皇帝崩。丁未，太子立。民出临三日，葬霸陵。",
      "相位": "六",
      "将位": "中尉亚夫为车骑将军，郎中令张武为复土将军，属国捍为将屯将军。詹事戎奴为车骑将军，侍太后。",
      "御史大夫位": ""
    },
    {
      "公元前": "156",
      "纪年": "孝景元年",
      "大事纪": "立孝文皇帝庙，郡国为太宗庙。",
      "相位": "七。置司徒官。",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "155",
      "纪年": "二",
      "大事纪": "立皇子德为河闲王，阏为临江王，余为淮阳王，非为汝南王，彭祖为广川王，发为长沙王。四月中，孝文太后崩。嘉卒。",
      "相位": "八。开封侯陶青为丞相。",
      "将位": "",
      "御史大夫位": "御史大夫错。"
    },
    {
      "公元前": "154",
      "纪年": "三",
      "大事纪": "吴楚七国反，发兵击，皆破之。皇子端为胶西王，胜为中山王。",
      "相位": "二。置太尉官。",
      "将位": "中尉条侯周亚夫。为太尉，击吴楚；曲周侯郦寄为将军，击赵；窦婴为大将军，屯荥阳，栾布为将军，击齐。",
      "御史大夫位": ""
    },
    {
      "公元前": "153",
      "纪年": "四",
      "大事纪": "立太子。",
      "相位": "三",
      "将位": "二。太尉亚夫。",
      "御史大夫位": "御史大夫蚡。"
    },
    {
      "公元前": "152",
      "纪年": "五",
      "大事纪": "置阳陵邑。丞相北平侯张苍卒。",
      "相位": "四",
      "将位": "三",
      "御史大夫位": ""
    },
    {
      "公元前": "151",
      "纪年": "六",
      "大事纪": "徙广川王彭祖为赵王。",
      "相位": "五",
      "将位": "四",
      "御史大夫位": "御史大夫阳陵侯岑迈。"
    },
    {
      "公元前": "150",
      "纪年": "七",
      "大事纪": "废太子荣为临江王。四月丁巳，胶东王立为太子。青罢相。",
      "相位": "六月乙巳，太尉条侯亚夫为丞相。罢太尉官。",
      "将位": "五。迁为丞相。",
      "御史大夫位": "御史大夫舍。"
    },
    {
      "公元前": "149",
      "纪年": "中元年",
      "大事纪": "",
      "相位": "二",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "148",
      "纪年": "二",
      "大事纪": "皇子越为广川王，寄为胶东王。",
      "相位": "三",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "147",
      "纪年": "三",
      "大事纪": "皇子乘为清河王。亚夫免相。",
      "相位": "四。御史大夫桃侯刘舍为丞相。",
      "将位": "",
      "御史大夫位": "御史大夫绾。"
    },
    {
      "公元前": "146",
      "纪年": "四",
      "大事纪": "临江王征，自杀，葬蓝田，燕数万为衔士置冢上。",
      "相位": "二",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "145",
      "纪年": "五",
      "大事纪": "皇子舜为常山王。",
      "相位": "三",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "144",
      "纪年": "六",
      "大事纪": "梁孝王武薨。分梁为五国，王诸子：子买为梁王，明为济川王，彭离为济东王，定为山阳王，不识为济阴王。",
      "相位": "四",
      "将位": "",
      "御史大夫位": ""
    },
    {
      "公元前": "143",
      "纪年": "后元年",
      "大事纪": "五月，地动。七月乙巳，日蚀。舍免相。",
      "相位": "五。八月壬辰，御史大夫建陵侯卫绾为丞相。",
      "将位": "",
      "御史大夫位": "御史大夫不疑。"
    },
    {
      "公元前": "142",
      "纪年": "二",
      "大事纪": "",
      "相位": "二",
      "将位": "六月丁丑，御史大夫岑迈卒。",
      "御史大夫位": ""
    },
    {
      "公元前": "141",
      "纪年": "三",
      "大事纪": "正月甲子，孝景皇帝崩。二月丙子，太子立。",
