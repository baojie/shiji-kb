    },
    {
      "公元前": "140",
      "纪年": "孝武建元元年",
      "大事纪": "绾免相。",
      "相位": "四。魏其侯窦婴为丞相。置太尉。",
      "将位": "武安侯田蚡为太尉。",
      "御史大夫位": "御史大夫抵。"
    },
    {
      "公元前": "139",
      "纪年": "二",
      "大事纪": "置茂陵。婴免相。",
