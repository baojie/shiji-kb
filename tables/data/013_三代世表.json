    {
      "section_title": "殷世系",
      "columns": [
        "帝王"
      ],
      "row_count": 29,
      "rows": [
        {
          "帝王": "帝外丙，汤太子。太丁蚤卒，故立次弟外丙。"
        },
        {
          "帝王": "帝仲壬，外丙弟。"
        },
        {
          "帝王": "帝太甲，故太子太丁子。淫，伊尹放之桐宫。三年，悔过自责，伊尹乃迎之复位。"
        },
        {
          "帝王": "帝沃丁。伊尹卒。"
        },
        {
          "帝王": "帝太庚，沃丁弟。"
        },
        {
          "帝王": "帝小甲，太庚弟。殷道衰，诸侯或不至。"
        },
        {
          "帝王": "帝雍己，小甲弟。"
        },
        {
          "帝王": "帝太戊，雍己弟。以桑穀生，称中宗。"
        },
        {
          "帝王": "帝中丁"
        },
        {
          "帝王": "帝外壬，中丁弟。"
        },
        {
          "帝王": "帝河亶甲，外壬弟。"
        },
        {
          "帝王": "帝祖乙"
        },
        {
          "帝王": "帝祖辛"
        },
        {
          "帝王": "帝沃甲，祖辛弟。"
        },
        {
          "帝王": "帝祖丁，祖辛子。"
        },
        {
          "帝王": "帝南庚，沃甲子。"
        },
        {
          "帝王": "帝阳甲，祖丁子。"
        },
        {
          "帝王": "帝盘庚，阳甲弟。徙河南。"
        },
        {
          "帝王": "帝小辛，盘庚弟。"
        },
        {
          "帝王": "帝小乙，小辛弟。"
        },
        {
          "帝王": "帝武丁。雉升鼎耳雊。得傅说。称高宗。"
        },
        {
          "帝王": "帝祖庚"
        },
        {
          "帝王": "帝甲，祖庚弟。淫。"
        },
        {
          "帝王": "帝廪辛"
        },
        {
          "帝王": "帝庚丁，廪辛弟。殷徙河北。"
        },
        {
          "帝王": "帝武乙。慢神震死。"
        },
        {
          "帝王": "帝太丁"
        },
        {
          "帝王": "帝乙。殷益衰。"
        },
        {
          "帝王": "帝辛，是为纣。弑。"
        }
      ]
    },
