        {
          "帝王世国号": "黄帝号有熊。",
          "颛顼属": "黄帝生昌意。",
          "俈属": "黄帝生玄嚣。",
          "尧属": "黄帝生玄嚣。",
          "舜属": "黄帝生昌意。",
          "夏属": "黄帝生昌意。",
          "殷属": "黄帝生玄嚣。",
          "周属": "黄帝生玄嚣。"
        },
        {
          "帝王世国号": "帝颛顼，黄帝孙。起黄帝，至颛顼三世，号高阳。",
          "颛顼属": "昌意生颛顼。为高阳氏。",
          "俈属": "玄嚣生蟜极。",
          "尧属": "玄嚣生蟜极。",
          "舜属": "昌意生颛顼。颛顼生穷蝉。",
          "夏属": "昌意生颛顼。",
          "殷属": "玄嚣生蟜极。蟜极生高辛。",
          "周属": "玄嚣生蟜极。蟜极生高辛。"
        },
        {
          "帝王世国号": "帝俈，黄帝曾孙。起黄帝，至帝俈四世。号高辛。",
          "颛顼属": "",
          "俈属": "蟜极生高辛，为帝俈。",
          "尧属": "蟜极生高辛。高辛生放勋。",
          "舜属": "穷蝉生敬康。敬康生句望。",
          "夏属": "",
          "殷属": "高辛生禼，为殷祖。",
          "周属": "高辛生后稷，为周祖。"
        },
        {
          "帝王世国号": "帝尧。起黄帝，至俈子五世。号唐。",
          "颛顼属": "",
          "俈属": "",
          "尧属": "放勋为尧。",
          "舜属": "句望生蟜牛。蟜牛生瞽叟。",
          "夏属": "",
          "殷属": "禼生昭明。",
          "周属": "后稷生不窋。"
        },
        {
          "帝王世国号": "帝舜，黄帝玄孙之玄孙，号虞。",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "瞽叟生重华，是为帝舜。",
          "夏属": "颛顼生鲧。鲧生文命。",
          "殷属": "昭明生相土。",
          "周属": "不窋生鞠。"
        },
        {
          "帝王世国号": "帝禹，黄帝耳孙，号夏。",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "文命，是为禹。",
          "殷属": "相土生昌若。",
          "周属": "鞠生公刘。"
        },
        {
          "帝王世国号": "帝启，伐有扈，作甘誓。",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "昌若生曹圉。",
          "周属": "公刘生庆节。"
        },
        {
          "帝王世国号": "帝太康",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "曹圉生冥。",
          "周属": "庆节生皇仆。"
        },
        {
          "帝王世国号": "帝仲康，太康弟。",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "冥生振。",
          "周属": "皇仆生差弗。"
        },
        {
          "帝王世国号": "帝相",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "振生微。",
          "周属": "差弗生毁渝。"
        },
        {
          "帝王世国号": "帝少康",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "微生报丁。",
          "周属": "毁渝生公非。"
        },
        {
          "帝王世国号": "帝予",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "报丁生报乙。",
          "周属": "公非生高圉。"
        },
        {
          "帝王世国号": "帝槐",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "报乙生报丙。",
          "周属": "高圉生亚圉。"
        },
        {
          "帝王世国号": "帝芒",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "报丙生主壬。",
          "周属": "亚圉生公祖类。"
        },
        {
          "帝王世国号": "帝泄",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "主壬生主癸。",
          "周属": "公祖类生太王亶父。"
        },
        {
          "帝王世国号": "帝不降",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "主癸生天乙，是为殷汤。",
          "周属": "亶父生季历。"
        },
        {
          "帝王世国号": "帝扃，不降弟。",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "",
          "周属": "季历生文王昌。益易卦。"
        },
        {
          "帝王世国号": "帝廑",
          "颛顼属": "",
          "俈属": "",
          "尧属": "",
          "舜属": "",
          "夏属": "",
          "殷属": "",
          "周属": "文王昌生武王发。"
        },
        {
          "帝王世国号": "帝孔甲，不降子。好鬼神，淫乱不好德，二龙去。",
