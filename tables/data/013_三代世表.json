          "周": "成王诵",
          "鲁": "鲁周公旦，武王弟。初封。",
          "齐": "齐太公尚，文王、武王师。初封。",
          "晋": "晋唐叔虞，武王子。初封。",
          "秦": "秦恶来，助纣。父飞廉，有力。",
          "楚": "楚熊绎。绎父鬻熊，事文王。初封。",
          "宋": "宋微子启，纣庶兄。初封。",
          "卫": "卫康叔，武王弟。初封。",
          "陈": "陈胡公满，舜之后。初封。",
          "蔡": "蔡叔度，武王弟。初封。",
          "曹": "曹叔振铎，武王弟。初封。",
          "燕": "燕召公奭，周同姓。初封。"
        },
        {
          "周": "康王钊，刑错四十余年。",
          "鲁": "鲁公伯禽",
          "齐": "丁公吕伋",
          "晋": "晋侯燮",
          "秦": "女防",
          "楚": "熊乂",
          "宋": "微仲，启弟。",
          "卫": "康伯",
          "陈": "申公",
          "蔡": "蔡仲",
          "曹": "",
          "燕": "九世至惠侯。"
        },
        {
          "周": "昭王瑕，南巡不返。不赴，讳之。",
